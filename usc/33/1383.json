{"tag":"section","attrib":{"id":"id6c0375d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383"},"text":null,"children":[{"tag":"num","attrib":{"value":"1383"},"text":"§ 1383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water pollution control revolving loan funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0375d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for obligation of grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before a State may receive a capitalization grant with funds made available under this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1285/m"},"text":"section 1285(m) of this title","children":[],"tail":", the State shall first establish a water pollution control revolving fund which complies with the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0375d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State water pollution control revolving fund shall be administered by an instrumentality of the State with such powers and limitations as may be required to operate such fund in accordance with the requirements and objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0375d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects and activities eligible for assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts of funds available to each State water pollution control revolving fund shall be used only for providing financial assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0375da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any municipality or intermunicipal, interstate, or State agency for construction of publicly owned treatment works (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1292"},"text":"section 1292 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the implementation of a management program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1329"},"text":"section 1329 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for development and implementation of a conservation and management plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the construction, repair, or replacement of decentralized wastewater treatment systems that treat municipal wastewater or domestic sewage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for measures to manage, reduce, treat, or recapture stormwater or subsurface drainage water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any municipality or intermunicipal, interstate, or State agency for measures to reduce the demand for publicly owned treatment works capacity through water conservation, efficiency, or reuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the development and implementation of watershed projects meeting the criteria set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1274"},"text":"section 1274 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any municipality or intermunicipal, interstate, or State agency for measures to reduce the energy consumption needs for publicly owned treatment works;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for reusing or recycling wastewater, stormwater, or subsurface drainage water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for measures to increase the security of publicly owned treatment works;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to any qualified nonprofit entity, as determined by the Administrator, to provide assistance to owners and operators of small and medium publicly owned treatment works—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0375e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to plan, develop, and obtain financing for eligible projects under this subsection, including planning, design, and associated preconstruction activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0375e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist such treatment works in achieving compliance with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to any qualified nonprofit entity, as determined by the Administrator, to provide assistance to an eligible individual (as defined in subsection (j))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0375e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the repair or replacement of existing individual household decentralized wastewater treatment systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0375e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/c/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which an eligible individual resides in a household that could be cost-effectively connected to an available publicly owned treatment works, for the connection of the applicable household to such treatment works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0375ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise limited by State law and provided in subsection (k), a water pollution control revolving fund of a State under this section may be used only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0375eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to make loans, on the condition that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0375ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such loans are made at or below market interest rates, including interest free loans, at terms not to exceed the lesser of 30 years and the projected useful life (as determined by the State) of the project to be financed with the proceeds of the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0375ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual principal and interest payments will commence not later than 1 year after completion of any project and all loans will be fully amortized upon the expiration of the term of the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0375ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient of a loan will establish a dedicated source of revenue for repayment of loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0375ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fund will be credited with all payments of principal and interest on all loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0375f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a treatment works proposed for repair, replacement, or expansion, and eligible for assistance under subsection (c)(1), the recipient of a loan shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c0375f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and implement a fiscal sustainability plan that includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c0375f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inventory of critical assets that are a part of the treatment works;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c0375f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the condition and performance of inventoried assets or asset groupings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c0375f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/E/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the recipient has evaluated and will be implementing water and energy conservation efforts as part of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c0375f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/E/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for maintaining, repairing, and, as necessary, replacing the treatment works and a plan for funding such activities; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c0375f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the recipient has developed and implemented a plan that meets the requirements under clause (i);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to buy or refinance the debt obligation of municipalities and intermunicipal and interstate agencies within the State at or below market rates, where such debt obligations were incurred after ","children":[{"tag":"date","attrib":{"date":"1985-03-07"},"text":"March 7, 1985","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to guarantee, or purchase insurance for, local obligations where such action would improve credit market access or reduce interest rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a source of revenue or security for the payment of principal and interest on revenue or general obligation bonds issued by the State if the proceeds of the sale of such bonds will be deposited in the fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide loan guarantees for similar revolving funds established by municipalities or intermunicipal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to earn interest on fund accounts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the reasonable costs of administering the fund and conducting activities under this subchapter, except that such amounts shall not exceed 4 percent of all grant awards to such fund under this subchapter, $400,000 per year, or ⅕ percent per year of the current valuation of the fund, whichever amount is greatest, plus the amount of any fees collected by the State for such purpose regardless of the source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0375fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation to prevent double benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State makes, from its water pollution revolving fund, a loan which will finance the cost of facility planning and the preparation of plans, specifications, and estimates for construction of publicly owned treatment works, the State shall ensure that if the recipient of such loan receives a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1281/g"},"text":"section 1281(g) of this title","children":[],"tail":" for construction of such treatment works and an allowance under section 1281("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1) of this title for non-Federal funds expended for such planning and preparation, such recipient will promptly repay such loan to the extent of such allowance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e5fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with planning requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may provide financial assistance from its water pollution control revolving fund only with respect to a project which is consistent with plans, if any, developed under sections 1285(j), 1288, 1313(e), 1329, and 1330 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e5ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority list requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State may provide financial assistance from its water pollution control revolving fund only with respect to a project for construction of a treatment works described in subsection (c)(1) if such project is on the State’s priority list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1296"},"text":"section 1296 of this title","children":[],"tail":". Such assistance may be provided regardless of the rank of such project on such list."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e600-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of non-Federal share of construction grant projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State water pollution control revolving fund may provide assistance (other than under subsection (d)(1) of this section) to a municipality or intermunicipal or interstate agency with respect to the non-Federal share of the costs of a treatment works project for which such municipality or agency is receiving assistance from the Administrator under any other authority only if such assistance is necessary to allow such project to proceed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e601-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional subsidization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c05e602-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which a State provides assistance to an eligible recipient under subsection (d), the State may provide additional subsidization (including forgiveness of principal, grants, negative interest loans, other loan forgiveness, and through buying, refinancing, or restructuring debt)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c05e603-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in assistance to a municipality or intermunicipal, interstate, or State agency to benefit a municipality that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c05e604-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the affordability criteria of the State established under paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c05e605-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not meet the affordability criteria of the State if the recipient—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c05e606-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeks additional subsidization to benefit individual ratepayers in the residential user rate class;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c05e607-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the State that such ratepayers will experience a significant hardship from the increase in rates necessary to finance the project or activity for which assistance is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c05e608-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures, as part of an assistance agreement between the State and the recipient, that the additional subsidization provided under this paragraph is directed through a user charge rate system (or other appropriate method) to such ratepayers; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c05e609-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to implement a process, material, technique, or technology—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c05e60a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address water-efficiency goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c05e60b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address energy-efficiency goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c05e60c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mitigate stormwater runoff; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c05e60d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage sustainable project planning, design, and construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c05e60e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affordability criteria","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c05e60f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c05e610-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2015-09-30"},"text":"September 30, 2015","children":[],"tail":", and after providing notice and an opportunity for public comment, a State shall establish affordability criteria to assist in identifying municipalities that would experience a significant hardship raising the revenue necessary to finance a project or activity eligible for assistance under subsection (c)(1) if additional subsidization is not provided."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c05e611-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria under clause (i) shall be based on income and unemployment data, population trends, and other data determined relevant by the State, including whether the project or activity is to be carried out in an economically distressed area, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161"},"text":"section 3161 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c05e612-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State has previously established, after providing notice and an opportunity for public comment, affordability criteria that meet the requirements of subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c05e613-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State may use the criteria for the purposes of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c05e614-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those criteria shall be treated as affordability criteria established under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c05e615-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to assist States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may publish information to assist States in establishing affordability criteria under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c05e616-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c05e617-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may provide additional subsidization in a fiscal year under this subsection only if the total amount appropriated for making capitalization grants to all States under this subchapter for the fiscal year exceeds $1,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c05e618-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total amount of subsidization","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c05e619-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, of the amount of the capitalization grant received by the State under this subchapter, the total amount of additional subsidization made available by a State under paragraph (1)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c05e61a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed 30 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c05e61b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that there are sufficient applications for assistance to communities described in that paragraph, may not be less than 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c05e61c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan from the water pollution control revolving fund of a State with an interest rate equal to or greater than 0 percent shall not be considered additional subsidization for purposes of this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c05e61d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of a State to provide additional subsidization under this subsection shall apply to amounts received by the State in capitalization grants under this subchapter for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c05e61e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/i/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State provides additional subsidization to a municipality or intermunicipal, interstate, or State agency under this subsection that meets the criteria under paragraph (1)(A), the State shall take the criteria set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1382/b/5"},"text":"section 1382(b)(5) of this title","children":[],"tail":" into consideration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e61f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In subsection (c)(12), the term “eligible individual” means a member of a household, the members of which have a combined income (for the most recent 12-month period for which information is available) equal to not more than 50 percent of the median nonmetropolitan household income for the State in which the household is located, according to the most recent decennial census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e620-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1383/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use an additional 2 percent of the funds annually awarded to each State under this subchapter for nonprofit organizations (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1254/w"},"text":"section 1254(w) of this title","children":[],"tail":") or State, regional, interstate, or municipal entities to provide technical assistance to rural, small, and tribal publicly owned treatment works (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1254/b/8/B"},"text":"section 1254(b)(8)(B) of this title","children":[],"tail":") in the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c05e621-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title VI, § 603, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/4/tII/s212/a"},"text":"Pub. L. 100–4, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/23"},"text":"101 Stat. 23","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5003"},"text":"Pub. L. 113–121, title V, § 5003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1323"},"text":"128 Stat. 1323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5012"},"text":"Pub. L. 114–322, title IV, § 5012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1902"},"text":"130 Stat. 1902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4107/a"},"text":"Pub. L. 115–270, title IV, § 4107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3876"},"text":"132 Stat. 3876","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50210/a/1"},"text":"Pub. L. 117–58, div. E, title II, § 50210(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1169"},"text":"135 Stat. 1169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c05e622-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c05e623-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c05e624-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50210/a/1/A"},"text":"Pub. L. 117–58, § 50210(a)(1)(A)","children":[],"tail":", inserted “and provided in subsection (k)” after “State law” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50210/a/1/B/i"},"text":"Pub. L. 117–58, § 50210(a)(1)(B)(i)","children":[],"tail":", substituted “(including forgiveness of principal, grants, negative interest loans, other loan forgiveness, and through buying, refinancing, or restructuring debt)” for “, including forgiveness of principal and negative interest loans” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50210/a/1/B/ii"},"text":"Pub. L. 117–58, § 50210(a)(1)(B)(ii)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which made an additional limitation on additional subsidization under subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50210/a/1/C"},"text":"Pub. L. 117–58, § 50210(a)(1)(C)","children":[],"tail":", added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4107/a/1"},"text":"Pub. L. 115–270, § 4107(a)(1)","children":[],"tail":", added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4107/a/2"},"text":"Pub. L. 115–270, § 4107(a)(2)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5012/1"},"text":"Pub. L. 114–322, § 5012(1)","children":[],"tail":", substituted “to an eligible recipient” for “to a municipality or intermunicipal, interstate, or State agency” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5012/2"},"text":"Pub. L. 114–322, § 5012(2)","children":[],"tail":", inserted “in assistance to a municipality or intermunicipal, interstate, or State agency” before “to benefit” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5003/1"},"text":"Pub. L. 113–121, § 5003(1)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “The amounts of funds available to each State water pollution control revolving fund shall be used only for providing financial assistance (1) to any municipality, intermunicipal, interstate, or State agency for construction of publicly owned treatment works (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1292"},"text":"section 1292 of this title","children":[],"tail":"), (2) for the implementation of a management program established under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1329"},"text":"section 1329 of this title","children":[],"tail":", and (3) for development and implementation of a conservation and management plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":". The fund shall be established, maintained, and credited with repayments, and the fund balance shall be available in perpetuity for providing such financial assistance.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5003/2/A/i"},"text":"Pub. L. 113–121, § 5003(2)(A)(i)","children":[],"tail":", substituted “the lesser of 30 years and the projected useful life (as determined by the State) of the project to be financed with the proceeds of the loan” for “20 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5003/2/A/ii"},"text":"Pub. L. 113–121, § 5003(2)(A)(ii)","children":[],"tail":", substituted “upon the expiration of the term of the loan” for “not later than 20 years after project completion”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5003/2/A/iii"},"text":"Pub. L. 113–121, § 5003(2)(A)(iii)","children":[],"tail":"–(v), added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5003/2/B"},"text":"Pub. L. 113–121, § 5003(2)(B)","children":[],"tail":", inserted “, $400,000 per year, or ⅕ percent per year of the current valuation of the fund, whichever amount is greatest, plus the amount of any fees collected by the State for such purpose regardless of the source” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5003/3"},"text":"Pub. L. 113–121, § 5003(3)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c05e625-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c05e626-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2014-10-01"},"text":"Oct. 1, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5006"},"text":"section 5006 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
