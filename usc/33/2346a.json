{"tag":"section","attrib":{"id":"id6c5e19a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2346a"},"text":"§ 2346a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real estate administrative fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5e19a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":", the Secretary shall initiate the development of guidance to standardize processes for developing, updating, and tracking real estate administrative fees administered by the Corps of Engineers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e19a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing guidance under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e19a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline standard methodologies to estimate costs for purposes of setting real estate administrative fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e19a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define the types of activities involved in managing real estate instruments that are included for purposes of setting such fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e19a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish cost-tracking procedures to capture data relating to the activities described in paragraph (2) for purposes of setting such fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e19aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline a schedule for divisions or districts of the Corps of Engineers to review, and update as appropriate, real estate administrative fees, including specifying what such reviews should entail and the frequency of such reviews; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6089ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for stakeholder input on real estate administrative fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6089ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly available","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make publicly available on the website of each Corps of Engineers district—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6089ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidance developed under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6089ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2346a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information on real estate administrative fees, including lists of real estate instruments requiring such fees, and methodologies used to set such fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c6089af-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1120"},"text":"Pub. L. 118–272, div. A, title I, § 1120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3014"},"text":"138 Stat. 3014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c6089b0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c6089b1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c6089b2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2024, and also as part of the Thomas R. Carper Water Resources Development Act of 2024, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c6089b3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c6089b4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1002"},"text":"section 1002 of Pub. L. 118–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
