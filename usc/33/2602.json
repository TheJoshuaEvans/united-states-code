{"tag":"section","attrib":{"id":"id6c654412-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602"},"text":null,"children":[{"tag":"num","attrib":{"value":"2602"},"text":"§ 2602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel permits and numbers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c654413-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel (except a public vessel as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of title 46","children":[],"tail":") may not transport municipal or commercial waste in coastal waters without—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c654414-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a permit for that vessel from the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654415-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" displaying a number or other marking on the vessel as prescribed by the Secretary under chapter 123 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12502/b"},"text":"section 12502(b) of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654416-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Application for a permit required by subsection (a) of this section shall be made by the vessel owner or operator and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c654417-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and telephone number of the vessel owner and operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654418-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel’s name and identification number;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654419-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel’s area of operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65441a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel’s transport capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65441b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a history of the types of cargo transported by that vessel during the previous year, including identifying the type of municipal or commercial waste transported as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c65441c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" municipal waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c65441d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c65441e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical waste; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c65441f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waste of another character.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654420-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654421-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an acknowledgment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654422-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of permits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A permit issued under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c654423-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is effective 30 days after the date on which it was issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654424-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be issued only for a period of not more than 5 years after the effective date of the permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654425-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be renewed for periods of not more than 5 years only by the vessel owner or operator that applied for the original permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654426-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is terminated when the vessel is sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654427-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of permits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, or at the request of the Administrator shall, deny the issuance of a permit for any vessel if the owner or operator of the vessel has a record of a pattern of serious violations of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c654428-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654429-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65442a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Marine Protection, Research, and Sanctuaries Act of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1431"},"text":"16 U.S.C. 1431","children":[],"tail":" et seq., 1447 et seq.; "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1401"},"text":"33 U.S.C. 1401","children":[],"tail":" et seq., 2801 et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65442b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rivers and Harbors Appropriation Act of 1899 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"33 U.S.C. 401","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65442c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65442d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, after consultation with the Administrator, shall issue or deny a vessel permit under this section within 30 days after receiving a complete application. On denying the issuance of the permit for a vessel the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c65442e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the applicant of the denial and the reasons for the denial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65442f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for a hearing on the denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654430-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintaining permit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c654431-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The permit issued for a vessel under this chapter shall be maintained in a manner prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654432-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endorsements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a vessel is a documented vessel, the Secretary may endorse a permit on the vessel’s certificate of documentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654433-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2602/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel information system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may include information in a permit in the vessel information system maintained under chapter 125 of title 46.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c654434-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4102"},"text":"Pub. L. 100–688, title IV, § 4102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4155"},"text":"102 Stat. 4155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c654435-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c654436-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c654437-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Solid Waste Disposal Act, referred to in subsec. (d)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272"},"text":"Pub. L. 89–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/997"},"text":"79 Stat. 997","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2795"},"text":"90 Stat. 2795","children":[],"tail":", which is classified generally to chapter 82 (§ 6901 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"section 6901 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Marine Protection, Research, and Sanctuaries Act of 1972, referred to in subsec. (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532"},"text":"Pub. L. 92–532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1052"},"text":"86 Stat. 1052","children":[],"tail":", which is classified generally to chapters 27 (§ 1401 et seq.) and 41 (§ 2801 et seq.) of this title and chapters 32 (§ 1431 et seq.) and 32A (§ 1447 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1401"},"text":"section 1401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rivers and Harbors Appropriation Act of 1899, referred to in subsec. (d)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch425"},"text":"act Mar. 3, 1899, ch. 425","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1151"},"text":"30 Stat. 1151","children":[],"tail":", which enacted sections 401, 403, 404, 406 to 409, 411 to 416, 418, 502, 549, 686, and 687 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (d)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c654438-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6c654439-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4204/b"},"text":"Pub. L. 100–688, title IV, § 4204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4160"},"text":"102 Stat. 4160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/688/tIV/s4204/b"},"text":"“Section 4102(a) of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2602/a"},"text":"33 U.S.C. 2602(a)","children":[],"tail":"] is effective 240 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c65443a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Applications","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4204/a"},"text":"Pub. L. 100–688, title IV, § 4204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4160"},"text":"102 Stat. 4160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/688/tIV/s4204/a"},"text":"“The Secretary shall make vessel applications for permits to be issued under section 4102 of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2602"},"text":"33 U.S.C. 2602","children":[],"tail":"] publicly available within 60 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
