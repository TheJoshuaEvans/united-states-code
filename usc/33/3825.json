{"tag":"section","attrib":{"id":"id6c8dda95-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3825"},"text":null,"children":[{"tag":"num","attrib":{"value":"3825"},"text":"§ 3825.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific and technical research and monitoring; communication and information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, the Administrator, and the Administrator of the National Oceanic and Atmospheric Administration may each undertake scientific and technical research and monitoring pursuant to article 8 of the Convention and to promote the availability of relevant information concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8dda96-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3825/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific and technical activities undertaken in accordance with the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8dda97-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3825/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine scientific and technological programs and their objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8dda98-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3825/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects observed from any monitoring and assessment programs relating to antifouling systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8dda99-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1025"},"text":"Pub. L. 111–281, title X, § 1025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3027"},"text":"124 Stat. 3027","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
