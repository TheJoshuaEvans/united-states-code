{"tag":"section","attrib":{"id":"id6b283042-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g"},"text":null,"children":[{"tag":"num","attrib":{"value":"426g"},"text":"§ 426g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storm and hurricane restoration and impact minimization program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b283043-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of small shore and beach restoration and protection projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b283044-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out a program for the construction of small shore and beach restoration and protection projects not specifically authorized by Congress that otherwise comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426e"},"text":"section 426e of this title","children":[],"tail":" if the Secretary determines that such construction is advisable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b283045-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local cooperation requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426e"},"text":"section 426e of this title","children":[],"tail":" shall apply to a project under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b283046-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completeness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b283047-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be complete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283048-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not commit the United States to any additional improvement to ensure the successful operation of the project; except for participation in periodic beach nourishment in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b283049-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426e"},"text":"section 426e of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b28304a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedure for projects authorized after submission of a survey report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b28304b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National shoreline erosion control development and demonstration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b28304c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct under the program authorized by subsection (a) a national shoreline erosion control development and demonstration program (referred to in this section as the “demonstration program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b28304d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b28304e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The demonstration program shall include provisions for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b28304f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects consisting of planning, design, construction, and monitoring of prototype engineered and native and naturalized vegetative shoreline erosion control devices and methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283050-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring of the applicable prototypes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283051-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed engineering and environmental reports on the results of each project carried out under the demonstraton ","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “demonstration”."}],"tail":" program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283052-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology transfers, as appropriate, to private property owners, State and local entities, nonprofit educational institutions, and nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283053-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of feasibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under the demonstration program shall not be carried out until the Secretary determines that the project is feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283054-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project under the demonstration program shall emphasize, to the maximum extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b283055-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and demonstration of innovative technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283056-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficient designs to prevent erosion at a shoreline site, taking into account the lifecycle cost of the design, including cleanup, maintenance, and amortization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283057-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new and enhanced shore protection project design and project formulation tools the purposes of which are to improve the physical performance, and lower the lifecycle costs, of the projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283058-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural designs, including the use of native and naturalized vegetation or temporary structures that minimize permanent structural alterations to the shoreline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283059-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the avoidance of negative impacts to adjacent shorefront communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b28305a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in areas with substantial residential or commercial interests located adjacent to the shoreline, designs that do not impair the aesthetic appeal of the interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b28305b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for long-term protection afforded by the technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b28305c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations developed from evaluations of the program established under the Shoreline Erosion Control Demonstration Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962–5"},"text":"42 U.S.C. 1962–5","children":[],"tail":" note),"},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" including—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id6b28305d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate consideration of the subgrade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b28305e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper filtration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b28305f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/viii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" durable components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b283060-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/viii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate connection between units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b283061-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/C/viii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of additional relevant information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283062-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sites","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b283063-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each project under the demonstration program may be carried out at—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6b283064-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a privately owned site with substantial public access; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b283065-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a publicly owned site on open coast or in tidal waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b283066-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop criteria for the selection of sites for projects under the demonstration program, including criteria based on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6b283067-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a variety of geographic and climatic conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b283068-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of the population that is dependent on the beaches for recreation or the protection of private property or public infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b283069-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of erosion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b28306a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant natural resources or habitats and environmentally sensitive areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b28306b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/2/D/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant threatened historic structures or landmarks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b28306c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out the demonstration program in consultation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b28306d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, particularly with respect to native and naturalized vegetative means of preventing and controlling shoreline erosion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b28306e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b28306f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283070-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coastal Engineering Research Center established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426–1"},"text":"section 426–1 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283071-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable university research facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b283072-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of demonstration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After carrying out the initial construction and evaluation of the performance and cost of a project under the demonstration program, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b283073-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amend, at the request of a non-Federal interest of the project, the partnership agreement for a federally authorized shore protection project in existence on the date on which initial construction of the project under the demonstration program is complete to incorporate the project constructed under the demonstration program as a feature of the shore protection project, with the future cost sharing of the project constructed under the demonstration program to be determined by the project purposes of the shore protection project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283074-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer all interest in and responsibility for the completed project constructed under the demonstration program to a non-Federal interest or another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b283075-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into a partnership agreement with the non-Federal interest or a cooperative agreement with the head of another Federal agency under the demonstration program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b283076-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share the costs of construction, operation, maintenance, and monitoring of a project under the demonstration program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283077-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share the costs of removing the project, or element of the project if the Secretary determines that the project or element of the project is detrimental to public or private property, public infrastructure, or public safety; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283078-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to specify ownership of the completed project if the Secretary determines that the completed project will not be part of a Corps of Engineers project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b283079-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":", and every 3 years thereafter, the Secretary shall prepare and submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report describing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b28307a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities carried out and accomplishments made under the demonstration program since the previous report under this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b28307b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Secretary relating to the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b28307c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b28307d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may expend, from any appropriations made available to the Secretary for the purpose of carrying out civil works, not more than $62,500,000 during any fiscal year to pay the Federal share of the costs of construction of small shore and beach restoration and protection projects or small projects under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b28307e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount expended for a project under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b28307f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be sufficient to pay the cost of Federal participation in the project (including periodic nourishment as provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426e"},"text":"section 426e of this title","children":[],"tail":"), as determined by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b283080-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be not more than $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b283081-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/ch960/s3"},"text":"Aug. 13, 1946, ch. 960, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1056"},"text":"60 Stat. 1056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-28/ch768"},"text":"July 28, 1956, ch. 768","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/703"},"text":"70 Stat. 703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/874/tI/s103/a/4"},"text":"Pub. L. 87–874, title I, § 103(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1178"},"text":"76 Stat. 1178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/298/tIII/s310/b"},"text":"Pub. L. 89–298, title III, § 310(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-27"},"text":"Oct. 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1095"},"text":"79 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/611/tI/s112/b"},"text":"Pub. L. 91–611, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1821"},"text":"84 Stat. 1821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s915/e"},"text":"Pub. L. 99–662, title IX, § 915(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4191"},"text":"100 Stat. 4191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s227/e/2/C"},"text":"Pub. L. 104–303, title II, § 227(e)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3703"},"text":"110 Stat. 3703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/53/tII/s226"},"text":"Pub. L. 106–53, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/298"},"text":"113 Stat. 298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2038/a"},"text":"Pub. L. 110–114, title II, § 2038(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1097"},"text":"121 Stat. 1097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1167"},"text":"Pub. L. 114–322, title I, § 1167","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1670"},"text":"130 Stat. 1670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1157/a"},"text":"Pub. L. 115–270, title I, § 1157(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3793"},"text":"132 Stat. 3793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1107/c"},"text":"Pub. L. 118–272, div. A, title I, § 1107(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3004"},"text":"138 Stat. 3004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b283082-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b283083-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b283084-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Shoreline Erosion Control Demonstration Act of 1974, referred to in subsec. (b)(2)(C)(viii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/251/tI/s54"},"text":"Pub. L. 93–251, title I, § 54","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-03-07"},"text":"Mar. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/26"},"text":"88 Stat. 26","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5"},"text":"section 1962d–5 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b283085-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/c/1"},"text":"Pub. L. 118–272, § 1107(c)(1)","children":[],"tail":", substituted “$62,500,000” for “$37,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/c/2"},"text":"Pub. L. 118–272, § 1107(c)(2)","children":[],"tail":", substituted “$15,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" substituted “$37,500,000” for “$30,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" substituted “$10,000,000” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" amended section generally. Prior to amendment, section related to authorization of small shore and beach restoration and protection projects not specifically authorized by Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53"},"text":"Pub. L. 106–53","children":[],"tail":" substituted “$3,000,000” for “$2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" substituted “Secretary” for “Secretary of the Army”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" substituted “$30,000,000” for “$25,000,000” and “$2,000,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611"},"text":"Pub. L. 91–611","children":[],"tail":" increased authorized annual allotment for Federal share of project construction costs from $10,000,000 to $25,000,000 and the limitation on allotment for any single project from $500,000 to $1,000,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/298"},"text":"Pub. L. 89–298","children":[],"tail":" increased authorized annual allotment for Federal share of project construction costs from $3,000,000 to $10,000,000 and the limitation on allotment for any single project from $400,000 to $500,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/874"},"text":"Pub. L. 87–874","children":[],"tail":" substituted provisions which authorize the Secretary of the Army to undertake small shore and beach projects not specifically authorized by Congress, which otherwise comply with "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426e"},"text":"section 426e of this title","children":[],"tail":", and to allot from any civil works appropriations hereafter made, an amount not to exceed $3,000,000 for the Federal share of such projects in any one fiscal year, provide that no such single project shall be allotted more than $400,000, including periodic nourishment, that provisions of local cooperation shall apply, and that the work shall be complete and not commit the United States to any additional improvement except for periodic beach nourishment, and as may result from procedure applying to projects authorized after submission of survey reports, for provisions which permitted the Chief of Engineers to make advance payments, not exceeding the United States pro rata part of the value of the labor and materials actually put in, and to undertake construction of restoration and protective works under sections 426e to 426h of this title upon the request of, and contribution of funds by, the interested political subdivision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-28"},"text":"July 28, 1956","children":[],"tail":", substituted “restoration and protective works under sections 426e to 426h of this title” for “improvement and protective works”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b283086-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b283087-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b283088-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s915/i"},"text":"Pub. L. 99–662, title IX, § 915(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4191"},"text":"100 Stat. 4191","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/662/tIX/s915/i"},"text":"“The amendments made by this section [amending this section and sections 426i, 577, 603a, 701g, 701r, and 701s of this title] shall not apply to any project under contract for construction on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b2a7a79-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611/tI/s112/c"},"text":"Pub. L. 91–611, title I, § 112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1821"},"text":"84 Stat. 1821","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/611/tI/s112/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s577"},"text":"section 577 of this title","children":[],"tail":"] shall not apply to any project under contract for construction on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b2a7a7a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions, powers, and duties of Secretary of the Army and other offices and officers of Department of the Army under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"section 401 of this title","children":[],"tail":" to extent that they relate generally to location and clearances of bridges and causeways in navigable waters of United States transferred to and vested in Secretary of Transportation by "},{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/g/6/A"},"text":"Pub. L. 89–670, § 6(g)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/941"},"text":"80 Stat. 941","children":[],"tail":", which created Department of Transportation. "},{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"section 401 of this title","children":[],"tail":" to reflect transfer made by "},{"tag":"ref","attrib":{"href":"/us/pl/89/670/s6/g/6/A"},"text":"section 6(g)(6)(A) of Pub. L. 89–670","children":[],"tail":", and repealed section 6(g)(6)(A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b2a7a7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hurricane and Storm Damage Protection Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1112"},"text":"Pub. L. 115–270, title I, § 1112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3775"},"text":"132 Stat. 3775","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/270/tI/s1112"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of the Army] is authorized to carry out a pilot program to award single contracts for more than one authorized hurricane and storm damage reduction project in a geographical region, including projects across more than one Corps of Engineers district, if the Secretary determines that the contract provides cost savings compared to the awarding of such work on a project-by-project basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the pilot program under subsection (a), the Secretary shall consult with relevant State agencies in selecting projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the pilot program under subsection (a), the Secretary shall establish criteria and other considerations that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster Federal, State, and local collaboration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the performance of projects being carried out under a single contract with respect to whether such projects yield any regional or multi-district benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include other criteria and considerations that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":"], and annually thereafter, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that includes findings and recommendations of the Secretary with respect to the projects completed under the pilot program carried out under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section $75,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary to enter into contracts pursuant to the pilot program carried out under subsection (a) shall expire on the date that is 10 years after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
