{"tag":"section","attrib":{"id":"id6c7d3922-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205"},"text":null,"children":[{"tag":"num","attrib":{"value":"3205"},"text":"§ 3205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tsunami research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7d3923-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall, in consultation with such other Federal agencies, State, tribal, and territorial governments, and academic institutions as the Administrator considers appropriate, the coordinating committee under section 3204(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002138"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002138"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should read “section 3204(b)”."}],"tail":" of this title, and the panel under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3206a/a"},"text":"section 3206a(a) of this title","children":[],"tail":", support or maintain a tsunami research program to develop detection, forecast, communication, and mitigation science and technology, including advanced sensing techniques, information and communication technology, data collection, analysis, assessment for tsunami tracking and numerical forecast modeling, and standards development."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7d3924-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The research program supported or maintained under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7d3925-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider other appropriate and cost effective solutions to mitigate the impact of tsunami, including the improvement of near-field and distant tsunami detection and forecasting capabilities, which may include use of a new generation of the Deep-ocean Assessment and Reporting of Tsunamis array, integration of tsunami sensors into commercial and Federal telecommunications cables, and other real-time tsunami monitoring systems and supercomputer capacity of the Administration to develop a rapid tsunami forecast for all United States coastlines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3926-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the National Weather Service on technology to be transferred to operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3927-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct social science research to develop and assess community warning, education, and evacuation materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3928-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the technical basis for validation of tsunami maps, numerical tsunami models, digital elevation models, and forecasts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3929-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3205/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that research and findings are available to the public and the scientific community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7d392a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/424/s6"},"text":"Pub. L. 109–424, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2907"},"text":"120 Stat. 2907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVIII/s806"},"text":"Pub. L. 109–479, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3658"},"text":"120 Stat. 3658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/tV"},"text":"Pub. L. 115–25, title V","children":[],"tail":", §§ 506, 512(a), "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/123"},"text":"131 Stat. 123","children":[],"tail":", 128.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7d392b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7d392c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c7d392d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/424"},"text":"Pub. L. 109–424","children":[],"tail":" and title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" enacted substantially identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/109/424"},"text":"Pub. L. 109–424","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/s512/a"},"text":"section 512(a) of Pub. L. 115–25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c7d392e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s506/1"},"text":"Pub. L. 115–25, § 506(1)","children":[],"tail":", (2), designated first and second sentences of existing provisions as subsecs. (a) and (b), respectively, and inserted headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s506/1"},"text":"Pub. L. 115–25, § 506(1)","children":[],"tail":", (2), substituted “The Administrator shall, in consultation with such other Federal agencies, State, tribal, and territorial governments, and academic institutions as the Administrator considers appropriate, the coordinating committee under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3204/d"},"text":"section 3204(d) of this title","children":[],"tail":", and the panel under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3206a/a"},"text":"section 3206a(a) of this title","children":[],"tail":", support or maintain” for “The Administrator shall, in consultation with other agencies and academic institutions, and with the coordinating committee established under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3204/b"},"text":"section 3204(b) of this title","children":[],"tail":", establish or maintain” and “assessment for tsunami tracking and numerical forecast modeling, and standards development.” for “and assessment for tsunami tracking and numerical forecast modeling.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s506/2"},"text":"Pub. L. 115–25, § 506(2)","children":[],"tail":", substituted “The research program supported or maintained under subsection (a) shall—” for “Such research program shall—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s506/3/A"},"text":"Pub. L. 115–25, § 506(3)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “consider other appropriate research to mitigate the impact of tsunami;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s506/3/B"},"text":"Pub. L. 115–25, § 506(3)(B)","children":[],"tail":", substituted “conduct” for “include” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s506/3/D"},"text":"Pub. L. 115–25, § 506(3)(D)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s506/3/C"},"text":"Pub. L. 115–25, § 506(3)(C)","children":[],"tail":", (E), redesignated par. (4) as (5) and substituted “to the public and the scientific community” for “to the scientific community”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
