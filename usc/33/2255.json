{"tag":"section","attrib":{"id":"id6c3f1ea2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255"},"text":null,"children":[{"tag":"num","attrib":{"value":"2255"},"text":"§ 2255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inland waterways riverbank stabilization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3f1ea3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", and biennially thereafter, the Secretary shall conduct a study to determine the feasibility of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1ea4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carrying out projects for the inland and intracoastal waterways for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3f1ea5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flood damage reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1ea6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency streambank and shoreline protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1ea7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention and mitigation of shore damages attributable to navigation improvements; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1ea8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifying projects for the inland and intracoastal waterways for the purpose of improving the quality of the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1ea9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study, the Secretary shall develop specific project recommendations and prioritize those recommendations based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1eaa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of damage and land loss resulting from riverbank erosion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1eab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of erosion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1eac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significant threat of future flood risk to public property, public infrastructure, or public safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1ead-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destruction of natural resources or habitats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1eae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential cost savings for maintenance of the channel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1eaf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out any project identified in the study conducted pursuant to subsection (a) in accordance with the criteria for projects carried out under one of the following authorities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1eb0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701r"},"text":"Section 701r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1eb1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701s"},"text":"Section 701s of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1eb2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426i"},"text":"Section 426i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1eb3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2309a"},"text":"Section 2309a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1eb4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a project recommended pursuant to the study that cannot be carried out under any of the authorities specified in subsection (c), upon a determination by the Secretary of the feasibility of the project, the Secretary may include a recommendation concerning the project in the annual report submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d"},"text":"section 2282d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3f1eb5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2009"},"text":"Pub. L. 113–121, title II, § 2009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1269"},"text":"128 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3f1eb6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3f1eb7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3f1eb8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3f1eb9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c3f1eba-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
