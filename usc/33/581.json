{"tag":"section","attrib":{"id":"id6b499b03-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s581"},"text":null,"children":[{"tag":"num","attrib":{"value":"581"},"text":"§ 581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring special means of transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In their execution and inspection of river and harbor improvement work, at points beyond easy reach of ordinary regular transportation lines, Engineer officers are authorized to hire and use such transportation as they may consider desirable and advantageous to the progress of work.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b499b04-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-07-25/ch253/s9"},"text":"July 25, 1912, ch. 253, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/233"},"text":"37 Stat. 233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b499b05-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b499b06-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b499b07-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from act ","children":[{"tag":"date","attrib":{"date":"1912-07-25"},"text":"July 25, 1912","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1912”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
