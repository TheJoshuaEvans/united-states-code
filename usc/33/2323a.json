{"tag":"section","attrib":{"id":"id6c54a327-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2323a"},"text":"§ 2323a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency and international support authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c54a328-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may engage in activities (including contracting) in support of Federal departments or agencies, nongovernmental organizations, international organizations, or foreign governments to address problems of national significance to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a329-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may engage in activities in support of international organizations or foreign governments only after consulting with the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a32a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Corps’ expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use the technical and managerial expertise, including the planning and design expertise, of the Corps of Engineers to address domestic and international problems related to water resources, infrastructure development, and environmental protection and restoration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c54a32b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c54a32c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $2,500,000 for fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c54a32d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2323a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept and expend additional funds from Federal departments or agencies, nongovernmental organizations, international organizations, or foreign governments to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c54a32e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s234"},"text":"Pub. L. 104–303, title II, § 234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3704"},"text":"110 Stat. 3704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s207"},"text":"Pub. L. 106–541, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2590"},"text":"114 Stat. 2590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2030"},"text":"Pub. L. 110–114, title II, § 2030","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1081"},"text":"121 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1029"},"text":"Pub. L. 113–121, title I, § 1029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1230"},"text":"128 Stat. 1230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tII/s1243"},"text":"Pub. L. 118–272, div. A, title II, § 1243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3092"},"text":"138 Stat. 3092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c54a32f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c54a330-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c54a331-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1996, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c54a332-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1243/1"},"text":"Pub. L. 118–272, § 1243(1)","children":[],"tail":", inserted “, including the planning and design expertise,” after “managerial expertise”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1243/2"},"text":"Pub. L. 118–272, § 1243(2)","children":[],"tail":", substituted “$2,500,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1029/1"},"text":"Pub. L. 113–121, § 1029(1)","children":[],"tail":", substituted “Federal departments or agencies, nongovernmental organizations,” for “other Federal agencies,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1029/2"},"text":"Pub. L. 113–121, § 1029(2)","children":[],"tail":", inserted “or foreign governments” after “organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1029/3"},"text":"Pub. L. 113–121, § 1029(3)","children":[],"tail":", inserted “and restoration” after “protection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1029/4"},"text":"Pub. L. 113–121, § 1029(4)","children":[],"tail":", designated first and second sentences as pars. (1) and (2), respectively, inserted headings, and substituted “Federal departments or agencies, nongovernmental organizations,” for “other Federal agencies,” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2030/1"},"text":"Pub. L. 110–114, § 2030(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “The Secretary may engage in activities in support of other Federal agencies or international organizations to address problems of national significance to the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2030/2"},"text":"Pub. L. 110–114, § 2030(2)","children":[],"tail":", substituted “Department of State” for “Secretary of State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2030/3"},"text":"Pub. L. 110–114, § 2030(3)","children":[],"tail":", substituted “$1,000,000 for fiscal year 2008” for “$250,000 for fiscal year 2001” and “, international organizations, or foreign governments” for “or international organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541"},"text":"Pub. L. 106–541","children":[],"tail":" substituted “There is authorized to be appropriated to carry out this section $250,000 for fiscal year 2001 and each fiscal year thereafter.” for “There is authorized to be appropriated $1,000,000 to carry out this section.” and inserted “out” after “carry” in second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c54a333-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a334-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Recreation Reservation Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s206"},"text":"Pub. L. 106–541, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2590"},"text":"114 Stat. 2590","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/541/tII/s206"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding section 611 of the Treasury and General Government Appropriations Act, 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/112/2681-515"},"text":"112 Stat. 2681–515","children":[],"tail":"), the Secretary [of the Army] may—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the National Recreation Reservation Service on an interagency basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the Department of the Army’s share of the activities required to implement, operate, and maintain the Service.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c54a335-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s2"},"text":"section 2 of Pub. L. 104–303","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
