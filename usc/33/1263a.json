{"tag":"section","attrib":{"id":"id6ba8f8f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1263a"},"text":"§ 1263a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to Alaska to improve sanitation in rural and Native villages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6ba8f8f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Environmental Protection Agency may make grants to the State of Alaska for the benefit of rural and Native villages in Alaska to pay the Federal share of the cost of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6ba8f8f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and construction of public water systems and wastewater systems to improve the health and sanitation conditions in the villages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba8f8f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training, technical assistance, and educational programs relating to the operation and management of sanitation services in rural and Native villages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba8f8f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the activities described in subsection (a) shall be 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba8f8f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State of Alaska may use an amount not to exceed 4 percent of any grant made available under this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" for administrative expenses necessary to carry out the activities described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba8f8f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with State of Alaska","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall consult with the State of Alaska on a method of prioritizing the allocation of grants under subsection (a) according to the needs of, and relative health and sanitation conditions in, each eligible village.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6ba8f8f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6ba8f8f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40,000,000 for each of fiscal years 2022 through 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba8f8f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6ba8f8fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1263a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,000 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6ba8f8fb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/tIII/s303"},"text":"Pub. L. 104–182, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1683"},"text":"110 Stat. 1683","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/457/tIX/s903"},"text":"Pub. L. 106–457, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1982"},"text":"114 Stat. 1982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50212"},"text":"Pub. L. 117–58, div. E, title II, § 50212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1172"},"text":"135 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6ba8f8fc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6ba8f8fd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6ba8f8fe-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Safe Drinking Water Act Amendments of 1996, and not as part of the Federal Water Pollution Control Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6ba8f8ff-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50212/1"},"text":"Pub. L. 117–58, § 50212(1)","children":[],"tail":", substituted “75 percent” for “50 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50212/2"},"text":"Pub. L. 117–58, § 50212(2)","children":[],"tail":", substituted “this section—” and pars. (1) to (3) for “this section $40,000,000 for each of fiscal years 2001 through 2005.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457"},"text":"Pub. L. 106–457","children":[],"tail":" substituted “to carry out this section $40,000,000 for each of fiscal years 2001 through 2005” for “$15,000,000 for each of the fiscal years 1997 through 2000 to carry out this section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
