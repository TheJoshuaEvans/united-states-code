{"tag":"section","attrib":{"id":"id6b9f5c77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1208"},"text":null,"children":[{"tag":"num","attrib":{"value":"1208"},"text":"§ 1208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b9f5c78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master, person in charge, or pilot subject to penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever, being the master or person in charge of a vessel subject to this chapter, fails to enforce or comply with this chapter or the regulation, hereunder; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Whoever, being designated by the master or person in charge of a vessel subject to this chapter to pilot or direct the movement of the vessel, fails to enforce or comply with this chapter or the regulations hereunder—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Is liable to a civil penalty of not more than $500 to be assessed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b9f5c79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels subject to penalty; jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every vessel navigating in violation of this chapter or the regulations hereunder is liable to a civil penalty of not more than $500 to be assessed by the Secretary for which the vessel may be proceeded against in any district court of the United States having jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b9f5c7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remission or mitigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any penalty assessed under this section may be remitted or mitigated by the Secretary upon such terms as he may deem proper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b9f5c7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/63/s9"},"text":"Pub. L. 92–63, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-04"},"text":"Aug. 4, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/165"},"text":"85 Stat. 165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b9f5c7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b9f5c7d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b9f5c7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":", or six months after the promulgation of regulations which would implement its provisions, whichever is later, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/63/s10"},"text":"section 10 of Pub. L. 92–63","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
