{"tag":"section","attrib":{"id":"id6c67b5d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2708"},"text":null,"children":[{"tag":"num","attrib":{"value":"2708"},"text":"§ 2708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery by responsible party","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c67b5d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsible party for a vessel or facility from which oil is discharged, or which poses the substantial threat of a discharge of oil, may assert a claim for removal costs and damages under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2713"},"text":"section 2713 of this title","children":[],"tail":" only if the responsible party demonstrates that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b5d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsible party is entitled to a defense to liability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2703"},"text":"section 2703 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c69fec7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsible party is entitled to a limitation of liability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2704"},"text":"section 2704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c69fec8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extent of recovery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A responsible party who is entitled to a limitation of liability may assert a claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2713"},"text":"section 2713 of this title","children":[],"tail":" only to the extent that the sum of the removal costs and damages incurred by the responsible party plus the amounts paid by the responsible party, or by the guarantor on behalf of the responsible party, for claims asserted under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2713"},"text":"section 2713 of this title","children":[],"tail":" exceeds the amount to which the total of the liability under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2702"},"text":"section 2702 of this title","children":[],"tail":" and removal costs and damages incurred by, or on behalf of, the responsible party is limited under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2704"},"text":"section 2704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c69fec9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tI/s1008"},"text":"Pub. L. 101–380, title I, § 1008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/497"},"text":"104 Stat. 497","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
