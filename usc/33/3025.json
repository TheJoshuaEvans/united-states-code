{"tag":"section","attrib":{"id":"id6c760e68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3025"},"text":null,"children":[{"tag":"num","attrib":{"value":"3025"},"text":"§ 3025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of service for promotion purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760e69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3025/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each officer shall be assumed to have, for promotion purposes, at least the same length of service as any other officer below that officer on the lineal list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e6a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3025/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), an officer who has lost numbers shall be assumed to have, for promotion purposes, no greater service than the officer next above such officer in such officer’s new position on the lineal list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760e6b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s225"},"text":"Pub. L. 107–372, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3085"},"text":"116 Stat. 3085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760e6c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760e6d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c760e6e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853f"},"text":"section 853f of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
