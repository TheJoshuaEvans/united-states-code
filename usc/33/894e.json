{"tag":"section","attrib":{"id":"id6b7ba78b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e"},"text":null,"children":[{"tag":"num","attrib":{"value":"894e"},"text":"§ 894e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on sexual assaults in the National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7ba78c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 15 of each year, the Secretary of Commerce shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Natural Resources of the House of Representatives a report on the sexual assaults involving employees of the National Oceanic and Atmospheric Administration, members of the commissioned officer corps of the Administration, and individuals who work with or conduct business on behalf of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba78d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subsection (a) shall include, with respect to the previous calendar year, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba78e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of alleged sexual assaults involving employees, members, and individuals described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba78f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A synopsis of each case and the disciplinary action taken, if any, in each case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba790-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The policies, procedures, and processes implemented by the Secretary, and any updates or revisions to such policies, procedures, and processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba791-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of the reports received by the Under Secretary for Oceans and Atmosphere under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s894/f"},"text":"section 894(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba792-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing and submitting a report under subsection (a), the Secretary shall ensure that no individual involved in an alleged sexual assault can be identified by the contents of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7ba793-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3548"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3548","children":[],"tail":", formerly § 3546, "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2804"},"text":"130 Stat. 2804","children":[],"tail":"; renumbered § 3548, "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tV/s504/b/1"},"text":"Pub. L. 116–259, title V, § 504(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1180"},"text":"134 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
