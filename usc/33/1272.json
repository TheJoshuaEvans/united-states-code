{"tag":"section","attrib":{"id":"id6bb26fc7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272"},"text":null,"children":[{"tag":"num","attrib":{"value":"1272"},"text":"§ 1272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental dredging","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb26fc8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance of navigation projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever necessary to meet the requirements of the Federal Water Pollution Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.], the Secretary, in consultation with the Administrator of the Environmental Protection Agency, may remove and remediate, as part of operation and maintenance of a navigation project, contaminated sediments outside the boundaries of and adjacent to the navigation channel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb26fc9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonproject specific","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb26fca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may remove and remediate contaminated sediments from the navigable waters of the United States for the purpose of environmental enhancement and water quality improvement if such removal and remediation is requested by a non-Federal sponsor and the sponsor agrees to pay 35 percent of the cost of such removal and remediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb26fcb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not expend more than $50,000,000 in a fiscal year to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb26fcc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint plan requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only remove and remediate contaminated sediments under subsection (b) in accordance with a joint plan developed by the Secretary and interested Federal, State, and local government officials. Such plan must include an opportunity for public comment, a description of the work to be undertaken, the method to be used for dredged material disposal, the roles and responsibilities of the Secretary and non-Federal sponsors, and identification of sources of funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb26fcd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Costs of disposal of contaminated sediments removed under this section shall be a ","children":[{"tag":"ref","attrib":{"idref":"fn002057"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002057"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “a” probably should not appear."}],"tail":" shared as a cost of construction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dfce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the rights and responsibilities of any person under the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dfcf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority work","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall give priority to work in the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4dfd0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Brooklyn Waterfront, New York.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfd1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Buffalo Harbor and River, New York.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfd2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ashtabula River, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfd3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mahoning River, Ohio.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfd4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lower Fox River, Wisconsin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfd5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Passaic River and Newark Bay, New Jersey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfd6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snake Creek, Bixby, Oklahoma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4dfd7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Willamette River, Oregon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4dfd8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1272/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b"},"text":"section 1962d–5b of title 42","children":[],"tail":", for any project carried out under this section, a non-Federal sponsor may include a nonprofit entity, with the consent of the affected local government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb4dfd9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s312"},"text":"Pub. L. 101–640, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4639"},"text":"104 Stat. 4639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s205"},"text":"Pub. L. 104–303, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3679"},"text":"110 Stat. 3679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/53/tII/s224"},"text":"Pub. L. 106–53, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/297"},"text":"113 Stat. 297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s210/a"},"text":"Pub. L. 106–541, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2592"},"text":"114 Stat. 2592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bb4dfda-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bb4dfdb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6bb4dfdc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to this chapter (§ 1251 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Comprehensive Environmental Response, Compensation, and Liability Act of 1980, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", which is classified principally to chapter 103 (§ 9601 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6bb4dfdd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1252"},"text":"section 1252 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1990, and not as part of the Federal Water Pollution Control Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bb4dfde-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541"},"text":"Pub. L. 106–541","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s224/1/A"},"text":"Pub. L. 106–53, § 224(1)(A)","children":[],"tail":", substituted “35 percent” for “50 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s224/1/B"},"text":"Pub. L. 106–53, § 224(1)(B)","children":[],"tail":", substituted “$50,000,000” for “$20,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s224/2"},"text":"Pub. L. 106–53, § 224(2)","children":[],"tail":", substituted “shared as a cost of construction” for “non-Federal responsibility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s224/3"},"text":"Pub. L. 106–53, § 224(3)","children":[],"tail":", added pars. (6) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s205/1"},"text":"Pub. L. 104–303, § 205(1)","children":[],"tail":", inserted “and remediate” after “remove”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s205/1"},"text":"Pub. L. 104–303, § 205(1)","children":[],"tail":", (2)(A), inserted “and remediate” after “remove” and inserted “and remediation” after “removal” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s205/2/B"},"text":"Pub. L. 104–303, § 205(2)(B)","children":[],"tail":", substituted “$20,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s205/1"},"text":"Pub. L. 104–303, § 205(1)","children":[],"tail":", inserted “and remediate” after “remove”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s205/3"},"text":"Pub. L. 104–303, § 205(3)","children":[],"tail":", added subsec. (f) and struck out heading and text of former subsec. (f). Text read as follows: “This section shall not be effective after the last day of the 5-year period beginning on "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"; except that the Secretary may complete any project commenced under this section on or before such last day.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
