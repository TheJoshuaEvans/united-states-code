{"tag":"section","attrib":{"id":"id6c4b0625-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2283a"},"text":"§ 2283a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c4b0626-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Concurrent with the President’s submission to Congress of the President’s request for appropriations for the Civil Works Program for a fiscal year, the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a report on the status of construction of projects that require mitigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2283"},"text":"section 2283 of this title","children":[],"tail":", the status of such mitigation, and the results of the consultation under subsection (d)(4)(B) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4b0627-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The status report shall include the status of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c4b0628-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all projects that are under construction as of the date of the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4b0629-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all projects for which the President requests funding for the next fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4b062a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all projects that have undergone or completed construction, but have not completed the mitigation required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2283"},"text":"section 2283 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4b062b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In reporting the status of all projects included in the report, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c4b062c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a uniform methodology for determining the status of all projects included in the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4b062d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a methodology that describes both a qualitative and quantitative status for all projects in the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4b062e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide specific dates for participation in the consultations required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2283/d/4/B"},"text":"section 2283(d)(4)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4b062f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2283a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make information contained in the status report available to the public, including on the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c4b0630-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2036/b"},"text":"Pub. L. 110–114, title II, § 2036(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1094"},"text":"121 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1041"},"text":"Pub. L. 113–121, title I, § 1041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1243"},"text":"128 Stat. 1243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4b0631-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c4b0632-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c4b0633-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2007, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c4b0634-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c4b0635-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c4b0636-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
