{"tag":"section","attrib":{"id":"id6c8ddb2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8ddb2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Administrator may provide financial assistance under this chapter to carry out projects, which shall be selected to ensure a diversity of project types and geographical locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8ddb2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8ddb2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide financial assistance to carry out all projects under this chapter that are eligible projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905/1"},"text":"section 3905(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide financial assistance to carry out all projects under this chapter that are eligible projects under paragraphs (2), (3), (4), (5), (6), (7), and (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905"},"text":"section 3905 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb2f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, may carry out eligible projects under paragraph (8) or (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3905"},"text":"section 3905 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8ddb30-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5023"},"text":"Pub. L. 113–121, title V, § 5023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1333"},"text":"128 Stat. 1333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5008/a"},"text":"Pub. L. 114–322, title IV, § 5008(a)","children":[],"tail":", (b)(2)(A), "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":