{"tag":"section","attrib":{"id":"id6b3ffeec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s549b"},"text":null,"children":[{"tag":"num","attrib":{"value":"549b"},"text":"§ 549b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of project or facility in Corps of Engineers workplan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b3ffeed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s549b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, include in the future workplan of the Corps any authorized project or facility of the Corps of Engineers—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3ffeee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s549b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Secretary has studied for disposition under an existing authority, including by carrying out a disposition study under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s549a"},"text":"section 549a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3ffeef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s549b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a final report by the Director of Civil Works has been completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3ffef0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s549b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of a final report referred to in subsection (a), the Secretary shall transmit a copy of the report to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b3ffef1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1117"},"text":"Pub. L. 115–270, title I, § 1117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3776"},"text":"132 Stat. 3776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3ffef2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b3ffef3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b3ffef4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s102"},"text":"section 102 of Pub. L. 115–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
