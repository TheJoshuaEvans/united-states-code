{"tag":"section","attrib":{"id":"id6b50a084-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s629"},"text":null,"children":[{"tag":"num","attrib":{"value":"629"},"text":"§ 629.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract for hire of dredging plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever it shall become, in the opinion of the Secretary of the Army, necessary or desirable to hire a dredging plant or plants for the performance of any of the public work carried on under his direction the said Secretary may, in his discretion, agree for the same, either in the manner customary on ","children":[{"tag":"date","attrib":{"date":"1907-03-02"},"text":"March 2, 1907","children":[],"tail":", or on the basis of an equitable reimbursement for deterioration of plant when in use by the Government, and a reasonable percentage of the total cost of the work."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b50a085-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-02/ch2509/s5"},"text":"Mar. 2, 1907, ch. 2509, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1119"},"text":"34 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b50a086-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b50a087-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b50a088-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Rivers and Harbors Appropriation Act of 1907.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The part of the original text omitted here repealed ","children":[{"tag":"ref","attrib":{"href":"/us/act/1904-04-28/ch1761/s4"},"text":"act Apr. 28, 1904, ch. 1761, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/452"},"text":"33 Stat. 452","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b50a089-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b50a08a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
