{"tag":"section","attrib":{"id":"id6b6623ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s702a–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"702a–3"},"text":"§ 702a–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levees; raising and enlarging","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The levees along the Mississippi River from the head of the Morganza Floodway to the head of the Atchafalaya River and down the east bank of the Atchafalaya River to intersection with the west protection levee of said Morganza Floodway shall be raised and enlarged to 1928 grade and section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b6623ed-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch548/s3"},"text":"June 15, 1936, ch. 548, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1509"},"text":"49 Stat. 1509","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
