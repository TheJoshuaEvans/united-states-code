{"tag":"section","attrib":{"id":"id6b472a48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s578b"},"text":null,"children":[{"tag":"num","attrib":{"value":"578b"},"text":"§ 578b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b472a49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s578b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out a disposition study for a project of the Corps of Engineers, or a separable element of such a project, including a disposition study under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s549a"},"text":"section 549a of this title","children":[],"tail":", the Secretary shall consider modifications that would improve the overall quality of the environment in the public interest, including removal of the project or separable element of a project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b472a4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s578b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition study transparency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out disposition studies described in subsection (a) in a transparent manner, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b472a4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s578b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing opportunities for public input; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b472a4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s578b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publishing the final disposition studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b472a4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s578b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For disposition studies described in subsection (a) in which the Secretary determines that a Federal interest no longer exists, and makes a recommendation of removal of the project or separable element of a project, the Secretary is authorized, using existing authorities, to pursue removal of the project or separable element of a project in partnership with other Federal agencies and non-Federal entities with appropriate capabilities to undertake infrastructure removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b472a4e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1168"},"text":"Pub. L. 115–270, title I, § 1168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3798"},"text":"132 Stat. 3798","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b472a4f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b472a50-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b472a51-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s102"},"text":"section 102 of Pub. L. 115–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
