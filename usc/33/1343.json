{"tag":"section","attrib":{"id":"id6bf78ed3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343"},"text":null,"children":[{"tag":"num","attrib":{"value":"1343"},"text":"§ 1343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean discharge criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bf78ed4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No permit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342"},"text":"section 1342 of this title","children":[],"tail":" for a discharge into the territorial sea, the waters of the contiguous zone, or the oceans shall be issued, after promulgation of guidelines established under subsection (c) of this section, except in compliance with such guidelines. Prior to the promulgation of such guidelines, a permit may be issued under such "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342"},"text":"section 1342 of this title","children":[],"tail":" if the Administrator determines it to be in the public interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bf78ed5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342"},"text":"section 1342 of this title","children":[],"tail":" may not be waived in the case of permits for discharges into the territorial sea."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bf78ed6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for determining degradation of waters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bf78ed7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall, within one hundred and eighty days after ","children":[{"tag":"date","attrib":{"date":"1972-10-18"},"text":"October 18, 1972","children":[],"tail":" (and from time to time thereafter), promulgate guidelines for determining the degradation of the waters of the territorial seas, the contiguous zone, and the oceans, which shall include:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bf78ed8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of disposal of pollutants on human health or welfare, including but not limited to plankton, fish, shellfish, wildlife, shorelines, and beaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bf78ed9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of disposal of pollutants on marine life including the transfer, concentration, and dispersal of pollutants or their byproducts through biological, physical, and chemical processes; changes in marine ecosystem diversity, productivity, and stability; and species and community population changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bf78eda-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of disposal, of pollutants on esthetic, recreation, and economic values;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bf78edb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the persistence and permanence of the effects of disposal of pollutants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bf78edc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the disposal of varying rates, of particular volumes and concentrations of pollutants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bf78edd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other possible locations and methods of disposal or recycling of pollutants including land-based alternatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bf78ede-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on alternate uses of the oceans, such as mineral exploitation and scientific study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bf78edf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1343/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any event where insufficient information exists on any proposed discharge to make a reasonable judgment on any of the guidelines established pursuant to this subsection no permit shall be issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1342"},"text":"section 1342 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bf78ee0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title IV, § 403, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/883"},"text":"86 Stat. 883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bf78ee1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6bf78ee2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6bf78ee3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Discharges From Point Sources in United States Virgin Islands Attributable to Manufacture of Rum; Exemption; Conditions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Discharges from point sources in the United States Virgin Islands in existence on ","children":[{"tag":"date","attrib":{"date":"1983-08-05"},"text":"Aug. 5, 1983","children":[],"tail":", attributable to the manufacture of rum not to be subject to the requirements of this section under certain conditions, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/67/s214/g"},"text":"section 214(g) of Pub. L. 98–67","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1311"},"text":"section 1311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6bf9fee4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6bf9fee5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea and Contiguous Zone of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea and contiguous zone of United States, see Proc. No. 5928 and Proc. No. 7219, respectively, set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
