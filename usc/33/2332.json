{"tag":"section","attrib":{"id":"id6c5bced8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332"},"text":null,"children":[{"tag":"num","attrib":{"value":"2332"},"text":"§ 2332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shoreline and riverine protection and restoration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5bced9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out studies and projects to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bceda-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce flood and hurricane and storm damage hazards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcedb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restore the natural functions and values of rivers and shorelines throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcedc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bcedd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5bcede-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary may carry out studies to identify appropriate measures for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c5bcedf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of flood and hurricane and storm damage hazards, including measures for erosion mitigation and bank stabilization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5bcee0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation and restoration of the natural functions and values of rivers and shorelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcee1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (f)(2), in carrying out subsection (a), the Secretary may design and implement projects described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcee2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The studies and projects carried out under this section shall be conducted, to the maximum extent practicable, in consultation and coordination with the Federal Emergency Management Agency and other appropriate Federal agencies, and in consultation and coordination with appropriate State and local agencies and tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcee3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonstructural approaches","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The studies and projects shall emphasize, to the maximum extent practicable and appropriate, nonstructural approaches to preventing or reducing flood and hurricane and storm damages, including the use of natural features or nature-based features.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcee4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The studies and projects shall be conducted, to the maximum extent practicable, in cooperation with State and local agencies and tribes to ensure the coordination of local flood and hurricane and storm damage reduction or riverine, shoreline, and wetland restoration studies with projects that conserve, restore, and manage hydrologic and hydraulic regimes and restore the natural functions and values of floodplains and coastal barriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcee5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bcee6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Studies conducted under this section shall be subject to cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2215"},"text":"section 2215 of this title","children":[],"tail":", except that the first $200,000 of the costs of a study conducted under this section shall be at Federal expense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcee7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental restoration and nonstructural projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5bcee8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Design and construction of a project under this section that includes a nonstructural measure, a natural feature or nature-based feature, or an environmental restoration measure, shall be subject to cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213"},"text":"section 2213 of this title","children":[],"tail":", except that the non-Federal share of the cost to design and construct such a project benefitting an economically disadvantaged community (including economically disadvantaged communities located in urban and rural areas) shall be 10 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcee9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Items provided by non-Federal interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal interests shall provide all land, easements, rights-of-way, dredged material disposal areas, and relocations necessary for such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bceea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The value of such land, easements, rights-of-way, dredged material disposal areas, and relocations shall be credited toward the payment required under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bceeb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structural flood control or hurricane and storm damage reduction projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any structural flood control or hurricane and storm damage reduction projects carried out under this section shall be subject to cost sharing in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213"},"text":"section 2213 of this title","children":[],"tail":", except that the non-Federal share of the cost to design and construct such a project benefitting an economically disadvantaged community (including economically disadvantaged communities located in urban and rural areas) shall be 10 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bceec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal interests shall be responsible for all costs associated with operating, maintaining, replacing, repairing, and rehabilitating all projects carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bceed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project justification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any requirement for economic justification established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962–2"},"text":"section 1962–2 of title 42","children":[],"tail":", the Secretary may implement a project under this section if the Secretary determines that the project—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bceee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will significantly reduce potential flood, hurricane and storm, or erosion damages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bceef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will improve the quality of the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcef0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is justified considering all costs and beneficial outputs of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcef1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas for Examination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bcef2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall examine appropriate locations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5bcef3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pima County, Arizona, at Paseo De Las Iglesias and Rillito River;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcef4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coachella Valley, Riverside County, California;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcef5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Los Angeles and San Gabriel Rivers, California;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcef6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Murrieta Creek, California;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcef7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Napa River Valley watershed, California, at Yountville, St. Helena, Calistoga, and American Canyon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcef8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Santa Clara basin, California, at Upper Guadalupe River and Tributaries, San Francisquito Creek, and Upper Penitencia Creek;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcef9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pond Creek, Kentucky;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcefa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Red River of the North, Minnesota, North Dakota, and South Dakota;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcefb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Connecticut River, New Hampshire;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcefc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pine Mount Creek, New Jersey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcefd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2332/e/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Southwest Valley, Albuquerque, New Mexico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparag