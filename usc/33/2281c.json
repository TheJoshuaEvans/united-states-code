{"tag":"section","attrib":{"id":"id6c43da15-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2281c"},"text":"§ 2281c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing authority programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c43da16-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community revitalization program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c43da17-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall implement a program, in accordance with this subsection, for carrying out a project under a continuing authority program for an economically disadvantaged community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da18-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c43da19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit project proposals from non-Federal interests by posting program information on a public-facing website and reaching out to non-Federal interests that have previously submitted relevant project proposals to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43da1a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review such proposals and select projects, taking into consideration geographic diversity among the selected projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the cost share authorized for the applicable continuing authority program, the Federal share of the cost of a project selected under paragraph (2) shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing authority program defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “continuing authority program” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d/c/1/D"},"text":"section 2282d(c)(1)(D) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $150,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c43da1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of Appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c43da1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency streambank and shoreline protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701r"},"text":"section 701r of this title","children":[],"tail":", there is authorized to be appropriated to carry out such section $25,500,000 for each of fiscal years 2021 through 2024."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storm and hurricane restoration and impact minimization program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426g/c"},"text":"section 426g(c) of this title","children":[],"tail":", there is authorized to be appropriated to carry out such section $38,000,000 for each of fiscal years 2021 through 2024."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small river and harbor improvement projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s577/a"},"text":"section 577(a) of this title","children":[],"tail":", there is authorized to be appropriated to carry out such section $63,000,000 for each of fiscal years 2021 through 2024."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional sediment management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326/g"},"text":"section 2326(g) of this title","children":[],"tail":", there is authorized to be appropriated to carry out such section $63,000,000 for each of fiscal years 2021 through 2024."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","c