","identifier":"/us/usc/t33/s2281c/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project modifications for improvement of environment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2309a/h"},"text":"section 2309a(h) of this title","children":[],"tail":", there is authorized to be appropriated to carry out such section $50,500,000 for each of fiscal years 2021 through 2024."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c43da27-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s165"},"text":"Pub. L. 116–260, div. AA, title I, § 165","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2668"},"text":"134 Stat. 2668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8118/b"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3711"},"text":"136 Stat. 3711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1107/k"},"text":"Pub. L. 118–272, div. A, title I, § 1107(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3006"},"text":"138 Stat. 3006","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c43da28-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c43da29-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c43da2a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/k"},"text":"Section 1107(k) of Pub. L. 118–272","children":[],"tail":", which amended this section, contains two pars. (3), the first of which amended subsec. (a)(2) of this section and the second of which amended subsec. (a)(4) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c43da2b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/k/1"},"text":"Pub. L. 118–272, § 1107(k)(1)","children":[],"tail":", substituted “Community revitalization program” for “Pilot Program for Continuing Authority Projects in Small or Disadvantaged Communities” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/k/2"},"text":"Pub. L. 118–272, § 1107(k)(2)","children":[],"tail":", substituted “a program” for “a pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/k/3/A"},"text":"Pub. L. 118–272, § 1107(k)(3)(A)","children":[],"tail":", struck out “pilot” before “program” in heading. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/k/3/B"},"text":"Pub. L. 118–272, § 1107(k)(3)(B)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “publish a notice in the Federal Register that requests non-Federal interest proposals for a project under a continuing authority program for an economically disadvantaged community; and”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/k/3/C"},"text":"Pub. L. 118–272, § 1107(k)(3)(C)","children":[],"tail":", substituted “select projects” for “select a total of 20 projects”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/k/3"},"text":"Pub. L. 118–272, § 1107(k)(3)","children":[],"tail":"–(6), added par. (5), redesignated former par. (5) as (4), made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d/c/1/D"},"text":"section 2282d(c)(1)(D) of this title","children":[],"tail":", and struck out former par. (4). Prior to amendment, text of par. (4) read as follows: “The authority to commence pursuant to this subsection a project selected under paragraph (2) shall terminate on the date that is 10 years after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":".” See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c464a2c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c464a2d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id6c464a2e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “economically disadvantaged community” as used in subsec. (a)(1) of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s160"},"text":"section 160 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
