{"tag":"section","attrib":{"id":"id6b55826c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s668"},"text":null,"children":[{"tag":"num","attrib":{"value":"668"},"text":"§ 668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Hydraulic mining” and “mining by hydraulic process” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this chapter “hydraulic mining” and “mining by the hydraulic process” are declared to have the meaning and application given to said terms in the State of California.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b55826d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-01/ch183/s8"},"text":"Mar. 1, 1893, ch. 183, § 8","children":[],"tail":", 27 Stat 508.)"}],"tail":"\n"}],"tail":null}
