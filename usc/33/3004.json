{"tag":"section","attrib":{"id":"id6c760dc9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004"},"text":null,"children":[{"tag":"num","attrib":{"value":"3004"},"text":"§ 3004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strength and distribution in grade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760dca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grades","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The commissioned grades in the commissioned officer corps of the Administration are the following, in relative rank with officers of the Navy:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760dcb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vice admiral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dcc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rear admiral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dcd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rear admiral (lower half).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Captain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dcf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commander.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dd0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lieutenant commander.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dd1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lieutenant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dd2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lieutenant (junior grade).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dd3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760dd4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grade distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe, with respect to the distribution on the lineal list in grade, the percentages applicable to the grades set forth in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760dd5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual computation of number in grade","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760dd6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once each year, the Secretary shall make a computation to determine the number of officers on the lineal list authorized to be serving in each grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dd7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of computation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number in each grade shall be computed by applying the applicable percentage to the total number of such officers serving on active duty on the date the computation is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dd8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fractions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a final fraction occurs in computing the authorized number of officers in a grade, the nearest whole number shall be taken. If the fraction is one-half, the next higher whole number shall be taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760dd9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary increase in numbers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total number of officers authorized by law to be on the lineal list during a fiscal year may be temporarily exceeded if the average number on that list during that fiscal year does not exceed the authorized number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760dda-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions of importance and responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Officers serving in positions designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3028/a"},"text":"section 3028(a) of this title","children":[],"tail":" and officers recalled from retired status shall not be counted when computing authorized strengths under subsection (c) and shall not count against those strengths."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760ddb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of grade and pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No officer may be reduced in grade or pay or separated from the commissioned officer corps of the Administration as the result of a computation made to determine the authorized number of officers in the various grades.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760ddc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s214"},"text":"Pub. L. 107–372, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3083"},"text":"116 Stat. 3083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tI/s101"},"text":"Pub. L. 116–259, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1154"},"text":"134 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760ddd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760dde-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c760ddf-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853a"},"text":"section 853a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760de0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259"},"text":"Pub. L. 116–259","children":[],"tail":" amended section generally. Prior to amendment, section established strength and distribution of officers in grades."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
