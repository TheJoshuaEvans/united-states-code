{"tag":"section","attrib":{"id":"id6b9f5c70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1207"},"text":null,"children":[{"tag":"num","attrib":{"value":"1207"},"text":"§ 1207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b9f5c71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating and technical conditions and characteristics; frequencies, emission, and power of radiotelephone equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Communications Commission shall, after consultation with other cognizant agencies, prescribe regulations necessary to specify operating and technical conditions and characteristics including frequencies, emission, and power of radiotelephone equipment required under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b9f5c72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, subject to the concurrence of the Federal Communications Commission, prescribe regulations for the enforcement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b9f5c73-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/63/s8"},"text":"Pub. L. 92–63, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-04"},"text":"Aug. 4, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/165"},"text":"85 Stat. 165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b9f5c74-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b9f5c75-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b9f5c76-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":", or six months after the promulgation of regulations which would implement its provisions, whichever is later, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/63/s10"},"text":"section 10 of Pub. L. 92–63","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
