{"tag":"section","attrib":{"id":"id6b2a7ae7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p"},"text":null,"children":[{"tag":"num","attrib":{"value":"426p"},"text":"§ 426p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps of Engineers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b2a7ae8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and other assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b2a7ae9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide emergency assistance to prevent or reduce damage attributable to high water levels in the Great Lakes, including provision of sandbags, sheeting, and stones and other armoring devices (taking account of flooding and erosion of other property which may be caused by such activity) but not including construction of permanent structures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7aea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to individuals and local governments with respect to measures to prevent or reduce such damage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7aeb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" compile and disseminate information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b2a7aec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water levels of the Great Lakes,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b2a7aed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" techniques for prevention or reduction of such damage, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b2a7aee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency relief available to persons who suffer economic injury attributable to high water levels in the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b2a7aef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of permits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b2a7af0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of flooding and erosion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing a permit under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b2a7af1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s403"},"text":"section 403 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b2a7af2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1344"},"text":"section 1344 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for any activity carried out with assistance under this title, the Secretary of the Army shall take account of flooding and erosion of other property which may be caused by such activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b2a7af3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank stabilization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b2a7af4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In issuing permits under sections 403 and 1344 of this title for a project involving dredging of any portion of the Great Lakes, the Secretary of the Army shall, if feasible, encourage for bank stabilization purposes the disposal of nonhazardous compatible sand from such project on shorelines affected by erosion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b2a7af5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426p/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subparagraph (A), the Secretary of the Army shall consult affected State and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b2a7af6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/tII/s203"},"text":"Pub. L. 100–707, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4712"},"text":"102 Stat. 4712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2a7af7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b2a7af8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b2a7af9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (b)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4711"},"text":"102 Stat. 4711","children":[],"tail":", known as the “Great Lakes Planning Assistance Act of 1988”. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2a7afa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6b2a7afb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/tII/s201"},"text":"Pub. L. 100–707, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4711"},"text":"102 Stat. 4711","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/707/tII/s201"},"text":"“This title [enacting this section, amending sections 3501 to 3503 of Title 16, Conservation, and enacting provisions set out as notes under this section and sections 3501 and 3505 of Title 16] may be cited as the ‘Great Lakes Planning Assistance Act of 1988’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b2a7afc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Great Lakes Damage Assistance and Prevention; Damage Assistance Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/tII/s202"},"text":"Pub. L. 100–707, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4711"},"text":"102 Stat. 4711","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/707/tII/s202"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director is authorized to provide assistance to Great Lakes States in the establishment of State programs to reduce and prevent damage attributable to high water levels in the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon application by a Great Lakes State within 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"], the Director may make a one-time grant to the State of not more than $250,000 for use by the State for—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of plans for mitigation, warning, emergency operations, and emergency assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of available State and Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and implementation of nonstructural measures to reduce or prevent damage attributable to high water levels in the Great Lakes, including establishment of setback requirements and other conditions on construction and reconstruction of public and private facilities, mapping of flooding zones, and technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting local governments in developing and implementing plans for nonstructural reduction and prevention of damages attributable to high water levels in the Great Lakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may provide technical assistance to Great Lakes States for carrying out any activity carried out with assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Matching","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State which receives a grant under this section shall match the grant with an amount of funds from non-Federal sources equal to 25 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated for making grants under this section not more than $2,000,000 for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b2ceafd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Great Lakes Damage Assistance and Prevention; Definitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707/tII/s205"},"text":"Pub. L. 100–707, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4715"},"text":"102 Stat. 4715","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s612/c"},"text":"Pub. L. 109–295, title VI, § 612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1410"},"text":"120 Stat. 1410","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s612/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For purposes of this title [see Short Title note above]—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Director’ means the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High water levels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘high water levels’ means water levels above the long-term average of water levels from 1900.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘local government’ means a county, city, village, town, district, or other political subdivision of a Great Lakes State and an Indian tribe or authorized tribal organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Great lakes state","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Great Lakes State’ means Minnesota, Wisconsin, Illinois, Ohio, Michigan, Indiana, Pennsylvania, and New York.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
