{"tag":"section","attrib":{"id":"id6c86af7f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606"},"text":null,"children":[{"tag":"num","attrib":{"value":"3606"},"text":"§ 3606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c86af80-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-03-30"},"text":"March 30, 2022","children":[],"tail":", and every 5 years thereafter, the Administrator shall prepare, and the President acting through the Council shall approve and transmit to Congress, a report on progress made in implementing this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c86af81-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c86af82-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of activities carried out under this chapter and the System Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af83-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of the System, including an evaluation of progress made by the Council to achieve the goals identified under the System Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af84-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of Federal and non-Federal assets as determined by the Council that have been integrated into the System, including assets essential to the gathering of required observation data variables necessary to meet the respective missions of Council agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af85-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of procurements, planned or initiated, by each department or agency represented on the Council to enhance, expand, or modernize the observation capabilities and data products provided by the System, including data management and communication subsystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af86-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a summary of the existing gaps in observation infrastructure and monitoring data collection, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c86af87-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priorities considered by the System advisory committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c86af88-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national sea surface current mapping network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c86af89-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal buoys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c86af8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ocean chemistry monitoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c86af8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine sound monitoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c86af8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unmanned maritime systems technology gaps;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment regarding activities to integrate Federal and non-Federal assets, nationally and on the regional level, and discussion of the performance and effectiveness of regional coastal observing systems to coordinate regional observation operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af8e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of benefits of the program to users of data products resulting from the System (including the general public, industries, scientists, resource managers, emergency responders, policy makers, and educators);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af8f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations, if any, concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c86af90-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifications to the System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c86af91-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding levels for the System in subsequent fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86af92-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3606/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of a periodic external independent programmatic audit of the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c86af93-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12307"},"text":"Pub. L. 111–11, title XII, § 12307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1435"},"text":"123 Stat. 1435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/271/tI/s105"},"text":"Pub. L. 116–271, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3339"},"text":"134 Stat. 3339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c86af94-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c86af95-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c86af96-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271"},"text":"Pub. L. 116–271","children":[],"tail":" amended section generally. Prior to amendment, section required that no later than 2 years after "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"March 30, 2009","children":[],"tail":", and every 2 years thereafter, the Administrator was to prepare and the President acting through the Council was to approve and transmit to Congress a report on progress made in implementing this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
