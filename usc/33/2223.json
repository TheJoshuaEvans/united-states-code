{"tag":"section","attrib":{"id":"id6c35a8c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223"},"text":null,"children":[{"tag":"num","attrib":{"value":"2223"},"text":"§ 2223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of excess credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c35a8c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c35a8c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary may apply credit for in-kind contributions provided by a non-Federal interest that are in excess of the required non-Federal cost share for a water resources development study or project toward the required non-Federal cost share for a different water resources development study or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c35a8c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application prior to completion of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of a non-Federal interest, the credit described in paragraph (1) may be applied prior to completion of a study or project, if the credit amount is verified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c35a8c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and projects with multiple non-Federal interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A credit described in paragraph (1) for a study or project with multiple non-Federal interests may be applied to the required non-Federal cost share for a study or project of any such non-Federal interest, if each such non-Federal interest agrees in writing to such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c35a8c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c35a8c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for subsection (a)(4)(D)(i) of that section, the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b"},"text":"section 1962d–5b of title 42","children":[],"tail":" (as amended by section 1018(a)) shall apply to any credit under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c35a8ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Credit in excess of the non-Federal share for a study or project may be approved under this section only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c35a8cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the non-Federal interest submits a comprehensive plan to the Secretary that identifies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c35a8cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the studies and projects for which the non-Federal interest intends to provide in-kind contributions for credit that are in excess of the non-Federal cost share for the study or project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c35a8cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorized studies and projects to which that excess credit would be applied;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c35a8ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary approves the comprehensive plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c35a8cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of credit does not exceed the total non-Federal share for the studies and projects in the approved comprehensive plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c35a8d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional approval of excess credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (2)(A)(ii), the Secretary may approve credit in excess of the non-Federal share for a study or project prior to the identification of each authorized study or project to which the excess credit will be applied, subject to the condition that the non-Federal interest agrees to submit for approval by the Secretary an amendment to the comprehensive plan prepared under paragraph (2) that identifies each authorized study or project in advance of execution of the feasibility cost-sharing agreement or project partnership agreement for that authorized study or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c35a8d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating a request to apply credit in excess of the non-Federal share for a study or project toward a different study or project, the Secretary shall consider whether applying that credit will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c35a8d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help to expedite the completion of a project or group of projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c35a8d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce costs to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c35a8d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aid the completion of a project that provides significant flood risk reduction or environmental benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c35a8d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided in this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c35a8d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c35a8d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadlines","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c35a8d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", and once every 2 years thereafter, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives and make publicly available an interim report on the use of the authority under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c35a8d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives and make publicly available a final report on the use of the authority under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c35a8da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reports described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c35a8db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the use of the authority under this section during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c35a8dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact of the authority under this section on the time required to complete projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c35a8dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2223/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact of the authority under this section on other water resources projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c35a8de-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1020"},"text":"Pub. L. 113–121, title I, § 1020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1227"},"text":"128 Stat. 1227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1166"},"text":"Pub. L. 114–322, title I, § 1166","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1670"},"text":"130 Stat. 1670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8383"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3829"},"text":"136 Stat. 3829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tIII/s1303/g"},"text":"Pub. L. 118–272, div. A, title III, § 1303(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3114"},"text":"138 Stat. 3114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c35a8df-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c35a8e0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c35a8e1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1018(a), referred to in subsec. (b)(1), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1018/a"},"text":"section 1018(a) of Pub. L. 113–121","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c35a8e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c35a8e3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (d), (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" substituted “2030” for “2028”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8383/1"},"text":"Pub. L. 117–263, § 8383(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8383/2"},"text":"Pub. L. 117–263, § 8383(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8383/3"},"text":"Pub. L. 117–263, § 8383(3)","children":[],"tail":", substituted “on "},{"tag":"date","attrib":{"date":"2028-12-31"},"text":"December 31, 2028","children":[],"tail":"” for “10 years after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8383/4"},"text":"Pub. L. 117–263, § 8383(4)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2028-12-31"},"text":"December 31, 2028","children":[],"tail":"” for “10 years after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" substituted “Application of credit” for “In general” in subsec. heading, designated existing provisions as par. (1) and inserted par. (1) heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c35a8e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c35a8e5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
