{"tag":"section","attrib":{"id":"id6b5582a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s680"},"text":null,"children":[{"tag":"num","attrib":{"value":"680"},"text":"§ 680.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of mines; reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Said commission, or a committee therefrom, or officer of said corps assigned to duty under its orders, shall, whenever deemed necessary, visit said territory and all mines operating under the provisions of this chapter. A report of such examination shall be placed on file.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5582a4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-01/ch183/s20"},"text":"Mar. 1, 1893, ch. 183, § 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/510"},"text":"27 Stat. 510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5582a5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5582a6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b5582a7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"California Debris Commission abolished and functions transferred to Secretary of the Army by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1106"},"text":"Pub. L. 99–662, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-1