{"tag":"section","attrib":{"id":"id6c24e0e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963"},"text":null,"children":[{"tag":"num","attrib":{"value":"1963"},"text":"§ 1963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and obligations of the Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c24e0e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have perpetual succession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct business throughout the several States, territories, and possessions of the United States and abroad; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall at all times maintain a designated agent authorized to accept service of process for the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The serving of notice to, or service of process upon, the agent required under subsection (a)(3), or mailed to the business address of such agent, shall be deemed as service upon or notice to the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out its purposes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1961"},"text":"section 1961 of this title","children":[],"tail":", the Foundation shall have, in addition to the powers otherwise given it under this title,"},{"tag":"ref","attrib":{"idref":"fn002089"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002089"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the usual powers of a nonprofit corporation formed in the District of Columbia, including the power—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c24e0e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, either absolutely or in trust, of real or personal property or any income therefrom or other interest therein;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire by purchase or exchange any real or personal property or interest therein;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to invest any funds provided to the Foundation by the Federal Government in obligations of the United States or in obligations or securities that are guaranteed or insured by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deposit any funds provided to the Foundation by the Federal Government into accounts that are insured by an agency or instrumentality of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make use of any interest or investment income that accrues as a consequence of actions taken under subparagraph (C) or (D) to carry out the purposes of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use Federal funds to make payments under cooperative agreements to provide substantial long-term benefits for the assessment, prevention, reduction, and removal of marine debris;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise required by the instrument of transfer, to sell, donate, lease, invest, reinvest, retain or otherwise dispose of any property or income therefrom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to borrow money and issue bonds, debentures, or other debt instruments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sue and be sued, and complain and defend itself in any court of competent jurisdiction, except that the Directors of the Foundation shall not be personally liable, except for gross negligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts or other arrangements with, or provide financial assistance to, public agencies and private organizations and persons and to make such payments as may be necessary to carry out its functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to do any and all acts necessary and proper to carry out the purposes of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal contributions to the fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A gift, devise, or bequest may be accepted by the Foundation without regard to whether the gift, devise, or bequest is encumbered, restricted, or subject to beneficial interests of private persons if any current or future interest in the gift, devise, or bequest is for the benefit of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Members of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation may not make a grant of Federal funds in an amount greater than $100,000 unless, by not later than 15 days before the grant is made, the Foundation provides notice of the grant to the Member of Congress for the congressional district in which the project to be funded with the grant will be carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of international efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any efforts of the Foundation carried out in a foreign country, and any grants provided to an individual or entity in a foreign country, shall be made only with the concurrence of the Secretary of State, in consultation, as appropriate, with the Administrator of the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation With NOAA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall consult with the Under Secretary during the planning of any restoration or remediation action using funds resulting from judgments or settlements relating to the damage to trust resources of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall locate the principal office of the Foundation in the National Capital Region, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2674/f/2"},"text":"section 2674(f)(2) of title 10","children":[],"tail":", or a coastal shoreline community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall develop and implement best practices for conducting outreach to Indian Tribes and Tribal Governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The best practices developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c24e0fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a process to support technical assistance and capacity building to improve outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote an awareness of programs and grants available under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to satisfy any requirement for government-to-government consultation with Tribal Governments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e100-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1963/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect or modify any treaty or other right of any Tribal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c24e101-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s113"},"text":"Pub. L. 109–449, § 113","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s113"},"text":"Pub. L. 116–224, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1077"},"text":"134 Stat. 1077","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s113"},"text":"Pub. L. 109–449, § 113","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/a"},"text":"Pub. L. 119–65, § 3(a)","children":[],"tail":", (e)–(g), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":", 1988.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c24e102-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c24e103-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c24e104-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c)(1), means title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1074"},"text":"134 Stat. 1074","children":[],"tail":", which was classified principally to subchapter I (§ 4211 et seq.) of chapter 55 of this title. Subtitles B and C of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" were transferred to subtitles B and C of "},{"tag":"ref","attrib":{"href":"/us/pl/109/449"},"text":"Pub. L. 109–449","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":", §§ 3(a), 4(a), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":", 1989, and are classified to this subchapter and subchapter III of this chapter, respectively. Subtitle A of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" amended sections 1951, 1958, and 1959 of this title, and subtitle D of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" is classified to part C (§ 4251) of subchapter I of chapter 55 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c275105-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4213"},"text":"section 4213 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c275106-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/e"},"text":"Pub. L. 119–65, § 3(e)","children":[],"tail":", substituted “powers of a nonprofit corporation formed” for “powers of a corporation acting as a trustee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/f"},"text":"Pub. L. 119–65, § 3(f)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/g"},"text":"Pub. L. 119–65, § 3(g)","children":[],"tail":", added subsecs. (h) and (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
