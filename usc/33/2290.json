{"tag":"section","attrib":{"id":"id6c4d76a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2290"},"text":null,"children":[{"tag":"num","attrib":{"value":"2290"},"text":"§ 2290.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flood control in Trust Territory of the Pacific Islands","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to use the authority contained in section 205 of the Flood Control Act of 1948 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701s"},"text":"33 U.S.C. 701s","children":[],"tail":"), section 2 of the Flood Control Act of "},{"tag":"date","attrib":{"date":"1937-08-28"},"text":"August 28, 1937","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s701g"},"text":"33 U.S.C. 701g","children":[],"tail":"), section 14 of the Flood Control Act of 1946 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s701r"},"text":"33 U.S.C. 701r","children":[],"tail":"), section 107 of the River and Harbor Act of 1960 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s577"},"text":"33 U.S.C. 577","children":[],"tail":"), section 3 of the Act entitled “An Act authorizing Federal participation in the cost of protecting the shores of publicly owned property”, approved "},{"tag":"date","attrib":{"date":"1946-08-13"},"text":"August 13, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426g"},"text":"33 U.S.C. 426g","children":[],"tail":"), and section 111 of the River and Harbor Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426i"},"text":"33 U.S.C. 426i","children":[],"tail":") in the Trust Territory of the Pacific Islands."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c4d76a5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s915/h"},"text":"Pub. L. 99–662, title IX, § 915(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4191"},"text":"100 Stat. 4191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4d76a6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c4d76a7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c4d76a8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
