{"tag":"section","attrib":{"id":"id6c3f1e62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252"},"text":null,"children":[{"tag":"num","attrib":{"value":"2252"},"text":"§ 2252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project delivery process reforms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3f1e63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for qualifying projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each qualifying project, the Secretary shall require—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1e64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each project manager, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3f1e65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project manager have formal project management training and certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1e66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project manager be assigned from among personnel certified by the Chief of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for an applicable cost estimation, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3f1e68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary utilize a risk-based cost estimate with a confidence level of at least 80 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1e69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the cost estimate be developed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c3f1e6a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a qualifying project that requires an increase in the authorized amount in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2280"},"text":"section 2280 of this title","children":[],"tail":", during the preparation of a post-authorization change report or other similar decision document;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3f1e6b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a qualifying project for which the first construction contract has not been awarded, prior to the award of the first construction contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3f1e6c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a qualifying project without a completed feasibility report in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282"},"text":"section 2282 of this title","children":[],"tail":", prior to the completion of such a report; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c3f1e6d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a qualifying project with a completed feasibility report in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282"},"text":"section 2282 of this title","children":[],"tail":" that has not yet been authorized, during design for the qualifying project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e6e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional project delivery process reforms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1e6f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a system to identify and apply on a continuing basis best management practices from prior or ongoing qualifying projects to improve the likelihood of on-time and on-budget completion of qualifying projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate early contractor involvement acquisition procedures to improve on-time and on-budget project delivery performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implement any additional measures that the Secretary determines will achieve the purposes of this subtitle, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3f1e72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of applicable practices and procedures developed pursuant to management by the Secretary of an applicable military construction program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1e73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of a portfolio of standard designs for inland navigation locks, incorporating the use of a center of expertise for the design and review of qualifying projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1e74-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of full-funding contracts or formulation of a revised continuing contracts clause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1e75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of procedures for recommending new project construction starts using a capital projects business model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1e77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary may carry out pilot projects to evaluate processes and procedures for the study, design, and construction of qualifying projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum, the Secretary shall carry out pilot projects under this subsection to evaluate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3f1e79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early contractor involvement in the development of features and components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1e7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate use of continuing contracts for the construction of features and components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1e7b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2252/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable principles, procedures, and processes used for military construction projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3f1e7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2002"},"text":"Pub. L. 113–121, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1261"},"text":"128 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3f1e7d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3f1e7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c3f1e7f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (b)(3), is subtitle A (§§ 2001–2013) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":", which enacted this section and sections 2253, 2254, and 2255 of this title, amended sections 2212, 2251, and 2327 of this title, and enacted provisions set out as a note under this section. For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3f1e80-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2002"},"text":"section 2002 of Pub. L. 113–121","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2002"},"text":"section 2002 of Pub. L. 113–121","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2251"},"text":"section 2251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3f1e81-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id6c3f1e82-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2001"},"text":"Pub. L. 113–121, title II, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1260"},"text":"128 Stat. 1260","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/121/tII/s2001"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and sections 2211a, 2238b, 2238c, 2243, 2253, 2254, and 2255 of this title and amending sections 2211, 2212, 2238, 2242, 2251, 2282a, and 2327 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505"},"text":"section 9505 of Title 26","children":[],"tail":", Internal Revenue Code]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inland waterways trust fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Inland Waterways Trust Fund’ means the Inland Waterways Trust Fund established by section 9506(a) of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9506/a"},"text":"26 U.S.C. 9506(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘qualifying project’ means any construction or major rehabilitation project for navigation infrastructure of the inland and intracoastal waterways that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized before, on, or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not completed on the date of enactment of this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funded at least in part from the Inland Waterways Trust Fund.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
