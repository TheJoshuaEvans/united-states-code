{"tag":"section","attrib":{"id":"id6b878ee6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s920"},"text":null,"children":[{"tag":"num","attrib":{"value":"920"},"text":"§ 920.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any proceeding for the enforcement of a claim for compensation under this chapter it shall be presumed, in the absence of substantial evidence to the contrary—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b878ee7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s920/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the claim comes within the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b878ee8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s920/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That sufficient notice of such claim has been given.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b878ee9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s920/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the injury was not occasioned solely by the intoxication of the injured employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b878eea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s920/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the injury was not occasioned by the willful intention of the injured employee to injure or kill himself or another.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b878eeb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s20"},"text":"Mar. 4, 1927, ch. 509, § 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1436"},"text":"44 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
