{"tag":"section","attrib":{"id":"id6b25bfec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426c"},"text":null,"children":[{"tag":"num","attrib":{"value":"426c"},"text":"§ 426c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Coastal Engineering Research Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Coastal Engineering Research Center, in making its report on any cooperative investigation and studies under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s426"},"text":"section 426 of this title","children":[],"tail":", relating to shore protection work shall, in addition to any other matters upon which it may be required to report, state its opinion as to (a) the advisability of adopting the project; (b) what public interest, if any, is involved in the proposed improvement; and (c) what share of the expense, if any, should be borne by the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b25bfed-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch334/s3"},"text":"July 31, 1945, ch. 334, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/508"},"text":"59 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/172/s1"},"text":"Pub. L. 88–172, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-07"},"text":"Nov. 7, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/304"},"text":"77 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b25bfee-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b25bfef-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b25bff0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Coastal Engineering Research Center has been substituted for Beach Erosion Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/172/s1"},"text":"Pub. L. 88–172, § 1","children":[],"tail":", providing in part for the abolition of the Beach Erosion Board, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426"},"text":"section 426 of this title","children":[],"tail":". For transfer of investigatory functions of the Beach Erosion Board to the Coastal Engineering Research Center see "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426–1"},"text":"section 426–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
