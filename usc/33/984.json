{"tag":"section","attrib":{"id":"id6b8eba3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984"},"text":null,"children":[{"tag":"num","attrib":{"value":"984"},"text":"§ 984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers of Corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b8eba3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of carrying out its functions under this chapter the Corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b8eba3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have succession in its corporate name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt and use a corporate seal, which shall be judicially noticed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may sue and be sued in its corporate name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba40-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt, amend, and repeal bylaws, rules, and regulations governing the manner in which its business may be conducted and the powers vested in it may be exercised;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba41-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make and carry out such contracts or agreements as are necessary or advisable in the conduct of its business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba42-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be held to be an inhabitant and resident of the northern judicial district of New York within the meaning of the laws of the United States relating to venue of civil suits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba43-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may appoint and fix the compensation, in accordance with the provisions of chapter 51 and subchapter III of chapter 53 of title 5, of such officers, attorneys, and employees as may be necessary for the conduct of its business, define their authority and duties, and delegate to them such of the powers vested in the Corporation as the Administrator may determine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba44-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may acquire, by purchase, lease, condemnation, or donation such real and personal property and any interest therein, and may sell, lease, or otherwise dispose of such real and personal property, as the Administrator deems necessary for the conduct of its business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba45-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine the character of and the necessity for its obligations and expenditures, and the manner in which they shall be incurred, allowed and paid, subject to provisions of law specifically applicable to Government corporations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba46-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may retain toll revenues for purposes of eventual reinvestment in the Seaway.","children":[{"tag":"ref","attrib":{"idref":"fn002042"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002042"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide services and facilities necessary in the maintenance and operation of the seaway, including but not limited to providing, at reasonable prices, services to vessels using the seaway and to visitors to the seaway, but not to include overnight housing accommodations for visitors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may participate with the Saint Lawrence Seaway Authority of Canada, or its designee, in the ownership and operation of a toll bridge company: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the United States’ portion of the revenue from the tolls charged to the users of any toll bridge operated under this section shall be applied solely to the cost of the bridge and approaches, including maintenance and operation, amortization of principal and interest, as established by the Secretary of the Treasury; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002043"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. There are two pars. designated (13)."}],"tail":" shall be credited with amounts received from any of the activities authorized by clauses (10) and (11) "},{"tag":"ref","attrib":{"idref":"fn002044"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" Clauses (10), (11), and (12) redesignated (11), (12), and (13) by "},{"tag":"ref","attrib":{"href":"/us/pl/97/369"},"text":"Pub. L. 97–369","children":[],"tail":"."}],"tail":" of this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b8eba4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" shall accept such amounts as may be transferred to the Corporation under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505/c/1"},"text":"section 9505(c)(1) of title 26","children":[],"tail":", except that such amounts shall be available only for the purpose of operating and maintaining those works which the Corporation is obligated to operate and maintain under subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s983"},"text":"section 983 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b8eba4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s984/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts credited under subsection (a)(12) ","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":" are available to pay any obligation or expense of the Corporation under this chapter, except as specifically provided in subsection (a)(11)."},{"tag":"sup","attrib":{},"text":"3","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b8eba4c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/ch201/s4"},"text":"May 13, 1954, ch. 201, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/94"},"text":"68 Stat. 94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/108/s1/1"},"text":"Pub. L. 85–108, § 1(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1957-07-17"},"text":"July 17, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/307"},"text":"71 Stat. 307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s232"},"text":"Pub. L. 92–310, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/214"},"text":"86 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/369/tIII/s311"},"text":"Pub. L. 97–369, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-18"},"text":"Dec. 18, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1783"},"text":"96 Stat. 1783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s805/a/1"},"text":"Pub. L. 99–662, title XIV, § 805(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4272"},"text":"100 Stat. 4272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b8eba4d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b8eba4e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b8eba4f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(7), “chapter 51 and subchapter III of chapter 53 of title 5” substituted for “the Classification Act of 1949” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b8eba50-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" added par. (13) relating to acceptance of amounts transferred to the Corporation under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505/c"},"text":"section 9505(c) of title 26","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(10) to (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/369"},"text":"Pub. L. 97–369","children":[],"tail":" added par. (10) and redesignated former pars. (10) to (12) as (11) to (13), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out provisions which empowered the Corporation to require bonds from such officers, attorneys, and employees as the Administrator might designate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1957—Subsecs. (a)(10) to (12), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/108"},"text":"Pub. L. 85–108","children":[],"tail":" added pars. (10) to (12) and subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b8eba51-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b8eba52-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s805/b"},"text":"Pub. L. 99–662, title XIV, § 805(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4272"},"text":"100 Stat. 4272","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/662/tXIV/s805/b"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s988a"},"text":"section 988a of this title","children":[],"tail":" and amending this section] shall take effect on "},{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
