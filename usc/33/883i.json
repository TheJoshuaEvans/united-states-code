{"tag":"section","attrib":{"id":"id6b76c5bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s883i"},"text":null,"children":[{"tag":"num","attrib":{"value":"883i"},"text":"§ 883i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such funds as may be necessary to acquire, construct, maintain, and operate ships, stations, equipment, and facilities and for such other expenditures, including personal services at the seat of government and elsewhere and including the erection of temporary observatory buildings and lease of sites therefor, as may be necessary for the conduct of the activities herein authorized.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b76c5c0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-06/ch504/s9"},"text":"Aug. 6, 1947, ch. 504, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/788"},"text":"61 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b76c5c1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b76c5c2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b76c5c3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Herein, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-06/ch504"},"text":"act Aug. 6, 1947, ch. 504","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/787"},"text":"61 Stat. 787","children":[],"tail":", which is classified generally to this subchapter (§ 883a et seq.). For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
