{"tag":"section","attrib":{"id":"id6c43d9db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2281a"},"text":"§ 2281a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal Liaison","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c43d9dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the District Commander for each Corps of Engineers district that contains a Tribal community shall have on staff a Tribal Liaison."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c43d9dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Tribal Liaison shall make recommendations to the applicable District Commander regarding, and be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c43d9de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removing barriers to access to, and participation in, Corps of Engineers programs for Tribal communities, including by improving implementation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213/m"},"text":"section 2213(m) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving outreach to, and engagement with, Tribal communities about relevant Corps of Engineers programs and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and engaging with Tribal communities suffering from water resources challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving, expanding, and facilitating government-to-government consultation between Tribal communities and the Corps of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating and implementing all relevant Tribal consultation policies and associated guidelines, including the requirements of section 2356 of title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and tools to facilitate the ability of Corps of Engineers staff to effectively engage with Tribal communities in a culturally competent manner, especially in regards to lands of ancestral, historic, or cultural significance to a Tribal community, including burial sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other issues identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c43d9e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniformity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall finalize guidelines for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c43d9e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position description for Tribal Liaisons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required qualifications for Tribal Liaisons, including experience and expertise relating to Tribal communities and water resource issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c43d9e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding for the position of Tribal Liaison shall be allocated from the budget line item provided for the expenses necessary for the supervision and general administration of the civil works program, and filling the position shall not be dependent on any increase in this budget line item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c43d9e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c43d9ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal community” means a community of people who are recognized and defined under Federal law as indigenous people of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal Liaison","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Tribal Liaison” means a permanent employee of a Corps of Engineers district whose primary responsibilities are to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c43d9ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a direct line of communication between the District Commander and the Tribal communities within the boundaries of the Corps of Engineers district; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43d9ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure consistency in government-to-government relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c43d9ee-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8112"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3704"},"text":"136 Stat. 3704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c43d9ef-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c43d9f0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c43d9f1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2022, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c43d9f2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c43d9f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8002"},"text":"section 8002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
