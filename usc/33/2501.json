{"tag":"section","attrib":{"id":"id6c62faef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2501"},"text":null,"children":[{"tag":"num","attrib":{"value":"2501"},"text":"§ 2501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62faf0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The washing ashore of potentially infectious medical wastes from public vessels of the United States may pose serious and widespread risks to public health and to the welfare of coastal communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faf1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current Federal law provides inadequate protections against the disposal of such wastes from such vessels into ocean waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faf2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators of such vessels must take immediate action to stop disposing of such wastes into ocean waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62faf3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIII/s3102"},"text":"Pub. L. 100–688, title III, § 3102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4152"},"text":"102 Stat. 4152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c62faf4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c62faf5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c62faf6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIII/s3101"},"text":"Pub. L. 100–688, title III, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4152"},"text":"102 Stat. 4152","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/688/tIII/s3101"},"text":"“This subtitle [subtitle A (§§ 3101–3105) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688"},"text":"Pub. L. 100–688","children":[],"tail":", enacting this chapter] may be cited as the ‘United States Public Vessel Medical Waste Anti-Dumping Act of 1988’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
