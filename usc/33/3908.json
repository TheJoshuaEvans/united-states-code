{"tag":"section","attrib":{"id":"id6c904baa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908"},"text":null,"children":[{"tag":"num","attrib":{"value":"3908"},"text":"§ 3908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secured loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c904bab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), the Secretary or the Administrator, as applicable, may enter into agreements with 1 or more obligors to make secured loans, the proceeds of which shall be used to finance eligible project costs of any project selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3907"},"text":"section 3907 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial risk assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before entering into an agreement under this subsection for a secured loan, the Secretary or the Administrator, as applicable, in consultation with the Director of the Office of Management and Budget and each rating agency providing a rating opinion letter under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3907/a/1/D"},"text":"section 3907(a)(1)(D) of this title","children":[],"tail":", shall determine an appropriate capital reserve subsidy amount for the secured loan, taking into account each such rating opinion letter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment-grade rating requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The execution of a secured loan under this section shall be contingent on receipt by the senior obligations of the project of an investment-grade rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904baf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bb0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A secured loan provided for a project under this section shall be subject to such terms and conditions, and contain such covenants, representations, warranties, and requirements (including requirements for audits), as the Secretary or the Administrator, as applicable, determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bb1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a secured loan under this section shall not exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bb2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 49 percent of the reasonably anticipated eligible project costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bb3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the secured loan does not receive an investment-grade rating, the amount of the senior project obligations of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bb4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A secured loan under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bb5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be payable, in whole or in part, from State or local taxes, user fees, or other dedicated revenue sources that also secure the senior project obligations of the relevant project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bb6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a rate covenant, coverage requirement, or similar security feature supporting the project obligations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bb7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may have a lien on revenues described in subparagraph (A), subject to any lien securing project obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bb8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interest rate on a secured loan under this section shall be not less than the yield on United States Treasury securities of a similar maturity to the maturity of the secured loan on the date of execution of the loan agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bb9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maturity date","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final maturity date of a secured loan under this section shall be the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904bbb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 35 years after the date of substantial completion of the relevant project (as determined by the Secretary or the Administrator, as applicable); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904bbc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the useful life of the project (as determined by the Secretary or Administrator, as applicable) is less than 35 years, the useful life the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bbd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for State infrastructure financing authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The final maturity date of a secured loan to a State infrastructure financing authority under this section shall be not later than 35 years after the date on which amounts are first disbursed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bbe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsubordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A secured loan under this section shall not be subordinated to the claims of any holder of project obligations in the event of bankruptcy, insolvency, or liquidation of the obligor of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bbf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bc0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary or the Administrator, as applicable, may establish fees at a level sufficient to cover all or a portion of the costs to the Federal Government of making a secured loan under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bc1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of an eligible entity, the Secretary or the Administrator, as applicable, shall allow the fees under subparagraph (A) to be financed as part of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bc2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds of a secured loan under this section may be used to pay any non-Federal share of project costs required if the loan is repayable from non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bc3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum Federal involvement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bc4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), for each project for which assistance is provided under this chapter, the total amount of Federal assistance shall not exceed 80 percent of the total project cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bc5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to any rural water project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904bc6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is authorized to be carried out by the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904bc7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes among its beneficiaries a federally recognized Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904bc8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the authorized Federal share of the total project costs is greater than the amount described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bc9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for projects funded by a State infrastructure financing authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), a State infrastructure financing authority may finance up to 100 percent of the costs of a project using the proceeds of financial assistance authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3912/e"},"text":"section 3912(e) of this title","children":[],"tail":", provided that, in the event of a default with respect to any such assistance, the State infrastructure financing authority is solely responsible for immediate repayment of such costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible project costs incurred and the value of any integral in-kind contributions made before receipt of assistance under this chapter shall be credited toward the 51 percent of project costs to be provided by sources of funding other than a secured loan under this chapter (as described in paragraph (2)(A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bcb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bcc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, shall establish a repayment schedule for each secured loan provided under this section, based on the projected cash flow from project revenues and other repayment sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bcd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Scheduled loan repayments of principal or interest on a secured loan under this section shall commence not later than 5 years after the date of substantial completion of the project (as determined by the Secretary or Administrator, as applicable).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bcf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for State infrastructure financing authorities","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904bd0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of scheduled loan repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Scheduled loan repayments of principal or interest on a secured loan to a State infrastructure financing authority under this chapter shall commence not later than 5 years after the date on which amounts are first disbursed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904bd1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds for repayment of a secured loan under this title from a State infrastructure financing authority may come from funds provided to a State revolving loan fund under title VI of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"33 U.S.C. 1381","children":[],"tail":" et seq.) or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bd2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bd3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, at any time after the date of substantial completion of a project for which a secured loan is provided under this section, the project is unable to generate sufficient revenues to pay the scheduled loan repayments of principal and interest on the secured loan, the Secretary or the Administrator, as applicable, subject to subparagraph (C), may allow the obligor to add unpaid principal and interest to the outstanding balance of the secured loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bd4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any payment deferred under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904bd5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to accrue interest in accordance with subsection (b)(4) until fully repaid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904bd6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be scheduled to be amortized over the remaining term of the secured loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bd7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904bd8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment deferral under subparagraph (A) shall be contingent on the project meeting such criteria as the Secretary or the Administrator, as applicable, may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904bd9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria established under clause (i) shall include standards for reasonable assurance of repayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bda-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904bdb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of excess revenues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any excess revenues that remain after satisfying scheduled debt service requirements on the project obligations and secured loan and all deposit requirements under the terms of any trust agreement, bond resolution, or similar agreement securing project obligations may be applied annually to prepay a secured loan under this section without penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904bdc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds of refinancing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A secured loan under this section may be prepaid at any time without penalty from the proceeds of refinancing from non-Federal funding sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904bdd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of secured loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904bde-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), as soon as practicable after the date of substantial completion of a project and after providing a notice to the obligor, the Secretary or the Administrator, as applicable, may sell to another entity or reoffer into the capital markets a secured loan for a project under this section, if the Secretary or the Administrator, as applicable, determines that the sale or reoffering can be made on favorable terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904bdf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of obligor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a sale or reoffering under paragraph (1), the Secretary or the Administrator, as applicable, may not change the original terms and conditions of the secured loan without the written consent of the obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904be0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904be1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as applicable, may provide a loan guarantee to a lender in lieu of making a secured loan under this section, if the Secretary or the Administrator, as applicable, determines that the budgetary cost of the loan guarantee is substantially the same as that of a secured loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904be2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3908/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms of a loan guarantee provided under this subsection shall be consistent with the terms established in this section for a secured loan, except that the rate on the guaranteed loan and any prepayment features shall be negotiated between the obligor and the lender, with the consent of the Secretary or the Administrator, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c904be3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5029"},"text":"Pub. L. 113–121, title V, § 5029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1338"},"text":"128 Stat. 1338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5008/c"},"text":"Pub. L. 114–322, title IV, § 5008(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1897"},"text":"130 Stat. 1897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4201/a/3"},"text":"Pub. L. 115–270, title IV, § 4201(a)(3)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3877"},"text":"132 Stat. 3877","children":[],"tail":", 3878.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c904be4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c904be5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c904be6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c)(2)(B)(ii), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1322"},"text":"128 Stat. 1322","children":[],"tail":". Subtitle C (§§ 5021–5035) of title V of "},{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" enacted this chapter. For complete classification of title V to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (c)(2)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":". Title VI of the Act is classified generally to subchapter VI (§ 1381 et seq.) of chapter 26 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c904be7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(9)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/b/1"},"text":"Pub. L. 115–270, § 4201(b)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/a/3"},"text":"Pub. L. 115–270, § 4201(a)(3)","children":[],"tail":", designated existing provisions as cl. (i), inserted heading, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5008/c/1"},"text":"Pub. L. 114–322, § 5008(c)(1)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, substituted “Except as provided in subparagraph (B), the Secretary” for “The Secretary”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s5008/c/2"},"text":"Pub. L. 114–322, § 5008(c)(2)","children":[],"tail":", added par. (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c904be8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c904be9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
