{"tag":"section","attrib":{"id":"id6b3d8d47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d"},"text":null,"children":[{"tag":"num","attrib":{"value":"535d"},"text":"§ 535d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitting for international bridges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b3d8d48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3d8d49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible applicant” means an entity that has submitted an application for a Presidential permit during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-12-01"},"text":"December 1, 2020","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":", for any of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b3d8d4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more international bridges in Webb County, Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3d8d4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An international bridge in Cameron County, Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3d8d4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An international bridge in Maverick County, Texas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential permit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b3d8d4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Presidential permit” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b3d8d4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an approval by the President to construct, maintain, and operate an international bridge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s535b"},"text":"section 535b of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b3d8d50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an approval by the President to construct, maintain, and operate an international bridge pursuant to a process described in Executive Order 13867 (84 Fed. Reg. 15491; relating to Issuance of Permits With Respect to Facilities and Land Transportation Crossings at the International Boundaries of the United States) (or any successor Executive Order).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3d8d51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Presidential permit” includes an amendment to an approval described in clause (i) or (ii) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3d8d53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible applicant for a Presidential permit to construct, maintain, and operate an international bridge shall submit an application for the permit to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3d8d54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3d8d55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Secretary receives an application under subsection (b), the Secretary shall make a recommendation to the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b3d8d56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to grant the Presidential permit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3d8d57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deny the Presidential permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The basis for a recommendation under paragraph (1) shall be whether the international bridge is in the foreign policy interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3d8d59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3d8d5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall grant or deny the Presidential permit for an application under subsection (b) by not later than 60 days after the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b3d8d5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Secretary makes a recommendation under subsection (c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3d8d5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Secretary is required to make a recommendation under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No action","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b3d8d5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), if the President does not grant or deny the Presidential permit for an application under subsection (b) by the deadline described in paragraph (1), the Presidential permit shall be considered to have been granted as of that deadline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b3d8d5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition on a Presidential permit considered to be granted under subparagraph (A), the eligible applicant shall complete all applicable environmental documents required pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3d8d60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Document requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall not require an eligible applicant for a Presidential permit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3d8d61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to include in the application under subsection (b) environmental documents prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have completed any environmental review under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) prior to the President granting a Presidential permit under subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3d8d63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3d8d64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits the President from granting a Presidential permit conditioned on the eligible applicant completing all environmental documents pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and complying with relevant laws;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits the Secretary from requesting a list of all permits and approvals from Federal, State, and local agencies that the eligible applicant believes are required in connection with the international bridge, or a brief description of how those permits and approvals will be acquired prior to making a recommendation to the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempts an eligible applicant from the requirement to complete all environmental documents pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) prior to construction of an international bridge; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3d8d67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535d/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempts an eligible applicant from complying with ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) or any other law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b3d8d68-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/434/s6"},"text":"Pub. L. 92–434, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLIV/s5414"},"text":"Pub. L. 118–31, div. E, title LIV, § 5414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/954"},"text":"137 Stat. 954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3d8d69-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3d8d6a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b3d8d6b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13867, referred to in subsec. (a)(2)(A)(ii), is Ex. Ord. No. 13867, ","children":[{"tag":"date","attrib":{"date":"2019-04-10"},"text":"Apr. 10, 2019","children":[],"tail":", 84 F.R. 15491, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Public Law 91–190","children":[],"tail":", referred to in subsecs. (d)(2)(B), (e), and (f), is "},{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", known as the National Environmental Policy Act of 1969, which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b3d8d6c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 535d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/434/s6"},"text":"Pub. L. 92–434, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-26"},"text":"Sept. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/732"},"text":"86 Stat. 732","children":[],"tail":", directed that tolls charged for use of an international bridge constructed or acquired under this subchapter by private individual, company, or other private entity be collected for a reasonable period for amortization of construction or acquisition costs, plus interest and reasonable return, that at end of such period the United States portion of bridge become the property of the State having jurisdiction over such United States portion, and that accurate records on expenditures and tolls collected be kept and annually reported to Secretary of Transportation, with authority for Secretary to conduct audits, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI/s135/g"},"text":"Pub. L. 100–17, title I, § 135(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/174"},"text":"101 Stat. 174","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
