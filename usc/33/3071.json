{"tag":"section","attrib":{"id":"id6c785768-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071"},"text":null,"children":[{"tag":"num","attrib":{"value":"3071"},"text":"§ 3071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions of title 10","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c785769-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions made applicable to the corps","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules of law that apply to the Armed Forces under the following provisions of title 10, as those provisions are in effect from time to time, apply also to the commissioned officer corps of the Administration:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78576a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 40, relating to leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78576b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 533(b), relating to constructive service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78576c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 716, relating to transfers between the armed forces and to and from National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tai