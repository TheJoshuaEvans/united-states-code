{"tag":"section","attrib":{"id":"id6c9506fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004"},"text":null,"children":[{"tag":"num","attrib":{"value":"4004"},"text":"§ 4004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Northern Gulf of Mexico hypoxia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9506ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial progress reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", and biennially thereafter, the Administrator, through the Mississippi River/Gulf of Mexico Watershed Nutrient Task Force, shall submit a progress report to the appropriate congressional committees and the President that describes the progress made by activities directed by the Mississippi River/Gulf of Mexico Watershed Nutrient Task Force and carried out or funded by the Environmental Protection Agency and other State and Federal partners toward attainment of the goals of the Gulf Hypoxia Action Plan 2008."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c950700-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c950701-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the progress made toward nutrient load reductions, the response of the hypoxic zone and water quality throughout the Mississippi/Atchafalaya River Basin, and the economic and social effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950702-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate lessons learned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950703-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4004/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend appropriate actions to continue to implement or, if necessary, revise the strategy set forth in the Gulf Hypoxia Action Plan 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c950704-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tVI/s604"},"text":"Pub. L. 105–383, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3449"},"text":"112 Stat. 3449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/124/s7"},"text":"Pub. L. 113–124, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1384"},"text":"128 Stat. 1384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c950705-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c950706-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c950707-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"section 1451 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c950708-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/124"},"text":"Pub. L. 113–124","children":[],"tail":" amended section generally. Prior to amendment, section required the Task Force to submit an integrated assessment of hypoxia in the northern Gulf of Mexico and develop a plan for reducing, mitigating, and controlling such hypoxia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
