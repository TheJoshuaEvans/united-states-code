{"tag":"section","attrib":{"id":"id6c0f83db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1483"},"text":null,"children":[{"tag":"num","attrib":{"value":"1483"},"text":"§ 1483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign government ships; immunity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No measures may be taken under authority of this chapter against any warship or other ship owned or operated by a country and used, for the time being, only on Government noncommercial service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c0f83dc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s14"},"text":"Pub. L. 93–248, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/10"},"text":"88 Stat. 10","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
