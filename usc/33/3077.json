{"tag":"section","attrib":{"id":"id6c7857bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077"},"text":null,"children":[{"tag":"num","attrib":{"value":"3077"},"text":"§ 3077.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education loan repayment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7857bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to repay education loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of maintaining adequate numbers of officers of the commissioned officer corps of the Administration on active duty who have skills required by the commissioned officer corps, the Secretary may repay, in the case of a person described in subsection (b), a loan that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was used by the person to finance education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was obtained from a governmental entity, private financial institution, educational institution, or other authorized entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to obtain a loan repayment under this section, a person must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfy one of the requirements specified in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be fully qualified for, or hold, an appointment as a commissioned officer in the commissioned officer corps of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sign a written agreement to serve on active duty, or, if on active duty, to remain on active duty for a period in addition to any other incurred active duty obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic and professional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"One of the following academic requirements must be satisfied for purposes of determining the eligibility of an individual for a loan repayment under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is fully qualified in a profession that the Secretary has determined to be necessary to meet identified skill shortages in the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is enrolled as a full-time student in the final year of a course of study at an accredited educational institution (as determined by the Secretary of Education) leading to a degree in a profession that will meet identified skill shortages in the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan repayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the limits established under paragraph (2), a loan repayment under this section may consist of the payment of the principal, interest, and related expenses of a loan obtained by a person described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each year of obligated service that a person agrees to serve in an agreement described in subsection (b)(3), the Secretary may pay not more than the amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2173/e/2"},"text":"section 2173(e)(2) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Active duty service obligation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person entering into an agreement described in subsection (b)(3) incurs an active duty service obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of obligation determined under regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7857cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the length of the obligation under paragraph (1) shall be determined under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7857cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations prescribed under subparagraph (A) may not provide for a period of obligation of less than one year for each maximum annual amount, or portion thereof, paid on behalf of the person for qualified loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons on active duty before entering into agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The active duty service obligation of persons on active duty before entering into the agreement shall be served after the conclusion of any other obligation incurred under the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent completion of service obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A service obligation under this section may be completed concurrently with a service obligation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3006"},"text":"section 3006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure to complete obligation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer who is relieved of the officer’s active duty obligation under this section before the completion of that obligation may be given any alternative obligation, at the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer who does not complete the period of active duty specified in the agreement entered into under subsection (b)(3), or the alternative obligation imposed under paragraph (1), shall be subject to the repayment provisions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3006"},"text":"section 3006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for qualified loans and authorized payees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3077/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other terms and conditions for the making of loan repayments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7857d6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s267"},"text":"Pub. L. 107–372, title II, § 267","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tII/s201/a"},"text":"Pub. L. 116–259, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1160"},"text":"134 Stat. 1160","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
