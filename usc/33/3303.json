{"tag":"section","attrib":{"id":"id6c7f82d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303"},"text":"§ 3303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory and inspection of levees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7f82d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levee database","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Secretary shall establish and maintain a database with an inventory of the Nation’s levees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The database shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location information of all Federal levees in the Nation (including global information system information) and updated levee information provided by States, regional districts, Indian tribes, Federal agencies, and other entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizing such information as is available, the general condition of each levee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the number of structures and population at risk and protected by each levee that would be adversely impacted if the levee fails or water levels exceed the height of the levee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to Federal, State, regional, tribal, and local governmental agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make all of the information in the database available to appropriate Federal, State, regional, tribal, and local governmental agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to the public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make the information in the database described in paragraph (2)(A), and such other information in the database as the Secretary determines appropriate, available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory and inspection of levees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal levees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, at Federal expense, shall establish an inventory and conduct an inspection of all federally owned and operated levees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally constructed, nonfederally operated and maintained levees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an inventory and conduct an inspection of all federally constructed, non-federally operated and maintained levees, at the original cost share for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating levees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For non-Federal levees the owners of which are participating in the emergency response to natural disasters program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s701n"},"text":"section 701n of this title","children":[],"tail":", the Secretary shall establish an inventory and conduct an inspection of each such levee if the owner of the levee requests such inspection. The Federal share of the cost of an inspection under this paragraph shall be 65 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levee review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a one-time inventory and review of all levees identified in the national levee database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No Federal interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The inventory and inspection under paragraph (1) does not create a Federal interest in the construction, operation, or maintenance of any levee that is included in the inventory or inspected under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the inventory and review, the Secretary shall use the levee safety action classification criteria to determine whether a levee should be classified in the inventory as requiring a more comprehensive inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, regional, and tribal participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of a State, regional district, or Indian tribe with respect to any levee subject to review under this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow an official of the State, regional district, or Indian tribe to participate in the review of the levee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to the State, regional district, or Indian tribe relating to the location, construction, operation, or maintenance of the levee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the inventory and review under this subsection, the Secretary shall not be required to review any levee that has been inspected by a State, regional district, or Indian tribe using the same methodology described in paragraph (3) during the 1-year period immediately preceding ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", if the Governor of the State or chief executive of the regional district or tribal government, as applicable, requests an exemption from the review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of deficiencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each levee included in an inventory established under subsection (b) or for which the Secretary has conducted a review under subsection (c), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the specific engineering and maintenance deficiencies, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the recommended remedies to correct each deficiency identified under subparagraph (A), and, if requested by owner of a non-Federal levee, the associated costs of those remedies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In identifying deficiencies and describing remedies for a levee under paragraph (1), the Secretary shall consult with relevant non-Federal interests, including by providing an opportunity for comment by those non-Federal interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7f82ef-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIX/s9004"},"text":"Pub. L. 110–114, title IX, § 9004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1290"},"text":"121 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3016/d"},"text":"Pub. L. 113–121, title III, § 3016(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1292"},"text":"128 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1130/b"},"text":"Pub. L. 114–322, title I, § 1130(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1650"},"text":"130 Stat. 1650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s131"},"text":"Pub. L. 116–260, div. AA, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2644"},"text":"134 Stat. 2644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7f82f0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7f82f1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c7f82f2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/b/1/A"},"text":"Pub. L. 114–322, § 1130(b)(1)(A)","children":[],"tail":", substituted “1 year after "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":",” for “one year after "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"November 8, 2007","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/b/1/B"},"text":"Pub. L. 114–322, § 1130(b)(1)(B)","children":[],"tail":", substituted “States, regional districts, Indian tribes, Federal agencies, and other entities” for “States, Indian tribes, Federal agencies, and other entities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/b/1/C"},"text":"Pub. L. 114–322, § 1130(b)(1)(C)","children":[],"tail":", substituted “Federal, State, regional, tribal, and local” for “Federal, State, and local” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/b/2/A"},"text":"Pub. L. 114–322, § 1130(b)(2)(A)","children":[],"tail":", substituted “State, regional, and tribal” for “State and tribal” in heading and “State, regional district, or Indian tribe” for “State or Indian tribe” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/b/2/B"},"text":"Pub. L. 114–322, § 1130(b)(2)(B)","children":[],"tail":", substituted “State, regional district, or Indian tribe” for “State or Indian tribe” and “chief executive of the regional district or tribal government” for “chief executive of the tribal government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/d/1"},"text":"Pub. L. 113–121, § 3016(d)(1)","children":[],"tail":", substituted “and updated levee information provided by States, Indian tribes, Federal agencies, and other entities” for “and, for non-Federal levees, such information on levee location as is provided to the Secretary by State and local governmental agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/d/2"},"text":"Pub. L. 113–121, § 3016(d)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c7f82f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c7f82f4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
