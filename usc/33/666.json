{"tag":"section","attrib":{"id":"id6b558261-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s666"},"text":null,"children":[{"tag":"num","attrib":{"value":"666"},"text":"§ 666.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noting conditions of navigable channels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The said commission shall from time to time note the conditions of the navigable channels of said river systems, by cross-section surveys or otherwise, in order to ascertain the effect therein of such hydraulic mining operations as may be permitted by its orders and such as is caused by erosion, natural or otherwise.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b558262-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-01/ch183/s6"},"text":"Mar. 1, 1893, ch. 183, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/508"},"text":"27 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b558263-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b558264-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b558265-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"California Debris Commission abolished and functions transferred to Secretary of the Army by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1106"},"text":"Pub. L. 99–662, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4229"},"text":"100 Stat. 4229","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
