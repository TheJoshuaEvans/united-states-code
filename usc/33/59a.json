{"tag":"section","attrib":{"id":"id6b0b813c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59a"},"text":null,"children":[{"tag":"num","attrib":{"value":"59a"},"text":"§ 59a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Back Cove, Portland, Maine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b0b813d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion declared nonnavigable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That portion of Back Cove at Portland, Maine, lying southerly of a line across the twelve-foot Federal project channel in Back Cove twenty-five hundred feet upstream from the Tukey Bridge, to the head of Back Cove, is declared to be a nonnavigable water of the United States within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b0b813e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion abandoned","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That portion of the twelve-foot Federal project channel in Back Cove lying southerly of a line across the channel twenty-five hundred feet upstream from the Tukey Bridge, to the head of Back Cove, a distance of approximately thirty-five hundred feet, is abandoned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b0b813f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of right to alter, amend or repeal section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b0b8140-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/126"},"text":"Pub. L. 85–126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-13"},"text":"Aug. 13, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/344"},"text":"71 Stat. 344","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
