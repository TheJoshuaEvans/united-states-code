{"tag":"section","attrib":{"id":"id6c950730-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005"},"text":null,"children":[{"tag":"num","attrib":{"value":"4005"},"text":"§ 4005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes hypoxia and harmful algal blooms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c950731-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", the Task Force, in accordance with the authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4001"},"text":"section 4001 of this title","children":[],"tail":", shall complete and submit to the Congress and the President an integrated assessment that examines the causes, consequences, and approaches to reduce hypoxia and harmful algal blooms in the Great Lakes, including the status of and gaps within current research, monitoring, management, prevention, response, and control activities by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c950732-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950733-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950734-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional research consortia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950735-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950736-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950737-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c950738-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c950739-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", the Task Force shall develop and submit to the Congress a plan, based on the integrated assessment under subsection (a), for reducing, mitigating, and controlling hypoxia and harmful algal blooms in the Great Lakes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c95073a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c95073b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the monitoring needs identified in the integrated assessment under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95073c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a timeline and budgetary requirements for deployment of future assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95073d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify requirements for the development and verification of Great Lakes hypoxia and harmful algal bloom models, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c95073e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all assumptions built into the models; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c95073f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data quality methods used to ensure the best available data are utilized; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950740-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe efforts to improve the assessment of the impacts of hypoxia and harmful algal blooms by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c950741-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" characterizing current and past biological conditions in ecosystems affected by hypoxia and harmful algal blooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c950742-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantifying effects, including economic effects, at the population and community levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c950743-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the plan, the Task Force shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c950744-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with State and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950745-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with representatives from academic, agricultural, industry, and other stakeholder groups, including relevant Canadian agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950746-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the plan complements and does not duplicate activities conducted by other Federal or State agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950747-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify critical research for reducing, mitigating, and controlling hypoxia events and their effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950748-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate cost-effective, incentive-based partnership approaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c950749-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the plan is technically sound and cost effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95074a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize existing research, assessments, reports, and program activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95074b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a summary of the proposed plan in the Federal Register at least 180 days prior to submitting the completed plan to Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c95074c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4005/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after submitting the completed plan to Congress, provide biennial progress reports on the activities toward achieving the objectives of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c95074d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tVI/s606"},"text":"Pub. L. 105–383, title VI, § 606","children":[],"tail":", formerly § 605, "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3449"},"text":"112 Stat. 3449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/456/tI/s105"},"text":"Pub. L. 108–456, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3633"},"text":"118 Stat. 3633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dB/tV/s528"},"text":"Pub. L. 110–161, div. B, title V, § 528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1930"},"text":"121 Stat. 1930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/124/s8"},"text":"Pub. L. 113–124, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1384"},"text":"128 Stat. 1384","children":[],"tail":"; renumbered § 606, "},{"tag":"ref","attrib":{"href":"/us/pl/117/144/s2/a/1"},"text":"Pub. L. 117–144, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1266"},"text":"136 Stat. 1266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c95074e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c95074f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c950750-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"section 1451 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c950751-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s606"},"text":"section 606 of Pub. L. 105–383","children":[],"tail":" was renumbered section 607 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4006"},"text":"section 4006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c950752-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/124"},"text":"Pub. L. 113–124","children":[],"tail":" amended section generally. Prior to amendment, section authorized appropriations for research, education, and monitoring activities related to the prevention, reduction, and control of harmful algal blooms and hypoxia for fiscal years 1999 to 2010."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s528/1"},"text":"Pub. L. 110–161, § 528(1)","children":[],"tail":", substituted “$30,000,000 for each of fiscal years 2008 through 2010” for “$25,500,000 for fiscal year 2008” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s528/2"},"text":"Pub. L. 110–161, § 528(2)","children":[],"tail":", substituted “2010” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s528/3"},"text":"Pub. L. 110–161, § 528(3)","children":[],"tail":", substituted “each of fiscal years 2008 through 2010” for “fiscal year 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s528/2"},"text":"Pub. L. 110–161, § 528(2)","children":[],"tail":", substituted “2010” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/456/s105/1"},"text":"Pub. L. 108–456, § 105(1)","children":[],"tail":", (2), in introductory provisions, struck out “and” after “2000,” and inserted “$23,500,000 for fiscal year 2005, $24,500,000 for fiscal year 2006, $25,000,000 for fiscal year 2007, and $25,500,000 for fiscal year 2008,” after “2001,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/456/s105/1"},"text":"Pub. L. 108–456, § 105(1)","children":[],"tail":", (3), struck out “and” after “2000,” and inserted “, and $2,500,000 for each of fiscal years 2005 through 2008” after “2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/456/s105/1"},"text":"Pub. L. 108–456, § 105(1)","children":[],"tail":", (4), struck out “and” after “2000,” and inserted “, and $6,500,000, of which $1,000,000 shall be used for the research program described in section 603(f)(2)(B), for each of fiscal years 2005 through 2008” after “2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/456/s105/1"},"text":"Pub. L. 108–456, § 105(1)","children":[],"tail":", (5), (6), struck out “and” after “2000,” and substituted “2001, and $3,000,000 for each of fiscal years 2005 through 2008” for “2001” and “blooms and to carry out section 603(d);” for “blooms;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/456/s105/7"},"text":"Pub. L. 108–456, § 105(7)","children":[],"tail":", substituted “2001, and $6,000,000 for each of fiscal years 2005 through 2008” for “and 2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/456/s105/1"},"text":"Pub. L. 108–456, § 105(1)","children":[],"tail":", (9), struck out “and” after “2000,” and substituted “2001, $4,000,000 for fiscal year 2005, $5,000,000 for fiscal year 2006, $5,500,000 for fiscal year 2007, and $6,000,000 for fiscal year 2008” for “2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/456/s105/8"},"text":"Pub. L. 108–456, § 105(8)","children":[],"tail":", (10), (11), added par. (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
