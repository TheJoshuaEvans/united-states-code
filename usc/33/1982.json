{"tag":"section","attrib":{"id":"id6c2751c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1982"},"text":null,"children":[{"tag":"num","attrib":{"value":"1982"},"text":"§ 1982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to Outer Continental Shelf Lands Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter supersedes, or limits the authority of the Secretary of the Interior under, the Outer Continental Shelf Lands Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"43 U.S.C. 1331","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c2751c5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s132"},"text":"Pub. L. 109–449, § 132","children":[],"tail":", formerly § 8, "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3339"},"text":"120 Stat. 3339","children":[],"tail":"; renumbered § 132, "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s4/b/1"},"text":"Pub. L. 119–65, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1989"},"text":"139 Stat. 1989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c2751c6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c2751c7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c2751c8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","chi