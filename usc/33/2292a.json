{"tag":"section","attrib":{"id":"id6c4d76b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2292a"},"text":"§ 2292a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National coastal mapping program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c4d76b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to carry out a national coastal mapping program to provide recurring national coastal mapping along the coasts of the United States to support Corps of Engineers navigation, flood risk management, environmental restoration, and emergency operations missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4d76b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c4d76ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall disseminate coastal mapping data and new or advanced geospatial information and remote sensing tools for coastal mapping derived from the analysis of such data to the Corps of Engineers, other Federal agencies, States, and other stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall implement coastal surveying based on findings of the national coastal mapping study carried out under section 8110 of the Water Resources Development Act of 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/136/3702"},"text":"136 Stat. 3702","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall conduct research and development on bathymetric liDAR and ancillary technologies necessary to advance coastal mapping capabilities in order to exploit data with increased efficiently and greater accuracy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to any region affected by a hurricane rated category 3 or higher, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c4d76be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct coastal mapping of such region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4d76bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine volume changes at Federal projects in such region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4d76c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantify damage to navigation infrastructure in such region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4d76c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess environmental impacts to such region, measure any coastal impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c4d76c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any data gathered under this paragraph publicly available not later than 2 weeks after the acquisition of such data;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of another Federal entity or a State or local government entity, may provide subject matter expertise, mapping services, and technology evolution assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into an agreement with another Federal agency or a State agency to accept funds from such agency to expand the coverage of the program to efficiently meet the needs of such agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall coordinate with representatives of the Naval Meteorology and Oceanography Command, the National Oceanic and Atmospheric Administration, United States Geological Survey, and any other representative of a Federal agency that the Secretary determines necessary, to support any relevant Federal, State, or local agency through participation in working groups, committees, and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may maintain the panel of senior leaders established under section 8110(e) of the Water Resources Development Act of 2022; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c4d76c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may convene an annual coastal mapping community of practice meeting to discuss and identify technical topics and challenges to inform such panel in carrying out the duties of such panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c4d76c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2292a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section for each fiscal year $15,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c4d76c9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1123"},"text":"Pub. L. 118–272, div. A, title I, § 1123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3015"},"text":"138 Stat. 3015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4d76ca-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c4d76cb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c4d76cc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 8110 of the Water Resources Development Act of 2022, referred to in subsec. (b)(2), (8), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8110"},"text":"section 8110 of title LXXXI of div. H of Pub. L. 117–263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3702"},"text":"136 Stat. 3702","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c4d76cd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2024, and also as part of the Thomas R. Carper Water Resources Development Act of 2024, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c4d76ce-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c4d76cf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/s1002"},"text":"section 1002 of div. A of Pub. L. 118–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
