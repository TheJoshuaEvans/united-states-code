{"tag":"section","attrib":{"id":"id6b093700-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s36"},"text":null,"children":[{"tag":"num","attrib":{"value":"36"},"text":"§ 36.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mosquito Creek, South Carolina","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Mosquito Creek, in Colleton County, South Carolina, is declared to be a nonnavigable stream within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b093701-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-08-08/ch49/s15"},"text":"Aug. 8, 1917, ch. 49, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/268"},"text":"40 Stat. 268","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
