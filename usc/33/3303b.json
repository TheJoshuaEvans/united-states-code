{"tag":"section","attrib":{"id":"id6c81f472-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303b"},"text":"§ 3303b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c81f473-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State of levees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f474-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", and biennially thereafter, the Secretary in coordination with the committee, shall submit to Congress and make publicly available a report describing the state of levees in the United States and the effectiveness of the levee safety initiative, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c81f475-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress achieved in implementing the levee safety initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c81f476-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, regional, and tribal participation in the levee safety initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c81f477-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations to improve coordination of levee safety, floodplain management, and environmental protection concerns, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c81f478-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and evaluating opportunities to coordinate public safety, floodplain management, and environmental protection activities relating to levees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c81f479-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating opportunities to coordinate environmental permitting processes for operation and maintenance activities at existing levee projects in compliance with all applicable laws; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c81f47a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for legislation and other congressional actions necessary to ensure national levee safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f47b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under paragraph (1) shall include a report of the committee that describes the independent recommendations of the committee for the implementation of the levee safety initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f47c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National dam and levee safety program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", to the maximum extent practicable, the Secretary and the Administrator, in coordination with the committee, shall submit to Congress and make publicly available a report that includes recommendations regarding the advisability and feasibility of, and potential approaches for, establishing a joint national dam and levee safety program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f47d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alignment of Federal programs relating to levees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Comptroller General of the United States shall submit to Congress a report on opportunities for alignment of Federal programs to provide incentives to State, regional, tribal, and local governments and individuals and entities—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f47e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote shared responsibility for levee safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f47f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the development of strong State, regional, and tribal levee safety programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f480-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to better align the levee safety initiative with other Federal flood risk management programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f481-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote increased levee safety through other Federal programs providing assistance to State, regional, tribal, and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f482-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for certain levee engineering projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Secretary shall submit to Congress and make publicly available a report that includes recommendations that identify and address any legal liability associated with levee engineering projects that prevent—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f483-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levee owners from obtaining needed levee engineering services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f484-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3303b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and implementation of a State, regional, or tribal levee safety program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c81f485-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIX/s9006"},"text":"Pub. L. 110–114, title IX, § 9006","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3016/e/2"},"text":"Pub. L. 113–121, title III, § 3016(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1299"},"text":"128 Stat. 1299","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1130/d"},"text":"Pub. L. 114–322, title I, § 1130(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1652"},"text":"130 Stat. 1652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c81f486-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c81f487-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c81f488-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s9006"},"text":"section 9006 of Pub. L. 110–114","children":[],"tail":" was renumbered section 9008, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3305"},"text":"section 3305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c81f489-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/d/1/A"},"text":"Pub. L. 114–322, § 1130(d)(1)(A)","children":[],"tail":", substituted “1 year after "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"” for “1 year after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/d/1/B"},"text":"Pub. L. 114–322, § 1130(d)(1)(B)","children":[],"tail":", substituted “State, regional, and tribal” for “State and tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/d/2/A"},"text":"Pub. L. 114–322, § 1130(d)(2)(A)","children":[],"tail":", in introductory provisions, substituted “2 years after "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"” for “2 years after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"” and “State, regional, tribal, and local” for “State, tribal, and local”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/d/2/B"},"text":"Pub. L. 114–322, § 1130(d)(2)(B)","children":[],"tail":", substituted “State, regional, and tribal” for “State and tribal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/d/2/C"},"text":"Pub. L. 114–322, § 1130(d)(2)(C)","children":[],"tail":", substituted “State, regional, tribal, and local” for “State and local”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/d/3/A"},"text":"Pub. L. 114–322, § 1130(d)(3)(A)","children":[],"tail":", substituted “1 year after "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"” for “1 year after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1130/d/3/B"},"text":"Pub. L. 114–322, § 1130(d)(3)(B)","children":[],"tail":", substituted “State, regional, or tribal” for “State or tribal”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c81f48a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c81f48b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
