{"tag":"section","attrib":{"id":"id6b1c493d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s382"},"text":null,"children":[{"tag":"num","attrib":{"value":"382"},"text":"§ 382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure of piratical vessels generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to instruct the commanders of the public armed vessels of the United States to subdue, seize, take, and send into any port of the United States, any armed vessel or boat, or any vessel or boat, the crew whereof shall be armed, and which shall have attempted or committed any piratical aggression, search, restraint, depredation, or seizure, upon any vessel of the United States, or of the citizens thereof, or upon any other vessel; and also to retake any vessel of the United States, or its citizens, which may have been unlawfully captured upon the high seas.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c493e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4294.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c493f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c4940-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c4941-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4294 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1819-03-03/ch77/s2"},"text":"Mar. 3, 1819, ch. 77, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/512"},"text":"3 Stat. 512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1823-01-30/ch7"},"text":"Jan. 30, 1823, ch. 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/721"},"text":"3 Stat. 721","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
