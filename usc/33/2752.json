{"tag":"section","attrib":{"id":"id6c6ee1b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752"},"text":null,"children":[{"tag":"num","attrib":{"value":"2752"},"text":"§ 2752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c6ee1b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), amounts in the Fund shall be available only as provided in annual appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee1b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6ee1ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c6ee1bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2706(f), 2712(a)(4), or 2736 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6ee1bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an amount, which may not exceed $50,000,000 in any fiscal year, made available by the President from the Fund—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c6ee1bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321/c"},"text":"section 1321(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c6ee1be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to initiate the assessment of natural resources damages required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2706"},"text":"section 2706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6ee1bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund advances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c6ee1c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that the amount described in subparagraph (B) of paragraph (1) is not adequate to carry out the activities described in such subparagraph, the Coast Guard may obtain 1 or more advances from the Fund as may be necessary, up to a maximum of $100,000,000 for each advance, with the total amount of advances not to exceed the amounts available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9509/c/2"},"text":"section 9509(c)(2) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6ee1c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date on which the Coast Guard obtains an advance under subparagraph (A), the Coast Guard shall notify Congress of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c6ee1c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount advanced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c6ee1c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facts and circumstances that necessitated the advance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6ee1c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts advanced under this paragraph shall be repaid to the Fund when, and to the extent that, removal costs are recovered by the Coast Guard from responsible parties for the discharge or substantial threat of discharge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6ee1c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2752/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts to which this subsection applies shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c6ee1c6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tVI/s6002"},"text":"Pub. L. 101–380, title VI, § 6002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/555"},"text":"104 Stat. 555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1102/c/1"},"text":"Pub. L. 104–324, title XI, § 1102(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3966"},"text":"110 Stat. 3966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIII/s323"},"text":"Pub. L. 107–295, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2104"},"text":"116 Stat. 2104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/191/s1"},"text":"Pub. L. 111–191, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-06-15"},"text":"June 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1278"},"text":"124 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/212/tII/s2001"},"text":"Pub. L. 111–212, title II, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2337"},"text":"124 Stat. 2337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11313"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4086"},"text":"136 Stat. 4086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c6ee1c7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c6ee1c8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c6ee1c9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (b) and struck out former subsec. (b) which related to exceptions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/212"},"text":"Pub. L. 111–212","children":[],"tail":", which directed amendment of second sentence by inserting “: (1)” before “may obtain an advance from the Fund” and substituting “advance; (2) in the case of discharge of oil that began in 2010 in connection with the explosion on, and sinking of, the mobile offshore drilling unit Deepwater Horizon, may, without further appropriation, obtain one or more advances from the Oil Spill Liability Trust Fund as needed, up to a maximum of $100,000,000 for each advance, the total amount of all advances not to exceed the amounts available under section 9509(c)(2) of the Internal Revenue Code of 1986 ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9509/c/2"},"text":"26 U.S.C. 9509(c)(2)","children":[],"tail":"), and within 7 days of each advance, shall notify Congress of the amount advanced and the facts and circumstances necessitating the advance; and (3) amounts” for “advance. Amounts”, could not be executed because of prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/111/191"},"text":"Pub. L. 111–191","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/191"},"text":"Pub. L. 111–191","children":[],"tail":", in second sentence, inserted “(1)” after “Coast Guard” and “and (2) in the case of the discharge of oil that began in 2010 in connection with the explosion on, and sinking of, the mobile offshore drilling unit Deepwater Horizon, may, without further appropriation, obtain 1 or more advances from the Fund as needed, up to a maximum of $100,000,000 for each advance, with the total amount of all advances not to exceed the amounts available under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9509/c/2"},"text":"section 9509(c)(2) of title 26","children":[],"tail":", and within 7 days of each advance, shall notify Congress of the amount advanced and the facts and circumstances necessitating the advance” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" inserted after first sentence “To the extent that such amount is not adequate, the Coast Guard may obtain an advance from the Fund of such sums as may be necessary, up to a maximum of $100,000,000, and within 30 days shall notify Congress of the amount advanced and the facts and circumstances necessitating the advance. Amounts advanced shall be repaid to the Fund when, and to the extent that, removal costs are recovered by the Coast Guard from responsible parties for the discharge or substantial threat of discharge.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" substituted “2736” for “2736(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c6ee1ca-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6c6ee1cb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c712abc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id6c712abd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (b) of this section delegated to Secretary of Department in which Coast Guard is operating by section 7(a)(1)(B) of Ex. Ord. No. 12777, ","children":[{"tag":"date","attrib":{"date":"1991-10-18"},"text":"Oct. 18, 1991","children":[],"tail":", 56 F.R. 54766, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
