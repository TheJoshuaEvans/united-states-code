{"tag":"section","attrib":{"id":"id6b0b8119-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s48"},"text":null,"children":[{"tag":"num","attrib":{"value":"48"},"text":"§ 48.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noxubee River, Mississippi","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"That portion of the Noxubee River in Noxubee County, in the State of Mississippi is declared to be a nonnavigable stream within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right of Congress to amend or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b811a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-02-24/ch25"},"text":"Feb. 24, 1934, ch. 25","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/48/356"},"text":"48 Stat. 356","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
