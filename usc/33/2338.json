{"tag":"section","attrib":{"id":"id6c5bcf7c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338"},"text":null,"children":[{"tag":"num","attrib":{"value":"2338"},"text":"§ 2338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reburial and conveyance authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5bcf7d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcf7e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reburial","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bcf7f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reburial areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with affected Indian tribes, the Secretary may identify and set aside areas at civil works projects of the Department of the Army that may be used to rebury Native American remains that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5bcf80-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been discovered on project land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bcf81-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been rightfully claimed by a lineal descendant or Indian tribe in accordance with applicable Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcf82-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reburial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with and with the consent of the lineal descendant or the affected Indian tribe, the Secretary may recover and rebury, at Federal expense, the remains at the areas identified and set aside under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcf83-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bcf84-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), notwithstanding any other provision of law, the Secretary may convey to an Indian tribe for use as a cemetery an area at a civil works project that is identified and set aside by the Secretary under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcf85-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2338/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of necessary property interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall retain any necessary right-of-way, easement, or other property interest that the Secretary determines to be necessary to carry out the authorized purposes of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5bcf86-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s208"},"text":"Pub. L. 106–541, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2590"},"text":"114 Stat. 2590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5bcf87-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5bcf88-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5bcf89-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2000, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5bcf8a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5bcf8b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s2"},"text":"section 2 of Pub. L. 106–541","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
