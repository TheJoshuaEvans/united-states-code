{"tag":"section","attrib":{"id":"id6c62fa9a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356"},"text":null,"children":[{"tag":"num","attrib":{"value":"2356"},"text":"§ 2356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project consultation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c62fa9b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit the following reports:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa9c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report required under section 1214 of the Water Resources Development Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/132/3809"},"text":"132 Stat. 3809","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa9d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report required under section 1120(a)(3) of the Water Resources Development Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/130/1643"},"text":"130 Stat. 1643","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa9e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental justice updates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa9f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the formulation of water development resources projects, the Secretary shall comply with any existing Executive order regarding environmental justice in effect as of ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", to address any disproportionate and adverse human health or environmental effects on minority communities, low-income communities, and Indian Tribes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faa0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall review, and shall update, where appropriate, any policies, regulations, and guidance of the Corps of Engineers necessary to implement any Executive order described in paragraph (1) with respect to water resources development projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faa1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In updating the policies, regulations, or guidance under paragraph (2), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62faa2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice to interested non-Federal stakeholders, including representatives of minority communities, low-income communities, and Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62faa3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for interested stakeholders to comment on potential updates of policies, regulations, or guidance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62faa4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the recommendations from the reports submitted under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62faa5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the meaningful involvement of minority communities, low-income communities, and Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62faa6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community engagement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a water resources development project, the Secretary shall, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62faa7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the meaningful involvement of minority communities, low-income communities, and Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faa8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance and technical assistance to such communities or Tribes to increase understanding of the project development and implementation activities, regulations, and policies of the Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faa9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with State, Tribal, and local governments with respect to activities carried out pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62faaa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal lands and consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out water resources development projects, the Secretary shall, to the extent practicable and in accordance with the Tribal Consultation Policy affirmed and formalized by the Secretary on ","children":[{"tag":"date","attrib":{"date":"2012-11-01"},"text":"November 1, 2012","children":[],"tail":" (or a successor policy)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62faab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote meaningful involvement with Indian Tribes specifically on any Tribal lands near or adjacent to any water resources development projects, for purposes of identifying lands of ancestral, cultural, or religious importance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with Indian Tribes specifically on any Tribal areas near or adjacent to any water resources development projects, for purposes of identifying lands, waters, and other resources critical to the livelihood of the Indian Tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62faad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2356/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with Indian Tribes to avoid, or otherwise find alternate solutions with respect to, such areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62faae-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s112"},"text":"Pub. L. 116–260, div. AA, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2625"},"text":"134 Stat. 2625","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c62faaf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c62fab0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c62fab1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1214 of the Water Resources Development Act of 2018, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1214"},"text":"section 1214 of Pub. L. 115–270","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3768"},"text":"132 Stat. 3768","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1120(a)(3) of the Water Resources Development Act of 2016, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1120/a/3"},"text":"section 1120(a)(3) of Pub. L. 114–322","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1632"},"text":"130 Stat. 1632","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c62fab2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of the Water Resources Development Act of 2020, and not as a part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c62fab3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c62fab4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
