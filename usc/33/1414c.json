{"tag":"section","attrib":{"id":"id6c0d11cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1414c"},"text":"§ 1414c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on disposal of sewage sludge at landfills on Staten Island","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0d11cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall dispose of sewage sludge at any landfill located on Staten Island, New York.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0d11cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0d11ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), a person who violates this section shall not be subject to any penalty under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0d11cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not prohibit the bringing of an action for, or the granting of, an injunction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1415"},"text":"section 1415 of this title","children":[],"tail":" with respect to a violation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0d11d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1414c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Sewage sludge” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “sewage sludge” has the meaning such term has in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1414b"},"text":"section 1414b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0d11d1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tI/s104C"},"text":"Pub. L. 92–532, title I, § 104C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/688/tI/s1005"},"text":"Pub. L. 100–688, title I, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4150"},"text":"102 Stat. 4150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0d11d2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0d11d3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c0d11d4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532"},"text":"Pub. L. 92–532","children":[],"tail":", which is classified generally to this chapter, chapter 41 (§ 2801 et seq.) of this title, and chapters 32 (§ 1431 et seq.) and 32A (§ 1447 et seq.) of Title 16, Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
