{"tag":"section","attrib":{"id":"id6bc3388b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1294"},"text":null,"children":[{"tag":"num","attrib":{"value":"1294"},"text":"§ 1294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information and education on recycling and reuse of wastewater, use of land treatment, and reduction of wastewater volume","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop and operate within one year of ","children":[{"tag":"date","attrib":{"date":"1977-12-27"},"text":"December 27, 1977","children":[],"tail":", a continuing program of public information and education on recycling and reuse of wastewater (including sludge), the use of land treatment, and methods for the reduction of wastewater volume."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6bc3388c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 214, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/217/s38"},"text":"Pub. L. 95–217, § 38","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-27"},"text":"Dec. 27, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1581"},"text":"91 Stat. 1581","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
