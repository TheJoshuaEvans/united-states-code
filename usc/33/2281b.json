{"tag":"section","attrib":{"id":"id6c43d9f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2281b"},"text":"§ 2281b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps of Engineers support for underserved communities; outreach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c43d9f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States for the Corps of Engineers to strive to understand and accommodate and, in coordination with non-Federal interests, seek to address the water resources development needs of all communities in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c43d9f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c43d9f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, at Federal expense, develop, support, and implement public awareness, education, and regular outreach and engagement efforts for potential non-Federal interests with respect to the water resources development authorities of the Secretary, with particular emphasis on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c43d9f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" technical service programs, including the authorities under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c43d9f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s709a"},"text":"section 709a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c43d9fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–16"},"text":"section 1962d–16 of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c43d9fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2269"},"text":"section 2269 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43d9fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing authority programs, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d/c/1/D"},"text":"section 2282d(c)(1)(D) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43d9fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that a potential non-Federal interest is aware of the roles, responsibilities, and financial commitments associated with a completed water resources development project prior to initiating a feasibility study (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2215/d"},"text":"section 2215(d) of this title","children":[],"tail":"), including operations, maintenance, repair, replacement, and rehabilitation responsibilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43d9fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c43d9ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and make publicly available (including on a publicly available website), technical assistance materials, guidance, and other information with respect to the water resources development authorities of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43da00-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designate and make publicly available a community project advisor at each district and division office of the Corps of Engineers for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c43da01-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inquiries from potential non-Federal interests relating to the water resources development authorities of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c43da02-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other responsibilities as determined by the Secretary that are appropriate to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43da03-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct regular outreach and engagement, including through hosting seminars and community information sessions, with local elected officials, community organizations, and previous and potential non-Federal interests, on opportunities to address local water resources challenges through the water resources development authorities of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43da04-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidance for, and provide technical assistance through technical service programs to, non-Federal interests to assist such interests in pursuing technical services and developing proposals for water resources development projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43da05-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, at the request of a non-Federal interest, assistance with researching and identifying existing project authorizations or authorities to address local water resources challenges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c43da06-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the maximum extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c43da07-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and continue to make publicly available, through a publicly available existing website, information on the projects and studies within the jurisdiction of each district of the Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c43da08-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the information described in clause (i) is consistent and made publicly available in the same manner across all districts of the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da09-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and issue guidance to ensure that community project advisors designated under paragraph (2)(B) are adequately fulfilling their obligations under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da0a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall, to the maximum extent practicable, prioritize awareness, education, and outreach and engagement to economically disadvantaged communities (as defined by the Secretary under section 160 of the Water Resources Development Act of 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"33 U.S.C. 2201","children":[],"tail":" note)), including economically disadvantaged communities located in urban and rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c43da0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $30,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c43da0c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8117"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3709"},"text":"136 Stat. 3709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1101/a"},"text":"Pub. L. 118–272, div. A, title I, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2996"},"text":"138 Stat. 2996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c43da0d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c43da0e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c43da0f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 160 of the Water Resources Development Act of 2020, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s160"},"text":"section 160 of div. AA of Pub. L. 116–260","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c43da10-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2022, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c43da11-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1101/a/1"},"text":"Pub. L. 118–272, § 1101(a)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1101/a/2/A"},"text":"Pub. L. 118–272, § 1101(a)(2)(A)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “establish and make publicly available (including on a publicly available website), an appropriate point of contact at each district and division office of the Corps of Engineers for inquiries from potential non-Federal interests relating to the water resources development authorities of the Secretary;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1101/a/2/B"},"text":"Pub. L. 118–272, § 1101(a)(2)(B)","children":[],"tail":"–(D), added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1101/a/3"},"text":"Pub. L. 118–272, § 1101(a)(3)","children":[],"tail":", (4), added par. (3) and redesignated former pars. (3) and (4) as (4) and (5), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c43da12-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c43da13-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tribal and Economically Disadvantaged Communities Advisory Committee","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8115"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3707"},"text":"136 Stat. 3707","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dH/tLXXXI/s8115"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary [of the Army] shall establish a committee, to be known as the ‘Tribal and Economically Disadvantaged Communities Advisory Committee’, to develop and make recommendations to the Secretary and the Chief of Engineers on activities and actions that should be undertaken by the Corps of Engineers to ensure more effective delivery of water resources development projects, programs, and other assistance to Indian Tribes and economically disadvantaged communities, including economically disadvantaged communities located in urban and rural areas."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of members, appointed by the Secretary, who have the requisite experiential or technical knowledge needed to address issues related to the water resources needs and challenges of economically disadvantaged communities and Indian Tribes, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 individuals representing organizations with expertise in environmental policy, rural water resources, economically disadvantaged communities, Tribal rights, or civil rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 individuals, each representing a non-Federal interest for a Corps of Engineers project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall provide advice and make recommendations to the Secretary and the Chief of Engineers to assist the Corps of Engineers in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficiently and effectively delivering solutions to the needs and challenges of water resources development projects for economically disadvantaged communities and Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating consideration of economically disadvantaged communities and Indian Tribes, where applicable, in the development of water resources development projects and programs of the Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the capability and capacity of the workforce of the Corps of Engineers to assist economically disadvantaged communities and Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall meet as appropriate to develop and make recommendations under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Recommendations made under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in a report submitted to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made publicly available, including on a publicly available website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Judgment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any recommendation made by the Committee to the Secretary and the Chief of Engineers under subsection (c)(1) shall reflect the independent judgment of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (3), the members of the Committee shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The members of the Committee shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The members of the Committee shall not be considered to be Federal employees, and the meetings and reports of the Committee shall not be considered a major Federal action under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Committee’ means the Tribal and Economically Disadvantaged Communities Advisory Committee established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Economically disadvantaged community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘economically disadvantaged community’ has the meaning given the term as defined by the Secretary under section 160 of the Water Resources Development Act of 2020 [div. AA of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"33 U.S.C. 2201","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Indian Tribe’ has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c43da14-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8002"},"text":"section 8002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
