{"tag":"section","attrib":{"id":"id6b3417c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g"},"text":null,"children":[{"tag":"num","attrib":{"value":"467g"},"text":"§ 467g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b3417c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in cooperation with the Board, shall carry out a program of technical and archival research to develop and support—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b3417c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved techniques, historical experience, and equipment for rapid and effective dam construction, rehabilitation, and inspection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3417c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" devices for the continued monitoring of the safety of dams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3417c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and maintenance of information resources systems needed to support managing the safety of dams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b3417c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives to guide the formulation of effective public policy and advance improvements in dam safety engineering, security, and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b3417c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide for State participation in research under subsection (a) and periodically advise all States and Congress of the results of the research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b3417c9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s9"},"text":"Pub. L. 92–367, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s215/c/8"},"text":"Pub. L. 104–303, title II, § 215(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3692"},"text":"110 Stat. 3692","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/310/s4"},"text":"Pub. L. 107–310, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2453"},"text":"116 Stat. 2453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3001/a/1"},"text":"Pub. L. 113–121, title III, § 3001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1282"},"text":"128 Stat. 1282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3417ca-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3417cb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b3417cc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 467g, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s8"},"text":"Pub. L. 92–367, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXII/s1201/b"},"text":"Pub. L. 99–662, title XII, § 1201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4261"},"text":"100 Stat. 4261","children":[],"tail":", set out the requisite features of State dam safety programs and provided for program approval and periodic review, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s215/c/2"},"text":"Pub. L. 104–303, title II, § 215(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3685"},"text":"110 Stat. 3685","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s9"},"text":"section 9 of Pub. L. 92–367","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s467h"},"text":"section 467h of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b3417cd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" substituted “Administrator” for “Director” in introductory provisions of subsec. (a) and in subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/310/s4/1"},"text":"Pub. L. 107–310, § 4(1)","children":[],"tail":", in introductory provisions, substituted “in cooperation with the Board” for “in cooperation with ICODS” and inserted “and support” after “develop”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/310/s4/2"},"text":"Pub. L. 107–310, § 4(2)","children":[],"tail":"–(4), added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
