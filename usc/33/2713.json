{"tag":"section","attrib":{"id":"id6c69ff19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713"},"text":null,"children":[{"tag":"num","attrib":{"value":"2713"},"text":"§ 2713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c69ff1a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), all claims for removal costs or damages shall be presented first to the responsible party or guarantor of the source designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2714/a"},"text":"section 2714(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c69ff1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation to Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c69ff1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Claims for removal costs or damages may be presented first to the Fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c69ff1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President has advertised or otherwise notified claimants in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2714/c"},"text":"section 2714(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c69ff1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a responsible party who may assert a claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2708"},"text":"section 2708 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c69ff1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Governor of a State for removal costs incurred by that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c69ff20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a United States claimant in a case where a foreign offshore unit has discharged oil causing damage for which the Fund is liable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2712/a"},"text":"section 2712(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c69ff21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on presenting claim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No claim of a person against the Fund may be approved or certified during the pendency of an action by the person in court to recover costs which are the subject of the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c69ff22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a claim is presented in accordance with subsection (a) and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c69ff23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person to whom the claim is presented denies all liability for the claim, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c69ff24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim is not settled by any person by payment within 90 days after the date upon which (A) the claim was presented, or (B) advertising was begun pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2714/b"},"text":"section 2714(b) of this title","children":[],"tail":", whichever is later,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the claimant may elect to commence an action in court against the responsible party or guarantor or to present the claim to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c69ff25-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uncompensated damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a claim is presented in accordance with this section, including a claim for interim, short-term damages representing less than the full amount of damages to which the claimant ultimately may be entitled, and full and adequate compensation is unavailable, a claim for the uncompensated damages and removal costs may be presented to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c69ff26-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2713/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for claims against Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall promulgate, and may from time to time amend, regulations for the presentation, filing, processing, settlement, and adjudication of claims under this Act against the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c69ff27-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tI/s1013"},"text":"Pub. L. 101–380, title I, § 1013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/501"},"text":"104 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1142/b"},"text":"Pub. L. 104–324, title XI, § 1142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3991"},"text":"110 Stat. 3991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVII/s708/a"},"text":"Pub. L. 108–293, title VII, § 708(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1077"},"text":"118 Stat. 1077","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8303(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4692"},"text":"134 Stat. 4692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c69ff28-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c69ff29-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c69ff2a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":", known as the Oil Pollution Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c69ff2b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" struck out subsec. (f) which related to loan program to provide interim assistance to fishermen and aquaculture producer claimants during the claims procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" added subsec.(f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" substituted “section, including a claim for interim, short-term damages representing less than the full amount of damages to which the claimant ultimately may be entitled,” for “section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c69ff2c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id6c69ff2d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (e) of this section delegated to Secretary of Department in which Coast Guard is operating by section 7(c)(2) of Ex. Ord. No. 12777, ","children":[{"tag":"date","attrib":{"date":"1991-10-18"},"text":"Oct. 18, 1991","children":[],"tail":", 56 F.R. 54767, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
