{"tag":"section","attrib":{"id":"id6c9507cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular assessment of unmanned maritime systems to support National Oceanic and Atmospheric Administration missions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9507d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, acting through the Assistant Administrator for Oceanic and Atmospheric Research and the Assistant Administrator of the National Oceanic and Atmospheric Administration for Marine and Aviation Operations and the National Oceanic and Atmospheric Administration Commissioned Officer Corps, shall regularly assess publicly and commercially available unmanned maritime systems for potential use to support missions of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science-based assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall carry out subsection (a) through the Assistant Administrator for all matters relating to assessment of the suitability, feasibility, and cost-effectiveness of unmanned maritime systems to meet data specifications required by programs of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of operational utility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall carry out subsection (a) through the Director for all matters relating to assessment of whether unmanned maritime systems are operationally reliable, feasible, and cost effective enough to make observations required by programs of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Administrator and the Director shall jointly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9507d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene and consult the Unmanned Maritime Systems Ocean Technology Coordinating Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4102/b"},"text":"section 4102(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the heads of other offices of the Administration, the academic sector, and developers and manufacturers of unmanned maritime systems to conduct the assessments under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9507d6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/394/s4"},"text":"Pub. L. 115–394, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5284"},"text":"132 Stat. 5284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8401/a/2"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8401(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1908"},"text":"139 Stat. 1908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c9507d7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c9507d8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c9507d9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “Assistant Administrator of the National Oceanic and Atmospheric Administration for” for “Director of the Office of”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
