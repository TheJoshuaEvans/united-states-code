{"tag":"section","attrib":{"id":"id6b76c651-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891f"},"text":null,"children":[{"tag":"num","attrib":{"value":"891f"},"text":"§ 891f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In implementing the NOAA fleet replacement and modernization program, the Secretary, acting through the Assistant Administrator of NOAA for Marine and Aviation Operations, shall use excess capacity of UNOLS vessels where appropriate and may enter into memoranda of agreement with the operators of these vessels to carry out this requirement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b76c652-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVI/s608"},"text":"Pub. L. 102–567, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4303"},"text":"106 Stat. 4303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8402/a/4"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8402(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1910"},"text":"139 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b76c653-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b76c654-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b76c655-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out subsec. (a) designation and heading “Vessel Agreements” and struck out subsec. (b), which required the Comptroller General to provide a report within one year after "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":" comparing the cost-efficiency, accounting, and operating practices of the vessels of NOAA, UNOLS, other Federal agencies, and the United States private sector in meeting the missions of NOAA."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
