{"tag":"section","attrib":{"id":"id6b237595-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s418"},"text":null,"children":[{"tag":"num","attrib":{"value":"418"},"text":"§ 418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions for protection of New York Harbor unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in sections 401, 403, 404, 406, 407, 408, 409, 411 to 416, and 502 of this title shall be construed as repealing, modifying, or in any manner affecting the provisions of subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b237596-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch425/s20/a"},"text":"Mar. 3, 1899, ch. 425, § 20(a)","children":[],"tail":", formerly § 20, "},{"tag":"ref","attrib":{"href":"/us/stat/30/1154"},"text":"30 Stat. 1154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1900-02-20/ch23/s3"},"text":"Feb. 20, 1900, ch. 23, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/32"},"text":"31 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-13/ch1079/s12"},"text":"June 13, 1902, ch. 1079, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/375"},"text":"32 Stat. 375","children":[],"tail":"; renumbered § 20(a), "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s939/b"},"text":"Pub. L. 99–662, title IX, § 939(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4199"},"text":"100 Stat. 4199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b237597-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":