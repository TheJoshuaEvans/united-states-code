{"tag":"section","attrib":{"id":"id6b0b810d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s45"},"text":null,"children":[{"tag":"num","attrib":{"value":"45"},"text":"§ 45.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swan Creek, Toledo, Ohio","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Swan Creek, a stream lying within the limits of the city of Toledo, State of Ohio, is declared to be not a navigable waterway of the United States within the meaning of the laws enacted by Congress for the preservation and protection of such waterways, and the consent of Congress is given for the filling in of said creek by the local authorities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b810e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1915-03-04/ch142/s13"},"text":"Mar. 4, 1915, ch. 142, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/1055"},"text":"38 Stat. 1055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0b810f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0b8110-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0b8111-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from act ","children":[{"tag":"date","attrib":{"date":"1915-03-04"},"text":"Mar. 4, 1915","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1915”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
