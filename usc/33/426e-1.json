{"tag":"section","attrib":{"id":"id6b283018-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"426e–1"},"text":"§ 426e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shore protection projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b283019-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the Act of ","children":[{"tag":"date","attrib":{"date":"1930-07-03"},"text":"July 3, 1930","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s426"},"text":"33 U.S.C. 426","children":[],"tail":") of this title, and notwithstanding administrative actions, it is the policy of the United States to promote beach nourishment for the purposes of flood damage reduction and hurricane and storm damage reduction and related research that encourage the protection, restoration, and enhancement of sandy beaches, including beach restoration and periodic beach renourishment for a period of 50 years, on a comprehensive and coordinated basis by the Federal Government, States, localities, and private enterprises."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b28301a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the policy under subsection (a), preference shall be given to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b28301b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas in which there has been a Federal investment of funds for the purposes described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b28301c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" areas with respect to which the need for prevention or mitigation of damage to shores and beaches is attributable to Federal navigation projects or other Federal activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b28301d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426e–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apply the policy under subsection (a) to each shore protection and beach renourishment project (including shore protection and beach renourishment projects constructed before ","children":[{"tag":"date","attrib":{"date":"2007-11-08"},"text":"November 8, 2007","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b28301e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2018"},"text":"Pub. L. 110–114, title II, § 2018","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1077"},"text":"121 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b28301f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b283020-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b283021-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1930-07-03"},"text":"July 3, 1930","children":[],"tail":", referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/act/1930-07-03/ch847"},"text":"act July 3, 1930, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/918"},"text":"46 Stat. 918","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b283022-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b283023-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
