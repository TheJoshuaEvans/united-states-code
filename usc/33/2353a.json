{"tag":"section","attrib":{"id":"id6c62fa76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2353a"},"text":"§ 2353a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging infrastructure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c62fa77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aging infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “aging infrastructure” means a water resources development project of the Corps of Engineers, or any other water resources, water storage, or irrigation project of another Federal agency, that is greater than 75 years old.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “enhanced inspection” means an inspection that uses current or innovative technology, including Light Detection and Ranging (commonly known as “LiDAR”), ground penetrating radar, subsurface imaging, or subsurface geophysical techniques, to detect whether the features of the aging infrastructure are structurally sound and can operate as intended, or are at risk of failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for enhanced inspection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa7b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out enhanced inspections of aging infrastructure, pursuant to a contract with the owner or operator of the aging infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa7c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain circumstances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, or funds available pursuant to subsection (d), the Secretary shall enter into a contract described in paragraph (1), if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa7d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator of the aging infrastructure requests that the Secretary carry out the enhanced inspections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa7e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inspection is at the full expense of such owner or operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa7f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require a non-Federal entity associated with a project under the jurisdiction of another Federal agency to carry out corrective or remedial actions in response to an enhanced inspection carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa80-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2353a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to accept funds from an owner or operator of aging infrastructure, and may use such funds to carry out an enhanced inspection pursuant to a contract entered into with such owner or operator under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62fa81-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s138"},"text":"Pub. L. 116–260, div. AA, title I, § 138","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2651"},"text":"134 Stat. 2651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c62fa82-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c62fa83-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c62fa84-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c62fa85-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c62fa86-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
