{"tag":"section","attrib":{"id":"id6b1e93b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s403b"},"text":null,"children":[{"tag":"num","attrib":{"value":"403b"},"text":"§ 403b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lighting at docks and boat launching facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary considers a permit application for a dock or a boat launching facility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s403"},"text":"section 403 of this title","children":[],"tail":", the Secretary shall consider the needs of such facility for lighting from sunset to sunrise to make such facility’s presence known within a reasonable distance."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1e93b6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s946"},"text":"Pub. L. 99–662, title IX, § 946","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4200"},"text":"100 Stat. 4200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1e93b7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b1e93b8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b1e93b9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
