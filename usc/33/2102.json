{"tag":"section","attrib":{"id":"id6c29c235-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Based on the best scientific information available, artificial reefs in waters covered under this chapter shall be sited and constructed, and subsequently monitored and managed in a manner which will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c29c236-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance fishery resources to the maximum extent practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c237-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate access and utilization by United States recreational and commercial fishermen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c238-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize conflicts among competing uses of waters covered under this chapter and the resources in such waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c239-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize environmental risks and risks to personal health and property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c23a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with generally accepted principles of international law and shall not create any unreasonable obstruction to navigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c29c23b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tII/s203"},"text":"Pub. L. 98–623, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3395"},"text":"98 Stat. 3395","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
