{"tag":"section","attrib":{"id":"id6bb4e05b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276"},"text":null,"children":[{"tag":"num","attrib":{"value":"1276"},"text":"§ 1276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced aquifer use and recharge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb4e05c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Administrator shall provide funding to carry out groundwater research on enhanced aquifer use and recharge in support of sole-source aquifers, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e05d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 50 percent shall be used to provide 1 grant to a State, unit of local government, or Indian Tribe to carry out activities that would directly support that research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e05e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder shall be provided to 1 appropriate research center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e05f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of accepting funds under subsection (a), the State, unit of local government, or Indian Tribe and the appropriate research center that receive funds under that subsection shall establish a formal research relationship for the purpose of coordinating efforts under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e060-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1276/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this section $5,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb4e061-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title I, § 124, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50222"},"text":"Pub. L. 117–58, div. E, title II, § 50222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1181"},"text":"135 Stat. 1181","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
