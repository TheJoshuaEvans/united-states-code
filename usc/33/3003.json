{"tag":"section","attrib":{"id":"id6c760dc5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3003"},"text":null,"children":[{"tag":"num","attrib":{"value":"3003"},"text":"§ 3003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized number on the active list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760dc6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual strength on active list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual strength of the commissioned corps in officers on the lineal list of active duty officers of the corps shall be prescribed by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760dc7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lineal list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain a list, known as the “lineal list”, of officers on active duty. Officers shall be carried on the lineal list by grade and, within grade, by seniority in grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760dc8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s213"},"text":"Pub. L. 107–372, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3083"},"text":"116 Stat. 3083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
