{"tag":"section","attrib":{"id":"id6c523181-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2317b"},"text":"§ 2317b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation banks and in-lieu fee arrangements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c523182-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Secretary shall issue implementation guidance that provides for the consideration in water resources development feasibility studies of the entire amount of potential in-kind credits available at mitigation banks approved by the Secretary and in-lieu fee programs with an approved service area that includes the location of the projected impacts of the water resources development project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523183-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All potential mitigation bank and in-lieu fee credits that meet the criteria under paragraph (1) shall be considered a reasonable alternative for planning purposes if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c523184-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicable mitigation bank—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c523185-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an approved mitigation banking instrument; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c523186-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed a functional analysis of the potential credits using the approved Corps of Engineers certified habitat assessment model specific to the region; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c523187-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the use of such banks or in-lieu fee programs provide reasonable assurance that the statutory (and regulatory) mitigation requirements for a water resources development project are met, including monitoring or demonstrating mitigation success.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523188-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c523189-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifies or alters any requirement for a water resources development project to comply with applicable laws or regulations, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2283"},"text":"section 2283 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c52318a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2317b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be construed as to limit mitigation alternatives or require the use of mitigation banks or in-lieu fee programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c52318b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2036/c"},"text":"Pub. L. 110–114, title II, § 2036(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1094"},"text":"121 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1163"},"text":"Pub. L. 114–322, title I, § 1163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1669"},"text":"130 Stat. 1669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c52318c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c52318d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c52318e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2007, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c52318f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" amended section generally. Prior to amendment, section related to use of the mitigation bank for certain water resources projects that involved wetlands mitigation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c523190-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c523191-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
