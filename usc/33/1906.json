{"tag":"section","attrib":{"id":"id6c2295db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1906"},"text":null,"children":[{"tag":"num","attrib":{"value":"1906"},"text":"§ 1906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incidents involving ships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c2295dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to report incident","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The master, person in charge, owner, charterer, manager, or operator of a ship involved in an incident shall report the incident in the manner prescribed by Article 8 of the Convention in accordance with regulations promulgated by the Secretary for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c2295dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to report discharge, probable discharge, or presence of oil","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The master or person in charge of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c2295de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a ship of United States registry or nationality, or operated under the authority of the United States, wherever located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c2295df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another ship while in the navigable waters of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c2295e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sea port or oil handling facility subject to the jurisdiction of the United States,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall report a discharge, probable discharge, or presence of oil in the manner prescribed by Article 4 of the International Convention on Oil Pollution Preparedness, Response and Cooperation, 1990 (adopted at London, ","children":[{"tag":"date","attrib":{"date":"1990-11-30"},"text":"November 30, 1990","children":[],"tail":"), in accordance with regulations promulgated by the Secretary for that purpose."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c2295e1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/478/s7"},"text":"Pub. L. 96–478, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2300"},"text":"94 Stat. 2300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/241/s39"},"text":"Pub. L. 102–241, § 39","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2225"},"text":"105 Stat. 2225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c2295e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c2295e3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c2295e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/241"},"text":"Pub. L. 102–241","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) As soon as he has knowledge of an incident, the master or other person in charge of a ship shall report it to the Secretary in the manner prescribed by Article 8 of the Convention.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Upon receipt of the report of an incident involving a ship, other than one of United States registry or nationality or one operated under the authority of the United States, the Secretary shall take the action required by Article 8 of the Convention.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
