{"tag":"section","attrib":{"id":"id6c0f83a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1475"},"text":null,"children":[{"tag":"num","attrib":{"value":"1475"},"text":"§ 1475.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation procedure","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Before taking any measure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1474"},"text":"section 1474 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f83a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1475/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult, through the Secretary of State, with other countries affected by the marine casualty, and particularly with the flag country of any ship involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1475/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify without delay the Administrator of the Environmental Protection Agency and any other persons known to the Secretary, or of whom he later becomes aware, who have interests which can reasonably be expected to be affected by any proposed measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1475/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any views submitted in response to the consultation or notification required by subsections (1) and (2) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f83a6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s6"},"text":"Pub. L. 93–248, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/9"},"text":"88 Stat. 9","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
