{"tag":"section","attrib":{"id":"id6c8b6a27-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708"},"text":null,"children":[{"tag":"num","attrib":{"value":"3708"},"text":"§ 3708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8b6a28-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NOAA","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the National Oceanic and Atmospheric Administration to carry out the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8b6a29-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,500,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $22,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $24,000,000 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $26,000,000 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $28,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NSF","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the National Science Foundation to carry out the purposes of this chapter, $20,000,000 for each of the fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8b6a2f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12409"},"text":"Pub. L. 111–11, title XII, § 12409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1441"},"text":"123 Stat. 1441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10649"},"text":"Pub. L. 117–167, div. B, title VI, § 10649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1681"},"text":"136 Stat. 1681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8b6a30-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"e