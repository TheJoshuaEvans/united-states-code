{"tag":"section","attrib":{"id":"id6c8b6a1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3707"},"text":null,"children":[{"tag":"num","attrib":{"value":"3707"},"text":"§ 3707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NASA ocean acidification activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8b6a1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean acidification activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Aeronautics and Space Administration, in coordination with other relevant agencies, shall ensure that space-based monitoring assets are used in as productive a manner as possible for monitoring of ocean acidification and coastal acidification and their respective impacts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that the Agency’s research and monitoring activities on ocean acidification and coastal acidification are carried out in a manner consistent with the strategic research plan developed by the Subcommittee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3704"},"text":"section 3704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall encourage coordination of the Agency’s ocean acidification and coastal acidification activities with such activities of other nations and international organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Researchers from the National Aeronautics and Space Administration under this subtitle that collect data described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3705/d"},"text":"section 3705(d) of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8b6a21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3707/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect such data in accordance with the standards, protocols, or procedures established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3705/d"},"text":"section 3705(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3707/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such data to the Administrator and the Secretary, in accordance with any rules promulgated by the Administrator or the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8b6a23-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12408"},"text":"Pub. L. 111–11, title XII, § 12408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1441"},"text":"123 Stat. 1441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10648"},"text":"Pub. L. 117–167, div. B, title VI, § 10648","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1681"},"text":"136 Stat. 1681","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8b6a24-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8b6a25-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c8b6a26-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10648/1"},"text":"Pub. L. 117–167, § 10648(1)","children":[],"tail":", substituted “ocean acidification and coastal acidification” for “ocean acidification” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10648/2"},"text":"Pub. L. 117–167, § 10648(2)","children":[],"tail":", substituted “their respective impacts” for “its impacts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10648/3"},"text":"Pub. L. 117–167, § 10648(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
