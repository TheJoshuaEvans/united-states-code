{"tag":"section","attrib":{"id":"id6c78575d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3063"},"text":null,"children":[{"tag":"num","attrib":{"value":"3063"},"text":"§ 3063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations when cooperating with military departments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c78575e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and the Secretary of Commerce shall jointly prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78575f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3063/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governing the duties to be performed by the Administration in time of war; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c785760-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3063/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the cooperation of the Administration with the military departments in time of peace in preparation for its duties in time of war.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c785761-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations under subsection (a) shall not be effective unless approved by each of those Secretaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c785762-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regulations under subsection (a) may provide procedures for making reports and communications between a military department and the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c785763-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s253"},"text":"Pub. L. 107–372, title II, § 253","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3091"},"text":"116 Stat. 3091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c785764-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c785765-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c785766-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s858"},"text":"section 858 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
