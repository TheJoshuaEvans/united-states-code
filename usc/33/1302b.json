{"tag":"section","attrib":{"id":"id6bc58214-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302b"},"text":"§ 1302b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small and medium publicly owned treatment works circuit rider program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc58215-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall establish a circuit rider program (referred to in this section as the “circuit rider program”) under which the Administrator shall award grants to qualified nonprofit entities, as determined by the Administrator, to provide assistance to owners and operators of small and medium publicly owned treatment works to carry out the activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1382/b/13"},"text":"section 1382(b)(13) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58216-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant provided under the circuit rider program shall be in an amount that is not more than $75,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58217-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting recipients of grants under the circuit rider program, the Administrator shall give priority to qualified nonprofit entities, as determined by the Administrator, that would serve a community that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc58218-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a history, for not less than the 10 years prior to the award of the grant, of unresolved wastewater issues, stormwater issues, or a combination of wastewater and stormwater issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58219-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is considered financially distressed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc5821a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faces the cumulative burden of stormwater and wastewater overflow issues; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc5821b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has previously failed to access Federal technical assistance due to cost-sharing requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc5821c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each qualified nonprofit entity that receives funding under this section shall, before using that funding to undertake activities to carry out this section, consult with the State in which the assistance is to be expended or otherwise made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc5821d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date on which the Administrator establishes the circuit rider program, and every 2 years thereafter, the Administrator shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc5821e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each recipient of a grant under the circuit rider program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc5821f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities carried out under the circuit rider program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58220-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc58221-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58222-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc7f323-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 224, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50206"},"text":"Pub. L. 117–58, div. E, title II, § 50206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1164"},"text":"135 Stat. 1164","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
