{"tag":"section","attrib":{"id":"id6c7856aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3033"},"text":null,"children":[{"tag":"num","attrib":{"value":"3033"},"text":"§ 3033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension during war or emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In time of emergency declared by the President or by the Congress, and in time of war, the President is authorized, in the President’s discretion, to suspend the operation of all or any part of the provisions of law pertaining to promotion of commissioned officers of the Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c7856ab-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s233"},"text":"Pub. L. 107–372, title II, § 233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3088"},"text":"116 Stat. 3088","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7856ac-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7856ad-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c7856ae-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853i/b"},"text":"section 853i(b) of this title","children":[],"tail