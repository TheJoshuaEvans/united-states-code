{"tag":"section","attrib":{"id":"id6c5bce4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330"},"text":null,"children":[{"tag":"num","attrib":{"value":"2330"},"text":"§ 2330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aquatic ecosystem restoration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5bce4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bce4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out a project to restore and protect an aquatic ecosystem or estuary if the Secretary determines that the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5bce4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c5bce4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will improve the quality of the environment and is in the public interest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5bce50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will improve the elements and features of an estuary (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2902"},"text":"section 2902 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bce51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is cost-effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dam removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this section may include removal of a dam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anadromous fish habitat and passage","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5bce54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project under this section may include measures to improve habitat or passage for anadromous fish, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c5bce55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installing fish bypass structures on small water diversions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5bce56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modifying tide gates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c5bce57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring or reconnecting floodplains and wetlands that are important for anadromous fish habitat or passage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5bce58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project that includes measures under this paragraph shall be formulated to maximize benefits for the anadromous fish species benefitted by the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drought resilience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under this section may include measures that enhance drought resilience through the restoration of wetlands or the removal of invasive species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bce5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal interests shall provide 35 percent of the cost of construction of any project carried out under this section, including provision of all lands, easements, rights-of-way, and necessary relocations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":", the Federal share of the cost of a project under this section may be provided in the form of reimbursements of project costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anadromous fish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), for projects carried out under subsection (a)(3), the non-Federal interest shall provide 15 percent of the cost of construction, including provision of all lands, easements, rights-of-way, and necessary relocations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bce5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Construction of a project under this section shall be initiated only after a non-Federal interest has entered into a binding agreement with the Secretary to pay the non-Federal share of the costs of construction required by this section and to pay 100 percent of any operation, maintenance, and replacement and rehabilitation costs with respect to the project in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b"},"text":"section 1962d–5b of title 42","children":[],"tail":", for any project carried out under this section, a non-Federal interest may include a nonprofit entity, with the consent of the affected local government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $15,000,000 in Federal funds may be allotted under this section for a project at any single locality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of natural and nature-based features","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out a project to restore and protect an aquatic ecosystem or estuary under subsection (a), the Secretary shall consider, and may include, with the consent of the non-Federal interest, a natural feature or nature-based feature, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2289a"},"text":"section 2289a of this title","children":[],"tail":", if the Secretary determines that inclusion of such features is consistent with the requirements of subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $75,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give projects that include measures described in subsection (a)(3) equal priority for implementation as other projects under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5bce65-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s206"},"text":"Pub. L. 104–303, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3679"},"text":"110 Stat. 3679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/53/tII/s210"},"text":"Pub. L. 106–53, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/287"},"text":"113 Stat. 287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2020"},"text":"Pub. L. 110–114, title II, § 2020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1078"},"text":"121 Stat. 1078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1030/g"},"text":"Pub. L. 113–121, title I, § 1030(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1232"},"text":"128 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI"},"text":"Pub. L. 115–270, title I","children":[],"tail":", §§ 1149(a), 1157(f), "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3787"},"text":"132 Stat. 3787","children":[],"tail":", 3794; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s126/a"},"text":"Pub. L. 116–260, div. AA, title I, § 126(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2640"},"text":"134 Stat. 2640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1107/e"},"text":"Pub. L. 118–272, div. A, title I, § 1107(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3004"},"text":"138 Stat. 3004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5bce66-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5bce67-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5bce68-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1996, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c5bce69-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/e/1"},"text":"Pub. L. 118–272, § 1107(e)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/e/2"},"text":"Pub. L. 118–272, § 1107(e)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/e/3"},"text":"Pub. L. 118–272, § 1107(e)(3)","children":[],"tail":", substituted “$15,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1107/e/4"},"text":"Pub. L. 118–272, § 1107(e)(4)","children":[],"tail":", substituted “$75,000,000” for “$62,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s126/a/1"},"text":"Pub. L. 116–260, § 126(a)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s126/a/2"},"text":"Pub. L. 116–260, § 126(a)(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1149/a/2"},"text":"Pub. L. 115–270, § 1149(a)(2)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":", §§ 1149(a)(1), 1157(f), redesignated subsec. (e) as (f) and substituted “$62,500,000” for “$50,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" substituted “$10,000,000” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2020/1"},"text":"Pub. L. 110–114, § 2020(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a), which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"General authority","children":[],"tail":".—The Secretary may carry out an aquatic ecosystem restoration and protection project if the Secretary determines that the project—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) will improve the quality of the environment and is in the public interest; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is cost-effective.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2020/2"},"text":"Pub. L. 110–114, § 2020(2)","children":[],"tail":", substituted “$50,000,000” for “$25,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s210/1"},"text":"Pub. L. 106–53, § 210(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s210/2"},"text":"Pub. L. 106–53, § 210(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5bce6a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5bce6b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s2"},"text":"section 2 of Pub. L. 104–303","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
