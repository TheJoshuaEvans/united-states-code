{"tag":"section","attrib":{"id":"id6b793693-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b"},"text":null,"children":[{"tag":"num","attrib":{"value":"892b"},"text":"§ 892b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality assurance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b793694-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “hydrographic product” means any publicly or commercially available product or service produced or disseminated by a non-Federal entity that includes or displays hydrographic data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b793695-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b793696-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b793697-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2002-12-19"},"text":"December 19, 2002","children":[],"tail":", shall, subject to the availability of appropriations, develop and implement a quality assurance program that is equally available to all applicants, under which the Administrator may certify hydrographic products that satisfy the standards promulgated by the Administrator under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s892a/a/3"},"text":"section 892a(a)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b793698-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may authorize the use of the emblem or any trademark of the Administration on a hydrographic product certified under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b793699-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may charge a fee for such certification and use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b79369a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on fee amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any fee under paragraph (1)(C) shall not exceed the costs of conducting the quality assurance testing, evaluation, or studies necessary to determine whether the hydrographic product satisfies the standards adopted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s892a/a/3"},"text":"section 892a(a)(3) of this title","children":[],"tail":", including the cost of administering such a program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b79369b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Government of the United States shall not be liable for any negligence by a person that produces hydrographic products certified under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b79369c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrographic Services Account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b79369d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury a separate account, which shall be known as the “Hydrographic Services Account”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b79369e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The account shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b79369f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received by the United States as fees charged under subsection (b)(1)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other amounts as may be provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the account shall be available to the Administrator, without further appropriation, for hydrographic services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on new fees and increases in existing fees for hydrographic services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1998-11-13"},"text":"November 13, 1998","children":[],"tail":", the Administrator may not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7936a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish any fee or other charge for the provision of any hydrographic service except as authorized by this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the amount of any fee or other charge for the provision of any hydrographic service except as authorized by this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1307"},"text":"section 1307 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7936a5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384/tIII/s304"},"text":"Pub. L. 105–384, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3455"},"text":"112 Stat. 3455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/372/tI/s104/a"},"text":"Pub. L. 107–372, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3080"},"text":"116 Stat. 3080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10308/c"},"text":"Pub. L. 117–263, div. J, title CIII, § 10308(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3980"},"text":"136 Stat. 3980","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7936a6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7936a7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b7936a8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “product or service produced or disseminated” for “product produced”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The Administrator may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) develop and implement a quality assurance program that is equally available to all applicants, under which the Administrator may certify hydrographic products that satisfy the standards promulgated by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s892a/a/3"},"text":"section 892a(a)(3) of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) authorize the use of the emblem or any trademark of the Administration on a hydrographic product certified under subparagraph (A); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) charge a fee for such certification and use.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
