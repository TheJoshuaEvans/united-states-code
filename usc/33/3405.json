{"tag":"section","attrib":{"id":"id6c81f4fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405"},"text":null,"children":[{"tag":"num","attrib":{"value":"3405"},"text":"§ 3405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean Exploration Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c81f4fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration shall appoint an Ocean Exploration Advisory Board composed of experts in relevant fields, including representatives from academic, commercial, nonprofit, philanthropic, policy, and Tribal entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c81f4fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Administrator on priority areas for survey, discovery, and opportunities for extramural collaboration and partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f4ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the program in the development of a 5-year strategic plan for the fields of ocean, marine, and Great Lakes science, exploration, and discovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f500-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to annually review the quality and effectiveness of the proposal review process established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3403/a/4"},"text":"section 3403(a)(4) of this title","children":[],"tail":"; and "},{"tag":"ref","attrib":{"idref":"fn002143"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002143"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f501-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify market barriers to development or commercialization of novel ocean mapping, exploration, and characterization products, processes, and tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f502-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify best practices to improve data management, processing, storage, and archiving standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c81f503-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide other assistance and advice as requested by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f504-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Board appointed under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c81f505-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with Outer Continental Shelf Lands Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter supersedes, or limits the authority of the Secretary of the Interior under the Outer Continental Shelf Lands Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"43 U.S.C. 1331","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c81f506-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12005"},"text":"Pub. L. 111–11, title XII, § 12005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1418"},"text":"123 Stat. 1418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10305/f"},"text":"Pub. L. 117–263, div. J, title CIII, § 10305(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3973"},"text":"136 Stat. 3973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/208"},"text":"Pub. L. 117–286, § 4(a)(208)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4329"},"text":"136 Stat. 4329","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c81f507-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c81f508-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c81f509-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Outer Continental Shelf Lands Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-07/ch345"},"text":"act Aug. 7, 1953, ch. 345","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/462"},"text":"67 Stat. 462","children":[],"tail":", which is classified generally to subchapter III (§ 1331 et seq.) of chapter 29 of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1301"},"text":"section 1301 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c81f50a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10305/f/1/A"},"text":"Pub. L. 117–263, § 10305(f)(1)(A)","children":[],"tail":", inserted “, including representatives from academic, commercial, nonprofit, philanthropic, policy, and Tribal entities” after “relevant fields” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10305/f/1/B"},"text":"Pub. L. 117–263, § 10305(f)(1)(B)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “to advise the Administrator on priority areas for survey and discovery;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10305/f/1/C"},"text":"Pub. L. 117–263, § 10305(f)(1)(C)","children":[],"tail":", (D), added pars. (4) and (5) and redesignated former par. (4) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10305/f/2"},"text":"Pub. L. 117–263, § 10305(f)(2)","children":[],"tail":", inserted “this” before “subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
