{"tag":"section","attrib":{"id":"id6b44b9aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s569c"},"text":null,"children":[{"tag":"num","attrib":{"value":"569c"},"text":"§ 569c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services of volunteers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Army Chief of Engineers may accept the services of volunteers and provide for their incidental expenses, including expenses relating to uniforms, transportation, lodging, and the subsistence of those volunteers, to carry out any activity of the Army Corps of Engineers except policy-making or law or regulatory enforcement. Such volunteers shall not be employees of the United States Government except for the purposes of (1) chapter 171 of title 28, relating to tort claims, and (2) chapter 81 of title 5, relating to compensation for work injuries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b44b9ab-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/63/tI"},"text":"Pub. L. 98–63, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-30"},"text":"July 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/312"},"text":"97 Stat. 312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1047/d"},"text":"Pub. L. 113–121, title I, § 1047(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1256"},"text":"128 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b44b9ac-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b44b9ad-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b44b9ae-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":", which directed amendment in the first sentence of chapter IV of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/98/63"},"text":"Public Law 98–63","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s569c"},"text":"33 U.S.C. 569c","children":[],"tail":") by inserting “, including expenses relating to uniforms, transportation, lodging, and the subsistence of those volunteers,” after “incidental expenses”, was executed by making the insertion in the first sentence of this section to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b44b9af-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b44b9b0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Services of Volunteers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1112"},"text":"Pub. L. 118–272, div. A, title I, § 1112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3010"},"text":"138 Stat. 3010","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/272/dA/tI/s1112"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of the Army] may recognize a volunteer providing services under the heading ‘Department of Defense—Civil—Department of the Army—Corps of Engineers—Civil—General Provisions’ in chapter IV of title I of the Supplemental Appropriations Act, 1983 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s569c"},"text":"33 U.S.C. 569c","children":[],"tail":") through an award or other appropriate means, except that such award may not be in the form of a cash award."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a process to carry out subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
