{"tag":"section","attrib":{"id":"id6b3b43ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s512"},"text":null,"children":[{"tag":"num","attrib":{"value":"512"},"text":"§ 512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obstruction of navigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No bridge shall at any time unreasonably obstruct the free navigation of any navigable waters of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3b43cb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-21/ch409/s2"},"text":"June 21, 1940, ch. 409, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/498"},"text":"54 Stat. 498","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
