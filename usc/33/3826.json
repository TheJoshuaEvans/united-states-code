{"tag":"section","attrib":{"id":"id6c8dda9a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3826"},"text":null,"children":[{"tag":"num","attrib":{"value":"3826"},"text":"§ 3826.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communication and exchange of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8dda9b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3826/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), with respect to those antifouling systems regulated by the Administrator, the Administrator shall provide to any party to the Convention that requests it, relevant information on which the decision to regulate was based, including information provided for in annex 3 to the Convention, or other information suitable for making an appropriate evaluation of the antifouling system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8dda9c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3826/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed to authorize the provision of information the disclosure of which is otherwise prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8dda9d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1026"},"text":"Pub. L. 111–281, title X, § 1026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3027"},"text":"124 Stat. 3027","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
