{"tag":"section","attrib":{"id":"id6c6ee1ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751"},"text":null,"children":[{"tag":"num","attrib":{"value":"2751"},"text":"§ 2751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c6ee1ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross-references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A reference to a law replaced by this Act, including a reference in a regulation, order, or other law, is deemed to refer to the corresponding provision of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee1ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order, rule, or regulation in effect under a law replaced by this Act continues in effect under the corresponding provision of this Act until repealed, amended, or superseded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee1ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An inference of legislative construction shall not be drawn by reason of the caption or catch line of a provision enacted by this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee1af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions and rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall apply to any rights and duties that matured, penalties that were incurred, and proceedings that were begun before ","children":[{"tag":"date","attrib":{"date":"1990-08-18"},"text":"August 18, 1990","children":[],"tail":", except as provided by this section, and shall be adjudicated pursuant to the law applicable on the date prior to "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"August 18, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6ee1b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admiralty and maritime law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this Act, this Act does not affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6ee1b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admiralty and maritime law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6ee1b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2751/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction of the district courts of the United States with respect to civil actions under admiralty and maritime jurisdiction, saving to suitors in all cases all other remedies to which they are otherwise entitled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c6ee1b3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tVI/s6001"},"text":"Pub. L. 101–380, title VI, § 6001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/554"},"text":"104 Stat. 554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c6ee1b4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c6ee1b5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c6ee1b6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":", known as the Oil Pollution Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
