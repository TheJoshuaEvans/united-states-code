{"tag":"section","attrib":{"id":"id6b4be5c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a"},"text":null,"children":[{"tag":"num","attrib":{"value":"605a"},"text":"§ 605a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mississippi River forecasting improvements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b4be5c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of the department in which the Coast Guard is operating, the Director of the United States Geological Survey, the Administrator of the National Oceanic and Atmospheric Administration, and the Director of the National Weather Service, as applicable, shall improve forecasting on the Mississippi River by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b4be5c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" updating forecasting technology deployed on the Mississippi River and its tributaries through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b4be5c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction of additional automated river gages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b4be5c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation of existing automated and manual river gages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b4be5c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the replacement of manual river gages with automated gages, as the Secretary determines to be necessary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be5c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructing additional sedimentation ranges on the Mississippi River and its tributaries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b4be5c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploying additional automatic identification system base stations at river gage sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b4be5ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall prioritize the sections of the Mississippi River on which additional and more reliable information would have the greatest impact on maintaining navigation on the Mississippi River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b4be5cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s605a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", the Secretary shall submit to Congress and make publicly available a report on the activities carried out by the Secretary under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b4be5cc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIV/s4002/a"},"text":"Pub. L. 113–121, title IV, § 4002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1308"},"text":"128 Stat. 1308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b4be5cd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b4be5ce-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b4be5cf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
