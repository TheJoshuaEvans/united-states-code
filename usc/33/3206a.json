{"tag":"section","attrib":{"id":"id6c7d3940-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3206a"},"text":"§ 3206a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tsunami Science and Technology Advisory Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7d3941-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall designate an existing working group within the Science Advisory Board of the Administration to serve as the Tsunami Science and Technology Advisory Panel to provide advice to the Administrator on matters regarding tsunami science, technology, and regional preparedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7d3942-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7d3943-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Panel shall be composed of no fewer than 7 members selected by the Administrator from among individuals from academia or State agencies who have academic or practical expertise in physical sciences, social sciences, information technology, coastal resilience, emergency management, or such other disciplines as the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3944-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No member of the Panel may be a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7d3945-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than once every 4 years, the Panel shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7d3946-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the activities of the Administration, and other Federal activities as appropriate, relating to tsunami research, detection, forecasting, warning, mitigation, resiliency, and preparation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7d3947-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Administrator and such others as the Administrator considers appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7d3948-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the working group with respect to the most recent review conducted under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7d3949-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations for legislative or administrative action as the working group considers appropriate to improve Federal tsunami research, detection, forecasting, warning, mitigation, resiliency, and preparation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7d394a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3206a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 4 years, the Administrator shall submit to the Committee on Commerce, Science, and Transportation of the Senate, and the Committee on Science, Space, and Technology of the House of Representatives a report on the findings and recommendations received by the Administrator under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7d394b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVIII/s808"},"text":"Pub. L. 109–479, title VIII, § 808","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/tV/s508/a/2"},"text":"Pub. L. 115–25, title V, § 508(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/125"},"text":"131 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7d394c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7d394d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c7d394e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479/s808"},"text":"section 808 of Pub. L. 109–479","children":[],"tail":" was renumbered section 809 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3207"},"text":"section 3207 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
