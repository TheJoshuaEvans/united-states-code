{"tag":"section","attrib":{"id":"id6c67b54f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704"},"text":null,"children":[{"tag":"num","attrib":{"value":"2704"},"text":"§ 2704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits on liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c67b550-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, the total of the liability of a responsible party under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2702"},"text":"section 2702 of this title","children":[],"tail":" and any removal costs incurred by, or on behalf of, the responsible party, with respect to each incident shall not exceed—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b551-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a tank vessel the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b552-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a single-hull vessel, including a single-hull vessel fitted with double sides only or a double bottom only, $3,000 per gross ton;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b553-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a vessel other than a vessel referred to in subparagraph (A), $1,900 per gross ton; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b554-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c67b555-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a vessel greater than 3,000 gross tons that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c67b556-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel described in subparagraph (A), $22,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b557-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel described in subparagraph (B), $16,000,000; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c67b558-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a vessel of 3,000 gross tons or less that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c67b559-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel described in subparagraph (A), $6,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c67b55a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel described in subparagraph (B), $4,000,000;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b55b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other vessel, $950 per gross ton or $800,000, whichever is greater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b55c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an offshore facility except a deepwater port, the total of all removal costs plus $75,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b55d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any onshore facility and a deepwater port, $350,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b55e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division of liability for mobile offshore drilling units","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b55f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treated first as tank vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the responsible party and applying this Act and except as provided in paragraph (2), a mobile offshore drilling unit which is being used as an offshore facility is deemed to be a tank vessel with respect to the discharge, or the substantial threat of a discharge, of oil on or above the surface of the water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b560-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treated as facility for excess liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that removal costs and damages from any incident described in paragraph (1) exceed the amount for which a responsible party is liable (as that amount may be limited under subsection (a)(1)), the mobile offshore drilling unit is deemed to be an offshore facility. For purposes of applying subsection (a)(3), the amount specified in that subsection shall be reduced by the amount for which the responsible party is liable under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b561-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b562-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acts of responsible party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply if the incident was proximately caused by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b563-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross negligence or willful misconduct of, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b564-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation of an applicable Federal safety, construction, or operating regulation by,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the responsible party, an agent or employee of the responsible party, or a person acting pursuant to a contractual relationship with the responsible party (except where the sole contractual arrangement arises in connection with carriage by a common carrier by rail).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b565-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure or refusal of responsible party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply if the responsible party fails or refuses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b566-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report the incident as required by law and the responsible party knows or has reason to know of the incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b567-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide all reasonable cooperation and assistance requested by a responsible official in connection with removal activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b568-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without sufficient cause, to comply with an order issued under subsection (c) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"section 1321 of this title","children":[],"tail":" or the Intervention on the High Seas Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1471"},"text":"33 U.S.C. 1471","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b569-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OCS facility or vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the limitations established under subsection (a) and the defenses of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2703"},"text":"section 2703 of this title","children":[],"tail":", all removal costs incurred by the United States Government or any State or local official or agency in connection with a discharge or substantial threat of a discharge of oil from any Outer Continental Shelf facility or a vessel carrying oil as cargo from such a facility shall be borne by the owner or operator of such facility or vessel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b56a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain tank vessels","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b56b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tank vessel on which the only oil carried as cargo is an animal fat or vegetable oil, as those terms are used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2720"},"text":"section 2720 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b56c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tank vessel that is designated in its certificate of inspection as an oil spill response vessel (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of title 46","children":[],"tail":") and that is used solely for removal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c67b56d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusting limits of liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c67b56e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Onshore facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the President may establish by regulation, with respect to any class or category of onshore facility, a limit of liability under this section of less than $350,000,000, but not less than $8,000,000, taking into account size, storage capacity, oil throughput, proximity to sensitive areas, type of oil handled, history of discharges, and other factors relevant to risks posed by the class or category of facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b56f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deepwater ports and associated vessels","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c67b570-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a study of the relative operational and environmental risks posed by the transportation of oil by vessel to deepwater ports (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1502"},"text":"section 1502 of this title","children":[],"tail":") versus the transportation of oil by vessel to other ports. The study shall include a review and analysis of offshore lightering practices used in connection with that transportation, an analysis of the volume of oil transported by vessel using those practices, and an analysis of the frequency and volume of oil discharges which occur in connection with the use of those practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b571-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1990-08-18"},"text":"August 18, 1990","children":[],"tail":", the Secretary shall submit to the Congress a report on the results of the study conducted under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c67b572-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking proceeding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines, based on the results of the study conducted under subparagraph (A), that the use of deepwater ports in connection with the transportation of oil by vessel results in a lower operational or environmental risk than the use of other ports, the Secretary shall initiate, not later than the 180th day following the date of submission of the report to the Congress under subparagraph (B), a rulemaking proceeding to lower the limits of liability under this section for deepwater ports as the Secretary determines appropriate. The Secretary may establish a limit of liability of less than $350,000,000, but not less than $50,000,000, in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b573-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall, within 6 months after ","children":[{"tag":"date","attrib":{"date":"1990-08-18"},"text":"August 18, 1990","children":[],"tail":", and from time to time thereafter, report to the Congress on the desirability of adjusting the limits of liability specified in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c67b574-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2704/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment to reflect Consumer Price Index","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, by regulations issued not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", and not less than every 3 years thereafter, shall adjust the limits on liability specified in subsection (a) to reflect significant increases in the Consumer Price Index."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c67b575-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tI/s1004"},"text":"Pub. L. 101–380, title I, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/491"},"text":"104 Stat. 491","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/55/s2/d/1"},"text":"Pub. L. 104–55, § 2(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-20"},"text":"Nov. 20, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/546"},"text":"109 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIV/s406"},"text":"Pub. L. 105–383, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3429"},"text":"112 Stat. 3429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tVI/s603/a/1"},"text":"Pub. L. 109–241, title VI, § 603(a)(1)","children":[],"tail":", (2), (b), "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/553"},"text":"120 Stat. 553","children":[],"tail":", 554; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s903/a/2"},"text":"Pub. L. 111–281, title IX, § 903(a)(2)","children":[],"tail":", (e)(1), "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3010"},"text":"124 Stat. 3010","children":[],"tail":", 3011; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3547/c"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3547(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2328"},"text":"132 Stat. 2328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c67b576-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c67b577-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c67b578-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":", known as the Oil Pollution Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Intervention on the High Seas Act, referred to in subsec. (c)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248"},"text":"Pub. L. 93–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/8"},"text":"88 Stat. 8","children":[],"tail":", which is classified generally to chapter 28 (§ 1471 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1471"},"text":"section 1471 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c67b579-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “under subparagraph (A)” for “under this subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s903/e/1"},"text":"Pub. L. 111–281, § 903(e)(1)","children":[],"tail":", struck out first comma after “$800,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s903/a/2"},"text":"Pub. L. 111–281, § 903(a)(2)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s603/a/2"},"text":"Pub. L. 109–241, § 603(a)(2)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s603/a/1"},"text":"Pub. L. 109–241, § 603(a)(1)","children":[],"tail":", added subpars. (A) to (C) and struck out former subpars. (A) and (B), which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $1,200 per gross ton; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B)(i) in the case of a vessel greater than 3,000 gross tons, $10,000,000; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) in the case of a vessel of 3,000 gross tons or less, $2,000,000;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s603/a/2"},"text":"Pub. L. 109–241, § 603(a)(2)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/s903/a/2"},"text":"Pub. L. 111–281, § 903(a)(2)","children":[],"tail":", substituted “$950 per gross ton” for “$600 per gross ton” and “$800,000,” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s603/b"},"text":"Pub. L. 109–241, § 603(b)","children":[],"tail":", amended heading and text of par. (4) generally. Prior to amendment, text read as follows: “The President shall, by regulations issued not less often than every 3 years, adjust the limits of liability specified in subsection (a) to reflect significant increases in the Consumer Price Index.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s406/1"},"text":"Pub. L. 105–383, § 406(1)","children":[],"tail":", substituted comma for “(except a tank vessel on which the only oil carried as cargo is an animal fat or vegetable oil, as those terms are used in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2720"},"text":"section 2720 of this title","children":[],"tail":")” after “tank vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s406/2"},"text":"Pub. L. 105–383, § 406(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/55"},"text":"Pub. L. 104–55","children":[],"tail":" substituted “for a tank vessel (except a tank vessel on which the only oil carried as cargo is an animal fat or vegetable oil, as those terms are used in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2720"},"text":"section 2720 of this title","children":[],"tail":")” for “for a tank vessel,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c67b57a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c67b57b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s903/a"},"text":"Pub. L. 111–281, title IX, § 903(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3010"},"text":"124 Stat. 3010","children":[],"tail":", provided that the amendment by section 903(a)(2) is effective with enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c67b57c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/tVI/s603/a/3"},"text":"Pub. L. 109–241, title VI, § 603(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/554"},"text":"120 Stat. 554","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/241/tVI/s603/a/3"},"text":"“In the case of an incident occurring before the 90th day following the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":"], section 1004(a)(1) of the Oil Pollution Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2704/a/1"},"text":"33 U.S.C. 2704(a)(1)","children":[],"tail":") shall apply as in effect immediately before the effective date of this subsection ["},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c67b57d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/tVI/s603/c"},"text":"Pub. L. 109–241, title VI, § 603(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/554"},"text":"120 Stat. 554","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tVI/s601/b"},"text":"Pub. L. 114–120, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/79"},"text":"130 Stat. 79","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tVI/s601/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 45 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":"], the Secretary of the department in which the Coast Guard is operating shall submit a report on liability limits described in paragraph (2) to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the extent to which oil discharges from vessels and nonvessel sources have or are likely to result in removal costs and damages (as defined in section 1001 of the Oil Pollution Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"33 U.S.C. 2701","children":[],"tail":")) for which no defense to liability exists under section 1003 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2703"},"text":"33 U.S.C. 2703","children":[],"tail":"] and that exceed the liability limits established in section 1004 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2704"},"text":"33 U.S.C. 2704","children":[],"tail":"], as amended by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the impacts that claims against the Oil Spill Liability Trust Fund for amounts exceeding such liability limits will have on the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Based on analyses under this paragraph and taking into account other factors impacting the Fund, recommendations on whether the liability limits need to be adjusted in order to prevent the principal of the Fund from declining to levels that are likely to be insufficient to cover expected claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide an update of the report to the Committees referred to in paragraph (1) not later than January 30 of the year following each year in which occurs an oil discharge from a vessel or nonvessel source that results or is likely to result in removal costs and damages (as those terms are defined in section 1001 of the Oil Pollution Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"33 U.S.C. 2701","children":[],"tail":")) that exceed liability limits established under section 1004 of the Oil Pollution Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2704"},"text":"33 U.S.C. 2704","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c67b57e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id6c67b57f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under subsec. (d) of this section, see section 4 of Ex. Ord. No. 12777, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"section 1321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
