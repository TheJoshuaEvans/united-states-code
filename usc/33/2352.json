{"tag":"section","attrib":{"id":"id6c62fa3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352"},"text":null,"children":[{"tag":"num","attrib":{"value":"2352"},"text":"§ 2352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding to process permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c62fa3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding to process permits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural gas company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “natural gas company” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16451"},"text":"section 16451 of title 42","children":[],"tail":", except that the term also includes a person engaged in the transportation of natural gas in intrastate commerce."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public-utility company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public-utility company” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16451"},"text":"section 16451 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad carrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “railroad carrier” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102"},"text":"section 20102 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa40-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian Tribe” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c62fa41-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c62fa42-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity formed under the authority of one or more Indian Tribes, as so defined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa43-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit processing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa44-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, after public notice, may accept and expend funds contributed by a non-Federal public entity or a public-utility company, Indian Tribe, natural gas company, or railroad carrier to expedite the evaluation of a permit of that entity, company, or carrier related to a project or activity for a public purpose under the jurisdiction of the Department of the Army, including an aquatic ecosystem restoration project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa45-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitigation bank instrument processing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An activity carried out by the Secretary to expedite evaluation of a permit described in subparagraph (A) may include the evaluation of an instrument for a mitigation bank if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c62fa46-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the non-Federal public entity, public-utility company, Indian Tribe, natural gas company, or railroad carrier applying for the permit described in that subparagraph is the sponsor of the mitigation bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c62fa47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expediting evaluation of the instrument is necessary to expedite evaluation of the permit described in that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall ensure that expediting the evaluation of a permit through the use of funds accepted and expended under this section does not adversely affect the timeline for evaluation (in the Corps district in which the project or activity is located) of permits under the jurisdiction of the Department of the Army of other entities that have not contributed funds under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on permitting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall ensure that the use of funds accepted under subsection (a) will not impact impartial decisionmaking with respect to permits, either substantively or procedurally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impartial decisionmaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall ensure that the evaluation of permits carried out using funds accepted under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be reviewed by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c62fa4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District Commander, or the Commander’s designee, of the Corps District in which the project or activity is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c62fa4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commander of the Corps Division in which the District is located if the evaluation of the permit is initially conducted by the District Commander; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the same procedures for decisions that would otherwise be required for the evaluation of permits for similar projects or activities not carried out using funds authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds accepted under this section shall be used to carry out a review of the evaluation of permits required under subsection (b)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that all final permit decisions carried out using funds authorized under this section are made available to the public in a common format, including on the Internet, and in a manner that distinguishes final permit decisions under this section from other final actions of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision document","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a standard decision document for evaluating all permits using funds accepted under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the standard decision document, along with all final permit decisions, available to the public, including on the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make all active agreements to accept funds under this section available on a single public Internet site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fa57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fa58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare an annual report on the implementation of this section, which, at a minimum, shall include for each district of the Corps of Engineers that accepts funds under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive list of any funds accepted under this section during the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive list of the permits reviewed and approved using funds accepted under this section during the previous fiscal year, including a description of the size and type of resources impacted and the mitigation required for each permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the training offered in the previous fiscal year for employees that is funded in whole or in part with funds accepted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fa5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the end of each fiscal year, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fa5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives the annual report described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fa5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2352/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make each report received under subparagraph (A) available on a single publicly accessible Internet site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62fa5f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s214"},"text":"Pub. L. 106–541, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2594"},"text":"114 Stat. 2594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/137/tI/s114"},"text":"Pub. L. 108–137, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-01"},"text":"Dec. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1836"},"text":"117 Stat. 1836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/99/s1"},"text":"Pub. L. 109–99, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-11"},"text":"Nov. 11, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2169"},"text":"119 Stat. 2169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/209/s1"},"text":"Pub. L. 109–209, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-24"},"text":"Mar. 24, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/318"},"text":"120 Stat. 318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/434/s1"},"text":"Pub. L. 109–434, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3197"},"text":"120 Stat. 3197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2002"},"text":"Pub. L. 110–114, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1067"},"text":"121 Stat. 1067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/120/s1"},"text":"Pub. L. 111–120, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-22"},"text":"Dec. 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3478"},"text":"123 Stat. 3478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/315/s1"},"text":"Pub. L. 111–315, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3450"},"text":"124 Stat. 3450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1006"},"text":"Pub. L. 113–121, title I, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1212"},"text":"128 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1125"},"text":"Pub. L. 114–322, title I, § 1125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1648"},"text":"130 Stat. 1648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1145"},"text":"Pub. L. 115–270, title I, § 1145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3785"},"text":"132 Stat. 3785","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8135"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3722"},"text":"136 Stat. 3722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1133"},"text":"Pub. L. 118–272, div. A, title I, § 1133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3024"},"text":"138 Stat. 3024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c62fa60-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c62fa61-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c62fa62-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2000, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c62fa63-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1133/1"},"text":"Pub. L. 118–272, § 1133(1)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1133/2/A"},"text":"Pub. L. 118–272, § 1133(2)(A)","children":[],"tail":", inserted “Indian Tribe,” after “public-utility company,” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1133/2/B"},"text":"Pub. L. 118–272, § 1133(2)(B)","children":[],"tail":", inserted “, including an aquatic ecosystem restoration project” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s1133/3"},"text":"Pub. L. 118–272, § 1133(3)","children":[],"tail":", struck out par. (4), which required the Comptroller General to carry out a followup study of the implementation of par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s1145/1"},"text":"Pub. L. 115–270, § 1145(1)","children":[],"tail":", redesignated par. (4) as (3) and struck out former par. (3) which read as follows: “The authority provided under paragraph (2) to a public-utility company, natural gas company, or railroad carrier shall expire on the date that is 10 years after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" redesignated par. (5) as (4) and substituted “"},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":"” for “4 years after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"” and “carry out a followup study” for “carry out a study”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1125/1"},"text":"Pub. L. 114–322, § 1125(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1125/2"},"text":"Pub. L. 114–322, § 1125(2)","children":[],"tail":", substituted “, natural gas company, or railroad carrier” for “or natural gas company” and “, company, or carrier” for “or company”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1125/3"},"text":"Pub. L. 114–322, § 1125(3)","children":[],"tail":", substituted “, natural gas company, or railroad carrier” for “or natural gas company” and “10 years” for “7 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1125/4"},"text":"Pub. L. 114–322, § 1125(4)","children":[],"tail":", substituted “, natural gas companies, and railroad carriers, including an evaluation of the compliance with the requirements of this section and, with respect to a permit for those entities, the requirements of applicable Federal laws” for “and natural gas companies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1006/1/A"},"text":"Pub. L. 113–121, § 1006(1)(A)","children":[],"tail":", (B), substituted “Funding to process permits” for “In general” in subsec. heading, added par. (1), redesignated text of subsec. (a) as par. (2), inserted heading, and inserted “or a public-utility company or natural gas company” after “non-Federal public entity” and “or company” after “that entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1006/1/C"},"text":"Pub. L. 113–121, § 1006(1)(C)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1006/2"},"text":"Pub. L. 113–121, § 1006(2)","children":[],"tail":", added subsecs. (d) and (e) and struck out former subsecs. (d) and (e) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—The Secretary shall ensure that all final permit decisions carried out using funds authorized under this section are made available to the public, including on the Internet."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(e) ","children":[{"tag":"inline","attrib":{},"text":"Duration of Authority","children":[],"tail":".—The authority provided under this section shall be in effect from "},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/315/s1/1"},"text":"Pub. L. 111–315, § 1(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The Secretary, after public notice, may accept and expend funds contributed by non-Federal public entities to expedite the evaluation of permits under the jurisdiction of the Department of the Army.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/315/s1/3"},"text":"Pub. L. 111–315, § 1(3)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “In carrying out this section, the Secretary shall ensure that the use of funds accepted under subsection (a) will not impact impartial decisionmaking with respect to permits, either substantively or procedurally.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/315/s1/2"},"text":"Pub. L. 111–315, § 1(2)","children":[],"tail":"–(4), added subsecs. (c) and (d), redesignated former subsec. (c) as (e), and, in subsec. (e), substituted “2016” for “2010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/120"},"text":"Pub. L. 111–120","children":[],"tail":" substituted “2010” for “2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" substituted “2009” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/434"},"text":"Pub. L. 109–434","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/209"},"text":"Pub. L. 109–209","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2006-03-31"},"text":"March 31, 2006","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/99/s1/1"},"text":"Pub. L. 109–99, § 1(1)","children":[],"tail":", substituted “The” for “In fiscal years 2001 through 2005, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/99/s1/2"},"text":"Pub. L. 109–99, § 1(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/