{"tag":"section","attrib":{"id":"id6b91046c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s988a"},"text":null,"children":[{"tag":"num","attrib":{"value":"988a"},"text":"§ 988a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of collection of charges or tolls","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b91046d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s988a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s988"},"text":"section 988 of this title","children":[],"tail":" or any other provision of law, the Corporation shall not collect any charge or toll established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s988"},"text":"section 988 of this title","children":[],"tail":" with respect to a commercial vessel (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4462/a/4"},"text":"section 4462(a)(4) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b91046e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s988a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Corporation will maintain a record of the annual amount of each charge or toll that would have been collected with respect to each such commercial vessel if it were not for paragraph (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b91046f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/ch201/s13"},"text":"May 13, 1954, ch. 201, § 13","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXIV/s805/a/4"},"text":"Pub. L. 99–662, title XIV, § 805(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4272"},"text":"100 Stat. 4272","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/331/tIII/s339"},"text":"Pub. L. 103–331, title III, § 339","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2496"},"text":"108 Stat. 2496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b910470-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b910471-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b910472-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/331"},"text":"Pub. L. 103–331","children":[],"tail":" substituted “Waiver of collection” for “Rebate of” in section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Corporation shall transfer to the Harbor Maintenance Trust Fund, at such times and under such terms and conditions as the Secretary of the Treasury may prescribe, all revenues derived from the collection of charges or tolls established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s988"},"text":"section 988 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b)(1) The Corporation shall certify to the Secretary of the Treasury, in such form and at such times as the Secretary of the Treasury shall prescribe—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the identity of any person who pays a charge or toll to the Corporation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s988"},"text":"section 988 of this title","children":[],"tail":" with respect to a commercial vessel (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4462/a/4"},"text":"section 4462(a)(4) of title 26","children":[],"tail":"),"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the amount of the toll or charge paid by such person with respect to such vessel.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Within 30 days of the receipt of a certification described in paragraph (1), the Secretary of the Treasury shall rebate, out of the Harbor Maintenance Trust Fund, to the person described in paragraph (1) the amount of the charge or toll paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s988"},"text":"section 988 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b910473-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b910474-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/s805/b"},"text":"section 805(b) of Pub. L. 99–662","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s984"},"text":"section 984 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
