{"tag":"section","attrib":{"id":"id6c739cca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804"},"text":null,"children":[{"tag":"num","attrib":{"value":"2804"},"text":"§ 2804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On September 30 of each other year beginning in 1993, the Administrator and the Under Secretary shall jointly submit to the Committee on Commerce, Science, and Transportation and the Committee on Environment and Public Works of the Senate and the Committee on Merchant Marine and Fisheries and the Committee on Public Works and Transportation of the House of Representatives a report describing the condition of the Nation’s coastal ecosystems, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739ccb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the status and health of the Nation’s coastal ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739ccc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of environmental trends in coastal ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739ccd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of sources of enironmental ","children":[{"tag":"ref","attrib":{"idref":"fn002128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “environmental”."}],"tail":" degradation affecting coastal ecosystems;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the extent to which floatables degrade coastal ecosystems, including trends in the accumulation of floatables and the threat posed by floatables to aquatic life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739ccf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact of government programs designed to abate the degradation of coastal ecosystems: ","children":[{"tag":"ref","attrib":{"idref":"fn002129"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002129"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cd0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the adequacy of monitoring programs and identification of any additional program elements which may be needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cd1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2804/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of monitoring results in areas monitored under subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 2803(d) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c739cd2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tV/s504"},"text":"Pub. L. 92–532, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/567/tV/s501"},"text":"Pub. L. 102–567, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4299"},"text":"106 Stat. 4299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c739cd3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c739cd4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6c739cd5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Public Works and Transportation of House of Representatives treated as referring to Committee on Transportation and Infrastructure of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c739cd6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of House Committee on Merchant Marine and Fisheries","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Merchant Marine and Fisheries of House of Representatives abolished and its jurisdiction transferred by House Resolution No. 6, One Hundred Fourth Congress, ","children":[{"tag":"date","attrib":{"date":"1995-01-04"},"text":"Jan. 4, 1995","children":[],"tail":". For treatment of references to Committee on Merchant Marine and Fisheries, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/b/3"},"text":"section 1(b)(3) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
