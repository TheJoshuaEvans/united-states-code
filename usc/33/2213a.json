{"tag":"section","attrib":{"id":"id6c333860-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2213a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2213a"},"text":"§ 2213a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain benefits and costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c333861-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2213a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a flood risk management or coastal storm risk management project in a region of moderate or high seismic hazard, for the purpose of a benefit-cost analysis for the project, the Secretary shall not include in that analysis any additional design and construction costs resulting from addressing seismic concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c333862-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2213a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except with respect to the benefit-cost analysis, the additional costs referred to in subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c333863-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2213a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in the total project cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c333864-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2213a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to cost-share requirements otherwise applicable to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c333865-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s152"},"text":"Pub. L. 116–260, div. AA, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2658"},"text":"134 Stat. 2658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8380"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3828"},"text":"136 Stat. 3828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c333866-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c333867-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c333868-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c333869-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “a flood risk management or coastal storm risk management project in a region” for “flood risk management project that incidentally generates seismic safety benefits in regions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c33386a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c33386b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
