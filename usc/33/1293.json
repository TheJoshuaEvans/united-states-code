{"tag":"section","attrib":{"id":"id6bc33866-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1293"},"text":null,"children":[{"tag":"num","attrib":{"value":"1293"},"text":"§ 1293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc33867-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1293/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State or local obligations issued exclusively to Federal Financing Bank for publicly owned treatment works; determination of eligibility of project by Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the conditions of this section and to such terms and conditions as the Administrator determines to be necessary to carry out the purposes of this subchapter, the Administrator is authorized to guarantee, and to make commitments to guarantee, the principal and interest (including interest accruing between the date of default and the date of the payment in full of the guarantee) of any loan, obligation, or participation therein of any State, municipality, or intermunicipal or interstate agency issued directly and exclusively to the Federal Financing Bank to finance that part of the cost of any grant-eligible project for the construction of publicly owned treatment works not paid for with Federal financial assistance under this subchapter (other than this section), which project the Administrator has determined to be eligible for such financial assistance under this subchapter, including, but not limited to, proj­ects eligible for reimbursement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1286"},"text":"section 1286 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc33868-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1293/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for issuance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No guarantee, or commitment to make a guarantee, may be made pursuant to this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc33869-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1293/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the Administrator certifies that the issuing body is unable to obtain on reasonable terms sufficient credit to finance its actual needs without such guarantee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc3386a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1293/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the Administrator determines that there is a reasonable assurance of repayment of the loan, obligation, or participation therein.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A determination of whether financing is available at reasonable rates shall be made by the Secretary of the Treasury with relationship to the current average yield on outstanding marketable obligations of municipalities of comparable maturity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc3386b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1293/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for application investigation and issuance of commitment guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is authorized to charge reasonable fees for the investigation of an application for a guarantee and for the issuance of a commitment to make a guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc3386c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1293/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commitment for repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in determining whether there is a reasonable assurance of repayment, may require a commitment which would apply to such repayment. Such commitment may include, but not be limited to, any funds received by such grantee from the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1286"},"text":"section 1286 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc3386d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 213, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/558"},"text":"Pub. L. 94–558","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2639"},"text":"90 Stat. 2639","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/483/s2/e"},"text":"Pub. L. 96–483, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2361"},"text":"94 Stat. 2361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bc3386e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bc3386f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bc33870-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/483"},"text":"Pub. L. 96–483","children":[],"tail":" struck out “(1) all or any portion of the funds retained by such grantee under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1284/b/3"},"text":"section 1284(b)(3) of this title","children":[],"tail":", and (2)” after “limited to”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6bc33871-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6bc33872-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/483"},"text":"Pub. L. 96–483","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-12-27"},"text":"Dec. 27, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/483/s2/g"},"text":"section 2(g) of Pub. L. 96–483","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1281"},"text":"section 1281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
