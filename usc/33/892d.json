{"tag":"section","attrib":{"id":"id6b7936c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d"},"text":null,"children":[{"tag":"num","attrib":{"value":"892d"},"text":"§ 892d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7936c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Administrator the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7936c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out nautical mapping and charting functions under sections 892b and 892c of this title, except for conducting hydrographic surveys, $71,000,000 for each of fiscal years 2023 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To contract for hydrographic surveys under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s892b/b/1"},"text":"section 892b(b)(1) of this title","children":[],"tail":", including the leasing or time chartering of vessels, $34,000,000 for each of fiscal years 2023 through 2028."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To operate hydrographic survey vessels owned by the United States and operated by the Administration, $38,000,000 for each of fiscal years 2023 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out geodetic functions under this subchapter, $45,000,000 for each of fiscal years 2023 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out tide and current measurement functions under this subchapter, $35,000,000 for each of fiscal years 2023 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To acquire a replacement hydrographic survey vessel capable of staying at sea continuously for at least 30 days $75,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arctic programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount authorized by this section for each fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7936cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $10,000,000 is authorized for use in the Arctic—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7936d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire hydrographic data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide hydrographic services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct coastal change analyses necessary to ensure safe navigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the management of coastal change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce risks of harm to subsistence and coastal communities associated with increased international maritime traffic; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 is authorized for use to acquire hydrographic data and provide hydrographic services in the Arctic necessary to delineate the United States extended Continental Shelf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses for surveys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts authorized by this section for each fiscal year for contract hydrographic surveys, not more than 5 percent is authorized for administrative costs associated with contract management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7936d7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384/tIII/s306"},"text":"Pub. L. 105–384, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3457"},"text":"112 Stat. 3457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIV/s432/b"},"text":"Pub. L. 105–383, title IV, § 432(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3445"},"text":"112 Stat. 3445","children":[],"tail":"; "},{"tag":"ref","attrib":