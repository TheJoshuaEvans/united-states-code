 10308(d)(4)","children":[],"tail":", substituted “$45,000,000 for each of fiscal years 2023 through 2028” for “$26,800,000 for each of fiscal years 2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10308/d/5"},"text":"Pub. L. 117–263, § 10308(d)(5)","children":[],"tail":", substituted “$35,000,000 for each of fiscal years 2023 through 2028” for “$30,564,000 for each of fiscal years 2019 through 2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/a/1"},"text":"Pub. L. 115–282, § 1001(a)(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/a/2/A"},"text":"Pub. L. 115–282, § 1001(a)(2)(A)","children":[],"tail":", substituted “surveys, $70,814,000 for each of fiscal years 2019 through 2023.” for “surveys—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $55,000,000 for fiscal year 2009;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $56,000,000 for fiscal year 2010;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $57,000,000 for fiscal year 2011; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) $58,000,000 for fiscal year 2012.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/a/2/B"},"text":"Pub. L. 115–282, § 1001(a)(2)(B)","children":[],"tail":", substituted “vessels, $25,000,000 for each of fiscal years 2019 through 2023.” for “vessels—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $32,130,000 for fiscal year 2009;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $32,760,000 for fiscal year 2010;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $33,390,000 for fiscal year 2011; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) $34,020,000 for fiscal year 2012.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/a/2/C"},"text":"Pub. L. 115–282, § 1001(a)(2)(C)","children":[],"tail":", substituted “Administration, $29,932,000 for each of fiscal years 2019 through 2023.” for “Administration—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $25,900,000 for fiscal year 2009;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $26,400,000 for fiscal year 2010;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $26,900,000 for fiscal year 2011; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) $27,400,000 for fiscal year 2012.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/a/2/D"},"text":"Pub. L. 115–282, § 1001(a)(2)(D)","children":[],"tail":", substituted “subchapter, $26,800,000 for each of fiscal years 2019 through 2023.” for “subchapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $32,640,000 for fiscal year 2009;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $33,280,000 for fiscal year 2010;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $33,920,000 for fiscal year 2011; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) $34,560,000 for fiscal year 2012.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/a/2/E"},"text":"Pub. L. 115–282, § 1001(a)(2)(E)","children":[],"tail":", substituted “subchapter, $30,564,000 for each of fiscal years 2019 through 2023.” for “subchapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $27,000,000 for fiscal year 2009;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $27,500,000 for fiscal year 2010;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $28,000,000 for fiscal year 2011; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) $28,500,000 for fiscal year 2012.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/a/3"},"text":"Pub. L. 115–282, § 1001(a)(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s1001/b"},"text":"Pub. L. 115–282, § 1001(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/386"},"text":"Pub. L. 110–386","children":[],"tail":" amended section generally. Prior to amendment, section authorized appropriations for fiscal years 2003 through 2007."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “There is authorized to be appropriated to the Administrator the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) To carry out nautical mapping and charting functions under the Act of 1947 and sections 892a and 892b of this title, except for conducting hydrographic surveys, $33,000,000 for fiscal year 1999, $34,000,000 for fiscal year 2000, and $35,000,000 for fiscal year 2001.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) To conduct hydrographic surveys under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s892a/a/1"},"text":"section 892a(a)(1) of this title","children":[],"tail":", including the leasing of ships, $33,000,000 for fiscal year 1999, $35,000,000 for fiscal year 2000, and $37,000,000 for fiscal year 2001. Of these amounts, no more than $16,000,000 is authorized for any one fiscal year to operate hydrographic survey vessels owned and operated by the Administration."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) To carry out geodetic functions under the Act of 1947, $25,000,000 for fiscal year 1999, $30,000,000 for fiscal year 2000, and $30,000,000 for fiscal year 2001.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) To carry out tide and current measurement functions under the Act of 1947, $22,500,000 for each of fiscal years 1999 through 2001. Of these amounts $4,500,000 is authorized for each fiscal year to implement and operate a national quality control system for real-time tide and current and maintain the national tide network, and $7,000,000 is authorized for each fiscal year to design and install real-time tide and current data measurement systems under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s892a/b/4"},"text":"section 892a(b)(4) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" amended section generally, substituting present provisions for substantially identical provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b7936dc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7936dd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/s432/a"},"text":"section 432(a) of Pub. L. 105–383","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s892c"},"text":"section 892c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
