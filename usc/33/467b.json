{"tag":"section","attrib":{"id":"id6b31a5dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467b"},"text":null,"children":[{"tag":"num","attrib":{"value":"467b"},"text":"§ 467b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation reports to Governors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after inspection of a dam, the Secretary shall notify the Governor of the State in which such dam is located the results of such investigation. In any case in which any hazardous conditions are found during an inspection, upon request by the owner, the Secretary, acting through the Chief of Engineers, may perform detailed engineering studies to determine the structural integrity of the dam, subject to reimbursement of such expense by the owner of such dam. The Secretary shall immediately notify the Governor of any hazardous conditions found during an inspection. The Secretary shall provide advice to the Governor, upon request, relating to timely remedial measures necessary to mitigate or obviate any hazardous conditions found during an inspection.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b31a5de-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s4"},"text":"Pub. L. 92–367, § 4","children":[],"tail":", formerly § 3, "},{"tag":"date","attrib":{"date":"1972-08-08"},"text":"Aug. 8, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/507"},"text":"86 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXII/s1204"},"text":"Pub. L. 99–662, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4263"},"text":"100 Stat. 4263","children":[],"tail":"; renumbered § 4 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s215/c/3"},"text":"Pub. L. 104–303, title II, § 215(c)(3)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3685"},"text":"110 Stat. 3685","children":[],"tail":", 3687.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b31a5df-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b31a5e0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b31a5e1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s4"},"text":"section 4 of Pub. L. 92–367","children":[],"tail":" was renumbered section 5 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s467c"},"text":"section 467c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b31a5e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" inserted section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" inserted “In any case in which any hazardous conditions are found during an inspection, upon request by the owner, the Secretary, acting through the Chief of Engineers, may perform detailed engineering studies to determine the structural integrity of the dam, subject to reimbursement of such expense by the owner of such dam.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
