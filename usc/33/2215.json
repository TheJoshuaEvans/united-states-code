{"tag":"section","attrib":{"id":"id6c33387a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215"},"text":null,"children":[{"tag":"num","attrib":{"value":"2215"},"text":"§ 2215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility studies; planning, engineering, and design","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c33387b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c33387c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c33387d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not initiate any feasibility study for a water resources project after ","children":[{"tag":"date","attrib":{"date":"1986-11-17"},"text":"November 17, 1986","children":[],"tail":", until appropriate non-Federal interests agree, by contract, to contribute 50 percent of the cost of the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c33387e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of cost share during period of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period of the study, the non-Federal share of the cost of the study payable under subparagraph (A) shall be 50 percent of the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c33387f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost estimate for the study as contained in the feasibility cost-sharing agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c333880-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any excess of the cost of the study over the cost estimate if the excess results from—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c333881-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in Federal law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c333882-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in the scope of the study requested by the non-Federal interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c333883-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of cost share on authorization of project or termination of study","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c333884-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project timely authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise agreed to by the Secretary and the non-Federal interests and subject to clause (ii), the non-Federal share of any excess of the cost of the study over the cost estimate (excluding any excess cost described in subparagraph (B)(ii)) shall be payable on the date on which the Secretary and the non-Federal interests enter into an agreement pursuant to section 2211(e) or 2213(j) of this title with respect to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c333885-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project not timely authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the project that is the subject of the study is not authorized by the date that is 5 years after the completion of the final report of the Chief of Engineers concerning the study or the date that is 2 years after the termination of the study, the non-Federal share of any excess of the cost of the study over the cost estimate (excluding any excess cost described in subparagraph (B)(ii)) shall be payable to the United States on that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c333886-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of cost estimate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost estimate referred to in subparagraph (B)(i) may be amended only by agreement of the Secretary and the non-Federal interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c333887-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share required under this paragraph may be satisfied by the provision of services, materials, supplies, or other in-kind services necessary to prepare the feasibility report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c333888-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not apply to any water resources study primarily designed for the purposes of navigational improvements in the nature of dams, locks, and channels on the Nation’s system of inland waterways.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c333889-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed project reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this subsection that apply to a feasibility study also shall apply to a study that results in a detailed project report, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c33388a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first $100,000 of the costs of a study that results in a detailed project report shall be a Federal expense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c33388b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1)(C)(ii) shall not apply to such a study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c33388c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning and engineering","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not initiate any planning or engineering for a water resources project until appropriate non-Federal interests agree, by contract, to contribute 50 percent of the cost of the planning and engineering during the period of the planning and engineering. Costs of planning and engineering of projects for which non-Federal interests contributed 50 percent of the cost of the feasibility study shall be treated as costs of construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c33388d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Costs of design of a water resources project shall be shared in the same percentage as the purposes of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c33388e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c33388f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed project report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “detailed project report” means a report for a project not specifically authorized by Congress in law or otherwise that determines the feasibility of the project with a level of detail appropriate to the scope and complexity of the recommended solution and sufficient to proceed directly to the preparation of contract plans and specifications. The term includes any associated environmental impact statement and mitigation plan. For a project for which the Federal cost does not exceed $1,000,000, the term includes a planning and design analysis document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c333890-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2215/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “feasibility study” means a study that results in a feasibility report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282"},"text":"section 2282 of this title","children":[],"tail":", and any associated environmental impact statement and mitigation plan, prepared by the Corps of Engineers for a water resources project. The term includes a study that results in a project implementation report prepared under title VI of the Water Resources Development Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/stat/114/2680-2694"},"text":"114 Stat. 2680–2694","children":[],"tail":"), a general reevaluation report, and a limited reevaluation report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c333891-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tI/s105"},"text":"Pub. L. 99–662, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4088"},"text":"100 Stat. 4088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s301"},"text":"Pub. L. 101–640, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4633"},"text":"104 Stat. 4633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s203/a"},"text":"Pub. L. 104–303, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3677"},"text":"110 Stat. 3677","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s225"},"text":"Pub. L. 106–541, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2598"},"text":"114 Stat. 2598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2043/a"},"text":"Pub. L. 110–114, title II, § 2043(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1101"},"text":"121 Stat. 1101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c333892-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c333893-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c333894-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Water Resources Development Act of 2000, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541"},"text":"Pub. L. 106–541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2572"},"text":"114 Stat. 2572","children":[],"tail":". Title VI of the Act is not classified to the Code. For complete classification of this Act to the Code, see Short Title of 2000 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c35a895-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2043/a/1"},"text":"Pub. L. 110–114, § 2043(a)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2043/a/2"},"text":"Pub. L. 110–114, § 2043(a)(2)","children":[],"tail":", struck out “authorized by this Act” before “for a water resources project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2043/a/3"},"text":"Pub. L. 110–114, § 2043(a)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541"},"text":"Pub. L. 106–541","children":[],"tail":" substituted “The” for “Not more than ½ of the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s203/a/1"},"text":"Pub. L. 104–303, § 203(a)(1)","children":[],"tail":", inserted heading and amended text of par. (1) generally. Prior to amendment text read as follows: “The Secretary shall not initiate any feasibility study for a water resources project after "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"November 17, 1986","children":[],"tail":", until appropriate non-Federal interests agree, by contract, to contribute 50 percent of the cost for such study during the period of such study. Not more than one-half of such non-Federal contribution may be made by the provision of services, materials, supplies, or other in-kind services necessary to prepare the feasibility report.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/s203/a/2"},"text":"Pub. L. 104–303, § 203(a)(2)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640"},"text":"Pub. L. 101–640","children":[],"tail":" inserted at end “Costs of planning and engineering of projects for which non-Federal interests contributed 50 percent of the cost of the feasibility study shall be treated as costs of construction.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c35a896-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c35a897-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s203/b"},"text":"Pub. L. 104–303, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3678"},"text":"110 Stat. 3678","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/303/tII/s203/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply notwithstanding any feasibility cost-sharing agreement entered into by the Secretary and the non-Federal interests. On request of the non-Federal interest, the Secretary shall amend any feasibility cost-sharing agreements in effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":"] so as to conform the agreements with the amendments.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c35a898-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Requirement of Reimbursement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s203/c"},"text":"Pub. L. 104–303, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3678"},"text":"110 Stat. 3678","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/303/tII/s203/c"},"text":"“Nothing in this section [amending this section and enacting provisions set out above] or any amendment made by this section requires the Secretary to reimburse the non-Federal interests for funds previously contributed for a study.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
