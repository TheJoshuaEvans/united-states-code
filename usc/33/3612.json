{"tag":"section","attrib":{"id":"id6c892006-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3612"},"text":null,"children":[{"tag":"num","attrib":{"value":"3612"},"text":"§ 3612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerating innovation at Cooperative Institutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c892007-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus on emerging technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall consider evaluating the goals of 1 or more Cooperative Institutes of the Administration to include focusing on advancing or applying emerging technologies, which may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c892008-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied uses and development of real-time and other advanced genetic technologies and applications, including such technologies and applications that derive genetic material directly from environmental samples without any obvious signs of biological source material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c892009-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deployment of, and improvements to the durability, maintenance, and other lifecycle concerns of, advanced unmanned vehicles, regional small research vessels, and other research vessels that support and launch unmanned vehicles and sensors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c89200a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3612/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supercomputing and big data management, including data collected through model outputs, electronic monitoring, and remote sensing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c89200b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Cooperative Institutes shall work with the Interagency Ocean Observation Committee, the regional associations of the Integrated Ocean Observing System, and other ocean observing programs to coordinate technology needs and the transition of new technologies from research to operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c89200c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCI/s10104"},"text":"Pub. L. 117–263, div. J, title CI, § 10104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3958"},"text":"136 Stat. 3958","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c89200d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c89200e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c89200f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Integrated Coastal and Ocean Observation System Act of 2009 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c892010-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c892011-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCI/s10101"},"text":"Pub. L. 117–263, div. J, title CI, § 10101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3957"},"text":"136 Stat. 3957","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dJ/tCI/s10101"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purpose of this title [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3613"},"text":"section 3613 of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s893c"},"text":"section 893c of this title","children":[],"tail":", and enacting provisions set out as notes under this section] is to promote and support—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monitoring, understanding, and exploration of the Great Lakes, oceans, bays, estuaries, and coasts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection, analysis, synthesis, and sharing of data related to the Great Lakes, oceans, bays, estuaries, and coasts to facilitate scientific research and operational decisionmaking.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c892012-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Additional Funds Authorized","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCI/s10106"},"text":"Pub. L. 117–263, div. J, title CI, § 10106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3961"},"text":"136 Stat. 3961","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dJ/tCI/s10106"},"text":"“Funds to carry out this title [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3613"},"text":"section 3613 of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s893c"},"text":"section 893c of this title","children":[],"tail":", and enacting provisions set out as notes under this section] may, as provided in advance in appropriations Acts, only come from within amounts authorized to be appropriated to the National Oceanic and Atmospheric Administration.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id6c892013-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCI/s10102"},"text":"Pub. L. 117–263, div. J, title CI, § 10102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3957"},"text":"136 Stat. 3957","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dJ/tCI/s10102"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3613"},"text":"section 3613 of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s893c"},"text":"section 893c of this title","children":[],"tail":", and enacting provisions set out as notes under this section]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Administration’ means the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Administrator’ means the Under Secretary of Commerce for Oceans and Atmosphere in the capacity as Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Indian Tribe’ has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
