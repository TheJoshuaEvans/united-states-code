{"tag":"section","attrib":{"id":"id6c0f839d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1474"},"text":null,"children":[{"tag":"num","attrib":{"value":"1474"},"text":"§ 1474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal intervention actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Upon a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1472"},"text":"section 1472 of this title","children":[],"tail":" of a grave and imminent danger to the coastline or related interests of the United States, the Secretary may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f839e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1474/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and direct all public and private efforts directed at the removal or elimination of the threatened pollution damage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f839f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1474/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or indirectly undertake the whole or any part of any salvage or other action he could require or direct under subsection (1) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1474/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove, and, if necessary, destroy the ship and cargo which is the source of the danger.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f83a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":