{"tag":"section","attrib":{"id":"id6c8ddb09-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901"},"text":null,"children":[{"tag":"num","attrib":{"value":"3901"},"text":"§ 3901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8ddb0a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community water system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community water system” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"section 300f of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal credit instrument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal credit instrument” means a secured loan or loan guarantee authorized to be made available under this chapter with respect to a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment-grade rating","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “investment-grade rating” means a rating of BBB minus, Baa3, bbb minus, BBB (low), or higher assigned by a rating agency to project obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lender","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8ddb0f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lender” means any non-Federal qualified institutional buyer (as defined in section 230.144A(a) of title 17, Code of Federal Regulations (or a successor regulation), known as Rule 144A(a) of the Securities and Exchange Commission and issued under the Securities Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lender” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c8ddb11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified retirement plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4974/c"},"text":"section 4974(c) of title 26","children":[],"tail":") that is a qualified institutional buyer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c8ddb12-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s414/d"},"text":"section 414(d) of title 26","children":[],"tail":") that is a qualified institutional buyer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb13-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan guarantee” means any guarantee or other pledge by the Secretary or the Administrator to pay all or part of the principal of, and interest on, a loan or other debt obligation issued by an obligor and funded by a lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb14-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “obligor” means an eligible entity that is primarily liable for payment of the principal of, or interest on, a Federal credit instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb15-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project obligation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8ddb16-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project obligation” means any note, bond, debenture, or other debt obligation issued by an obligor in connection with the financing of a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb17-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project obligation” does not include a Federal credit instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb18-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rating agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rating agency” means a credit rating agency registered with the Securities and Exchange Commission as a nationally recognized statistical rating organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of title 15","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb19-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secured loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “secured loan” means a direct loan or other debt obligation issued by an obligor and funded by the Secretary or Administrator, as applicable, in connection with the financing of a project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3908"},"text":"section 3908 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb1a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8ddb1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb1c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddb1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State infrastructure financing authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State infrastructure financing authority” means the State entity established or designated by the Governor of a State to receive a capitalization grant provided by, or otherwise carry out the requirements of, title VI of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"33 U.S.C. 1381","children":[],"tail":" et."},{"tag":"ref","attrib":{"idref":"fn002161"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":" seq.) or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsidy amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “subsidy amount” means the amount of budget authority sufficient to cover the estimated long-term cost to the Federal Government of a Federal credit instrument, as calculated on a net present value basis, excluding administrative costs and any incidental effects on governmental receipts or outlays in accordance with the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"2 U.S.C. 661","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial completion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “substantial completion”, with respect to a project, means the earliest date on which a project is considered to perform the functions for which the project is designed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddb22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3901/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment works","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “treatment works” has the meaning given the term in section 212 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1292"},"text":"33 U.S.C. 1292","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8ddb23-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5022"},"text":"Pub. L. 113–121, title V, § 5022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1332"},"text":"128 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8ddb24-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8ddb25-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c8ddb26-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Securities Act of 1933, referred to in par. (5)(A), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"act May 27, 1933, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in par. (12), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/816"},"text":"86 Stat. 816","children":[],"tail":", which is classified generally to chapter 26 (§ 1251 et seq.) of this title. Title VI of the Act is classified generally to subchapter VI (§ 1381 et seq.) of chapter 26 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Credit Reform Act of 1990, referred to in par. (13), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-609"},"text":"104 Stat. 1388–609","children":[],"tail":", which is classified generally to subchapter III (§ 661 et seq.) of chapter 17A of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c8ddb27-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c8ddb28-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5021"},"text":"Pub. L. 113–121, title V, § 5021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1332"},"text":"128 Stat. 1332","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/121/tV/s5021"},"text":"“This subtitle [subtitle C (§§ 5021–5035) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":", enacting this chapter] may be cited as the ‘Water Infrastructure Finance and Innovation Act of 2014’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c8ddb29-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
