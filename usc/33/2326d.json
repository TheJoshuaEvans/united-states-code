{"tag":"section","attrib":{"id":"id6c56ed30-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2326d"},"text":"§ 2326d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative projects to maintenance dredging","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into agreements to assume the operation and maintenance costs of an alternative project to maintenance dredging for a Federal navigation channel if the costs of the operation and maintenance of the alternative project, and any remaining costs necessary for maintaining the Federal navigation channel, are less than the costs of maintaining such channel without the alternative project.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c595d31-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1106"},"text":"Pub. L. 114–322, title I, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1634"},"text":"130 Stat. 1634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595d32-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595d33-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595d34-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c595d35-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595d36-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1002"},"text":"section 1002 of Pub. L. 114–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
