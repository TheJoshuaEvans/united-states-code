{"tag":"section","attrib":{"id":"id6b89d82b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s929"},"text":null,"children":[{"tag":"num","attrib":{"value":"929"},"text":"§ 929.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record of injury or death","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every employer shall keep a record in respect of any injury to an employee. Such record shall contain such information of disease, other disability, or death in respect of such injury as the Secretary may by regulation require, and shall be available to inspection by the Secretary or by any State authority at such times and under such conditions as the Secretary may by regulation prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b89d82c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s29"},"text":"Mar. 4, 1927, ch. 509, § 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1438"},"text":"44 Stat. 1438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s27/a/2"},"text":"Pub. L. 98–426, § 27(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1654"},"text":"98 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b89d82d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b89d82e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b89d82f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"child