{"tag":"section","attrib":{"id":"id6b3ffee7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s549a"},"text":null,"children":[{"tag":"num","attrib":{"value":"549a"},"text":"§ 549a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of navigation, flood control, and water supply projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army, acting through the Chief of Engineers, is authorized to review the operation of projects the construction of which has been completed and which were constructed by the Corps of Engineers in the interest of navigation, flood control, water supply, and related purposes, when found advisable due ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “due to”."}],"tail":" the significantly changed physical or economic conditions, and to report thereon to Congress with recommendations on the advisability of modifying the structures or their operation, and for improving the quality of the environment in the overall public interest."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3ffee8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611/tII/s216"},"text":"Pub. L. 91–611, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1830"},"text":"84 Stat. 1830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3ffee9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3ffeea-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b3ffeeb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611"},"text":"Pub. L. 91–611","children":[],"tail":", popularly known as the “Flood Control Act of 1970”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
