{"tag":"section","attrib":{"id":"id6c9507a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102"},"text":null,"children":[{"tag":"num","attrib":{"value":"4102"},"text":"§ 4102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination regarding assessment and acquisition by National Oceanic and Atmospheric Administration of unmanned maritime systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9507a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall direct the Office of Oceanic and Atmospheric Research (in this chapter referred to as “OAR”) and the Office of Marine and Aviation Operations (in this chapter referred to as “OMAO”)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9507a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the Administration’s research, assessment, and acquisition of unmanned maritime systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to consider the use of unmanned maritime systems in cooperative activities of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination within the Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9507aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unmanned Systems Executive Oversight Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In meeting the requirements described in subsection (a), the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9507ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the Unmanned Systems Executive Oversight Board (in this chapter referred to as the “USEOB”) as the coordinating mechanism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that OAR and OMAO address requirements throughout the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In utilizing the USEOB under paragraph (1), the Administrator shall ensure that representation on the USEOB is included from the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9507ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Ocean Exploration (OER).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program office of the Integrated Ocean Observing System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other offices of the Administration as the Administrator determines are actively engaged with unmanned maritime systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Navy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9507b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9507b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make efforts to coordinate with the Secretary of the Navy to leverage expertise in the development and operational transition of unmanned maritime systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" align with, utilize, and inform the Deputy Under Secretary of Commerce for Operations and the Oceanographer of the Navy’s strategic and operational priorities, particularly for missions and geography within the Administration’s purview;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to utilize Naval unmanned systems test or training ranges, such as the Gulf of Mexico Unmanned Systems Test and Training Range of the Naval Meteorology and Oceanography Command, and maximize interagency cooperation and sharing of best practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to formalize coordination, execute a memorandum of understanding with the Secretary of the Navy that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c9507b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporating consideration of priorities and requirements of the Administration into research and development activities conducted by the Secretary of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c9507b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation intended to encourage and facilitate efforts by the Administration to partner with the Navy to procure unmanned maritime systems and to establish, instrument, and operate test or training ranges and related facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c9507b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopting procedures defined by the Secretary of the Navy for the Administration to access and utilize test or training ranges or related Naval facilities for purposes identified in paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c9507ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other topics as the Administrator considers necessary or advisable, including mapping, bathymetry, observations, and ocean exploration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall, if practicable, carry out the activities authorized by this chapter at a facility where the Navy and the Administration are co-located, for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9507bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gaining efficiencies through collaboration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Advancing development of unmanned maritime systems, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c9507be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c9507bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c9507c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems modifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c9507c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems integration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9507c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accelerating transition from concept to manufacturing and acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, the Administrator and the Secretary of the Navy may utilize the National Oceanographic Partnership Program, established under chapter 665 of title 10, as a mechanism for providing interagency coordination for the advancement of unmanned maritime systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with academic sector","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Administrator, in consultation with the Secretary of the Navy, may coordinate and co-locate with an academic research institution, or consortium of academic research institutions, for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9507c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maximizing opportunities for research and development of unmanned maritime systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing training in unmanned maritime systems as part of an accredited certificate or degree program of education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitating the commercialization of unmanned maritime systems through public-private partnerships that includes academic research institutions, private industry, and public safety agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arranging access to and use of additional facilities that support testing and assessment of or training with respect to unmanned maritime systems under environmental conditions of interest, increasing operational tolerance under such conditions, certifying operational capacity under such conditions, whether real or simulated, and training operators of unmanned maritime systems in real or simulated environments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitating engagement with other academic institutions with interest or relevant expertise in unmanned maritime systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting information sharing between the academic, environmental, and military institutions to lead to more robust, mission-oriented unmanned maritime systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9507cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement with the private sector","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Other than as described in subsection (e), the Administrator, in consultation with the Secretary of the Navy, may, in carrying out this chapter, to the extent practicable, coordinate and consult with the private sector—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9507cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the commercialization of unmanned maritime systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9507cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4102/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist with their assessment of commercially available unmanned maritime systems to support the missions and goals of the Navy, the Administration, and cooperative activities of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9507ce-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/394/s3"},"text":"Pub. L. 115–394, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5282"},"text":"132 Stat. 5282","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
