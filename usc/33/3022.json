{"tag":"section","attrib":{"id":"id6c760e45-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022"},"text":null,"children":[{"tag":"num","attrib":{"value":"3022"},"text":"§ 3022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760e46-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convening","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once each year and at such other times as the Secretary determines necessary, the Secretary shall convene a personnel board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A board convened under subsection (a) shall consist of five or more officers who are serving in or above the permanent grade of the officers under consideration by the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Officers on the retired list may be recalled to serve on such personnel boards as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No membership on two successive boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No officer may be a member of two successive personnel boards convened to consider officers of the same grade for promotion or separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each personnel board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Secretary such changes as may be necessary to correct any erroneous position on the lineal list that was caused by administrative error; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make selections and recommendations to the Secretary and the President for the appointment, promotion, involuntary separation, continuation, and involuntary retirement of officers in the commissioned officer corps of the Administration as prescribed in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action on recommendations not acceptable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any recommendation by a board convened under subsection (a) is not accepted by the Secretary or the President, the board shall make such further recommendations as the Secretary or the President considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for officers to opt out of promotion consideration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Oceanic and Atmospheric Administration Commissioned Officer Corps may provide that an officer, upon the officer’s request and with the approval of the Director, be excluded from consideration for promotion by a personnel board convened under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall approve a request made by an officer under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760e52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the request is to allow the officer to complete a broadening assignment, advanced education, another assignment of significant value to the Administration, a career progression requirement delayed by the assignment or education, or a qualifying personal or professional circumstance, as determined by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines the exclusion from consideration is in the best interest of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3022/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has not previously failed selection for promotion to the grade for which the officer requests the exclusion from consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760e55-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s222"},"text":"Pub. L. 107–372, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3085"},"text":"116 Stat. 3085","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tIII/s302"},"text":"Pub. L. 116–259, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1171"},"text":"134 Stat. 1171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760e56-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760e57-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c760e58-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(2), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3082"},"text":"116 Stat. 3082","children":[],"tail":", which is classified principally to this chapter. For complete classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c760e59-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853r"},"text":"section 853r of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760e5a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259"},"text":"Pub. L. 116–259","children":[],"tail":" amended section generally. Prior to amendment, section related to convening, duties and recommendations of personnel boards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
