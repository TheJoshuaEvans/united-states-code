{"tag":"section","attrib":{"id":"id6c24e0b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962"},"text":"§ 1962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors of the Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c24e0b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall have a governing Board of Directors (in this title ","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" referred to as the “Board”), which shall consist of the Under Secretary and 12 additional Directors appointed in accordance with subsection (b) from among individuals who are United States citizens."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of diverse points of view","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the membership of the Board shall represent diverse points of view relating to the assessment, prevention, reduction, and removal of marine debris.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointment as a Director of the Foundation shall not constitute employment by, or the holding of an office of, the United States for the purpose of any Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of Board regarding appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For appointments made under paragraph (2), the Board shall submit to the Under Secretary recommendations on candidates for appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), after consulting with the EPA Administrator, the Director of the United States Fish and Wildlife Service, the Assistant Secretary of State for the Bureau of Oceans and International Environmental and Scientific Affairs, and the Administrator of the United States Agency for International Development, considering the recommendations submitted by the Board, and with the approval of the Secretary of Commerce, the Under Secretary shall appoint 12 Directors who meet the criteria established by subsection (a), of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c24e0c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 4 shall be educated or experienced in the assessment, prevention, reduction, or removal of marine debris, which may include an individual with expertise in post-consumer materials management or a circular economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 shall be educated or experienced in the assessment, prevention, reduction, or removal of marine debris outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 shall be educated or experienced in ocean and coastal resource conservation science or policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 shall be educated or experienced in international trade or foreign policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Director appointed under paragraph (2) shall be appointed for a term of 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c24e0c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall fill a vacancy on the Board with the approval of the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of appointments to fill unexpired terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed to fill a vacancy that occurs before the expiration of the term of a Director shall be appointed for the remainder of the term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual shall not serve more than 2 consecutive terms as a Director, excluding any term of less than 6 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation before removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may remove a Director from the Board only after consultation with the Assistant Secretary of State for the Bureau of Oceans and International Environmental and Scientific Affairs, the Director of the United States Fish and Wildlife Service, the Administrator of the United States Agency for International Development, and the EPA Administrator and with the approval of the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman shall be elected by the Board from its members for a 2-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the current membership of the Board shall constitute a quorum for the transaction of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet at the call of the Chairman at least once a year. If a Director misses 3 consecutive regularly scheduled meetings, that individual may be removed from the Board and that vacancy filled in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without pay, but may be reimbursed for the actual and necessary traveling and subsistence expenses incurred by them in the performance of the duties of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may complete the organization of the Foundation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c24e0d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointing the initial officers and employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopting a constitution and bylaws consistent with the purposes of the Foundation and the provisions of this title; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertaking of other such acts as may be necessary to carry out the provisions of this title.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following limitations apply with respect to the appointment of officers and employees of the Foundation:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c24e0d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers and employees may not be appointed until the Foundation has sufficient funds to pay them for their service. Officers and employees of the Foundation shall be appointed without regard to the provisions of title 5 governing appointments in the competitive service, and may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c24e0d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The first officer or employee appointed by the Board shall be the Secretary of the Board who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c24e0d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve, at the direction of the Board, as the chief executive officer of the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c24e0d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be knowledgeable and experienced in matters relating to the assessment, prevention, reduction, and removal of marine debris.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief executive officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; removal; review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall appoint and review the performance of, and may remove, the chief executive officer of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1962/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief executive officer of the Foundation may appoint, remove, and review the performance of any officer or employee of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c24e0db-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s112"},"text":"Pub. L. 109–449, § 112","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s112"},"text":"Pub. L. 116–224, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1075"},"text":"134 Stat. 1075","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s112"},"text":"Pub. L. 109–449, § 112","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/a"},"text":"Pub. L. 119–65, § 3(a)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c24e0dc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c24e0dd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c24e0de-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsecs. (a)(1) and (g)(1)(B), (C), means title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1074"},"text":"134 Stat. 1074","children":[],"tail":". This subchapter and subchapter III of this chapter were originally enacted as subtitles B and C, respectively, of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" and were transferred to subtitles B and C, respectively, of "},{"tag":"ref","attrib":{"href":"/us/pl/109/449"},"text":"Pub. L. 109–449","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":", §§ 3(a), 4(a), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":", 1989. Consequently, the reference to “this title” probably should be to “this subtitle and subtitle C”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c24e0df-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4212"},"text":"section 4212 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c24e0e0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/1/B"},"text":"Pub. L. 119–65, § 3(d)(1)(B)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/1/A"},"text":"Pub. L. 119–65, § 3(d)(1)(A)","children":[],"tail":", (C), redesignated par. (1) as (2) and, in introductory provisions, substituted “considering” for “and considering” and inserted “and with the approval of the Secretary of Commerce,” after “by the Board,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/1/A"},"text":"Pub. L. 119–65, § 3(d)(1)(A)","children":[],"tail":", (D), redesignated par. (2) as (3) and amended it generally. Prior to amendment, par. related to length of terms of Directors and initial appointments to new member positions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/1/A"},"text":"Pub. L. 119–65, § 3(d)(1)(A)","children":[],"tail":", redesignated par. (3) as (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/1/E"},"text":"Pub. L. 119–65, § 3(d)(1)(E)","children":[],"tail":", inserted “with the approval of the Secretary of Commerce” after “the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/1/A"},"text":"Pub. L. 119–65, § 3(d)(1)(A)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/1/A"},"text":"Pub. L. 119–65, § 3(d)(1)(A)","children":[],"tail":", (F), redesignated par. (5) as (6) and inserted “the Administrator of the United States Agency for International Development,” after “Service,” and “and with the approval of the Secretary of Commerce” after “EPA Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/2/A"},"text":"Pub. L. 119–65, § 3(d)(2)(A)","children":[],"tail":", substituted “the initial officers and employees” for “officers and employees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/2/B"},"text":"Pub. L. 119–65, § 3(d)(2)(B)","children":[],"tail":", substituted “the chief executive officer of the Foundation” for “its chief operating officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/d/3"},"text":"Pub. L. 119–65, § 3(d)(3)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
