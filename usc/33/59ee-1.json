{"tag":"section","attrib":{"id":"id6b12ad2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59ee–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"59ee–1"},"text":"§ 59ee–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of nonnavigability for portion of Sacramento Deep Water Ship Channel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All waters within such portion of the project are declared to be nonnavigable waters of the United States solely for the purposes of the General Bridge Act of 1946 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s525"},"text":"33 U.S.C. 525","children":[],"tail":" et seq.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b12ad2b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tIII/s347/a/2"},"text":"Pub. L. 106–541, title III, § 347(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2618"},"text":"114 Stat. 2618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b12ad2c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b12ad2d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b12ad2e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"“Such portion of the project”, referred to in text, means “The portion of the project for navigation, Sacramento Deep Water Ship Channel, California, authorized by section 202(a) of the Water Resources Development Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/100/4092"},"text":"100 Stat. 4092","children":[],"tail":"), beginning from the confluence of the Sacramento River and the Barge Canal to a point 3,300 feet west of the William G. Stone Lock western gate (including the William G. Stone Lock and the Bascule Bridge and Barge Canal).” See first sentence of "},{"tag":"ref","attrib":{"href":"/us/pl/106/541/s347/a/2"},"text":"section 347(a)(2) of Pub. L. 106–541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2618"},"text":"114 Stat. 2618","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The General Bridge Act of 1946, referred to in text, is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"act Aug. 2, 1946, ch. 753","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/847"},"text":"60 Stat. 847","children":[],"tail":", which is classified generally to subchapter III (§ 525 et seq.) of chapter 11 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s525"},"text":"section 525 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b12ad2f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s347/a/2"},"text":"section 347(a)(2) of Pub. L. 106–541","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
