{"tag":"section","attrib":{"id":"id6b55826e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s669"},"text":null,"children":[{"tag":"num","attrib":{"value":"669"},"text":"§ 669.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition by hydraulic miners","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The individual proprietor or proprietors, or in case of a corporation, its manager or agent appointed for that purpose, owning mining ground in the territory in the State of California mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s663"},"text":"section 663 of this title","children":[],"tail":", which it is desired to work by the hydraulic process, must file with said commission a verified petition, setting forth such facts as will comply with law and the rules prescribed by said commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b55826f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-01/ch183/s9"},"text":"Mar. 1, 1893, ch. 183, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/508"},"text":"27 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b558270-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b558271-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b558272-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"California Debris Commission abolished and functions transferred to Secretary of the Army by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1106"},"text":"Pub. L. 99–662, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4229"},"text":"100 Stat. 4229","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
