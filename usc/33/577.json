{"tag":"section","attrib":{"id":"id6b472a1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577"},"text":null,"children":[{"tag":"num","attrib":{"value":"577"},"text":"§ 577.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small river and harbor improvement projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b472a1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment from appropriations for construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army is authorized to allot from any appropriations hereafter made for rivers and harbors not to exceed $62,500,000 for any one fiscal year for the construction of small river and harbor improvement projects not specifically authorized by Congress which will result in substantial benefits to navigation and which can be operated consistently with appropriate and economic use of the waters of the Nation for other purposes, when in the opinion of the Chief of Engineers such work is advisable, if benefits are in excess of the cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b472a20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $15,000,000 shall be allotted for the construction of a project under this section at any single locality and the amount allotted shall be sufficient to complete the Federal participation in the project under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b472a21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lands, easements, and rights-of-way; indemnification; assurances of local cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Local interests shall provide without cost to the United States all necessary lands, easements and rights-of-way for all projects to be constructed under the authority of this section. In addition, local interests may be required to hold and save the United States free from damages that may result from the construction and maintenance of the project and may be required to provide such additional local cooperation as the Chief of Engineers deems appropriate. A State, county, municipality or other responsible local entity shall give assurance satisfactory to the Chief of Engineers that such conditions of cooperation as are required will be accomplished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b472a22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of costs by non-Federal interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal interests may be required to share in the cost of the project to the extent that the Chief of Engineers deems that such cost should not be borne by the Federal Government in view of the recreational or otherwise special or local nature of the project benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b472a23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completeness of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each project for which money is allotted under this section shall be complete in itself and not commit the United States to any additional improvement to insure its successful operation, other than routine maintenance, and except as may result from the normal procedure applying to projects authorized after submission of survey reports, and projects constructed under the authority of this section shall be considered as authorized projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b472a24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s577/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low water access navigation channels from existing channel of Mississippi River","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to, but not be limited to, the provision of low water access navigation channels from the existing channel of the Mississippi River to harbor areas heretofore or now established and located along the Mississippi River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b472a25-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/645/tI/s107"},"text":"Pub. L. 86–645, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/486"},"text":"74 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/298/tIII/s310/a"},"text":"Pub. L. 89–298, title III, § 310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-27"},"text":"Oct. 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1095"},"text":"79 Stat. 1095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/611/tI/s112/a"},"text":"Pub. L. 91–611, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1821"},"text":"84 Stat. 1821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/587/s133/a"},"text":"Pub. L. 94–587, § 133(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2928"},"text":"90 Stat. 2928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s915/d"},"text":"Pub. L. 99–662, title IX, § 915(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4191"},"text":"100 Stat. 4191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2022"},"text":"Pub. L. 110–114, title II, § 2022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1078"},"text":"121 Stat. 1078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1030/b"},"text":"Pub. L. 113–121, title I, § 1030(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1231"},"text":"128 Stat. 1231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tI/s1157/b"},"text":"Pub. L. 115–270, title I, § 1157(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3794"},"text":"132 Stat. 3794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1107/d"},"text":"Pub. L. 118–272, div. A, title I, § 1107(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3004"},"text":"138 Stat. 3004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b472a26-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b472a27-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b472a28-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" substituted “$15,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" substituted “$62,500,000” for “$50,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1030/b/1"},"text":"Pub. L. 113–121, § 1030(b)(1)","children":[],"tail":", substituted “$50,000,000” for “$35,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1030/b/2"},"text":"Pub. L. 113–121, § 1030(b)(2)","children":[],"tail":", substituted “$10,000,000” for “$7,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" substituted “$7,000,000” for “$4,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" substituted “$35,000,000” for “$25,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" substituted “$4,000,000” for “$2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/587"},"text":"Pub. L. 94–587","children":[],"tail":" substituted “$2,000,000” for “$1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611"},"text":"Pub. L. 91–611","children":[],"tail":" substituted “$25,000,000” for “$10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/611"},"text":"Pub. L. 91–611","children":[],"tail":" substituted “$1,000,000” for “$500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/298/s310/a/1"},"text":"Pub. L. 89–298, § 310(a)(1)","children":[],"tail":", substituted “$10,000,000” for “$2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/298/s310/a/2"},"text":"Pub. L. 89–298, § 310(a)(2)","children":[],"tail":", substituted “$500,000” for “$200,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b472a29-3a70-11f1-9100-cf79f4fb4b3e"},"text":nul