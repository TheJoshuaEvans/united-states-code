{"tag":"section","attrib":{"id":"id6c785705-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042"},"text":null,"children":[{"tag":"num","attrib":{"value":"3042"},"text":"§ 3042.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separation pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c785706-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer who is separated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3041/a/2"},"text":"section 3041(a)(2) of this title","children":[],"tail":" and who has completed more than three years of continuous active service immediately before that separation is entitled to separation pay computed under subsection (b) unless the Secretary determines that the conditions under which the officer is separated do not warrant payment of that pay."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c785707-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of separation pay","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c785708-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Six or more years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an officer who has completed six or more years of continuous active service immediately before that separation, the amount of separation pay to be paid to the officer under this section is 10 percent of the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c785709-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of active service creditable to the officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c78570a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 times the monthly basic pay to which the officer was entitled at the time of separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78570b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Three to six years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an officer who has completed three or more but fewer than six years of continuous active service immediately before that separation, the amount of separation pay to be paid to the officer under this section is one-half of the amount computed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c78570c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other conditions, requirements, and administrative provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (f), (g), and (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174"},"text":"section 1174 of title 10","children":[],"tail":" shall apply to separation pay under this section in the same manner as such provisions apply to separation pay under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c78570d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer discharged for twice failing selection for promotion to the next higher grade is not entitled to separation pay under this section if the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78570e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expresses a desire not to be selected for promotion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78570f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3042/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requests removal from the list of selectees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c785710-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s242"},"text":"Pub. L. 107–372, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3088"},"text":"116 Stat. 3088","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tIV/s402"},"text":"Pub. L. 116–259, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1178"},"text":"134 Stat. 1178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c785711-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c785712-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c785713-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853h"},"text":"section 853h of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c785714-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259"},"text":"Pub. L. 116–259","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
