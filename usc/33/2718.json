c6c70b0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Vessel Safety and Ability To Meet Legal Obligations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/241/s32"},"text":"Pub. L. 102–241, § 32","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2222"},"text":"105 Stat. 2222","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/241/s32"},"text":"“Not later than one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":"], the Secretary of Transportation shall report to Congress on the effect of section 1018 of the Oil Pollution Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Public Law 101–380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2718"},"text":"33 U.S.C. 2718","children":[],"tail":"] on the safety of vessels being used to transport oil and the capability of owners and operators to meet their legal obligations in the event of an oil spill.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
