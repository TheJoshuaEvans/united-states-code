{"tag":"section","attrib":{"id":"id6c6c709d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718"},"text":null,"children":[{"tag":"num","attrib":{"value":"2718"},"text":"§ 2718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c6c709e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of State authorities; Solid Waste Disposal Act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act or the Act of ","children":[{"tag":"date","attrib":{"date":"1851-03-03"},"text":"March 3, 1851","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6c709f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" affect, or be construed or interpreted as preempting, the authority of any State or political subdivision thereof from imposing any additional liability or requirements with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c6c70a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discharge of oil or other pollution by oil within such State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c6c70a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any removal activities in connection with such a discharge; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6c70a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect, or be construed or interpreted to affect or modify in any way the obligations or liabilities of any person under the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.) or State law, including common law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6c70a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of State funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act or in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9509"},"text":"section 9509 of title 26","children":[],"tail":" shall in any way affect, or be construed to affect, the authority of any State—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6c70a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish, or to continue in effect, a fund any purpose of which is to pay for costs or damages arising out of, or directly resulting from, oil pollution or the substantial threat of oil pollution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6c70a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require any person to contribute to such a fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6c70a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements and liabilities; penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act, chapter 305 of title 46, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9509"},"text":"section 9509 of title 26","children":[],"tail":", shall in any way affect, or be construed to affect, the authority of the United States or any State or political subdivision thereof—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c6c70a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to impose additional liability or additional requirements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c6c70a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to impose, or to determine the amount of, any fine or penalty (whether criminal or civil in nature) for any violation of law;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"relating to the discharge, or substantial threat of a discharge, of oil.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c6c70a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2718/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employee liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2679/b/2/B"},"text":"section 2679(b)(2)(B) of title 28","children":[],"tail":", nothing in this Act shall be construed to authorize or create a cause of action against a Federal officer or employee in the officer’s or employee’s personal or individual capacity for any act or omission while acting within the scope of the officer’s or employee’s office or employment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c6c70aa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tI/s1018"},"text":"Pub. L. 101–380, title I, § 1018","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/505"},"text":"104 Stat. 505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXVII/s7701/g/6"},"text":"Pub. L. 119–60, div. G, title LXXVII, § 7701(g)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1836"},"text":"139 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c6c70ab-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c6c70ac-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c6c70ad-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"