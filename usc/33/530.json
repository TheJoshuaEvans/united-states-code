{"tag":"section","attrib":{"id":"id6b3d8d22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s530"},"text":null,"children":[{"tag":"num","attrib":{"value":"530"},"text":"§ 530.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bridges included and excluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall apply only to bridges over navigable waters of the United States, the construction of which is approved after ","children":[{"tag":"date","attrib":{"date":"1946-08-02"},"text":"August 2, 1946","children":[],"tail":", under the provisions of this subchapter; and the provisions of the first proviso of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s401"},"text":"section 401 of this title","children":[],"tail":", and the provisions of sections 491 to 494 and 495 to 498 of this title, shall not apply to such bridges."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3d8d23-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title V, § 507, "},{"tag":"ref","attrib":{"href":"/us/stat/60/849"},"text":"60 Stat. 849","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
