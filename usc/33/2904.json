{"tag":"section","attrib":{"id":"id6c739d44-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904"},"text":null,"children":[{"tag":"num","attrib":{"value":"2904"},"text":"§ 2904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Estuary Habitat Restoration Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c739d45-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a council to be known as the “Estuary Habitat Restoration Council”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d46-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soliciting, reviewing, and evaluating project proposals and developing recommendations concerning such proposals based on the factors specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2903/c/3"},"text":"section 2903(c)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting to the Secretary a list of recommended projects, including a recommended priority order and any recommendation as to whether a project should be carried out by the Secretary or by another Federal department or agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2903/g"},"text":"section 2903(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and transmitting to Congress a national strategy for restoration of estuary habitat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically reviewing the effectiveness of the national strategy in meeting the purposes of this chapter and, as necessary, updating the national strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d4b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing advice on the development of the database, monitoring standards, and report required under sections 2906 and 2907 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d4c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperating in the implementation of the strategy developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2905"},"text":"section 2905 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d4d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending standards for monitoring for restoration projects and contribution of project information to the database developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2906"},"text":"section 2906 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d4e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise using the respective authorities of the Council members to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary (or the Secretary’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Oceans and Atmosphere of the Department of Commerce (or the Under Secretary’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Environmental Protection Agency (or the Administrator’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior, acting through the Director of the United States Fish and Wildlife Service (or such Secretary’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture (or such Secretary’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of any other Federal agency designated by the President to serve as an ex officio member of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council may not receive compensation for their service as members of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson shall be elected by the Council from among its members for a 3-year term, except that the first elected chairperson may serve a term of fewer than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convening of Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall convene the first meeting of the Council not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2000-11-07"},"text":"November 7, 2000","children":[],"tail":", for the purpose of electing a chairperson."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson shall convene additional meetings of the Council as often as appropriate to ensure that this chapter is fully carried out, but not less often than annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall establish procedures for voting, the conduct of meetings, and other matters, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Meetings of the Council shall be open to the public. The Council shall provide notice to the public of such meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c739d5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall consult with persons with recognized scientific expertise in estuary or estuary habitat restoration, representatives of State agencies, local or regional government agencies, and nongovernmental organizations with expertise in estuary or estuary habitat restoration, and representatives of Indian tribes, agricultural interests, fishing interests, and other estuary users—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739d5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Council in the development of the estuary habitat restoration strategy to be developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2905"},"text":"section 2905 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739d5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2904/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide advice and recommendations to the Council on proposed estuary habitat restoration projects, including advice on the scientific merit, technical merit, and feasibility of a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c739d60-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s105"},"text":"Pub. L. 106–457, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1962"},"text":"114 Stat. 1962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5017/d"},"text":"Pub. L. 110–114, title V, § 5017(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1198"},"text":"121 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c739d61-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c739d62-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c739d63-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" added pars. (6) to (8)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
