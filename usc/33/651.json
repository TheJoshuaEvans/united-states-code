{"tag":"section","attrib":{"id":"id6b5310f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s651"},"text":null,"children":[{"tag":"num","attrib":{"value":"651"},"text":"§ 651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tributaries of Mississippi River below Cairo; levee and bank protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The jurisdiction of the Mississippi River Commission is extended, for the purposes of levee protection and bank protection, to the tributaries and outlets of the Mississippi River between Cairo, Illinois, and the Head of the Passes, in so far as these tributaries and outlets are affected by the flood waters of the Mississippi River.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5310f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-22/ch427/s13"},"text":"Sept. 22, 1922, ch. 427, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1047"},"text":"42 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5310f4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5310f5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b5310f6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Rivers and Harbors Appropriation Act for the year 1922.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
