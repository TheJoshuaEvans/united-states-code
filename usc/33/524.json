{"tag":"section","attrib":{"id":"id6b3b4404-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s524"},"text":null,"children":[{"tag":"num","attrib":{"value":"524"},"text":"§ 524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of administrative procedure provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the administration of this Act, hearings and other procedures shall be exempted from the provisions of subchapter II of chapter 5, and chapter 7, of title 5, except as to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3b4405-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-16/ch889/s3"},"text":"July 16, 1952, ch. 889, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/733"},"text":"66 Stat. 733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3b4406-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3b4407-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b3b4408-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-16/ch889"},"text":"act July 16, 1952, ch. 889","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/732"},"text":"66 Stat. 732","children":[],"tail":", which enacted this section and amended sections 511, 516, and 523 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b3b4409-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-21/ch409"},"text":"act June 21, 1940, ch. 409","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/497"},"text":"54 Stat. 497","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Subchapter II of chapter 5, and chapter 7, of title 5” and “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"” substituted in text for “the Administrative Procedure Act ("},{"tag":"ref","attrib":{"href":"/us/stat/60/237"},"text":"60 Stat. 237","children":[],"tail":")” and “section 3 thereof”, respectively, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
