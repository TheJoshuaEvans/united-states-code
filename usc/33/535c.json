{"tag":"section","attrib":{"id":"id6b3d8d42-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535c"},"text":null,"children":[{"tag":"num","attrib":{"value":"535c"},"text":"§ 535c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Secretary; commencement and completion requirements; extension of time limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The approval of the Secretary of the department in which the Coast Guard is operating, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s491"},"text":"section 491 of this title","children":[],"tail":", shall be given only subsequent to the President’s approval, as provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s535b"},"text":"section 535b of this title","children":[],"tail":", and shall be null and void unless the construction of the bridge is commenced within two years and completed within five years from the date of the Secretary’s approval: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That the Secretary, for good cause shown, may extend for a reasonable time either or both of the time limits herein provided."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3d8d43-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/434/s5"},"text":"Pub. L. 92–434, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-26"},"text":"Sept. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/732"},"text":"86 Stat. 732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s306/b/6/A"},"text":"Pub. L. 114–120, title III, § 306(b)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/56"},"text":"130 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3d8d44-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3d8d45-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b3d8d46-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" substituted “Secretary of the department in which the Coast Guard is operating” for “Secretary of Transportation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
