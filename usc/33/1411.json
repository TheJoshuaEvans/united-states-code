{"tag":"section","attrib":{"id":"id6c05e694-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1411"},"text":null,"children":[{"tag":"num","attrib":{"value":"1411"},"text":"§ 1411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c05e695-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as may be authorized by a permit issued pursuant to section 1412 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1413"},"text":"section 1413 of this title","children":[],"tail":", and subject to regulations issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1418"},"text":"section 1418 of this title","children":[],"tail":","}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c05e696-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no person shall transport from the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c05e697-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel or aircraft registered in the United States or flying the United States flag or in the case of a United States department, agency, or instrumentality, no person shall transport from any location","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any material for the purpose of dumping it into ocean waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e698-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as may be authorized by a permit issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1412"},"text":"section 1412 of this title","children":[],"tail":", and subject to regulations issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1418"},"text":"section 1418 of this title","children":[],"tail":", no person shall dump any material transported from a location outside the United States (1) into the territorial sea of the United States, or (2) into a zone contiguous to the territorial sea of the United States, extending to a line twelve nautical miles seaward from the base line from which the breadth of the territorial sea is measured, to the extent that it may affect the territorial sea or the territory of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c05e699-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tI/s101"},"text":"Pub. L. 92–532, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1053"},"text":"86 Stat. 1053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/254/s1/3"},"text":"Pub. L. 93–254, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-03-22"},"text":"Mar. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/51"},"text":"88 Stat. 51","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c05e69a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c05e69b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c05e69c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/254"},"text":"Pub. L. 93–254","children":[],"tail":" incorporated existing provisions in introductory text, substituting reference to permits issued under section 1412 or "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1413"},"text":"section 1413 of this title","children":[],"tail":" for prior reference to such issuance under this subchapter; incorporated existing provisions in item designated (1); added item (2); and substituted prohibition against transportation of any material for ocean dumping for former prohibition against such dumping of any radiological, chemical, or biological warfare agent or any high-level radioactive waste, or any other material."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/254"},"text":"Pub. L. 93–254","children":[],"tail":" substituted reference to permits issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1412"},"text":"section 1412 of this title","children":[],"tail":" for former reference to such issuance under this subchapter, made any ocean dumping subject to regulations issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1418"},"text":"section 1418 of this title","children":[],"tail":", and substituted prohibition against dumping of any material for former prohibition against dumping of any radiological, chemical, or biological warfare agent or any high-level radioactive waste, or any other material."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/254"},"text":"Pub. L. 93–254","children":[],"tail":" struck out subsec. (c) which prohibited any officer, employee, agent, department, agency, or instrumentality of the United States from transporting from any location outside the United States any radiological, chemical, or biological warfare agent or any high-level radioactive waste, or, except as may be authorized in a permit, any other material for purpose of dumping in ocean waters. See subsec. (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c08579d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c08579e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/254"},"text":"Pub. L. 93–254","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-03-22"},"text":"Mar. 22, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/254/s2"},"text":"section 2 of Pub. L. 93–254","children":[],"tail":", set out in part as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1401"},"text":"section 1401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6c08579f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tI/s110/a"},"text":"Pub. L. 92–532, title I, § 110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1060"},"text":"86 Stat. 1060","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/532/tI/s110/a"},"text":"“This title [this subchapter] shall take effect six months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id6c0857a0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tI/s110/b"},"text":"Pub. L. 92–532, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-23"},"text":"Oct. 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1060"},"text":"86 Stat. 1060","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/532/tI/s110/b"},"text":"“No legal action begun, or right of action accrued, prior to the effective date of this title [this subchapter] shall be affected by any provision of this title [this subchapter].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c0857a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c0857a2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea and Contiguous Zone of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea and contiguous zone of United States, see Proc. No. 5928 and Proc. No. 7219, respectively, set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
