{"tag":"section","attrib":{"id":"id6bc581ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302a"},"text":"§ 1302a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean water infrastructure resiliency and sustainability program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc581f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc581f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc581f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intermunicipal, interstate, or State agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural hazard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “natural hazard” means a hazard caused by natural forces, including extreme weather events, sea-level rise, and extreme drought conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the clean water infrastructure resilience and sustainability program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc581f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Administrator shall establish a clean water infrastructure resilience and sustainability program under which the Administrator shall award grants to eligible entities for the purpose of increasing the resilience of publicly owned treatment works to a natural hazard or cybersecurity vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc581f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under the program shall use the grant funds for planning, designing, or constructing projects (on a system-wide or area-wide basis) that increase the resilience of a publicly owned treatment works to a natural hazard or cybersecurity vulnerabilities through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc581f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conservation of water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of water use efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the enhancement of wastewater and stormwater management by increasing watershed preservation and protection, including through the use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc581fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural and engineered green infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reclamation and reuse of wastewater and stormwater, such as aquifer recharge zones;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification or relocation of an existing publicly owned treatment works, conveyance, or discharge system component that is at risk of being significantly impaired or damaged by a natural hazard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and implementation of projects to increase the resilience of publicly owned treatment works to a natural hazard or cybersecurity vulnerabilities, as applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enhancement of energy efficiency or the use and generation of recovered or renewable energy in the management, treatment, or conveyance of wastewater or stormwater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58200-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under the program, an eligible entity shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc58201-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal of the project to be planned, designed, or constructed using funds under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58202-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the natural hazard risk of the area where the proposed project is to be located or potential cybersecurity vulnerability, as applicable, to be addressed by the proposed project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58203-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation prepared by a Federal, State, regional, or local government agency of the natural hazard risk of the area where the proposed project is to be located or potential cybersecurity vulnerability, as applicable, of the area where the proposed project is to be located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58204-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any recent natural hazard risk of the area where the proposed project is to be located or potential cybersecurity vulnerabilities that have affected the publicly owned treatment works;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58205-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the proposed project would improve the performance of the publicly owned treatment works under an anticipated natural hazard or natural hazard risk of the area where the proposed project is to be located or a potential cybersecurity vulnerability, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58206-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how the proposed project is expected to enhance the resilience of the publicly owned treatment works to a natural hazard risk of the area where the proposed project is to be located or a potential cybersecurity vulnerability, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58207-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount and other Federal requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc58208-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a grant under the program shall not exceed 75 percent of the total cost of the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58209-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc5820a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), a grant under the program shall not exceed 90 percent of the total cost of the proposed project if the project serves a community that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bc5820b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a population of fewer than 10,000 individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bc5820c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the affordability criteria established by the State in which the community is located under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1383/i/2"},"text":"section 1383(i)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc5820d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the discretion of the Administrator, a grant for a project described in subparagraph (A) may cover 100 percent of the total cost of the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc5820e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1388"},"text":"section 1388 of this title","children":[],"tail":" shall apply to a project funded with a grant under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc5820f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall submit to Congress a report that describes the implementation of the program, which shall include an accounting of all grants awarded under the program, including a description of each grant recipient and each project funded using a grant under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58210-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc58211-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $25,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58212-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc58213-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 223, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50205"},"text":"Pub. L. 117–58, div. E, title II, § 50205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1162"},"text":"135 Stat. 1162","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
