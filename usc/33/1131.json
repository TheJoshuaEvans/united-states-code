":"1991-12-04"},"text":"Dec. 4, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1282"},"text":"105 Stat. 1282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/160/s9/a"},"text":"Pub. L. 105–160, § 9(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-03-06"},"text":"Mar. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/26"},"text":"112 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/299/s7"},"text":"Pub. L. 107–299, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-26"},"text":"Nov. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2347"},"text":"116 Stat. 2347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/394/s10"},"text":"Pub. L. 110–394, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4209"},"text":"122 Stat. 4209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/221/s9/a"},"text":"Pub. L. 116–221, § 9(a)","children":[],"tail":", (b), (c)(2), "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1060"},"text":"134 Stat. 1060","children":[],"tail":", 1061.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b982ffa-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b982ffb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b982ffc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (e), was in the original “this Act” and was translated as reading “this title” meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454"},"text":"Pub. L. 89–454","children":[],"tail":", which enacted this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b982ffd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/221/s9/a/1"},"text":"Pub. L. 116–221, § 9(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) authorized appropriations for fiscal years 2009 through 2014."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/221/s9/a/2"},"text":"Pub. L. 116–221, § 9(a)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) related to priority activities for fiscal years 2009 through 2014."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/221/s9/b"},"text":"Pub. L. 116–221, § 9(b)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) related to limitations on amounts for administration of programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/221/s9/c/2"},"text":"Pub. L. 116–221, § 9(c)(2)","children":[],"tail":", redesignated subsecs. (d) and (e) as (c) and (d), respectively, and struck out former subsec. (c) which related to distribution of excess funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s10/1"},"text":"Pub. L. 110–394, § 10(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which authorized appropriations for fiscal years 2003 through 2008."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s10/2/A"},"text":"Pub. L. 110–394, § 10(2)(A)","children":[],"tail":", substituted “fiscal years 2009 through 2014—” for “fiscal years 2003 through 2008—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s10/2/B"},"text":"Pub. L. 110–394, § 10(2)(B)","children":[],"tail":", substituted “biology, prevention, and control of aquatic” for “biology and control of zebra mussels and other important aquatic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s10/2/C"},"text":"Pub. L. 110–394, § 10(2)(C)","children":[],"tail":", substituted “blooms; and” for “blooms, including Pfiesteria piscicida; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s10/3"},"text":"Pub. L. 110–394, § 10(3)","children":[],"tail":", substituted “performance assessments” for “rating under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1123/d/3/A"},"text":"section 1123(d)(3)(A) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s10/4"},"text":"Pub. L. 110–394, § 10(4)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “national strategic investments authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1123/b/4"},"text":"section 1123(b)(4) of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/299"},"text":"Pub. L. 107–299","children":[],"tail":" amended subsecs. (a) to (c) generally, substituting provisions relating to authorization, limitations, and distribution of funds for provisions relating to authorization, program elements, and priority oyster disease research."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s9/a"},"text":"Pub. L. 105–160, § 9(a)","children":[],"tail":", inserted heading and amended text of subsec. (a) generally. Prior to amendment, text read as follows: “There is authorized to be appropriated to carry out the provisions of sections 1124 and 1127 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1124a"},"text":"section 1124a of this title","children":[],"tail":", an amount—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) for fiscal year 1991, not to exceed $44,398,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) for fiscal year 1992, not to exceed $46,014,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) for fiscal year 1993, not to exceed $47,695,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) for fiscal year 1994, not to exceed $49,443,000; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) for fiscal year 1995, not to exceed $51,261,000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s9/b"},"text":"Pub. L. 105–160, § 9(b)","children":[],"tail":", inserted subsec. heading and amended par. (1) generally. Prior to amendment, par. (1) read as follows: “There is authorized to be appropriated for administration of this subchapter, including "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1128"},"text":"section 1128 of this title","children":[],"tail":", by the National Sea Grant Office and the Administration, an amount—"}],"tail":"\n"}