{"tag":"section","attrib":{"id":"id6b982fdf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131"},"text":"§ 1131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b982fe0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b982fe1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b982fe2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $87,520,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fe3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $91,900,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fe4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $96,500,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fe5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $101,325,000 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fe6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $105,700,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b982fe7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority activities for fiscal years 2021 through 2025","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the amounts authorized to be appropriated under paragraph (1), there are authorized to be appropriated $6,000,000 for each of fiscal years 2021 through 2025 for competitive grants for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b982fe8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University research on the biology, prevention, and control of aquatic nonnative species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fe9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University research on oyster diseases, oyster restoration, and oyster-related human health risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University research on the biology, prevention, and forecasting of harmful algal blooms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982feb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University research, education, training, and extension services and activities focused on coastal resilience and United States working waterfronts and other regional or national priority issues identified in the strategic plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1123/c/1"},"text":"section 1123(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" University research and extension on sustainable aquaculture techniques and technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982fed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fishery research and extension activities conducted by sea grant colleges or sea grant institutes to enhance, and not supplant, existing core program funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b982fee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b982fef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b982ff0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There may not be used for administration of programs under this subchapter in a fiscal year more than 5.5 percent of the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b982ff1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount authorized to be appropriated under this subchapter for the fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b982ff2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount appropriated under this subchapter for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b982ff3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical staffing requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b982ff4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall use the authority under subchapter VI of chapter 33 of title 5, and under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1129"},"text":"section 1129 of this title","children":[],"tail":", to meet any critical staffing requirement while carrying out the activities authorized under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b982ff5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception from cap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), any costs incurred as a result of an exercise of authority as described in clause (i) shall not be considered an amount used for administration of programs under this subchapter in a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b982ff6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use for other offices or programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums appropriated under the authority of subsection (a)(2) shall not be available for administration of this subchapter by the National Sea Grant Office, for any other Administration or department program, or for any other administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b982ff7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of sums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums appropriated pursuant to this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b982ff8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1131/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reversion of unobligated amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any grant, or portion of a grant, made to a person under any section of this subchapter that is not obligated by that person during the first fiscal year for which it was authorized to be obligated or during the next fiscal year thereafter shall revert to the Secretary. The Secretary shall add that reverted amount to the funds available for grants under the section for which the reverted amount was originally made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b982ff9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tII/s212"},"text":"Pub. L. 89–454, title II, § 212","children":[],"tail":", as added "}