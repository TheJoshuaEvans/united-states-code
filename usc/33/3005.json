{"tag":"section","attrib":{"id":"id6c760de1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3005"},"text":null,"children":[{"tag":"num","attrib":{"value":"3005"},"text":"§ 3005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of authorized commissioned officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760de2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total number of authorized commissioned officers on the lineal list of the commissioned officer corps of the Administration shall not exceed 500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760de3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions of importance and responsibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officers serving in positions designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3028"},"text":"section 3028 of this title","children":[],"tail":" and officers recalled from retired status or detailed to an agency other than the Administration—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760de4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be counted in determining the total number of authorized officers on the lineal list under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760de5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not count against such number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760de6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s215"},"text":"Pub. L. 107–372, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3084"},"text":"116 Stat. 3084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/386/s6"},"text":"Pub. L. 110–386, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4108"},"text":"122 Stat. 4108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tI/s102/a"},"text":"Pub. L. 116–259, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1155"},"text":"134 Stat. 1155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760de7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760de8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c760de9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s853a"},"text":"section 853a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760dea-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/259"},"text":"Pub. L. 116–259","children":[],"tail":" amended section generally. Prior to amendment, section related to number of authorized commissioned officers effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/386"},"text":"Pub. L. 110–386","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “There are authorized to be on the lineal list of the commissioned corps of the National Oceanic and Atmospheric Administration—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 270 officers for fiscal year 2003;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 285 officers for fiscal year 2004; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) 299 officers for fiscal year 2005.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
