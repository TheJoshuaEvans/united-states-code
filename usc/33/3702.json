{"tag":"section","attrib":{"id":"id6c892048-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c892049-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal acidification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coastal acidification” means the decrease in pH and changes in the water chemistry of coastal oceans, estuaries, and Great Lakes from atmospheric pollution, freshwater inputs, and excess nutrient run-off from land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c89204a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean acidification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ocean acidification” means the decrease in pH and changes in the water chemistry of the Earth’s oceans, coastal estuaries, marine waterways, and Great Lakes caused by carbon dioxide from the atmosphere and the breakdown of organic matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c89204b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce, acting through the Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c89204c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcommittee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Subcommittee” means the National Science and Technology Council Subcommittee on Ocean Science and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c89204d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, Guam, the Commonwealth of the Northern Mariana Islands, the Virgin Islands of the United States, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c89204e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12403"},"text":"Pub. L. 111–11, title XII, § 12403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1437"},"text":"123 Stat. 1437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10643"},"text":"Pub. L. 117–167, div. B, title VI, § 10643","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1672"},"text":"136 Stat. 1672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c89204f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c892050-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c892051-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10643/4"},"text":"Pub. L. 117–167, § 10643(4)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10643/1"},"text":"Pub. L. 117–167, § 10643(1)","children":[],"tail":", substituted “and changes in the water chemistry of the Earth’s oceans, coastal estuaries, marine waterways, and Great Lakes caused by carbon dioxide from the atmosphere and the breakdown of organic matter” for “of the Earth’s oceans and changes in ocean chemistry caused by chemical inputs from the atmosphere, including carbon dioxide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10643/3"},"text":"Pub. L. 117–167, § 10643(3)","children":[],"tail":", redesignated par. (1) as (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10643/3"},"text":"Pub. L. 117–167, § 10643(3)","children":[],"tail":", redesignated par. (2) as (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10643/2"},"text":"Pub. L. 117–167, § 10643(2)","children":[],"tail":", substituted “National Science and Technology Council Subcommittee on Ocean Science and Technology” for “Joint Subcommittee on Ocean Science and Technology of the National Science and Technology Council”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10643/3"},"text":"Pub. L. 117–167, § 10643(3)","children":[],"tail":", redesignated par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10643/5"},"text":"Pub. L. 117–167, § 10643(5)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
