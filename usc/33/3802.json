{"tag":"section","attrib":{"id":"id6c8b6a50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802"},"text":null,"children":[{"tag":"num","attrib":{"value":"3802"},"text":"§ 3802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8b6a51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Included vessel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), after the Convention enters into force for the United States, the following vessels are subject to the requirements of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8b6a52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel documented under chapter 121 of title 46 or one operated under the authority of the United States, wherever located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vessel permitted by a Federal agency to operate on the Outer Continental Shelf.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any other vessel when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8b6a55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the internal waters of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8b6a56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any port, shipyard, offshore terminal, or other place in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8b6a57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lightering in the territorial sea; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8b6a58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent consistent with international law, anchoring in the territorial sea of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excluded vessels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8b6a5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following vessels are not subject to the requirements of this chapter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8b6a5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any warship, naval auxiliary, or other vessel owned or operated by a foreign state, and used, for the time being, only on government noncommercial service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8b6a5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), any warship, naval auxiliary, or other vessel owned or operated by the United States and used for the time being only on government noncommercial service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to United States government vessels","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8b6a5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may apply any requirement of this chapter to one or more classes of vessels described in paragraph (1)(B), if the head of the Federal department or agency under which those vessels operate concurs in that application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8b6a5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3802/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation for combat-related vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to combat-related vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8b6a60-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1012"},"text":"Pub. L. 111–281, title X, § 1012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3024"},"text":"124 Stat. 3024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8b6a61-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8b6a62-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c8b6a63-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3023"},"text":"124 Stat. 3023","children":[],"tail":", which enacted this chapter and repealed chapter 37 (§ 2401 et seq.) of this title. For complete classification of title X to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
