{"tag":"section","attrib":{"id":"id6c760d86-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907"},"text":null,"children":[{"tag":"num","attrib":{"value":"2907"},"text":"§ 2907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760d87-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":", and every 2 years thereafter, the Secretary, after considering the advice and recommendations of the Council, shall transmit to Congress a report on the results of activities carried out under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760d88-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760d89-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on the number of acres of estuary habitat restored under this chapter, including descriptions of, and partners involved with, projects selected, in progress, and completed under this chapter that comprise those acres;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760d8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information from the database established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2906/b"},"text":"section 2906(b) of this title","children":[],"tail":" related to ongoing monitoring of projects to ensure that short-term and long-term restoration goals are achieved;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760d8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the long-term success of varying restoration techniques used in carrying out estuary habitat restoration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760d8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of how the information described in paragraphs (1) through (3) has been incorporated in the selection and implementation of estuary habitat restoration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760d8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of efforts made to maintain an appropriate database of restoration projects carried out under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760d8e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2907/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the measures taken to provide the information described in paragraphs (1) through (3) to persons with responsibility for assisting in the restoration of estuary habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760d8f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s108"},"text":"Pub. L. 106–457, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1965"},"text":"114 Stat. 1965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5017/f"},"text":"Pub. L. 110–114, title V, § 5017(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1198"},"text":"121 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760d90-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760d91-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760d92-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" substituted “Not later than "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":", and every 2 years thereafter” for “At the end of the third and fifth fiscal years following "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"November 7, 2000","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
