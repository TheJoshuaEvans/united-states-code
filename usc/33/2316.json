{"tag":"section","attrib":{"id":"id6c52313f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2316"},"text":null,"children":[{"tag":"num","attrib":{"value":"2316"},"text":"§ 2316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental protection mission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c523140-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include environmental protection as one of the primary missions of the Corps of Engineers in planning, designing, constructing, operating, and maintaining water resources projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c523141-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section affects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c523142-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Corps of Engineers’ authorities, including its authorities with respect to navigation and flood control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523143-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pending Corps of Engineers permit applications or pending lawsuits involving permits or water resources projects; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523144-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2316/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of public interest review procedures for Corps of Engineers permits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c523145-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640/tIII/s306"},"text":"Pub. L. 101–640, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4635"},"text":"104 Stat. 4635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c523146-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c523147-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c523148-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1990, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c523149-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{