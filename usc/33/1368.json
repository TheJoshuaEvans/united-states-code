{"tag":"section","attrib":{"id":"id6bfebb0a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368"},"text":null,"children":[{"tag":"num","attrib":{"value":"1368"},"text":"§ 1368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal procurement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bfebb0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts with violators prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal agency may enter into any contract with any person, who has been convicted of any offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1319/c"},"text":"section 1319(c) of this title","children":[],"tail":", for the procurement of goods, materials, and services if such contract is to be performed at any facility at which the violation which gave rise to such conviction occurred, and if such facility is owned, leased, or supervised by such person. The prohibition in the preceding sentence shall continue until the Administrator certifies that the condition giving rise to such conviction has been corrected."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bfebb0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish procedures to provide all Federal agencies with the notification necessary for the purposes of subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bfebb0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bfebb0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exempt any contract, loan, or grant from all or part of the provisions of this section where he determines such exemption is necessary in the paramount interest of the United States and he shall notify the Congress of such exemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bfebb0f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall annually report to the Congress on measures taken in compliance with the purpose and intent of this section, including, but not limited to, the progress and problems associated with such compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bfebb10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor certification or contract clause in acquisition of commercial products or commercial services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bfebb11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No certification by a contractor, and no contract clause, may be required in the case of a contract for the acquisition of commercial products or commercial services in order to implement a prohibition or requirement of this section or a prohibition or requirement issued in the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c012b12-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1368/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In paragraph (1), the terms “commercial product” and “commercial service” have the meanings given those terms in sections 103 and 103a, respectively, of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c012b13-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title V, § 508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/500/s2"},"text":"Pub. L. 92–500, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-18"},"text":"Oct. 18, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/891"},"text":"86 Stat. 891","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVIII/s8301/a"},"text":"Pub. L. 103–355, title VIII, § 8301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3396"},"text":"108 Stat. 3396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/g/5"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(g)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1873"},"text":"132 Stat. 1873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c012b14-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c012b15-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c012b16-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section authorized the President to cause to be issued, not more than 180 days after ","children":[{"tag":"date","attrib":{"date":"1972-10-18"},"text":"October 18, 1972","children":[],"tail":", an order (1) requiring each Federal agency authorized to enter into contracts or to extend Federal assistance by way of grant, loan, or contract, to effectuate the purpose and policy of this chapter, and (2) setting forth procedures, sanctions and penalties as the President determines necessary to carry out such requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c012b17-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/g/5/A"},"text":"Pub. L. 115–232, § 836(g)(5)(A)","children":[],"tail":", substituted “commercial products or commercial services” for “commercial items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/g/5/B"},"text":"Pub. L. 115–232, § 836(g)(5)(B)","children":[],"tail":", substituted “the terms ‘commercial product’ and ‘commercial service’ have the meanings given those terms in sections 103 and 103a, respectively, of title 41.” for “the term ‘commercial item’ has the meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of title 41","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c012b18-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c012b19-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"Jan. 1, 2020","children":[],"tail":", subject to a savings provision, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/h"},"text":"section 836(h) of Pub. L. 115–232","children":[],"tail":", set out as an Effective Date of 2018 Amendment; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s453b"},"text":"section 453b of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c012b1a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10001"},"text":"section 10001 of Pub. L. 103–355","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8752"},"text":"section 8752 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c012b1b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c012b1c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration of Chapter With Respect to Federal Contracts, Grants, or Loans","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions concerning the administration of this chapter with respect to Federal contracts, grants, or loans, see Ex. Ord. No. 11738, ","children":[{"tag":"date","attrib":{"date":"1973-09-10"},"text":"Sept. 10, 1973","children":[],"tail":", 38 F.R. 25161, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7606"},"text":"section 7606 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
