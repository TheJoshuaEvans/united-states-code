{"tag":"section","attrib":{"id":"id6c0375ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1381"},"text":null,"children":[{"tag":"num","attrib":{"value":"1381"},"text":"§ 1381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States for establishment of revolving funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0375ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of this subchapter, the Administrator shall make capitalization grants to each State for the purpose of establishing a water pollution control revolving fund to accomplish the objectives, goals, and policies of this chapter by providing assistance for projects and activities identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1383/c"},"text":"section 1383(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0375af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of grant payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator and each State shall jointly establish a schedule of payments under which the Administrator will pay to the State the amount of each grant to be made to the State under this subchapter. Such schedule shall be based on the State’s intended use plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1386/c"},"text":"section 1386(c) of this title","children":[],"tail":", except that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0375b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1381/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such payments shall be made in quarterly installments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1381/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such payments shall be made as expeditiously as possible, but in no event later than the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0375b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1381/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 quarters after the date such funds were obligated by the State, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0375b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1381/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 quarters after the date such funds were allotted to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0375b4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title VI, § 601, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/4/tII/s212/a"},"text":"Pub. L. 100–4, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/22"},"text":"101 Stat. 22","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5001"},"text":"Pub. L. 113–121, title V, § 5001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1322"},"text":"128 Stat. 1322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0375b5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0375b6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0375b7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":" substituted “to accomplish the objectives, goals, and policies of this chapter by providing assistance for projects and activities identified in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1383/c"},"text":"section 1383(c) of this title","children":[],"tail":".” for “for providing assistance (1) for construction of treatment works (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1292"},"text":"section 1292 of this title","children":[],"tail":") which are publicly owned, (2) for implementing a management program under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1329"},"text":"section 1329 of this title","children":[],"tail":", and (3) for developing and implementing a conservation and management plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c0375b8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c0375b9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5006"},"text":"Pub. L. 113–121, title V, § 5006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1327"},"text":"128 Stat. 1327","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/121/tV/s5006"},"text":"“This subtitle [subtitle A (§§ 5001–5006) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121"},"text":"Pub. L. 113–121","children":[],"tail":", enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1388"},"text":"section 1388 of this title","children":[],"tail":" and amending this section and sections 1382 and 1383 of this title], including any amendments made by the subtitle, shall take effect on "},{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
