{"tag":"section","attrib":{"id":"id6c78578c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3071a"},"text":"§ 3071a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions of title 37","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provisions of law applicable to the Armed Forces under the following provisions of title 37 shall apply to the commissioned officer corps of the Administration:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78578d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 403(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), relating to temporary continuation of housing allowance for dependents of members dying on active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78578e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 415, relating to initial uniform allowances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78578f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3071a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 488, relating to allowances for recruiting expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c785790-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s261A"},"text":"Pub. L. 107–372, title II, § 261A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/u