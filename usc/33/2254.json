{"tag":"section","attrib":{"id":"id6c3f1e8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254"},"text":null,"children":[{"tag":"num","attrib":{"value":"2254"},"text":"§ 2254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of operation and maintenance needs of the Atlantic Intracoastal Waterway and the Gulf Intracoastal Waterway","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3f1e8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", the Secretary shall assess the operation and maintenance needs of the Atlantic Intracoastal Waterway and the Gulf Intracoastal Waterway."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall assess the operation and maintenance needs of the Atlantic Intracoastal Waterway and the Gulf Intracoastal Waterway as used for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1e8e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial navigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e8f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial fishing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e90-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsistence, including utilization by Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":") for subsistence and ceremonial purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e91-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use as ingress and egress to harbors of refuge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e92-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e93-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purposes relating to domestic energy production, including fabrication, servicing, and supply of domestic offshore energy production facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e94-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities of the Secretary of the department in which the Coast Guard is operating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e95-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public health and safety related equipment for responding to coastal and inland emergencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e96-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recreation purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e97-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other authorized purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1e98-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2015, and biennially thereafter, in conjunction with the annual budget submission by the President to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives and make publicly available a report that, with respect to the Atlantic Intracoastal Waterway and the Gulf Intracoastal Waterway—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1e99-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the operation and maintenance costs required to achieve the authorized length, width, and depth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e9a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the amount of funding requested in the President’s budget for operation and maintenance costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1e9b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2254/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the unmet operation and maintenance needs of the Atlantic Intracoastal Waterway and the Gulf Intracoastal Waterway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3f1e9c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2008"},"text":"Pub. L. 113–121, title II, § 2008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1268"},"text":"128 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3f1e9d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3f1e9e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3f1e9f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3f1ea0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c3f1ea1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
