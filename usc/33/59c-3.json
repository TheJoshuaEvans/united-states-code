{"tag":"section","attrib":{"id":"id6b0b814c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"59c–3"},"text":"§ 59c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Queens County, New York","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b0b814d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of nonnavigable area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (b) and (c), the area of Long Island City, Queens County, New York, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b0b814e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not submerged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0b814f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"1996-10-12"},"text":"October 12, 1996","children":[],"tail":", lies between the southerly high water line of Anable Basin (also known as the “11th Street Basin”) and the northerly high water line of Newtown Creek; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0b8150-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extends from the high water line (as of ","children":[{"tag":"date","attrib":{"date":"1996-10-12"},"text":"October 12, 1996","children":[],"tail":") of the East River to the original high water line of the East River;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is declared to be nonnavigable waters of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b0b8151-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that area be improved","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b0b8152-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The declaration of nonnavigability under subsection (a) shall apply only to those portions of the area described in subsection (a) that are, or will be, bulkheaded, filled, or otherwise occupied by permanent structures or other permanent physical improvements (including parkland).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0b8153-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Federal law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Improvements described in paragraph (1) shall be subject to applicable Federal laws, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b0b8154-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 401 and 403 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b0b8155-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1344"},"text":"section 1344 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b0b8156-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b0b8157-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The declaration of nonnavigability under subsection (a) shall expire with respect to a portion of the area described in subsection (a), if the portion—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b0b8158-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not bulkheaded, filled, or otherwise occupied by a permanent structure or other permanent physical improvement (including parkland) in accordance with subsection (b) by the date that is 20 years after ","children":[{"tag":"date","attrib":{"date":"1996-10-12"},"text":"October 12, 1996","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b0b8159-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59c–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires an improvement described in subsection (b)(2) that is subject to a permit under an applicable Federal law, and the improvement is not commenced by the date that is 5 years after the date of issuance of the permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b0b815a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303/tV/s556"},"text":"Pub. L. 104–303, title V, § 556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3782"},"text":"110 Stat. 3782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0b815b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0b815c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b0b815d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
