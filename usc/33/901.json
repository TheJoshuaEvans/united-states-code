{"tag":"section","attrib":{"id":"id6b7ba798-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s901"},"text":null,"children":[{"tag":"num","attrib":{"value":"901"},"text":"§ 901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter may be cited as “Longshore and Harbor Workers’ Compensation Act.”","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b7ba799-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s1"},"text":"Mar. 4, 1927, ch. 509, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1424"},"text":"44 Stat. 1424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s27/d/1"},"text":"Pub. L. 98–426, § 27(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1654"},"text":"98 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7ba79a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7ba79b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b7ba79c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":" substituted “Longshore” for “Longshoremen’s”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b7ba79d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7ba79e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s28/a"},"text":"Pub. L. 98–426, § 28(a)","children":[],"tail":"–(g), "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1655"},"text":"98 Stat. 1655","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/426/s28/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, the amendments made by this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s942"},"text":"section 942 of this title","children":[],"tail":", amending this section, sections 902 to 910, 912 to 914, 917 to 919, 921 to 923, 928 to 935, 938 to 940, 944, and 948a of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s932"},"text":"section 932 of Title 30","children":[],"tail":", Mineral Lands and Mining, repealing sections 945 to 947 of this title, and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s907"},"text":"section 907 of this title","children":[],"tail":"] shall be effective on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":"] and shall apply both with respect to claims filed after such date and to claims pending on such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 7(a), 7(e), 8(f), 11(b), 11(c), and 13 [amending sections 907, 908, 912, and 914 of this title] shall be effective 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":"] and shall apply both with respect to claims filed after such 90th day and to claims pending on such 90th day."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 2(a), 3(a), 5, and 8(b) [amending sections 902, 903, 905, and 908 of this title] shall apply with respect to any injury after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 6(a), 8(d), and 9 [amending sections 906, 908, and 909 of this title] shall apply with respect to any death after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 2(c), 8(c)(1), 8(e)(4), 8(e)(5), 8(g), 10(b), 15 through 20, and 22 through 27 [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s942"},"text":"section 942 of this title","children":[],"tail":", amending this section and sections 902, 908 to 910, 914, 918, 919, 921 to 923, 928 to 932, 934, 935, 938 to 940, 944, and 948a of this title, repealing sections 945 to 947, and enacting provisions set out as a note under this section] shall be effective on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-09-24"},"text":"Sept. 24, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 7(b), 7(c), 7(d), and 8(h) [amending sections 907 and 908 of this title] shall be effective 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by section 6(b) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s906"},"text":"section 906 of this title","children":[],"tail":"] shall apply with respect to any injury, disability, or death after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an occupational disease which does not immediately result in a disability or death, an injury shall be deemed to arise on the date on which the employee or claimant becomes aware, or in the exercise of reasonable diligence or by reason of medical advice should have been aware, of the disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘disability’ has the meaning given such term by section 2(10) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s902/10"},"text":"section 902(10) of this title","children":[],"tail":"] as amended by this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b7ba79f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 52, formerly § 51, of act ","children":[{"tag":"date","attrib":{"date":"1927-03-04"},"text":"Mar. 4, 1927","children":[],"tail":", renumbered "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/576/s19"},"text":"Pub. L. 92–576, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1263"},"text":"86 Stat. 1263","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/576/s19"},"text":"“Sections 39 to 48, 50 to 52 [50 to 52, formerly 49 to 51, renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576/s19"},"text":"Pub. L. 92–576, § 19","children":[],"tail":"], inclusive [sections 939 to 948, 949, and 950 of this title], shall become effective upon the passage of this Act ["},{"tag":"date","attrib":{"date":"1927-03-04"},"text":"Mar. 4, 1927","children":[],"tail":"], and the remainder of this Act shall become effective on "},{"tag":"date","attrib":{"date":"1927-07-01"},"text":"July 1, 1927","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6b7ba7a0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s1/a"},"text":"Pub. L. 98–426, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1639"},"text":"98 Stat. 1639","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/426/s1/a"},"text":"“this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s942"},"text":"section 942 of this title","children":[],"tail":", amending this section, sections 902 to 910, 912 to 914, 917 to 919, 921 to 923, 928 to 935, 938 to 940, 944, and 948a of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s932"},"text":"section 932 of Title 30","children":[],"tail":", Mineral Lands and Mining, repealing sections 945 to 947 of this title, and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s907"},"text":"section 907 of this title","children":[],"tail":"] may be cited as the ‘Longshore and Harbor Workers’ Compensation Act Amendments of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6b7ba7a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576/s1"},"text":"Pub. L. 92–576, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1251"},"text":"86 Stat. 1251","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/576/s1"},"text":"“That this Act [enacting section 948a, amending sections 902, 903, 905 to 910, 912 to 914, 917, 919, 921, 921a, 923, 927, 928, 933, 935, 939, 940, and 944 of this title, and enacting and amending provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s902"},"text":"section 902 of this title","children":[],"tail":"] may be cited as the ‘Longshoremen’s and Harbor Workers’ Compensation Act Amendments of 1972’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b7ba7a2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Longshoremen’s and Harbor Workers’ Compensation Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s27/d/2"},"text":"Pub. L. 98–426, § 27(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1654"},"text":"98 Stat. 1654","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/426/s27/d/2"},"text":"“Reference in any other statute, regulation, order, or other document to the Longshoremen’s and Harbor Workers’ Compensation Act shall be deemed to refer to the Longshore and Harbor Workers’ Compensation Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
