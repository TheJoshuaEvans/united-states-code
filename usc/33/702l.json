{"tag":"section","attrib":{"id":"id6b689585-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s702l"},"text":null,"children":[{"tag":"num","attrib":{"value":"702l"},"text":"§ 702l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of inconsistent laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All laws or parts of laws inconsistent with sections 702a, 702b to 702d, 702e to 702g, 702h, 702i, 702j, and 702k of this title, are repealed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b689586-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-05-15/ch569/s12"},"text":"May 15, 1928, ch. 569, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/539"},"text":"45 Stat. 539","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
