{"tag":"section","attrib":{"id":"id6c5bce6c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2330a"},"text":"§ 2330a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring ecosystem restoration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5bce6d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting a feasibility study for a project (or a component of a project) for ecosystem restoration, the Secretary shall ensure that the recommended project includes, as an integral part of the project, a plan for monitoring the success of the ecosystem restoration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce6e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The monitoring plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bce6f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a description of the monitoring activities to be carried out, the criteria for ecosystem restoration success, and the estimated cost and duration of the monitoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify that the monitoring shall continue until such time as the Secretary determines that the criteria for ecosystem restoration success will be met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a period of 10 years from completion of construction of a project (or a component of a project) for ecosystem restoration, the Secretary shall consider the cost of carrying out the monitoring as a project cost. If the monitoring plan under subsection (b) requires monitoring beyond the 10-year period, the cost of monitoring shall be a non-Federal responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A monitoring plan under subsection (b) shall include a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bce73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types and number of restoration activities to be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce74-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the physical action to be undertaken to achieve the restoration objectives of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the functions and values that will result from the restoration plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bce76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contingency plan for taking corrective actions in cases in which monitoring demonstrates that restoration measures are not achieving ecological success in accordance with criteria described in the monitoring plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conclusion of operation and maintenance responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responsibility of a non-Federal interest for operation and maintenance of the nonstructural and nonmechanical elements of a project, or a component of a project, for ecosystem restoration shall cease 10 years after the date on which the Secretary makes a determination of success under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bce78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is not responsible for the operation or maintenance of any components of a project with respect to which a non-Federal interest is released from obligations under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5bce79-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2039"},"text":"Pub. L. 110–114, title II, § 2039","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1100"},"text":"121 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1161"},"text":"Pub. L. 114–322, title I, § 1161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1668"},"text":"130 Stat. 1668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5bce7a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5bce7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5bce7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2007, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c5bce7d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" added subsecs. (d) to (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5bce7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5bce7f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
