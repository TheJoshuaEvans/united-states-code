{"tag":"section","attrib":{"id":"id6c975188-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4265"},"text":null,"children":[{"tag":"num","attrib":{"value":"4265"},"text":"§ 4265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of marine debris in negotiating international agreements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In negotiating any relevant international agreement with any country or countries after ","children":[{"tag":"date","attrib":{"date":"2020-12-18"},"text":"December 18, 2020","children":[],"tail":", the President shall, as appropriate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c975189-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4265/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the impact of land-based sources of plastic waste and other solid waste from that country on the marine and aquatic environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c97518a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4265/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the agreement strengthens efforts to eliminate land-based sources of plastic waste and other solid waste from that country that impact the marine and aquatic environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c97518b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224/tII/s206"},"text":"Pub. L. 116–224, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1091"},"text":"134 Stat. 1091","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
