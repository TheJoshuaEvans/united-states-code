{"tag":"section","attrib":{"id":"id6c89203a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c89203b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" development coordination ","children":[{"tag":"ref","attrib":{"idref":"fn002156"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002156"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and implementation of a comprehensive interagency plan to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c89203c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3701/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and conduct research on the processes and consequences of ocean acidification and coastal acidification on marine organisms and ecosystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c89203d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3701/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and advise an interagency research, monitoring, and public outreach program on ocean acidification and coastal acidification;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c89203e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of an ocean acidification program within the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c89203f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment and consideration of regional and national ecosystem and socioeconomic impacts of increased ocean acidification and coastal acidification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c892040-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research adaptation strategies and mitigating the impacts of ocean and coastal acidification and related co-stressors on marine ecosystems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c892041-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12402"},"text":"Pub. L. 111–11, title XII, § 12402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1436"},"text":"123 Stat. 1436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10642"},"text":"Pub. L. 117–167, div. B, title VI, § 10642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1672"},"text":"136 Stat. 1672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c892042-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c892043-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c892044-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10642/b"},"text":"Pub. L. 117–167, § 10642(b)","children":[],"tail":", struck out subsec. (a) designation and heading “Purposes” before “The purposes” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10642/a/1"},"text":"Pub. L. 117–167, § 10642(a)(1)","children":[],"tail":", substituted “development coordination and implementation” for “development and coordination” in introductory provisions, “acidification and coastal acidification on marine organisms” for “acidification on marine organisms” in subpar. (A), and “maintain and advise an interagency research, monitoring, and public outreach program on ocean acidification and coastal acidification;” for “establish an interagency research and monitoring program on ocean acidification;” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10642/a/2"},"text":"Pub. L. 117–167, § 10642(a)(2)","children":[],"tail":", substituted “maintenance” for “establishment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10642/a/3"},"text":"Pub. L. 117–167, § 10642(a)(3)","children":[],"tail":", inserted “and coastal acidification” after “ocean acidification”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10642/a/4"},"text":"Pub. L. 117–167, § 10642(a)(4)","children":[],"tail":", substituted “mitigating the impacts of ocean and coastal acidification and related co-stressors on marine ecosystems.” for “techniques for effectively conserving marine ecosystems as they cope with increased ocean acidification.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c892045-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id6c892046-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10641"},"text":"Pub. L. 117–167, div. B, title VI, § 10641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1672"},"text":"136 Stat. 1672","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/167/dB/tVI/s10641"},"text":"“This subtitle [subtitle E (§§ 10641–10649) of title VI of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", amending this section and sections 3702 to 3708 of this title] may be cited as the ‘Coastal and Ocean Acidification Research and Innovation Act of 2021’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c892047-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12401"},"text":"Pub. L. 111–11, title XII, § 12401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1436"},"text":"123 Stat. 1436","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/11/tXII/s12401"},"text":"“This subtitle [subtitle D (§§ 12401–12409) of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", enacting this chapter] may be cited as the ‘Federal Ocean Acidification Research And Monitoring Act of 2009’ or the ‘FOARAM Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
