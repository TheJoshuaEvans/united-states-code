{"tag":"section","attrib":{"id":"id6b8eba5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s985a"},"text":null,"children":[{"tag":"num","attrib":{"value":"985a"},"text":"§ 985a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of bonds issued under section 985","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any bond issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s985"},"text":"section 985 of this title","children":[],"tail":", is hereby canceled together with the obligation to pay such bond."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b8eba5f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/369/tIII/s311"},"text":"Pub. L. 97–369, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-18"},"text":"Dec. 18, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1782"},"text":"96 Stat. 1782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b8eba60-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b8eba61-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b8eba62-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Transportation and Related Agencies Appropriations Act, 1983, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/ch201"},"text":"act May 13, 1954, c