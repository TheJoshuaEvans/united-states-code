{"tag":"section","attrib":{"id":"id6c8ddb00-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3857"},"text":null,"children":[{"tag":"num","attrib":{"value":"3857"},"text":"§ 3857.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies not affected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8ddb01-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3857/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter limits, denies, amends, modifies, or repeals any other remedy available to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8ddb02-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3857/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State and local law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter limits, denies, amends, modifies, or repeals any rights under existing law, of any State, territory, or possession of the United States, or any political subdivision thereof, to regulate any antifouling system. Compliance with the requirements of a State, territory, or possession of the United States, or political subdivision thereof related to antifouling paint or any other antifouling system does not relieve any person of the obligation to comply with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8ddb03-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1047"},"text":"Pub. L. 111–281, title X, § 1047","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3031"},"text":"124 Stat. 3031","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8ddb04-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8ddb05-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c8ddb06-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3023"},"text":"124 Stat. 3023","children":[],"tail":", which enacted this chapter and repealed chapter 37 (§ 2401 et seq.) of this title. For complete classification of title X to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
