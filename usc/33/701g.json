{"tag":"section","attrib":{"id":"id6b5cadec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701g"},"text":null,"children":[{"tag":"num","attrib":{"value":"701g"},"text":"§ 701g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of obstructions; clearing channels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army is authorized to allot not to exceed $15,000,000 from any appropriations heretofore or hereafter made for any one fiscal year for flood control, for removing accumulated snags and other debris, for preventing and mitigating flood damages associated with ice jams, and clearing and straightening the channel in navigable streams and tributaries thereof, when in the opinion of the Chief of Engineers such work is advisable in the interest of flood control: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That not more than $1,000,000 shall be expended for this purpose for any single tributary from the appropriations for any one fiscal year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b5caded-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-28/ch877/s2"},"text":"Aug. 28, 1937, ch. 877, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/877"},"text":"50 Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-11/ch699/s1"},"text":"Aug. 11, 1939, ch. 699, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1414"},"text":"53 Stat. 1414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-08-18/ch377/s9"},"text":"Aug. 18, 1941, ch. 377, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/650"},"text":"55 Stat. 650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-24/ch596/s13"},"text":"July 24, 1946, ch. 596, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/652"},"text":"60 Stat. 652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1264"},"text":"Sept. 3, 1954, ch. 1264","children":[],"tail":", title II, § 208, "},{"tag":"ref","attrib":{"href":"/us/stat/68/1266"},"text":"68 Stat. 1266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/251/tI/s26"},"text":"Pub. L. 93–251, title I, § 26","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-03-07"},"text":"Mar. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/20"},"text":"88 Stat. 20","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s915/b"},"text":"Pub. L. 99–662, title IX, § 915(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4191"},"text":"100 Stat. 4191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1107/f"},"text":"Pub. L. 118–272, div. A, title I, § 1107(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3005"},"text":"138 Stat. 3005","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5cadee-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b5cadef-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b5cadf0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" substituted “$15,000,000” for “$7,500,000” and “$1,000,000” for “$500,000” and inserted “for preventing and mitigating flood damages associated with ice jams,” after “other debris,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662"},"text":"Pub. L. 99–662","children":[],"tail":" substituted “$7,500,000” for “$5,000,000” and “$500,000” for “$250,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/251"},"text":"Pub. L. 93–251","children":[],"tail":" substituted “$5,000,000” for “$2,000,000” and “$250,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “$2,000,000” for “$1,000,000” and “$100,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-07-24"},"text":"July 24, 1946","children":[],"tail":", substituted “$1,000,000” for “$500,000” and “$50,000” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Act ","children":[{"tag":"date","attrib":{"date":"1941-08-18"},"text":"Aug. 18, 1941","children":[],"tail":", substituted “$500,000” for “$300,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Act ","children":[{"tag":"date","attrib":{"date":"1939-08-11"},"text":"Aug. 11, 1939","children":[],"tail":", authorized Secretary to allot instead of to approve amount for flood control and limited amount allotted instead of expended for any single tributary."}],"tail":"\n"}],"tail":"\n"}