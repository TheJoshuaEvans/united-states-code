{"tag":"section","attrib":{"id":"id6b63b2c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701u"},"text":null,"children":[{"tag":"num","attrib":{"value":"701u"},"text":"§ 701u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International engineering or scientific conferences; attendance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army is authorized to allot from any appropriations heretofore or hereafter made for flood control or rivers and harbors, funds for payment of expenses of representatives of the Corps of Engineers engaged on flood control and river and harbor work to international engineering or scientific conferences to be held outside the United States: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That not more than ten representatives of the Corps of Engineers shall attend any one conference."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b63b2c3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-05-17/ch188"},"text":"May 17, 1950, ch. 188","children":[],"tail":", title II, § 211, "},{"tag":"ref","attrib":{"href":"/us/stat/64/183"},"text":"64 Stat. 183","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s222"},"text":"Pub. L. 104–303, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3697"},"text":"110 Stat. 3697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b63b2c4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b63b2c5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b63b2c6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" substituted “outside the United States” for “outside the continental limits of the United States” and struck out before period at end “: "},{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That not more than $25,000 shall be allotted during any one fiscal year for this purpose”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
