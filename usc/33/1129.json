{"tag":"section","attrib":{"id":"id6b982fd4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1129"},"text":null,"children":[{"tag":"num","attrib":{"value":"1129"},"text":"§ 1129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency cooperation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each department, agency, or other instrumentality of the Federal Government which is engaged in or concerned with, or which has authority over, matters relating to ocean, coastal, and Great Lakes resources—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b982fd5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1129/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, upon a written request from the Secretary, make available, on a reimbursable basis or otherwise any personnel (with their consent and without prejudice to their position and rating), service, or facility which the Secretary deems necessary to carry out any provision of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b982fd6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1129/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, upon a written request from the Secretary, furnish any available data or other information which the Secretary deems necessary to carry out any provision of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b982fd7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1129/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall cooperate with the Administration and duly authorized officials thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b982fd8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tII/s210"},"text":"Pub. L. 89–454, title II, § 210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/461/s2"},"text":"Pub. L. 94–461, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1968"},"text":"90 Stat. 1968","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/220/tIII/s3104/b/1/G"},"text":"Pub. L. 100–220, title III, § 3104(b)(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-29"},"text":"Dec. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1471"},"text":"101 Stat. 1471","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b982fd9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b982fda-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b982fdb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220"},"text":"Pub. L. 100–220","children":[],"tail":" substituted “ocean, coastal, and Great Lakes resources” for “ocean and coastal resources” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
