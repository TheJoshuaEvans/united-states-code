{"tag":"section","attrib":{"id":"id6b50a07f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s628"},"text":null,"children":[{"tag":"num","attrib":{"value":"628"},"text":"§ 628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure for dredging within harbor lines","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No money appropriated for the improvement of rivers and harbors shall be expended for dredging inside of harbor lines duly established.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b50a080-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1892-07-13/ch158/s5"},"text":"July 13, 1892, ch. 158, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/111"},"text":"27 Stat. 111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b50a081-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b50a082-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b50a083-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Rivers and Harbors Appropriation Act of 1892.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
