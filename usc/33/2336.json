{"tag":"section","attrib":{"id":"id6c5bcf60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336"},"text":null,"children":[{"tag":"num","attrib":{"value":"2336"},"text":"§ 2336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abandoned and inactive noncoal mine restoration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5bcf61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical, planning, and design assistance to Federal and non-Federal interests for carrying out projects to address water quality problems caused by drainage and related activities from abandoned and inactive noncoal mines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcf62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under subsection (a) may be in support of projects for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bcf63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing drainage from abandoned and inactive noncoal mines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcf64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restoring and protecting streams, rivers, wetlands, other waterbodies, and riparian areas degraded by drainage from abandoned and inactive noncoal mines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bcf65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrating management practices and innovative and alternative treatment technologies to minimize or eliminate adverse environmental effects associated with drainage from abandoned and inactive noncoal mines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcf66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of assistance under subsection (a) shall be 50 percent, except that the Federal share with respect to projects located on land owned by the United States, on land held in trust by the Secretary of the Interior on behalf of, and for the benefit of, an Indian Tribe, or on restricted land of any Indian Tribe, shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcf67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on authority of Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the authority of the Secretary of the Interior under title IV of the Surface Mining Control and Reclamation Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s1231"},"text":"30 U.S.C. 1231","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcf68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology database for reclamation of abandoned mines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide assistance to non-Federal and nonprofit entities to develop, manage, and maintain a database of conventional and innovative, cost-effective technologies for reclamation of abandoned and inactive noncoal mine sites. Such assistance shall be provided through the Restoration of Abandoned Mine Sites Program managed by the Albuquerque District Office of the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5bcf69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2336/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5bcf6a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/tV/s560"},"text":"Pub. L. 106–53, title V, § 560","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/354"},"text":"113 Stat. 354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/137/tI/s118"},"text":"Pub. L. 108–137, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-01"},"text":"Dec. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1836"},"text":"117 Stat. 1836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2025"},"text":"Pub. L. 110–114, title II, § 2025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1079"},"text":"121 Stat. 1079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tIII/s302"},"text":"Pub. L. 116–260, div. AA, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2703"},"text":"134 Stat. 2703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8390"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8390","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3831"},"text":"136 Stat. 3831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5bcf6b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5bcf6c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c5bcf6d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Surface Mining Control and Reclamation Act of 1977, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/87"},"text":"Pub. L. 95–87","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/445"},"text":"91 Stat. 445","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 1231 et seq.) of chapter 25 of Title 30, Mineral Lands and Mining. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1201"},"text":"section 1201 of Title 30","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5bcf6e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1999, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c5bcf6f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8390/1"},"text":"Pub. L. 117–263, § 8390(1)","children":[],"tail":", inserted “, on land held in trust by the Secretary of the Interior on behalf of, and for the benefit of, an Indian Tribe, or on restricted land of any Indian Tribe,” after “land owned by the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8390/2"},"text":"Pub. L. 117–263, § 8390(2)","children":[],"tail":", substituted “Restoration” for “Rehabilitation” and “Albuquerque” for “Sacramento”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8390/3"},"text":"Pub. L. 117–263, § 8390(3)","children":[],"tail":", substituted “$50,000,000” for “$30,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “$30,000,000” for “$20,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114"},"text":"Pub. L. 110–114","children":[],"tail":" substituted “$20,000,000” for “$7,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/137"},"text":"Pub. L. 108–137","children":[],"tail":" substituted “$7,500,000” for “$5,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5bcf70-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5bcf71-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/53/s2"},"text":"section 2 of Pub. L. 106–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
