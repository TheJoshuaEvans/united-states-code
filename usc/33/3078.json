{"tag":"section","attrib":{"id":"id6c7857d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078"},"text":null,"children":[{"tag":"num","attrib":{"value":"3078"},"text":"§ 3078.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest payment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7857d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may pay the interest and any special allowances that accrue on one or more student loans of an eligible officer, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac7d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible officers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer is eligible for the benefit described in subsection (a) while the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac7da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not completed more than three years of service on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the debtor on one or more unpaid loans described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not in default on any such loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac7de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority to make payments under subsection (a) may be exercised with respect to the following loans:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac7df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan made, insured, or guaranteed under part B of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan made under part D of such title (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087a"},"text":"20 U.S.C. 1087a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan made under part E of such title (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087aa"},"text":"20 U.S.C. 1087aa","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac7e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest and any special allowance may be paid on behalf of an officer under this section for any of the 36 consecutive months during which the officer is eligible under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac7e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with Secretary of Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac7e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Secretary of Education regarding the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac7e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to reimburse the Secretary of Education—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7ac7e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the funds necessary to pay interest and special allowances on student loans under this section (in accordance with sections 428(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), 455("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), and 464(j) of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078"},"text":"20 U.S.C. 1078","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), 1087e("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), and 1087dd(j)); "},{"tag":"ref","attrib":{"idref":"fn002133"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002133"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be preceded by a third closing parenthesis."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7ac7e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any reasonable administrative costs incurred by the Secretary of Education in coordinating the program under this section with the administration of the student loan programs under parts B, D, and E of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq., 1087a et seq., 1087aa et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac7e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3078/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special allowance defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term ‘special allowance’ means a special allowance that is payable under section 438 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087–1"},"text":"20 U.S.C. 1087–1","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7ac7e9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s268"},"text":"Pub. L. 107–372, title II, § 268","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tII/s202/a"},"text":"Pub. L. 116–259, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1162"},"text":"134 Stat. 1162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7ac7ea-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7ac7eb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c7ac7ec-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsecs. (c) and (e)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Parts B, D, and E of title IV of the Act are classified generally to parts B (§ 1071 et seq.), D (§ 1087a et seq.), and E (§ 1087aa et seq.), respectively, of subchapter IV of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/329/s1"},"text":"section 1 of Pub. L. 89–329","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
