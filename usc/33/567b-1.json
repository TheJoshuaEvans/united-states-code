{"tag":"section","attrib":{"id":"id6b44b98c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s567b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"567b–1"},"text":"§ 567b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amended compact","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The consent of Congress is hereby given to the States of Maryland and West Virginia and the Commonwealths of Virginia and Pennsylvania and the District of Columbia to adopt the aforementioned amendments and enter into the amended compact hereinbefore recited and every part and article thereof: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing contained in such amended compact shall be construed as impairing or in any manner affecting any right or jurisdiction of the United States in and over the region which forms the subject of this compact: "},{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That the consent herein given does not extend to section (F)(2) of article II of the amended compact."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b44b98d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/407/s1"},"text":"Pub. L. 91–407, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-25"},"text":"Sept. 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/860"},"text":"84 Stat. 860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b44b98e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b44b98f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b44b990-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amended compact, referred to in text, is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/stat/84/856"},"text":"84 Stat. 856","children":[],"tail":" to 860."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
