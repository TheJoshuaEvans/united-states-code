{"tag":"section","attrib":{"id":"id6c48bc81-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282e"},"text":"§ 2282e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-authorization change reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c48bc82-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The completion of a post-authorization change report prepared by the Corps of Engineers for a water resources development project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bc83-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be delayed as a result of consideration being given to changes in policy or priority with respect to project consideration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc84-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be submitted, upon completion, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c48bc85-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c48bc86-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bc87-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a post-authorization change report subject to review by the Secretary, the Secretary shall, not later than 120 days after the date of completion of such report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bc88-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc89-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to Congress any recommendations of the Secretary regarding modification of the applicable water resources development project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bc8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prior reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", with respect to any post-authorization change report that was completed prior to "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", and is subject to a review by the Secretary that has yet to be completed, the Secretary shall complete review of, and provide recommendations to Congress with respect to, the report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bc8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-authorization change report inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “post-authorization change report” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bc8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general reevaluation report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a limited reevaluation report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc8e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other report that recommends the modification of an authorized water resources development project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c48bc8f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1132"},"text":"Pub. L. 114–322, title I, § 1132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1653"},"text":"130 Stat. 1653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c48bc90-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c48bc91-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c48bc92-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c48bc93-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c48bc94-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1002"},"text":"section 1002 of Pub. L. 114–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
