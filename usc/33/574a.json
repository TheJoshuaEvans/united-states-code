{"tag":"section","attrib":{"id":"id6b44b9d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a"},"text":null,"children":[{"tag":"num","attrib":{"value":"574a"},"text":"§ 574a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b44b9da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may include individuals not employed by the Department of the Army in training classes and courses offered by the Corps of Engineers in any case in which the Secretary determines that it is in the best interest of the Federal Government to include those individuals as participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b44b9db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b44b9dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual not employed by the Department of the Army attending a training class or course described in subsection (a) shall pay the full cost of the training provided to the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b44b9dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments made by an individual for training received under paragraph (1), up to the actual cost of the training—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b44b9de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be retained by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b44b9df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to an appropriations account used for paying training costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b44b9e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available for use by the Secretary, without further appropriation, for training purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b44b9e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s574a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payments received under paragraph (2) that are in excess of the actual cost of training provided shall be credited as miscellaneous receipts to the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b44b9e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2016"},"text":"Pub. L. 110–114, title II, § 2016","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1076"},"text":"121 Stat. 1076","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b44b9e3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b44b9e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b44b9e5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
