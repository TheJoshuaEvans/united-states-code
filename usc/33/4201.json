{"tag":"section","attrib":{"id":"id6c9750eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201"},"text":null,"children":[{"tag":"num","attrib":{"value":"4201"},"text":"§ 4201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9750ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Circular economy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “circular economy” means an economy that uses a systems-focused approach and involves industrial processes and economic activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9750ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are restorative or regenerative by design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable resources used in such processes and activities to maintain their highest values for as long as possible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aim for the elimination of waste through the superior design of materials, products, and systems (including business models).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EPA Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “EPA Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given the term “Indian tribe” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":", without regard to capitalization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Marine Debris Coordinating Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Interagency Marine Debris Coordinating Committee” means the Interagency Marine Debris Coordinating Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1954"},"text":"section 1954 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine debris","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marine debris” has the meaning given that term in section 1981 ","children":[{"tag":"ref","attrib":{"idref":"fn002164"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002164"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine debris event","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “marine debris event” means an event or related events that affects or may imminently affect the United States involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9750f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine debris caused by a natural event, including a tsunami, flood, landslide, hurricane, or other natural source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distinct, nonrecurring marine debris, including derelict vessel groundings and container spills, that have immediate or long-term impacts on habitats with high ecological, economic, or human-use values; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine debris caused by an intentional or grossly negligent act or acts that causes substantial economic or environmental harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonprofit organization” means an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-consumer materials management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “post-consumer materials management” means the systems, operation, supervision, and long-term management of processes and equipment used for post-use material (including packaging, goods, products, and other materials), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9750fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe disposal of waste that cannot be recovered, reused, recycled, repaired, or refurbished; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems and processes related to post-use materials that can be recovered, reused, recycled, repaired, or refurbished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9750ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975100-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975101-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975102-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory or possession of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975103-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any political subdivision of an entity described in subparagraphs (A) through (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975104-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4201/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Under Secretary” means the Under Secretary of Commerce for Oceans and Atmosphere and Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c975105-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224/s2"},"text":"Pub. L. 116–224, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1073"},"text":"134 Stat. 1073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s5/b"},"text":"Pub. L. 119–65, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1990"},"text":"139 Stat. 1990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c975106-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c975107-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c975108-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1072"},"text":"134 Stat. 1072","children":[],"tail":", known as the Save Our Seas 2.0 Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1981"},"text":"Section 1981 of this title","children":[],"tail":", referred to in par. (5), was in the original “section 7 of the Marine Debris Act”, and was translated as reading “section 131” of that Act to reflect the probable intent of Congress and the renumbering of section 7 as 131 by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s4/b/1"},"text":"Pub. L. 119–65, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1989"},"text":"139 Stat. 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c975109-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Pars. (7) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":" transferred par. (7) of this section to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1981/8"},"text":"section 1981(8) of this title","children":[],"tail":" and redesignated former pars. (8) to (11) as (7) to (10), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c97510a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c97510b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224/s1/a"},"text":"Pub. L. 116–224, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1072"},"text":"134 Stat. 1072","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/224/s1/a"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1959"},"text":"section 1959 of this title","children":[],"tail":" and amending sections 1951 and 1958 of this title] may be cited as the ‘Save Our Seas 2.0 Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
