{"tag":"section","attrib":{"id":"id6b1c4976-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s394"},"text":null,"children":[{"tag":"num","attrib":{"value":"394"},"text":"§ 394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Challenge to jurors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At the trial in summary cases, if by jury, the United States and the accused shall each be entitled to three peremptory challenges. Challenges for cause, in such cases, shall be tried by the court without the aid of triers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c4977-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4303.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c4978-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c4979-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c497a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4303 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-11/ch121/s7"},"text":"act June 11, 1864, ch. 121, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/125"},"text":"13 Stat. 125","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
