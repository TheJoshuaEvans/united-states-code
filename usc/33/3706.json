{"tag":"section","attrib":{"id":"id6c8b6a0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706"},"text":null,"children":[{"tag":"num","attrib":{"value":"3706"},"text":"§ 3706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NSF ocean acidification activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8b6a0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Science Foundation shall continue to carry out research activities on ocean acidification and coastal acidification which shall support competitive, merit-based, peer-reviewed proposals for research, observation, and monitoring of ocean acidification and coastal acidification and their respective impacts, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8b6a0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impacts on marine organisms, including species cultured for aquaculture, and marine ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a0f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impacts on ocean, coastal, and estuarine biogeochemistry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of methodologies and technologies to evaluate ocean acidification and coastal acidification and their respective impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impacts of multiple stressors on ecosystems exhibiting hypoxia, harmful algal blooms, or sediment delivery, combined with changes in ocean chemistry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a12-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adaptation and mitigation strategies to address socioeconomic effects of ocean acidification and coastal acidification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a13-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The research activities shall be consistent with the strategic research plan developed by the Subcommittee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3704"},"text":"section 3704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a14-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall encourage coordination of the Foundation’s ocean acidification and coastal acidification activities with such activities of other nations and international organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8b6a15-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Recipients of grants from the National Science Foundation under this chapter that collect data described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3705/d"},"text":"section 3705(d) of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8b6a16-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect data in accordance with the standards, protocols, or procedures established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3705/d"},"text":"section 3705(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8b6a17-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such data to the Director and the Secretary after publication, in accordance with any rules promulgated by the Director or the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8b6a18-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12407"},"text":"Pub. L. 111–11, title XII, § 12407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1441"},"text":"123 Stat. 1441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/271/tI/s112"},"text":"Pub. L. 116–271, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3344"},"text":"134 Stat. 3344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10647"},"text":"Pub. L. 117–167, div. B, title VI, § 10647","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1680"},"text":"136 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8b6a19-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8b6a1a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c8b6a1b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10647/1"},"text":"Pub. L. 117–167, § 10647(1)","children":[],"tail":", substituted “ocean acidification and coastal acidification” for “ocean acidification” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10647/2/A"},"text":"Pub. L. 117–167, § 10647(2)(A)","children":[],"tail":", substituted “their respective impacts” for “its impacts” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10647/2/B"},"text":"Pub. L. 117–167, § 10647(2)(B)","children":[],"tail":", substituted “and their respective impacts” for “and its impacts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10647/2/C"},"text":"Pub. L. 117–167, § 10647(2)(C)","children":[],"tail":", (D), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10647/3"},"text":"Pub. L. 117–167, § 10647(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271"},"text":"Pub. L. 116–271","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Director of the National Science Foundation shall continue to carry out research activities on ocean acidification which shall support competitive, merit-based, peer-reviewed proposals for research and monitoring of ocean acidification and its impacts, including—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) impacts on marine organisms and marine ecosystems;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) impacts on ocean, coastal, and estuarine biogeochemistry; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the development of methodologies and technologies to evaluate ocean acidification and its impacts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
