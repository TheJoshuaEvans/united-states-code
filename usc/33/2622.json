{"tag":"section","attrib":{"id":"id6c654478-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2622"},"text":null,"children":[{"tag":"num","attrib":{"value":"2622"},"text":"§ 2622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c654479-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Federal and State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter does not affect the application of any other Federal or State law, statutory or common, including the Marine Protection, Research, and Sanctuaries Act of 1972 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1431"},"text":"16 U.S.C. 1431","children":[],"tail":" et seq., 1447 et seq.; "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1401"},"text":"33 U.S.C. 1401","children":[],"tail":" et seq., 2801 et seq.] and the Solid Waste Disposal Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65447a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on foreign vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall be carried out with respect to foreign vessels consistent with the obligations of the United States under international law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c65447b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","ch