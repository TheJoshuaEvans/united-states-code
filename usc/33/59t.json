{"tag":"section","attrib":{"id":"id6b103bc0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59t"},"text":null,"children":[{"tag":"num","attrib":{"value":"59t"},"text":"§ 59t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burnham Canal, Milwaukee, Wisconsin","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The portion of the Burnham Canal, in Milwaukee, Wisconsin, which is underneath and west of a point one hundred feet east of South Eleventh Street is declared to be not a navigable water of the United States within the meaning of the Constitution and laws of the United States. The right to alter, amend, or repeal this section is hereby expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b103bc1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468/tV/s503"},"text":"Pub. L. 97–468, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2552"},"text":"96 Stat. 2552","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
