{"tag":"section","attrib":{"id":"id6c03759a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1377a"},"text":"§ 1377a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Green infrastructure promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c03759b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall promote the use of green infrastructure in, and coordinate the integration of green infrastructure into, permitting and enforcement under this chapter, planning efforts, research, technical assistance, and funding guidance of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c03759c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall ensure that the Office of Water coordinates efforts to increase the use of green infrastructure with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c03759d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal departments and agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c03759e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, tribal, and local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c03759f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0375a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional green infrastructure promotion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall direct each regional office of the Environmental Protection Agency, as appropriate based on local factors, and consistent with the requirements of this chapter, to promote and integrate the use of green infrastructure within the region, including through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0375a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach and training regarding green infrastructure implementation for State, tribal, and local governments, tribal communities, and the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incorporation of green infrastructure into permitting and other regulatory programs, codes, and ordinance development, including the requirements under consent decrees and settlement agreements in enforcement actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0375a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Green infrastructure information-sharing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall promote green infrastructure information-sharing, including through an internet website, to share information with, and provide technical assistance to, State, tribal, and local governments, tribal communities, the private sector, and the public, regarding green infrastructure approaches for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0375a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing water pollution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting water resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complying with regulatory requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0375a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1377a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving other environmental, public health, and community goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0375a8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title V, § 519, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/436/s5/b/2"},"text":"Pub. L. 115–436, § 5(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5561"},"text":"132 Stat. 5561","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0375a9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0375aa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c0375ab-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 519 of act ","children":[{"tag":"date","attrib":{"date":"1948-06-30"},"text":"June 30, 1948","children":[],"tail":", was renumbered section 520 and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
