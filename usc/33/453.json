{"tag":"section","attrib":{"id":"id6b2f5c76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s453"},"text":null,"children":[{"tag":"num","attrib":{"value":"453"},"text":"§ 453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for navigation of Ambrose Channel; exclusion of tows and sailing vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army is authorized to make such rules and regulations for the navigation of Ambrose Channel as he may deem necessary or expedient to insure its safe use in all kinds of weather, night and day, for all vessels under control and running under their own power, and to this end he may, in his discretion, forbid its use to tows of every description and to sailing vessels.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b2f5c77-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch144/s1"},"text":"Mar. 4, 1913, ch. 144, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/803"},"text":"37 Stat. 803","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2f5c78-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b2f5c79-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b2f5c7a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-06-29/ch496"},"text":"act June 29, 1888, ch. 496","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/209"},"text":"25 Stat. 209","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2f5c7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b2f5c7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n