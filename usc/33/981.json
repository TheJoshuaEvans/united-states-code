n"},{"tag":"note","attrib":{"topic":"separability","id":"id6b8eba22-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 11 of act ","children":[{"tag":"date","attrib":{"date":"1954-05-13"},"text":"May 13, 1954","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{},"text":"“If any provision of this Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s846"},"text":"section 846 of Title 31","children":[],"tail":", Money and Finance] or the application of such provision to any person or circumstances shall be held invalid, the remainder of the Act and the application of such provision to persons or circumstances other than those to which it is held invalid shall not be affected thereby.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b8eba23-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Saint Lawrence Seaway Development Corporation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/b"},"text":"Pub. L. 116–260, div. AA, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2756"},"text":"134 Stat. 2756","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dAA/tV/s512/b"},"text":"“Any reference to the Saint Lawrence Seaway Development Corporation in any law, regulation, document, record, Executive order, or other paper of the United States shall be deemed to be a reference to the Great Lakes St. Lawrence Seaway Development Corporation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"mis