{"tag":"section","attrib":{"id":"id6b8eba1b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s981"},"text":null,"children":[{"tag":"num","attrib":{"value":"981"},"text":"§ 981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby created, subject to the direction and supervision of the Secretary of Transportation, a body corporate to be known as the Great Lakes St. Lawrence Seaway Development Corporation (hereinafter referred to as the “Corporation”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b8eba1c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-05-13/ch201/s1"},"text":"May 13, 1954, ch. 201, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/93"},"text":"68 Stat. 93","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/670/s8/g/1"},"text":"Pub. L. 89–670, § 8(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/943"},"text":"80 Stat. 943","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/a/1"},"text":"Pub. L. 116–260, div. AA, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2756"},"text":"134 Stat. 2756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b8eba1d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b8eba1e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Edi