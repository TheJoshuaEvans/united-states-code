{"tag":"section","attrib":{"id":"id6c05e652-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388"},"text":null,"children":[{"tag":"num","attrib":{"value":"1388"},"text":"§ 1388.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c05e653-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available from a State water pollution control revolving fund established under this subchapter may not be used for a project for the construction, alteration, maintenance, or repair of treatment works unless all of the iron and steel products used in the project are produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e654-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of iron and steel products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “iron and steel products” means the following products made primarily of iron or steel: lined or unlined pipes and fittings, manhole covers and other municipal castings, hydrants, tanks, flanges, pipe clamps and restraints, valves, structural steel, reinforced precast concrete, construction materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e655-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply in any case or category of cases in which the Administrator finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c05e656-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying subsection (a) would be inconsistent with the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c05e657-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" iron and steel products are not produced in the United States in sufficient and reasonably available quantities and of a satisfactory quality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c05e658-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inclusion of iron and steel products produced in the United States will increase the cost of the overall project by more than 25 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e659-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator receives a request for a waiver under this section, the Administrator shall make available to the public, on an informal basis, a copy of the request and information available to the Administrator concerning the request, and shall allow for informal public input on the request for at least 15 days prior to making a finding based on the request. The Administrator shall make the request and accompanying information available by electronic means, including on the official public Internet site of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e65a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall be applied in a manner consistent with United States obligations under international agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e65b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may retain up to 0.25 percent of the funds appropriated for this subchapter for management and oversight of the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e65c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1388/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not apply with respect to a project if a State agency approves the engineering plans and specifications for the project, in that agency’s capacity to approve such plans and specifications prior to a project requesting bids, prior to ","children":[{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c05e65d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title VI, § 608, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5004"},"text":"Pub. L. 113–121, title V, § 5004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1326"},"text":"128 Stat. 1326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c05e65e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c05e65f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6c05e660-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"Oct. 1, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/s5006"},"text":"section 5006 of Pub. L. 113–121","children":[],"tail":", set out as an Effective Date of 2014 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"section 1381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
