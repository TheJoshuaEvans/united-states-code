{"tag":"section","attrib":{"id":"id6c595d37-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2326e"},"text":"§ 2326e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal interest dredging authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c595d38-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit a non-Federal interest to carry out, for an authorized navigation project (or a separable element of an authorized navigation project), such maintenance activities as are necessary to ensure that the project is maintained to not less than the minimum project dimensions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this section and subject to the availability of appropriations, the costs incurred by a non-Federal interest in performing the maintenance activities described in subsection (a) shall be eligible for reimbursement, not to exceed an amount that is equal to the estimated Federal cost for the performance of the maintenance activities, with any reimbursement subject to the non-Federal interest complying with all Federal laws and regulations that would apply to such maintenance activities if carried out by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before initiating maintenance activities under this section, a non-Federal interest shall enter into an agreement with the Secretary that specifies, for the performance of the maintenance activities, the terms and conditions that are acceptable to the non-Federal interest and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of equipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out maintenance activities under this section, a non-Federal interest shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide equipment at no cost to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold and save the United States free from any and all damage that arises from the use of the equipment of the non-Federal interest, except for damage due to the fault or negligence of a contractor of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement eligibility limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Costs that are eligible for reimbursement under this section are the costs of maintenance activities directly related to the costs associated with operation and maintenance of a dredge based on the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs associated with operation and maintenance of the dredge during the period of time that the dredge is being used in the performance of work for the Federal Government during a given fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d40-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual fiscal year Federal appropriations that are made available for the portion of the maintenance activities for which the dredge was used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d41-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not earlier than 5 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Secretary may conduct an audit on any maintenance activities for an authorized navigation project (or a separable element of an authorized navigation project) carried out under this section to determine if permitting a non-Federal interest to carry out maintenance activities under this section has resulted in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d42-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved reliability and safety for navigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d43-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost savings to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595d44-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326e/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary under this section terminates on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c595d45-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1113"},"text":"Pub. L. 114–322, title I, § 1113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1637"},"text":"130 Stat. 1637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595d46-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595d47-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595d48-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c595d49-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595d4a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1002"},"text":"section 1002 of Pub. L. 114–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
