{"tag":"section","attrib":{"id":"id6c760e03-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008"},"text":null,"children":[{"tag":"num","attrib":{"value":"3008"},"text":"§ 3008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative aviation centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760e04-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e05-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Under Secretary of Commerce for Oceans and Atmosphere and the Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e06-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative Aviation Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Cooperative Aviation Center” means a Cooperative Aviation Center designated under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e07-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative Aviation Centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e08-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall designate one or more Cooperative Aviation Centers for the commissioned officer corps of the Administration at institutions described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e09-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of Cooperative Aviation Centers is to facilitate the development and recruitment of aviators for the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e0a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution described in this paragraph is an educational institution that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760e0b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies to enter into an agreement with the Administrator providing for the establishment of the program at the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e0c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, as a part of its curriculum, a four-year baccalaureate program of professional flight and piloting instruction that is accredited by the Aviation Accreditation Board International; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e0d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a geographic area that experiences a wide variation in climate-related activity, including frequent high winds, convective activity (including tornadoes), periods of low visibility, heat, and snow and ice episodes, to provide opportunities for pilots to demonstrate skill in all weather conditions compatible with future encounters during their service in the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760e0e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative Aviation Centers Advisor","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760e0f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall assign an officer or employee of the commissioned officer corps of the Administration to serve as the Cooperative Aviation Centers Advisor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760e10-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Cooperative Aviation Centers Advisor shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760e11-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate all engagement of the Administration with Cooperative Aviation Centers, including assistance with curriculum development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760e12-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3008/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the chief aviation recruiting officer for the commissioned officer corps of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760e13-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s218"},"text":"Pub. L. 107–372, title II, § 218","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tI/s105/a"},"text":"Pub. L. 116–259, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1157"},"text":"134 Stat. 1157","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8403/a"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1910"},"text":"139 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760e14-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760e15-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760e16-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/1"},"text":"Pub. L. 119–60, § 8403(a)(1)","children":[],"tail":", substituted “Cooperative aviation centers” for “Aviation accession training programs” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/2"},"text":"Pub. L. 119–60, § 8403(a)(2)","children":[],"tail":", added par. (2) and struck out former pars. (2) and (3), which defined, respectively, “member of the program” and “program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/3/A"},"text":"Pub. L. 119–60, § 8403(a)(3)(A)","children":[],"tail":", substituted “Cooperative aviation centers” for “Aviation accession training programs” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/3/B"},"text":"Pub. L. 119–60, § 8403(a)(3)(B)","children":[],"tail":"–(D), added pars. (1) and (2), struck out former par. (1), which authorized aviation accession training programs, redesignated par. (2) as (3), and struck out former par. (3), which placed limitations on particular institutions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/3/E/ii"},"text":"Pub. L. 119–60, § 8403(a)(3)(E)(ii)","children":[],"tail":", substituted “applies” for “that requests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/3/E/iii"},"text":"Pub. L. 119–60, § 8403(a)(3)(E)(iii)","children":[],"tail":", substituted “has” for “that has” and “; and” for semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/3/E/iv"},"text":"Pub. L. 119–60, § 8403(a)(3)(E)(iv)","children":[],"tail":", substituted “is located” for “that is located” and struck out “that—” after “geographic area” in introductory provisions; in cl. (i), struck out cl. (i) designation and substituted “that experiences” for “experiences” and a period for “; and”; and struck out cl. (ii), which read as follows: “has a climate that can accommodate both primary and advanced flight training activity at least 75 percent of the year; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/3/E/v"},"text":"Pub. L. 119–60, § 8403(a)(3)(E)(v)","children":[],"tail":", struck out subpar. (D) which read as follows: “at which the Administrator determines that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) there will be at least one student enrolled in the program; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the provisions of this section are otherwise satisfied.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8403/a/4"},"text":"Pub. L. 119–60, § 8403(a)(4)","children":[],"tail":", added subsec. (c) and struck out former subsecs. (c) to (e), which related, respectively, to program membership, financial assistance for qualified members, and repayment of unearned portion of financial assistance when conditions of payment are not met."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
