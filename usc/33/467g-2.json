{"tag":"section","attrib":{"id":"id6b3417d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467g–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"467g–2"},"text":"§ 467g–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public awareness and outreach for dam safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator, in consultation with other Federal agencies, State and local governments, dam owners, the emergency management community, the private sector, nongovernmental organizations and associations, institutions of higher education, and any other appropriate entities shall, subject to the availability of appropriations, carry out a nationwide public awareness and outreach initiative to assist the public in preparing for, mitigating, responding to, and recovering from dam incidents.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3417d5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s11"},"text":"Pub. L. 92–367, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3001/d/2"},"text":"Pub. L. 113–121, title III, § 3001(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1283"},"text":"128 Stat. 1283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3417d6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3417d7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b3417d