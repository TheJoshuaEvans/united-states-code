:", which provided that subsecs. (a) and (c) of this section applied to projects authorized for construction by "},{"tag":"ref","attrib":{"href":"/us/pl/100/676"},"text":"Pub. L. 100–676","children":[],"tail":" (see Short Title of 1988 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"), except that the 5-year period during which funds had to be obligated to prevent deauthorization began on "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", and were also to apply to projects authorized for construction subsequent to "},{"tag":"ref","attrib":{"href":"/us/pl/100/676"},"text":"Pub. L. 100–676","children":[],"tail":", except that 5-year period during which funds had to be obligated to prevent deauthorization began on the date of the authorization of such projects, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s228/b/1"},"text":"Pub. L. 104–303, title II, § 228(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3703"},"text":"110 Stat. 3703","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b472a7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
