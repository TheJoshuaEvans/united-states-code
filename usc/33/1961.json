{"tag":"section","attrib":{"id":"id6c24e0aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961"},"text":null,"children":[{"tag":"num","attrib":{"value":"1961"},"text":"§ 1961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purposes of Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c24e0ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Marine Debris Foundation (in this title ","children":[{"tag":"ref","attrib":{"idref":"fn002087"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002087"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" referred to as the “Foundation”). The Foundation is a charitable and nonprofit corporation and is not an agency or establishment of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c24e0ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Foundation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c24e0ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage, accept, and administer private gifts of property for the benefit of, or in connection with, the activities and services of the National Oceanic and Atmospheric Administration under the Marine Debris Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1952"},"text":"section 1952 of this title","children":[],"tail":", and other relevant programs and agencies;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undertake and conduct such other activities as will augment efforts of the National Oceanic and Atmospheric Administration to assess, prevent, reduce, and remove marine debris and address the adverse impacts of marine debris on the economy of the United States, the marine environment, and navigation safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate with, and otherwise assist, State, local, and Tribal governments, Indian Tribes, foreign governments, entities, and individuals in undertaking and conducting activities to assess, prevent, reduce, and remove marine debris and address the adverse impacts of marine debris and its root causes on the economy of the United States, the marine environment (including waters in the jurisdiction of the United States, the high seas, and waters in the jurisdiction of other countries), and navigation safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to an agreement with the Secretary of Commerce, administer the Genius Prize for Save Our Seas Innovation as described in subchapter III; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c24e0b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1961/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support other Federal actions to reduce marine debris.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c24e0b2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s111"},"text":"Pub. L. 109–449, § 111","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s111"},"text":"Pub. L. 116–224, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1075"},"text":"134 Stat. 1075","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s111"},"text":"Pub. L. 109–449, § 111","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/a"},"text":"Pub. L. 119–65, § 3(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c24e0b3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c24e0b4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c24e0b5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (a), means title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1074"},"text":"134 Stat. 1074","children":[],"tail":", but probably should refer to “this subtitle”, meaning subtitle B of "},{"tag":"ref","attrib":{"href":"/us/pl/109/449"},"text":"Pub. L. 109–449","children":[],"tail":", which is classified generally to this subchapter and was transferred from subtitle B of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/a"},"text":"Pub. L. 119–65, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":". As originally enacted, subtitle B was the only subtitle in title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":" to refer to the term “Foundation” on its own."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c24e0b6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4211"},"text":"section 4211 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65"},"text":"Pub. L. 119–65","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c24e0b7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/b"},"text":"Pub. L. 119–65, § 3(b)","children":[],"tail":", substituted “corporation” for “organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/c/1"},"text":"Pub. L. 119–65, § 3(c)(1)","children":[],"tail":", inserted “Indian Tribes,” after “Tribal governments,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/c/2"},"text":"Pub. L. 119–65, § 3(c)(2)","children":[],"tail":", substituted “subchapter III” for “title II”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
