{"tag":"section","attrib":{"id":"id6c3f1ebb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2255a"},"text":"§ 2255a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High water-low water preparedness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3f1ebc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1ebd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bypass","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bypass” means an alternate water route adjacent to a lock and dam on a Federal inland waterway system that can be used for commercial navigation during high water conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1ebe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency condition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency condition” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3f1ebf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsafe conditions on a Federal inland waterway system that prevent the operation of commercial vessels, resulting from a major change in water level or flows;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1ec0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an obstruction in a Federal inland waterway system, including silt, sediment, rock formation, or a shallow channel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1ec1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an impaired or inoperable Federal lock and dam; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1ec2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other condition determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1ec3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the District Commanders responsible for maintaining any Federal inland waterway system, the users of the waterway system, and the Coast Guard, may make a determination that an emergency condition exists on the waterway system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1ec4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency mitigation project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3f1ec5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2) and the availability of appropriations, and in accordance with all applicable Federal requirements, the Secretary may carry out an emergency mitigation project on a Federal inland waterway system with respect to which the Secretary has determined that an emergency condition exists under subsection (b), or on a bypass of such system, to remedy that emergency condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3f1ec6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An emergency mitigation project under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3f1ec7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be initiated by not later than 60 days after the date on which the Secretary makes the applicable determination under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3f1ec8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, be completed by not later than 1 year after the date on which the Secretary makes such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3f1ec9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2255a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $25,000,000 for each of fiscal years 2022 through 2024, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3f1eca-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s151"},"text":"Pub. L. 116–260, div. AA, title I, § 151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2657"},"text":"134 Stat. 2657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3f1ecb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3f1ecc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3f1ecd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3f1ece-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c3f1ecf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
