{"tag":"section","attrib":{"id":"id6b793663-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892"},"text":null,"children":[{"tag":"num","attrib":{"value":"892"},"text":"§ 892.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b793664-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b793665-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administration” means the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b793666-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrographic data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “hydrographic data” means information that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b793667-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is acquired through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b793668-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrographic, bathymetric, photogrammetric, lidar, radar, remote sensing, or shoreline and other ocean- and coastal-related surveying;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b793669-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geodetic, geospatial, or geomagnetic measurements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b79366a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tide, water level, and current observations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b79366b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other methods; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b79366c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used in providing hydrographic services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b79366d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrographic services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “hydrographic services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b79366e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management, maintenance, interpretation, certification, and dissemination of bathymetric, hydrographic, shoreline, geodetic, geospatial, geomagnetic, and tide, water level, and current information, including the production of nautical charts, nautical information databases, hydrodynamic forecast and datum transformation models, and other products derived from hydrographic data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b79366f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of nautical information systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b793670-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b793671-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s892/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coast and Geodetic Survey Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Coast and Geodetic Survey Act” means the Act entitled “An Act to define the functions and duties of the Coast and Geodetic Survey, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1947-08-06"},"text":"August 6, 1947","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s883a"},"text":"33 U.S.C. 883a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b793672-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384/tIII/s302"},"text":"Pub. L. 105–384, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3454"},"text":"112 Stat. 3454","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/372/tI/s102"},"text":"Pub. L. 107–372, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3079"},"text":"116 Stat. 3079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/386/s2"},"text":"Pub. L. 110–386, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4106"},"text":"122 Stat. 4106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10308/a"},"text":"Pub. L. 117–263, div. J, title CIII, § 10308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3980"},"text":"136 Stat. 3980","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b793673-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b793674-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b793675-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384"},"text":"Pub. L. 105–384","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3454"},"text":"112 Stat. 3454","children":[],"tail":", which is classified principally to this subchapter. For complete classification of this title to the Code, see Short Title of 1998 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s851"},"text":"section 851 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1947-08-06"},"text":"August 6, 1947","children":[],"tail":", referred to in par. (5), is "},{"tag":"ref","attrib":{"href":"/us/act/1947-08-06/ch504"},"text":"act Aug. 6, 1947, ch. 504","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/787"},"text":"61 Stat. 787","children":[],"tail":", which is classified generally to subchapter II of this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b793676-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “hydrodynamic forecast and datum transformation models,” after “nautical information databases,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Pars. (3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/386"},"text":"Pub. L. 110–386","children":[],"tail":", which directed the amendment of section “303 of the Hydrographic Services Improvement Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s892"},"text":"33 U.S.C. 892","children":[],"tail":")” by adding pars. (3) to (5) and striking out former pars. (3) to (5), was executed to this section, which is section 302 of the Hydrographic Services Improvement Act of 1998, to reflect the probable intent of Congress. Prior to amendment, pars. (3) to (5) defined the terms “hydrographic data”, “hydrographic services”, and “Act of 1947”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/s102/1"},"text":"Pub. L. 107–372, § 102(1)","children":[],"tail":", inserted “, geospatial, or geomagnetic” after “geodetic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/s102/2"},"text":"Pub. L. 107–372, § 102(2)","children":[],"tail":", inserted “geospatial, geomagnetic,” after “geodetic,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b793677-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6b793678-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “Hydrographic Services Improvement Act of 1998”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/384/s301"},"text":"section 301 of Pub. L. 105–384","children":[],"tail":", set out as a Short Title of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s851"},"text":"section 851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
