{"tag":"section","attrib":{"id":"id6bb4e009-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275"},"text":null,"children":[{"tag":"num","attrib":{"value":"1275"},"text":"§ 1275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Columbia River Basin Restoration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb4e00a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e00b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Columbia River Basin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Columbia River Basin” means the entire United States portion of the Columbia River watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e00c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuary Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Estuary Partnership” means the Lower Columbia Estuary Partnership, an entity created by the States of Oregon and Washington and the Environmental Protection Agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e00d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuary Plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e00e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Estuary Plan” means the Estuary Partnership Comprehensive Conservation and Management Plan adopted by the Environmental Protection Agency and the Governors of Oregon and Washington on ","children":[{"tag":"date","attrib":{"date":"1999-10-20"},"text":"October 20, 1999","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e00f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Estuary Plan” includes any amendments to the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e010-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower Columbia River Estuary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Lower Columbia River Estuary” means the mainstem Columbia River from the Bonneville Dam to the Pacific Ocean and tidally influenced portions of tributaries to the Columbia River in that region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e011-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Middle and Upper Columbia River Basin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Middle and Upper Columbia River Basin” means the region consisting of the United States portion of the Columbia River Basin above Bonneville Dam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e012-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Columbia River Basin Restoration Program established under subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e013-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Columbia River Basin Restoration Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e014-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e015-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish within the Environmental Protection Agency a Columbia River Basin Restoration Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e016-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bb4e017-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of the Program does not modify any legal or regulatory authority or program in effect as of ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", including the roles of Federal agencies in the Columbia River Basin."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e018-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not create any new regulatory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e019-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program shall consist of a collaborative stakeholder-based program for environmental protection and restoration activities throughout the Columbia River Basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e01a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e01b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess trends in water quality, including trends that affect uses of the water of the Columbia River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e01c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, characterize, and assess data on water quality to identify possible causes of environmental problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e01d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide grants in accordance with subsection (d) for projects that assist in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bb4e01e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminating or reducing pollution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e01f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cleaning up contaminated sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e020-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e021-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring to evaluate trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e022-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing runoff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e023-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting habitat; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e024-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/b/3/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting citizen engagement or knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e025-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stakeholder Working Group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e026-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a Columbia River Basin Restoration Working Group (referred to in this subsection as the “Working Group”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e027-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e028-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Membership in the Working Group shall be on a voluntary basis and any person invited by the Adminis