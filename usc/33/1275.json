n"},{"tag":"clause","attrib":{"id":"id6bb4e02e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industries operating in the Columbia River Basin that affect or could affect water quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e02f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric, water, and wastewater utilities operating in the Columba ","children":[{"tag":"ref","attrib":{"idref":"fn002058"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002058"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Columbia”."}],"tail":" River Basin;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e030-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private landowners in the Columbia River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e031-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil and water conservation districts in the Columbia River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e032-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations that have a presence in the Columbia River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e033-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general public in the Columbia River Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e034-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Estuary Partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e035-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic representation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Working Group shall include representatives from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e036-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State located in whole or in part in the Columbia River Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e037-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the lower, middle, and upper basins of the Columbia River.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e038-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Working Group shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e039-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend and prioritize projects and actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e03a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the progress and effectiveness of projects and actions implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e03b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower Columbia River Estuary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e03c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuary Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Estuary Partnership shall perform the duties and fulfill the responsibilities of the Working Group described in paragraph (4) as those duties and responsibilities relate to the Lower Columbia River Estuary for such time as the Estuary Partnership is the management conference for the Lower Columbia River National Estuary Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e03d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Estuary Partnership ceases to be the management conference for the Lower Columbia River National Estuary Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":", the Administrator may designate the new management conference to assume the duties and responsibilities of the Working Group described in paragraph (4) as those duties and responsibilities relate to the Lower Columbia River Estuary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e03e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Estuary Partnership is removed from the National Estuary Program, the duties and responsibilities for the lower 146 miles of the Columbia River pursuant to this section shall be incorporated into the duties of the Working Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e03f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e040-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a voluntary, competitive Columbia River Basin program to provide grants to State governments, tribal governments, regional water pollution control agencies and entities, local government entities, nongovernmental entities, or soil and water conservation districts to develop or implement projects authorized under this section for the purpose of environmental protection and restoration activities throughout the Columbia River Basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e041-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e042-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the Federal share of the cost of any project or activity carried out using funds from a grant provided to any person (including a State, tribal, or local government or interstate or regional agency) under this subsection for a fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bb4e043-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed 75 percent of the total cost of the project or activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e044-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made on condition that the non-Federal share of such total cost shall be provided from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e045-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to cost-sharing for a grant provided under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6bb4e046-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal government may use Federal funds for the non-Federal share; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6bb4e047-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator may increase the Federal share under such circumstances as the Administrator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e048-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants using funds appropriated to carry out this section, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e049-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide not less than 25 percent of the funds to make grants for projects, programs, and studies in the Lower Columbia River Estuary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e04a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide not less than 25 percent of the funds to make grants for projects, programs, and studies in the Middle and Upper Columbia River Basin, including the Snake River Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e04b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain not more than 5 percent of the funds for the Environmental Protection Agency for purposes of implementing this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e04c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e04d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant recipient under this subsection shall submit to the Administrator reports on progress being made in achieving the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e04e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish requirements and timelines for recipients of grants under this subsection to report on progress made in achieving the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e04f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb4e050-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection limits the eligibility of the Estuary Partnership to receive funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330/g"},"text":"section 1330(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb4e051-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds made available under this subsection may be used for the administration of a management conference under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1330"},"text":"section 1330 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e052-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $30,000,000 for each of fiscal years 2020 and 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb4e053-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual budget plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, as part of the annual budget submission of the President to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", shall submit information regarding each Federal agency involved in protection and restoration of the Columbia River Basin, including an interagency crosscut budget that displays for each Federal agency—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb4e054-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts obligated for the preceding fiscal year for protection and restoration projects, programs, and studies relating to the Columbia River Basin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e055-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated budget for the current fiscal year for protection and restoration projects, programs, and studies relating to the Columbia River Basin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb4e056-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1275/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed budget for protection and restoration projects, programs, and studies relating to the Columbia River Basin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb4e057-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title I, § 123, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5010"},"text":"Pub. L. 114–322, title IV, § 5010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1898"},"text":"130 Stat. 1898","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4105"},"text":"Pub. L. 115–270, title IV, § 4105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3875"},"text":"132 Stat. 3875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bb4e058-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bb4e059-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bb4e05a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270"},"text":"Pub. L. 115–270","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
