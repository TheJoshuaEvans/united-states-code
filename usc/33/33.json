{"tag":"section","attrib":{"id":"id6b06c5f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s33"},"text":null,"children":[{"tag":"num","attrib":{"value":"33"},"text":"§ 33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Little River, Arkansas, from Big Lake to Marked Tree","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Little River, from Big Lake in Mississippi County to Marked Tree in Poinsett County, Arkansas, is declared to be not a navigable waterway of the United States within the meaning of the laws enacted by Congress for the protection of such waterways.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b06c5f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-03-02/ch95/s4"},"text":"Mar. 2, 1919, ch. 95, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1287"},"text":"40 Stat. 1287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0936f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0936fa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0936fb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from section 4 of act ","children":[{"tag":"date","attrib":{"date":"1919-03-02"},"text":"Mar. 2, 1919","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1919”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
