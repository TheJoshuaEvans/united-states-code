{"tag":"section","attrib":{"id":"id6c7ac887-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac888-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve tsunami detection, forecasting, warnings, research, notification, outreach, and mitigation to protect life and property in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac889-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance and modernize the existing United States Tsunami Warning System to increase the accuracy of forecasts and warnings, to ensure full coverage of tsunami threats to the United States with a network of detection assets, and to reduce false alarms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac88a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve and develop standards and guidelines for mapping, modeling, and assessment efforts to improve tsunami detection, forecasting, warnings, notification, mitigation, resiliency, response, outreach, and recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac88b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve research efforts related to improving tsunami detection, forecasting, warnings, notification, mitigation, resiliency, response, outreach, and recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac88c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve, increase, and develop uniform standards and guidelines for education and outreach activities and ensure that those receiving tsunami warnings and the at-risk public know what to do when a tsunami is approaching, including the warning signs of locally generated tsunami;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac88d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical and other assistance to speed international efforts to establish regional tsunami warning systems in vulnerable areas worldwide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac88e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster resilient communities in the face of tsunami and other similar coastal hazards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac88f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3202/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve Federal, State, and international coordination for detection, warnings, and outreach for tsunami and other coastal impacts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7ac890-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/424/s3"},"text":"Pub. L. 109–424, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2902"},"text":"120 Stat. 2902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tVIII/s803"},"text":"Pub. L. 109–479, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3653"},"text":"120 Stat. 3653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/tV"},"text":"Pub. L. 115–25, title V","children":[],"tail":", §§ 503, 512(a), "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/115"},"text":"131 Stat. 115","children":[],"tail":", 128.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7ac891-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7ac892-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c7ac893-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/424"},"text":"Pub. L. 109–424","children":[],"tail":" and title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" enacted substantially identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/109/424"},"text":"Pub. L. 109–424","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/s512/a"},"text":"section 512(a) of Pub. L. 115–25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c7ac894-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/1"},"text":"Pub. L. 115–25, § 503(1)","children":[],"tail":", inserted “research,” after “warnings,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/2"},"text":"Pub. L. 115–25, § 503(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “to enhance and modernize the existing Pacific Tsunami Warning System to increase coverage, reduce false alarms, and increase the accuracy of forecasts and warnings, and to expand detection and warning systems to include other vulnerable States and United States territories, including the Atlantic Ocean, Caribbean Sea, and Gulf of Mexico areas;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/3"},"text":"Pub. L. 115–25, § 503(3)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “to improve mapping, modeling, research, and assessment efforts to improve tsunami detection, forecasting, warnings, notification, outreach, mitigation, response, and recovery;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/5"},"text":"Pub. L. 115–25, § 503(5)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/4"},"text":"Pub. L. 115–25, § 503(4)","children":[],"tail":", (6), redesignated par. (4) as (5), substituted “, increase, and develop uniform standards and guidelines for” for “and increase”, and inserted “, including the warning signs of locally generated tsunami” after “approaching”. Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/4"},"text":"Pub. L. 115–25, § 503(4)","children":[],"tail":", (7), redesignated par. (5) as (6) and substituted semicolon at end for “, including the Indian Ocean; and”. Former par. (6) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/8"},"text":"Pub. L. 115–25, § 503(8)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s503/4"},"text":"Pub. L. 115–25, § 503(4)","children":[],"tail":", redesignated par. (6) as (8)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
