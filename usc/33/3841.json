{"tag":"section","attrib":{"id":"id6c8dda9f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841"},"text":null,"children":[{"tag":"num","attrib":{"value":"3841"},"text":"§ 3841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8ddaa0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, it is unlawful for any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8ddaa1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act in violation of this chapter, or any regulation prescribed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddaa2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sell or distribute in domestic or international commerce organotin or an antifouling system containing organotin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddaa3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manufacture, process, or use organotin to formulate an antifouling system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddaa4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to apply an antifouling system containing organotin on any vessel to which this chapter applies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddaa5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the Convention enters into force for the United States, to apply or otherwise use in a manner inconsistent with the Convention, an antifouling system on any vessel that is subject to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8ddaa6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel hulls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), no vessel shall bear on its hull or outer surface any antifouling system containing organotin, regardless of when such system was applied, unless that vessel bears an overcoating which forms a barrier to organotin leaching from the underlying antifouling system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8ddaa7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c8ddaa8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (b) does not apply to fixed or floating platforms, FSUs, or FPSOs that were constructed prior to ","children":[{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":", and that have not been in dry dock on or after that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c8ddaa9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale, manufacture, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c8ddaaa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale, distribution, or use pursuant to any agreement between the Administrator and any person that results in an earlier prohibition or cancellation date than specified in this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c8ddaab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3841/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacture, processing, formulation, sale, distribution, or use of organotin or antifouling systems containing organotin used or intended for use only for sonar domes or in conductivity sensors in oceanographic instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8ddaac-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1031"},"text":"Pub. L. 111–281, title X, § 1031","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3027"},"text":"124 Stat. 3027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8ddaad-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8ddaae-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c8ddaaf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1), (4), (5) and (c)(2)(A), was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3023"},"text":"124 Stat. 3023","children":[],"tail":", which enacted this chapter and repealed chapter 37 (§ 2401 et seq.) of this title. For complete classification of title X to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
