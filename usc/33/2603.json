{"tag":"section","attrib":{"id":"id6c65443b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603"},"text":null,"children":[{"tag":"num","attrib":{"value":"2603"},"text":"§ 2603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waste handling practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c65443c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c65443d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loading","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of the waste source shall take all reasonable steps to assure that all municipal or commercial waste is loaded onto a vessel in a manner that assures that waste deposited in coastal waters is minimized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65443e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of a vessel shall assure that all municipal or commercial waste loaded onto the vessel is secured by netting or other means to assure that waste will not be deposited into coastal waters during transport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c65443f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offloading","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of the receiving facility shall take all reasonable steps to assure that any municipal or commercial waste is offloaded from a vessel in a manner that assures that waste deposited into coastal waters is minimized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654440-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cleaning up","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner or operator of any waste source or receiving facility shall provide adequate control measures to clean up any municipal or commercial waste which is deposited into coastal waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654441-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Secretary of Transportation, shall prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c654442-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring that waste sources, receiving facilities, and vessels provide the means and facilities to assure that the waste will not be deposited into coastal waters during loading, offloading, and transport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654443-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring, as appropriate, the submission and adoption by each responsible party of an operation and maintenance manual identifying procedures to be used to prevent, report, and clean up any deposit of municipal or commercial waste into coastal waters, including record keeping requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654444-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator determines that tracking systems are required to assure adequate enforcement of laws preventing the deposit of municipal or commercial waste into coastal waters, requiring installation of the appropriate systems within 18 months after the Administrator makes that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c654445-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4103"},"text":"Pub. L. 100–688, title IV, § 4103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4156"},"text":"102 Stat. 4156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c654446-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c654447-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6c654448-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4204/c"},"text":"Pub. L. 100–688, title IV, § 4204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4160"},"text":"102 Stat. 4160","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/688/tIV/s4204/c"},"text":"“Section 4103 of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2603"},"text":"33 U.S.C. 2603","children":[],"tail":"] takes effect 60 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
