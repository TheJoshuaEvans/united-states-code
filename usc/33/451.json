{"tag":"section","attrib":{"id":"id6b2f5c55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s451"},"text":null,"children":[{"tag":"num","attrib":{"value":"451"},"text":"§ 451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervisor of harbor; appointment and duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An officer of the Corps of Engineers shall, for each harbor subject to this subchapter, be designated by the Secretary of the Army as supervisor of the harbor, to act under the direction of the Chief of Engineers in enforcing the provisions of this subchapter, and in detecting offenders against the same. Each such officer shall have personal charge and supervision under the Chief of Engineers, and shall direct the patrol boats and other means to detect and bring to punishment offenders against the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b2f5c56-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-06-29/ch496/s5"},"text":"June 29, 1888, ch. 496, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/210"},"text":"25 Stat. 210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-29/ch278"},"text":"June 29, 1949, ch. 278","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/300"},"text":"63 Stat. 300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-12/ch707"},"text":"July 12, 1952, ch. 707","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/596"},"text":"66 Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/802/s1/6"},"text":"Pub. L. 85–802, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/970"},"text":"72 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2f5c57-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b2f5c58-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b2f5c59-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/802"},"text":"Pub. L. 85–802","children":[],"tail":" inserted “for each harbor subject to this subchapter,” and substituted “Each such officer” for “This officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-07-12"},"text":"July 12, 1952","children":[],"tail":", transferred enforcement responsibilities of this section from a Naval officer to the Army district engineer at New York."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-06-29"},"text":"June 29, 1949","children":[],"tail":", struck out “shall receive the sea-pay of his grade and” after “this officer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2f5c5a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"ta