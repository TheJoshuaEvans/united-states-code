{"tag":"section","attrib":{"id":"id6c9750dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106"},"text":null,"children":[{"tag":"num","attrib":{"value":"4106"},"text":"§ 4106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding and additional authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9750dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall carry out this chapter using existing amounts appropriated or otherwise made available to the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9750de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9750df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, cooperative agreements, and other transactions with any domestic or foreign government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", accept donations and voluntary and uncompensated services;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept funds from other Federal departments and agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the National Oceanographic Partnership Program established under chapter 665 of title 10 to accept funds from other Federal departments and agencies, to accept donations, and to enter into contracts and award grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under an agreement entered into under paragraph (1), transfer funds appropriated to carry our this chapter to any organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9750e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use, with their consent, with or without reimbursement, and subject to the availability of appropriations, the land, services, equipment, personnel, and facilities of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9750e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any department, agency, or instrumentality of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State or local government or tribal government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9750e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4106/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign government or international organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9750e8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/394/s7"},"text":"Pub. L. 115–394, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5286"},"text":"132 Stat. 5286","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
