{"tag":"section","attrib":{"id":"id6b76c656-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891g"},"text":null,"children":[{"tag":"num","attrib":{"value":"891g"},"text":"§ 891g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interoperability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Oceanographer of the Navy regarding appropriate measures that should be taken, on a reimbursable basis, to ensure that NOAA vessels are interoperable with vessels of the Department of the Navy, including with respect to operation, maintenance, and repair of those vessels.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b76c657-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVI/s609"},"text":"Pub. L. 102–567, title VI, § 609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4303"},"text":"106 Stat. 4303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b76c658-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b76c659-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b76c65a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interoperability of Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tIV/s401/b/5"},"text":"Pub. L. 102–567, title IV, § 401(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4291"},"text":"106 Stat. 4291","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/567/tIV/s401/b/5"},"text":"“The Secretary of Commerce shall consult with the Oceanographer of the Navy regarding appropriate cost effective and practical measures to allow vessels of the National Oceanic and Atmospheric Administration to be interoperable with vessels of the Department of the Navy, including with respect to operation, maintenance, and repair of those vessels.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
