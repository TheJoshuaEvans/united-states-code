{"tag":"section","attrib":{"id":"id6b426f33-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s557"},"text":null,"children":[{"tag":"num","attrib":{"value":"557"},"text":"§ 557.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs of printing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The printing of matter relating to river and harbor works, including all reports, compilations, regulations, and so forth, whose preparation is allowable under Department of the Army regulations, shall be done and paid for out of regular annual appropriations for printing and binding for the Department of the Army.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b426f34-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-07-25/ch253/s13"},"text":"July 25, 1912, ch. 253, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/234"},"text":"37 Stat. 234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1916-07-01/ch209/s1"},"text":"July 1, 1916, ch. 209, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/330"},"text":"39 Stat. 330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b426f35-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b426f36-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b426f37-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from section 1 of act ","children":[{"tag":"date","attrib":{"date":"1916-07-01"},"text":"July 1, 1916","children":[],"tail":", repealing section 13 of act "},{"tag":"date","attrib":{"date":"1912-07-25"},"text":"July 25, 1912","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1 of that act was a provision, following an appropriation for printing for the War Department, of the Sundry Civil Appropriation Act for 1917.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The repealed section 13 of act ","children":[{"tag":"date","attrib":{"date":"1912-07-25"},"text":"July 25, 1912","children":[],"tail":", read as follows: "},{"tag":"quotedContent","attrib":{},"text":"“The printing of matter relating to river and harbor works, including all reports, compilations, regulations, and so forth, whose preparation is allowable under War Department regulations, may, upon recommendation of the Chief of Engineers and approval by the Secretary of War, be paid for from river and harbor appropriations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b426f38-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b426f39-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
