{"tag":"section","attrib":{"id":"id6c78569c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3031"},"text":null,"children":[{"tag":"num","attrib":{"value":"3031"},"text":"§ 3031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay and allowances; date of acceptance of promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c78569d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance and date of promotion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer of the commissioned corps who is promoted to a higher grade—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c78569e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3031/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deemed for all purposes to have accepted the promotion upon the date the promotion is made by the President, unless the officer expressly declines the promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c78569f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3031/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall receive the pay and allowances of the higher grade from that date unless the officer is entitled under another provision of law to receive the pay and allowances of the higher grade from an earlier date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7856a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer who subscribed to the oath of office required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of title 5","children":[],"tail":" shall not be required to renew such oath or to take a new oath upon promotion to a higher grade, if the service of the officer after the taking of such oath is continuous."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7856a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s231"},"text":"Pub. L. 107–372, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3087"},"text":"116 Stat. 3087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7856a2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7856a3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c7856a4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section are contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s854a–2"},"text":"section 854a–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
