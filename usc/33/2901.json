{"tag":"section","attrib":{"id":"id6c739cdd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2901"},"text":null,"children":[{"tag":"num","attrib":{"value":"2901"},"text":"§ 2901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c739cde-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the restoration of estuary habitat by implementing a coordinated Federal approach to estuary habitat restoration activities, including the use of common monitoring standards and a common system for tracking restoration acreage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739cdf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement a national estuary habitat restoration strategy for creating and maintaining effective estuary habitat restoration partnerships among public agencies at all levels of government and to establish new partnerships between the public and private sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739ce0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide Federal assistance for estuary habitat restoration projects through cooperative agreements and to promote efficient financing of such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c739ce1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and enhance monitoring and research capabilities through the use of the environmental technology innovation program associated with the National Estuarine Research Reserve System established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1461"},"text":"section 1461 of title 16","children":[],"tail":" to ensure that estuary habitat restoration efforts are based on sound scientific understanding and innovative technologies."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c739ce2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s102"},"text":"Pub. L. 106–457, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1958"},"text":"114 Stat. 1958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5017/a"},"text":"Pub. L. 110–114, title V, § 5017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1197"},"text":"121 Stat. 1197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c739ce3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c739ce4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c739ce5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/a/1"},"text":"Pub. L. 110–114, § 5017(a)(1)","children":[],"tail":", inserted “by implementing a coordinated Federal approach to estuary habitat restoration activities, including the use of common monitoring standards and a common system for tracking restoration acreage” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/a/2"},"text":"Pub. L. 110–114, § 5017(a)(2)","children":[],"tail":", inserted “and implement” after “to develop”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/a/3"},"text":"Pub. L. 110–114, § 5017(a)(3)","children":[],"tail":", inserted “through cooperative agreements” after “restoration projects”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c739ce6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c739ce7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/s1/a"},"text":"Pub. L. 106–457, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1957"},"text":"114 Stat. 1957","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/457/s1/a"},"text":"“This Act [enacting this chapter, sections 1273 and 1300 of this title, and sections 277d–43 to 277d–46 of Title 22, Foreign Relations and Intercourse, amending sections 1263a, 1267, 1269, 1324, and 1330 of this title, and enacting provisions set out as notes under this section, sections 1251 and 1267 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s277d–43"},"text":"section 277d–43 of Title 22","children":[],"tail":"] may be cited as the ‘Estuaries and Clean Waters Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s101"},"text":"Pub. L. 106–457, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1958"},"text":"114 Stat. 1958","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/457/tI/s101"},"text":"“This title [enacting this chapter] may be cited as the ‘Estuary Restoration Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c739ce8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purchase of American-Made Equipment and Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tIX/s901"},"text":"Pub. L. 106–457, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1981"},"text":"114 Stat. 1981","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/457/tIX/s901"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that, to the extent practicable, all equipment and products purchased with funds made available under this Act [see Short Title note above] should be American made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Recipients of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each Federal Agency [sic] providing financial assistance under this Act, to the extent practicable, shall provide to each recipient of the assistance a notice describing the statement made in subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c739ce9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Long-Term Estuary Assessment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tIX/s902"},"text":"Pub. L. 106–457, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1981"},"text":"114 Stat. 1981","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/457/tIX/s902"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Commerce (acting through the Under Secretary for Oceans and Atmosphere) and the Secretary of the Interior (acting through the Director of the Geological Survey) may carry out a long-term estuary assessment project (in this section referred to as the ‘project’) in accordance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the project shall be to establish a network of strategic environmental assessment and monitoring projects for the Mississippi River south of Vicksburg, Mississippi, and the Gulf of Mexico, in order to develop advanced long-term assessment and monitoring systems and models relating to the Mississippi River and other aquatic ecosystems, including developing equipment and techniques necessary to implement the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To establish, operate, and implement the project, the Secretary of Commerce and the Secretary of the Interior may enter into a management agreement with a university-based consortium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 2001 to develop the management agreement under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $4,000,000 for each of fiscal years 2002, 2003, 2004, and 2005 to carry out the project.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such sums shall remain available until expended.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
