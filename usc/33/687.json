{"tag":"section","attrib":{"id":"id6b57cbbd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s687"},"text":null,"children":[{"tag":"num","attrib":{"value":"687"},"text":"§ 687.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of State dredge and appliances in river and harbor improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army is authorized to accept from the State of California the use of any dredger, or appliances owned or controlled by said State, conformably to any offer thereof by the said State; and the Secretary of the Army is authorized to use any such dredger or appliances in any river or harbor improvement that may be prosecuted therein by the United States, either on the part of the United States alone or conjointly with said State: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing shall be paid to the State of California for the use of said dredger, and that nothing herein contained shall create any liability against the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b57cbbe-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch425/s1"},"text":"Mar. 3, 1899, ch. 425, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1148"},"text":"30 Stat. 1148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b57cbbf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b57cbc0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b57cbc1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of act ","children":[{"tag":"date","attrib":{"date":"1899-03-03"},"text":"Mar. 3, 1899","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act of 1899”, and not as part of "},{"tag":"ref","attrib":{"href":"/us/act/1893-03-01/ch183"},"text":"act Mar. 1, 1893, ch. 183","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/507"},"text":"27 Stat. 507","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b57cbc2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b57cbc3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
