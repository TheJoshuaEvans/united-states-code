{"tag":"section","attrib":{"id":"id6c975195-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282"},"text":null,"children":[{"tag":"num","attrib":{"value":"4282"},"text":"§ 4282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c975196-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-consumer materials management infrastructure grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c975197-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The EPA Administrator may provide grants to States to implement the strategy developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4281/a"},"text":"section 4281(a) of this title","children":[],"tail":" and—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c975198-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support improvements to local post-consumer materials management, including municipal recycling programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975199-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist local waste management authorities in making improvements to local waste management systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c97519a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), the applicant State shall submit to the EPA Administrator an application at such time, in such manner, and containing such information as the EPA Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c97519b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing application requirements, the EPA Administrator shall consider requesting that a State applicant provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c97519c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c97519d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project or projects to be carried out using grant funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c97519e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the project or projects would result in the generation of less plastic waste;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c97519f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the funds will support disadvantaged communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of any limitations, such as flow control measures, that restrict access to reusable or recyclable materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9751a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", the EPA Administrator shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure and the Committee on Energy and Commerce of the House of Representatives a report that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9751a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities carried out under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates as to how much plastic waste was prevented from entering the oceans and other waterways as a result of activities funded pursuant to this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recommendation on the utility of evolving the grant program into a new waste management State revolving fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9751a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drinking water infrastructure grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9751a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The EPA Administrator may provide competitive grants to units of local government, Indian Tribes, and public water systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"section 300f of title 42","children":[],"tail":") to support improvements in reducing and removing plastic waste and post-consumer materials, including microplastics and microfibers, from drinking water or sources of drinking water, including planning, design, construction, technical assistance, and planning support for operational adjustments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9751a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), an applicant shall submit to the EPA Administrator an application at such time, in such manner, and containing such information as the EPA Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9751a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wastewater infrastructure grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9751a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The EPA Administrator may provide grants to municipalities (as defined in section 502 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1362"},"text":"33 U.S.C. 1362","children":[],"tail":")) or Indian Tribes that own and operate treatment works (as such term is defined in section 212 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1292"},"text":"33 U.S.C. 1292","children":[],"tail":")) for the construction of improvements to reduce and remove plastic waste and post-consumer materials, including microplastics and microfibers, from wastewater."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9751aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), an applicant shall submit to the EPA Administrator an application at such time, in such manner, and containing such information as the EPA Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9751ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trash-free waters grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9751ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The EPA Administrator may provide grants to units of local government, Indian Tribes, and nonprofit organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9751ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support projects to reduce the quantity of solid waste in bodies of water by reducing the quantity of waste at the source, including through anti-litter initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce local post-consumer materials management ordinances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement State or local policies relating to solid waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to capture post-consumer materials at stormwater inlets, at stormwater outfalls, or in bodies of water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide education and outreach about post-consumer materials movement and reduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9751b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor or model flows of post-consumer materials, including monitoring or modeling a reduction in trash as a result of the implementation of best management practices for the reduction of plastic waste and other post-consumer materials in sources of drinking water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9751b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under paragraph (1), an applicant shall submit to the EPA Administrator an application at such time, in such manner, and containing such information as the EPA Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9751b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Federal law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9751b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The EPA Administrator shall ensure that all laborers and mechanics employed on projects funded directly, or assisted in whole or in part, by a grant established by this section shall be paid wages at rates not less than those prevailing on projects of a character similar in the locality as determined by the Secretary of Labor in accordance with subchapter IV of chapter 31 of part A of subtitle II of title 40.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9751b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the labor standards specified in paragraph (1), the Secretary of Labor shall have the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1267"},"text":"64 Stat. 1267","children":[],"tail":"; 5 U.S.C. App.) and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9751b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of section 608 of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1388"},"text":"33 U.S.C. 1388","children":[],"tail":") shall apply to the construction of a project carried out, in whole or in part, with assistance made available under this section in the same manner as the requirements of such section apply with respect to funds made available pursuant to title VI of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"33 U.S.C. 1381","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9751b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section may not be used (directly or indirectly) as a source of payment (in whole or in part) of, or security for, an obligation the interest on which is excluded from gross income under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s103"},"text":"section 103 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9751b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9751ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the program described ","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “in”."}],"tail":" subsection (a), $55,000,000 for each of fiscal years 2021 through 2025; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9751bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4282/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of the programs described ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" subsections (b), (c), and (d), $10,000,000 for each of fiscal years 2021 through 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9751bc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224/tIII/s302"},"text":"Pub. L. 116–224, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1092"},"text":"134 Stat. 1092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c9751bd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c9751be-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c9751bf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Water Pollution Control Act, referred to in subsec. (e)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"act June 30, 1948, ch. 758","children":[],"tail":". Title VI of the Act, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/4/tII/s212/a"},"text":"Pub. L. 100–4, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/22"},"text":"101 Stat. 22","children":[],"tail":", is classified generally to subchapter VI (§ 1381 et seq.) of chapter 26 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"section 1251 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
