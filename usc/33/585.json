{"tag":"section","attrib":{"id":"id6b499b21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s585"},"text":null,"children":[{"tag":"num","attrib":{"value":"585"},"text":"§ 585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve component training at water resources development projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b499b22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s585/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out military training activities or otherwise fulfilling military training requirements, units or members of a reserve component of the Armed Forces may perform services and furnish supplies in support of a water resources development project or program of the Corps of Engineers without reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b499b23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s585/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to any member of a reserve component of the Armed Forces who is employed by the Corps of Engineers on a full-time basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b499b24-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8124"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3715"},"text":"136 Stat. 3715","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
