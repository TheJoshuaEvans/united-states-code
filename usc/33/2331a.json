{"tag":"section","attrib":{"id":"id6c5bced1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2331a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2331a"},"text":"§ 2331a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiating work on separable elements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"With respect to a water resources development project that has received construction funds in the previous 6-year period, for purposes of initiating work on a separable element of the project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5bced2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2331a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no new start or new investment decision shall be required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5bced3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2331a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the work shall be treated as ongoing work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5bced4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1146"},"text":"Pub. L. 114–322, title I, § 1146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1659"},"text":"130 Stat. 1659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5bced5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5bced6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5bced7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2016, and also as part of the Water Infrastructure Improvements for the Nation Act, also known as the WIIN Act, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
