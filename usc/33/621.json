{"tag":"section","attrib":{"id":"id6b4e564e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s621"},"text":null,"children":[{"tag":"num","attrib":{"value":"621"},"text":"§ 621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By what methods river and harbor work may be authorized to be prosecuted","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any public work on canals, rivers, and harbors adopted by Congress may be prosecuted by direct appropriations, by continuing contracts, or by both direct appropriations and continuing contracts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b4e564f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-22/ch427/s10"},"text":"Sept. 22, 1922, ch. 427, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1043"},"text":"42 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b4e5650-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b4e5651-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b4e5652-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Rivers and Harbors Appropriation Act of 1922.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
