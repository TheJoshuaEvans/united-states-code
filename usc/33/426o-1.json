{"tag":"section","attrib":{"id":"id6b2a7ad8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"426o–1"},"text":"§ 426o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes dredging levels adjustment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b2a7ad9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Great Lake","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Great Lake” means Lake Superior, Lake Michigan, Lake Huron (including Lake St. Clair), Lake Erie, and Lake Ontario (including the St. Lawrence River to the 45th parallel of latitude).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b2a7ada-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s426o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dredging levels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In operating and maintaining Federal channels and harbors of, and the connecting channels between, the Great Lakes, the Secretary shall conduct such dredging as is necessary to ensure minimal operation depths consistent with the original authorized depths of the channels and harbors when water levels in the Great Lakes are, or are forecast to be, below the International Great Lakes Datum of 1985.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b2a7adb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tIII/s343"},"text":"Pub. L. 106–541, title III, § 343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2613"},"text":"114 Stat. 2613","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2a7adc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b2a7add-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b2a7ade-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/s2"},"text":"section 2 of Pub. L. 106–541","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
