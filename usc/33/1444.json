{"tag":"section","attrib":{"id":"id6c0f8361-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444"},"text":null,"children":[{"tag":"num","attrib":{"value":"1444"},"text":"§ 1444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0f8362-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary of Commerce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In March of each year, the Secretary of Commerce shall report to the Congress on his activities under this subchapter during the previous fiscal year. The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f8363-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary’s findings made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1441"},"text":"section 1441 of this title","children":[],"tail":", including an evaluation of the short-term ecological effects and the social and economic factors involved with the dumping;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f8364-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of activities undertaken pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1442"},"text":"section 1442 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f8365-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the concurrence of the Administrator and after consulting with officials of other appropriate Federal agencies, an identification of the short- and long-term research requirements associated with activities under subchapter I, and a description of how Federal research under this subchapter and subchapter I will meet those requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f8366-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities of the Department of Commerce under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s665"},"text":"section 665 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f8367-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In March of each year, the Administrator shall report to the Congress on his activities during the previous fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1443"},"text":"section 1443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f8368-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1444/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Under Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On October 31 of each year, the Under Secretary shall report to the Congress the specific programs that the National Oceanic and Atmospheric Administration and the Environmental Protection Agency carried out pursuant to this subchapter in the previous fiscal year, specifically listing the amount of funds allocated to those specific programs in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f8369-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/tII/s204"},"text":"Pub. L. 92–532, title II, § 204","children":[],"tail":", formerly § 205, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/572/s5"},"text":"Pub. L. 96–572, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3345"},"text":"94 Stat. 3345","children":[],"tail":"; renumbered § 204 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tVI/s6065"},"text":"Pub. L. 99–272, title VI, § 6065","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/132"},"text":"100 Stat. 132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/627/tI/s102"},"text":"Pub. L. 100–627, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3213"},"text":"102 Stat. 3213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0f836a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0f836b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c0f836c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/532/s204"},"text":"section 204 of Pub. L. 92–532","children":[],"tail":", which was classified to this section, was renumbered section 205 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1445"},"text":"section 1445 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0f836d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/627"},"text":"Pub. L. 100–627","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Administrator of the Environmental Protection Agency is authorized to conduct a study to assist the city of New York in evaluating the technological options available for the removal of heavy metals and other toxic organic materials from the sewage sludge of the city of New York. The study shall also examine options available to reduce the amount of such pollutants entering the sewage system. The study is to be completed by "},{"tag":"date","attrib":{"date":"1981-07-01"},"text":"July 1, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
