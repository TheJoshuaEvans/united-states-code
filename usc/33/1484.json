{"tag":"section","attrib":{"id":"id6c0f83dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1484"},"text":null,"children":[{"tag":"num","attrib":{"value":"1484"},"text":"§ 1484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretation and administration; other right, duty, privilege, or immunity and other remedy unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall be interpreted and administered in a manner consistent with the convention, the protocol, and other international law. Except as specifically provided, nothing in this chapter may be interpreted to prejudice any otherwise applicable right, duty, privilege, or immunity or deprive any country or person of any remedy otherwise applicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c0f83de-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s15"},"text":"Pub. L. 93–248, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/10"},"text":"88 Stat. 10","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/6"},"text":"Pub. L. 95–302, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-26"},"text":"June 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/345"},"text":"92 Stat. 345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0f83df-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0f83e0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0f83e1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302"},"text":"Pub. L. 95–302","children":[],"tail":" inserted “, the protocol,” after “convention”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c0f83e2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c0f83e3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302"},"text":"Pub. L. 95–302","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s2"},"text":"section 2 of Pub. L. 95–302","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1487"},"text":"section 1487 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
