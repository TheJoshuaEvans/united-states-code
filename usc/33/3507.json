{"tag":"section","attrib":{"id":"id6c86aec8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507"},"text":null,"children":[{"tag":"num","attrib":{"value":"3507"},"text":"§ 3507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c86aec9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator’ ” ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Closing single quotation mark probably should not appear."}],"tail":" means the Administrator of the National Oceanic and Atmospheric Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aeca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal state","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coastal state” has the meaning given that term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453/4"},"text":"section 1453(4) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aecb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working Group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Working Group” means the Interagency Working Group on Ocean and Coastal Mapping under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3502"},"text":"section 3502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aecc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive economic zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “exclusive economic zone” means the exclusive economic zone of the United States established by Presidential Proclamation No. 5030, of ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aecd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ocean and coastal mapping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ocean and coastal mapping” means the acquisition, processing, management, maintenance, interpretation, certification, and dissemination of physical, biological, geological, chemical, and archaeological characteristics and boundaries of ocean and coastal areas, resources, and sea beds through the use of acoustics, satellites, aerial photogrammetry, light and imaging, direct sampling, and other mapping technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aece-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial sea","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “territorial sea” means the belt of sea measured from the baseline of the United States determined in accordance with international law, as set forth in Presidential Proclamation Number 5928, dated ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aecf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernmental entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nongovernmental entities” includes nongovernmental organizations, members of the academic community, and private sector organizations that provide products and services associated with measuring, locating, and preparing maps, charts, surveys, aerial photographs, satellite imagines,","children":[{"tag":"ref","attrib":{"idref":"fn002152"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002152"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “images,”."}],"tail":" or other graphical or digital presentations depicting natural or manmade physical features, phenomena, and legal boundaries of the Earth."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aed0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outer Continental Shelf","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Outer Continental Shelf” means all submerged lands lying seaward and outside of lands beneath navigable waters (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1301"},"text":"section 1301 of title 43","children":[],"tail":"), and of which the subsoil and seabed appertain to the United States and are subject to its jurisdiction and control."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c86aed1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3507/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastal Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coastal Indian Tribe” means an “Indian Tribe”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":", the land of which is located in a coastal State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c86aed2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12210"},"text":"Pub. L. 111–11, title XII, § 12210","children":[],"tail":", formerly § 12208, "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1426"},"text":"123 Stat. 1426","children":[],"tail":"; renumbered § 12210 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10307/b/1/C"},"text":"Pub. L. 117–263, div. J, title CIII, § 10307(b)(1)(C)","children":[],"tail":", (e)(1), (g), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3976"},"text":"136 Stat. 3976","children":[],"tail":", 3978, 3979.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c86aed3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c86aed4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c86aed5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation No. 5030, referred to in par. (4), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"section 1453 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Presidential Proclamation Number 5928, referred to in par. (6), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c86aed6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10307/b/1/C"},"text":"Pub. L. 117–263, § 10307(b)(1)(C)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “The term ‘Committee’ means the Interagency Ocean and Coastal Mapping Committee established by "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3502"},"text":"section 3502 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10307/g/1"},"text":"Pub. L. 117–263, § 10307(g)(1)","children":[],"tail":", substituted “processing, management, maintenance, interpretation, certification, and dissemination” for “processing, and management”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s10307/g/2"},"text":"Pub. L. 117–263, § 10307(g)(2)","children":[],"tail":", added par. (9)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
