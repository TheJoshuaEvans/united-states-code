{"tag":"section","attrib":{"id":"id6b06c5ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s31"},"text":null,"children":[{"tag":"num","attrib":{"value":"31"},"text":"§ 31.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Iowa River, Iowa, above Toolsboro","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"So much of the Iowa River within the State of Iowa, as lies north of the town of Wapello, and so much of the said river within the State of Iowa, as lies between the town of Toolsboro and the town of Wapello, in the county of Louisa, shall not be deemed a navigable river or public highway, but dams and bridges may be constructed across it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b06c5ee-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 5248; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-08-18/ch299/s1"},"text":"Aug. 18, 1894, ch. 299, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/356"},"text":"28 Stat. 356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b06c5ef-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b06c5f0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b06c5f1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5248 derived from Res. ","children":[{"tag":"date","attrib":{"date":"1868-07-13"},"text":"July 13, 1868","children":[],"tail":", No. 55, "},{"tag":"ref","attrib":{"href":"/us/stat/15/257"},"text":"15 Stat. 257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1870-05-06/ch92"},"text":"act May 6, 1870, ch. 92","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/121"},"text":"16 Stat. 121","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The portion of this section relating to the Iowa river north of the town of Wapello is from R.S. § 5248.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The remainder the section, relating to so much of the river as lies between Toolsboro and Wapello, is from act ","children":[{"tag":"date","attrib":{"date":"1894-08-18"},"text":"Aug. 18, 1894","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
