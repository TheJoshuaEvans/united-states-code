{"tag":"section","attrib":{"id":"id6c27510e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1965"},"text":null,"children":[{"tag":"num","attrib":{"value":"1965"},"text":"§ 1965.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may accept, without regard to the civil service classification laws, rules, or regulations, the services of the Foundation, the Board, and the officers and employees of the Board, without compensation from the Department of Commerce, as volunteers in the performance of the functions authorized in this title.","children":[{"tag":"ref","attrib":{"idref":"fn002090"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002090"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c27510f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s115"},"text":"Pub. L. 109–449, § 115","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s115"},"text":"Pub. L. 116–224, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1079"},"text":"134 Stat. 1079","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s115"},"text":"Pub. L. 109–449, § 115","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/a"},"text":"Pub. L. 119–65, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"ta