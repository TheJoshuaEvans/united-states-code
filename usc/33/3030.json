{"tag":"section","attrib":{"id":"id6c760ea0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3030"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030"},"text":"§ 3030.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary appointment or advancement of commissioned officers in time of war or national emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760ea1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3030/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Officers of the Administration shall be subject in like manner and to the same extent as personnel of the Navy to all laws authorizing temporary appointment or advancement of commissioned officers in time of war or national emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760ea2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3030/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall be applied subject to the following limitations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760ea3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3030/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned officer in the service of a military department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3061"},"text":"section 3061 of this title","children":[],"tail":" may, upon the recommendation of the Secretary of the military department concerned, be temporarily promoted to a higher rank or grade."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760ea4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3030/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned officer in the service of the Administration may be temporarily promoted to fill vacancies in ranks and grades caused by the transfer of commissioned officers to the service and jurisdiction of a military department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3061"},"text":"section 3061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c785695-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3030/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary appointments may be made in all grades to which original appointments in the Administration are authorized, except that the number of officers holding temporary appointments may not exceed the number of officers transferred to a military department under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3061"},"text":"section 3061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c785696-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s230"},"text":"Pub. L. 107–372, title II, § 230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3087"},"text":"116 Stat. 3087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c785697-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c785698-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c785699-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section are contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s854a–1"},"text":"section 854a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c78569a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id6c78569b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (b) of this section delegated to Secretary of Commerce by section 1(h)–(j) of Ex. Ord. No. 11023, ","children":[{"tag":"date","attrib":{"date":"1962-05-28"},"text":"May 28, 1962","children":[],"tail":", 27 F.R. 5131, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
