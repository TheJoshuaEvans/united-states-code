{"tag":"section","attrib":{"id":"id6c760d93-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908"},"text":null,"children":[{"tag":"num","attrib":{"value":"2908"},"text":"§ 2908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760d94-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760d95-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuary habitat restoration projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated for carrying out and providing technical assistance for estuary habitat restoration projects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760d96-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary, $25,000,000 for each of fiscal years 2008 through 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760d97-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of the Interior (acting through the Director of the United States Fish and Wildlife Service), $2,500,000 for each of fiscal years 2008 through 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760d98-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Under Secretary for Oceans and Atmosphere of the Department of Commerce, $2,500,000 for each of fiscal years 2008 through 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760d99-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Administrator of the Environmental Protection Agency, $2,500,000 for each of fiscal years 2008 through 2021; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760d9a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of Agriculture, $2,500,000 for each of fiscal years 2008 through 2021.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760d9b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Under Secretary for Oceans and Atmosphere of the Department of Commerce for the acquisition, maintenance, and management of monitoring data on restoration projects carried out under this chapter and other information compiled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2906"},"text":"section 2906 of this title","children":[],"tail":", $1,500,000 for each of fiscal years 2001 through 2021. Such sums shall remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760d9c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside for administrative expenses of the Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 3 percent of the amounts appropriated for a fiscal year under subsection (a)(1) or $1,500,000, whichever is greater, may be used by the Secretary for administration and operation of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760d9d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s109"},"text":"Pub. L. 106–457, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1965"},"text":"114 Stat. 1965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5017/g"},"text":"Pub. L. 110–114, title V, § 5017(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1198"},"text":"121 Stat. 1198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5013/b"},"text":"Pub. L. 114–322, title IV, § 5013(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1903"},"text":"130 Stat. 1903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760d9e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760d9f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760da0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" substituted “through 2021” for “through 2012” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/g/1"},"text":"Pub. L. 110–114, § 5017(g)(1)","children":[],"tail":", struck out “to the Secretary” after “appropriated” in introductory provisions, added subpars. (A) to (E), and struck out former subpars. (A) to (D) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $40,000,000 for fiscal year 2001;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $50,000,000 for each of fiscal years 2002 and 2003;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $60,000,000 for fiscal year 2004; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) $75,000,000 for fiscal year 2005.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/g/2"},"text":"Pub. L. 110–114, § 5017(g)(2)","children":[],"tail":", inserted “and other information compiled under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2906"},"text":"section 2906 of this title","children":[],"tail":"” after “this chapter” and substituted “2012” for “2005”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
