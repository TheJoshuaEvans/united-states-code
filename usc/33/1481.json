{"tag":"section","attrib":{"id":"id6c0f83c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1481"},"text":null,"children":[{"tag":"num","attrib":{"value":"1481"},"text":"§ 1481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0f83c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person commits a class A misdemeanor if that person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f83c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1481/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully violates a provision of this chapter or a regulation issued thereunder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1481/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully refuses or fails to comply with any lawful order or direction given pursuant to this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f83c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1481/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully obstructs any person who is acting in compliance with an order or direction under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f83ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"t