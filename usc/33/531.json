{"tag":"section","attrib":{"id":"id6b3d8d24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s531"},"text":null,"children":[{"tag":"num","attrib":{"value":"531"},"text":"§ 531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International bridges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall not be construed to authorize the construction of any bridge which will connect the United States, or any Territory or possession of the United States, with any foreign country.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3d8d25-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"Aug. 2, 1946, ch. 753","children":[],"tail":", title V, § 508, "},{"tag":"ref","attrib":{"href":"/us/stat/60/849"},"text":"60 Stat. 849","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
