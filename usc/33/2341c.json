{"tag":"section","attrib":{"id":"id6c5e18d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2341c"},"text":"§ 2341c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for funding environmental infrastructure projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5e18d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall develop specific criteria for the evaluation and ranking of individual environmental assistance projects authorized by Congress (including projects authorized pursuant to environmental assistance programs) for the Secretary to carry out."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e18d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of carrying out this section, the Secretary shall evaluate, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e18d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the nature and extent of the positive and negative local economic impacts of the project, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e18d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of the project to the local economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the project will enhance local development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of jobs that will be directly created by the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the non-Federal interest to pay the applicable non-Federal share of the cost of the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the demographics of the location in which the project is to be carried out, including whether the project serves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c5e18dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c5e18dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economically disadvantaged community, including an economically disadvantaged minority community;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of appropriations a project has received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding capability of the Corps of Engineers with respect to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the project could be carried out under other Federal authorities at an equivalent cost to the non-Federal interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other criteria that the Secretary considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e18e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include the criteria developed under subsection (a) in the annual Civil Works Direct Program Development Policy Guidance of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e18e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2341c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2022, and biennially thereafter, in conjunction with the President’s annual budget submission to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Secretary shall submit to the Committee on Environment and Public Works and the Committee on Appropriations of the Senate and the Committee on Transportation and Infrastructure and the Committee on Appropriations of the House of Representatives a report that identifies the Secretary’s ranking of individual environmental assistance projects authorized by Congress for the Secretary to carry out, in accordance with the criteria developed under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5e18e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s137"},"text":"Pub. L. 116–260, div. AA, title I, § 137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2650"},"text":"134 Stat. 2650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5e18e5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5e18e6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5e18e7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5e18e8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e18e9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id6c5e18ea-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “economically disadvantaged community” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s160"},"text":"section 160 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
