{"tag":"section","attrib":{"id":"id6c0f8376-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471"},"text":"§ 1471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c0f8377-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “a substance other than convention oil” means those oils, noxious substances, liquefied gases, and radioactive substances—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0f8378-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enumerated in the protocol, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0f8379-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise determined to be hazardous under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1473/a"},"text":"section 1473(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f837a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “convention” means the International Convention Relating to Intervention on the High Seas in Cases of Oil Pollution Casualties, 1969, including annexes thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f837b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “convention oil” means crude oil, fuel oil, diesel oil, and lubricating oil;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f837c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the department in which the Coast Guard is operating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f837d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “ship” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c0f837e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a seagoing vessel of any type whatsoever, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c0f837f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any floating craft, except an installation or device engaged in the exploration and exploitation of the resources of the seabed and the ocean floor and the subsoil thereof;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f8380-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “protocol” means the Protocol Relating to Intervention on the High Seas in Cases of Marine Pollution by Substances Other Than Oil, 1973, including annexes thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c0f8381-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1471/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the States, the District of Columbia, the Commonwealth of Puerto Rico, the Canal Zone, Guam, American Samoa, the United States Virgin Islands, the Trust Territory of the Pacific Islands, the Commonwealth of the Northern Marianas, and any other commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f8382-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s2"},"text":"Pub. L. 93–248, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/8"},"text":"88 Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/1"},"text":"Pub. L. 95–302, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-26"},"text":"June 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/344"},"text":"92 Stat. 344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c0f8383-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c0f8384-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c0f8385-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, referred to in par. (7), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c0f8386-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302"},"text":"Pub. L. 95–302","children":[],"tail":" in cl. (1) substituted definition of “a substance other than convention oil” for definition of “ship”, in cl. (2) substituted definition of “convention” for definition of “oil”, in cl. (3) substituted definition of “convention oil” for definition of “convention”, in cl. (5) substituted definition of “ship” for definition of “United States”, and added cls. (6) and (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c0f8387-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6c0f8388-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/302"},"text":"Pub. L. 95–302","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s2"},"text":"section 2 of Pub. L. 95–302","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1487"},"text":"section 1487 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6c0f8389-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s1"},"text":"Pub. L. 93–248, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/8"},"text":"88 Stat. 8","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/248/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Intervention on the High Seas Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6c0f838a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6c0f838b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c0f838c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
