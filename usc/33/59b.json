{"tag":"section","attrib":{"id":"id6b0b8141-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s59b"},"text":null,"children":[{"tag":"num","attrib":{"value":"59b"},"text":"§ 59b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bayous Terrebonne and LeCarpe, Louisiana","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Bayou Terrebonne west of Barrow Street and Bayou LeCarpe west of the Intracoastal Waterway in the city of Houma, State of Louisiana, are declared to be not navigable waters of the United States within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b8142-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/226"},"text":"Pub. L. 86–226","children":[],"tail":", §§ 2, 3, "},{"tag":"date","attrib":{"date":"1959-09-08"},"text":"Sept. 8, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/455"},"text":"73 Stat. 455","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
