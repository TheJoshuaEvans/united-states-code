{"tag":"section","attrib":{"id":"id6c05e627-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1384"},"text":null,"children":[{"tag":"num","attrib":{"value":"1384"},"text":"§ 1384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c05e628-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums authorized to be appropriated to carry out this section for each of fiscal years 1989 and 1990 shall be allotted by the Administrator in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1285/c"},"text":"section 1285(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e629-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds for planning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall reserve each fiscal year 1 percent of the sums allotted to such State under this section for such fiscal year, or $100,000, whichever amount is greater, to carry out planning under sections 1285(j) and 1313(e) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c05e62a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c05e62b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1384/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability for grant award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums allotted to a State under this section for a fiscal year shall be available for obligation by the State during the fiscal year for which sums are authorized and during the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c05e62c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1384/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment of unobligated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any allotment not obligated by the State by the last day of the 2-year period of availability established by paragraph (1) shall be immediately reallotted by the Administrator on the basis of the same ratio as is applicable to sums allotted under subchapter II of this chapter for the second fiscal year of such 2-year period. None of the funds reallotted by the Administrator shall be reallotted to any State which has not obligated all sums allotted to such State in the first fiscal year of such 2-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c05e62d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title VI, § 604, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/4/tII/s212/a"},"text":"Pub. L. 100–4, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-02-04"},"text":"Feb. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/25"},"text":"101 Stat. 25","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c05e62e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c05e62f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c05e630-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Capitalization Grant Funds for Construction Grants","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/144/tIII"},"text":"Pub. L. 101–144, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-09"},"text":"Nov. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/858"},"text":"103 Stat. 858","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/302/tII"},"text":"Pub. L. 101–302, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-25"},"text":"May 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/238"},"text":"104 Stat. 238","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/302/tII"},"text":"“That, notwithstanding any other provision of law, sums heretofore, herein or hereafter appropriated under this heading [“","children":[{"tag":"inline","attrib":{},"text":"Environmental Protection Agency","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"construction grants","children":[],"tail":"”] allotted for title VI ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1381"},"text":"33 U.S.C. 1381","children":[],"tail":" et seq.] capitalization grants to American Samoa, Commonwealth of the Northern Mariana Islands, Guam, the Republic of Palau (or its successor entity), Virgin Islands and the District of Columbia, may be used for title II ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1281"},"text":"33 U.S.C. 1281","children":[],"tail":" et seq.] construction grants at the request of the chief executive of each of the above named entities, and sums appropriated in fiscal year 1989 shall remain available for obligation until "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
