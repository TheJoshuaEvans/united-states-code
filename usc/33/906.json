{"tag":"section","attrib":{"id":"id6b7df1ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s906"},"text":null,"children":[{"tag":"num","attrib":{"value":"906"},"text":"§ 906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7df1eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No compensation shall be allowed for the first three days of the disability, except the benefits provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s907"},"text":"section 907 of this title","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That in case the injury results in disability of more than fourteen days the compensation shall be allowed from the date of the disability."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7df1ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum rate of compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7df1ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for disability or death (other than compensation for death required by this chapter to be paid in a lump sum) shall not exceed an amount equal to 200 per centum of the applicable national average weekly wage, as determined by the Secretary under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7df1ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for total disability shall not be less than 50 per centum of the applicable national average weekly wage determined by the Secretary under paragraph (3), except that if the employee’s average weekly wages as computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s910"},"text":"section 910 of this title","children":[],"tail":" are less than 50 per centum of such national average weekly wage, he shall receive his average weekly wages as compensation for total disability."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7df1ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable after June 30 of each year, and in any event prior to October 1 of such year, the Secretary shall determine the national average weekly wage for the three consecutive calendar quarters ending June 30. Such determination shall be the applicable national average weekly wage for the period beginning with October 1 of that year and ending with September 30 of the next year. The initial determination under this paragraph shall be made as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1972-10-27"},"text":"October 27, 1972","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7df1f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Determinations under subsection (b)(3) with respect to a period shall apply to employees or survivors currently receiving compensation for permanent total disability or death benefits during such period, as well as those newly awarded compensation during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7df1f1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s6"},"text":"Mar. 4, 1927, ch. 509, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1426"},"text":"44 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch623/s1"},"text":"June 24, 1948, ch. 623, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/602"},"text":"62 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-26/ch735/s1"},"text":"July 26, 1956, ch. 735, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/654"},"text":"70 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/87/s1"},"text":"Pub. L. 87–87, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-07-14"},"text":"July 14, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/203"},"text":"75 Stat. 203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/576"},"text":"Pub. L. 92–576","children":[],"tail":", §§ 4, 5(a), "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1252"},"text":"86 Stat. 1252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s6"},"text":"Pub. L. 98–426, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1641"},"text":"98 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7df1f2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7df1f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b7df1f4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s6/a"},"text":"Pub. L. 98–426, § 6(a)","children":[],"tail":", substituted provisions setting a maximum compensation for disability on death of 200 per centum of the applicable national average weekly wage as determined by the Secretary for former provisions which had set out a schedule of progressive percentages of 125 per centum or $167, whichever is greater, during the period ending "},{"tag":"date","attrib":{"date":"1973-09-30"},"text":"September 30, 1973","children":[],"tail":", 150 per centum during the period beginning "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"October 1, 1973","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1974-09-30"},"text":"September 30, 1974","children":[],"tail":", 175 per centum during the period beginning "},{"tag":"date","attrib":{"date":"1974-10-01"},"text":"October 1, 1974","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1975-09-30"},"text":"September 30, 1975","children":[],"tail":", and 200 per centum beginning "},{"tag":"date","attrib":{"date":"1975-10-01"},"text":"October 1, 1975","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s6/b"},"text":"Pub. L. 98–426, § 6(b)","children":[],"tail":", redesignated subsec. (d) as (c) and substituted “under subsection (b)(3)” for “under this subsection”. Former subsec. (c), which had directed that the maximum rate of compensation for a nonappropriated fund instrumentality employee be equal to 66⅔ per centum of the maximum rate of basic pay established for a Federal employee in grade GS–12 by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" and the minimum rate of compensation for such an employee be equal to 66⅔ per centum of the minimum rate of basic pay established for a Federal employee in grade GS–2 by such section, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576/s4"},"text":"Pub. L. 92–576, § 4","children":[],"tail":", substituted “fourteen days” for “twenty-eight days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576/s5/a"},"text":"Pub. L. 92–576, § 5(a)","children":[],"tail":" added subsecs. (b) to (d) and struck out former subsec. (b) compensation for disability provisions which prescribed a $70 per week limit, a $18 per week minimum for total disability, and provided that if the employee’s average weekly wages, as computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s910"},"text":"section 910 of this title","children":[],"tail":", were less than $18 per week he should receive as compensation for total disability his average weekly wages."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/87"},"text":"Pub. L. 87–87","children":[],"tail":" increased limitation on compensation for disability from “$54” to “$70” per week."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1956-07-26"},"text":"July 26, 1956","children":[],"tail":", substituted “three days” for “seven days” and “twenty-eight days” for “forty-nine days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1956-07-26"},"text":"July 26, 1956","children":[],"tail":", substituted “$54” for “$35”, and “$18” for “$12” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1948—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1948-06-24"},"text":"June 24, 1948","children":[],"tail":", increased maximum weekly compensation from $25 to $35 and the minimum from $9 to $12 in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b7df1f5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7df1f6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426/s6/a"},"text":"section 6(a) of Pub. L. 98–426","children":[],"tail":" applicable with respect to any death after "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s6/b"},"text":"section 6(b) of Pub. L. 98–426","children":[],"tail":" applicable with respect to any injury, disability, or death after "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", see section 28(d), (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7df1f7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/576"},"text":"Pub. L. 92–576","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/576/s22"},"text":"section 22 of Pub. L. 92–576","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7df1f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1961 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/87/s4"},"text":"Pub. L. 87–87, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-07-14"},"text":"July 14, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/204"},"text":"75 Stat. 204","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/87/s4"},"text":"“The amendments made by the foregoing provisions of this Act [amending this section and sections 909 and 914 of this title] shall become effective as to injuries or death sustained on or after the date of enactment [","children":[{"tag":"date","attrib":{"date":"1961-07-14"},"text":"July 14, 1961","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7df1f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1956 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-26/ch735/s9"},"text":"Act July 26, 1956, ch. 735, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/656"},"text":"70 Stat. 656","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-07-26/ch735/s9"},"text":"“The amendments made by the first section and sections 2, 4, and 5 of this Act [amending this section and sections 908, 909, and 914 of this title] shall be applicable only with respect to injuries and death occurring on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1956-07-26"},"text":"July 26, 1956","children":[],"tail":"] notwithstanding the provisions of the Act of "},{"tag":"date","attrib":{"date":"1942-12-02"},"text":"December 2, 1942","children":[],"tail":", as amended (42 U.S.C. sec. 1701 et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b7df1fa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch623/s6"},"text":"Act June 24, 1948, ch. 623, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/604"},"text":"62 Stat. 604","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1948-06-24/ch623/s6"},"text":"“The provisions of this Act [amending this section and sections 908, 909, 910, and 914 of this title] shall be applicable only to injuries or deaths occurring on or after the effective date hereof [","children":[{"tag":"date","attrib":{"date":"1948-06-24"},"text":"June 24, 1948","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
