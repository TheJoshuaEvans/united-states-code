{"tag":"section","attrib":{"id":"id6c595d5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2326g"},"text":"§ 2326g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficial use of dredged material; dredged material management plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c595d5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National policy on the beneficial use of dredged material","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595d5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595d5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States for the Corps of Engineers to maximize the beneficial use, in an environmentally acceptable manner, of suitable dredged material obtained from the construction or operation and maintenance of water resources development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the greatest extent practicable, the Secretary shall ensure that not less than 70 percent by volume (as measured in cubic yards) of suitable dredged material obtained from the construction or operation and maintenance of water resources development projects is used beneficially.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595d5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement of dredged materials","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595d60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating the placement of dredged material obtained from the construction or operation and maintenance of water resources development projects, the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595d61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suitability of the dredged material for a full range of beneficial uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595d62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic and environmental benefits, efficiencies, and impacts (including the effects on living coral) of using the dredged material for beneficial uses, including, in the case of beneficial use activities that involve more than one water resources development project, the benefits, efficiencies, and impacts that result from the combined activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of Federal standard","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595d64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The economic benefits and efficiencies from the beneficial use of dredged material considered by the Secretary under subparagraph (A) shall be included in any determination relating to the “Federal standard” by the Secretary under section 335.7 of title 33, Code of Federal Regulations, for the placement or disposal of such material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595d65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to Congress—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c595d66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report detailing the method and all of the factors utilized by the Corps of Engineers to determine the Federal standard referred to in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c595d67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each evaluation under subparagraph (A), a report displaying the calculations for economic and environmental benefits and efficiencies from the beneficial use of dredged material (including, where appropriate, the utilization of alternative dredging equipment and dredging disposal methods) considered by the Secretary under such subparagraph for the placement or disposal of such material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595d68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2326g/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c595d69-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s125/a"},"text":"Pub. L. 116–260, div. AA, title I, § 125(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2636"},"text":"134 Stat. 2636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1130/c"},"text":"Pub. L. 118–272, div. A, title I, § 1130(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3019"},"text":"138 Stat. 3019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595d6a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595d6b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595d6c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s125/a"},"text":"section 125(a) of div. AA of Pub. L. 116–260","children":[],"tail":". Par. (2)(C) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s125/a"},"text":"section 125(a) of div. AA of Pub. L. 116–260","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2326"},"text":"section 2326 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c595d6d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272"},"text":"Pub. L. 118–272","children":[],"tail":" designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c595d6e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595d6f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
