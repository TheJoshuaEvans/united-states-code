{"tag":"section","attrib":{"id":"id6b3ffe8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s540a"},"text":null,"children":[{"tag":"num","attrib":{"value":"540a"},"text":"§ 540a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations for attendance by military personnel at meetings and for printing survey reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations in this title ","children":[{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or appropriations made in this title "},{"tag":"ref","attrib":{"idref":"fn002017"},"text":"1","children":[],"tail":" in subsequent Energy and Water Development Appropriations Acts shall on and after "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"October 2, 1992","children":[],"tail":", be available for expenses of attendance by military personnel at meetings in the manner authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4110"},"text":"section 4110 of title 5","children":[],"tail":", uniforms, and allowances therefor, as authorized by law ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901–590"},"text":"5 U.S.C. 5901–590","children":[],"tail":"2), and for printing, either during a recess or session of Congress, of survey reports authorized by law, and such survey reports as may be printed during a recess of Congress shall be printed, with illustrations, as documents of the next succeeding session of Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3ffe8b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377/tI"},"text":"Pub. L. 102–377, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1325"},"text":"106 Stat. 1325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b3ffe8c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b3ffe8d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b3ffe8e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377"},"text":"Pub. L. 102–377","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1315"},"text":"106 Stat. 1315","children":[],"tail":". For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
