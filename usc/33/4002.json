{"tag":"section","attrib":{"id":"id6c9296a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002"},"text":null,"children":[{"tag":"num","attrib":{"value":"4002"},"text":"§ 4002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National harmful algal bloom and hypoxia program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c9296a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", the Under Secretary, acting through the Task Force, shall maintain and enhance a national harmful algal bloom and hypoxia program, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9296a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of objectives, including understanding, detecting, predicting, controlling, mitigating, and responding to marine and freshwater harmful algal bloom and hypoxia events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comprehensive research plan and action strategy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4003"},"text":"section 4003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9296a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall periodically review and revise the Program, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9296aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9296ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate interagency review of the objectives and activities of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedite the interagency review process by ensuring timely review and dispersal of required reports and assessments under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the implementation of the Action Strategy, including the coordination and integration of the research of all Federal programs, including ocean and Great Lakes science and management programs and centers, that address the chemical, biological, and physical components of marine and freshwater harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of institutional mechanisms and financial instruments to further the objectives and activities of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the Program’s distribution of Federal funding to address the objectives and activities of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the development of new technologies for predicting, monitoring, and mitigating harmful algal bloom and hypoxia conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such interagency working groups as it considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9296b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (h), the National Oceanic and Atmospheric Administration shall have primary responsibility for administering the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9296b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the Program, the Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9296b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the Program, including to local and regional stakeholders through the establishment and maintenance of a publicly accessible Internet website that provides information as to Program activities completed under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare work and spending plans for implementing the research and activities identified under the Action Strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administer peer-reviewed, merit-based, competitive grant funding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9296b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and enhance baseline monitoring programs established by the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9296b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the projects maintained and established by the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9296b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address the research and management needs and priorities identified in the Action Strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9296ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accelerate the utilization of effective methods of intervention and mitigation to reduce the frequency, severity, and impacts of harmful algal bloom and hypoxia events;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with, and work cooperatively to provide technical assistance to, regional, State, tribal, and local government agencies and programs that address marine and freshwater harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Secretary of State to support international efforts on marine and freshwater harmful algal bloom and hypoxia information sharing, research, prediction, mitigation, control, and response activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify additional research, development, and demonstration needs and priorities relating to monitoring, prevention, control, mitigation, and response to marine and freshwater harmful algal blooms and hypoxia, including methods and technologies to protect the ecosystems affected by marine and freshwater harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate, coordinate, and augment existing education and extension programs to improve public understanding and awareness of the causes, impacts, intervention, and mitigation efforts for marine and freshwater harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9296bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate and provide resources to train State and local coastal and water resource managers in the methods and technologies for monitoring, preventing, controlling, and mitigating marine and freshwater harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support regional efforts to control and mitigate outbreaks through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9506c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication of the contents of the Action Strategy and maintenance of online data portals for other information about harmful algal blooms and hypoxia to State, tribal, and local stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing the development, review, and periodic updating of the Action Strategy;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene at least 1 meeting of the Task Force each year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/e/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other tasks as may be delegated by the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Oceanic and Atmospheric Administration activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9506c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and enhance the existing competitive programs at the National Oceanic and Atmospheric Administration relating to harmful algal blooms and hypoxia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out marine and Great Lakes harmful algal bloom and hypoxia events response activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and enhance, including with respect to infrastructure, which shall include unmanned systems, as necessary, critical observations, monitoring, modeling, data management, information dissemination, and operational forecasts relevant to harmful algal blooms and hypoxia events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance communication and coordination among Federal agencies carrying out marine and freshwater harmful algal bloom and hypoxia activities and research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the greatest extent practicable, leverage existing resources and expertise available from local research universities and institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increase the availability to appropriate public and private entities of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9506cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytical facilities and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational forecasts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506ce-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reference and research materials;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506cf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use cost effective methods in carrying out this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506d0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop contingency plans for the long-term monitoring of hypoxia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506d1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall work cooperatively and avoid duplication of effort with other offices, centers, and programs within the National Oceanic and Atmospheric Administration, other agencies on the Task Force, and States, tribes, and nongovernmental organizations concerned with marine and freshwater issues to coordinate harmful algal bloom and hypoxia (and related) activities and research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506d2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freshwater","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the freshwater aspects of the Program, the Administrator, through the Task Force, shall carry out the duties otherwise assigned to the Under Secretary under this section, except the activities described in subsection (f).","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c9506d3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator’s participation under this section shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c9506d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on the ecology and impacts of freshwater harmful algal blooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c9506d5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forecasting and monitoring of and event response to freshwater harmful algal blooms in lakes, rivers, estuaries (including their tributaries), and reservoirs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c9506d6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that activities carried out under this chapter focus on new approaches to addressing freshwater harmful algal blooms and are not duplicative of existing research and development programs authorized by this chapter or any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c9506d7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4002/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated Coastal and Ocean Observation System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The collection of monitoring and observation data under this chapter shall comply with all data standards and protocols developed pursuant to the Integrated Coastal and Ocean Observation System Act of 2009 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3601"},"text":"33 U.S.C. 3601","children":[],"tail":" et seq.). Such data shall be made available through the system established under that Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c9506d8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tVI/s603A"},"text":"Pub. L. 105–383, title VI, § 603A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/124/s4"},"text":"Pub. L. 113–124, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1379"},"text":"128 Stat. 1379","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/e"},"text":"Pub. L. 115–423, § 9(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5462"},"text":"132 Stat. 5462","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c9506d9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c9506da-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c9506db-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Integrated Coastal and Ocean Observation System Act of 2009, referred to in subsec. (i), is subtitle C (§ 12301 et seq.) of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1427"},"text":"123 Stat. 1427","children":[],"tail":", which is classified generally to chapter 49 (§ 3601 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c9506dc-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/e/1/A"},"text":"Pub. L. 115–423, § 9(e)(1)(A)","children":[],"tail":", inserted “, including to local and regional stakeholders through the establishment and maintenance of a publicly accessible Internet website that provides information as to Program activities completed under this section” after “Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/e/1/B"},"text":"Pub. L. 115–423, § 9(e)(1)(B)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/e/1/C"},"text":"Pub. L. 115–423, § 9(e)(1)(C)","children":[],"tail":", substituted “, and work cooperatively to provide technical assistance to,” for “and work cooperatively with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/e/1/D"},"text":"Pub. L. 115–423, § 9(e)(1)(D)","children":[],"tail":", inserted “and extension” after “existing education” and “intervention,” after “awareness of the causes, impacts,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/e/2/A"},"text":"Pub. L. 115–423, § 9(e)(2)(A)","children":[],"tail":", inserted “, which shall include unmanned systems,” after “infrastructure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s9/e/2/B"},"text":"Pub. L. 115–423, § 9(e)(2)(B)","children":[],"tail":"–(D), added pars. (7) and (8)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
