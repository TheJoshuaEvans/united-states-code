{"tag":"section","attrib":{"id":"id6c48bc54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282d–1"},"text":"§ 2282d–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress on authorized studies and projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c48bc55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than February 1 of each year, the Secretary shall develop and submit to Congress an annual report, to be entitled “Report to Congress on Authorized Water Resources Development Projects and Studies”, that identifies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bc56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ongoing or new feasibility studies, authorized within the previous 20 years, for which a Report of the Chief of Engineers has not been issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized feasibility studies for projects in the preconstruction, engineering and design phase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ongoing or new water resources development projects authorized for construction within the previous 20 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized and constructed water resources development projects the Secretary has the responsibility to operate or maintain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bc5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bc5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c48bc5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in each report submitted under this section only a feasibility study or water resources development project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c48bc5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has been authorized by Congress to be carried out by the Secretary and does not require any additional congressional authorization to be carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c48bc5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Secretary has the capability to carry out if funds are appropriated for such study or project under any of the “Investigations”, “Construction”, “Operation and Maintenance”, or “Mississippi River and Tributaries” appropriations accounts for the Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c48bc5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which a non-Federal interest—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c48bc60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a study or a project other than a project for which funds may be appropriated for operation and maintenance, has entered into a feasibility cost-sharing agreement, design agreement, or project partnership agreement with the Corps of Engineers, or has informed the Secretary that the non-Federal interest has the financial capability to enter into such an agreement within 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c48bc61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates the legal and financial capability to satisfy the requirements for local cooperation with respect to the study or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c48bc62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of benefits","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c48bc63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, describe in each report submitted under this section the benefits, as described in clause (ii), of each feasibility study and water resources development project included in the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c48bc64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The benefits referred to in clause (i) are benefits to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c48bc65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of human life and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c48bc66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement to transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c48bc67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national, regional, or local economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c48bc68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c48bc69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/1/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc6a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in each report submitted under this section, for each feasibility study and water resources development project included in the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c48bc6b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the associated non-Federal interest, including the name of any non-Federal interest that has contributed, or is expected to contribute, a non-Federal share of the cost of the study or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c48bc6c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of the study or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c48bc6d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an estimate, to the extent practicable, of the Federal, non-Federal, and total costs of the study or project, including, to the extent practicable, the fully funded capability of the Corps of Engineers for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c48bc6e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 3 fiscal years following the fiscal year in which the report is submitted, in the case of a feasibility study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c48bc6f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 5 fiscal years following the fiscal year in which the report is submitted, in the case of a water resources development project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c48bc70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate, to the extent practicable, of the monetary and nonmonetary benefits of the study or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in each report submitted under this section a certification stating that each feasibility study or water resources development project included in the report meets the criteria described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omissions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c48bc73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not omit from a report submitted under this section a study or project that otherwise meets the criteria for inclusion in the report solely on the basis of a policy of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c48bc74-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appendix","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary omits from a report submitted under this section a study or project that otherwise meets the criteria for inclusion in the report, the Secretary shall include with the report an appendix that lists the name of the study or project and reason for its omission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bc75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress; publication","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bc76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may submit a report under this section in conjunction with the submission of the annual report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2282d"},"text":"section 2282d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On submission of each report under this section, the Secretary shall make the report publicly available, including through publication on the internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c48bc78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c48bc79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-Federal interest” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1962d–5b"},"text":"section 1962d–5b of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c48bc7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2282d–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water resources development project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “water resources development project” includes a separable element of a project, a project under an environmental infrastructure assistance program, and a project the authorized purposes of which include water supply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c48bc7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tII/s222"},"text":"Pub. L. 116–260, div. AA, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2694"},"text":"134 Stat. 2694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c48bc7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c48bc7d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c48bc7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2020, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c48bc7f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c48bc80-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/s2"},"text":"section 2 of div. AA of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
