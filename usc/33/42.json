{"tag":"section","attrib":{"id":"id6b093714-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s42"},"text":null,"children":[{"tag":"num","attrib":{"value":"42"},"text":"§ 42.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Platte River, Missouri","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Platte River in the State of Missouri is declared to be a nonnavigable stream within the meaning of the Constitution and laws of the United States, and jurisdiction over said river is declared to be vested in the State of Missouri.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right of Congress to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b093715-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-02-16/ch62"},"text":"Feb. 16, 1921, ch. 62","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/41/1105"},"text":"41 Stat. 1105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b093716-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b093717-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b093718-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The two sentences of this section are, respectively, from sections 1 and 2 of act ","children":[{"tag":"date","attrib":{"date":"1921-02-16"},"text":"Feb. 16, 1921","children":[],"tail":", entitled “An Act declaring the Platte River to be a nonnavigable stream”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
