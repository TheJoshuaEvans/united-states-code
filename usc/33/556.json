{"tag":"section","attrib":{"id":"id6b426f2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s556"},"text":null,"children":[{"tag":"num","attrib":{"value":"556"},"text":"§ 556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing reports generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army shall cause the manuscript of the annual report of the Chief of Engineers and subordinate engineers, relating to the improvement of rivers and harbors, and the report of the Mississippi River Commission to be placed in the hands of the Director of the Government Publishing Office on or before the 15th day of October in each year, and the Director of the Government Publishing Office shall cause said reports to be printed with an accurate and comprehensive index thereof, on or before the first Monday in December in each year, for the use of Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"All reports on examinations and surveys which may be prepared during the recess of Congress shall, in the discretion of the Secretary of the Army, be printed by the Director of the Government Publishing Office as documents of the following session of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b426f2c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-08-11/ch860/s8"},"text":"Aug. 11, 1888, ch. 860, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/424"},"text":"25 Stat. 424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1902-06-13/ch1079/s1"},"text":"June 13, 1902, ch. 1079, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/367"},"text":"32 Stat. 367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch144/s3"},"text":"Mar. 4, 1913, ch. 144, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/826"},"text":"37 Stat. 826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"July 26, 1947, ch. 343","children":[],"tail":", title II, § 205(a), "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b426f2d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b426f2e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b426f2f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first paragraph of this section is from act ","children":[{"tag":"date","attrib":{"date":"1888-08-11"},"text":"Aug. 11, 1888","children":[],"tail":", popularly known as the “Rivers and Harbors Appropriation Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Mississippi River Commission was created by act ","children":[{"tag":"date","attrib":{"date":"1879-06-28"},"text":"June 28, 1879","children":[],"tail":", set out as sections 641, 642, 644, 646, and 647 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and Missouri” which appeared in the original text after “Mississippi” were superseded by the abolition of the Missouri River Commission by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-13/ch1079/s1"},"text":"act June 13, 1902, ch. 1079, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/367"},"text":"32 Stat. 367","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second paragraph of this section is from the last paragraph of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", which superseded a similar provision of "},{"tag":"ref","attrib":{"href":"/us/act/1912-07-25/ch253"},"text":"act July 25, 1912, ch. 253","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/231"},"text":"37 Stat. 231","children":[],"tail":". Other parts of said section 3 are set out in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s545"},"text":"section 545 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b426f30-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b426f31-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Department of War designated Department of the Army and title of Secretary of War changed to Secretary of the Army by section 205(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/tII"},"text":"act July 26, 1947, ch. 343, title II","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". Section 205(a) of act "},{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":", was repealed by section 53 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/641"},"text":"70A Stat. 641","children":[],"tail":". Section 1 of act "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", enacted “Title 10, Armed Forces” which in sections 3010 to 3013 continued Department of the Army under administrative supervision of Secretary of the Army."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b426f32-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compilation and Printing of Laws","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch252/s6"},"text":"Act June 5, 1920, ch. 252, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1014"},"text":"41 Stat. 1014","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch467/s4"},"text":"act Mar. 3, 1925, ch. 467, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1190"},"text":"43 Stat. 1190","children":[],"tail":", provided for compilation and printing of laws relating to improvement of rivers and harbors, passed between "},{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", until and including laws of second session of Sixty-eighth Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
