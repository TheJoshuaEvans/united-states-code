{"tag":"section","attrib":{"id":"id6c5e18eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2342"},"text":null,"children":[{"tag":"num","attrib":{"value":"2342"},"text":"§ 2342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to water resource data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c5e18ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using available funds, the Secretary shall make publicly available, including on the Internet, all data in the custody of the Corps of Engineers on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c5e18ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning, design, construction, operation, and maintenance of water resources development projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c5e18ee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water quality and water management of projects owned, operated, or managed by the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e18ef-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to compel or authorize the disclosure of data or other information determined by the Secretary to be confidential information, privileged information, law enforcement information, national security information, infrastructure security information, personal information, or information the disclosure of which is otherwise prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e18f0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that data is made publicly available under subsection (a) as quickly as practicable after the data is generated by the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c5e18f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2342/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary may develop partnerships, including through cooperative agreements, with State, tribal, and local governments and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c5e18f2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tII/s2017"},"text":"Pub. L. 110–114, title II, § 2017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1077"},"text":"121 Stat. 1077","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1135"},"text":"Pub. L. 114–322, title I, § 1135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1656"},"text":"130 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5e18f3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5e18f4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5e18f5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2007, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c5e18f6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" amended section generally. Prior to amendment, section related to access to water resource data."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5e18f7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e18f8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Data Transparency","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tI/s158/b"},"text":"Pub. L. 116–260, div. AA, title I, § 158(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2662"},"text":"134 Stat. 2662","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dAA/tI/s158/b"},"text":"“The Secretary [of the Army] shall prioritize making publicly available water resources data in the custody of the Corps of Engineers, as authorized by section 2017 of the Water Resources Development Act of 2007 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2342"},"text":"33 U.S.C. 2342","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5e18f9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
