,"tail":", "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/66"},"text":"106 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a"},"text":"Pub. L. 105–160, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-03-06"},"text":"Mar. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/21"},"text":"112 Stat. 21","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/174/tIII/s10003"},"text":"Pub. L. 105–174, title III, § 10003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-05-01"},"text":"May 1, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/99"},"text":"112 Stat. 99","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/394"},"text":"Pub. L. 110–394","children":[],"tail":", §§ 4, 9(a)(4)(B), "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4206"},"text":"122 Stat. 4206","children":[],"tail":", 4208.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b937549-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b93754a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b93754b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1123"},"text":"Section 1123 of this title","children":[],"tail":", referred to in par. (2), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/105/160/s5"},"text":"Pub. L. 105–160, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-03-06"},"text":"Mar. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/22"},"text":"112 Stat. 22","children":[],"tail":", and, as so amended, provisions relating to appointment of the Director of the National Sea Grant College Program, which formerly appeared in subsec. (b), are contained in subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b93754c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s4/a/1"},"text":"Pub. L. 110–394, § 4(a)(1)","children":[],"tail":", inserted “management,” after “development,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s4/b"},"text":"Pub. L. 110–394, § 4(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/s307/a"},"text":"section 307(a) of Pub. L. 102–251","children":[],"tail":". See 1992 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s9/a/4/B"},"text":"Pub. L. 110–394, § 9(a)(4)(B)","children":[],"tail":", amended par. (9) generally. Prior to amendment, par. (9) read as follows: “The term ‘panel’ means the sea grant review panel established under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1128"},"text":"section 1128 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s4/a/2"},"text":"Pub. L. 110–394, § 4(a)(2)","children":[],"tail":", substituted “extension services” for “advisory services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (12), (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s4/a/3"},"text":"Pub. L. 110–394, § 4(a)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1126"},"text":"section 1126 of this title","children":[],"tail":"”, requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/1"},"text":"Pub. L. 105–160, § 4(a)(1)","children":[],"tail":", substituted “his or her” for “their university or” and “college or sea grant institute” for “college, programs, or regional consortium”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/2"},"text":"Pub. L. 105–160, § 4(a)(2)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “The term ‘field related to ocean, coastal, and Great Lakes resources’ means any discipline or field (including marine science (and the physical, natural, and biological sciences, and engineering, included therein), marine technology, education, marine affairs and resource management, economics, sociology, communications, planning, law, international affairs, and public administration) which is concerned with or likely to improve the understanding, assessment, development, utilization, or conservation of ocean, coastal, and Great Lakes resources.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/174/s10003/1"},"text":"Pub. L. 105–174, § 10003(1)","children":[],"tail":", redesignated par. (6) as (5) and struck out former par. (5) which read as follows: “The term ‘Great Lakes’ includes Lake Champlain.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/3"},"text":"Pub. L. 105–160, § 4(a)(3)","children":[],"tail":", added par. (5). Former par. (5) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/174/s10003/1"},"text":"Pub. L. 105–174, § 10003(1)","children":[],"tail":", redesignated par. (7) as (6). Former par. (6) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/3"},"text":"Pub. L. 105–160, § 4(a)(3)","children":[],"tail":", added par. (6). Former par. (6) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/174/s10003"},"text":"Pub. L. 105–174, § 10003","children":[],"tail":", redesignated par. (8) as (7), added subpar. (C), and redesignated former subpars. (C) to (F) as (D) to (G), respectively. Former par. (7) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/3"},"text":"Pub. L. 105–160, § 4(a)(3)","children":[],"tail":", redesignated par. (5) as (7). Former par. (7) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (8) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/174/s10003/1"},"text":"Pub. L. 105–174, § 10003(1)","children":[],"tail":", redesignated pars. (9) to (11) as (8) to (10), respectively. Former par. (8) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/3"},"text":"Pub. L. 105–160, § 4(a)(3)","children":[],"tail":", redesignated pars. (6) to (8) as (8) to (10), respectively. Former pars. (9) and (10) redesignated (11) and (12), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/174/s10003/1"},"text":"Pub. L. 105–174, § 10003(1)","children":[],"tail":", redesignated par. (12) as (11). Former par. (11) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/3"},"text":"Pub. L. 105–160, § 4(a)(3)","children":[],"tail":", (4), redesignated par. (9) as (11) and substituted “institute or other institution” for “regional consortium, institution of higher education, institute, or laboratory”. Former par. (11) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (12) to (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/174/s10003/1"},"text":"Pub. L. 105–174, § 10003(1)","children":[],"tail":", redesignated pars. (13) to (17) as (12) to (16), respectively. Former par. (12) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/5"},"text":"Pub. L. 105–160, § 4(a)(5)","children":[],"tail":", added pars. (12) to (17) and struck out former pars. (12) to (17) which defined “sea grant college”, “sea grant program”, “sea grant regional consortium”, “Secretary”, “State”, and “Under Secretary”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160/s4/a/3"},"text":"Pub. L. 105–160, § 4(a)(3)","children":[],"tail":", redesignated pars. (10) to (15) as (12) to (17), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (6)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251/s307/a"},"text":"Pub. L. 102–251, § 307(a)","children":[],"tail":", which directed addition of subpar. (F) and redesignation of former subpar. (F) as (G), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/394/s4/b"},"text":"section 4(b) of Pub. L. 110–394","children":[],"tail":". See Effective Date of 1992 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/186"},"text":"Pub. L. 102–186","children":[],"tail":" inserted “marine affairs and resource management,” after “education,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220/s3104/a/1"},"text":"Pub. L. 100–220, § 3104(a)(1)","children":[],"tail":", (2), added par. (3), redesignated former par. (3) as (2), and struck out former par. (2) which read as follows: “The term ‘Administrator’ means the Administrator of the National Oceanic and Atmospheric Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220/s3104/b/1/C"},"text":"Pub. L. 100–220, § 3104(b)(1)(C)","children":[],"tail":", substituted “ocean, coastal, and Great Lakes resources” for “ocean and coastal resources” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220/s3104/a/3"},"text":"Pub. L. 100–220, § 3104(a)(3)","children":[],"tail":", added par. (6) and struck out former par. (6) which read as follows: “The term ‘marine environment’ means the coastal zone, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453/1"},"text":"section 1453(1) of title 16","children":[],"tail":"; the seabed, subsoil, and waters of the Great Lakes and the territorial sea of the United States; the waters of any zone over which the United States asserts exclusive fishery management authority; the waters of the high seas; and the seabed and subsoil of and beyond the outer Continental Shelf.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220/s3104/a/3"},"text":"Pub. L. 100–220, § 3104(a)(3)","children":[],"tail":", added par. (7) and struck out former par. (7) which read as follows: “The term ‘ocean and coastal resource’ means any resource (whether living, nonliving, manmade, tangible, intangible, actual, or potential) which is located in, derived from, or traceable to, the marine environment. Such term includes the habitat of any such living resource, the coastal space, the ecosystems, the nutrient-rich areas, and the other components of the marine environment which contribute to or provide (or which are capable of contributing to or providing) recreational, scenic, esthetic, biological, habitational, commercial, economic, or conservation values. Living resources include natural and cultured plant life, fish, shellfish, marine mammals, and wildlife. Nonliving resources include energy sources, minerals, and chemical substances.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220/s3104/b/1/C"},"text":"Pub. L. 100–220, § 3104(b)(1)(C)","children":[],"tail":", substituted “ocean, coastal, and Great Lakes resources” for “ocean and coastal resources”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220/s3104/a/4"},"text":"Pub. L. 100–220, § 3104(a)(4)","children":[],"tail":", added par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/289"},"text":"Pub. L. 96–289","children":[],"tail":" extended term “marine environment” to include waters of Great Lakes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/428"},"text":"Pub. L. 95–428","children":[],"tail":" substituted “national sea grant college program” for “national sea grant program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/461"},"text":"Pub. L. 94–461","children":[],"tail":" substituted provisions defining terms used in this subchapter for provisions designating Secretary of Commerce as administering authority for national sea grant program and authorizing appropriations through fiscal 1976."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/73/s1/5"},"text":"Pub. L. 93–73, § 1(5)","children":[],"tail":", substituted “Secretary of Commerce” and “Secretary” for “National Science Foundation” and “Foundation”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/73/s1/1"},"text":"Pub. L. 93–73, § 1(1)","children":[],"tail":", (5), authorized appropriations of $30,000,000; $40,000,000; and $50,000,000 for fiscal years ending "},{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", 1975, and 1976, and substituted “Secretary” for “Foundation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/349"},"text":"Pub. L. 91–349","children":[],"tail":" authorized appropriations for fiscal year ending "},{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", not to exceed the sum of $20,000,000, for fiscal year ending "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", not to exceed the sum of $25,000,000, and for fiscal year ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", not to exceed the sum of $30,000,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/477"},"text":"Pub. L. 90–477","children":[],"tail":" authorized appropriations for fiscal year ending "},{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", not to exceed the sum of $6,000,000, and for fiscal year ending "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", not to exceed the sum of $15,000,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b93754d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":