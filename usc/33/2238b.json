{"tag":"section","attrib":{"id":"id6c3a6453-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2238b"},"text":"§ 2238b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for harbor maintenance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c3a6454-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3a6455-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total amount of harbor maintenance taxes received","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “total amount of harbor maintenance taxes received” means, with respect to a fiscal year, the aggregate of amounts appropriated, transferred, or credited to the Harbor Maintenance Trust Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505/a"},"text":"section 9505(a) of title 26","children":[],"tail":" for that fiscal year as set forth in the current year estimate provided in the President’s budget request for the subsequent fiscal year, submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3a6456-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total budget resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “total budget resources” means the total amount made available by appropriations Acts from the Harbor Maintenance Trust Fund for a fiscal year for making expenditures under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505/c"},"text":"section 9505(c) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3a6457-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3a6458-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), the target total budget resources made available to the Secretary from the Harbor Maintenance Trust Fund for a fiscal year shall be not less than the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c3a6459-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2015, 67 percent of the total amount of harbor maintenance taxes received in fiscal year 2014.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a645a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2016, 69 percent of the total amount of harbor maintenance taxes received in fiscal year 2015.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a645b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2017, 71 percent of the total amount of harbor maintenance taxes received in fiscal year 2016.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a645c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2018, 74 percent of the total amount of harbor maintenance taxes received in fiscal year 2017.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a645d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2019, 77 percent of the total amount of harbor maintenance taxes received in fiscal year 2018.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a645e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2020, 80 percent of the total amount of harbor maintenance taxes received in fiscal year 2019.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a645f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2021, 83 percent of the total amount of harbor maintenance taxes received in fiscal year 2020.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a6460-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2022, 87 percent of the total amount of harbor maintenance taxes received in fiscal year 2021.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a6461-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2023, 91 percent of the total amount of harbor maintenance taxes received in fiscal year 2022.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a6462-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2024, 95 percent of the total amount of harbor maintenance taxes received in fiscal year 2023.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c3a6463-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2025, and each fiscal year thereafter, 100 percent of the total amount of harbor maintenance taxes received in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3a6464-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total budget resources described in paragraph (1) may be used only for making expenditures under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9505/c"},"text":"section 9505(c) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3a6465-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the target total budget resources for a fiscal year described in subparagraphs (A) through (J) of subsection (b)(1) is lower than the target total budget resources for the previous fiscal year, the target total budget resources shall be adjusted to be equal to the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3a6466-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 103 percent of the total budget resources appropriated for the previous fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3a6467-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the total amount of harbor maintenance taxes received in the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c3a6468-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact on other funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c3a6469-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that any increase in funding for harbor maintenance programs under this section shall result from an overall increase in appropriations for the civil works program of the Corps of Engineers and not from reductions in the appropriations for other programs, projects, and activities carried out by the Corps of Engineers for other authorized purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c3a646a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2238b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The target total budget resources for a fiscal year specified in subsection (b)(1) shall only apply in a fiscal year for which the level of appropriations provided for the civil works program of the Corps of Engineers in that fiscal year is increased, as compared to the previous fiscal year, by a dollar amount that is at least equivalent to the dollar amount necessary to address such target total budget resources in that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c3a646b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tII/s2101"},"text":"Pub. L. 113–121, title II, § 2101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1272"},"text":"128 Stat. 1272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tI/s1108"},"text":"Pub. L. 114–322, title I, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1634"},"text":"130 Stat. 1634","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c3a646c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c3a646d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c3a646e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c3a646f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1108/1"},"text":"Pub. L. 114–322, § 1108(1)","children":[],"tail":", substituted “Except as provided in subsection (c), the target total” for “The target total” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/s1108/2"},"text":"Pub. L. 114–322, § 1108(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c3a6470-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c3a6471-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
