{"tag":"section","attrib":{"id":"id6bc581d8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wastewater efficiency grant pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc581d9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Administrator shall establish a wastewater efficiency grant pilot program (referred to in this section as the “pilot program”) to award grants to owners or operators of publicly owned treatment works to carry out projects that create or improve waste-to-energy systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc581da-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc581db-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under the pilot program, an owner or operator of a treatment works shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581dc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall select not more than 15 recipients of grants under the pilot program from applications submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc581dd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc581de-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a recipient of a grant under the pilot program may use grant funds for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc581df-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sludge collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581e0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installation of anaerobic digesters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581e1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methane capture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methane transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility upgrades and retrofits necessary to create or improve waste-to-energy systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581e4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other new and emerging, but proven, technologies that transform waste to energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581e5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant to a recipient under the pilot program shall be not more than $4,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc581e6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc581e7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to the Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after receiving a grant under the pilot program and each year thereafter for which amounts are made available for the pilot program under subsection (e), the recipient of the grant shall submit to the Administrator a report describing the impact of that project on the communities within 3 miles of the treatment works.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581e8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after first awarding grants under the pilot program and each year thereafter for which amounts are made available for the pilot program under subsection (e), the Administrator shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bc581e9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applications received by the Administrator for grants under the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bc581ea-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projects for which grants were awarded under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc581eb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc581ec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the pilot program $20,000,000 for each of fiscal years 2022 through 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc581ed-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1302/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc581ee-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50202"},"text":"Pub. L. 117–58, div. E, title II, § 50202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1158"},"text":"135 Stat. 1158","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
