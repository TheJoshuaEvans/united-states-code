{"tag":"section","attrib":{"id":"id6b720aa8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s857–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"857–15"},"text":"§ 857–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b720aa9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s857–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall submit an annual report to the President and to the Congress setting forth an assessment, on a selective basis, of the status of the Nation’s marine and atmospheric activities, and shall submit such other reports as may from time to time be requested by the President or the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b720aaa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s857–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each annual report shall also be submitted to the Secretary of Commerce, who shall, within 60 days after receipt thereof, transmit his or her comments and recommendations to the President and to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b720aab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s857–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report submittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual report required under subsection (a) shall be submitted on or before June 30 of each year, beginning with ","children":[{"tag":"date","attrib":{"date":"1978-06-30"},"text":"June 30, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b720aac-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/63/s4"},"text":"Pub. L. 95–63, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-05"},"text":"July 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/266"},"text":"91 Stat. 266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b720aad-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b720aae-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b720aaf-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A provision similar to that contained in this section, which required an annual report, beginning ","children":[{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", from the National Advisory Committee on Oceans and Atmosphere as originally established on "},{"tag":"date","attrib":{"date":"1971-08-16"},"text":"Aug. 16, 1971","children":[],"tail":", was contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s857–9"},"text":"section 857–9 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/63/s7/a"},"text":"section 7(a) of Pub. L. 95–63","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b720ab0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b720ab1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (a) of this section relating to submitting an annual report to Congress and provisions in subsec. (b) of this section relating to annually transmitting comments and recommendations to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and pages 50 and 177 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b720ab2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee 