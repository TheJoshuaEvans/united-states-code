{"tag":"section","attrib":{"id":"id6c5bcebd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2330d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2330d"},"text":"§ 2330d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public recreational amenities in ecosystem restoration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At the request of a non-Federal interest, the Secretary is authorized to study the incorporation of public recreational amenities, including facilities for hiking, biking, walking, and waterborne recreation, into a project for ecosystem restoration, including a project carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2330"},"text":"section 2330 of this title","children":[],"tail":", if the incorporation of such amenities would be consistent with the ecosystem restoration purposes of the project."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c5bcebe-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8105"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3699"},"text":"136 Stat. 3699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c5bcebf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c5bcec0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c5bcec1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2022, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c5bcec2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c5bcec3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8002"},"text":"section 8002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
