<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id6c86afa1-3a70-11f1-9100-cf79f4fb4b3e" identifier="/us/usc/t33/s3610"><num value="3610">§ 3610.</num><heading> Authorization of appropriations</heading>
<chapeau style="-uslm-lc:I11" class="indent0">There are authorized to be appropriated to the Secretary of Commerce to support the integrated oceans observations under this chapter—</chapeau><paragraph style="-uslm-lc:I12" class="indent1" id="id6c86afa2-3a70-11f1-9100-cf79f4fb4b3e" identifier="/us/usc/t33/s3610/1"><num value="1">(1)</num><content> $48,000,000 for fiscal year 2021;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id6c86afa3-3a70-11f1-9100-cf79f4fb4b3e" identifier="/us/usc/t33/s3610/2"><num value="2">(2)</num><content> $50,000,000 for fiscal year 2022;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id6c86afa4-3a70-11f1-9100-cf79f4fb4b3e" identifier="/us/usc/t33/s3610/3"><num value="3">(3)</num><content> $52,000,000 for fiscal year 2023;</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id6c86afa5-3a70-11f1-9100-cf79f4fb4b3e" identifier="/us/usc/t33/s3610/4"><num value="4">(4)</num><content> $54,000,000 for fiscal year 2024; and</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id6c891fa6-3a70-11f1-9100-cf79f4fb4b3e" identifier="/us/usc/t33/s3610/5"><num value="5">(5)</num><content> $56,000,000 for fiscal year 2025.</content>
</paragraph>
<sourceCredit id="id6c891fa7-3a70-11f1-9100-cf79f4fb4b3e">(<ref href="/us/pl/111/11/tXII/s12311">Pub. L. 111–11, title XII, § 12311</ref>, <date date="2009-03-30">Mar. 30, 2009</date>, <ref href="/us/stat/123/1436">123 Stat. 1436</ref>; <ref href="/us/pl/116/271/tI/s108">Pub. L. 116–271, title I, § 108</ref>, <date date="2020-12-31">Dec. 31, 2020</date>, <ref href="/us/stat/134/3341">134 Stat. 3341</ref>.)</sourceCredit>
