{"tag":"section","attrib":{"id":"id6b7ba77d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894d–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"894d–1"},"text":"§ 894d–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7ba77e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894d–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to investigate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7ba77f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894d–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, acting through the Under Secretary for Oceans and Atmosphere, shall ensure that each allegation of sexual harassment reported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s894"},"text":"section 894 of this title","children":[],"tail":" and each allegation of sexual assault reported under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s894a"},"text":"section 894a of this title","children":[],"tail":" is investigated thoroughly and promptly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7ba780-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894d–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on commencement of investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the Secretary should ensure that an investigation of alleged sexual harassment reported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s894"},"text":"section 894 of this title","children":[],"tail":" or sexual assault reported under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s894a"},"text":"section 894a of this title","children":[],"tail":" commences not later than 48 hours after the time at which the allegation was reported."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7ba781-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s894d–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of delay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the time between the reporting of alleged sexual harassment or sexual assault under section 894 or 894a of this title, respectively, and commencement of an investigation of the allegation exceeds 48 hours, the Secretary shall notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Natural Resources of the House of Representatives of the delay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b7ba782-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3546"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3546","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tV/s504/b/2"},"text":"Pub. L. 116–259, title V, § 504(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1180"},"text":"134 Stat. 1180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b7ba783-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b7ba784-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b7ba785-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3546"},"text":"section 3546 of Pub. L. 114–328","children":[],"tail":" was renumbered section 3548 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s894e"},"text":"section 894e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
