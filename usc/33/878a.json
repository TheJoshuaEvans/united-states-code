{"tag":"section","attrib":{"id":"id6b747c4f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a"},"text":null,"children":[{"tag":"num","attrib":{"value":"878a"},"text":"§ 878a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract for development of a major program; costs; Major Program Annual Report for satellite development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b747c50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b747c51-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Under Secretary” means Under Secretary of Commerce for Oceans and Atmosphere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c52-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b747c53-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c54-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Science, Space and Technology of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c55-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “satellite” means the satellites proposed to be acquired for the National Oceanic and Atmospheric Administration (NOAA);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c56-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “development” means the phase of a program following the formulation phase and beginning with the approval to proceed to implementation, as defined in NOAA Administrative Order 216–108, Department of Commerce Administrative Order 208–3, and NASA’s Procedural Requirements 7120.5c, dated ","children":[{"tag":"date","attrib":{"date":"2005-03-22"},"text":"March 22, 2005","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c57-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “development cost” means the total of all costs, including construction of facilities and civil servant costs, from the period beginning with the approval to proceed to implementation through the achievement of operational readiness, without regard to funding source or management control, for the life of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c58-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “life-cycle cost” means the total of the direct, indirect, recurring, and nonrecurring costs, including the construction of facilities and civil servant costs, and other related expenses incurred or estimated to be incurred in the design, development, verification, production, operation, maintenance, support, and retirement of a program over its planned lifespan, without regard to funding source or management control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c59-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “major program” means an activity approved to proceed to implementation that has an estimated life-cycle cost of more than $250,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c5a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “baseline” means the program as set following contract award and preliminary design review of the space and ground systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b747c5b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract requirements for major programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b747c5c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" NOAA shall not enter into a contract for development of a major program, unless the Under Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b747c5d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical, cost, and schedule risks of the program are clearly identified and the program has developed a plan to manage those risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c5e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technologies required for the program have been demonstrated in a relevant laboratory or test environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c5f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program complies with all relevant policies, regulations, and directives of NOAA and the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c60-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program has demonstrated a high likelihood of accomplishing its intended goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c61-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of satellites for use in the program represents a good value to accomplishing NOAA’s mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c62-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary shall transmit a report describing the basis for the determination required under paragraph (1) to the appropriate congressional committees at least 30 days before entering into a contract for development under a major program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c63-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary may not delegate the determination requirement under this subsection, except in cases in which the Under Secretary has a conflict of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b747c64-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b747c65-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annually, at the same time as the President’s annual budget submission to the Congress, the Under Secretary shall transmit to the appropriate congressional committees a report that includes the information required by this section for the satellite development program for which NOAA proposes to expend funds in the subsequent fiscal year. The report under this paragraph shall be known as the Major Program Annual Report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c66-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The first Major Program Annual Report for NOAA’s satellite development program shall include a Baseline Report that shall, at a minimum, include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b747c67-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes of the program and key technical characteristics necessary to fulfill those purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c68-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the life-cycle cost for the program, with a detailed breakout of the development cost, program reserves, and an estimate of the annual costs until development is completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c69-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the schedule for development, including key program milestones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c6a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan for mitigating technical, cost, and schedule risks identified in accordance with subsection (b)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c6b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the person responsible for making notifications under subsection (d), who shall be an individual whose primary responsibility is overseeing the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c6c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the major program for which a Baseline Report has been submitted, subsequent Major Program Annual Reports shall describe any changes to the information that had been provided in the Baseline Report, and the reasons for those changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b747c6d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Under Secretary of excess development costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b747c6e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual identified under subsection (c)(2)(E) shall immediately notify the Under Secretary any time that individual has reasonable cause to believe that, for the major program for which he or she is responsible, the development cost of the program has exceeded the estimate provided in the Baseline Report of the program by 20 percent or more.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c6f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the notification required under paragraph (1), the individual identified under subsection (c)(2)(E) shall transmit to the Under Secretary a written notification explaining the reasons for the change in the cost of the program for which notification was provided under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c70-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 15 days after the Under Secretary receives a written notification under paragraph (2), the Under Secretary shall transmit the notification to the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b747c71-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Under Secretary of excess development costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after receiving a written notification under subsection (d)(2), the Under Secretary shall determine whether the development cost of the program has exceeded the estimate provided in the Baseline Report of the program by 20 percent or more. If the determination is affirmative, the Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b747c72-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transmit to the appropriate congressional committees, not later than 15 days after making the determination, a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b747c73-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the increase in cost and a detailed explanation for the increase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c74-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of actions taken or proposed to be taken in response to the cost increase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any impacts the cost increase, or the actions described under subparagraph (B), will have on any other program within NOAA; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b747c76-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Under Secretary intends to continue with the program, promptly initiate an analysis of the program, which shall include, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b747c77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected cost and schedule for completing the program if current requirements of the program are not modified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected cost and the schedule for completing the program after instituting the actions described under paragraph (1)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b747c79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of, and the projected cost and schedule for, a broad range of alternatives to the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b747c7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s878a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion and transmittal of analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"NOAA shall complete an analysis initiated under subsection (e)(2) not later than 6 months after the Under Secretary makes a determination under subsection (e). The Under Secretary shall transmit the analysis to the appropriate congressional committees not later than 30 days after its completion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b747c7b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/55/dB/tI/s105"},"text":"Pub. L. 112–55, div. B, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"Nov. 18, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/599"},"text":"125 Stat. 599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/6/dB/tI/s105/a"},"text":"Pub. L. 113–6, div. B, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-26"},"text":"Mar. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/242"},"text":"127 Stat. 242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b747c7c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b747c7d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b747c7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Commerce, Justice, Science, and Related Agencies Appropriations Act, 2012, which is division B of the Consolidated and Further Continuing Appropriations Act, 2012.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b747c7f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dB/tI/s112"},"text":"Pub. L. 110–161, div. B, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1894"},"text":"121 Stat. 1894","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b747c80-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/6"},"text":"Pub. L. 113–6","children":[],"tail":" substituted “subsection (e)(2)” for “paragraph (2)” and “subsection (e)” for “this subsection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b747c81-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b747c82-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirements Adopted by Reference","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dA/tI