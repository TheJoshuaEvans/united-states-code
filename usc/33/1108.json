{"tag":"section","attrib":{"id":"id6b910509-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1108"},"text":null,"children":[{"tag":"num","attrib":{"value":"1108"},"text":"§ 1108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out this subchapter, but sums appropriated for any one fiscal year shall not exceed $1,200,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b91050a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tI/s9"},"text":"Pub. L. 89–454, title I, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-06-17"},"text":"June 17, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/208"},"text":"80 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/688/s2/b"},"text":"Pub. L. 89–688, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1001"},"text":"80 Stat. 1001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/15/s2"},"text":"Pub. L. 91–15, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-05-23"},"text":"May 23, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/10"},"text":"83 Stat. 10","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b91050b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b91050c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b91050d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/15"},"text":"Pub. L. 91–15","children":[],"tail":" substituted “$1,200,000” for “$1,500,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/688"},"text":"Pub. L. 89–688","children":[],"tail":" substituted “this title” for “this Act”, which, for purposes of codification, has been changed to “this subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
