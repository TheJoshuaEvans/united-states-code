{"tag":"section","attrib":{"id":"id6c97518d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4281"},"text":null,"children":[{"tag":"num","attrib":{"value":"4281"},"text":"§ 4281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy for improving post-consumer materials management and water management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c97518e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-18"},"text":"December 18, 2020","children":[],"tail":", the EPA Administrator shall, in consultation with stakeholders, develop a strategy to improve post-consumer materials management and infrastructure for the purpose of reducing plastic waste and other post-consumer materials in waterways and oceans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c97518f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On development of the strategy under subsection (a), the EPA Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c975190-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribute the strategy to States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975191-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make the strategy publicly available, including for use by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c975192-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4281/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for-profit private entities involved in post-consumer materials management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975193-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4281/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other nongovernmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c975194-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224/tIII/s301"},"text":"Pub. L. 116–224, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1092"},"text":"134 Stat. 1092","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
