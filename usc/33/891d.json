{"tag":"section","attrib":{"id":"id6b76c61c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d"},"text":null,"children":[{"tag":"num","attrib":{"value":"891d"},"text":"§ 891d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b76c61d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b76c61e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341"},"text":"section 1341 of title 31","children":[],"tail":" and subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6301"},"text":"section 6301 of title 41","children":[],"tail":", the Secretary may acquire vessels for the NOAA fleet by purchase, lease, lease-purchase, or otherwise, under one or more multiyear contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c61f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into a contract pursuant to this subsection unless the Secretary finds with respect to that contract that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b76c620-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reasonable expectation that throughout the contemplated contract period the Secretary will request from Congress funding for the contract at the level required to avoid contract termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c621-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the contract will promote the best interests of the United States by encouraging competition and promoting economic efficiency in the operation of the NOAA fleet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c622-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required contract provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not enter into a contract pursuant to this subsection unless the contract includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b76c623-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision under which the obligation of the United States to make payments under the contract for any fiscal year is subject to the availability of appropriations provided in advance for those payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c624-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provision that specifies the term of effectiveness of the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c625-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appropriate provisions under which, in case of any termination of the contract before the end of the term specified pursuant to subparagraph (B), the United States shall only be liable for the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b76c626-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount specified in the contract for such a termination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b76c627-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" amounts that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6b76c628-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were appropriated before the date of the termination for the performance of the contract or for procurement of the type of acquisition covered by the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6b76c629-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/a/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are unobligated on the date of the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b76c62a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may enter into multiyear contracts for oceanographic research, fisheries research, and mapping and charting services to assist the Secretary in fulfilling NOAA missions. The Secretary may only enter into these contracts if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b76c62b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary finds that it is in the public interest to do so;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c62c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract is for not more than 7 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b76c62d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b76c62e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the contract is less than the cost (including the cost of operation, maintenance, and personnel) to the NOAA of obtaining those services on NOAA vessels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b76c62f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NOAA vessels are not available or cannot provide those services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b76c630-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s891d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonding authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, the Secretary may not require a contractor for the construction, alteration, repair or maintenance of a NOAA vessel to provide a bid bond, payment bond, performance bond, completion bond, or other surety instrument in an amount greater than 20 percent of the value of the base contract quantity (excluding options) unless the Secretary determines that requiring an instrument in that amount will not prevent a responsible bidder or offeror from competing for the award of the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b76c631-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tVI/s606"},"text":"Pub. L. 102–567, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4301"},"text":"106 Stat. 4301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b76c632-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b76c633-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b76c634-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1), “subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6301"},"text":"section 6301 of title 41","children":[],"tail":"” substituted for “section 3732 of the Revised Statutes of the United States ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s11"},"text":"41 U.S.C. 11","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
