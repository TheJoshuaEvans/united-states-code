{"tag":"section","attrib":{"id":"id6b6623e2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s702a–1b"},"text":null,"children":[{"tag":"num","attrib":{"value":"702a–1b"},"text":"§ 702a–1b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further modification; adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The project for flood control of the Lower Mississippi River adopted by sections 642a, 702a to 702a–1a, 702a–2 to 702d, and 702e to 702h, 702i to 702m, and 704 of this title is modified and, as modified, is authorized and adopted.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b6623e3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-08-18/ch377/s3"},"text":"Aug. 18, 1941, ch. 377, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/642"},"text":"55 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b6623e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b6623e5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b6623e6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 702a–1¾ of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
