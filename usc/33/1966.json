{"tag":"section","attrib":{"id":"id6c275114-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1966"},"text":null,"children":[{"tag":"num","attrib":{"value":"1966"},"text":"§ 1966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report requirements; petition of Attorney General for equitable relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c275115-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1966/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall, as soon as practicable after the end of each fiscal year, transmit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Natural Resources, the Committee on Transportation and Infrastructure, and the Committee on Energy and Commerce of the House of Representatives a report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c275116-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1966/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the proceedings and activities of the Foundation during that fiscal year, including a full and complete statement of its receipts, expenditures, and investments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c275117-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1966/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including a detailed statement of the recipient, amount, and purpose of each grant made by the Foundation in the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c275118-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1966/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief with respect to certain Foundation acts or failure to act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c275119-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1966/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in, or threatens to engage in, any act, practice, or policy that is inconsistent with its purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1961/b"},"text":"section 1961(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c27511a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1966/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses, fails, or neglects to discharge its obligations under this title,","children":[{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or threatens to do so,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Attorney General may petition in the United States District Court for the District of Columbia for such equitable relief as may be necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c27511b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/449/s116"},"text":"Pub. L. 109–449, § 116","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/116/224/tI/s116"},"text":"Pub. L. 116–224, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1079"},"text":"134 Stat. 1079","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/449/s116"},"text":"Pub. L. 109–449, § 116","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/119/65/s3/a"},"text":"Pub. L. 119–65, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-26"},"text":"Dec. 26, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1987"},"text":"139 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c27511c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c27511d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c27511e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (b)(2), means title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"text":"Pub. L. 116–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1074"},"text":"134 Stat. 1074","children":[],"tail":", which was classified principally to subchapter I (§ 4211 et seq.) of chapter 55 of this title. Subtitles B and C of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/116/224"},"tex