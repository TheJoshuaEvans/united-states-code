{"tag":"section","attrib":{"id":"id6b045495-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"§ 8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Toll free rivers in Alabama","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Tennessee, Coosa, Cahawba, and Black Warrior Rivers, within the State of Alabama, shall be forever free from toll for all property belonging to the United States, and for all persons in their service, and for all citizens of the United States, except as to such tolls as may be allowed by Act of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b045496-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 5244.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b045497-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b045498-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b045499-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5244 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1828-05-23/ch75/s7"},"text":"act May 23, 1828, ch. 75, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/290"},"text":"4 Stat. 290","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another R.S. 5244 is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s43"},"text":"section 43 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"t