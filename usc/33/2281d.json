{"tag":"section","attrib":{"id":"id6c464a2f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2281d"},"text":"§ 2281d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c464a30-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States for the Corps of Engineers, consistent with applicable statutory authorities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464a31-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize opportunities for water supply, water conservation measures, and drought resiliency efforts at and in the operation of water resources development projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464a32-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390b"},"text":"section 390b of title 43","children":[],"tail":", to participate and cooperate with States and local interests in developing water supplies for domestic, municipal, industrial, and other purposes in authorized connection with the construction, maintenance, and operation of water resources development projects; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464a33-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with non-Federal interests, to enable the adoption of water conservation measures and drought resiliency measures that are in alignment with the authorized purposes of water resources development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c464a34-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In support of subsection (a), the Secretary shall give full consideration to requests and proposals from non-Federal interests to utilize the authorities of the Corps of Engineers in furtherance of water supply features, water conservation measures, and drought resiliency efforts that are in alignment the authorized purposes of water resources development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c464a35-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c464a36-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" affects, modifies, or changes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c464a37-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of a State to manage, use, or allocate the water resources of that State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464a38-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any water right in existence on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464a39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing water supply agreements between the Secretary and the non-Federal interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464a3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorized purposes of a water resources development project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c464a3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing Corps of Engineers authorities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464a3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preempts or affects any State water law or interstate compact governing water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464a3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diminishes the other priorities and the primary or secondary missions of the Corps of Engineers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c464a3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2281d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be interpreted to supersede or modify any written agreement between the Federal Government and a non-Federal interest that is in effect on ","children":[{"tag":"date","attrib":{"date":"2025-01-04"},"text":"January 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c464a3f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/tI/s1161"},"text":"Pub. L. 118–272, div. A, title I, § 1161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3046"},"text":"138 Stat. 3046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c464a40-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c464a41-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c464a42-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Grace F. Napolitano Priority for Water Supply, Water Conservation, and Drought Resiliency Act of 2024 and also as part of the Water Resources Development Act of 2024 and the Thomas R. Carper Water Resources Development Act of 2024, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c464a43-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c464a44-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/dA/s1002"},"text":"section 1002 of div. A of Pub. L. 118–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
