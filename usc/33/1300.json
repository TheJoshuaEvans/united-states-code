{"tag":"section","attrib":{"id":"id6bc5818e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300"},"text":null,"children":[{"tag":"num","attrib":{"value":"1300"},"text":"§ 1300.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program for alternative water source projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bc5818f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251/g"},"text":"section 1251(g) of this title","children":[],"tail":" and all of the provisions of this section shall be carried out in accordance with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251/g"},"text":"section 1251(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58190-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc58191-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative water source project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “alternative water source project” means a project designed to provide municipal, industrial, and agricultural water supplies in an environmentally sustainable manner by conserving, managing, reclaiming, or reusing water, wastewater, or stormwater or by treating wastewater or stormwater for groundwater recharge, potable reuse, or other purposes. Such term does not include water treatment or distribution facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58192-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical water supply needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical water supply needs” means existing or reasonably anticipated future water supply needs that cannot be met by existing water supplies, as identified in a comprehensive statewide or regional water supply plan or assessment projected over a planning period of at least 20 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58193-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may establish a pilot program to make grants to State, interstate, and intrastate water resource development agencies (including water management districts and water supply authorities), local government agencies, private utilities, and nonprofit entities for alternative water source projects to meet critical water supply needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58194-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make grants under this section to an entity only if the entity has authority under State law to develop or provide water for municipal, industrial, and agricultural uses in an area of the State that is experiencing critical water supply needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58195-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc58196-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project that has received construction funds under the reclamation and reuse program conducted under the Reclamation Projects Authorization and Adjustment Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s390h"},"text":"43 U.S.C. 390h","children":[],"tail":" et seq.) shall not be eligible for grant assistance under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc58197-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographical distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Alternative water source projects selected by the Administrator under this section shall reflect a variety of geographical and environmental conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58198-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts from grants received under this section may be used for engineering, design, construction, and final testing of alternative water source projects designed to meet critical water supply needs. Such amounts may not be used for planning, feasibility studies or for operation, maintenance, replacement, repair, or rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc58199-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the eligible costs of an alternative water source project carried out using assistance made available under this section shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc5819a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On or before ","children":[{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":", the Administrator shall transmit to Congress a report on the results of the pilot program established under this section, including progress made toward meeting the critical water supply needs of the participants in the pilot program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bc5819b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bc5819c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $25,000,000 for each of fiscal years 2022 through 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bc5819d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1300/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available for grants under paragraph (1), not more than 2 percent may be used to pay the administrative costs of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bc5819e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch758"},"text":"June 30, 1948, ch. 758","children":[],"tail":", title II, § 220, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/457/tVI/s602"},"text":"Pub. L. 106–457, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1975"},"text":"114 Stat. 1975","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tII/s50203"},"text":"Pub. L. 117–58, div. E, title II, § 50203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1159"},"text":"135 Stat. 1159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bc5819f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bc581a0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6bc581a1-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Reclamation Projects Authorization and Adjustment Act of 1992, referred to in subsec. (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/575"},"text":"Pub. L. 102–575","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-30"},"text":"Oct. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4600"},"text":"106 Stat. 4600","children":[],"tail":". Provisions relating to the reclamation and reuse program are classified generally to section 390h et seq. of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title of 1992 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s371"},"text":"section 371 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6bc581a2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/6"},"text":"Pub. L. 117–58, § 50203(6)","children":[],"tail":", redesignated subsec. (i) as (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/1"},"text":"Pub. L. 117–58, § 50203(1)","children":[],"tail":", substituted “Establishment” for “In general” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/6"},"text":"Pub. L. 117–58, § 50203(6)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/6"},"text":"Pub. L. 117–58, § 50203(6)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/2/A"},"text":"Pub. L. 117–58, § 50203(2)(A)","children":[],"tail":", inserted “construction” before “funds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/2/B"},"text":"Pub. L. 117–58, § 50203(2)(B)","children":[],"tail":", (C), redesignated par. (3) as (2) and struck out former par. (2) which related to additional consideration regarding the location of a project."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/6"},"text":"Pub. L. 117–58, § 50203(6)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/3"},"text":"Pub. L. 117–58, § 50203(3)","children":[],"tail":", struck out subsec. (e) which related to committee resolution procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/6"},"text":"Pub. L. 117–58, § 50203(6)","children":[],"tail":", redesignated subsec. (j) as (i). Former subsec. (i) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/4/A"},"text":"Pub. L. 117–58, § 50203(4)(A)","children":[],"tail":", struck out “, the following definitions apply” before the semicolon in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/4/B"},"text":"Pub. L. 117–58, § 50203(4)(B)","children":[],"tail":", substituted “water, wastewater, or stormwater or by treating wastewater or stormwater for groundwater recharge, potable reuse, or other purposes” for “water or wastewater or by treating wastewater”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/6"},"text":"Pub. L. 117–58, § 50203(6)","children":[],"tail":", redesignated subsec. (j) as (i). Former subsec. (i) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s50203/5"},"text":"Pub. L. 117–58, § 50203(5)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “$25,000,000 for each of fiscal years 2022 through 2026, to” for “a total of $75,000,000 for fiscal years 2002 through 2004. Such sums shall”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
