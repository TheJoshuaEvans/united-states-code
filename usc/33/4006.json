{"tag":"section","attrib":{"id":"id6c950753-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4006"},"text":null,"children":[{"tag":"num","attrib":{"value":"4006"},"text":"§ 4006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of States’ rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c950754-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be interpreted to adversely affect existing State regulatory or enforcement power which has been granted to any State through the Clean Water Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1251"},"text":"33 U.S.C. 1251","children":[],"tail":" et seq.] or Coastal Zone Management Act of 1972 ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1451"},"text":"16 U.S.C. 1451","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c950755-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be interpreted to expand the regulatory or enforcement power of the Federal Government which has been delegated to any State through the Clean Water Act or Coastal Zone Management Act of 1972.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c950756-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tVI/s607"},"text":"Pub. L. 105–383, title VI, § 607","children":[],"tail":", formerly § 606, "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3450"},"text":"112 Stat. 3450","children":[],"tail":"; renumbere