{"tag":"section","attrib":{"id":"id6c7ac820-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3079b"},"text":"§ 3079b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shore leave for professional mariners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7ac821-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may prescribe regulations relating to shore leave for professional mariners without regard to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6305"},"text":"section 6305 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac822-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7ac823-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a professional mariner serving aboard an ocean-going vessel be granted a leave of absence of 4 days per pay period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7ac824-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that a professional mariner serving in a temporary promotion position aboard a vessel may be paid the difference between such mariner’s temporary and permanent rates of pay for leave accrued while serving in the temporary promotion position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7ac825-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3079b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional mariner defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “professional mariner” means an individual employed on a vessel of the Administration who has the necessary expertise to serve in the engineering, deck, steward, electronic technician, or survey department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7ac826-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s269B"},"text":"Pub. L. 107–372, title II, § 269B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVII/s11706/a"},"text":"Pub. L. 117–263, div. K, title CXVII, § 11706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4157"},"text":"136 Stat. 4157","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
