{"tag":"section","attrib":{"id":"id6b04549a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"§ 9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Des Moines River as toll free","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Des Moines River shall forever remain free from any toll, or other charge whatever, for any property of the United States, or persons in their service, passing along the same.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b04549b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 5246.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b04549c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b04549d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b04549e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 5246 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1846-08-08/ch103/s3"},"text":"Aug. 8, 1846, ch. 103, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/9/78"},"text":"9 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1870-01-20/ch7"},"text":"Jan. 20, 1870, ch. 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/16/61"},"text":"16 Stat. 61","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
