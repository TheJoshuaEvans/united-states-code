{"tag":"section","attrib":{"id":"id6c904c36-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913"},"text":null,"children":[{"tag":"num","attrib":{"value":"3913"},"text":"§ 3913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on program implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c904c37-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after each fiscal year for which amounts are made available to carry out this chapter, the Secretary and the Administrator shall publish on a dedicated, publicly accessible Internet site—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904c38-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each application received for assistance under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c39-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of the projects selected for assistance under this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904c3a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c3b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of financial assistance provided for each project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c3c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the selection of each project with respect to the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c904c3d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c904c3e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":", the Comptroller General of the United States shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report summarizing for the projects that are receiving, or have received, assistance under this chapter—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904c3f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applications received for assistance under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c40-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projects selected for assistance under this chapter, including a description of the projects and the basis for the selection of those projects with respect to the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c41-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type and amount of financial assistance provided for each project selected for assistance under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c42-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial performance of each project selected for assistance under this chapter, including an evaluation of whether the objectives of this chapter are being met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c43-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits and impacts of implementation of this chapter, including the public benefit provided by the projects selected for assistance under this chapter, including, as applicable, water quality and water quantity improvement, the protection of drinking water, and the reduction of flood risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c44-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the feasibility of attracting non-Federal public or private financing for water infrastructure projects as a result of the implementation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c904c45-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c904c46-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the impacts (if any) of the limitation under section 3907(a)(5) ","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title on the ability of eligible entities to finance water infrastructure projects under this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c904c47-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a recommendation as to whether the objectives of this chapter would be best served—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c904c48-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by continuing the authority of the Secretary or the Administrator, as applicable, to provide assistance under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904c49-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by establishing a Government corporation or Government-sponsored enterprise to provide assistance in accordance with this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c904c4a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by terminating the authority of the Secretary and the Administrator under this chapter and relying on the capital markets to fund the types of infrastructure investments assisted by this chapter without Federal participation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c92963b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3913/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proposed changes to improve the efficiency and effectiveness of this chapter in providing financing for water infrastructure projects, taking into consideration the recommendations made under subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c92963c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tV/s5034"},"text":"Pub. L. 113–121, title V, § 5034","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1343"},"text":"128 Stat. 1343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4201/d"},"text":"Pub. L. 115–270, title IV, § 4201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3880"},"text":"132 Stat. 3880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c92963d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c92963e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c92963f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3907/a/5"},"text":"Section 3907(a)(5) of this title","children":[],"tail":", referred to in subsec. (b)(2)(A), was struck out, and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3907/a/6"},"text":"section 3907(a)(6) of this title","children":[],"tail":" was redesignated as 3907(a)(5), by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1445"},"text":"Pub. L. 114–94, div. A, title I, § 1445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1437"},"text":"129 Stat. 1437","children":[],"tail":". As amended, section 3907(a)(5) no longer relates to limitation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c929640-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/d/1"},"text":"Pub. L. 115–270, § 4201(d)(1)","children":[],"tail":", struck out “pilot” before “program” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/270/s4201/d/2"},"text":"Pub. L. 115–270, § 4201(d)(2)","children":[],"tail":", substituted “3 years after "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"October 23, 2018","children":[],"tail":"” for “4 years after "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":"” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c929641-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c929642-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
