{"tag":"section","attrib":{"id":"id6b31a5e3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s467c"},"text":null,"children":[{"tag":"num","attrib":{"value":"467c"},"text":"§ 467c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of danger to human life and property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of determining whether a dam (including the waters impounded by such dam) constitutes a danger to human life or property, the Secretary shall take into consideration the possibility that the dam might be endangered by overtopping, seepage, settlement, erosion, sediment, cracking, earth movement, earthquakes, failure of bulkheads, flashboard, gates on conduits, or other conditions which exist or which might occur in any area in the vicinity of the dam.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b31a5e4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s5"},"text":"Pub. L. 92–367, § 5","children":[],"tail":", formerly § 4, "},{"tag":"date","attrib":{"date":"1972-08-08"},"text":"Aug. 8, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/507"},"text":"86 Stat. 507","children":[],"tail":"; renumbered § 5 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/303/tII/s215/c/3"},"text":"Pub. L. 104–303, title II, § 215(c)(3)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3685"},"text":"110 Stat. 3685","children":[],"tail":", 3687.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b31a5e5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b31a5e6-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b31a5e7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/367/s5"},"text":"section 5 of Pub. L. 92–367","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s467d"},"text":"section 467d of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b31a5e8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/303"},"text":"Pub. L. 104–303","children":[],"tail":" inserted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
