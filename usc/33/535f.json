{"tag":"section","attrib":{"id":"id6b3d8d75-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s535f"},"text":null,"children":[{"tag":"num","attrib":{"value":"535f"},"text":"§ 535f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall apply to all international bridges constructed under the authority of this subchapter. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s535a"},"text":"Section 535a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s129/a/3"},"text":"section 129(a)(3) of title 23","children":[],"tail":", shall apply to all international bridges the construction of which has been heretofore approved by Congress, notwithstanding any conflicting provision in any Act authorizing the construction of such a bridge or in any agreement entered into by the Federal Government and a State."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b3d8d76-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/434/s9"},"text":"Pub. L. 92–434, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-26"},"text":"Sept. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/733"},"text":"86 Stat. 733","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
