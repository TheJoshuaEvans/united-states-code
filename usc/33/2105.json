{"tag":"section","attrib":{"id":"id6c29c258-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2105"},"text":null,"children":[{"tag":"num","attrib":{"value":"2105"},"text":"§ 2105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c29c259-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2105/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “artificial reef” means a structure which is constructed or placed in waters covered under this chapter for the purpose of enhancing fishery resources and commercial and recreational fishing opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c25a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2105/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State of the United States, the District of Columbia, Puerto Rico, the United States Virgin Islands, American Samoa, Guam, Johnston Island, Midway Island, and Wake Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c29c25b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2105/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “waters covered under this chapter” means the navigable waters of the United States and the waters superjacent to the Outer Continental Shelf as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of title 43","children":[],"tail":", to the extent such waters exist in or are adjacent to any State."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c29c25c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623/tII/s206"},"text":"Pub. L. 98–623, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3397"},"text":"98 Stat. 3397","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
