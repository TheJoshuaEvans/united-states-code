{"tag":"section","attrib":{"id":"id6c65444d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605"},"text":null,"children":[{"tag":"num","attrib":{"value":"2605"},"text":"§ 2605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c65444e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation shall enforce this chapter under section 89 ","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14. The Secretary may authorize other officers or employees of the United States Government to enforce this chapter under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65444f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic examinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct periodic examinations of vessels operating under this chapter transporting municipal or commercial waste to determine that each of these vessels has a permit issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2602"},"text":"section 2602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654450-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal of clearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may refuse the clearance required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":", to any vessel subject to this chapter which does not have a permit required under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2602"},"text":"section 2602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654451-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of entry and detention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a vessel does not comply with this chapter, the Secretary of Transportation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c654452-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny entry to any place in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c654453-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detain at the place in the United States from which it is about to depart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c654454-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2605/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persistent violators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall conduct an investigation of the owner or operator of a vessel or facility if the owner has 5 or more separate violations during a 6-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c654455-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4105"},"text":"Pub. L. 100–688, title IV, § 4105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4157"},"text":"102 Stat. 4157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c654456-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c654457-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c654458-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s89"},"text":"Section 89 of title 14","children":[],"tail":", referred to in subsec. (a), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s522"},"text":"section 522 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s105/b"},"text":"Pub. L. 115–282, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4200"},"text":"132 Stat. 4200","children":[],"tail":", and reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s89"},"text":"section 89 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Sections of Title 14 as Redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c654459-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":"” substituted for “section 4197 of the Revised Statutes of the United States (46 App. U.S.C. 91)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/c"},"text":"Pub. L. 109–304, § 18(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":", which Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of Title 46","children":[],"tail":", Shipping."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
