{"tag":"section","attrib":{"id":"id6c8dda77-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3821"},"text":null,"children":[{"tag":"num","attrib":{"value":"3821"},"text":"§ 3821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c8dda78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On entry into force of the Convention for the United States, any vessel of at least 400 gross tons that engages in one or more international voyages (except fixed or floating platforms, FSUs, and FPSOs) shall carry an International Antifouling System Certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8dda79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of Certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On entry into force of the Convention, on a finding that a successful survey required by the Convention has been completed, a vessel of at least 400 gross tons that engages in at least one international voyage (except fixed or floating platforms, FSUs, and FPSOs) shall be issued an International Antifouling System Certificate. The Secretary may issue the Certificate required by this section. The Secretary may delegate this authority to an organization that the Secretary determines is qualified to undertake that responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8dda7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of Certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Certificate required by this section shall be maintained as required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8dda7b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3821/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates issued by other party countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Certificate issued by any country that is a party to the Convention has the same validity as a Certificate issued by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c8dda7c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3821/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels of nonparty countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), a vessel of at least 400 gross tons, having the nationality of or entitled to fly the flag of a country that is not a party to the Convention, may demonstrate compliance with this chapter through other appropriate documentation considered acceptable by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c8dda7d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tX/s1021"},"text":"Pub. L. 111–281, title X, § 1021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3025"},"text":"124 Stat. 3025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c8dda7e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c8dda7f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c8dda80-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e), was in the original “this title”, meaning title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3023"},"text":"124 Stat. 3023","children":[],"tail":", which enacted this chapter and repealed chapter 37 (§ 2401 et seq.) of this title. For complete classification of title X to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
