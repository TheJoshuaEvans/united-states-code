{"tag":"section","attrib":{"id":"id6bb26fa5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271"},"text":null,"children":[{"tag":"num","attrib":{"value":"1271"},"text":"§ 1271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sediment survey and monitoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6bb26fa6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb26fa7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in consultation with the Administrator of the National Oceanic and Atmospheric Administration and the Secretary, shall conduct a comprehensive national survey of data regarding aquatic sediment quality in the United States. The Administrator shall compile all existing information on the quantity, chemical and physical composition, and geographic location of pollutants in aquatic sediment, including the probable source of such pollutants and identification of those sediments which are contaminated pursuant to section 501(b)(4).","children":[{"tag":"ref","attrib":{"idref":"fn002056"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002056"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb26fa8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-31"},"text":"October 31, 1992","children":[],"tail":", the Administrator shall report to the Congress the findings, conclusions, and recommendations of such survey, including recommendations for actions necessary to prevent contamination of aquatic sediments and to control sources of contamination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6bb26fa9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6bb26faa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Administrator of the National Oceanic and Atmospheric Administration and the Secretary, shall conduct a comprehensive and continuing program to assess aquatic sediment quality. The program conducted pursuant to this subsection shall, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6bb26fab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the location of pollutants in aquatic sediment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb26fac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the extent of pollutants in sediment and those sediments which are contaminated pursuant to section 501(b)(4); ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb26fad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish methods and protocols for monitoring the physical, chemical, and biological effects of pollutants in aquatic sediment and of contaminated sediment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb26fae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a system for the management, storage, and dissemination of data concerning aquatic sediment quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb26faf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assessment of aquatic sediment quality trends over time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb26fb0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify locations where pollutants in sediment may pose a threat to the quality of drinking water supplies, fisheries resources, and marine habitats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6bb26fb1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a clearing house for information on technology, methods, and practices available for the remediation, decontamination, and control of sediment contamination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6bb26fb2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1271/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall submit to Congress a report on the findings of the monitoring under paragraph (1) on the date that is 2 years after the date specified in subsection (a)(2) and biennially thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6bb26fb3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/tV/s503"},"text":"Pub. L. 102–580, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4865"},"text":"106 Stat. 4865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6bb26fb4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6bb26fb5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6bb26fb6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(b)(4), referred to in subsecs. (a)(1) and (b)(1)(B), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/s501/b/4"},"text":"section 501(b)(4) of Pub. L. 102–580","children":[],"tail":", which is set out below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6bb26fb7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 1992 and also as part of the National Contaminated Sediment Assessment and Management Act, and not as part of the Federal Water Pollution Control Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6bb26fb8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6bb26fb9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Contaminated Sediments Information","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/tIII/s327"},"text":"Pub. L. 102–580, title III, § 327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4851"},"text":"106 Stat. 4851","children":[],"tail":", directed Secretary to conduct national study on information that was currently available on contaminated sediments of surface waters of United States and compile information obtained for the purpose of identifying location and nature of contaminated sediments and, not later than 1 year after "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", to transmit to Congress a report on the results of the study."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6bb26fba-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Contaminated Sediment Assessment and Management; Short Title; Definitions; Task Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/tV"},"text":"Pub. L. 102–580, title V","children":[],"tail":", §§ 501, 502, "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4864"},"text":"106 Stat. 4864","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/580/tV"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"501"},"text":"“SEC. 501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE AND DEFINITIONS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This title [enacting this section, amending sections 1412 to 1416, 1420, and 1421 of this title, and enacting provisions set out below] may be cited as the ‘National Contaminated Sediment Assessment and Management Act’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of sections 502 and 503 of this title [enacting this section and provisions set out below]—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘aquatic sediment’ means sediment underlying the navigable waters of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘navigable waters’ has the same meaning as in section 502(7) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1362/7"},"text":"33 U.S.C. 1362(7)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘pollutant’ has the same meaning as in section 502(6) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1362/6"},"text":"33 U.S.C. 1362(6)","children":[],"tail":"); except that such term does not include dredge spoil, rock, sand, or cellar dirt;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘contaminated sediment’ means aquatic sediment which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains chemical substances in excess of appropriate geochemical, toxicological or sediment quality criteria or measures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise considered by the Administrator to pose a threat to human health or the environment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Administrator’ means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"502"},"text":"“SEC. 502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NATIONAL CONTAMINATED SEDIMENT TASK FORCE.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a National Contaminated Sediment Task Force (hereinafter referred to in this section as the ‘Task Force’). The Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Administrator and the Secretary in the implementation of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and comment on reports concerning aquatic sediment quality and the extent and seriousness of aquatic sediment contamination throughout the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and comment on programs for the research and development of aquatic sediment restoration methods, practices, and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and comment on the selection of pollutants for development of aquatic sediment criteria and the schedule for the development of such criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise appropriate officials in the development of guidelines for restoration of contaminated sediment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make recommendations to appropriate officials concerning practices and measures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the contamination of aquatic sediments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to control sources of sediment contamination; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and assess the means and methods for locating and constructing permanent, cost-effective long-term disposal sites for the disposal of dredged material that is not suitable for ocean dumping (as determined under the Marine Protection, Research, and Sanctuaries Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1401"},"text":"33 U.S.C. 1401","children":[],"tail":" et seq.) [also "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1431"},"text":"16 U.S.C. 1431","children":[],"tail":" et seq., 1447 et seq.; "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2801"},"text":"33 U.S.C. 2801","children":[],"tail":" et seq.])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the Task Force shall include 1 representative of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Geological Survey [now United States Geological Survey].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Additional members of the Task Force shall be jointly selected by the Administrator and the Secretary, and shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 3 representatives of States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 3 representatives of ports, agriculture, and manufacturing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 3 representatives of public interest organizations with a demonstrated interest in aquatic sediment contamination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cochairmen","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the Secretary shall serve as cochairmen of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clerical and technical assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such clerical and technical assistance as may be necessary to discharge the duties of the Task Force shall be provided by the personnel of the Environmental Protection Agency and the Army Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation for additional members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The additional members of the Task Force selected under paragraph (2) shall, while attending meetings or conferences of the Task Force, be compensated at a rate to be fixed by the cochairmen, but not to exceed the daily equivalent of the base rate of pay in effect for grade GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":", United States Code, for each day (including travel time) during which they are engaged in the actual performance of duties vested in the Task Force. While away from their homes or regular places of business in the performance of services for the Task Force, such members shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703/b"},"text":"section 5703(b) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":"], the Task Force shall submit to Congress a report stating the findings and recommendations of the Task Force.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6bb26fbb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/tV/s509/b"},"text":"Pub. L. 102–580, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4870"},"text":"106 Stat. 4870","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/580/tV/s509/b"},"text":"“There is authorized to be appropriated to the Administrator to carry out sections 502 and 503 [enacting this section and provisions set out above] such sums as may be necessary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6bb26fbc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/580/s3"},"text":"section 3 of Pub. L. 102–580","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
