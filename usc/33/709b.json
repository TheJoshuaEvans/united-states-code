{"tag":"section","attrib":{"id":"id6b6adece-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s709b"},"text":null,"children":[{"tag":"num","attrib":{"value":"709b"},"text":"§ 709b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flood hazard information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, the Administrator of the Federal Emergency Management Agency, and the Administrator of the Soil Conservation Service shall take necessary actions, including the posting and distribution of information and the preparation and distribution of educational materials and programs, to ensure that information relating to flood hazard areas is generally available to the public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b6adecf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tIX/s944"},"text":"Pub. L. 99–662, title IX, § 944","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4200"},"text":"100 Stat. 4200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s612/c"},"text":"Pub. L. 109–295, title VI, § 612(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1410"},"text":"120 Stat. 1410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b6aded0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b6aded1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b6aded2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Administrator of the Federal Emergency Management Agency” substituted for “Director of the Federal Emergency Management Agency” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/c"},"text":"section 612(c) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":", Domestic Security. Any reference to the Administrator of the Federal Emergency Management Agency in title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" or an amendment by title VI to be considered to refer and apply to the Director of the Federal Emergency Management Agency until "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"Mar. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/f/2"},"text":"section 612(f)(2) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b6aded3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
