{"tag":"section","attrib":{"id":"id6c7857aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3075"},"text":null,"children":[{"tag":"num","attrib":{"value":"3075"},"text":"§ 3075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to use appropriated funds for transportation and reimbursement of certain items","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7857ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of effects of deceased officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an officer who dies on active duty, the Secretary may provide, from appropriations made available to the Administration, transportation (including packing, unpacking, crating, and uncrating) of personal and household effects of that officer to the official residence of record of that officer. However, upon application by the dependents of such an officer, such transportation may be provided to such other location as may be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7857ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for supplies furnished by officers to distressed and shipwrecked persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary, appropriations made available to the Administration may be used to reimburse an officer for food, clothing, medicines, and other supplies furnished by the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7857ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3075/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the temporary relief of distressed persons in remote localities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7857ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3075/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to shipwrecked persons who are temporarily provided for by the officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7857af-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s265"},"text":"Pub. L. 107–372, title II, § 265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3093"},"text":"116 Stat. 3093","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7857b0-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7857b1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c7857b2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s874"},"text":"section 874 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
