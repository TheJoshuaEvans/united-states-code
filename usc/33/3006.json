{"tag":"section","attrib":{"id":"id6c760deb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006"},"text":null,"children":[{"tag":"num","attrib":{"value":"3006"},"text":"§ 3006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligated service requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760dec-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760ded-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe the obligated service requirements for appointments, training, promotions, separations, continuations, and retirements of officers not otherwise covered by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760dee-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and officers shall enter into written agreements that describe the officers’ obligated service requirements prescribed under paragraph (1) in return for such appointments, training, promotions, separations, continuations, and retirements as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760def-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment for failure to satisfy requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760df0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require an officer who fails to meet the service requirements prescribed under subsection (a)(1) to reimburse the Secretary in an amount that bears the same ratio to the total costs of the training provided to that officer by the Secretary as the unserved portion of active duty bears to the total period of active duty the officer agreed to serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760df1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation as debt to United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An obligation to reimburse the Secretary under paragraph (1) is, for all purposes, a debt owed to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760df2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge in bankruptcy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A discharge in bankruptcy under title 11 that is entered less than five years after the termination of a written agreement entered into under subsection (a)(2) does not discharge the individual signing the agreement from a debt arising under such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760df3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver or suspension of compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the service obligation of an officer who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760df4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes unqualified to serve on active duty in the commissioned officer corps of the Administration because of a circumstance not within the control of that officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760df5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c760df6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not physically qualified for appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c760df7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3006/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined to be unqualified for service in the commissioned officer corps of the Administration because of a physical or medical condition that was not the result of the officer’s own willful misconduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760df8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tII/s216"},"text":"Pub. L. 107–372, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/259/tI/s103/a"},"text":"Pub. L. 116–259, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1155"},"text":"134 Stat. 1155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIV/s8405"},"text":"Pub. L. 119–60, div. H, title LXXXIV, § 8405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1913"},"text":"139 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760df9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760dfa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760dfb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “willful misconduct” for “misconduct or grossly negligent conduct”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
