{"tag":"section","attrib":{"id":"id6b95e69a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126"},"text":null,"children":[{"tag":"num","attrib":{"value":"1126"},"text":"§ 1126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sea grant colleges and sea grant institutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b95e69b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b95e69c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A sea grant college or sea grant institute shall meet the following qualifications—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b95e69d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an existing broad base of competence in fields related to ocean, coastal, and Great Lakes resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e69e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a long-term commitment to the objective in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1121/b"},"text":"section 1121(b) of this title","children":[],"tail":", as determined by the Secretary;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e69f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with other sea grant colleges and institutes and other persons to solve problems or meet needs relating to ocean, coastal, and Great Lakes resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e6a0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have received financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1124"},"text":"section 1124 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e6a1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be recognized for excellence in fields related to ocean, coastal, and Great Lakes resources (including marine resources management and science), as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e6a2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such other qualifications as the Secretary, in consultation with the Board, considers necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b95e6a3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may designate an institution, or an association or alliance of two or more such institutions, as a sea grant college if the institution, association, or alliance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b95e6a4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the qualifications in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e6a5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains a program of research, extension services, training, and education in fields related to ocean, coastal, and Great Lakes resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b95e6a6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may designate an institution, or an association or alliance of two or more such institutions, as a sea grant institute if the institution, association, or alliance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b95e6a7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the qualifications in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e6a8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains a program which includes, at a minimum, research and extension services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b95e6a9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional designations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b95e6aa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress of designations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b95e6ab-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 30 days before designating an institution, or an association or alliance of two or more such institutions, as a sea grant college or sea grant institute under subsection (a), the Secretary shall notify Congress in writing of the proposed designation. The notification shall include an evaluation and justification for the designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b95e6ac-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of joint resolution of disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not designate an institution, or an association or alliance of two or more such institutions, as a sea grant college or sea grant institute under subsection (a) if, before the end of the 30-day period described in subparagraph (A), a joint resolution disapproving the designation is enacted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b95e6ad-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing designees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any institution, or association or alliance of two or more such institutions, designated as a sea grant college or awarded institutional program status by the Director prior to ","children":[{"tag":"date","attrib":{"date":"1998-03-06"},"text":"March 6, 1998","children":[],"tail":", shall not have to reapply for designation as a sea grant college or sea grant institute, respectively, after "},{"tag":"date","attrib":{"date":"1998-03-06"},"text":"March 6, 1998","children":[],"tail":", if the Director determines that the institution, or association or alliance of institutions, meets the qualifications in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b95e6ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination of designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for cause and after an opportunity for hearing, suspend or terminate any designation under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b95e6af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to any regulations prescribed or guidelines established by the Secretary, it shall be the responsibility of each sea grant college and sea grant institute—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b95e6b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement, in consultation with the Secretary and the Board, a program that is consistent with the guidelines and priorities established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1123/c"},"text":"section 1123(c) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b95e6b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1126/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct a merit review of all proposals for grants and contracts to be awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1124"},"text":"section 1124 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b95e6b2-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/454/tII/s207"},"text":"Pub. L. 89–454, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/461/s2"},"text":"Pub. L. 94–461, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-08"},"text":"Oct. 8, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1966"},"text":"90 Stat. 1966","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/220/tIII/s3104/b/1/E"},"text":"Pub. L. 100–220, title III, § 3104(b)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-29"},"text":"Dec. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1470"},"text":"101 Stat. 1470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/160/s7"},"text":"Pub. L. 105–160, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-03-06"},"text":"Mar. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/24"},"text":"112 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/299/s8"},"text":"Pub. L. 107–299, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-26"},"text":"Nov. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2348"},"text":"116 Stat. 2348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/394"},"text":"Pub. L. 110–394","children":[],"tail":", §§ 7, 9(a)(4)(C)(ii), "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4207"},"text":"122 Stat. 4207","children":[],"tail":", 4208; "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/tII/s201/a"},"text":"Pub. L. 113–188, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2018"},"text":"128 Stat. 2018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/221/s7"},"text":"Pub. L. 116–221, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1059"},"text":"134 Stat. 1059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b95e6b3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b95e6b4-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b95e6b5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/221/s7/2"},"text":"Pub. L. 116–221, § 7(2)","children":[],"tail":", added par. (1), designated existing provisions as par. (2), and inserted par. (2) heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/221/s7/1"},"text":"Pub. L. 116–221, § 7(1)","children":[],"tail":", substituted “Additional designations” for “Existing designees” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188"},"text":"Pub. L. 113–188","children":[],"tail":", which directed amendment of section 207 of the National Sea Grant Program Act by striking subsec. (e), was executed to this section, which is section 207 of the National Sea Grant College Program Act, to reflect the probable intent of Congress. Prior to amendment, subsec. (e) related to annual reports on progress made by colleges, universities, institutions, associations, and alliances to become designated under this section as sea grant colleges or sea grant institutes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s9/a/4/C/ii"},"text":"Pub. L. 110–394, § 9(a)(4)(C)(ii)","children":[],"tail":", substituted “Board” for “panel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B), (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s7"},"text":"Pub. L. 110–394, § 7","children":[],"tail":", substituted “extension services” for “advisory services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/394/s9/a/4/C/ii"},"text":"Pub. L. 110–394, § 9(a)(4)(C)(ii)","children":[],"tail":", substituted “Board” for “panel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/299"},"text":"Pub. L. 107–299","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/160"},"text":"Pub. L. 105–160","children":[],"tail":" amended section catchline and text generally. Prior to amendment text consisted of subsecs. (a) to (c) relating to authorization of the Secretary to designate sea grant college and sea grant regional consortia with certain prerequisites, requirement of regulations to prescribe qualifications and guidelines, and authorization of the Secretary to suspend or terminate any designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2)(A), (3)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/220"},"text":"Pub. L. 100–220","children":[],"tail":" substituted “ocean, coastal, and Great Lakes resources” for “ocean and coastal resources”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
