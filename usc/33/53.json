{"tag":"section","attrib":{"id":"id6b0b8126-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s53"},"text":null,"children":[{"tag":"num","attrib":{"value":"53"},"text":"§ 53.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benton Harbor Canal, Michigan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Benton Harbor Canal at and above the west line of Ninth Street, in the city of Benton Harbor and State of Michigan, is declared to be not a navigable water of the United States within the meaning of the Constitution and laws of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0b8127-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-06-02/ch288"},"text":"June 2, 1937, ch. 288","children":[],"tail":", §§ 1, 3, "},{"tag":"ref","attrib":{"href":"/us/stat/50/243"},"text":"50 Stat. 243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0b8128-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0b8129-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6b0b812a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-06-02/ch288"},"text":"act June 2, 1937, ch. 288","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/243"},"text":"50 Stat. 243","children":[],"tail":", sections 1 and 3 of which are classified to this section. Section 2 of the Act, which relates to abandonment of a portion of the Benton Harbor Canal project, is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
