{"tag":"section","attrib":{"id":"id6b2ceb50-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s450"},"text":null,"children":[{"tag":"num","attrib":{"value":"450"},"text":"§ 450.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of vessel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any boat or vessel used or employed in violating any provision of this subchapter, shall be liable to the pecuniary penalties imposed thereby, and may be proceeded against, summarily by way of libel in any district court of the United States having jurisdiction thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b2f5c51-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-06-29/ch496/s4"},"text":"June 29, 1888, ch. 496, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/210"},"text":"25 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b2f5c52-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b2f5c53-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b2f5c54-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1888-06-29"},"text":"June 29, 1888","children":[],"tail":", which enacted sections 449 and 450 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
