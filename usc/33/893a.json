{"tag":"section","attrib":{"id":"id6b7936f1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a"},"text":null,"children":[{"tag":"num","attrib":{"value":"893a"},"text":"§ 893a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NOAA ocean and atmospheric science education programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b7936f2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration shall conduct, develop, support, promote, and coordinate formal and informal educational activities at all levels to enhance public awareness and understanding of ocean, coastal, Great Lakes, and atmospheric science and stewardship by the general public and other coastal stakeholders, including underrepresented groups in ocean and atmospheric science and policy careers. In conducting those activities, the Administrator shall build upon the educational programs and activities of the agency, with consideration given to the goal of promoting the participation of individuals identified in sections 1885a and 1885b of title 42 in STEM fields and in promoting the acquisition and retention of highly qualified and motivated young scientists to complement and supplement workforce needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936f3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational program goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The education programs developed by NOAA shall, to the extent applicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b7936f4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out and support research based programs and activities designed to increase student interest and participation in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936f5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve public literacy in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936f6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ proven strategies and methods for improving student learning and teaching in STEM;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936f7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide curriculum support materials and other resources that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b7936f8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designed to be integrated with comprehensive STEM education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936f9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are aligned with national science education standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936fa-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designed considering the unique needs of underrepresented groups, translating such materials and other resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936fb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the adoption and implementation of high-quality education practices that build toward college and career-readiness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b7936fc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are promoted widely, especially among individuals identified in sections 1885a and 1885b of title 42; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b7936fd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and support opportunities for enhanced and ongoing professional development for teachers using best practices that improves the STEM content and knowledge of the teachers, including through programs linking STEM teachers with STEM educators at the higher education level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936fe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NOAA science education plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, appropriate National Oceanic and Atmospheric Administration programs, ocean atmospheric science and education experts, and interested members of the public shall maintain a science education plan setting forth education goals and strategies for the Administration, as well as programmatic actions to carry out such goals and priorities over the next 20 years, and evaluate and update such plan every 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b7936ff-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metrics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In executing the National Oceanic and Atmospheric Administration science education plan under subsection (c), the Administrator shall maintain a comprehensive system for evaluating the Administration’s educational programs and activities. In so doing, the Administrator shall ensure that such education programs have measurable objectives and milestones as well as clear, documented metrics for evaluating programs. For each such education program or portfolio of similar programs, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b793700-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the collection of evidence as relevant to the measurable objectives and milestones; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b793701-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that program or portfolio evaluations focus on educational outcomes and not just inputs, activities completed, or the number of participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b793702-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to affect the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232a"},"text":"section 1232a of title 20","children":[],"tail":" or sections 794 and 794d of title 29."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b793703-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s893a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “STEM” means the academic and professional disciplines of science, technology, engineering, and mathematics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b793704-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIV/s4002"},"text":"Pub. L. 110–69, title IV, § 4002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/600"},"text":"121 Stat. 600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIII/s302"},"text":"Pub. L. 111–358, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3997"},"text":"124 Stat. 3997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s314"},"text":"Pub. L. 114–329, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3015"},"text":"130 Stat. 3015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b793705-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b793706-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b793707-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s314/a"},"text":"Pub. L. 114–329, § 314(a)","children":[],"tail":", substituted “the agency, with consideration given to the goal of promoting the participation of individuals identified in sections 1885a and 1885b of title 42” for “agency, with consideration given to the goal of promoting the participation of individuals from underrepresented groups”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s314/b"},"text":"Pub. L. 114–329, § 314(b)","children":[],"tail":", added subpars. (C) and (E) and redesignated former subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s314/c"},"text":"Pub. L. 114–329, § 314(c)","children":[],"tail":", added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s302/1"},"text":"Pub. L. 111–358, § 302(1)","children":[],"tail":", substituted “agency, with consideration given to the goal of promoting the participation of individuals from underrepresented groups in STEM fields and in promoting the acquisition and retention of highly qualified and motivated young scientists to complement and supplement workforce needs.” for “the agency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s302/3"},"text":"Pub. L. 111–358, § 302(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s302/4"},"text":"Pub. L. 111–358, § 302(4)","children":[],"tail":", substituted “maintain” for “develop”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s302/2"},"text":"Pub. L. 111–358, § 302(2)","children":[],"tail":", redesignated subsec. (b) as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s302/2"},"text":"Pub. L. 111–358, § 302(2)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s302/5"},"text":"Pub. L. 111–358, § 302(5)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
