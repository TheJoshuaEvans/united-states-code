{"tag":"section","attrib":{"id":"id6b5a3d78-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"701b–17"},"text":"§ 701b–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps of Engineers Western Water Cooperative Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6b5a3d79-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6b5a3d7a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall establish a Western Water Cooperative Committee (referred to in this section as the “Cooperative Committee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d7b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Cooperative Committee is to ensure that Corps of Engineers flood control projects in Western States are operated consistent with congressional directives by identifying opportunities to avoid or minimize conflicts between the operation of Corps of Engineers projects and water rights and water laws in such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d7c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Cooperative Committee shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b5a3d7d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of the Army for Civil Works (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d7e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of Engineers (or a designee);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d7f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from each of the Western States, who may serve on the Western States Water Council, to be appointed by the Governor of each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d80-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative with legal experience from each of the Western States, to be appointed by the attorney general of each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d81-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 employee from each of the impacted regional offices of the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d82-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b5a3d83-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Cooperative Committee shall meet not less than once each year in one of the Western States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d84-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Available to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each meeting of the Cooperative Committee shall be open and accessible to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d85-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Cooperative Committee shall publish in the Federal Register adequate advance notice of a meeting of the Cooperative Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d86-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b5a3d87-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Cooperative Committee shall develop and make recommendations to avoid or minimize conflicts between the operation of Corps of Engineers projects and the water rights and water laws of Western States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d88-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subparagraph (A), the Cooperative Committee shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b5a3d89-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations that only apply to Western States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b5a3d8a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any recommended changes or modifications to policy or regulations for Corps of Engineers projects would not adversely affect water resources within the State of Missouri.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d8b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status updates","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b5a3d8c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the Secretary shall provide to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a written report that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b5a3d8d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the contents of meetings of the Cooperative Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b5a3d8e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legislative proposal from a Western State proposed to the Cooperative Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b5a3d8f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any recommendations made by the Cooperative Committee under paragraph (5), including actions taken by the Secretary in response to such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d90-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6b5a3d91-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days following the conclusion of a meeting of the Cooperative Committee, the Secretary shall provide to members of the Cooperative Committee an opportunity to comment on the contents of the meeting and any recommendations made under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6b5a3d92-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Comments provided under clause (i) shall be included in the report provided under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d93-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b5a3d94-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the members of the Cooperative Committee shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d95-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Cooperative Committee shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d96-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Cooperative Committee shall maintain records pertaining to operating costs and records of the Cooperative Committee for a period of not less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6b5a3d97-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provisions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6b5a3d98-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section provides authority to the Cooperative Committee to affect any Federal or State water law or interstate compact governing water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6b5a3d99-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be interpreted, by negative implication or otherwise, as suggesting that States not represented on the Cooperative Committee have lesser interest or authority, in relation to Western States, in managing the water within their borders or in vindicating State water rights and water laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6b5a3d9a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s701b–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Western States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Western States” means the States of Alaska, Arizona, California, Colorado, Idaho, Kansas, Montana, Nebraska, Nevada, New Mexico, North Dakota, Oklahoma, Oregon, South Dakota, Texas, Utah, Washington, and Wyoming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6b5a3d9b-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8158"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3738"},"text":"136 Stat. 3738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b5a3d9c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b5a3d9d-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6b5a3d9e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8002"},"text":"section 8002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
