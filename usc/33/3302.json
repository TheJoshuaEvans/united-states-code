{"tag":"section","attrib":{"id":"id6c7d39ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302"},"text":null,"children":[{"tag":"num","attrib":{"value":"3302"},"text":"§ 3302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee on Levee Safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c7d39bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a committee to be known as the “Committee on Levee Safety”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7d39bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committee shall be composed of 16 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7d39bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonvoting members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following 2 nonvoting members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82ae-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary (or a designee of the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82af-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator (or a designee of the Administrator).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82b0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following 14 voting members appointed by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82b1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eight representatives of State levee safety agencies, one from each of the eight civil works divisions of the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82b2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two representatives of the private sector who have expertise in levee safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82b3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two representatives of local and regional governmental agencies who have expertise in levee safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82b4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two representatives of Indian tribes who have expertise in levee safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of voting members","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A voting member of the committee shall be appointed for a term of 3 years, except that, of the members first appointed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c7f82b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 shall be appointed for a term of 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7f82b9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c7f82ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 shall be appointed for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A voting member of the committee may be reappointed to the committee, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82bc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the committee shall be filled in the same manner as the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82bd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82be-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The voting members of the committee shall appoint a chairperson from among the voting members of the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82bf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson shall serve a term of not more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82c0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standing committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82c1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The committee may establish standing committees comprised of volunteers from all levels of government and the private sector, to advise the committee regarding specific levee safety issues, including participating programs, technical issues, public education and awareness, and safety and the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82c2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The committee shall recommend to the Secretary for approval individuals for membership on the standing committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82c3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82c4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit to the Secretary and Congress an annual report regarding the effectiveness of the levee safety initiative in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3303b"},"text":"section 3303b of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82c5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may secure from other Federal agencies such services, and enter into such contracts, as the committee determines to be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82c6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The committee shall, to the maximum extent practicable, coordinate the activities of the committee with the Federal Interagency Floodplain Management Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82c7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c7f82c8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the committee who is an officer or employee of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c7f82c9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall serve without compensation in addition to compensation received for the services of the member as an officer or employee of the United States; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c7f82ca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be allowed a per diem allowance for travel expenses, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5, while away from the home or regular place of business of the member in the performance of the duties of the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82cb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent amounts are made available to carry out this section in appropriations Acts, the Secretary shall provide to each member of the committee who is not an officer or employee of the United States a stipend and a per diem allowance for travel expenses, at rates authorized for an employee of an agency under subchapter I of chapter 57 of title 5, while away from the home or regular place of business of the member in performance of services for the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c7f82cc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standing committee members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of a standing committee shall serve in a voluntary capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c7f82cd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3302/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c7f82ce-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/tIX/s9003"},"text":"Pub. L. 110–114, title IX, § 9003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1288"},"text":"121 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/274/s1"},"text":"Pub. L. 110–274, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-15"},"text":"July 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2493"},"text":"122 Stat. 2493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/tIII/s3016/c"},"text":"Pub. L. 113–121, title III, § 3016(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1291"},"text":"128 Stat. 1291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/207"},"text":"Pub. L. 117–286, § 4(a)(207)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4328"},"text":"136 Stat. 4328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c7f82cf-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c7f82d0-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c7f82d1-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/c/1"},"text":"Pub. L. 113–121, § 3016(c)(1)","children":[],"tail":", added par. (1), redesignated par. (3) as (2), inserted “voting” after “14” in introductory provisions of par. (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Secretary (or the Secretary’s designee), who shall serve as the chairperson of the Committee.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Administrator of the Federal Emergency Management Agency (or the Administrator’s designee).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s3016/c/2"},"text":"Pub. L. 113–121, § 3016(c)(2)","children":[],"tail":", (3), added subsecs. (c) to (g), redesignated former subsec. (g) as (h), and struck out former subsecs. (c) to (f) which related to duties, purposes, compensation of members, and travel expenses, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/274"},"text":"Pub. L. 110–274","children":[],"tail":" substituted “Subject to the availability of appropriations,” for “To the extent amounts are made available in advance in appropriations Acts,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c7f82d2-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c7f82d3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s2"},"text":"section 2 of Pub. L. 110–114","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
