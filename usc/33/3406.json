{"tag":"section","attrib":{"id":"id6c81f50b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3406"},"text":null,"children":[{"tag":"num","attrib":{"value":"3406"},"text":"§ 3406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the National Oceanic and Atmospheric Administration to carry out this subchapter $60,000,000 for each of fiscal years 2023 through 2028 ","children":[{"tag":"ref","attrib":{"idref":"fn002144"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002144"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c81f50c-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12006"},"text":"Pub. L. 111–11, title XII, § 12006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1419"},"text":"123 Stat. 1419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10305/g"},"text":"Pub. L. 117–263, div. J, title CIII, § 10305(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3974"},"text":"136 Stat. 3974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c81f50d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c81f50e-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c81f50f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “this subchapter $60,000,000 for each of fiscal years 2023 through 2028” for “this subchapter—” and struck out pars. (1) to (7) which authorized appropriations for fiscal years 2009 through 2015."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
