{"tag":"section","attrib":{"id":"id6b9d1253-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1201"},"text":null,"children":[{"tag":"num","attrib":{"value":"1201"},"text":"§ 1201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this chapter to provide a positive means whereby the operators of approaching vessels can communicate their intentions to one another through voice radio, located convenient to the operator’s navigation station. To effectively accomplish this, there is need for a specific frequency or frequencies dedicated to the exchange of navigational information, on navigable waters of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b9d1254-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/63/s2"},"text":"Pub. L. 92–63, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-04"},"text":"Aug. 4, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/164"},"text":"85 Stat. 164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b9d1255-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b9d1256-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id6b9d1257-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/63/s1"},"text":"Pub. L. 92–63, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-04"},"text":"Aug. 4, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/164"},"text":"85 Stat. 164","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/63/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Vessel Bridge-to-Bridge Radiotelephone Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b9d1258-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/63/s10"},"text":"Pub. L. 92–63, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-04"},"text":"Aug. 4, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/165"},"text":"85 Stat. 165","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/63/s10"},"text":"“This Act [enacting this chapter] shall become effective ","children":[{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":", or six months after the promulgation of regulations which would implement its provisions, whichever is later.”"}],"tail":"\n See 47 CFR 83.701 et seq."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
