{"tag":"section","attrib":{"id":"id6b1c496f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s393"},"text":null,"children":[{"tag":"num","attrib":{"value":"393"},"text":"§ 393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments of complaint and adjournments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be lawful for the court to allow the United States attorney to amend his statement of complaint at any stage of the proceedings, before verdict, if, in the opinion of the court, such amendment will work no injustice to the accused; and if it appears to the court that the accused is unprepared to meet the charge as amended, and that an adjournment of the cause will promote the ends of justice, such adjournment shall be made, until a further day, to be fixed by the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b1c4970-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(R.S. § 4302; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b1c4971-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b1c4972-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b1c4973-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4302 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-11/ch121/s6"},"text":"act June 11, 1864, ch. 121, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/13/125"},"text":"13 Stat. 125","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b1c4974-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id6b1c4975-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", substituted “United States attorney” for “district attorney”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and Historical and Revision Notes set out thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
