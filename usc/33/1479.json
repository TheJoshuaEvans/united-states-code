{"tag":"section","attrib":{"id":"id6c0f83b5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1479"},"text":null,"children":[{"tag":"num","attrib":{"value":"1479"},"text":"§ 1479.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal liability for unreasonable damages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c0f83b6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1479/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall be obliged to pay compensation to the extent of the damage caused by measures which exceed those reasonably necessary to achieve the end mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1472"},"text":"section 1472 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f83b7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1479/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Actions against the United States seeking compensation for any excessive measures may be brought in the United States Court of Federal Claims, in any district court of the United States, and in those courts enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s460"},"text":"section 460 of title 28","children":[],"tail":". For purposes of this chapter, American Samoa shall be included within the judicial district of the District Court of the United States for the District of Hawaii, and the Trust Territory of the Pacific Islands shall be included within the judicial districts of both the District Court of the United States for the District of Hawaii and the District Court of Guam."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c0f83b8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s1479/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to intervention for a substance identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1473/a"},"text":"section 1473(a) of this title","children":[],"tail":", the United States has the burden of establishing that, under the circumstances present at the time of the intervention, the substance could reasonably pose a grave and imminent danger analogous to that posed by a substance enumerated in the protocol."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c0f83b9-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/248/s10"},"text":"Pub. L. 93–248, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-02-05"},"text":"Feb. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/10"},"text":"88 Stat. 10","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/302/s1/4"},"text":"Pub. L. 95–302, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-26"},"text":"June 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/345"},"text":"92 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s161/6"},"text":"Pub. L. 97–164, title I, § 161(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"hr