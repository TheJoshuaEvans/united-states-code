{"tag":"section","attrib":{"id":"id6c4b0663-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2286"},"text":null,"children":[{"tag":"num","attrib":{"value":"2286"},"text":"§ 2286.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of certain funds for mitigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to accept funds from any entity, public or private, in accordance with the Pacific Northwest Electric Power Planning and Conservation Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s839"},"text":"16 U.S.C. 839","children":[],"tail":" et seq.] to be used to protect, mitigate, and enhance fish and wildlife in connection with projects constructed or operated by the Secretary. The Secretary may accept and use funds for such purposes without regard to any limitation established under any other provision of law or rule of law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6c4b0664-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1146"},"text":"Pub. L. 99–662, title XI, § 1146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4253"},"text":"100 Stat. 4253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c4b0665-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c4b0666-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c4b0667-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Pacific Northwest Electric Power Planning and Conservation Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/501"},"text":"Pub. L. 96–501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2697"},"text":"94 Stat. 2697","children":[],"tail":", which is classified principally to chapter 12H (§ 839 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s839"},"text":"section 839 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
