{"tag":"section","attrib":{"id":"id6c523111-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2314b"},"text":"§ 2314b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced modeling technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c523112-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the greatest extent practicable, the Secretary shall encourage and incorporate advanced modeling technologies, including 3-dimensional digital modeling, that can expedite project delivery or improve the evaluation of water resources development projects that receive Federal funding by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c523113-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerating and improving the environmental review process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523114-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing effective public participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523115-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the detail and accuracy of project designs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523116-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523117-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerating construction and reducing construction costs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c523118-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise achieving the purposes described in paragraphs (1) through (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c523119-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary, to the greatest extent practicable, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c52311a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile information related to advanced modeling technologies, including industry best practices with respect to the use of the technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52311b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate to non-Federal interests the information described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c52311c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2314b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of advanced modeling technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c52311d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1034"},"text":"Pub. L. 113–121, title I, § 1034","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1234"},"text":"128 Stat. 1234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c52311e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c52311f-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c523120-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c523121-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c523122-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
