{"tag":"section","attrib":{"id":"id6c65445a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2606"},"text":null,"children":[{"tag":"num","attrib":{"value":"2606"},"text":"§ 2606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpena authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c65445b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an investigation under this chapter, the attendance and testimony of witnesses, including parties in interest, and the production of any evidence may be compelled by subpena. The subpena authority granted by this section is coextensive with that of a district court of the United States, in civil matters, for the district in which the investigation is conducted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65445c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpena authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An official designated by the Secretary of Transportation or Administrator to conduct an investigation under this chapter may issue subpenas as provided in this section and administer oaths to witnesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65445d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a person fails to obey a subpena issued under this section, the district court of the United States for the district in which the investigation is conducted or in which the person failing to obey is found, shall on proper application issue an order directing that person to comply with the subpena. The court may punish as contempt any disobedience of its order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c65445e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2606/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A witness complying with a subpena issued under this section may be paid for actual travel and attendance at the rate provided for witnesses in the district courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c65445f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/688/tIV/s4106"},"text":"Pub. L. 100–688, title IV, § 4106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4157"},"text":"102 Stat. 4157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c654460-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c654461-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c654462-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this part” and was translated as reading “this title” to reflect the probable intent of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
