{"tag":"section","attrib":{"id":"id6b76c5ba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s883h"},"text":null,"children":[{"tag":"num","attrib":{"value":"883h"},"text":"§ 883h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of public vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to cause to be employed such of the public vessels as he deems it expedient to employ, and to give such instructions for regulating their conduct as he deems proper in order to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b76c5bb-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-08-06/ch504/s8"},"text":"Aug. 6, 1947, ch. 504, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/788"},"text":"61 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b76c5bc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id6b76c5bd-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id6b76c5be-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of Commerce, see section 1(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of Ex. Ord. No. 11023, "},{"tag":"date","attrib":{"date":"1962-05-28"},"text":"May 28, 1962","children":[],"tail":", 27 F.R. 5131, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
