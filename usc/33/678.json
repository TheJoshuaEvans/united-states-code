{"tag":"section","attrib":{"id":"id6b558297-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s678"},"text":null,"children":[{"tag":"num","attrib":{"value":"678"},"text":"§ 678.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification and revocation of permit to mine","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The said commission may, at any time when the condition of the navigable rivers or when the capacities of all impounding and settling facilities erected by mine owners or such as may be provided by Government authority require same, modify the order granting the privilege to mine by the hydraulic mining process so as to reduce the amount thereof to meet the capacities of the facilities then in use; or, if actually required in order to protect the navigable rivers from damage or in case of failure to pay the tax prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s683"},"text":"section 683 of this title","children":[],"tail":" within thirty days after same becomes due, may revoke same until the further notice of the commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b558298-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-01/ch183/s18"},"text":"Mar. 1, 1893, ch. 183, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/509"},"text":"27 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch661/s1"},"text":"June 19, 1934, ch. 661, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1118"},"text":"48 Stat. 1118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b558299-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b55829a-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b55829b-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1934—Act ","children":[{"tag":"date","attrib":{"date":"1934-06-19"},"text":"June 19, 1934","children":[],"tail":", inserted “or in case of failure to pay the tax prescribed by "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s683"},"text":"section 683 of this title","children":[],"tail":" within thirty days after same becomes due”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b55829c-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id6b55829d-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"California Debris Commission abolished and functions transferred to Secretary of the Army by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/662/tXI/s1106"},"text":"Pub. L. 99–662, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-17"},"text":"Nov. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/4229"},"text":"100 Stat. 4229","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
