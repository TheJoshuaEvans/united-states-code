{"tag":"section","attrib":{"id":"id6c62fab5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357"},"text":null,"children":[{"tag":"num","attrib":{"value":"2357"},"text":"§ 2357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managed aquifer recharge study and working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c62fab6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fab7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in consultation with applicable non-Federal interests, conduct a national assessment of carrying out managed aquifer recharge projects to address drought, water resiliency, and aquifer depletion at authorized water resources development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fab8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fab9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and identify opportunities to support non-Federal interests, including Tribal communities, in carrying out managed aquifer recharge projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62faba-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess preliminarily local hydrogeologic conditions relevant to carrying out managed aquifer recharge projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fabb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall coordinate, as appropriate, with the heads of other Federal agencies, States, regional governmental agencies, units of local government, experts in managed aquifer recharge, and Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fabc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility studies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fabd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to carry out feasibility studies, at the request of a non-Federal interest, of managed aquifer recharge projects in areas that are experiencing, or have recently experienced, prolonged drought conditions, aquifer depletion, or water supply scarcity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fabe-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out not more than 10 feasibility studies under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fabf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, use information gathered from the assessment conducted under subsection (a) in identifying and selecting feasibility studies to carry out under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fac0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a feasibility study carried out under this subsection shall be 90 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fac1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fac2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall establish a managed aquifer recharge working group made up of subject matter experts within the Corps of Engineers and relevant non-Federal stakeholders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fac3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the working group under paragraph (1), the Secretary shall ensure that members of the working group have expertise working with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62fac4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects providing water supply storage to meet regional water supply demand, particularly in regions experiencing drought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fac5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of groundwater supply, including promoting infiltration and increased recharge in groundwater basins, and groundwater quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fac6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aquifer storage, recharge, and recovery wells;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fac7-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dams that provide recharge enhancement benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fac8-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groundwater hydrology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62fac9-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conjunctive use water systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62faca-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural water resources, including the use of aquifers for irrigation purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62facb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group established under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c62facc-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary regarding the development and execution of the assessment under subsection (a) and any feasibility studies under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62facd-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist Corps of Engineers offices at the headquarter, division, and district levels with raising awareness of non-Federal interests of the potential benefits of carrying out managed aquifer recharge projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c62face-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist with the development of the report required to be submitted under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62facf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a report on managed aquifer recharge that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fad0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the assessment conducted under subsection (a) and any feasibility studies carried out under subsection (b), including data collected under such assessment and studies and any recommendations on managed aquifer recharge opportunities for non-Federal interests, States, local governments, and Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fad1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a status update on the implementation of the recommendations included in the report of the U.S. Army Corps of Engineers Institute for Water Resources entitled “Managed Aquifer Recharge and the U.S. Army Corps of Engineers: Water Security through Resilience”, published in April 2020 (2020–WP–01); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fad2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the benefits of creating a new or modifying an existing planning center of expertise for managed aquifer recharge, and identify potential locations for such a center of expertise, if feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fad3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the non-Federal share of the cost of construction of a managed aquifer recharge project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2213"},"text":"section 2213 of this title","children":[],"tail":" or any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c62fad4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c62fad5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managed aquifer recharge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “managed aquifer recharge” means the intentional banking and treatment of water in aquifers for storage and future use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c62fad6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2357/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managed aquifer recharge project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “managed aquifer recharge project” means a project to incorporate managed aquifer recharge features into a water resources development project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c62fad7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dH/tLXXXI/s8108"},"text":"Pub. L. 117–263, div. H, title LXXXI, § 8108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3700"},"text":"136 Stat. 3700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c62fad8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c62fad9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c62fada-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Development Act of 2022, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c62fadb-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c62fadc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s8002"},"text":"section 8002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
