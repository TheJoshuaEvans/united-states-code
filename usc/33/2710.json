{"tag":"section","attrib":{"id":"id6c69fecf-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2710"},"text":null,"children":[{"tag":"num","attrib":{"value":"2710"},"text":"§ 2710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c69fed0-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements not prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act prohibits any agreement to insure, hold harmless, or indemnify a party to such agreement for any liability under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c69fed1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability not transferred","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No indemnification, hold harmless, or similar agreement or conveyance shall be effective to transfer liability imposed under this Act from a responsible party or from any person who may be liable for an incident under this Act to any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c69fed2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other causes of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act, including the provisions of subsection (b), bars a cause of action that a responsible party subject to liability under this Act, or a guarantor, has or would have, by reason of subrogation or otherwise, against any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c69fed3-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/tI/s1010"},"text":"Pub. L. 101–380, title I, § 1010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/498"},"text":"104 Stat. 498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c69fed4-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c69fed5-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id6c69fed6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/484"},"text":"104 Stat. 484","children":[],"tail":", known as the Oil Pollution Act of 1990, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
