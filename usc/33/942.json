{"tag":"section","attrib":{"id":"id6b8c49d4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s942"},"text":null,"children":[{"tag":"num","attrib":{"value":"942"},"text":"§ 942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall make to Congress at the end of each fiscal year,","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" a report of the administration of this chapter for the preceding fiscal year, including a detailed statement of receipts of and expenditures from the fund established in "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s944"},"text":"section 944 of this title","children":[],"tail":", together with such recommendations as the Secretary deems advisable. Such report shall include the annual report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s936/b"},"text":"section 936(b) of title 30","children":[],"tail":" and shall be identified as the Annual Report of the Office of Workers’ Compensation Programs."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b8c49d5-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s42"},"text":"Mar. 4, 1927, ch. 509, § 42","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s23"},"text":"Pub. L. 98–426, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1653"},"text":"98 Stat. 1653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1102/b/1"},"text":"Pub. L. 104–66, title I, § 1102(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/722"},"text":"109 Stat. 722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b8c49d6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b8c49d7-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6b8c49d8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 942, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s42"},"text":"act Mar. 4, 1927, ch. 509, § 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1444"},"text":"44 Stat. 1444","children":[],"tail":", related to travel and subsistence expenses. See section 5701 et seq. of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b8c49d9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" substituted “end of each fiscal year” for “beginning of each regular session, commencing at the beginning of the second regular session after "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"September 28, 1984","children":[],"tail":"” and inserted at end “Such report shall include the annual report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s936/b"},"text":"section 936(b) of title 30","children":[],"tail":" and shall be identified as the Annual Report of the Office of Workers’ Compensation Programs.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b8c49da-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id6b8c49db-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s28/e/1"},"text":"section 28(e)(1) of Pub. L. 98–426","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
