{"tag":"section","attrib":{"id":"id6b8c497d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s934"},"text":null,"children":[{"tag":"num","attrib":{"value":"934"},"text":"§ 934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every employer who has secured compensation under the provisions of this chapter shall keep posted in a conspicuous place or places in and about his place or places of business typewritten or printed notices, in accordance with a form prescribed by the Secretary, stating that such employer has secured the payment of compensation in accordance with the provisions of this chapter. Such notices shall contain the name and address of the carrier, if any, with whom the employer has secured payment of compensation and the date of the expiration of the policy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b8c497e-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509/s34"},"text":"Mar. 4, 1927, ch. 509, § 34","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1441"},"text":"44 Stat. 1441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s27/a/2"},"text":"Pub. L. 98–426, § 27(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1654"},"text":"98 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b8c497f-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b8c4980-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6b8c4981-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":" substituted “Secretary” for “commission”. See Transfer of Functions note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902"},"text":"section 902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6b8c4982-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id6b8c4983-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/426"},"text":"Pub. L. 98–426","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/426/s28/e/1"},"text":"section 28(e)(1) of Pub. L. 98–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
