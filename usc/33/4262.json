{"tag":"section","attrib":{"id":"id6c97513c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262"},"text":null,"children":[{"tag":"num","attrib":{"value":"4262"},"text":"§ 4262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of efforts and assistance to combat marine debris and improve plastic waste management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c97513d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall, in coordination with the Administrator of the United States Agency for International Development, as appropriate, and the officials specified in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c97513e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead and coordinate efforts to implement the policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4261"},"text":"section 4261 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c97513f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop strategies and implement programs that prioritize engagement and cooperation with foreign governments, subnational and local stakeholders, and the private sector to expedite efforts and assistance in foreign countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c975140-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to partner with, encourage, advise and facilitate national and subnational governments on the development and execution, where practicable, of national projects, programs and initiatives to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c975141-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the capacity, security, and standards of operations of post-consumer materials management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c975142-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and track how well post-consumer materials management systems are functioning nationwide, based on uniform and transparent standards developed in cooperation with municipal, industrial, and civil society stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c975143-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the operational challenges of post-consumer materials management systems and develop policy and programmatic solutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c975144-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" end intentional or unintentional incentives for municipalities, industries, and individuals to improperly dispose of plastic waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c975145-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach campaigns to raise public awareness of the importance of proper waste disposal and the reduction of plastic waste;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975146-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the involvement of municipalities and industries in improving solid waste reduction, collection, disposal, and reuse and recycling projects, programs, and initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975147-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to partner with and provide technical assistance to investors, and national and local institutions, including private sector actors, to develop new business opportunities and solutions to specifically reduce plastic waste and expand solid waste and post-consumer materials management best practices in foreign countries by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c975148-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the number of people and businesses, in both rural and urban communities, receiving reliable solid waste and post-consumer materials management services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c975149-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving and expanding the capacity of foreign industries to responsibly employ post-consumer materials management practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c97514a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving and expanding the capacity and transparency of tracking mechanisms for marine debris to reduce the impacts on the marine environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c97514b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminating incentives that undermine responsible post-consumer materials management practices and lead to improper waste disposal practices and leakage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c97514c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" building the capacity of countries—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c97514d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce, monitor, regulate, and manage waste, post-consumer materials and plastic waste, and pollution appropriately and transparently, including imports of plastic waste from the United States and other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c97514e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage private investment in post-consumer materials management and reduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c97514f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage private investment, grow opportunities, and develop markets for recyclable, reusable, and repurposed plastic waste and post-consumer materials, and products with high levels of recycled plastic content, at both national and local levels; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c975150-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting safe and affordable reusable alternatives to disposable plastic products, to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c975151-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to research, identify, and facilitate opportunities to promote collection and proper disposal of damaged or derelict fishing gear.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c975152-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officials specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officials specified in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c975153-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975154-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975155-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The EPA Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975156-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Trade and Development Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975157-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President and the Board of Directors of the Overseas Private Investment Corporation or the Chief Executive Officer and the Board of Directors of the United States International Development Finance Corporation, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975158-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Executive Officer and the Board of Directors of the Millennium Challenge Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c975159-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant of the Coast Guard, with respect to pollution from ships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c97515a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The heads of such other agencies as the Secretary of State considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c97515b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the officials specified in subsection (b) shall prioritize assistance to countries with, and regional organizations in regions with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c97515c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rapidly developing economies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c97515d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rivers and coastal areas that are the most severe sources of marine debris, as identified by the best available science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c97515e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness measurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prioritizing and expediting efforts and assistance under this section, the officials specified in subsection (b) shall use clear, accountable, and metric-based targets to measure the effectiveness of guarantees and assistance in achieving the policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s4261"},"text":"section 4261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c97515f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s4262/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to authorize the modification of or the imposition of limits on the portfolios of any agency or institution led by an official specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c975160-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/224/tII/s202"},"text":"Pub. L. 116–224, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1087"},"text":"134 Stat. 1087","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
