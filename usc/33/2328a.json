{"tag":"section","attrib":{"id":"id6c595e1d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2328a"},"text":"§ 2328a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special use permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c595e1e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special use permits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595e1f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue special permits for uses such as group activities, recreation events, motorized recreation vehicles, and such other specialized recreation uses as the Secretary determines to be appropriate, subject to such terms and conditions as the Secretary determines to be in the best interest of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e20-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595e21-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595e22-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and collect fees associated with the issuance of the permits described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595e23-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept in-kind services in lieu of those fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595e24-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outdoor recreation equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish and collect fees for the provision of outdoor recreation equipment and services for activities described in paragraph (1) at public recreation areas located at lakes and reservoirs operated by the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595e25-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fees generated pursuant to this subsection shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595e26-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retained at the site collected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595e27-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available for use, without further appropriation, solely for administering the special permits under this subsection and carrying out related operation and maintenance activities at the site at which the fees are collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595e28-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595e29-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id6c595e2a-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the Secretary may enter into an agreement with a State or local government to provide for the cooperative management of a public recreation area if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id6c595e2b-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the public recreation area is located—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id6c595e2c-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a lake or reservoir operated by the Corps of Engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id6c595e2d-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjacent to or near a State or local park or recreation area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id6c595e2e-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that cooperative management between the Corps of Engineers and a State or local government agency of a portion of the Corps of Engineers recreation area or State or local park or recreation area will allow for more effective and efficient management of those areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id6c595e2f-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not transfer administration responsibilities for any public recreation area operated by the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e30-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of goods and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may acquire from or provide to a State or local government with which the Secretary has entered into a cooperative agreement under paragraph (1) goods and services to be used by the Secretary and the State or local government in the cooperative management of the areas covered by the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e31-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into 1 or more cooperative management agreements or such other arrangements as the Secretary determines to be appropriate, including leases or licenses, with non-Federal interests to share the costs of operation, maintenance, and management of recreation facilities and natural resources at recreation areas that are jointly managed and funded under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c595e32-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c595e33-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that it is in the public interest for purposes of enhancing recreation opportunities at Corps of Engineers water resources development projects, the Secretary may use funds made available to the Secretary to support activities carried out by State, local, and tribal governments and such other public or private nonprofit entities as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c595e34-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2328a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any use of funds pursuant to this subsection shall be carried out through the execution of a cooperative agreement, which shall contain such terms and conditions as the Secretary determines to be necessary in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c595e35-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/tI/s1047"},"text":"Pub. L. 113–121, title I, § 1047","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-06-10"},"text":"June 10, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1255"},"text":"128 Stat. 1255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c595e36-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c595e37-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6c595e38-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Water Resources Reform and Development Act of 2014, and not as part of the Water Resources Development Act of 1986 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1047"},"text":"section 1047 of Pub. L. 113–121","children":[],"tail":". Subsecs. (d) and (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/121/s1047"},"text":"section 1047 of Pub. L. 113–121","children":[],"tail":" amended sections 569c and 2339 of this title, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id6c595e39-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id6c595e3a-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Army, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/121/s2"},"text":"section 2 of Pub. L. 113–121","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
