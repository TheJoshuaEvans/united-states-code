{"tag":"section","attrib":{"id":"id6c86aeb3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3504b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3504b"},"text":"§ 3504b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements and financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c86aeb4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3504b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations for such purpose, the head of a Federal agency that is represented on the Interagency Committee on Ocean and Coastal Mapping may enter into agreements with any other agency that is so represented to provide, on a reimbursable or nonreimbursable basis, facilities, equipment, services, personnel, and other support services to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c86aeb5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s3504b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make financial assistance awards (grants of cooperative agreements) to any State or subdivision thereof or any public or private organization or individual to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c86aeb6-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXII/s12207"},"text":"Pub. L. 111–11, title XII, § 12207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCIII/s10307/e/2"},"text":"Pub. L. 117–263, div. J, title CIII, § 10307(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3979"},"text":"136 Stat. 3979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c86aeb7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c86aeb8-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id6c86aeb9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/s12207"},"text":"section 12207 of Pub. L. 111–11","children":[],"tail":" was renumbered section 12209 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s3506"},"text":"section 3506 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
