{"tag":"section","attrib":{"id":"id6b0454bb-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"§ 24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Big Tarkio River, Missouri","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Big Tarkio River, in the counties of Holt and Atchison, in the State of Missouri, is declared to be not a navigable water of the United States within the meaning of the laws enacted by Congress for the preservation and protection of such waters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The right to alter, amend, or repeal this section is expressly reserved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id6b0454bc-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-02-15/ch33"},"text":"Feb. 15, 1910, ch. 33","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/36/194"},"text":"36 Stat. 194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6b0454bd-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6b0454be-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id6b0454bf-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first sentence hereof is section 1 and the last sentence section 2 of act ","children":[{"tag":"date","attrib":{"date":"1910-02-15"},"text":"Feb. 15, 1910","children":[],"tail":", entitled “An Act to declare Big Tarkio River, in Holt and Atchison counties, Missouri, nonnavigable”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
