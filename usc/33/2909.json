{"tag":"section","attrib":{"id":"id6c760da1-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2909"},"text":null,"children":[{"tag":"num","attrib":{"value":"2909"},"text":"§ 2909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id6c760da2-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency consultation and coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, the Secretary shall, as necessary, consult with, cooperate with, and coordinate its activities with the activities of other Federal departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760da3-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements; memoranda of understanding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id6c760da4-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2909/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into cooperative agreements or contracts with Federal, State, and local government agencies, nongovernmental organizations, and other entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id6c760da5-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2909/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute such memoranda of understanding as are necessary to reflect the agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id6c760da6-3a70-11f1-9100-cf79f4fb4b3e","identifier":"/us/usc/t33/s2909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency facilities and personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal agencies may cooperate in carrying out scientific and other programs necessary to carry out this chapter, and may provide facilities and personnel, for the purpose of assisting the Council in carrying out its duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id6c760da7-3a70-11f1-9100-cf79f4fb4b3e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/457/tI/s110"},"text":"Pub. L. 106–457, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1966"},"text":"114 Stat. 1966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/114/tV/s5017/h"},"text":"Pub. L. 110–114, title V, § 5017(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-11-08"},"text":"Nov. 8, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1199"},"text":"121 Stat. 1199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id6c760da8-3a70-11f1-9100-cf79f4fb4b3e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id6c760da9-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id6c760daa-3a70-11f1-9100-cf79f4fb4b3e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/h/1"},"text":"Pub. L. 110–114, § 5017(h)(1)","children":[],"tail":", inserted “or contracts” after “agreements” and “, nongovernmental organizations,” after “agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/114/s5017/h/2"},"text":"Pub. L. 110–114, § 5017(h)(2)","children":[],"tail":", struck out subsecs. (d) and (e) which related to identification and mapping of dredged material disposal sites and study of bioremediation technology, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
