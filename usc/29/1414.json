{"tag":"section","attrib":{"id":"id5b4d32a6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1414"},"text":null,"children":[{"tag":"num","attrib":{"value":"1414"},"text":"§ 1414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset transfer rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b4d32a7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability and scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A transfer of assets from a multiemployer plan to another plan shall comply with asset-transfer rules which shall be adopted by the multiemployer plan and which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4d32a8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not unreasonably restrict the transfer of plan assets in connection with the transfer of plan liabilities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4d32a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate and are applied uniformly with respect to each proposed transfer, except that the rules may provide for reasonable variations taking into account the potential financial impact of a proposed transfer on the multiemployer plan.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Plan rules authorizing asset transfers consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1412/c/3"},"text":"section 1412(c)(3) of this title","children":[],"tail":" shall be considered to satisfy the requirements of this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4d32aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of de minimis transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall prescribe regulations which exempt de minimis transfers of assets from the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4d32ab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written reciprocity agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part shall not apply to transfers of assets pursuant to written reciprocity agreements, except to the extent provided in regulations prescribed by the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4d32ac-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4234"},"text":"Pub. L. 93–406, title IV, § 4234","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1247"},"text":"94 Stat. 1247","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
