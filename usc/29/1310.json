"tag":"ref","attrib":{"href":"/us/pl/109/280/s108/b/3"},"text":"section 108(b)(3) of Pub. L. 109–280","children":[],"tail":" applicable to plan years beginning after 2007, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s108/e"},"text":"section 108(e) of Pub. L. 109–280","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1021"},"text":"section 1021 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tV/s505/c"},"text":"Pub. L. 109–280, title V, § 505(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/946"},"text":"120 Stat. 946","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tV/s505/c"},"text":"“The amendments made by this section [amending this section] shall apply with respect to years beginning after 2007.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b32f473-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVII/s772/c"},"text":"Pub. L. 103–465, title VII, § 772(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5044"},"text":"108 Stat. 5044","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/465/tVII/s772/c"},"text":"“The amendments made by this section [enacting this section] shall be effective on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b32f474-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Amendments by Subtitles A and B of Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"For special rules on applicability of amendments by subtitles A (§§ 101–108) and B (§§ 111–116) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" to certain eligible cooperative plans, PBGC settlement plans, and eligible government contractor plans, see sections 104, 105, and 106 of "},{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
