{"tag":"section","attrib":{"id":"id5a0ff878-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f"},"text":null,"children":[{"tag":"num","attrib":{"value":"49f"},"text":"§ 49f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage disposition of allotted funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a0ff879-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of 90 percent of funds allotted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Ninety percent of the sums allotted to each State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s49e"},"text":"section 49e of this title","children":[],"tail":" may be used—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a0ff87a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for job search and placement services to job seekers, including unemployment insurance claimants, including counseling, testing, occupational and labor market information, assessment, and referral to employers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff87b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for appropriate recruitment services and special technical services for employers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff87c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a0ff87d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff87e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing linkages between services funded under this chapter and related Federal or State legislation, including the provision of labor exchange services at education sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff87f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing services for workers who have received notice of permanent layoff or impending layoff, or workers in occupations which are experiencing limited demand due to technological change, impact of imports, or plant closures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff880-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and providing labor market and occupational information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff881-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a management information system and compiling and analyzing reports therefrom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff882-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering the work test for the State unemployment compensation system, including making eligibility assessments, and providing job finding and placement services for unemployment insurance claimants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff883-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing unemployment insurance claimants with referrals to, and application assistance for, training and education resources and programs, including Federal Pell Grants under subpart 1 of part A of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a"},"text":"20 U.S.C. 1070a","children":[],"tail":" et seq.), educational assistance under chapter 30 of title 38 (commonly referred to as the Montgomery GI Bill), and chapter 33 of that title (Post-9/11 Veterans Educational Assistance), student assistance under title IV of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.), State student higher education assistance, and training and education programs provided under titles I and II of the Workforce Innovation and Opportunity Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3111"},"text":"29 U.S.C. 3111","children":[],"tail":" et seq., 3271 et seq.], and title I of the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s720"},"text":"29 U.S.C. 720","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a0ff884-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of 10 percent of funds allotted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Ten percent of the sums allotted to each State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s49e"},"text":"section 49e of this title","children":[],"tail":" shall be reserved for use in accordance with this subsection by the Governor of each such State to provide—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a0ff885-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance incentives for public employment service offices and programs, consistent with the performance accountability measures that are based on indicators described in section 116(b)(2)(A)(i) of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/2/A/i"},"text":"29 U.S.C. 3141(b)(2)(A)(i)","children":[],"tail":"], taking into account direct or indirect placements (including those resulting from self-directed job search or group job search activities assisted by such offices or programs), wages on entered employment, retention, and other appropriate factors;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff886-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services for groups with special needs, carried out pursuant to joint agreements between the employment service offices and the appropriate local workforce investment board and chief elected official or officials or other public agencies or private nonprofit organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff887-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extra costs of exemplary models for delivering services of the types described in subsection (a), and models for enhancing professional development and career advancement opportunities of State agency staff, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s49b/c/4"},"text":"section 49b(c)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a0ff888-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a0ff889-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds made available to States under this section may be used to provide additional funds under an applicable program if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a0ff88a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program otherwise meets the requirements of this chapter and the requirements of the applicable program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff88b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program serves the same individuals that are served under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff88c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such program provides services in a coordinated manner with services provided under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a0ff88d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such funds would be used to supplement, and not supplant, funds provided from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff88e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term “applicable program” means any workforce investment activity carried out under the Workforce Innovation and Opportunity Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a0ff88f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of services and activities under contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the services and activities otherwise authorized by this chapter, the Secretary or any State agency designated under this chapter may perform such other services and activities as shall be specified in contracts for payment or reimbursement of the costs thereof made with the Secretary or with any Federal, State, or local public agency, or administrative entity under the Workforce Innovation and Opportunity Act, or private nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a126890-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services as part of one-stop delivery system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All job search, placement, recruitment, workforce and labor market information, and other labor exchange services authorized under subsection (a) shall be provided, consistent with the other requirements of this chapter, as part of the one-stop delivery system established by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a126891-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-06/ch49/s7"},"text":"June 6, 1933, ch. 49, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/tVI/s601/c"},"text":"Pub. L. 97–300, title VI, § 601(c)","children":[],"tail":", formerly title V, § 501(c), "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1394"},"text":"96 Stat. 1394","children":[],"tail":"; renumbered title VI, § 601(c), "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVII/s712/a/1"},"text":"Pub. L. 100–628, title VII, § 712(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3248"},"text":"102 Stat. 3248","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/392/s5/b"},"text":"Pub. L. 101–392, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-09-25"},"text":"Sept. 25, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/759"},"text":"104 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIII"},"text":"Pub. L. 105–220, title III","children":[],"tail":", §§ 305, 310, "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1081"},"text":"112 Stat. 1081","children":[],"tail":", 1086; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIII/s305"},"text":"Pub. L. 113–128, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1626"},"text":"128 Stat. 1626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a126892-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a126893-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a126894-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (a)(3)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 1070 et seq.) of chapter 28 of Title 20, Education. Subpart 1 of part A of title IV of the Act is classified generally to subpart 1 (§ 1070a et seq.) of part A of subchapter IV of chapter 28 of Title 20. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in subsecs. (a)(3)(G), (c)(2), and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":", which enacted chapter 32 (§ 3101 et seq.) of this title, repealed chapter 30 (§ 2801 et seq.) of this title and chapter 73 (§ 9201 et seq.) of Title 20, Education, and made conforming amendments to numerous other sections and notes in the Code. Titles I and II of the Act are classified generally to subchapters I (§ 3111 et seq.) and II (§ 3271 et seq.), respectively, of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rehabilitation Act of 1973, referred to in subsec. (a)(3)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/355"},"text":"87 Stat. 355","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 720 et seq.) of chapter 16 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"section 701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a126895-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 49f, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-06/ch49/s7"},"text":"act June 6, 1933, ch. 49, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/115"},"text":"48 Stat. 115","children":[],"tail":", related to ascertainment of amounts due to States, and certification to the Secretary of the Treasury, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch933/s3"},"text":"act Sept. 8, 1950, ch. 933, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/823"},"text":"64 Stat. 823","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a126896-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/a"},"text":"Pub. L. 113–128, § 305(a)","children":[],"tail":", inserted “, including unemployment insurance claimants,” after “seekers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/b/2/A"},"text":"Pub. L. 113–128, § 305(b)(2)(A)","children":[],"tail":", inserted “, including making eligibility assessments,” after “system”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/b/1"},"text":"Pub. L. 113–128, § 305(b)(1)","children":[],"tail":", (2)(B), (3), added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/c/1"},"text":"Pub. L. 113–128, § 305(c)(1)","children":[],"tail":", substituted “the performance accountability measures that are based on indicators described in section 116(b)(2)(A)(i) of the Workforce Innovation and Opportunity Act” for “performance standards established by the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/c/2"},"text":"Pub. L. 113–128, § 305(c)(2)","children":[],"tail":", inserted “offices” after “employment service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/c/3"},"text":"Pub. L. 113–128, § 305(c)(3)","children":[],"tail":", inserted “, and models for enhancing professional development and career advancement opportunities of State agency staff, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s49b/c/4"},"text":"section 49b(c)(4) of this title","children":[],"tail":"” after “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(2), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/d"},"text":"Pub. L. 113–128, § 305(d)","children":[],"tail":", substituted “the Workforce Innovation and Opportunity Act” for “the Workforce Investment Act of 1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s305/e"},"text":"Pub. L. 113–128, § 305(e)","children":[],"tail":", substituted “workforce and labor market information” for “labor employment statistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220/s305/1"},"text":"Pub. L. 105–220, § 305(1)","children":[],"tail":", substituted “local workforce investment board” for “private industry council”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220/s305/2"},"text":"Pub. L. 105–220, § 305(2)","children":[],"tail":", substituted “any workforce investment activity carried out under the Workforce Investment Act of 1998.” for “any program under any of the following provisions of law:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) The Carl D. Perkins Vocational and Applied Technology Education Act.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Section 123, title II, and title III of the Job Training Partnership Act.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220/s310"},"text":"Pub. L. 105–220, § 310","children":[],"tail":", substituted “Secretary or with” for “Secretary of Labor or with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220/s305/3"},"text":"Pub. L. 105–220, § 305(3)","children":[],"tail":", substituted “Secretary or any State” for “United States Employment Service or any State” and “Workforce Investment Act of 1998” for “Job Training Partnership Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220/s305/4"},"text":"Pub. L. 105–220, § 305(4)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib