{"tag":"section","attrib":{"id":"id5aa162df-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d"},"text":null,"children":[{"tag":"num","attrib":{"value":"796d"},"text":"§ 796d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewide Independent Living Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aa162e0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive financial assistance under this part, each State shall establish and maintain a Statewide Independent Living Council (referred to in this section as the “Council”). The Council shall not be established as an entity within a State agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa162e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition and appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa162e2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council shall be appointed by the Governor or, in the case of a State that, under State law, vests authority for the administration of the activities carried out under this chapter in an entity other than the Governor (such as one or more houses of the State legislature or an independent board), the chief officer of that entity. The appointing authority shall select members after soliciting recommendations from representatives of organizations representing a broad range of individuals with disabilities and organizations interested in individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa162e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among its voting members, at least 1 director of a center for independent living chosen by the directors of centers for independent living within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among its voting members, for a State in which 1 or more centers for independent living are run by, or in conjunction with, the governing bodies of American Indian tribes located on Federal or State reservations, at least 1 representative of the directors of such centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as ex officio, nonvoting members, a representative of the designated State entity, and representatives from State agencies that provide services for individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa162e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other representatives from centers for independent living;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parents and guardians of individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocates of and for individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from private businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from organizations that provide services for individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa162f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of members—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa162f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who provide statewide representation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa162f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who represent a broad range of individuals with disabilities from diverse backgrounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa162f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are knowledgeable about centers for independent living and independent living services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa162f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a majority of whom are persons who are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5aa162f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/20/B"},"text":"section 705(20)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5aa162f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not employed by any State agency or center for independent living.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A majority of the voting members of the Council shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa162f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/20/B"},"text":"section 705(20)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa162f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not employed by any State agency or center for independent living.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa162fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Council shall select a chairperson from among the voting membership of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation by chief executive officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In States in which the Governor does not have veto power pursuant to State law, the appointing authority described in paragraph (1) shall designate a voting member of the Council to serve as the chairperson of the Council or shall require the Council to so designate such a voting member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa162fe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Council shall serve for a term of 3 years, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa162ff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member appointed to fill a vacancy occurring prior to the expiration of the term for which a predecessor was appointed, shall be appointed for the remainder of such term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa16300-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of service of the members initially appointed shall be (as specified by the appointing authority described in paragraph (3)) for such fewer number of years as will provide for the expiration of terms on a staggered basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa16301-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No member of the Council, other than a representative described in paragraph (2)(A) if there is only one center for independent living within the State, may serve more than two consecutive full terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa16302-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa16303-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), any vacancy occurring in the membership of the Council shall be filled in the same manner as the original appointment. The vacancy shall not affect the power of the remaining members to execute the duties of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa16304-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointing authority described in paragraph (3) may delegate the authority to fill such a vacancy to the remaining voting members of the Council after making the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16305-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa16306-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa16307-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop the State plan as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796c/a/2"},"text":"section 796c(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa16308-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor, review, and evaluate the implementation of the State plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa16309-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet regularly, and ensure that such meetings of the Council are open to the public and sufficient advance notice of such meetings is provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa1630a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Administrator such periodic reports as the Administrator may reasonably request, and keep such records, and afford such access to such records, as the Administrator finds necessary to verify the information in such reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa1630b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, coordinate activities with other entities in the State that provide services similar to or complementary to independent living services, such as entities that facilitate the provision of or provide long-term community-based services and supports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa1630c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council may, consistent with the State plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796c"},"text":"section 796c of this title","children":[],"tail":", unless prohibited by State law—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa1630d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to improve services provided to individuals with disabilities, work with centers for independent living to coordinate services with public and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa1630e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct resource development activities to support the activities described in this subsection or to support the provision of independent living services by centers for independent living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa1630f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions, consistent with the purpose of this part and comparable to other functions described in this subsection, as the Council determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa16310-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall not provide independent living services directly to individuals with significant disabilities or manage such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16311-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and forums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council is authorized to hold such hearings and forums as the Council may determine to be necessary to carry out the duties of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16312-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa16313-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall prepare, in conjunction with the designated State entity, a plan for the provision of such resources, including such staff and personnel, as may be necessary and sufficient to carry out the functions of the Council under this section, with funds made available under this part, and under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s730"},"text":"section 730 of this title","children":[],"tail":" (consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/18"},"text":"section 721(a)(18) of this title","children":[],"tail":"), and from other public and private sources. The resource plan shall, to the maximum extent possible, rely on the use of resources in existence during the period of implementation of the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa16314-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision and evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Council shall, consistent with State law, supervise and evaluate such staff and other personnel as may be necessary to carry out the functions of the Council under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa16315-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While assisting the Council in carrying out its duties, staff and other personnel shall not be assigned duties by the designated State entity or any other agency or office of the State, that would create a conflict of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16316-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may use available resources to reimburse members of the Council for reasonable and necessary expenses of attending Council meetings and performing Council duties (such as personal assistance services), and to pay reasonable compensation to a member of the Council, if such member is not employed or must forfeit wages from other employment, for each day the member is engaged in performing Council duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa16317-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s705"},"text":"Pub. L. 93–112, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1220"},"text":"112 Stat. 1220","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/c/7"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(c)(7)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–416; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s475"},"text":"Pub. L. 113–128, title IV, § 475","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1687"},"text":"128 Stat. 1687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa16318-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa16319-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa1631a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s705"},"text":"Pub. L. 93–112, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4446"},"text":"106 Stat. 4446","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/c"},"text":"Pub. L. 103–73, title I, § 114(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/728"},"text":"107 Stat. 728","children":[],"tail":", related to Statewide Independent Living Councils, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 796d, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s705"},"text":"Pub. L. 93–112, title VII, § 705","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tIII/s301"},"text":"Pub. L. 95–602, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2997"},"text":"92 Stat. 2997","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tI/s103/d/2/B"},"text":"Pub. L. 99–506, title I, § 103(d)(2)(B)","children":[],"tail":", (C), (h)(2), title VIII, § 802, title X, § 1001(g)(3), "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1810"},"text":"100 Stat. 1810","children":[],"tail":", 1811, 1837, 1843; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s208/d"},"text":"Pub. L. 100–630, title II, § 208(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3314"},"text":"102 Stat. 3314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/119/s26/e"},"text":"Pub. L. 102–119, § 26(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-07"},"text":"Oct. 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/607"},"text":"105 Stat. 607","children":[],"tail":", related to State plans for providing comprehensive services for independent living, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/s701/1"},"text":"Pub. L. 102–569, § 701(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa1631b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/1"},"text":"Pub. L. 113–128, § 475(1)","children":[],"tail":", inserted “and maintain” after “shall establish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/2/A/i"},"text":"Pub. L. 113–128, § 475(2)(A)(i)","children":[],"tail":", inserted “among its voting members,” before “at least” and substituted “1” for “one”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/2/A/ii"},"text":"Pub. L. 113–128, § 475(2)(A)(ii)","children":[],"tail":", added subpars. (B) and (C) and struck out former subpars. (B) and (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) as ex officio, nonvoting members—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) a representative from the designated State unit; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) representatives from other State agencies that provide services for individuals with disabilities; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) in a State in which one or more projects are carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s741"},"text":"section 741 of this title","children":[],"tail":", at least one representative of the directors of the projects.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/2/B/ii"},"text":"Pub. L. 113–128, § 475(2)(B)(ii)","children":[],"tail":", struck out “parents and guardians of” before “individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/2/B/i"},"text":"Pub. L. 113–128, § 475(2)(B)(i)","children":[],"tail":", (iii), added subpar. (C) and redesignated former subpars. (C) to (F) as (D) to (G), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/2/C"},"text":"Pub. L. 113–128, § 475(2)(C)","children":[],"tail":", substituted “paragraph (1)” for “paragraph (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/2/D"},"text":"Pub. L. 113–128, § 475(2)(D)","children":[],"tail":", inserted “, other than a representative described in paragraph (2)(A) if there is only one center for independent living within the State,” after “the Council”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/3"},"text":"Pub. L. 113–128, § 475(3)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to duties of the Council."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/4/A"},"text":"Pub. L. 113–128, § 475(4)(A)","children":[],"tail":", substituted “prepare, in conjunction with the designated State entity, a plan” for “prepare, in conjunction with the designated State unit, a plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/4/B"},"text":"Pub. L. 113–128, § 475(4)(B)","children":[],"tail":", substituted “State entity” for “State agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s475/5"},"text":"Pub. L. 113–128, § 475(5)","children":[],"tail":", substituted “available resources” for “such resources” and “(such as personal assistance services), and to pay reasonable compensation” for “(including child care and personal assistance services), and to pay compensation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s402/c/7/A"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 402(c)(7)(A)]","children":[],"tail":", in first sentence, substituted “by the Governor or, in the case of a State that, under State law, vests authority for the administration of the activities carried out under this chapter in an entity other than the Governor (such as one or more houses of the State legislature or an independent board), the chief officer of that entity” for “by the Governor” and, in second sentence, substituted “The appointing authority” for “The Governor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s402/c/7/B"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 402(c)(7)(B)]","children":[],"tail":", substituted “chief executive officer” for “Governor” in heading and “appointing authority described in paragraph (3) shall” for “Governor shall” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6)(A)(ii), (7)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s402/c/7/C"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 402(c)(7)(C)]","children":[],"tail":", substituted “appointing authority described in paragraph (3)” for “Governor”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
