{"tag":"section","attrib":{"id":"id5b46076f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385"},"text":null,"children":[{"tag":"num","attrib":{"value":"1385"},"text":"§ 1385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial withdrawals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b460770-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinative factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, there is a partial withdrawal by an employer from a plan on the last day of a plan year if for such plan year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b460771-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a 70-percent contribution decline, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b460772-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a partial cessation of the employer’s contribution obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b460773-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b460774-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b460775-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a 70-percent contribution decline for any plan year if during each plan year in the 3-year testing period the employer’s contribution base units do not exceed 30 percent of the employer’s contribution base units for the high base year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b460776-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b460777-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “3-year testing period” means the period consisting of the plan year and the immediately preceding 2 plan years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b460778-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of contribution base units for the high base year is the average number of such units for the 2 plan years for which the employer’s contribution base units were the highest within the 5 plan years immediately preceding the beginning of the 3-year testing period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b460779-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b46077a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is a partial cessation of the employer’s contribution obligation for the plan year if, during such year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b46077b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer permanently ceases to have an obligation to contribute under one or more but fewer than all collective bargaining agreements under which the employer has been obligated to contribute under the plan but continues to perform work in the jurisdiction of the collective bargaining agreement of the type for which contributions were previously required or transfers such work to another location or to an entity or entities owned or controlled by the employer, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b46077c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer permanently ceases to have an obligation to contribute under the plan with respect to work performed at one or more but fewer than all of its facilities, but continues to perform work at the facility of the type for which the obligation to contribute ceased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b46077d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subparagraph (A), a cessation of obligations under a collective bargaining agreement shall not be considered to have occurred solely because, with respect to the same plan, one agreement that requires contributions to the plan has been substituted for another agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b46077e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail food industry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b46077f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a plan in which a majority of the covered employees are employed in the retail food industry, the plan may be amended to provide that this section shall be applied with respect to such plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b460780-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “35 percent” for “70 percent” in subsections (a) and (b), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b460781-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “65 percent” for “30 percent” in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b460782-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amendment adopted under paragraph (1) shall provide rules for the equitable reduction of withdrawal liability in any case in which the number of the plan’s contribution base units, in the 2 plan years following the plan year of withdrawal of the employer, is higher than such number immediately after the withdrawal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b460783-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1388"},"text":"Section 1388 of this title","children":[],"tail":" shall not apply to a plan which has been amended under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b460784-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1385/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of liability of employer for partial withdrawal under amended plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s404/c"},"text":"section 404(c) of title 26","children":[],"tail":", or a continuation thereof, the plan may be amended to provide rules setting forth other conditions consistent with the purposes of this chapter under which an employer has liability for partial withdrawal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b460785-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4205"},"text":"Pub. L. 93–406, title IV, § 4205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1221"},"text":"94 Stat. 1221","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7891/a/1"},"text":"Pub. L. 101–239, title VII, § 7891(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2445"},"text":"103 Stat. 2445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tII/s204/b/1"},"text":"Pub. L. 109–280, title II, § 204(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/887"},"text":"120 Stat. 887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b460786-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b460787-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b460788-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", known as the Employee Retirement Income Security Act of 1974. Titles I, III, and IV of such Act are classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b460789-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" inserted “or to an entity or entities owned or controlled by the employer” after “to another location”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b46078a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b46078b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tII/s204/b/2"},"text":"Pub. L. 109–280, title II, § 204(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/887"},"text":"120 Stat. 887","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tII/s204/b/2"},"text":"“The amendment made by this subsection [amending this section] shall apply with respect to work transferred on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b46078c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/f"},"text":"section 7891(f) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b46078d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability to Certain Employers Engaged in Trade or Business of Shipping Bulk Cargoes in Great Lakes Maritime Industry","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s108/c/2"},"text":"Pub. L. 96–364, title I, § 108(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1268"},"text":"94 Stat. 1268","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/364/tI/s108/c/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of applying section 4205 of the Employee Retirement Income Security Act of 1974 [this section] in the case of an employer described in subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ‘more than 75 percent’ shall be substituted for ‘70 percent’ in subsections (a) and (b) of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ‘25 percent or less’ shall be substituted for ‘30 percent’ in subsection (b) of such section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of contribution units for the high base year shall be the average annual number of such units for calendar years 1970 and 1971.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employer is described in this subparagraph if—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer is engaged in the trade or business of shipping bulk cargoes in the Great Lakes Maritime Industry, and whose fleet consists of vessels the gross registered tonnage of which was at least 7,800, as stated in the American Bureau of Shipping Record, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose fleet during any 5 years from the period 1970 through and including 1979 has experienced a 33 percent or more increase in the contribution units as measured from the average annual contribution units for the calendar years 1970 and 1971.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b46078e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability to Specified Plan Year, Cessation of Contribution Obligations, and Contribution Base Units of Employer","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s108/d"},"text":"Pub. L. 96–364, title I, § 108(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1269"},"text":"94 Stat. 1269","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tV/s558/b/2"},"text":"Pub. L. 98–369, div. A, title V, § 558(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/899"},"text":"98 Stat. 899","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/369/dA/tV/s558/b/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For purposes of section 4205 of the Employee Retirement Income Security Act of 1974 [this section]—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a)(1) of such section shall not apply to any plan year beginning before ","children":[{"tag":"date","attrib":{"date":"1982-09-26"},"text":"September 26, 1982","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a)(2) of such section shall not apply with respect to any cessation of contribution obligations occurring before ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in applying subsection (b) of such section, the employer’s contribution base units for any plan year ending before ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", shall be deemed to be equal to the employer’s contribution base units for the last plan year ending before such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b46078f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Liability of Certain Employers Announcing Publicly Before ","children":[{"tag":"date","attrib":{"date":"1979-12-13"},"text":"December 13, 1979","children":[],"tail":", Total Cessation of Covered Operations at a Facility in a State; Amount, Coverage, Determinative Factors, Etc."}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s108/e"},"text":"Pub. L. 96–364, title I, § 108(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1269"},"text":"94 Stat. 1269","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/364/tI/s108/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a partial withdrawal under section 4205 of the Employee Retirement Income Security Act of 1974 [this section], an employer who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1979-12-13"},"text":"December 13, 1979","children":[],"tail":", had publicly announced the total cessation of covered operations at a facility in a State (and such cessation occurred within 12 months after the announcement),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had not been obligated to make contributions to the plan on behalf of the employees at such facility for more than 8 years before the discontinuance of contributions, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the discontinuance of contributions does not within 1 year after the date of the partial withdrawal perform work in the same State of the type for which contributions were previously required,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be liable under such section with respect to such partial withdrawal in an amount not greater than the amount determined under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount determined under this paragraph is the excess (if any) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the present value (on the withdrawal date) of the benefits under the plan which—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were vested on the withdrawal date (or, if earlier, at the time of separation from service with the employer at the facility),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were accrued by employees who on ","children":[{"tag":"date","attrib":{"date":"1979-12-13"},"text":"December 13, 1979","children":[],"tail":" (or, if earlier, at the time of separation from service with the employer at the facility), were employed at the facility, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are attributable to service with the withdrawing employer, over","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all employer contributions to the plan on behalf of employees at the facility before the withdrawal date,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest (to the withdrawal date) on amounts described in subclause (I), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"“(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000, reduced by","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits paid under the plan on or before the withdrawal date with respect to former employees who separated from employment at the facility, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest (to the withdrawal date) on amounts described in subclause (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actuarial assumptions shall be those used in the last actuarial report completed before ","children":[{"tag":"date","attrib":{"date":"1979-12-13"},"text":"December 13, 1979","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘withdrawal date’ means the date on which the employer ceased work at the facility of the type for which contributions were previously required, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘facility’ means the facility referred to in paragraph (1).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
