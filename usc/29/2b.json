{"tag":"section","attrib":{"id":"id5a068259-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2b"},"text":"§ 2b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies of productivity and labor costs in industries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Bureau of Labor Statistics of the United States Department of Labor is authorized and directed to make continuing studies of productivity and labor costs in the manufacturing, mining, transportation, distribution, and other industries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a06825a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-07/ch267"},"text":"June 7, 1940, ch. 267","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/249"},"text":"54 Stat. 249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1076/s1/27"},"text":"Aug. 30, 1954, ch. 1076, § 1(27)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/968"},"text":"68 Stat. 968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a06825b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a06825c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a06825d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision of this section authorizing appropriations of up to $100,000 for studies by the bureau in the first fiscal year was omitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a06825e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-30"},"text":"Aug. 30, 1954","children":[],"tail":", repealed second par. which required Secretary of Labor to submit annually to Congress reports of findings under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5a06825f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5a068260-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of Labor, with certain exceptions, to Secretary of Labor, with power to delegate, see Reorg. Plan No. 6 of 1950, §§ 1, 2, 15 F.R. 3174, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
