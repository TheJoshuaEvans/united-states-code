{"tag":"section","attrib":{"id":"id5b6771e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620"},"text":null,"children":[{"tag":"num","attrib":{"value":"2620"},"text":"§ 2620.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health emergency leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b6771e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following shall apply with respect to leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6771e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611"},"text":"section 2611 of this title","children":[],"tail":" shall apply, except as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employee","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b6771ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In lieu of the definition in sections 2611(2)(A) and 2611(2)(B)(ii) of this title, the term “eligible employee” means an employee who has been employed for at least 30 calendar days by the employer with respect to whom leave is requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b6771eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002194"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002194"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two cls. (ii) have been enacted."}],"tail":" Rule regarding rehired employees"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of clause (i), the term “employed for at least 30 calendar days”, used with respect to an employee and an employer described in clause (i), includes an employee who was laid off by that employer not earlier than ","children":[{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":", had worked for the employer for not less than 30 of the last 60 calendar days prior to the employee’s layoff, and was rehired by the employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b6771ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Special rule"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":" and this section under the Congressional Accountability Act of 1995 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"2 U.S.C. 1301","children":[],"tail":" et seq.], in lieu of the definition in section 202(a)(2)(B) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1312/a/2/B"},"text":"2 U.S.C. 1312(a)(2)(B)","children":[],"tail":"), the term “eligible employee” means a covered employee (as defined in section 101 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"2 U.S.C. 1301","children":[],"tail":")) who has been employed for at least 30 calendar days by the employing office (as so defined) with respect to whom leave is requested under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer threshold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611/4/A/i"},"text":"Section 2611(4)(A)(i) of this title","children":[],"tail":" shall be applied by substituting “fewer than 500 employees” for “50 or more employees for each working day during each of 20 or more calendar workweeks in the current or preceding calendar year”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the definitions described in paragraph (1), the following definitions shall apply with respect to leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":":"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying need related to a public health emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying need related to a public health emergency”, with respect to leave, means the employee is unable to work (or telework) due to a need for leave to care for the son or daughter under 18 years of age of such employee if the school or place of care has been closed, or the child care provider of such son or daughter is unavailable, due to a public health emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public health emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public health emergency” means an emergency with respect to COVID–19 declared by a Federal, State, or local authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child care provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child care provider” means a provider who receives compensation for providing child care services on a regular basis, including an “eligible child care provider” (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858n"},"text":"section 9858n of title 42","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “school” means an “elementary school” or “secondary school” as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor shall have the authority to issue regulations for good cause under sections 553(b)(B) and 553(d)(3) of title 5—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exclude certain health care providers and emergency responders from the definition of eligible employee under subsection (a)(1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exempt small businesses with fewer than 50 employees from the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":" when the imposition of such requirements would jeopardize the viability of the business as a going concern; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as necessary to carry out the purposes of this Act, including to ensure consistency between this Act and Division E and Division G of the Families First Coronavirus Response Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget shall have the authority to exclude for good cause from the requirements under subsection (b) certain employers of the United States Government with respect to certain categories of Executive Branch employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b6771f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to paid leave","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6771f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unpaid leave for initial 10 days","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first 10 days for which an employee takes leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":" may consist of unpaid leave."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee may elect to substitute any accrued vacation leave, personal leave, or medical or sick leave for unpaid leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":" in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/d/2/B"},"text":"section 2612(d)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paid leave for subsequent days","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer shall provide paid leave for each day of leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":" that an employee takes after taking leave under such section for 10 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771fe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b6771ff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to clause (ii), paid leave under subparagraph (A) for an employee shall be calculated based on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b677200-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that is not less than two-thirds of an employee’s regular rate of pay (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s207/e"},"text":"section 207(e) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b677201-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours the employee would otherwise be normally scheduled to work (or the number of hours calculated under subparagraph (C)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b677202-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer shall not be required to pay more than $200 per day and $10,000 in the aggregate for each employee for paid leave under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b677203-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Varying schedule hours calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an employee whose schedule varies from week to week to such an extent that an employer is unable to determine with certainty the number of hours the employee would have worked if such employee had not taken leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":", the employer shall use the following in place of such number:"}],"tail":null},{"tag":"clause","attrib":{"id":"id5b677204-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to clause (ii), a number equal to the average number of hours that the employee was scheduled per day over the 6-month period ending on the date on which the employee takes such leave, including hours for which the employee took leave of any type.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b677205-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the employee did not work over such period, the reasonable expectation of the employee at the time of hiring of the average number of hours per day that the employee would normally be scheduled to work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b677206-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case where the necessity for leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":" for the purpose described in subsection (a)(2)(A) is foreseeable, an employee shall provide the employer with such notice of leave as is practicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b677207-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration to position","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b677208-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2614/a/1"},"text":"Section 2614(a)(1) of this title","children":[],"tail":" shall not apply with respect to an employee of an employer who employs fewer than 25 employees if the conditions described in paragraph (2) are met."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b677209-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conditions described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b67720a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee takes leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b67720b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The position held by the employee when the leave commenced does not exist due to economic conditions or other changes in operating conditions of the employer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b67720c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that affect employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b67720d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are caused by a public health emergency during the period of leave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b67720e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employer makes reasonable efforts to restore the employee to a position equivalent to the position the employee held when the leave commenced, with equivalent employment benefits, pay, and other terms and conditions of employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b67720f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the reasonable efforts of the employer under subparagraph (C) fail, the employer makes reasonable efforts during the period described in paragraph (3) to contact the employee if an equivalent position described in subparagraph (C) becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b677210-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contact period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period described under this paragraph is the 1-year period beginning on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b677211-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the qualifying need related to a public health emergency concludes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b677212-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2620/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 12 weeks after the date on which the employee’s leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":" commences."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b677213-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tI/s110"},"text":"Pub. L. 103–3, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/127/dC/s3102/b"},"text":"Pub. L. 116–127, div. C, § 3102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/189"},"text":"134 Stat. 189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII"},"text":"Pub. L. 116–136, div. A, title III","children":[],"tail":", §§ 3601, 3604(a), 3605, 3611(1), (3), (7), div. B, title IX, § 19008, "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/410"},"text":"134 Stat. 410","children":[],"tail":", 411, 414, 415, 579.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b677214-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b677215-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b677216-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Congressional Accountability Act of 1995, referred to in subsec. (a)(1)(A)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/3"},"text":"109 Stat. 3","children":[],"tail":", which is classified principally to chapter 24 (§ 1301 et seq.) of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"section 1301 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a)(3)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":", known as the Family and Medical Leave Act of 1993, which enacted this chapter, sections 60m and 60n of Title 2, The Congress, and sections 6381 to 6387 of Title 5, Government Organization and Employees, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Families First Coronavirus Response Act, referred to in subsec. (a)(3)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Pub. L. 116–127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/178"},"text":"134 Stat. 178","children":[],"tail":". Division E (§§ 5101–5112) of the Act, known as the Emergency Paid Sick Leave Act, is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":". Division G (§§ 7001–7005) of the Act is set out as notes under sections 1401 and 3111 of Title 26, Internal Revenue Code. For complete classification of this Act to the Code, see Short Title of 2020 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b677217-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s19008/1"},"text":"Pub. L. 116–136, § 19008(1)","children":[],"tail":", which directed amendment of subpar. (A) by inserting cl. (i) designation and heading before “In lieu of”, was not executed due to intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3605"},"text":"Pub. L. 116–136, § 3605","children":[],"tail":", see below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3605"},"text":"Pub. L. 116–136, § 3605","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, text read as follows: “In lieu of the definition in sections 2611(2)(A) and 2611(2)(B)(ii) of this title, the term ‘eligible employee’ means an employee who has been employed for at least 30 calendar days by the employer with respect to whom leave is requested under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"section 2612(a)(1)(F) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s19008/2"},"text":"Pub. L. 116–136, § 19008(2)","children":[],"tail":", added cl. (ii) related to special rule regarding eligible employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3611/1"},"text":"Pub. L. 116–136, § 3611(1)","children":[],"tail":", substituted “553(d)(3)” for “553(d)(A)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3611/7"},"text":"Pub. L. 116–136, § 3611(7)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3604/a"},"text":"Pub. L. 116–136, § 3604(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3601"},"text":"Pub. L. 116–136, § 3601","children":[],"tail":", added cl. (ii) and struck out former cl. (ii). Prior to amendment, text read as follows: “In no event shall such paid leave exceed $200 per day and $10,000 in the aggregate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3611/3"},"text":"Pub. L. 116–136, § 3611(3)","children":[],"tail":", substituted “subsection (a)(2)(A)” for “subsection (a)(2)(A)(iii)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b677218-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b677219-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127/dC/s3106"},"text":"Pub. L. 116–127, div. C, § 3106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/192"},"text":"134 Stat. 192","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/127/dC/s3106"},"text":"“This Act [div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Pub. L. 116–127","children":[],"tail":", enacting this section, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":", and enacting provisions set out as notes under this section] shall take effect not later than 15 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b67721a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employment Under Multi-Employer Bargaining Agreements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127/dC/s3103"},"text":"Pub. L. 116–127, div. C, § 3103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/192"},"text":"134 Stat. 192","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/127/dC/s3103"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employer signatory to a multiemployer collective bargaining agreement may, consistent with its bargaining obligations and its collective bargaining agreement, fulfill its obligations under section 110(b)(2) of title I of the Family and Medical Leave Act of 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2620/b/2"},"text":"29 U.S.C. 2620(b)(2)","children":[],"tail":"], as added by the Families First Coronavirus Response Act ["},{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Pub. L. 116–127","children":[],"tail":"], by making contributions to a multiemployer fund, plan, or program based on the paid leave each of its employees is entitled to under such section while working under the multiemployer collective bargaining agreement, provided that the fund, plan, or program enables employees to secure pay from such fund, plan, or program based on hours they have worked under the multiemployer collective bargaining agreement for paid leave taken under section 102(a)(1)(F) of title I of the Family and Medical Leave Act of 1993 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"29 U.S.C. 2612(a)(1)(F)","children":[],"tail":"], as added by the Families First Coronavirus Response Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Employees who work under a multiemployer collective bargaining agreement into which their employers make contributions as provided in subsection (a) may secure pay from such fund, plan, or program based on hours they have worked under the multiemployer collective bargaining agreement for paid leave taken under section 102(a)(1)(F) of title I of the Family and Medical Leave Act of 1993, as added by the Families First Coronavirus Response Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b67721b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Rule for Certain Employers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127/dC/s3104"},"text":"Pub. L. 116–127, div. C, § 3104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/192"},"text":"134 Stat. 192","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3611/4"},"text":"Pub. L. 116–136, div. A, title III, § 3611(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/414"},"text":"134 Stat. 414","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dA/tIII/s3611/4"},"text":"“An employer under section 110(a)(1)(B) of the Family and Medical Leave Act of 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2620/a/1/B"},"text":"29 U.S.C. 2620(a)(1)(B)","children":[],"tail":"] shall not be subject to section 107(a) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2617/a"},"text":"29 U.S.C. 2617(a)","children":[],"tail":"] for a violation of section 102(a)(1)(F) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/F"},"text":"29 U.S.C. 2612(a)(1)(F)","children":[],"tail":"] if the employer does not meet the definition of employer set forth in section 101(4)(A)(i) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611/4/A/i"},"text":"29 U.S.C. 2611(4)(A)(i)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b69bb0c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Rule for Health Care Providers and Emergency Responders","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127/dC/s3105"},"text":"Pub. L. 116–127, div. C, § 3105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/192"},"text":"134 Stat. 192","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/127/dC/s3105"},"text":"“An employer of an employee who is a health care provider or an emergency responder may elect to exclude such employee from the application of the provisions in the amendments made under of [sic] section 3102 of this Act [div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Pub. L. 116–127","children":[],"tail":", enacting this section and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
