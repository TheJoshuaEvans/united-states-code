{"tag":"section","attrib":{"id":"id5a4ba1bb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s522"},"text":null,"children":[{"tag":"num","attrib":{"value":"522"},"text":"§ 522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extortionate picketing; penalty for violation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a4ba1bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be unlawful to carry on picketing on or about the premises of any employer for the purpose of, or as part of any conspiracy or in furtherance of any plan or purpose for, the personal profit or enrichment of any individual (except a bona fide increase in wages or other employee benefits) by taking or obtaining any money or other thing of value from such employer against his will or with his consent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a4ba1bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully violates this section shall be fined not more than $10,000 or imprisoned not more than twenty years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a4ba1be-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/257/tVI/s602"},"text":"Pub. L. 86–257, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/539"},"text":"73 Stat. 539","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
