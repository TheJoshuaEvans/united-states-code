{"tag":"section","attrib":{"id":"id5b604600-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2107"},"text":null,"children":[{"tag":"num","attrib":{"value":"2107"},"text":"§ 2107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b604601-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor shall prescribe such regulations as may be necessary to carry out this chapter. Such regulations shall, at a minimum, include interpretative regulations describing the methods by which employers may provide for appropriate service of notice as required by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b604602-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The mailing of notice to an employee’s last known address or inclusion of notice in the employee’s paycheck will be considered acceptable methods for fulfillment of the employer’s obligation to give notice to each affected employee under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b604603-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/379/s8"},"text":"Pub. L. 100–379, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/894"},"text":"102 Stat. 894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b604604-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b604605-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b604606-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":", except that the authority of the Secretary of Labor under this section is effective on "},{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/379/s11"},"text":"section 11 of Pub. L. 100–379","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
