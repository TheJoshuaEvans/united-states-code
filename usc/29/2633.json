{"tag":"section","attrib":{"id":"id5b69bb1f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633"},"text":null,"children":[{"tag":"num","attrib":{"value":"2633"},"text":"§ 2633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b69bb20-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b69bb21-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of 12 voting members and 4 ex officio members to be appointed not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"February 5, 1993","children":[],"tail":", as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b69bb22-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One Senator shall be appointed by the Majority Leader of the Senate, and one Senator shall be appointed by the Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb23-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One Member of the House of Representatives shall be appointed by the Speaker of the House of Representatives, and one Member of the House of Representatives shall be appointed by the Minority Leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb24-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b69bb25-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Two members each shall be appointed by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b69bb26-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b69bb27-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Majority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b69bb28-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Minority Leader of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b69bb29-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b69bb2a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such members shall be appointed by virtue of demonstrated expertise in relevant family, temporary disability, and labor management issues. Such members shall include representatives of employers, including employers from large businesses and from small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b69bb2b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, the Secretary of Labor, the Secretary of Commerce, and the Administrator of the Small Business Administration shall serve on the Commission as nonvoting ex officio members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb2c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the Commission shall be filled in the manner in which the original appointment was made. The vacancy shall not affect the power of the remaining members to execute the duties of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb2d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson and vice chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall elect a chairperson and a vice chairperson from among the members of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb2e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2633/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eight members of the Commission shall constitute a quorum for all purposes, except that a lesser number may constitute a quorum for the purpose of holding hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b69bb2f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tIII/s303"},"text":"Pub. L. 103–3, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/24"},"text":"107 Stat. 24","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
