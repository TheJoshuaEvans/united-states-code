{"tag":"section","attrib":{"id":"id5b48515d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396"},"text":"§ 1396.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s404/c"},"text":"section 404(c) of title 26","children":[],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"id5b48515e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of withdrawal liability; determinative factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a plan described in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b48515f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if an employer withdraws prior to a termination described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341a/a/2"},"text":"section 1341a(a)(2) of this title","children":[],"tail":", the amount of withdrawal liability to be paid in any year by such employer shall be an amount equal to the greater of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b485160-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1399/c/1/C/i"},"text":"section 1399(c)(1)(C)(i) of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b485161-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b485162-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of contribution base units for which the employer would have been required to make contributions for the prior plan year if the employer had not withdrawn, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b485163-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contribution rate for the plan year which would be required to meet the amortization schedules contained in section 1423(d)(3)(B)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002181"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002181"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title (determined without regard to any limitation on such rate otherwise provided by this subchapter)"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that an employer shall not be required to pay an amount in excess of the withdrawal liability computed with interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b485164-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the withdrawal liability of an employer who withdraws after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", as a result of a termination described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341a/a/2"},"text":"section 1341a(a)(2) of this title","children":[],"tail":" which is agreed to by the labor organization that appoints the employee representative on the joint board of trustees which sponsors the plan, shall be determined under subsection (c) if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b485165-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of prior employer withdrawals in any plan year commencing after ","children":[{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":", the number of contribution base units is reduced to less than 67 percent of the average number of such units for the calendar years 1974 through 1979; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b485166-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the withdrawal liability attributable to the first 33 percent decline described in subparagraph (A) has been determined by the plan sponsor to be uncollectible within the meaning of regulations of the corporation of general applicability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b485167-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of employer contributions under the plan for each plan year following the first plan year beginning after ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":" and preceding the termination date equals or exceeds the rate described in section 1423(d)(3) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b485168-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan is described in this subsection if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b485169-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is a plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s404/c"},"text":"section 404(c) of title 26","children":[],"tail":" or a continuation thereof; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b48516a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in the plan is substantially limited to individuals who retired prior to ","children":[{"tag":"date","attrib":{"date":"1976-01-01"},"text":"January 1, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b48516b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of liability of employer; “a year of signatory service” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b48516c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of an employer’s liability under this paragraph is the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b48516d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the employer’s withdrawal liability determined without regard to this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b48516e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of 90 percent, or a fraction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b48516f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numerator of which is an amount equal to the portion of the plan’s unfunded vested benefits that is attributable to plan participants who have a total of 10 or more years of signatory service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b485170-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the denominator of which is an amount equal to the total unfunded vested benefits of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b485171-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1396/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), the term “a year of signatory service” means a year during any portion of which a participant was employed for an employer who was obligated to contribute in that year, or who was subsequently obligated to contribute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b485172-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4216"},"text":"Pub. L. 93–406, title IV, § 4216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1234"},"text":"94 Stat. 1234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b485173-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b485174-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b485175-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1423"},"text":"Section 1423 of this title","children":[],"tail":", referred to in subsec. (a)(1)(B)(ii), (2)(C), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dO/tI/s108/a/1"},"text":"Pub. L. 113–235, div. O, title I, § 108(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2786"},"text":"128 Stat. 2786","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
