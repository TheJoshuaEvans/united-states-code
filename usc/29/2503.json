{"tag":"section","attrib":{"id":"id5b628f73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503"},"text":null,"children":[{"tag":"num","attrib":{"value":"2503"},"text":"§ 2503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b628f74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With funds appropriated to carry out this section, the Secretary shall make grants to community-based organizations to provide technical assistance to employers and labor unions selected under subsection (b). Such technical assistance may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b628f75-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing outreach and orientation sessions to recruit women into the employers’ apprenticeable occupations and nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f76-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing preapprenticeable occupations or nontraditional skills training to prepare women for apprenticeable occupations or nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f77-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing ongoing orientations for employers, unions, and workers on creating a successful environment for women in apprenticeable occupations or nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f78-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting up support groups and facilitating networks for women in nontraditional occupations on or off the job site to improve their retention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting up a local computerized data base referral system to maintain a current list of tradeswomen who are available for work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f7a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as a liaison between tradeswomen and employers and tradeswomen and labor unions to address workplace issues related to gender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f7b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting exit interviews with tradeswomen to evaluate their on-the-job experience and to assess the effectiveness of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b628f7c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of employer and labor unions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select a total of 50 employers or labor unions to receive technical assistance provided with grants made under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b628f7d-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/530/s4"},"text":"Pub. L. 102–530, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3466"},"text":"106 Stat. 3466","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
