,"tail":", 1813; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s202/a"},"text":"Pub. L. 100–630, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3304"},"text":"102 Stat. 3304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/52/s2/a"},"text":"Pub. L. 102–52, § 2(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1991-06-06"},"text":"June 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/260"},"text":"105 Stat. 260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s121/a"},"text":"Pub. L. 102–569, title I, § 121(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4365"},"text":"106 Stat. 4365","children":[],"tail":", 4367, related to congressional findings, purpose, policy, authorization of appropriations, change in Consumer Price Index, and extension of program, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a71c6b7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s411/a/1/A"},"text":"Pub. L. 113–128, § 411(a)(1)(A)","children":[],"tail":", substituted “competitive integrated employment” for “integrated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s411/a/1/B"},"text":"Pub. L. 113–128, § 411(a)(1)(B)","children":[],"tail":", substituted “Medicar