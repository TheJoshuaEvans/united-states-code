{"tag":"section","attrib":{"id":"id5b05a338-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1139"},"text":null,"children":[{"tag":"num","attrib":{"value":"1139"},"text":"§ 1139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application of such provision to any person or circumstances, shall be held invalid, the remainder of this chapter, or the application of such provision to persons or circumstances other than those as to which it is held invalid, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b05a339-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s509"},"text":"Pub. L. 93–406, title I, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/895"},"text":"88 Stat. 895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b05a33a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b05a33b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b05a33c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", known as the Employee Retirement Income Security Act of 1974. Titles I, III, and IV of such Act are classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b05a33d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b05a33e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary authorized, effective ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", to promulgate regulations wherever provisions of this subchapter call for the promulgation of regulations, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
