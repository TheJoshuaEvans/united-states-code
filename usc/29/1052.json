\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aceb4c4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7861/a/2"},"text":"Pub. L. 101–239, § 7861(a)(2)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":". See 1986 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/c/2/A"},"text":"Pub. L. 101–239, § 7894(c)(2)(A)","children":[],"tail":", substituted “educational organization” for “educational institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/a/1"},"text":"Pub. L. 101–239, § 7891(a)(1)","children":[],"tail":", substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7892/a"},"text":"Pub. L. 101–239, § 7892(a)","children":[],"tail":", struck out comma after “specified age”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/c/2/B"},"text":"Pub. L. 101–239, § 7894(c)(2)(B)","children":[],"tail":", substituted “a plan” for “the plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7861/a/2"},"text":"Pub. L. 101–239, § 7861(a)(2)","children":[],"tail":", substituted “2 years of service” for “3 years of service” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" substituted a period for “unless—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the plan is a—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) defined benefit plan, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) target benefit plan (as defined under regulations prescribed by the Secretary of the Treasury), and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) such employees begin employment with the employer after they have attained a specified age which is not more than 5 years before the normal retirement age under the plan.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/397/s102/a"},"text":"Pub. L. 98–397, § 102(a)","children":[],"tail":", substituted “21” for “25” in subpar. (A)(i) and “ ‘26’ for ‘21’ ” for “ ‘30’ for ‘25’ ” in subpar. (B)(ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/397/s102/d/1"},"text":"Pub. L. 98–397, § 102(d)(1)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “In the case of an employee who does not have any nonforfeitable right to an accrued benefit derived from employer contributions, years of service with the employer or employers maintaining the plan before a break in service shall not be required to be taken into account in computing the period of service for purposes of subsection (a)(1) if the number of consecutive 1-year breaks in service equals or exceeds the aggregate number of such years of service before such break. Such aggregate number of years of service before such break shall be deemed not to include any years of service not required to be taken into account under this paragraph by reason of any prior break in service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/397/s102/e/1"},"text":"Pub. L. 98–397, § 102(e)(1)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5aceb4c5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5aceb4c6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" applicable to plan years beginning after "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"Dec. 31, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s125/f/1"},"text":"section 125(f)(1) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5aceb4c7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"t