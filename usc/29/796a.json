{"tag":"section","attrib":{"id":"id5a9f18a0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796a"},"text":null,"children":[{"tag":"num","attrib":{"value":"796a"},"text":"§ 796a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f18a1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Administration for Community Living of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18a2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for independent living","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “center for independent living” means a consumer-controlled, community-based, cross-disability, nonresidential private nonprofit agency for individuals with significant disabilities (regardless of age or income) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9f18a3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed and operated within a local community by individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f18a4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an array of independent living services, including, at a minimum, independent living core services as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/17"},"text":"section 705(17) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18a5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer control” means, with respect to a center for independent living, that the center vests power and authority in individuals with disabilities, in terms of the management, staffing, decisionmaking, operation, and provisions of services, of the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a9f18a6-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s702"},"text":"Pub. L. 93–112, title VII, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1218"},"text":"112 Stat. 1218","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s473"},"text":"Pub. L. 113–128, title IV, § 473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1685"},"text":"128 Stat. 1685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a9f18a7-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a9f18a8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a9f18a9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s702"},"text":"Pub. L. 93–112, title VII, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4443"},"text":"106 Stat. 4443","children":[],"tail":", defined terms “center for independent living” and “consumer control”, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 796a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s702"},"text":"Pub. L. 93–112, title VII, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tIII/s301"},"text":"Pub. L. 95–602, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2995"},"text":"92 Stat. 2995","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tI/s103/d/2/A"},"text":"Pub. L. 99–506, title I, § 103(d)(2)(A)","children":[],"tail":", (C), title VIII, § 801, title X, §§ 1001(g)(1), 1002(h), "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1810"},"text":"100 Stat. 1810","children":[],"tail":", 1837, 1843, 1844; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s208/a"},"text":"Pub. L. 100–630, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3314"},"text":"102 Stat. 3314","children":[],"tail":", provided eligibility requirements and definition of “comprehensive services for independent living”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/s701/1"},"text":"Pub. L. 102–569, § 701(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a9f18aa-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s473/4"},"text":"Pub. L. 113–128, § 473(4)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s473/1/A"},"text":"Pub. L. 113–128, § 473(1)(A)","children":[],"tail":", inserted “for individuals with significant disabilities (regardless of age or income)” before “that—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s473/1/B"},"text":"Pub. L. 113–128, § 473(1)(B)","children":[],"tail":", inserted “, including, at a minimum, independent living core services as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/17"},"text":"section 705(17) of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s473/3"},"text":"Pub. L. 113–128, § 473(3)","children":[],"tail":", redesignated par. (1) as (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s473/2"},"text":"Pub. L. 113–128, § 473(2)","children":[],"tail":", inserted “, in terms of the management, staffing, decisionmaking, operation, and provisions of services, of the center” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s473/3"},"text":"Pub. L. 113–128, § 473(3)","children":[],"tail":", redesignated par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
