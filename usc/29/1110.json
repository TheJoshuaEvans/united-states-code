{"tag":"section","attrib":{"id":"id5b00e72b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1110"},"text":null,"children":[{"tag":"num","attrib":{"value":"1110"},"text":"§ 1110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exculpatory provisions; insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b00e72c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in sections 1105(b)(1) and 1105(d) of this title, any provision in an agreement or instrument which purports to relieve a fiduciary from responsibility or liability for any responsibility, obligation, or duty under this part shall be void as against public policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b00e72d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this subpart ","children":[{"tag":"ref","attrib":{"idref":"fn002109"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. This part does not contain subparts."}],"tail":" shall preclude—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b00e72e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan from purchasing insurance for its fiduciaries or for itself to cover liability or losses occurring by reason of the act or omission of a fiduciary, if such insurance permits recourse by the insurer against the fiduciary in the case of a breach of a fiduciary obligation by such fiduciary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b00e72f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fiduciary from purchasing insurance to cover liability under this part from and for his own account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b00e730-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1110/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer or an employee organization from purchasing insurance to cover potential liability of one or more persons who serve in a fiduciary capacity with regard to an employee benefit plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b00e731-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s410"},"text":"Pub. L. 93–406, title I, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/886"},"text":"88 Stat. 886","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
