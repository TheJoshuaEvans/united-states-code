{"tag":"section","attrib":{"id":"id5b98ba51-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206"},"text":null,"children":[{"tag":"num","attrib":{"value":"3206"},"text":"§ 3206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experimental projects and technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b98ba52-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out experimental, research, or demonstration projects relating to carrying out the Job Corps program. The Secretary may waive any provisions of this part that the Secretary finds would prevent the Secretary from carrying out the projects if the Secretary informs the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate, in writing, not less than 90 days in advance of issuing such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b98ba53-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the funds provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3212"},"text":"section 3212 of this title","children":[],"tail":" (for the purposes of administration), the Secretary may reserve ¼ of 1 percent to provide, directly or through grants, contracts, or other agreements or arrangements as the Secretary considers appropriate, technical assistance for the Job Corps program for the purpose of improving program quality. Such assistance shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b98e164-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assisting Job Corps centers and programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b98e165-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in correcting deficiencies under, and violations of, this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b98e166-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in meeting or exceeding the expected levels of performance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3209/c/1"},"text":"section 3209(c)(1) of this title","children":[],"tail":" for the indicators of performance described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/2/A"},"text":"section 3141(b)(2)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b98e167-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the development of sound management practices, including financial management procedures; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b98e168-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting entities, including entities not currently operating a Job Corps center, in developing the additional selection factors information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3197/a/3"},"text":"section 3197(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b98e169-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s156"},"text":"Pub. L. 113–128, title I, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1552"},"text":"128 Stat. 1552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b98e16a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b98e16b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b98e16c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/us