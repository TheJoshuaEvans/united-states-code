{"tag":"section","attrib":{"id":"id5a7dae6e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731"},"text":null,"children":[{"tag":"num","attrib":{"value":"731"},"text":"§ 731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a7dae6f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7dae70-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), from each State’s allotment under this part for any fiscal year, the Commissioner shall pay to a State an amount equal to the Federal share of the cost of vocational rehabilitation services under the plan for that State approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721"},"text":"section 721 of this title","children":[],"tail":", including expenditures for the administration of the State plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae71-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7dae72-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total of payments under paragraph (1) to a State for a fiscal year may not exceed its allotment under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s730"},"text":"section 730 of this title","children":[],"tail":" for such year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount otherwise payable to a State for a fiscal year under this section shall be reduced by the amount by which expenditures from non-Federal sources under the State plan under this subchapter for any previous fiscal year are less than the total of such expenditures for the second fiscal year preceding that previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner may waive or modify any requirement or limitation under subparagraph (B) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/17"},"text":"section 721(a)(17) of this title","children":[],"tail":" if the Commissioner determines that a waiver or modification is an equitable response to exceptional or uncontrollable circumstances affecting the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae75-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7dae76-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the amount of a payment under this section with respect to any construction project in any State shall be equal to the same percentage of the cost of such project as the Federal share that is applicable in the case of rehabilitation facilities (as defined in section 291","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(g) of title 42), in such State."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae77-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Federal share with respect to rehabilitation facilities in such State is determined pursuant to section 291","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)(2) of title 42, the percentage of the cost for purposes of this section shall be determined in accordance with regulations prescribed by the Commissioner designed to achieve as nearly as practicable results comparable to the results obtained under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7dae78-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of computation and payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The method of computing and paying amounts pursuant to subsection (a) shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7dae79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner shall, prior to the beginning of each calendar quarter or other period prescribed by the Commissioner, estimate the amount to be paid to each State under the provisions of such subsection for such period, such estimate to be based on such records of the State and information furnished by it, and such other investigation as the Commissioner may find necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae7a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s731/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner shall pay, from the allotment available therefor, the amount so estimated by the Commissioner for such period, reduced or increased, as the case may be, by any sum (not previously adjusted under this paragraph) by which the Commissioner finds that the estimate of the amount to be paid the State for any prior period under such subsection was greater or less than the amount which should have been paid to the State for such prior period under such subsection. Such payment shall be made prior to audit or settlement by the Government Accountability Office, shall be made through the disbursing facilities of the Treasury Department, and shall be made in such installments as the Commissioner may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a7dae7b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s111"},"text":"Pub. L. 93–112, title I, § 111","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s404"},"text":"Pub. L. 105–220, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1162"},"text":"112 Stat. 1162","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/b/8"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(b)(8)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–413; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s420"},"text":"Pub. L. 113–128, title IV, § 420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1656"},"text":"128 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a7dae7c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a7dae7d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a7dae7e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 731, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s111"},"text":"Pub. L. 93–112, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/371"},"text":"87 Stat. 371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s122/b/1"},"text":"Pub. L. 95–602, title I, § 122(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"te