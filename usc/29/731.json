8"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “The” for “For fiscal year 1994 and each fiscal year thereafter, the”, “this subchapter for any previous” for “this subchapter for the previous”, and “year preceding that previous” for “year preceding the previous”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" made technical amendment to section designation and catchline in original."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a7dae80-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id5a7dae81-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions of Terms in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s3"},"text":"section 3 of Pub. L. 113–128","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":", apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
