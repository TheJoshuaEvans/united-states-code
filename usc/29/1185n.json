{"tag":"section","attrib":{"id":"id5b1fe13c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1185n"},"text":"§ 1185n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on pharmacy benefits and drug costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b1fe13d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and not later than June 1 of each year thereafter, a group health plan (or health insurance coverage offered in connection with such a plan) shall submit to the Secretary, the Secretary of Health and Human Services, and the Secretary of the Treasury the following information with respect to the health plan or coverage in the previous plan year:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b1fe13e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The beginning and end dates of the plan year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe13f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe140-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State in which the plan or coverage is offered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe141-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 50 brand prescription drugs most frequently dispensed by pharmacies for claims paid by the plan or coverage, and the total number of paid claims for each such drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe142-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 50 most costly prescription drugs with respect to the plan or coverage by total annual spending, and the annual amount spent by the plan or coverage for each such drug.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe143-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 50 prescription drugs with the greatest increase in plan expenditures over the plan year preceding the plan year that is the subject of the report, and, for each such drug, the change in amounts expended by the plan or coverage in each such plan year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe144-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Total spending on health care services by such group health plan or health insurance coverage, broken down by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b1fe145-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the type of costs, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b1fe146-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospital costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b1fe147-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care provider and clinical service costs, for primary care and specialty care separately;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b1fe148-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs for prescription drugs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b1fe149-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other medical costs, including wellness services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b1fe14a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" spending on prescription drugs by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b1fe14b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health plan or coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b1fe14c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe14d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The average monthly premium—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b1fe14e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid by employers on behalf of participants and beneficiaries, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b1fe14f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid by participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe150-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any impact on premiums by rebates, fees, and any other remuneration paid by drug manufacturers to the plan or coverage or its administrators or service providers, with respect to prescription drugs prescribed to participants or beneficiaries in the plan or coverage, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b1fe151-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts so paid for each therapeutic class of drugs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b1fe152-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts so paid for each of the 25 drugs that yielded the highest amount of rebates and other remuneration under the plan or coverage from drug manufacturers during the plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b1fe153-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reduction in premiums and out-of-pocket costs associated with rebates, fees, or other remuneration described in paragraph (9).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b1fe154-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the date on which the first report is required under subsection (a) and biannually thereafter, the Secretary, acting in coordination with the Inspector General of the Department of Labor, shall make available on the internet website of the Department of Labor a report on prescription drug reimbursements under group health plans (or health insurance coverage offered in connection with such a plan), prescription drug pricing trends, and the role of prescription drug costs in contributing to premium increases or decreases under such plans or coverage, aggregated in such a way as no drug or plan specific information will be made public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b1fe155-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No confidential or trade secret information submitted to the Secretary under subsection (a) shall be included in the report under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b1fe156-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s725"},"text":"Pub. L. 93–406, title I, § 725","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tII/s204/b"},"text":"Pub. L. 116–260, div. BB, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2919"},"text":"134 Stat. 2919","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
