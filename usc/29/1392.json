{"tag":"section","attrib":{"id":"id5b485140-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1392"},"text":null,"children":[{"tag":"num","attrib":{"value":"1392"},"text":"§ 1392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation to contribute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b485141-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Obligation to contribute” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “obligation to contribute” means an obligation to contribute arising—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b485142-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1392/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under one or more collective bargaining (or related) agreements, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b485143-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1392/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of a duty under applicable labor-management relations law, but","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"does not include an obligation to pay withdrawal liability under this section or to pay delinquent contributions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b485144-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments of withdrawal liability not considered contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments of withdrawal liability under this part shall not be considered contributions for purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b485145-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions to evade or avoid liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a principal purpose of any transaction is to evade or avoid liability under this part, this part shall be applied (and liability shall be determined and collected) without regard to such transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b485146-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4212"},"text":"Pub. L. 93–406, title IV, § 4212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1233"},"text":"94 Stat. 1233","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
