{"tag":"section","attrib":{"id":"id5b222c38-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1191d"},"text":"§ 1191d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardized reporting format","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b222c39-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall establish (and periodically update) a standardized reporting format for the voluntary reporting, by group health plans to State All Payer Claims Databases, of medical claims, pharmacy claims, dental claims, and eligibility and provider files that are collected from private and public payers, and shall provide guidance to States on the process by which States may collect such data from such plans in the standardized reporting format."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222c3a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222c3b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall convene an Advisory Committee (referred to in this section as the “Committee”), consisting of 15 members to advise the Secretary regarding the format and guidance described in paragraph (1)."},{"tag":"ref","attrib":{"idref":"fn002141"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002141"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (a).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c3c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c3d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with subparagraph (B), not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary, in coordination with the Secretary of Health and Human Services, shall appoint under subparagraph (B)(iii), and the Comptroller General of the United States shall appoint under subparagraph (B)(iv), members who have distinguished themselves in the fields of health services research, health economics, health informatics, data privacy and security, or the governance of State All Payer Claims Databases, or who represent organizations likely to submit data to or use the database, including patients, employers, or employee organizations that sponsor group health plans, health care providers, health insurance issuers, or third-party administrators of group health plans. Such members shall serve 3-year terms on a staggered basis. Vacancies on the Committee shall be filled by appointment consistent with this paragraph not later than 3 months after the vacancy arises."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c3e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be comprised of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b222c3f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary of Employee Benefits and Security Administration of the Department of Labor, or a designee of such Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c40-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Planning and Evaluation of the Department of Health and Human Services, or a designee of such Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c41-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" members appointed by the Secretary, in coordination with the Secretary of Health and Human Services, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b222c42-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member to serve as the chair of the Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c43-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the Centers for Medicare & Medicaid Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c44-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the Agency for Healthcare Research and Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c45-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the Office for Civil Rights of the Department of Health and Human Services with expertise in data privacy and security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c46-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the National Center for Health Statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c47-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the Office of the National Coordinator for Health Information Technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c48-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of a State All-Payer ","children":[{"tag":"ref","attrib":{"idref":"fn002142"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Definition in subsec. (c) does not contain hyphen in “All Payer”."}],"tail":" Claims Database;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c49-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" members appointed by the Comptroller General of the United States, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b222c4a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of an employer that sponsors a group health plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c4b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of an employee organization that sponsors a group health plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c4c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 academic researcher with expertise in health economics or health services research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c4d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 consumer advocate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b222c4e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/2/B/iv/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 additional members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c4f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Committee shall report to the Secretary, the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Energy and Commerce and the Committee on Education and Labor of the House of Representatives. Such report shall include recommendations on the establishment of the format and guidance described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222c50-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State All Payer Claims Database","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “State All Payer Claims Database” means, with respect to a State, a database that may include medical claims, pharmacy claims, dental claims, and eligibility and provider files, which are collected from private and public payers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222c51-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $5,000,000 for fiscal year 2021, to remain available until expended or, if sooner, until the date described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222c52-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the date on which the report is submitted under subsection (b)(3), subsection (b) shall have no force or effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b222c53-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s735"},"text":"Pub. L. 93–406, title I, § 735","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s115/b"},"text":"Pub. L. 116–260, div. BB, title I, § 115(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2877"},"text":"134 Stat. 2877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b222c54-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b222c55-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5b222c56-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
