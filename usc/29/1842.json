{"tag":"section","attrib":{"id":"id5b591a08-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1842"},"text":null,"children":[{"tag":"num","attrib":{"value":"1842"},"text":"§ 1842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation of registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall utilize the services of any farm labor contractor to supply any migrant or seasonal agricultural worker unless the person first takes reasonable steps to determine that the farm labor contractor possesses a certificate of registration which is valid and which authorizes the activity for which the contractor is utilized. In making that determination, the person may rely upon either possession of a certificate of registration, or confirmation of such registration by the Department of Labor. The Secretary shall maintain a central public registry of all persons issued a certificate of registration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b591a09-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/tIV/s402"},"text":"Pub. L. 97–470, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2595"},"text":"96 Stat. 2595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b591a0a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b591a0b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b591a0c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days from ","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/470/s524"},"text":"section 524 of Pub. L. 97–470","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
