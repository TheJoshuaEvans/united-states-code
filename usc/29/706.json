{"tag":"section","attrib":{"id":"id5a6d0bdc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706"},"text":null,"children":[{"tag":"num","attrib":{"value":"706"},"text":"§ 706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment percentage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6d0bdd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0bde-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s730"},"text":"section 730 of this title","children":[],"tail":", the allotment percentage for any State shall be 100 per centum less that percentage which bears the same ratio to 50 per centum as the per capita income of such State bears to the per capita income of the United States, except that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a6d0bdf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment percentage shall in no case be more than 75 per centum or less than 33⅓ per centum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a6d0be0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allotment percentage for the District of Columbia, Puerto Rico, Guam, the Virgin Islands, American Samoa, and the Commonwealth of the Northern Mariana Islands shall be 75 per centum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0be1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allotment percentages shall be promulgated by the Secretary of Education between October 1 and December 31 of each even-numbered year, on the basis of the average of the per capita incomes of the States and of the United States for the three most recent consecutive years for which satisfactory data are available from the Department of Commerce. Such promulgation shall be conclusive for each of the 2 fiscal years in the period beginning on the October 1 next succeeding such promulgation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0be2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” means (but only for purposes of this subsection) the 50 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0be3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The population of the several States and of the United States shall be determined on the basis of the most recent data available, to be furnished by the Department of Commerce by October 1 of the year preceding the fiscal year for which funds are appropriated pursuant to statutory authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6d0be4-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s8"},"te