{"tag":"section","attrib":{"id":"id5a578878-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s628"},"text":null,"children":[{"tag":"num","attrib":{"value":"628"},"text":"§ 628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations; exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with the provisions of subchapter II of chapter 5 of title 5, the Equal Employment Opportunity Commission may issue such rules and regulations as it may consider necessary or appropriate for carrying out this chapter, and may establish such reasonable exemptions to and from any or all provisions of this chapter as it may find necessary and proper in the public interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a578879-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/202/s9"},"text":"Pub. L. 90–202, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/605"},"text":"81 Stat. 605","children":[],"tail":"; 1978 Reorg. Plan No. 1, § 2, eff. "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", 43 F.R. 19807, "},{"tag":"ref","attrib":{"href":"/us/stat/92/3781"},"text":"92 Stat. 3781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a57887a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5a57887b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5a57887c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Equal Employment Opportunity Commission” and “it” substituted in text for “Secretary of Labor” and “he”, respectively, pursuant to Reorg. Plan No. 1 of 1978, § 2, 43 F.R. 19807, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/92/3781"},"text":"92 Stat. 3781","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees, which transferred all functions vested by this section in Secretary of Labor to Equal Employment Opportunity Commission, effective "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", as provided by section 1–101 of Ex. Ord. No. 12106, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1053."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
