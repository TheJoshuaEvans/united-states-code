{"tag":"section","attrib":{"id":"id5a1994cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s142"},"text":null,"children":[{"tag":"num","attrib":{"value":"142"},"text":"§ 142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a1994ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s142/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “industry affecting commerce” means any industry or activity in commerce or in which a labor dispute would burden or obstruct commerce or tend to burden or obstruct commerce or the free flow of commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a1994cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s142/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “strike” includes any strike or other concerted stoppage of work by employees (including a stoppage by reason of the expiration of a collective-bargaining agreement) and any concerted slowdown or other concerted interruption of operations by employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a1994d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s142/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “commerce”, “labor disputes”, “employer”, “employee”, “labor organization”, “representative”, “person”, and “supervisor” shall have the same meaning as when used in subchapter II of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a1994d1-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-23/ch120"},"text":"June 23, 1947, ch. 120","children":[],"tail":", title V, § 501, "},{"tag":"ref","attrib":{"href":"/us/stat/61/161"},"text":"61 Stat. 161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a1994d2-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a1994d3-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a1994d4-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter II of this chapter, referred to in par. (3), was in the original “the National Labor Relations Act as amended by this Act” [29 U.S.C. § 151 et seq.].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
