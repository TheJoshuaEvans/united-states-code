{"tag":"section","attrib":{"id":"id5a172449-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s50"},"text":null,"children":[{"tag":"num","attrib":{"value":"50"},"text":"§ 50.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of labor standards of apprenticeship","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor is authorized and directed to formulate and promote the furtherance of labor standards necessary to safeguard the welfare of apprentices, to extend the application of such standards by encouraging the inclusion thereof in contracts of apprenticeship, to bring together employers and labor for the formulation of programs of apprenticeship, to cooperate with State agencies engaged in the formulation and promotion of standards of apprenticeship, and to cooperate with the Secretary of Education in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s17"},"text":"section 17 of title 20","children":[],"tail":". For the purposes of this chapter the term “State” shall include the District of Columbia."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a17244a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-16/ch663/s1"},"text":"Aug. 16, 1937, ch. 663, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/664"},"text":"50 Stat. 664","children":[],"tail":"; 1939 Reorg. Plan No. I, §§  201, 204, 206, eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2728, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1424"},"text":"53 Stat. 1424","children":[],"tail":", 1425; "},{"tag":"ref","attrib":{"href":"/us/act/1943-07-12/ch221"},"text":"July 12, 1943, ch. 221","children":[],"tail":", title VII, "},{"tag":"ref","attrib":{"href":"/us/stat/57/518"},"text":"57 Stat. 518","children":[],"tail":"; 1953 Reorg. Plan No. 1, §§ 5, 8, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/631"},"text":"67 Stat. 631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/198/tII"},"text":"Pub. L. 93–198, title II","children":[],"tail":", §  204(h), "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"Dec. 24, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/784"},"text":"87 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tIII/s301/a/1"},"text":"Pub. L. 96–88, title III, § 301(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/677"},"text":"93 Stat. 677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a17244b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a17244c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a17244d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s17"},"text":"Section 17 of title 20","children":[],"tail":", referred to in text, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/643"},"text":"80 Stat. 643","children":[],"tail