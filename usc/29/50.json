 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id5a172452-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/134/s1"},"text":"Pub. L. 116–134, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-26"},"text":"Mar. 26, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/276"},"text":"134 Stat. 276","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/134/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s50c"},"text":"section 50c of this title","children":[],"tail":"] may be cited as the ‘Support for Veterans in Effective Apprenticeships Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id5a172453-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-16/ch663"},"text":"act of Aug. 16, 1937, ch. 663","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/664"},"text":"50 Stat. 664","children":[],"tail":", which enacted this chapter, is popularly known as the “National Apprenticeship Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5a172454-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Education” substituted in text for “Office of Education under the Department of Health, Education, and Welfare”, pursuant to ","children":[{"tag":"ref","attrib":{"hre