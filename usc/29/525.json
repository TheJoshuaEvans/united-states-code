{"tag":"section","attrib":{"id":"id5a4ba1ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s525"},"text":null,"children":[{"tag":"num","attrib":{"value":"525"},"text":"§ 525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this chapter, service of summons, subpena, or other legal process of a court of the United States upon an officer or agent of a labor organization in his capacity as such shall constitute service upon the labor organization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a4ba1cf-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/257/tVI/s605"},"text":"Pub. L. 86–257, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/540"},"text":"73 Stat. 540","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
