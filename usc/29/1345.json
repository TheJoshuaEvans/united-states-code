{"tag":"section","attrib":{"id":"id5b3edaa8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345"},"text":null,"children":[{"tag":"num","attrib":{"value":"1345"},"text":"§ 1345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recapture of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b3edaa9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to recover benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), the trustee is authorized to recover for the benefit of a plan from a participant the recoverable amount (as defined in subsection (b)) of all payments from the plan to him which commenced within the 3-year period immediately preceding the time the plan is terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3edaaa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoverable amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a) the recoverable amount is the excess of the amount determined under paragraph (1) over the amount determined under paragraph (2).","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edaab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount determined under this paragraph is the sum of the amount of the actual payments received by the participant within the 3-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edaac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount determined under this paragraph is the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3edaad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the amount such participant would have received during each consecutive 12-month period within the 3 years if the participant received the benefit in the form described in paragraph (3),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edaae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum for each of the consecutive 12-month periods of the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b3edaaf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess, if any, of $10,000 over the benefit in the form described in paragraph (3), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b3edab0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess of the actual payment, if any, over the benefit in the form described in paragraph (3), and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edab1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value at the time of termination of the participant’s future benefits guaranteed under this subchapter as if the benefits commenced in the form described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edab2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The form of benefit for purposes of this subsection shall be the monthly benefit the participant would have received during the consecutive 12-month period, if he had elected at the time of the first payment made during the 3-year period, to receive his interest in the plan as a monthly benefit in the form of a life annuity commencing at the time of such first payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3edab3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments made on or after death or disability of participant; waiver of recovery in case of hardship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edab4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a distribution described in section 1343(b)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn002172"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002172"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title the 3-year period referred to in subsection (b) shall not end sooner than the date on which the corporation is notified of the distribution."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edab5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The trustee shall not recover any payment made from a plan after or on account of the death of a participant, or to a participant who is disabled (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s72/m/7"},"text":"section 72(m)(7) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edab6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1345/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation is authorized to waive, in whole or in part, the recovery of any amount which the trustee is authorized to recover for the benefit of a plan under this section in any case in which it determines that substantial economic hardship would result to the participant or his beneficiaries from whom such amount is recoverable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b3edab7-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4045"},"text":"Pub. L. 93–406, title IV, § 4045","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1027"},"text":"88 Stat. 1027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7891/a/1"},"text":"Pub. L. 101–239, title VII, § 7891(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2445"},"text":"103 Stat. 2445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b3edab8-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b3edab9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b3edaba-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1343/b/7"},"text":"Section 1343(b)(7) of this title","children":[],"tail":", referred to in subsec. (c)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1343/c/7"},"text":"section 1343(c)(7) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVII/s771/b"},"text":"Pub. L. 103–465, title VII, § 771(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5042"},"text":"108 Stat. 5042","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b3edabb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b3edabc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b3edabd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/f"},"text":"section 7891(f) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
