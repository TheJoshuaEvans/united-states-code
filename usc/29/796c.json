{"tag":"section","attrib":{"id":"id5a9f18b0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c"},"text":null,"children":[{"tag":"num","attrib":{"value":"796c"},"text":"§ 796c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a9f18b1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f18b2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive financial assistance under this part, a State shall submit to the Administrator, and obtain approval of, a State plan developed and signed in accordance with paragraph (2), containing such provisions as the Administrator may require, including, at a minimum, the provisions required in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18b3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan under paragraph (1) shall be jointly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9f18b4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed by the chairperson of the Statewide Independent Living Council, and the directors of the centers for independent living in the State, after receiving public input from individuals with disabilities and other stakeholders throughout the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f18b5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" signed by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a9f18b6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairperson of the Statewide Independent Living Council, acting on behalf of and at the direction of the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a9f18b7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the director of the designated State entity described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a9f18b8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 51 percent of the directors of the centers for independent living in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18b9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review and revision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall provide for the review and revision of the plan, not less than once every 3 years, to ensure the existence of appropriate planning, financial support and coordination, and other assistance to appropriately address, on a statewide and comprehensive basis, needs in the State for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9f18ba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of independent living services in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f18bb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and support of a statewide network of centers for independent living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f18bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" working relationships and collaboration between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a9f18bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" centers for independent living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a9f18be-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5a9f18bf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities carrying out programs that provide independent living services, including those serving older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a9f18c0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other community-based organizations that provide or coordinate the provision of housing, transportation, employment, information and referral assistance, services, and supports for individuals with significant disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a9f18c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/3/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities carrying out other programs providing services for individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall submit the plan to the Administrator 90 days before the completion date of the preceding plan. If a State fails to submit such a plan that complies with the requirements of this section, the Administrator may withhold financial assistance under this part until such time as the State submits such a plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewideness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State plan shall describe strategies for providing independent living services on a statewide basis, to the greatest extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewide Independent Living Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall provide for the establishment of a Statewide Independent Living Council in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d"},"text":"section 796d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of State entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall designate a State entity of such State (referred to in this subchapter as the “designated State entity”) as the agency that, on behalf of the State, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f18c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive, account for, and disburse funds received by the State under this part based on the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide administrative support services for a program under subpart 2, and a program under subpart 3 in a case in which the program is administered by the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796f–2"},"text":"section 796f–2 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep such records and afford such access to such records as the Administrator finds to be necessary with respect to the programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such additional information or provide such assurances as the Administrator may require with respect to the programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain not more than 5 percent of the funds received by the State for any fiscal year under subpart 2, for the performance of the services outlined in paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f18cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the objectives to be achieved under the plan and establish timelines for the achievement of the objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain how such objectives are consistent with and further the purpose of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent living services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall provide that the State will provide independent living services under this part to individuals with significant disabilities, and will provide the services to such an individual in accordance with an independent living plan mutually agreed upon by an appropriate staff member of the service provider and the individual, unless the individual signs a waiver stating that such a plan is unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope and arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall describe the extent and scope of independent living services to be provided under this part to meet such objectives. If the State makes arrangements, by grant or contract, for providing such services, such arrangements shall be described in the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall set forth a design for the establishment of a statewide network of centers for independent living that comply with the standards and assurances set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796f–4"},"text":"section 796f–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In States in which State funding for centers for independent living equals or exceeds the amount of funds allotted to the State under subpart 3, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796f–2"},"text":"section 796f–2 of this title","children":[],"tail":", the plan shall include policies, practices, and procedures governing the awarding of grants to centers for independent living and oversight of such centers consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796f–2"},"text":"section 796f–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation, coordination, and working relationships among various entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall set forth the steps that will be taken to maximize the cooperation, coordination, and working relationships among—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f18d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Statewide Independent Living Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" centers for independent living;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designated State entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f18d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other State agencies or entities represented on the Council, other councils that address the needs and issues of specific disability populations, and other public and private entities determined to be appropriate by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall describe how services funded under this part will be coordinated with, and complement, other services, in order to avoid unnecessary duplication with other Federal, State, and local programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination between Federal and State sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall describe efforts to coordinate Federal and State funding for centers for independent living and independent living services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to services and centers funded under this part, the plan shall set forth steps to be taken regarding outreach to populations that are unserved or underserved by programs under this subchapter, including minority groups and urban and rural populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f18da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall provide satisfactory assurances that all recipients of financial assistance under this part will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f18db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify all individuals seeking or receiving services under this part about the availability of the client assistance program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s732"},"text":"section 732 of this title","children":[],"tail":", the purposes of the services provided under such program, and how to contact such program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take affirmative action to employ and advance in employment qualified individuals with disabilities on the same terms and conditions required with respect to the employment of such individuals under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s793"},"text":"section 793 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt such fiscal control and fund accounting procedures as may be necessary to ensure the proper disbursement of and accounting for funds paid to the State under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa162cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain records that fully disclose—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa162d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and disposition by such recipient of the proceeds of such financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa162d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the project or undertaking in connection with which such financial assistance is given or used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa162d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of that portion of the cost of the project or undertaking supplied by other sources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such other records as the Administrator determines to be appropriate to facilitate an effective audit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford such access to records maintained under subparagraphs (A) and (B) as the Administrator determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa162d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such reports with respect to such records as the Administrator determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide access to the Administrator and the Comptroller General or any of their duly authorized representatives, for the purpose of conducting audits and examinations, of any books, documents, papers, and records of the recipients that are pertinent to the financial assistance received under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa162d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/m/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for public hearings regarding the contents of the plan during both the formulation and review of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa162d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall establish a method for the periodic evaluation of the effectiveness of the plan in meeting the objectives established in subsection (d), including evaluation of satisfaction by individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa162d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796c/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting full access to community life","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall describe how the State will provide independent living services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/18"},"text":"section 705(18) of this title","children":[],"tail":" that promote full access to community life for individuals with significant disabilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa162da-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s704"},"text":"Pub. L. 93–112, title VII, § 704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1218"},"text":"112 Stat. 1218","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s474"},"text":"Pub. L. 113–128, title IV, § 474","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1686"},"text":"128 Stat. 1686","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa162db-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa162dc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa162dd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s704"},"text":"Pub. L. 93–112, title VII, § 704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4444"},"text":"106 Stat. 4444","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/b"},"text":"Pub. L. 103–73, title I, § 114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/728"},"text":"107 Stat. 728","children":[],"tail":", related to State plans, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 796c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s704"},"text":"Pub. L. 93–112, title VII, § 704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tIII/s301"},"text":"Pub. L. 95–602, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2997"},"text":"92 Stat. 2997","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s208/c"},"text":"Pub. L. 100–630, title II, § 208(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3314"},"text":"102 Stat. 3314","children":[],"tail":", related to payments to States from allotments to pay Federal share of expenditures, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/s701/1"},"text":"Pub. L. 102–569, § 701(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa162de-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/1/A"},"text":"Pub. L. 113–128, § 474(1)(A)","children":[],"tail":", substituted “Administrator” for “Commissioner” in two places and inserted “developed and signed in accordance with paragraph (2),” after “State plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/1/B"},"text":"Pub. L. 113–128, § 474(1)(B)","children":[],"tail":", struck out “developed and signed by” after “jointly” in introductory provisions, added subpars. (A) and (B), and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the director of the designated State unit; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the chairperson of the Statewide Independent Living Council, acting on behalf of and at the direction of the Council.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/1/C/i"},"text":"Pub. L. 113–128, § 474(1)(C)(i)","children":[],"tail":", substituted “independent living services in the State” for “State independent living services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/1/C/ii"},"text":"Pub. L. 113–128, § 474(1)(C)(ii)","children":[],"tail":", added subpar. (C) and struck out former subpar. (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) working relationships between—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) programs providing independent living services and independent living centers; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the vocational rehabilitation program established under subchapter I of this chapter, and other programs providing services for individuals with disabilities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/1/D"},"text":"Pub. L. 113–128, § 474(1)(D)","children":[],"tail":", substituted “Administrator” for “Commissioner” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/1/E"},"text":"Pub. L. 113–128, § 474(1)(E)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/2/A"},"text":"Pub. L. 113–128, § 474(2)(A)","children":[],"tail":", (B), substituted “entity” for “unit” in heading and “a State entity of such State (referred to in this subchapter as the ‘designated State entity’)” for “the designated State unit of such State” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/2/C"},"text":"Pub. L. 113–128, § 474(2)(C)","children":[],"tail":", substituted “Administrator” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/2/D"},"text":"Pub. L. 113–128, § 474(2)(D)","children":[],"tail":"–(F), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/3"},"text":"Pub. L. 113–128, § 474(3)","children":[],"tail":", added pars. (1) to (4) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the independent living rehabilitation service program, the Statewide Independent Living Council, and centers for independent living; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the designated State unit, other State agencies represented on such Council, other councils that address the needs of specific disability populations and issues, and other public and private entities determined to be appropriate by the Council.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/4"},"text":"Pub. L. 113–128, § 474(4)","children":[],"tail":", substituted “Administrator” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s474/5"},"text":"Pub. L. 113–128, § 474(5)","children":[],"tail":", added subsec. ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
