{"tag":"section","attrib":{"id":"id5a1bdf0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s156"},"text":null,"children":[{"tag":"num","attrib":{"value":"156"},"text":"§ 156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board shall have authority from time to time to make, amend, and rescind, in the manner prescribed by subchapter II of chapter 5 of title 5, such rules and regulations as may be necessary to carry out the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a1bdf0e-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-05/ch372/s6"},"text":"July 5, 1935, ch. 372, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/452"},"text":"49 Stat. 452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-06-23/ch120"},"text":"June 23, 1947, ch. 120","children":[],"tail":", title I, § 101, "},{"tag":"ref","attrib":{"href":"/us/stat/61/140"},"text":"61 Stat. 140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a1bdf0f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a1bdf10-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a1bdf11-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Subchapter II of chapter 5 of title 5” substituted in text for “the Administrative Procedure Act” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a1bdf12-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1947—Act ","children":[{"tag":"date","attrib":{"date":"1947-06-23"},"text":"June 23, 1947","children":[],"tail":", amended section generally to provide that the rules and regulations issued by the Board should be in the manner prescribed by the Administrative Procedure Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a1bdf13-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a1bdf14-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1947 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by act ","children":[{"tag":"date","attrib":{"date":"1947-06-23"},"text":"June 23, 1947","children":[],"tail":", see section 104 of act "},{"tag":"date","attrib":{"date":"1947-06-23"},"text":"June 23, 1947","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
