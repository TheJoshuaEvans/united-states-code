{"tag":"section","attrib":{"id":"id5aa1634f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"796e–1"},"text":"§ 796e–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States from allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aa16350-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the allotment of each State for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796e"},"text":"section 796e of this title","children":[],"tail":", the State shall be paid the Federal share of the expenditures incurred during such year under its State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d–1"},"text":"section 796d–1 of this title","children":[],"tail":". Such payments may be made (after necessary adjustments on account of previously made overpayments or underpayments) in advance or by way of reimbursement, and in such installments and on such conditions as the Administrator may determine."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16351-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa16352-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share with respect to any State for any fiscal year shall be 90 percent of the expenditures incurred by the State during such year under its State plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d–1"},"text":"section 796d–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa16353-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of any project that receives assistance through an allotment under this subpart may be provided in cash or in kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa16354-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s712"},"text":"Pub. L. 93–112, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1225"},"text":"112 Stat. 1225","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s476/c"},"text":"Pub. L. 113–128, title IV, § 476(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1691"},"text":"128 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa16355-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa16356-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa16357-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796e–1, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s712"},"text":"Pub. L. 93–112, title VII, § 712","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4451"},"text":"106 Stat. 4451","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/f"},"text":"Pub. L. 103–73, title I, § 114(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/730"},"text":"107 Stat. 730","children":[],"tail":", related to payments to States from allotments, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa16358-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “Administrator” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
