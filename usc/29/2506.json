{"tag":"section","attrib":{"id":"id5b628f8c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2506"},"text":null,"children":[{"tag":"num","attrib":{"value":"2506"},"text":"§ 2506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison role of Department of Labor","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Department of Labor shall serve as a liaison among employers, labor unions, and community-based organizations. The liaison role may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b628f8d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2506/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of employers, labor unions, and community-based organizations with respect to technical assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2503/a"},"text":"section 2503(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f8e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2506/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting regular assessment meetings with representatives of employers, labor unions, and community-based organizations with respect to such technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f8f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2506/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeking the input of employers and labor unions with respect to strategies and recommendations for improving such technical assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b628f90-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/530/s7"},"text":"Pub. L. 102–530, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3467"},"text":"106 Stat. 3467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
