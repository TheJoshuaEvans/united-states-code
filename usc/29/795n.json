{"tag":"section","attrib":{"id":"id5a9f1861-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n"},"text":null,"children":[{"tag":"num","attrib":{"value":"795n"},"text":"§ 795n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Increasing Competitive Integrated Employment for Individuals with Disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a9f1862-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", the Secretary of Labor shall establish an Advisory Committee on Increasing Competitive Integrated Employment for Individuals with Disabilities (referred to in this section as the “Committee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f1863-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and vacancies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f1864-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall appoint the members of the Committee described in subsection (c)(6), in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1865-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Committee shall not affect its powers, but shall be filled in the same manner, in accordance with the same paragraph of subsection (c), as the original appointment or designation was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f1866-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f1867-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Disability Employment Policy, the Assistant Secretary for Employment and Training, and the Administrator of the Wage and Hour Division, of the Department of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1868-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of the Administration on Intellectual and Developmental Disabilities, or the Commissioner’s designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1869-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Centers for Medicare & Medicaid Services of the Department of Health and Human Services, or the Director’s designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f186a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of Social Security, or the Commissioner’s designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f186b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of the Rehabilitation Services Administration, or the Commissioner’s designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f186c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives from constituencies consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9f186d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-advocates for individuals with intellectual or developmental disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f186e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providers of employment services, including those that employ individuals with intellectual or developmental disabilities in competitive integrated employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f186f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of national disability advocacy organizations for adults with intellectual or developmental disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f1870-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts with a background in academia or research and expertise in employment and wage policy issues for individuals with intellectual or developmental disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f1871-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the employer community or national employer organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f1872-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/c/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals or representatives of organizations with expertise on increasing opportunities for competitive integrated employment for individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f1873-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall elect a Chairperson of the Committee from among the appointed members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f1874-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet at the call of the Chairperson, but not less than 8 times.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f1875-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall study, and prepare findings, conclusions, and recommendations for the Secretary of Labor on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f1876-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to increase the employment opportunities for individuals with intellectual or developmental disabilities or other individuals with significant disabilities in competitive integrated employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1877-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the certificate program carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s214/c"},"text":"section 214(c) of this title","children":[],"tail":" for the employment of individuals with intellectual or developmental disabilities, or other individuals with significant disabilities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1878-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to improve oversight of the use of such certificates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f1879-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee personnel matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f187a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Committee shall not receive compensation for the performance of services for the Committee, but shall be allowed reasonable travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Committee. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary may accept the voluntary and uncompensated services of members of the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f187b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor may designate such personnel as may be necessary to enable the Committee to perform its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f187c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal Government employee, with the approval of the head of the appropriate Federal agency, may be detailed to the Committee without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f187d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities, equipment, and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall make available to the Committee, under such arrangements as may be appropriate, necessary equipment, supplies, and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f187e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f187f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim and final reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall prepare and submit to the Secretary of Labor, as well as the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Education and the Workforce of the House of Representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9f1880-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interim report that summarizes the progress of the Committee, along with any interim findings, conclusions, and recommendations as described in subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f1881-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a final report that states final findings, conclusions, and recommendations as described in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1882-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation and submission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reports shall be prepared and submitted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9f1883-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the interim report, not later than 1 year after the date on which the Committee is established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9f1884-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the final report, not later than 2 years after the date on which the Committee is established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9f1885-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795n/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall terminate on the day after the date on which the Committee submits the final report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a9f1886-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s609"},"text":"Pub. L. 93–112, title VI, § 609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s461/11"},"text":"Pub. L. 113–128, title IV, § 461(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1682"},"text":"128 Stat. 1682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a9f1887-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a9f1888-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a9f1889-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 795n, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s609"},"text":"Pub. L. 93–112, title VI, § 609","children":[],"tail":", formerly § 628, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s409"},"text":"Pub. L. 105–220, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1217"},"text":"112 Stat. 1217","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/b/19"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(b)(19)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–414; renumbered § 609, "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s461/3"},"text":"Pub. L. 113–128, title IV, § 461(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1679"},"text":"128 Stat. 1679","children":[],"tail":", related to authorization of appropriations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s461/11"},"text":"Pub. L. 113–128, title IV, § 461(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1682"},"text":"128 Stat. 1682","children":[],"tail":". See section 795"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title. Provisions similar to prior section 795n were contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s795q"},"text":"section 795q of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 795n, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s635"},"text":"Pub. L. 93–112, title VI, § 635","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVI/s621/a"},"text":"Pub. L. 102–569, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4440"},"text":"106 Stat. 4440","children":[],"tail":", which related to State plans, was omitted in the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s795k"},"text":"section 795k of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 795n, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s635"},"text":"Pub. L. 93–112, title VI, § 635","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tVII/s704/a/1"},"text":"Pub. L. 99–506, title VII, § 704(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1836"},"text":"100 Stat. 1836","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s207/g"},"text":"Pub. L. 100–630, title II, § 207(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3314"},"text":"102 Stat. 3314","children":[],"tail":", related to availability and comparability of services under former part C of this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/s621/a"},"text":"Pub. L. 102–569, § 621(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
