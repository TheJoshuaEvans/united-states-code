{"tag":"section","attrib":{"id":"id5a1994b9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s115"},"text":null,"children":[{"tag":"num","attrib":{"value":"115"},"text":"§ 115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of conflicting acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All acts and parts of acts in conflict with the provisions of this chapter are repealed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a1994ba-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-03-23/ch90/s15"},"text":"Mar. 23, 1932, ch. 90, § 15","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/73"},"text":"47 Stat. 73","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
