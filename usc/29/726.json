{"tag":"section","attrib":{"id":"id5a7b3ce7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726"},"text":null,"children":[{"tag":"num","attrib":{"value":"726"},"text":"§ 726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation standards and performance indicators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a7b3ce8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7b3ce9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and indicators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The evaluation standards and performance indicators for the vocational rehabilitation program carried out under this subchapter shall be subject to the performance accountability provisions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b"},"text":"section 3141(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3cea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional performance accountability indicators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may establish and provide information on additional performance accountability indicators, which shall be identified in the State plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721"},"text":"section 721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7b3ceb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7b3cec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with regulations established by the Secretary, each State shall report to the Commissioner after the end of each fiscal year the extent to which the State is in compliance with the standards and indicators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3ced-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program improvement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3cee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commissioner determines that the performance of any State is below established standards, the Commissioner shall provide technical assistance to the State, and the State and the Commissioner shall jointly develop a program improvement plan outlining the specific actions to be taken by the State to improve program performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3cef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a7b3cf0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a biannual basis, review the program improvement efforts of the State and, if the State has not improved its performance to acceptable levels, as determined by the Commissioner, direct the State to make further revisions to the plan to improve performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a7b3cf1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to conduct such reviews and request such revisions until the State sustains satisfactory performance over a period of more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7b3cf2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commissioner determines that a State whose performance falls below the established standards has failed to enter into a program improvement plan, or is not complying substantially with the terms and conditions of such a program improvement plan, the Commissioner shall, consistent with subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s727"},"text":"section 727 of this title","children":[],"tail":", reduce or make no further payments to the State under this program, until the State has entered into an approved program improvement plan, or satisfies the Commissioner that the State is complying substantially with the terms and conditions of such a program improvement plan, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7b3cf3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s726/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 1999, the Commissioner shall include in each annual report to the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s710"},"text":"section 710 of this title","children":[],"tail":" an analysis of program performance, including relative State performance, based on the standards and indicators."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a7b3cf4-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s106"},"text":"Pub. L. 93–112, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s404"},"text":"Pub. L. 105–220, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1156"},"text":"112 Stat. 1156","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s416"},"text":"Pub. L. 113–128, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1654"},"text":"128 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a7b3cf5-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a7b3cf6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a7b3cf7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 726, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s106"},"text":"Pub. L. 93–112, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s127/a"},"text":"Pub. L. 102–569, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4385"},"text":"106 Stat. 4385","children":[],"tail":", related to evaluation standards and performance indicators, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a7b3cf8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s416/1"},"text":"Pub. L. 113–128, § 416(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which provided for the establishment, review, and revision of evaluation standards and performance indicators."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s416/2"},"text":"Pub. L. 113–128, § 416(2)","children":[],"tail":", substituted “on a biannual basis, review the program improvement efforts of the State and, if the State has not improved its performance to acceptable levels, as determined by the Commissioner, direct the State” for “review the program improvement efforts of the State on a biannual basis and, if necessary, request the State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a7b3cf9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id5a7b3cfa-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions of Terms in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s3"},"text":"section 3 of Pub. L. 113–128","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":", apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
