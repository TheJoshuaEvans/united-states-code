{"tag":"section","attrib":{"id":"id5b9e120a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225"},"text":null,"children":[{"tag":"num","attrib":{"value":"3225"},"text":"§ 3225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National dislocated worker grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b9e120b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9e120c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency or disaster","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency or disaster” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9e120d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency or a major disaster, as defined in paragraphs (1) and (2), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e120e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency or disaster situation of national significance that could result in a potentially large loss of employment, as declared or otherwise recognized by the chief official of a Federal agency with authority for or jurisdiction over the Federal response to the emergency or disaster situation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9e120f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disaster area” means an area that has suffered or in which has occurred an emergency or disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9e1210-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9e1211-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to award national dislocated worker grants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9e1212-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an entity described in subsection (c)(1)(B) to provide employment and training assistance to workers affected by major economic dislocations, such as plant closures, mass layoffs, or closures and realignments of military installations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e1213-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide assistance to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b9e1214-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor of any State within the boundaries of which is a disaster area, to provide disaster relief employment in the disaster area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9e1215-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor of any State to which a substantial number of workers from an area in which an emergency or disaster has been declared or otherwise recognized have relocated;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e1216-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide additional assistance to a State board or local board for eligible dislocated workers in a case in which the State board or local board has expended the funds provided under this section to carry out activities described in subparagraphs (A) and (B) and can demonstrate the need for additional funds to provide appropriate services for such workers, in accordance with requirements prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e6037-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide additional assistance to a State board or local board serving an area where—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b9e6038-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a higher-than-average demand for employment and training activities for dislocated members of the Armed Forces, spouses described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102/15/E"},"text":"section 3102(15)(E) of this title","children":[],"tail":", or members of the Armed Forces described in subsection (c)(2)(A)(iv), exceeds State and local resources for providing such activities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9e6039-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such activities are to be carried out in partnership with the Department of Defense and Department of Veterans Affairs transition assistance programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9e603a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions and obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue a final decision on an application for a national dislocated worker grant under this subsection not later than 45 calendar days after receipt of the application. The Secretary shall issue a notice of obligation for such grant not later than 10 days after the award of such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9e603b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and training assistance requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9e603c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipient eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9e603d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (b)(1)(A), an entity shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e603e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “entity” means a State, a local board, an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3221/c"},"text":"section 3221(c) of this title","children":[],"tail":", an entity determined to be eligible by the Governor of the State involved, and any other entity that demonstrates to the Secretary the capability to effectively respond to the circumstances relating to particular dislocations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9e603f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9e6040-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be eligible to receive employment and training assistance under a national dislocated worker grant awarded pursuant to subsection (b)(1)(A), an individual shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b9e6041-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dislocated worker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9e6042-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civilian employee of the Department of Defense or the Department of Energy employed at a military installation that is being closed, or that will undergo realignment, within the next 24 months after the date of the determination of eligibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9e6043-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is employed in a nonmanagerial position with a Department of Defense contractor, who is determined by the Secretary of Defense to be at risk of termination from employment as a result of reductions in defense expenditures, and whose employer is converting operations from defense to nondefense applications in order to prevent worker layoffs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9e8754-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a member of the Armed Forces who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b9e8755-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was on active duty or full-time National Guard duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b9e8756-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b9e8757-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is involuntarily separated (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1141"},"text":"section 1141 of title 10","children":[],"tail":") from active duty or full-time National Guard duty; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b9e8758-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated from active duty or full-time National Guard duty pursuant to a special separation benefits program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174a"},"text":"section 1174a of title 10","children":[],"tail":", or the voluntary separation incentive program under section 1175 of that title;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b9e8759-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not entitled to retired or retained pay incident to the separation described in subclause (II); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b9e875a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/A/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies for such employment and training assistance before the end of the 180-day period beginning on the date of that separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e875b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retraining assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individuals described in subparagraph (A)(iii) shall be eligible for retraining assistance to upgrade skills by obtaining marketable skills needed to support the conversion described in subparagraph (A)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e875c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and publish additional requirements related to eligibility for employment and training assistance under the national dislocated worker grants to ensure effective use of the funds available for this purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9e875d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the terms “military installation” and “realignment” have the meanings given the terms in section 2910 of the Defense Base Closure and Realignment Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Public Law 101–510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9e875e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster relief employment assistance requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9e875f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under subsection (b)(1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9e8760-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used, in coordination with the Administrator of the Federal Emergency Management Agency, as applicable, to provide disaster relief employment on projects that provide food, clothing, shelter, and other humanitarian assistance for emergency and disaster victims, and projects regarding demolition, cleaning, repair, renovation, and reconstruction of damaged and destroyed structures, facilities, and lands located within the disaster area and in offshore areas related to the emergency or disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9eae71-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be expended through public and private agencies and organizations engaged in such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9eae72-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be expended to provide employment and training activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9eae73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual shall be eligible to be offered disaster relief employment under subsection (b)(1)(B) if such individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9eae74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a dislocated worker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9eae75-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a long-term unemployed individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9eae76-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is temporarily or permanently laid off as a consequence of the emergency or disaster; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9eae77-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who is self-employed, becomes unemployed or significantly underemployed as a result of the emergency or disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9eae78-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on disaster relief employment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9eae79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), no individual shall be employed under subsection (b)(1)(B) for more than 12 months for work related to recovery from a single emergency or disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9eae7a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of a State, the Secretary may extend such employment, related to recovery from a single emergency or disaster involving the State, for not more than an additional 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9eae7b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of available funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under subsection (b)(1)(B) shall be available to assist workers described in paragraph (2) who are affected by an emergency or disaster, including workers who have relocated from an area in which an emergency or disaster has been declared or otherwise recognized, as appropriate. Under conditions determined by the Secretary and following notification to the Secretary, a State may use such funds, that are appropriated for any fiscal year and available for expenditure under any grant awarded to the State under this section, to provide any assistance authorized under this subsection. Funds used pursuant to the authority provided under this paragraph shall be subject to the liability and reimbursement requirements described in paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9eae7c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3225/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability and reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall be construed to relieve liability, by a responsible party that is liable under Federal law, for any costs incurred by the United States under subsection (b)(1)(B) or this subsection, including the responsibility to provide reimbursement for such costs to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b9ed58d-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s170"},"text":"Pub. L. 113–128, title I, § 170","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1573"},"text":"128 Stat. 1573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b9ed58e-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b9ed58f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b9ed590-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":", known as the Workforce Innovation and Opportunity Act, which enacted this chapter, repealed chapter 30 (§ 2801 et seq.) of this title and chapter 73 (§ 9201 et seq.) of Title 20, Education, and made amendments to numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b9ed591-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b9ed592-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
