7(a)(1)","children":[],"tail":", inserted “of Education” after “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s407/a/3/A"},"text":"Pub. L. 113–128, § 407(a)(3)(A)","children":[],"tail":"–(C), designated existing provisions as par. (1), redesignated subsec. (c) as par. (2), and redesignated subsec. (d) as par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s407/a/3/D"},"text":"Pub. L. 113–128, § 407(a)(3)(D)","children":[],"tail":", redesignated subsecs. (e) and (f) as (c) and (d), respectively. Former subsecs. (c) and (d) redesignated pars. (2) and (3), respectively, of subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s407/a/4"},"text":"Pub. L. 113–128, § 407(a)(4)","children":[],"tail":", added subsecs. (e) and (f). Former subsecs. (e) and (f) redesignated (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s407/a/2"},"text":"Pub. L. 113–128, § 407(a)(2)","children":[],"tail":", inserted “competitive” after “nonintegrated to”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
