{"tag":"section","attrib":{"id":"id5b48515b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1395"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395"},"text":"§ 1395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan notification to corporation of potentially significant withdrawals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation may, by regulation, require the plan sponsor of a multiemployer plan to provide notice to the corporation when the withdrawal from the plan by any employer has resulted, or will result, in a significant reduction in the amount of aggregate contributions under the plan made by employers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b48515c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4215"},"text":"Pub. L. 93–406, title IV, § 4215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1234"},"text":"94 Stat. 1234","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
