{"tag":"section","attrib":{"id":"id5a4ba1dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s531"},"text":null,"children":[{"tag":"num","attrib":{"value":"531"},"text":"§ 531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application of such provision to any person or circumstances, shall be held invalid, the remainder of this chapter or the application of such provision to persons or circumstances other than those as to which it is held invalid, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a4ba1de-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/257/tVI/s611"},"text":"Pub. L. 86–257, title VI, § 611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/541"},"text":"73 Stat. 541","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
