{"tag":"section","attrib":{"id":"id5b4607cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390"},"text":null,"children":[{"tag":"num","attrib":{"value":"1390"},"text":"§ 1390.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of withdrawal liability for certain temporary contribution obligation periods; exception","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b4607d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employer who withdraws from a plan in complete or partial withdrawal is not liable to the plan if the employer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4607d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first had an obligation to contribute to the plan after ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" had an obligation to contribute to the plan for no more than the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4607d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 consecutive plan years preceding the date on which the employer withdraws, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4607d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of years required for vesting under the plan,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was required to make contributions to the plan for each such plan year in an amount equal to less than 2 percent of the sum of all employer contributions made to the plan for each such year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has never avoided withdrawal liability because of the application of this section with respect to the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4607d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) shall apply to an employer with respect to a plan only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4607d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is amended to provide that subsection (a) applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan provides, or is amended to provide, that the reduction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s411/a/3/E"},"text":"section 411(a)(3)(E) of title 26","children":[],"tail":" applies with respect to the employees of the employer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1390/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ratio of the assets of the plan for the plan year preceding the first plan year for which the employer was required to contribute to the plan to the benefit payments made during that plan year was at least 8 to 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4607db-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4210"},"text":"Pub. L. 93–406, title IV, § 4210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1226"},"text":"94 Stat. 1226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7891/a/1"},"text":"Pub. L. 101–239, title VII, § 7891(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2445"},"text":"103 Stat. 2445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tII/s204/c/1"},"text":"Pub. L. 109–280, title II, § 204(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/887"},"text":"120 Stat. 887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b4607dc-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b4607dd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b4607de-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" redesignated pars. (2) to (4) as (1) to (3), respectively, and struck out former par. (1) which read as follows: “the plan is not a plan which primarily covers employees in the building and construction industry;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b4607df-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b4607e0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tII/s204/c/3"},"text":"Pub. L. 109–280, title II, § 204(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/887"},"text":"120 Stat. 887","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tII/s204/c/3"},"text":"“The amendments made by this subsection [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1391"},"text":"section 1391 of this title","children":[],"tail":"] shall apply with respect to plan withdrawals occurring on or after "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b4607e1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/f"},"text":"section 7891(f) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
