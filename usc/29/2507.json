{"tag":"section","attrib":{"id":"id5b628f91-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507"},"text":"§ 2507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of barriers to participation of women in apprenticeable occupations and nontraditional occupations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b628f92-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With funds available to the Secretary to carry out the operations of the Department of Labor in fiscal years 1994 and 1995, the Secretary shall conduct a study of the participation of women in apprenticeable occupations and nontraditional occupations. The study shall examine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b628f93-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the barriers to participation of women in apprenticeable occupations and nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f94-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies for overcoming such barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f95-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retention rates for women in apprenticeable occupations and nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f96-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies for retaining women in apprenticeable occupations and nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f97-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the technical assistance provided by the community-based organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f98-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant issues affecting the participation of women in apprenticeable occupations and nontraditional occupations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b628f99-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-27"},"text":"October 27, 1992","children":[],"tail":", the Secretary shall submit to the Congress a report containing a summary of the results of the study described in subsection (a) and such recommendations as the Secretary determines to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b628f9a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/530/s8"},"text":"Pub. L. 102–530, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3467"},"text":"106 Stat. 3467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
