{"tag":"section","attrib":{"id":"id5b628f7e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2504"},"text":null,"children":[{"tag":"num","attrib":{"value":"2504"},"text":"§ 2504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b628f7f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each community-based organization that desires to receive a grant to provide technical assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2503/a"},"text":"section 2503(a) of this title","children":[],"tail":" to employers and labor unions shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may reasonably require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b628f80-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2503/a"},"text":"section 2503(a) of this title","children":[],"tail":", the Secretary shall give priority to applications from community-based organizations that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b628f81-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate experience preparing women to gain employment in apprenticeable occupations or other nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f82-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate experience working with the business community to prepare them to place women in apprenticeable occupations or other nontraditional occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f83-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have tradeswomen or women in nontraditional occupations as active members of the organization, as either employed staff or board members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f84-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2504/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have experience delivering technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b628f85-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/530/s5"},"text":"Pub. L. 102–530, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3467"},"text":"106 Stat. 3467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
