{"tag":"section","attrib":{"id":"id5b981ed1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of conduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b981ed2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision and enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide, and directors of Job Corps centers shall stringently enforce, standards of conduct within the centers. Such standards of conduct shall include provisions forbidding the actions described in subsection (b)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b981ed3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disciplinary measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b981ed4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To promote the proper behavioral standards in the Job Corps, the directors of Job Corps centers shall have the authority to take appropriate disciplinary measures against enrollees if such a director determines that an enrollee has committed a violation of the standards of conduct. The director shall dismiss the enrollee from the Job Corps if the director determines that the retention of the enrollee in the Job Corps will jeopardize the enforcement of such standards, threaten the safety of staff, students, or the local community, or diminish the opportunities of other enrollees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b981ed5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero tolerance policy and drug testing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b981ed6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adopt guidelines establishing a zero tolerance policy for an act of violence, for use, sale, or possession of a controlled substance, for abuse of alcohol, or for other illegal or disruptive activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9845e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require drug testing of all enrollees for controlled substances in accordance with procedures prescribed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3195/a"},"text":"section 3195(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9845e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b9845e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “controlled substance” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"section 802 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9845ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero tolerance policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “zero tolerance policy” means a policy under which an enrollee shall be automatically dismissed from the Job Corps after a determination by the director that the enrollee has carried out an action described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9845eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A disciplinary measure taken by a director under this section shall be subject to expeditious appeal in accordance with procedures established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b9845ec-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s152"},"text":"Pub. L. 113–128, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1549"},"text":"128 Stat. 1549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b9845ed-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b9845ee-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b9845ef-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
