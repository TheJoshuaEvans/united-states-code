{"tag":"section","attrib":{"id":"id5a78f394-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s724"},"text":null,"children":[{"tag":"num","attrib":{"value":"724"},"text":"§ 724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share for establishment of program or construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of determining the amount of payments to States for carrying out part B (or to an Indian tribe under part C), the non-Federal share, subject to such limitations and conditions as may be prescribed in regulations by the Commissioner, shall include contributions of funds made by any private agency, organization, or individual to a State or local agency to assist in meeting the costs of establishment of a community rehabilitation program or construction, under special circumstances, of a facility for such a program, which would be regarded as State or local funds except for the condition, imposed by the contributor, limiting use of such funds to establishment of such a program or construction of such a facility.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a7b3c85-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s104"},"text":"Pub. L. 93–112, title I, § 104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s404"},"text":"Pub. L. 105–220, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1151"},"text":"112 Stat. 1151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a7b3c86-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a7b3c87-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a7b3c88-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 724, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s104"},"text":"Pub. L. 93–112, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/370"},"text":"87 Stat. 370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s122/b/1"},"text":"Pub. L. 95–602, title I, § 122(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2987"},"text":"92 Stat. 2987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tII/s205"},"text":"Pub. L. 99–506, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1817"},"text":"100 Stat. 1817","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s125"},"text":"Pub. L. 102–569, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4381"},"text":"106 Stat. 4381","children":[],"tail":", related to non-Federal share for construction, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
