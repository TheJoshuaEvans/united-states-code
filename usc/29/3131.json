{"tag":"section","attrib":{"id":"id5b7cced4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3131"},"text":null,"children":[{"tag":"num","attrib":{"value":"3131"},"text":"§ 3131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding of State and local boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b7cced5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State boards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In funding a State board under this part, a State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b7cced6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use funds available as described in section 3164(b)(3) or 3174(a)(3)(B) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b7cced7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use non-Federal funds available to the State that the State determines are appropriate and available for that use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b7cced8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local boards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In funding a local board under this part, the chief elected official and local board for the local area—","children":[],"tail":null},{"