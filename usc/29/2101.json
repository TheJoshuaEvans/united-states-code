{"tag":"section","attrib":{"id":"id5b6045a7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101"},"text":"§ 2101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; exclusions from definition of loss of employment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b6045a8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6045a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employer” means any business enterprise that employs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6045aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 or more employees, excluding part-time employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6045ab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 or more employees who in the aggregate work at least 4,000 hours per week (exclusive of hours of overtime);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045ac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “plant closing” means the permanent or temporary shutdown of a single site of employment, or one or more facilities or operating units within a single site of employment, if the shutdown results in an employment loss at the single site of employment during any 30-day period for 50 or more employees excluding any part-time employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045ad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “mass layoff” means a reduction in force which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6045ae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not the result of a plant closing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6045af-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" results in an employment loss at the single site of employment during any 30-day period for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b6045b0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b6045b1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 33 percent of the employees (excluding any part-time employees); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b6045b2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 employees (excluding any part-time employees); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b6045b3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 500 employees (excluding any part-time employees);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045b4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “representative” means an exclusive representative of employees within the meaning of section 159(a) or 158(f) of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s152"},"text":"section 152 of title 45","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045b5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “affected employees” means employees who may reasonably be expected to experience an employment loss as a consequence of a proposed plant closing or mass layoff by their employer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045b6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b), the term “employment loss” means (A) an employment termination, other than a discharge for cause, voluntary departure, or retirement, (B) a layoff exceeding 6 months, or (C) a reduction in hours of work of more than 50 percent during each month of any 6-month period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045b7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unit of local government” means any general purpose political subdivision of a State which has the power to levy taxes and spend funds, as well as general corporate and police powers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045b8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “part-time employee” means an employee who is employed for an average of fewer than 20 hours per week or who has been employed for fewer than 6 of the 12 months preceding the date on which notice is required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b6045b9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions from definition of employment loss","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6045ba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a sale of part or all of an employer’s business, the seller shall be responsible for providing notice for any plant closing or mass layoff in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2102"},"text":"section 2102 of this title","children":[],"tail":", up to and including the effective date of the sale. After the effective date of the sale of part or all of an employer’s business, the purchaser shall be responsible for providing notice for any plant closing or mass layoff in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2102"},"text":"section 2102 of this title","children":[],"tail":". Notwithstanding any other provision of this chapter, any person who is an employee of the seller (other than a part-time employee) as of the effective date of the sale shall be considered an employee of the purchaser immediately after the effective date of the sale."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6045bb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsection (a)(6), an employee may not be considered to have experienced an employment loss if the closing or layoff is the result of the relocation or consolidation of part or all of the employer’s business and, prior to the closing or layoff—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6045bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer offers to transfer the employee to a different site of employment within a reasonable commuting distance with no more than a 6-month break in employment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6045bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2101/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer offers to transfer the employee to any other site of employment regardless of distance with no more than a 6-month break in employment, and the employee accepts within 30 days of the offer or of the closing or layoff, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b6045be-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/379/s2"},"text":"Pub. L. 100–379, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/890"},"text":"102 Stat. 890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b6045bf-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b6045c0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b6045c1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/379/s11"},"text":"Pub. L. 100–379, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/895"},"text":"102 Stat. 895","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/379/s11"},"text":"“This Act [enacting this chapter] shall take effect on the date which is 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":"], except that the authority of the Secretary of Labor under section 8 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2107"},"text":"section 2107 of this title","children":[],"tail":"] is effective upon enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id5b6045c2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/379/s1/a"},"text":"Pub. L. 100–379, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-04"},"text":"Aug. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/890"},"text":"102 Stat. 890","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/379/s1/a"},"text":"“This Act [enacting this chapter] may be cited as the ‘Worker Adjustment and Retraining Notification Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
