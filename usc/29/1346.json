{"tag":"section","attrib":{"id":"id5b3edabe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1346"},"text":null,"children":[{"tag":"num","attrib":{"value":"1346"},"text":"§ 1346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to trustee","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation and the plan administrator of any plan to be terminated under this subtitle shall furnish to the trustee such information as the corporation or the plan administrator has and, to the extent practicable, can obtain regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edabf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1346/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of benefits payable with respect to each participant under a plan to be terminated,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edac0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1346/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of basic benefits guaranteed under section 1322 or 1322a of this title which are payable with respect to each participant in the plan,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edac1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1346/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value, as of the time of termination, of the aggregate amount of basic benefits payable under section 1322 or 1322a of this title (determined without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1322b"},"text":"section 1322b of this title","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edac2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1346/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the assets of the plan at the time of termination,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edac3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1346/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the computations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1344"},"text":"section 1344 of this title","children":[],"tail":", and all actuarial assumptions under which the items described in paragraphs (1) through (4) were computed, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edac4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1346/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information with respect to the plan the trustee may require in order to terminate the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b3edac5-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4046"},"text":"Pub. L. 93–406, title IV, § 4046","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1028"},"text":"88 Stat. 1028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIV/s403/e"},"text":"Pub. L. 96–364, title IV, § 403(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1301"},"text":"94 Stat. 1301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b3edac6-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b3edac7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b3edac8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/s403/e/1"},"text":"Pub. L. 96–364, § 403(e)(1)","children":[],"tail":", inserted “basic” before “benefits” and “or 1322a” after “1322”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/s403/e"},"text":"Pub. L. 96–364, § 403(e)","children":[],"tail":", inserted “basic” before “benefits” and “or 1322a” after “1322”, and substituted “1322b” for “1322(b)(5)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b3edac9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b3edaca-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"