{"tag":"section","attrib":{"id":"id5b00e75d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1113"},"text":null,"children":[{"tag":"num","attrib":{"value":"1113"},"text":"§ 1113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No action may be commenced under this subchapter with respect to a fiduciary’s breach of any responsibility, duty, or obligation under this part, or with respect to a violation of this part, after the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b00e75e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1113/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six years after (A) the date of the last action which constituted a part of the breach or violation, or (B) in the case of an omission the latest date on which the fiduciary could have cured the breach or violation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b00e75f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1113/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three years after the earliest date on which the plaintiff had actual knowledge of the breach or violation;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that in the case of fraud or concealment, such action may be commenced not later than six years after the date of discovery of such breach or violation.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b00e760-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s413"},"text":"Pub. L. 93–406, title I, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/889"},"text":"88 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9342/b"},"text":"Pub. L. 100–203, title IX, § 9342(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-371"},"text":"101 Stat. 1330–371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7881(j)(4), 7894(e)(5), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2443"},"text":"103 Stat. 2443","children":[],"tail":", 2450.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b00e761-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b00e762-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b00e763-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/e/5"},"text":"Pub. L. 101–239, § 7894(e)(5)","children":[],"tail":", struck out “(a)” before “No action”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7881/j/4"},"text":"Pub. L. 101–239, § 7881(j)(4)","children":[],"tail":", struck out comma after “violation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" struck out “(A)” after “date” and struck out “or (B) on which a report from which he could reasonably be expected to have obtained knowledge of such breach or violation was filed with the Secretary under this subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b00e764-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b00e765-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7881/j/4"},"text":"section 7881(j)(4) of Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Pension Protection Act, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", §§ 9302–9346, to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7882"},"text":"section 7882 of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401"},"text":"section 401 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/e/5"},"text":"section 7894(e)(5) of Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if originally included in the provision of the Employee Retirement Income Security Act of 1974, "},{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","childre