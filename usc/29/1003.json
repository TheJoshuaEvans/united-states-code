{"tag":"section","attrib":{"id":"id5ab4755f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003"},"text":null,"children":[{"tag":"num","attrib":{"value":"1003"},"text":"§ 1003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ab47560-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b) or (c) and in sections 1051, 1081, and 1101 of this title, this subchapter shall apply to any employee benefit plan if it is established or maintained—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ab47561-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any employer engaged in commerce or in any industry or activity affecting commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ab47562-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any employee organization or organizations representing employees engaged in commerce or in any industry or activity affecting commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ab47563-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ab47564-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for certain plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this subchapter shall not apply to any employee benefit plan if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ab47565-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such plan is a governmental plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/32"},"text":"section 1002(32) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ab47566-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such plan is a church plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/33"},"text":"section 1002(33) of this title","children":[],"tail":") with respect to which no election has been made under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s410/d"},"text":"section 410(d) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ab47567-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such plan is maintained solely for the purpose of complying with applicable workmen’s compensation laws or unemployment compensation or disability insurance laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ab47568-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such plan is maintained outside of the United States primarily for the benefit of persons substantially all of whom are nonresident aliens; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ab47569-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such plan is an excess benefit plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/36"},"text":"section 1002(36) of this title","children":[],"tail":") and is unfunded."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The provisions of part 7 of subtitle B of this subchapter shall not apply to a health insurance issuer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/b/2"},"text":"section 1191b(b)(2) of this title","children":[],"tail":") solely by reason of health insurance coverage (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/b/1"},"text":"section 1191b(b)(1) of this title","children":[],"tail":") provided by such issuer in connection with a group health plan (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/a/1"},"text":"section 1191b(a)(1) of this title","children":[],"tail":") if the provisions of this subchapter do not apply to such group health plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ab4756a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary employee contributions to accounts and annuities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a pension plan allows an employee to elect to make voluntary employee contributions to accounts and annuities as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s408/q"},"text":"section 408(q) of title 26","children":[],"tail":", such accounts and annuities (and contributions thereto) shall not be treated as part of such plan (or as a separate pension plan) for purposes of any provision of this subchapter other than section 1103(c), 1104, or 1105 of this title (relating to exclusive benefit, and fiduciary and co-fiduciary responsibilities) and part 5 of subtitle B of this subchapter "},{"tag":"ref","attrib":{"idref":"fn002071"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (relating to administration and enforcement). Such provisions shall apply to such accounts and annuities in a manner similar to their application to a simplified employee pension under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s408/k"},"text":"section 408(k) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ab4756b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s4"},"text":"Pub. L. 93–406, title I, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/839"},"text":"88 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7891/a/1"},"text":"Pub. L. 101–239, title VII, § 7891(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2445"},"text":"103 Stat. 2445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s101/d"},"text":"Pub. L. 104–191, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1952"},"text":"110 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s603/b/3/A"},"text":"Pub. L. 104–204, title VI, § 603(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2938"},"text":"110 Stat. 2938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/16/tVI/s602/b"},"text":"Pub. L. 107–16, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-06-07"},"text":"June 7, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/96"},"text":"115 Stat. 96","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s411/i/2"},"text":"Pub. L. 107–147, title IV, § 411(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/47"},"text":"116 Stat. 47","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ab4756c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ab4756d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5ab4756e-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part 5 of subtitle B of this subchapter, referred to in subsec. (c), was in the original a reference to “part 5” and was translated as meaning part 5 of subtitle B of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5ab4756f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text":"Pub. L. 107–147","children":[],"tail":" inserted “and part 5 of subtitle B of this subchapter (relating to administration and enforcement)” after “co-fiduciary responsibilities)” and “Such provisions shall apply to such accounts and annuities in a manner similar to their application to a simplified employee pension under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s408/k"},"text":"section 408(k) of title 26","children":[],"tail":".” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s602/b/2"},"text":"Pub. L. 107–16, § 602(b)(2)","children":[],"tail":", inserted “or (c)” after “subsection (b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/16/s602/b/1"},"text":"Pub. L. 107–16, § 602(b)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":", in concluding provisions, made technical amendment to references in original act which appear in text as references to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b"},"text":"section 1191b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":" inserted at end “The provisions of part 7 of subtitle B of this subchapter shall not apply to a health insurance issuer (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/b/2"},"text":"section 1191b(b)(2) of this title","children":[],"tail":") solely by reason of health insurance coverage (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/b/1"},"text":"section 1191b(b)(1) of this title","children":[],"tail":") provided by such issuer in connection with a group health plan (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/a/1"},"text":"section 1191b(a)(1) of this title","children":[],"tail":") if the provisions of this subchapter do not apply to such group health plan.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ab6e670-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5ab6e671-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/147"},"text"