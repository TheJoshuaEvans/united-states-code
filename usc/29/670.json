{"tag":"section","attrib":{"id":"id5a636edf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670"},"text":null,"children":[{"tag":"num","attrib":{"value":"670"},"text":"§ 670.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and employee education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a636ee0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of Health and Human Services to conduct education and informational programs; consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, after consultation with the Secretary and with other appropriate Federal departments and agencies, shall conduct, directly or by grants or contracts (1) education programs to provide an adequate supply of qualified personnel to carry out the purposes of this chapter, and (2) informational programs on the importance of and proper use of adequate safety and health equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636ee1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of Labor to conduct short-term training of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is also authorized to conduct, directly or by grants or contracts, short-term training of personnel engaged in work related to his responsibilities under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636ee2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of Labor to establish and supervise education and training programs and consult and advise interested parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Health and Human Services, shall (1) provide for the establishment and supervision of programs for the education and training of employers and employees in the recognition, avoidance, and prevention of unsafe or unhealthful working conditions in employments covered by this chapter, and (2) consult with and advise employers and employees, and organizations representing employers and employees as to effective means of preventing occupational injuries and illnesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636ee3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance assistance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a636ee4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish and support cooperative agreements with the States under which employers subject to this chapter may consult with State personnel with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636ee5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of occupational safety and health requirements under this chapter or under State plans approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s667"},"text":"section 667 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636ee6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary efforts that employers may undertake to establish and maintain safe and healthful employment and places of employment.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such agreements may provide, as a condition of receiving funds under such agreements, for contributions by States towards meeting the costs of such agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636ee7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to such agreements the State shall provide on-site consultation at the employer’s worksite to employers who request such assistance. The State may also provide other education and training programs for employers and employees in the State. The State shall ensure that on-site consultations conducted pursuant to such agreements include provision for the participation by employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636ee8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities under this subsection shall be conducted independently of any enforcement activity. If an employer fails to take immediate action to eliminate employee exposure to an imminent danger identified in a consultation or fails to correct a serious hazard so identified within a reasonable time, a report shall be made to the appropriate enforcement authority for such action as is appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636ee9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall, by regulation after notice and opportunity for comment, establish rules under which an employer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636eea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which requests and undergoes an on-site consultative visit provided under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636eeb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which corrects the hazards that have been identified during the visit within the time frames established by the State and agrees to request a subsequent consultative visit if major changes in working conditions or work processes occur which introduce new hazards in the workplace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636eec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is implementing procedures for regularly identifying and preventing hazards regulated under this chapter and maintains appropriate involvement of, and training for, management and non-management employees in achieving safe and healthful working conditions,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may be exempt from an inspection (except an inspection requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s657/f"},"text":"section 657(f) of this title","children":[],"tail":" or an inspection to determine the cause of a workplace accident which resulted in the death of one or more employees or hospitalization for three or more employees) for a period of 1 year from the closing of the consultative visit."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636eed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s670/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State shall provide worksite consultations under paragraph (2) at the request of an employer. Priority in scheduling such consultations shall be assigned to requests from small businesses which are in higher hazard industries or have the most hazardous conditions at issue in the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a636eee-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596/s21"},"text":"Pub. L. 91–596, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1612"},"text":"84 Stat. 1612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/197/s2"},"text":"Pub. L. 105–197, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-16"},"text":"July 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/638"},"text":"112 Stat. 638","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a636eef-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a636ef0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a636ef1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/197"},"text":"Pub. L. 105–197","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a636ef2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5a636ef3-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsecs. (a) and (c) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5a636ef4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retention of Training Institute Course Tuition Fees by OSHA","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions stating that notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"31 U.S.C. 3302","children":[],"tail":", the Occupational Safety and Health Administration could retain up to $750,000 per fiscal year of training institute course tuition fees, otherwise authorized by law to be collected, and could utilize such sums for occupational safety and health training and education grants, were contained in Department of Labor Appropriations Act, 2006, "},{"tag":"ref","attrib":{"href":"/us/pl/109/149/tI"},"text":"Pub. L. 109–149, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2839"},"text":"119 Stat. 2839","children":[],"tail":", and were repeated in provisions of subsequent appropriations acts which are not set out in the Code. Similar provisions were also contained in the following prior appropriations acts:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dF/tI"},"text":"Pub. L. 108–447, div. F, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3118"},"text":"118 Stat. 3118","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dE/tI"},"text":"Pub. L. 108–199, div. E, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/232"},"text":"118 Stat. 232","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dG/tI"},"text":"Pub. L. 108–7, div. G, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/303"},"text":"117 Stat. 303","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/116/tI"},"text":"Pub. L. 107–116, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2182"},"text":"115 Stat. 2182","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/1/tI"},"text":"Pub. L. 106–554, § 1(a)(1) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–8."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/4/tI"},"text":"Pub. L. 106–113, div. B, § 1000(a)(4) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–222."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tI"},"text":"Pub. L. 105–277, div. A, § 101(f) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–343."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/78/tI"},"text":"Pub. L. 105–78, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1474"},"text":"111 Stat. 1474","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/e/tI"},"text":"Pub. L. 104–208, div. A, title I, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-233"},"text":"110 Stat. 3009–233","children":[],"tail":", 3009–239."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101/d/tI"},"text":"Pub. L. 104–134, title I, § 101(d) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-211"},"text":"110 Stat. 1321–211","children":[],"tail":", 1321–217; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/333/tI"},"text":"Pub. L. 103–333, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2544"},"text":"108 Stat. 2544","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
