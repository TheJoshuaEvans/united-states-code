{"tag":"section","attrib":{"id":"id5b65015b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614"},"text":null,"children":[{"tag":"num","attrib":{"value":"2614"},"text":"§ 2614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and benefits protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b65015c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration to position","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b65015d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), any eligible employee who takes leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":" for the intended purpose of the leave shall be entitled, on return from such leave—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b65015e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be restored by the employer to the position of employment held by the employee when the leave commenced; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b65015f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be restored to an equivalent position with equivalent employment benefits, pay, and other terms and conditions of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b650160-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The taking of leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":" shall not result in the loss of any employment benefit accrued prior to the date on which the leave commenced."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b650161-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to entitle any restored employee to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b650162-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accrual of any seniority or employment benefits during any period of leave; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b650163-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right, benefit, or position of employment other than any right, benefit, or position to which the employee would have been entitled had the employee not taken the leave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b650164-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of restoration under paragraph (1) for an employee who has taken leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/D"},"text":"section 2612(a)(1)(D) of this title","children":[],"tail":", the employer may have a uniformly applied practice or policy that requires each such employee to receive certification from the health care provider of the employee that the employee is able to resume work, except that nothing in this paragraph shall supersede a valid State or local law or a collective bargaining agreement that governs the return to work of such employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b650165-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to prohibit an employer from requiring an employee on leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":" to report periodically to the employer on the status and intention of the employee to return to work."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b650166-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption concerning certain highly compensated employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b650167-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of restoration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employer may deny restoration under subsection (a) to any eligible employee described in paragraph (2) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b650168-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such denial is necessary to prevent substantial and grievous economic injury to the operations of the employer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b650169-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer notifies the employee of the intent of the employer to deny restoration on such basis at the time the employer determines that such injury would occur; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b65016a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which the leave has commenced, the employee elects not to return to employment after receiving such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b65016b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affected employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible employee described in paragraph (1) is a salaried eligible employee who is among the highest paid 10 percent of the employees employed by the employer within 75 miles of the facility at which the employee is employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b67716c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of health benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b67716d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), during any period that an eligible employee takes leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":", the employer shall maintain coverage under any “group health plan” (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s5000/b/1"},"text":"section 5000(b)(1) of title 26","children":[],"tail":") for the duration of such leave at the level and under the conditions coverage would have been provided if the employee had continued in employment continuously for the duration of such leave."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b67716e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to return from leave","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The employer may recover the premium that the employer paid for maintaining coverage for the employee under such group health plan during any period of unpaid leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b67716f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee fails to return from leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":" after the period of leave to which the employee is entitled has expired; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b677170-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the employee fails to return to work for a reason other than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b677171-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuation, recurrence, or onset of a serious health condition that entitles the employee to leave under subparagraph (C) or (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1"},"text":"section 2612(a)(1) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/3"},"text":"section 2612(a)(3) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b677172-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other circumstances beyond the control of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b677173-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b677174-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employer may require that a claim that an employee is unable to return to work because of the continuation, recurrence, or onset of the serious health condition described in paragraph (2)(B)(i) be supported by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b677175-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification issued by the health care provider of the son, daughter, spouse, or parent of the employee, as appropriate, in the case of an employee unable to return to work because of a condition specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/C"},"text":"section 2612(a)(1)(C) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b677176-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification issued by the health care provider of the eligible employee, in the case of an employee unable to return to work because of a condition specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1/D"},"text":"section 2612(a)(1)(D) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b677177-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification issued by the health care provider of the servicemember being cared for by the employee, in the case of an employee unable to return to work because of a condition specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/3"},"text":"section 2612(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b677178-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The employee shall provide, in a timely manner, a copy of such certification to the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b677179-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sufficiency of certification","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b67717a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave due to serious health condition of employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certification described in subparagraph (A)(ii) shall be sufficient if the certification states that a serious health condition prevented the employee from being able to perform the functions of the position of the employee on the date that the leave of the employee expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b67717b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2614/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave due to serious health condition of family member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certification described in subparagraph (A)(i) shall be sufficient if the certification states that the employee is needed to care for the son, daughter, spouse, or parent who has a serious health condition on the date that the leave of the employee expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b67717c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tI/s104"},"text":"Pub. L. 103–3, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/12"},"text":"107 Stat. 12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s585/a/3/F"},"text":"Pub. L. 110–181, div. A, title V, § 585(a)(3)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/131"},"text":"122 Stat. 131","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b67717d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b67717e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b67717f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s585/a/3/F/i"},"text":"Pub. L. 110–181, § 585(a)(3)(F)(i)","children":[],"tail":", inserted “or under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/3"},"text":"section 2612(a)(3) of this title","children":[],"tail":"” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s585/a/3/F/ii"},"text":"Pub. L. 110–181, § 585(a)(3)(F)(ii)","children":[],"tail":", added cl. (iii)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b677180-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b677181-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", except that, in the case of collective bargaining agreements in effect on that effective date, section applicable on the earlier of (1) the date of termination of such agreement, or (2) the date that occurs 12 months after "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/3/s405/b"},"text":"section 405(b) of Pub. L. 103–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
