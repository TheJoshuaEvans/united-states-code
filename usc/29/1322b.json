{"tag":"section","attrib":{"id":"id5b353e3c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1322b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1322b"},"text":"§ 1322b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate limit on benefits guaranteed; criteria applicable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b353e3d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1322b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding sections 1322 and 1322a of this title, no person shall receive from the corporation pursuant to a guarantee by the corporation of basic benefits with respect to a participant under all multiemployer and single employer plans an amount, or amounts, with an actuarial value which exceeds the actuarial value of a monthly benefit in the form of a life annuity commencing at age 65 equal to the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1322/b/3/B"},"text":"section 1322(b)(3)(B) of this title","children":[],"tail":" as of the date of the last plan termination."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b353e3e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1322b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b353e3f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1322b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of benefits under a multiemployer plan receiving financial assistance from the corporation shall be considered the receipt of amounts from the corporation pursuant to a guarantee by the corporation of basic benefits except to the extent provided in regulations prescribed by the corporation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b353e40-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1322b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a multiemployer plan, whether or not terminated, begins receiving financial assistance from the corporation shall be considered a date of plan termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b353e41-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4022B"},"text":"Pub. L. 93–406, title IV, § 4022B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s102"},"text":"Pub. L. 96–364, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1215"},"text":"94 Stat. 1215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b353e42-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b353e43-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b353e44-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":" Section effective ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
