{"tag":"section","attrib":{"id":"id5b222c58-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193"},"text":null,"children":[{"tag":"num","attrib":{"value":"1193"},"text":"§ 1193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pension-linked emergency savings accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b222c59-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan sponsor of an individual account plan may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222c5a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in such individual account plan a pension-linked emergency savings account meeting the requirements of subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c5b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c5c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer to enroll an eligible participant in such pension-linked emergency savings account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c5d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatically enroll an eligible participant in such account pursuant to an automatic contribution arrangement described in paragraph (2) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222c5e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible participant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222c5f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “eligible participant”, with regard to an individual account plan, means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c60-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets any age, service, and other eligibility requirements of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c61-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a highly compensated employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c62-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible participant who becomes a highly compensated employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1)(B), an individual who is enrolled in a pension-linked emergency savings account and thereafter becomes a highly compensated employee may not make further contributions to such account, but retains the right to withdraw any account balance of such account in accordance with subsection (c)(1)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c63-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “highly compensated employee” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s414/q"},"text":"section 414(q) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222c64-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222c65-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A pension-linked emergency savings account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c66-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b222c67-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not have a minimum contribution or account balance requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c68-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for withdrawal by the participant of the account balance, in whole or in part at the discretion of the participant, at least once per calendar month and for distribution of such withdrawal to the participant as soon as practicable from the date on which the participant elects to make such withdrawal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c69-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be, as selected by the plan sponsor, held as cash, in an interest-bearing deposit account, or in an investment product—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b222c6a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designed to—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b249c6b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A/iii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain over the term of the investment, the dollar value that is equal to the amount invested in the product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b249c6c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A/iii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve principal and provide a reasonable rate of return, whether or not such return is guaranteed, consistent with the need for liquidity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b249c6d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered by a State- or federally-regulated financial institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c6e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be subject to, as permitted by the Secretary, reasonable restrictions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c6f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c70-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not, for not less than the first 4 withdrawals of funds from the account in a plan year, be subject to any fees or charges solely on the basis of such a withdrawal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c71-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, for any subsequent withdrawal in a plan year, be subject to reasonable fees or charges in connection with such a withdrawal, including reasonable reimbursement fees imposed for the incidental costs of handling of paper checks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249c72-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and termination of account","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b249c73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pension-linked emergency savings account feature shall be included in the plan document of the individual account plan. Such individual account plan shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separately account for contributions to the pension-linked emergency savings account of the individual account plan and any earnings properly allocable to the contributions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c75-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain separate recordkeeping with respect to each such pension-linked emergency savings account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c76-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow withdrawals from such account in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s402A/e/7"},"text":"section 402A(e)(7) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c77-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan sponsor may terminate the pension-linked emergency savings account feature of an individual account plan at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b249c78-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b249c79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b249c7a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), no contribution shall be accepted to a pension-linked emergency savings account to the extent such contribution would cause the portion of the account balance attributable to participant contributions to exceed the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c7b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,500; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c7c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined by the plan sponsor of the pension-linked emergency savings account.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In the case of contributions made in taxable years beginning after ","children":[{"tag":"date","attrib":{"date":"2024-12-31"},"text":"December 31, 2024","children":[],"tail":", the Secretary shall adjust the amount under clause (i) at the same time and in the same manner as the adjustment made by the Secretary of the Treasury under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s415/d"},"text":"section 415(d) of title 26","children":[],"tail":", except that the base period shall be the calendar quarter beginning "},{"tag":"date","attrib":{"date":"2023-07-01"},"text":"July 1, 2023","children":[],"tail":". Any increase under the preceding sentence which is not a multiple of $100 shall be rounded to the next lowest multiple of $100."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c7d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess contributions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent any contribution to the pension-linked emergency savings account of a participant for a taxable year would exceed the limitation of subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c7e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a participant with another designated Roth account under the individual account plan, such plan may provide that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b249c7f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant may elect to increase the participant’s contribution to such other account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b249c80-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of such a participant election, the participant is deemed to have elected to increase the participant’s contributions to such other account at the rate at which contributions were being made to the pension-linked emergency savings account; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c81-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, such plan shall provide that such excess contributions will not be accepted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249c82-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic contribution arrangement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b249c83-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An automatic contribution arrangement described in this paragraph is an arrangement under which an eligible participant is treated as having elected to have the plan sponsor make elective contributions to a pension-linked emergency savings account at a participant contribution rate that is not more than 3 percent of the compensation of the eligible participant, unless the eligible participant, at any time (subject to such reasonable advance notice as is required by the plan administrator), affirmatively elects to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c84-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make contributions at a different rate or amount; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c85-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opt out of such contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c86-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant contribution rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of an automatic contribution arrangement described in subparagraph (A), the plan sponsor—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c87-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall select a participant contribution rate under such automatic contribution arrangement that meets the requirements of subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c88-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may amend (prior to the plan year in which an amendment would take effect) such rate not more than once annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249c89-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by plan administrator of contributions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b249c8a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an individual account plan with a pension-linked emergency savings account feature, the administrator of the plan shall, not less than 30 days and not more than 90 days prior to date of the first contribution to the pension-linked emergency savings account, including any contribution under an automatic contribution arrangement described in subsection (d)(2), or the date of any adjustment to the participant contribution rate under subsection (d)(2)(B)(ii), and not less than annually thereafter, shall furnish to the participant a notice describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c8b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of the account, which is for short-term, emergency savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c8c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limits on, and tax treatment of, contributions to the pension-linked emergency savings account of the participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c8d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fees, expenses, restrictions, or charges associated with such pension-linked emergency savings account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c8e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for electing to make contributions to or opting out of the pension-linked emergency savings account, for changing participant contribution rates for such pension-linked emergency savings account, and for making participant withdrawals from such pension-linked emergency savings account, including any limits on frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c8f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as applicable, the amount of the intended contribution to such pension-linked emergency savings account or the change in the percentage of the compensation of the participant of such contribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c90-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in the emergency savings account and the amount or percentage of compensation that a participant has contributed to the pension-linked emergency savings account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c91-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designated investment option under subsection (c)(1)(A)(iii) for amounts contributed to the pension-linked emergency savings account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c92-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the options under subsection (e) for the account balance of the pension-linked emergency savings account after termination of the employment of the participant or termination by the plan sponsor of the pension-linked emergency savings account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c93-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of a participant who becomes a highly compensated employee (as such term is defined in paragraph (3) of subsection (b)) to, as described in paragraph (2) of such subsection, withdraw any account balance from a pension-linked emergency savings account and the restriction on the ability of such a participant to make further contributions to the pension-linked emergency savings account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c94-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notice furnished to a participant under subparagraph (A) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b249c95-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficiently accurate and comprehensive to apprise the participant of the rights and obligations of the participant with regard to the pension-linked emergency savings account of the participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b249c96-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written in a manner calculated to be understood by the average participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c97-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The required notices under subparagraph (A) may be included with any other notice under this chapter, including under section 1104(c)(5)(B) or 1144(e)(3) of this title, or under section 401(k)(13)(E) or 414(w)(4) of title 26, if such other notice is provided to the participant at the time required for such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249c98-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer matching contributions to an individual account plan for employee contributions to a pension-linked emergency savings account","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b249c99-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an employer makes any matching contributions to an individual account plan of which a pension-linked emergency savings account is part, subject to the limitations of paragraph (1)(A), the employer shall make matching contributions on behalf of a participant on account of the contributions by the participant to the pension-linked emergency savings account at the same rate as any other matching contribution on account of an elective contribution by such participant. The matching contributions shall be made to the participant’s account under the individual account plan that is not the pension-linked emergency savings account. Such matching contributions on account of contributions under paragraph (1)(A) shall not exceed the maximum account balance under paragraph (1)(A) for such plan year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c9a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of any applicable limitation on matching contributions, any matching contributions made under the plan shall be treated first as attributable to the elective deferrals of the participant other than contributions to a pension-linked emergency savings account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249c9b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), the term “matching contribution” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s401/m/4"},"text":"section 401(m)(4) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b249c9c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account balance after termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon termination of employment of the participant, or termination by the plan sponsor of the pension-linked emergency savings account, the pension-linked emergency savings account of such participant in an individual account plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b249c9d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow, at the election of the participant, for transfer by the participant of the account balance of such account, in whole or in part, into another designated Roth account of the participant under the individual account plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249c9e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any amounts in such account not transferred under paragraph (1), make such amounts available within a reasonable time to the participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b249c9f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-abuse rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b249ca0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan of which a pension-linked emergency savings account is part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b249ca1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may employ reasonable procedures to limit the frequency or amount of matching contributions with respect to contributions to such account, solely to the extent necessary to prevent manipulation of the rules of the plan to cause matching contributions to exceed the intended amounts or frequency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249ca2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be required to suspend matching contributions following any participant withdrawal of contributions, including elective deferrals and employee contributions, whether or not matched and whether or not made pursuant to an automatic contribution arrangement described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s402A/e/4"},"text":"section 402A(e)(4) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249ca3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations or other guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury, in consultation with the Secretary of Labor, shall issue regulations or other guidance not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", with respect to the anti-abuse rules described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b249ca4-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s801"},"text":"Pub. L. 93–406, title I, § 801","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s127/b/1"},"text":"Pub. L. 117–328, div. T, title I, § 127(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5318"},"text":"136 Stat. 5318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b249ca5-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b249ca6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b249ca7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"Dec. 31, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s127/g"},"text":"section 127(g) of Pub. L. 117–328","children":[],"tail":", set out as an Effective Date of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
