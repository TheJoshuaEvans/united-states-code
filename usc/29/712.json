{"tag":"section","attrib":{"id":"id5a6d0c44-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712"},"text":null,"children":[{"tag":"num","attrib":{"value":"712"},"text":"§ 712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6d0c45-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; information and resources for individuals with disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Education shall establish a central clearinghouse for information and resource availability for individuals with disabilities which shall provide information and data regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0c46-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location, provision, and availability of services and programs for individuals with disabilities, including such information and data provided by State workforce development boards regarding such services and programs authorized under title I of such Act; ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c47-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and recent medical and scientific developments bearing on disabilities (and their prevention, amelioration, causes, and cures); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c48-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current numbers of individuals with disabilities and their needs.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The clearinghouse shall also provide any other relevant information and data which the Secretary of Education considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c49-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and data retrieval system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may assist the Secretary of Education to develop within the Department of Education a coordinated system of information and data retrieval, which will have the capacity and responsibility to provide information regarding the information and data referred to in subsection (a) of this section to the Congress, public and private agencies and organizations, individuals with disabilities and their families, professionals in fields serving such individuals, and the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6f563a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Information and Resources for Individuals with Disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The office established to carry out the provisions of this section shall be known as the “Office of Information and Resources for Individuals with Disabilities”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6f563b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6f563c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s15"},"text":"Pub. L. 93–112, § 15","children":[],"tail":", formerly § 13, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1113"},"text":"112 Stat. 1113","children":[],"tail":"; renumbered § 15, "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/a/1"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–412; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s407/b"},"text":"Pub. L. 113–128, title IV, § 407(b)","children":[],"tail":", "},{"