{"tag":"section","attrib":{"id":"id5b70e7e2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006"},"text":null,"children":[{"tag":"num","attrib":{"value":"3006"},"text":"§ 3006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects of national significance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b70e7e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of project of national significance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “project of national significance”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e7e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a project that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases access to, and acquisition of, assistive technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates opportunities for individuals with disabilities to directly and fully contribute to, and participate in, all facets of education, employment, community living, and recreational activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e7e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and expand partnerships between State Medicaid agencies and recipients of grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":" to reutilize durable medical equipment;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase collaboration between the recipients of grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":" and States receiving grants under the Money Follows the Person Rebalancing Demonstration under section 6071 of the Deficit Reduction Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"42 U.S.C. 1396a","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase collaboration between recipients of grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":" and area agencies on aging, as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3002"},"text":"section 3002 of title 42","children":[],"tail":", which may include collaboration on emergency preparedness, safety equipment, or assistive technology toolkits;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide aid to assist youth with disabilities to transition from school to adult life, especially in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b70e7ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finding employment and postsecondary education opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e7ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upgrading and changing any assistive technology devices that may be needed as a youth matures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase access to and acquisition of assistive technology addressing the needs of aging individuals and aging caregivers in the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase effective and efficient use of assistive technology as part of early intervention for infants and toddlers with disabilities from birth to age 3;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase awareness of and access to the Disability Funds-Financial Assistance funding provided by the Community Development Financial Institutions Fund that supports acquisition of assistive technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase awareness of and access to assistive technology, such as through models described in subclauses (I) through (IV) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/e/2/A/iii"},"text":"section 3003(e)(2)(A)(iii) of this title","children":[],"tail":" and other Federally funded disability programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e7f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If funds are available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3008/c"},"text":"section 3008(c) of this title","children":[],"tail":" to carry out this section for a fiscal year, the Secretary may award, on a competitive basis, grants, contracts, and cooperative agreements to public or private nonprofit entities to enable the entities to carry out projects of national significance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e7f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A public or private nonprofit entity desiring a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing a description of the project of national significance the entity proposes to carry out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e7f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each grant award period, the Secretary may give preference for 1 or more categories of projects of national significance described in subparagraphs (A) through (H) of subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e7f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3006/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum funding level required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only award grants, contracts, or cooperative agreements under this section if the amount made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3008"},"text":"section 3008 of this title","children":[],"tail":" to carry out sections 3003, 3004, and 3005 of this title is equal to or greater than $49,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b70e7f6-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/394/s7"},"text":"Pub. L. 105–394, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/364/s2"},"text":"Pub. L. 108–364, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1734"},"text":"118 Stat. 1734","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s491"},"text":"Pub. L. 113–128, title IV, § 491","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1698"},"text":"128 Stat. 1698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5402"},"text":"Pub. L. 117–263, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3286"},"text":"136 Stat. 3286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b70e7f7-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b70e7f8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b70e7f9-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6071 of the Deficit Reduction Act of 2005, referred to in subsec. (a)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s6071"},"text":"section 6071 of Pub. L. 109–171","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396a"},"text":"section 1396a of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b70e7fa-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section contained provisions for the administration of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s491"},"text":"Pub. L. 113–128, § 491","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3)(A)(i), substituted “the Administrator of the Administration for Community Living” for “the Assistant Secretary for Special Education and Rehabilitative Services of the Department of Education, acting through the Rehabilitation Services Administration,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s491"},"text":"Pub. L. 113–128, § 491","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3)(A)(ii), substituted “The Administrator of the Administration for Community Living shall consult with the Office of Special Education Programs of the Department of Education, the Rehabilitation Services Administration of the Department of Education, the Office of Disability Employment Policy of the Department of Labor, the National Institute on Disability, Independent Living, and Rehabilitation Research, and other appropriate Federal entities in the administration of this chapter.” for “The Assistant Secretary for Special Education and Rehabilitative Services shall consult with the Office of Special Education Programs, the Rehabilitation Services Administration, and the National Institute on Disability and Rehabilitation Research in the Office of Special Education and Rehabilitative Services, and appropriate Federal entities in the administration of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s491"},"text":"Pub. L. 113–128, § 491","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3)(A)(iii), substituted “the Administrator of the Administration for Community Living” for “the Rehabilitation Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s491"},"text":"Pub. L. 113–128, § 491","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3)(B), substituted “Health and Human Services” for “Education”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b70e7fb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b70e7fc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" effective on the day that is 6 months after "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5403"},"text":"section 5403 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
