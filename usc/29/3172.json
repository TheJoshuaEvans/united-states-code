{"tag":"section","attrib":{"id":"id5b8b9b3f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172"},"text":null,"children":[{"tag":"num","attrib":{"value":"3172"},"text":"§ 3172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b8b9b40-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b8b9b41-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make allotments and grants from the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/b"},"text":"section 3181(b) of this title","children":[],"tail":" for a fiscal year in accordance with subsection (b)(1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8b9b42-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b8b9b43-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve 20 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/c"},"text":"section 3181(c) of this title","children":[],"tail":" for the fiscal year for use under subsection (b)(2)(A), and under sections 3223(b) (relating to dislocated worker technical assistance), 3224(c) (relating to dislocated worker projects), and 3225 of this title (relating to national dislocated worker grants); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b8bc254-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make allotments from 80 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/c"},"text":"section 3181(c) of this title","children":[],"tail":" for the fiscal year in accordance with subsection (b)(2)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b8bc255-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment among States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b8bc256-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult employment and training activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b8bc257-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for outlying areas","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b8bc258-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount made available under subsection (a)(1) for a fiscal year, the Secretary shall reserve not more than ¼ of 1 percent of such amount to provide assistance to the outlying areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8bc259-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved under clause (i), the Secretary shall provide assistance to the outlying areas for adult employment and training activities and statewide workforce investment activities in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/B"},"text":"section 3162(b)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b8bc25a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b8bc25b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After determining the amount to be reserved under subparagraph (A), the Secretary shall allot the remainder of the amount made available under subsection (a)(1) for that fiscal year to the States pursuant to clause (ii) for adult employment and training activities and statewide workforce investment activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8bc25c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to clauses (iii) and (iv), of the remainder—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b8bc25d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative number of unemployed individuals in areas of substantial unemployment in each State, compared to the total number of unemployed individuals in areas of substantial unemployment in all States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8bc25e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative excess number of unemployed individuals in each State, compared to the total excess number of unemployed individuals in all States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8bc25f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative number of disadvantaged adults in each State, compared to the total number of disadvantaged adults in all States, except as described in clause (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8bc260-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining an allotment under clause (ii)(III) for any State in which there is an area that was designated as a local area as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3122/c/1/C"},"text":"section 3122(c)(1)(C) of this title","children":[],"tail":", the allotment shall be based on the higher of—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id5b8be971-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of adults in families with an income below the low-income level in such area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8be972-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of disadvantaged adults in such area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8be973-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum and maximum percentages and minimum allotments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making allotments under this subparagraph, the Secretary shall ensure the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b8be974-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum percentage and allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subclause (IV), the Secretary shall ensure that no State shall receive an allotment for a fiscal year that is less than an amount based on 90 percent of the allotment percentage of the State for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8be975-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small State minimum allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subclauses (I), (III), and (IV), the Secretary shall ensure that no State shall receive an allotment under this subparagraph that is less than the total of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b8be976-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"10","children":[],"tail":" of 1 percent of $960,000,000 of the remainder described in clause (i) for the fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b8be977-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the remainder described in clause (i) for the fiscal year exceeds $960,000,000, ⅖ of 1 percent of the excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8be978-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subclause (I), the Secretary shall ensure that no State shall receive an allotment percentage for a fiscal year that is more than 130 percent of the allotment percentage of the State for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8be979-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any fiscal year in which the remainder described in clause (i) does not exceed $960,000,000, the minimum allotments under subclauses (I) and (II) shall be calculated by the methodology specified in section 132(b)(1)(B)(iv)(IV) of the Workforce Investment Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2862/b/1/B/iv/IV"},"text":"29 U.S.C. 2862(b)(1)(B)(iv)(IV)","children":[],"tail":"] (as in effect on the day before "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8be97a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of the formula specified in this subparagraph:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b8be97b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adult” means an individual who is not less than age 22 and not more than age 72.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8be97c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “allotment percentage”, used with respect to fiscal year 2015 or a subsequent fiscal year, means a percentage of the remainder described in clause (i) that is received through an allotment made under this subparagraph for the fiscal year. The term, used with respect to fiscal year 2014, means the percentage of the amount allotted to States under section 132(b)(1)(B) of the Workforce Investment Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2862/b/1/B"},"text":"29 U.S.C. 2862(b)(1)(B)","children":[],"tail":"] (as in effect on the day before "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":") that is received under such section by the State involved for fiscal year 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c108d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area of substantial unemployment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “area of substantial unemployment” means any area that is of sufficient size and scope to sustain a program of workforce investment activities carried out under this part and that has an average rate of unemployment of at least 6.5 percent for the most recent 12 months, as determined by the Secretary. For purposes of this subclause, determinations of areas of substantial unemployment shall be made once each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c108e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged adult","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subclause (V), the term “disadvantaged adult” means an adult who received an income, or is a member of a family that received a total family income, that, in relation to family size, does not exceed the higher of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b8c108f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/IV/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the poverty line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b8c1090-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/IV/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of the lower living standard income level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c1091-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged adult special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as appropriate and to the extent practicable, exclude college students and members of the Armed Forces from the determination of the number of disadvantaged adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c1092-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess number","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excess number” means, used with respect to the excess number of unemployed individuals within a State, the higher of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b8c1093-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/VI/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number that represents the number of unemployed individuals in excess of 4.5 percent of the civilian labor force in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b8c1094-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/VI/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number that represents the number of unemployed individuals in excess of 4.5 percent of the civilian labor force in areas of substantial unemployment in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c1095-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/1/B/v/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income level” means $7,000 with respect to income in 1969, and for any later year means that amount that bears the same relationship to $7,000 as the Consumer Price Index for that year bears to the Consumer Price Index for 1969, rounded to the nearest $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8c37a6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dislocated worker employment and training activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b8c37a7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation for outlying areas","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b8c37a8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount made available under subsection (a)(2)(A) for a fiscal year, the Secretary shall reserve not more than ¼ of 1 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/c"},"text":"section 3181(c) of this title","children":[],"tail":" for the fiscal year to provide assistance to the outlying areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8c37a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount reserved under clause (i), the Secretary shall provide assistance to the outlying areas for dislocated worker employment and training activities and statewide workforce investment activities in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/B"},"text":"section 3162(b)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b8c37aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b8c37ab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allot the amount referred to in subsection (a)(2)(B) for a fiscal year to the States pursuant to clause (ii) for dislocated worker employment and training activities and statewide workforce investment activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8c37ac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to clause (iii), of the amount—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b8c37ad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative number of unemployed individuals in each State, compared to the total number of unemployed individuals in all States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c37ae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative excess number of unemployed individuals in each State, compared to the total excess number of unemployed individuals in all States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c37af-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative number of individuals in each State who have been unemployed for 15 weeks or more, compared to the total number of individuals in all States who have been unemployed for 15 weeks or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8c37b0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum and maximum percentages and minimum allotments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making allotments under this subparagraph, for fiscal year 2016 and each subsequent fiscal year, the Secretary shall ensure the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b8c37b1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum percentage and allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that no State shall receive an allotment for a fiscal year that is less than an amount based on 90 percent of the allotment percentage of the State for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c37b2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subclause (I), the Secretary shall ensure that no State shall receive an allotment percentage for a fiscal year that is more than 130 percent of the allotment percentage of the State for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8c5ec3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of the formula specified in this subparagraph:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b8c5ec4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “allotment percentage”, used with respect to fiscal year 2015 or a subsequent fiscal year, means a percentage of the amount described in clause (i) that is received through an allotment made under this subparagraph for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b8c5ec5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/b/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excess number” means, used with respect to the excess number of unemployed individuals within a State, the number that represents the number of unemployed individuals in excess of 4.5 percent of the civilian labor force in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b8c5ec6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b8c5ec7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in accordance with this subsection, reallot to eligible States amounts that are made available to States from allotments made under this section or a corresponding provision of the Workforce Investment Act of 1998 for employment and training activities and statewide workforce investment activities (referred to individually in this subsection as a “State allotment”) and that are available for reallotment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8c5ec8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount available for reallotment for a program year for programs funded under subsection (b)(1)(B) (relating to adult employment and training) or for programs funded under subsection (b)(2)(B) (relating to dislocated worker employment and training) is equal to the amount by which the unobligated balance of the State allotments for adult employment and training activities or dislocated worker employment and training activities, respectively, at the end of the program year prior to the program year for which the determination under this paragraph is made, exceeds 20 percent of such allotments for the prior program year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8c5ec9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making reallotments to eligible States of amounts available pursuant to paragraph (2) for a program year, the Secretary shall allot to each eligible State an amount based on the relative amount of the State allotment under paragraph (1)(B) or (2)(B), respectively, of subsection (b) for the program year for which the determination is made, as compared to the total amount of the State allotments under paragraph (1)(B) or (2)(B), respectively, of subsection (b) for all eligible States for such program year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8c85da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, an eligible State means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b8c85db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to funds allotted through a State allotment for adult employment and training activities, a State that does not have an amount of such funds available for reallotment under paragraph (2) for the program year for which the determination under paragraph (2) is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b8c85dc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to funds allotted through a State allotment for dislocated worker employment and training activities, a State that does not have an amount of such funds available for reallotment under paragraph (2) for the program year for which the determination under paragraph (2) is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8c85dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3172/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall prescribe uniform procedures for the obligation of funds by local areas within the State in order to avoid the requirement that funds be made available for reallotment under this subsection. The Governor shall further prescribe equitable procedures for making funds available from the State and local areas in the event that a State is required to make funds available for reallotment under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b8c85de-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s132"},"text":"Pub. L. 113–128, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1511"},"text":"128 Stat. 1511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/18/s2/d"},"text":"Pub. L. 114–18, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-22"},"text":"May 22, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/213"},"text":"129 Stat. 213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b8c85df-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b8c85e0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b8c85e1-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Workforce Investment Act of 1998, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/936"},"text":"112 Stat. 936","children":[],"tail":", and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV"},"text":"Pub. L. 113–128, title V","children":[],"tail":", §§ 506, 511(a), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1703"},"text":"128 Stat. 1703","children":[],"tail":", 1705, effective "},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":". Pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3361/a"},"text":"section 3361(a) of this title","children":[],"tail":", references to a provision of the Workforce Investment Act of 1998 are deemed to refer to the corresponding provision of the Workforce Innovation and Opportunity Act, "},{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":". For complete classification of the Workforce Investment Act of 1998 to the Code, see Tables. For complete classification of the Workforce Innovation and Opportunity Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b8c85e2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1)(B)(iv)(I), (2)(B)(iii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/18"},"text":"Pub. L. 114–18","children":[],"tail":" inserted “less than” after “fiscal year that is”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b8cacf3-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b8cacf4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/18"},"text":"Pub. L. 114–18","children":[],"tail":" effective as if included in the Workforce Innovation and Opportunity Act ["},{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":"], see "},{"tag":"ref","attrib":{"href":"/us/pl/114/18/s2/f"},"text":"§ 2(f) of Pub. L. 114–18","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3112"},"text":"section 3112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b8cacf5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
