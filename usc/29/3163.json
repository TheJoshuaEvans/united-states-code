{"tag":"section","attrib":{"id":"id5b864468-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163"},"text":null,"children":[{"tag":"num","attrib":{"value":"3163"},"text":"§ 3163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Within State allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b864469-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations for statewide activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b86446a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall reserve not more than 15 percent of each of the amounts allotted to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/C"},"text":"section 3162(b)(1)(C) of this title","children":[],"tail":" and paragraphs (1)(B) and (2)(B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3172/b"},"text":"section 3172(b) of this title","children":[],"tail":" for a fiscal year for statewide workforce investment activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b86446b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Regardless of whether the reserved amounts were allotted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/C"},"text":"section 3162(b)(1)(C) of this title","children":[],"tail":", or under paragraph (1)(B) or (2)(B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3172/b"},"text":"section 3172(b) of this title","children":[],"tail":", the Governor may use the reserved amounts to carry out statewide activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3164/b"},"text":"section 3164(b) of this title","children":[],"tail":" or statewide employment and training activities, for adults or dislocated workers, under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3174/a"},"text":"section 3174(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b86446c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Within State allocations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b86446d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor, acting in accordance with the State plan, and after consulting with chief elected officials and local boards in the local areas, shall allocate the funds that are allotted to the State for youth activities and statewide workforce investment activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/C"},"text":"section 3162(b)(1)(C) of this title","children":[],"tail":" and are not reserved under subsection (a), in accordance with paragraph (2) or (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b86446e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b86446f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth activities","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b866b80-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In allocating the funds described in paragraph (1) to local areas, a State may allocate—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b866b81-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent of the funds on the basis described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/C/ii/I"},"text":"section 3162(b)(1)(C)(ii)(I) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b866b82-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent of the funds on the basis described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/C/ii/II"},"text":"section 3162(b)(1)(C)(ii)(II) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b866b83-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent of the funds on the basis described in clauses (ii)(III) and (iii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1/C"},"text":"section 3162(b)(1)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b866b84-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local area shall not receive an allocation percentage for a fiscal year that is less than 90 percent of the average allocation percentage of the local area for the 2 preceding fiscal years. Amounts necessary for increasing such allocations to local areas to comply with the preceding sentence shall be obtained by ratably reducing the allocations to be made to other local areas under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b866b85-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subparagraph, the term “allocation percentage”, used with respect to fiscal year 2015 or a subsequent fiscal year, means a percentage of the funds referred to in clause (i), received through an allocation made under this subparagraph, for the fiscal year. The term, used with respect to fiscal year 2013 or 2014, means a percentage of the funds referred to in section 128(b)(1) of the Workforce Investment Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2853/b/1"},"text":"29 U.S.C. 2853(b)(1)","children":[],"tail":"] (as in effect on the day before "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":"), received through an allocation made under paragraph (2) or (3) of section 128(b) of the Workforce Investment Act of 1998 (as so in effect), for the fiscal year 2013 or 2014, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b866b86-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b866b87-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" references in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b"},"text":"section 3162(b) of this title","children":[],"tail":" to a State shall be deemed to be references to a local area;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b866b88-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" references in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b"},"text":"section 3162(b) of this title","children":[],"tail":" to all States shall be deemed to be references to all local areas in the State involved; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b866b89-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as described in clause (i), references in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/1"},"text":"section 3162(b)(1) of this title","children":[],"tail":" to the term “excess number” shall be considered to be references to the term as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3162/b/2"},"text":"section 3162(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b866b8a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth discretionary allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In lieu of making the allocation described in paragraph (2), in allocating the funds described in paragraph (1) to local areas, a State may distribute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b86929b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a portion equal to not less than 70 percent of the funds in accordance with paragraph (2)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b86929c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the remaining portion of the funds on the basis of a formula that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b86929d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" incorporates additional factors (other than the factors described in paragraph (2)(A)) relating to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b86929e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excess youth poverty in urban, rural, and suburban local areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b86929f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excess unemployment above the State average in urban, rural, and suburban local areas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b8692a0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was developed by the State board and approved by the Secretary as part of the State plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8692a1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local administrative cost limit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b8692a2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount allocated to a local area under this subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3173/b"},"text":"section 3173(b) of this title","children":[],"tail":" for a fiscal year, not more than 10 percent of the amount may be used by the local board involved for the administrative costs of carrying out local workforce investment activities under this subpart or subpart 3."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b8692a3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available for administrative costs under subparagraph (A) may be used for the administrative costs of any of the local workforce investment activities described in this subpart or subpart 3, regardless of whether the funds were allocated under this subsection or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3173/b"},"text":"section 3173(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b8692a4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation among local areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b8692a5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor may, in accordance with this subsection and after consultation with the State board, reallocate to eligible local areas within the State amounts that are made available to local areas from allocations made under this section or a corresponding provision of the Workforce Investment Act of 1998 for youth workforce investment activities (referred to individually in this subsection as a “local allocation”) and that are available for reallocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8692a6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount available for reallocation for a program year is equal to the amount by which the unobligated balance of the local allocation, at the end of the program year prior to the program year for which the determination under this paragraph is made, exceeds 20 percent of such allocation for the prior program year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b86b9b7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making reallocations to eligible local areas of amounts available pursuant to paragraph (2) for a program year, the Governor shall allocate to each eligible local area within the State an amount based on the relative amount of the local allocation for the program year for which the determination is made, as compared to the total amount of the local allocations for all eligible local areas in the State for such program year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b86b9b8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3163/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, an eligible local area means a local area that does not have an amount available for reallocation under paragraph (2) for the program year for which the determination under paragraph (2) is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b86b9b9-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s128"},"text":"Pub. L. 113–128, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1502"},"text":"128 Stat. 1502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b86b9ba-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b86b9bb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b86b9bc-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Workforce Investment Act of 1998, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/936"},"text":"112 Stat. 936","children":[],"tail":", and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV"},"text":"Pub. L. 113–128, title V","children":[],"tail":", §§ 506, 511(a), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1703"},"text":"128 Stat. 1703","children":[],"tail":", 1705, effective "},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":". Pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3361/a"},"text":"section 3361(a) of this title","children":[],"tail":", references to a provision of the Workforce Investment Act of 1998 are deemed to refer to the corresponding provision of the Workforce Innovation and Opportunity Act, "},{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":". For complete classification of the Workforce Investment Act of 1998 to the Code, see Tables. For complete classification of the Workforce Innovation and Opportunity Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b86b9bd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b86b9be-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b86b9bf-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Workforce Response Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3515"},"text":"Pub. L. 116–136, div. A, title III, § 3515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/407"},"text":"134 Stat. 407","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dA/tIII/s3515"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 128(b)(4) of the Workforce Innovation [and] Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3163/b/4"},"text":"29 U.S.C. 3163(b)(4)","children":[],"tail":"), of the total amount allocated to a local area (including the total amount allotted to a single State local area) under subtitle B of title I of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151"},"text":"29 U.S.C. 3151","children":[],"tail":" et seq.) for program year 2019, not more than 20 percent of the total amount may be used for the administrative costs of carrying out local workforce investment activities under chapter 2 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3161"},"text":"29 U.S.C. 3161","children":[],"tail":" et seq.] or chapter 3 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3171"},"text":"29 U.S.C. 3171","children":[],"tail":" et seq.] of subtitle B of title I of such Act, if the portion of the total amount that exceeds 10 percent of the total amount is used to respond to a qualifying emergency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rapid Response Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statewide rapid response","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the funds reserved by a Governor for program year 2019 for statewide activities under section 128(a) of the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3163/a"},"text":"29 U.S.C. 3163(a)","children":[],"tail":") that remain unobligated, such funds may be used for statewide rapid response activities as described in section 134(a)(2)(A) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3174/a/2/A"},"text":"29 U.S.C. 3174(a)(2)(A)","children":[],"tail":") for responding to a qualifying emergency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local boards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the funds reserved by a Governor for program year 2019 under section 133(a)(2) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3173/a/2"},"text":"29 U.S.C. 3173(a)(2)","children":[],"tail":") that remain unobligated, such funds may be released within 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":"] to the local boards most impacted by the coronavirus at the determination of the Governor for rapid response activities related to responding to a qualifying emergency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, the terms in this section have the meanings given the terms in section 3 of the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"29 U.S.C. 3102","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “qualifying emergency” and “coronavirus” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3515"},"text":"section 3515 of Pub. L. 116–136","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s3502"},"text":"section 3502 of Pub. L. 116–136","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
