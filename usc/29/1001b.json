{"tag":"section","attrib":{"id":"id5aafba7d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001b"},"text":"§ 1001b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aafba7e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aafba7f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" single-employer defined benefit pension plans have a substantial impact on interstate commerce and are affected with a national interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba80-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued well-being and retirement income security of millions of workers, retirees, and their dependents are directly affected by such plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba81-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existence of a sound termination insurance system is fundamental to the retirement income security of participants and beneficiaries of such plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba82-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current termination insurance system in some instances encourages employers to terminate pension plans, evade their obligations to pay benefits, and shift unfunded pension liabilities onto the termination insurance system and the other premium-payers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aafba83-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress further finds that modification of the current termination insurance system and an increase in the insurance premium for single-employer defined benefit pension plans—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aafba84-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is desirable to increase the likelihood that full benefits will be paid to participants and beneficiaries of such plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba85-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is desirable to provide for the transfer of liabilities to the termination insurance system only in cases of severe hardship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba86-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to maintain the premium costs of such system at a reasonable level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba87-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to finance properly current funding deficiencies and future obligations of the single-employer pension plan termination insurance system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aafba88-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is hereby declared to be the policy of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aafba89-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster and facilitate interstate commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba8a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the maintenance and growth of single-employer defined benefit pension plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba8b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the likelihood that participants and beneficiaries under single-employer defined benefit pension plans will receive their full benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba8c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the transfer of unfunded pension liabilities onto the single-employer pension plan termination insurance system only in cases of severe hardship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba8d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain the premium costs of such system at a reasonable level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba8e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure the prudent financing of current funding deficiencies and future obligations of the single-employer pension plan termination insurance system by increasing termination insurance premiums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aafba8f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXI/s11002"},"text":"Pub. L. 99–272, title XI, § 11002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/237"},"text":"100 Stat. 237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aafba90-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aafba91-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5aafba92-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c), is title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/237"},"text":"100 Stat. 237","children":[],"tail":", known as the Single-Employer Pension Plan Amendments Act of 1986. For complete classification of this Act to the Code, see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5aafba93-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Single-Employer Pension Plan Amendments Act of 1986, and not as part of the Employee Retirement Income Security Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5aafba94-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5aafba95-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/s11019"},"text":"section 11019 of Pub. L. 99–272","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341"},"text":"section 1341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
