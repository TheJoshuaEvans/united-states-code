er "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003"},"text":"section 1003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b222bcd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to group health plans for plan years beginning after ","children":[{"tag":"date","attrib":{"date":"1997-06-30"},"text":"June 30, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/s101/g"},"text":"section 101(g) of Pub. L. 104–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
