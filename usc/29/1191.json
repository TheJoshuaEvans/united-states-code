{"tag":"section","attrib":{"id":"id5b222bb5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191"},"text":null,"children":[{"tag":"num","attrib":{"value":"1191"},"text":"§ 1191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption; State flexibility; construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b222bb6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued applicability of State law with respect to health insurance issuers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222bb7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2) and except as provided in subsection (b), this part shall not be construed to supersede any provision of State law which establishes, implements, or continues in effect any standard or requirement solely relating to health insurance issuers in connection with group health insurance coverage except to the extent that such standard or requirement prevents the application of a requirement of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bb8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued preemption with respect to group health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to affect or modify the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1144"},"text":"section 1144 of this title","children":[],"tail":" with respect to group health plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bb9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules in case of portability requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222bba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the provisions of this part relating to health insurance coverage offered by a health insurance issuer supersede any provision of State law which establishes, implements, or continues in effect a standard or requirement applicable to imposition of a preexisting condition exclusion specifically governed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of this title","children":[],"tail":" which differs from the standards or requirements specified in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bbb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Only in relation to health insurance coverage offered by a health insurance issuer, the provisions of this part do not supersede any provision of State law to the extent that such provision—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222bbc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the reference to “6-month period” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181/a/1"},"text":"section 1181(a)(1) of this title","children":[],"tail":" a reference to any shorter period of time;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bbd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the reference to “12 months” and “18 months” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181/a/2"},"text":"section 1181(a)(2) of this title","children":[],"tail":" a reference to any shorter period of time;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bbe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the references to “63 days” in sections 1181(c)(2)(A) and (d)(4)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002138"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002138"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181/d/4"},"text":"Section 1181(d)(4) of this title","children":[],"tail":" does not contain subpars."}],"tail":" of this title a reference to any greater number of days;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bbf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for the reference to “30-day period” in sections 1181(b)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002139"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002139"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181/b/2"},"text":"Section 1181(b)(2) of this title","children":[],"tail":" does not refer to a 30-day period."}],"tail":" and (d)(1) of this title a reference to any greater period;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bc0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits the imposition of any preexisting condition exclusion in cases not described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181/d"},"text":"section 1181(d) of this title","children":[],"tail":" or expands the exceptions described in such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bc1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires special enrollment periods in addition to those required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181/f"},"text":"section 1181(f) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bc2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduces the maximum period permitted in an affiliation period under section 1181(g)(1)(B) ","children":[{"tag":"ref","attrib":{"idref":"fn002140"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002140"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “1181(g)(1)(C)”."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bc3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1185"},"text":"section 1185 of this title","children":[],"tail":", nothing in this part shall be construed as requiring a group health plan or health insurance coverage to provide specific benefits under the terms of such plan or coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bc4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222bc5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State law” includes all laws, decisions, rules, regulations, or other State action having the effect of law, of any State. A law of the United States applicable only to the District of Columbia shall be treated as a State law rather than a law of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bc6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes a State, the Northern Mariana Islands, any political subdivisions of a State or such Islands, or any agency or instrumentality of either.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b222bc7-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s731"},"text":"Pub. L. 93–406, title I, § 731","children":[],"tail":", formerly § 704, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s101/a"},"text":"Pub. L. 104–191, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1946"},"text":"110 Stat. 1946","children":[],"tail":"; renumbered § 731 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s603/a/3"},"text":"Pub. L. 104–204, title VI, § 603(a)(3)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2935"},"text":"110 Stat. 2935","children":[],"tail":", 2937.)"}],"tail":"\n"},{"tag":"notes","attri