{"tag":"section","attrib":{"id":"id5add0c6d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1058"},"text":null,"children":[{"tag":"num","attrib":{"value":"1058"},"text":"§ 1058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mergers and consolidations of plans or transfers of plan assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A pension plan may not merge or consolidate with, or transfer its assets or liabilities to, any other plan after ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"September 2, 1974","children":[],"tail":", unless each participant in the plan would (if the plan then terminated) receive a benefit immediately after the merger, consolidation, or transfer which is equal to or greater than the benefit he would have been entitled to receive immediately before the merger, consolidation, or transfer (if the plan had then terminated). The preceding sentence shall not apply to any transaction to the extent that participants either before or after the transaction are covered under a multiemployer plan to which subchapter III of this chapter applies."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5add0c6e-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s208"},"text":"Pub. L. 93–406, title I, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/865"},"text":"88 Stat. 865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIV/s402/b/1"},"text":"Pub. L. 96–364, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1299"},"text":"94 Stat. 1299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5add0c6f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5add0c70-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5add0c71-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" substituted provisions respecting applicability of preceding sentence to transactions under a covered multiemployer plan to which subchapter III applies, for provisions relating to applicability of paragraph to a multiemployer plan only to extent determined by Corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5add0c72-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5add0c73-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
