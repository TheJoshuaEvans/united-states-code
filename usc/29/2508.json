{"tag":"section","attrib":{"id":"id5b628f9b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2508"},"text":null,"children":[{"tag":"num","attrib":{"value":"2508"},"text":"§ 2508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b628f9c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2508/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “community-based organization” means a community-based organization as defined in section 4(5) of the Job Training Partnership Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501/5"},"text":"29 U.S.C. 1501(5)","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002193"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002193"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" that has demonstrated experience administering programs that train women for apprenticeable occupations or other nontraditional occupations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f9d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2508/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nontraditional occupation” means jobs in which women make up 25 percent or less of the total number of workers in that occupation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f9e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2508/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b628f9f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/530/s9"},"text":"Pub. L. 102–530, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3468"},"text":"106 Stat. 3468","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b628fa0-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b628fa1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b628fa2-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4(5) of the Job Training Partnership Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501/5"},"text":"29 U.S.C. 1501(5)","children":[],"tail":"), referred to in par. (1), was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1503/5"},"text":"section 1503(5) of this title","children":[],"tail":" and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tI/s199/b/2"},"text":"Pub. L. 105–220, title I, § 199(b)(2)","children":[],"tail":", (c)(2)(B), "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1059"},"text":"112 Stat. 1059","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2000-07-01"},"text":"July 1, 2000","children":[],"tail":". Pursuant to former "},{