{"tag":"section","attrib":{"id":"id5b222c31-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1191c"},"text":"§ 1191c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, consistent with section 104 of the Health Care Portability and Accountability Act of 1996, may promulgate such regulations as may be necessary or appropriate to carry out the provisions of this part. The Secretary may promulgate any interim final rules as the Secretary determines are appropriate to carry out this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b222c32-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s734"},"text":"Pub. L. 93–406, title I, § 734","children":[],"tail":", formerly § 707, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s101/a"},"text":"Pub. L. 104–191, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1951"},"text":"110 Stat. 1951","children":[],"tail":"; renumbered § 734, "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s603/a/3"},"text":"Pub. L. 104–204, title VI, § 603(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2935"},"text":"110 Stat. 2935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b222c33-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b222c34-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"child