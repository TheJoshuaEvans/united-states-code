{"tag":"section","attrib":{"id":"id5b48517f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1398"},"text":null,"children":[{"tag":"num","attrib":{"value":"1398"},"text":"§ 1398.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal not to occur because of change in business form or suspension of contributions during labor dispute","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this part, an employer shall not be considered to have withdrawn from a plan solely because—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b485180-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1398/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an employer ceases to exist by reason of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b485181-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1398/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change in corporate structure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1369/b"},"text":"section 1369(b) of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b485182-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1398/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change to an unincorporated form of business enterprise,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if the change causes no interruption in employer contributions or obligations to contribute under the plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b485183-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1398/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer suspends contributions under the plan during a labor dispute involving its employees.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this part, a successor or parent corporation or other entity resulting from any such change shall be considered the original employer.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b485184-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4218"},"text":"Pub. L. 93–406, title IV, § 4218","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1236"},"text":"94 Stat. 1236","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/tXVIII/s1879/u/4"},"text":"Pub. L. 99–514, title XVIII, § 1879(u)(4)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7862/b/1/C"},"text":"Pub. L. 101–239, title VII, § 7862(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2432"},"text":"103 Stat. 2432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7893/f"},"text":"Pub. L. 101–239, title VII, § 7893(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2447"},"text":"103 Stat. 2447","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b485185-3