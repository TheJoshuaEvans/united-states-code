{"tag":"section","attrib":{"id":"id5b6771bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618"},"text":null,"children":[{"tag":"num","attrib":{"value":"2618"},"text":"§ 2618.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules concerning employees of local educational agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b6771bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6771be-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, the rights (including the rights under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2614"},"text":"section 2614 of this title","children":[],"tail":", which shall extend throughout the period of leave of any employee under this section), remedies, and procedures under this subchapter shall apply to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771bf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any “local educational agency” (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":") and an eligible employee of the agency; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771c0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any private elementary or secondary school and an eligible employee of the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the application described in paragraph (1):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible employee” means an eligible employee of an agency or school described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employer” means an agency or school described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b6771c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave does not violate certain other Federal laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency and a private elementary or secondary school shall not be in violation of the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.), "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of this title","children":[],"tail":", or title VI of the Civil Rights Act of 1964 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.), solely as a result of an eligible employee of such agency or school exercising the rights of such employee under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b6771c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermittent leave or leave on reduced schedule for instructional employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6771c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), in any case in which an eligible employee employed principally in an instructional capacity by any such educational agency or school requests leave under subparagraph (C) or (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1"},"text":"section 2612(a)(1) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/3"},"text":"section 2612(a)(3) of this title","children":[],"tail":" that is foreseeable based on planned medical treatment and the employee would be on leave for greater than 20 percent of the total number of working days in the period during which the leave would extend, the agency or school may require that such employee elect either—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take leave for periods of a particular duration, not to exceed the duration of the planned medical treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to transfer temporarily to an available alternative position offered by the employer for which the employee is qualified, and that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b6771c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has equivalent pay and benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b6771ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" better accommodates recurring periods of leave than the regular employment position of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The elections described in subparagraphs (A) and (B) of paragraph (1) shall apply only with respect to an eligible employee who complies with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/e/2"},"text":"section 2612(e)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b6771cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules applicable to periods near conclusion of academic term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following rules shall apply with respect to periods of leave near the conclusion of an academic term in the case of any eligible employee employed principally in an instructional capacity by any such educational agency or school:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6771cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave more than 5 weeks prior to end of term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the eligible employee begins leave under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":" more than 5 weeks prior to the end of the academic term, the agency or school may require the employee to continue taking leave until the end of such term, if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leave is of at least 3 weeks duration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return to employment would occur during the 3-week period before the end of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave less than 5 weeks prior to end of term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the eligible employee begins leave under subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1"},"text":"section 2612(a)(1) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/3"},"text":"section 2612(a)(3) of this title","children":[],"tail":" during the period that commences 5 weeks prior to the end of the academic term, the agency or school may require the employee to continue taking leave until the end of such term, if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6771d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leave is of greater than 2 weeks duration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6771d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return to employment would occur during the 2-week period before the end of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6771d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave less than 3 weeks prior to end of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the eligible employee begins leave under subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1"},"text":"section 2612(a)(1) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/3"},"text":"section 2612(a)(3) of this title","children":[],"tail":" during the period that commences 3 weeks prior to the end of the academic term and the duration of the leave is greater than 5 working days, the agency or school may require the employee to continue to take leave until the end of such term."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b6771d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration to equivalent employment position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determinations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2614/a/1/B"},"text":"section 2614(a)(1)(B) of this title","children":[],"tail":" (relating to the restoration of an eligible employee to an equivalent position), in the case of a local educational agency or a private elementary or secondary school, such determination shall be made on the basis of established school board policies and practices, private school policies and practices, and collective bargaining agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b6771d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2618/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of amount of liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a local educational agency or a private elementary or secondary school that has violated this subchapter proves to the satisfaction of the court that the agency, school, or department had reasonable grounds for believing that the underlying act or omission was not a violation of this subchapter, such court may, in the discretion of the court, reduce the amount of the liability provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2617/a/1/A"},"text":"section 2617(a)(1)(A) of this title","children":[],"tail":" to the amount and interest determined under clauses (i) and (ii), respectively, of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b6771d6-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tI/s108"},"text":"Pub. L. 103–3, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/17"},"text":"107 Stat. 17","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s394/e"},"text":"Pub. L. 103–382, title III, § 394(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4027"},"text":"108 Stat. 4027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/v"},"text":"Pub. L. 107–110, title X, § 1076(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2093"},"text":"115 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s585/a/3/H"},"text":"Pub. L. 110–181, div. A, title V, § 585(a)(3)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/131"},"text":"122 Stat. 131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/hh"},"text":"Pub. L. 114–95, title IX, § 9215(hh)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2175"},"text":"129 Stat. 2175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b6771d7-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b6771d8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b6771d9-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (b), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230