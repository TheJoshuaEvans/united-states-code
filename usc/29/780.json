{"tag":"section","attrib":{"id":"id5a8e5027-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780"},"text":null,"children":[{"tag":"num","attrib":{"value":"780"},"text":"§ 780.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National Council on Disability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a8e5028-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a8e5029-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a8e502a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is established within the Federal Government a National Council on Disability (referred to in this subchapter as the “National Council”), which, subject to subparagraph (B), shall be composed of 9 members, of which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a8e502b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 shall be appointed by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a8e502c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Majority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a8e502d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Minority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a8e502e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Speaker of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a8e502f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Minority Leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a8e5030-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Council shall transition from 15 members (as of ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":") to 9 members as follows:"}],"tail":null},{"tag":"clause","attrib":{"id":"id5a8e5031-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On the first 4 expirations of National Council terms (after that date), replacement members shall be appointed to the National Council in the following order and manner:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5a8e5032-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Majority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a8e5033-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a8e5034-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Speaker of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a8e5035-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the Minority Leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a8e5036-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the next 6 expirations of National Council terms (after the 4 expirations described in clause (i) occur), no replacement members shall be appointed to the National Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a8e5037-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any vacancy on the National Council that occurs after the transition described in subparagraph (B), the vacancy shall be filled in the same manner as the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a8e5038-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The members of the National Council shall be individuals with disabilities, parents or guardians of individuals with disabilities, national leaders on disability policy, or other individuals who have substantial knowledge or experience relating to disability policy or issues that affect individuals with disabilities. The members of the National Council shall be appointed so as to be representative of individuals with disabilities, national organizations concerned with individuals with disabilities, providers and administrators of services to individuals with disabilities, individuals engaged in conducting medical or scientific research relating to individuals with disabilities, business concerns, and labor organizations. A majority of the members of the National Council shall be individuals with disabilities. The members of the National Council shall be broadly representative of minority and other individuals and groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a8e5039-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purpose of the National Council is to promote policies, programs, practices, and procedures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a8e503a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guarantee equal opportunity for all individuals with disabilities, regardless of the nature or severity of the disability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a8e503b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" empower individuals with disabilities to achieve economic self-sufficiency, independent living, and inclusion and integration into all aspects of society.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a8e503c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a8e503d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the National Council shall serve for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a8e503e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a8e503f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No member of the National Council may serve more than two consecutive full terms beginning on the date of commencement of the first full term on the Council. Members may serve after the expiration of their terms until their successors have taken office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a8e5040-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this paragraph, the term “full term” means a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a8e5041-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member appointed to fill a vacancy occurring before the expiration of the term for which such member’s predecessor was appointed shall be appointed only for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a8e5042-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson; meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate the Chairperson from among the members appointed to the National Council. The National Council shall meet at the call of the Chairperson, but not less often than four times each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a8e5043-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s780/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum; vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Five members of the National Council shall constitute a quorum and any vacancy in the National Council shall not affect its power to function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a8e5044-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s400"},"text":"Pub. L. 93–112, title IV, § 400","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s407"},"text":"Pub. L. 105–220, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1198"},"text":"112 Stat. 1198","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/q"},"text":"Pub. L. 112–166, § 2(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1288"},"text":"126 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s451"},"text":"Pub. L. 113–128, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1674"},"text":"128 Stat. 1674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/18/s3/a"},"text":"Pub. L. 114–18, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-22"},"text":"May 22, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/214"},"text":"129 Stat. 214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a8e5045-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a8e5046-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a8e5047-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 780, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s400"},"text":"Pub. L. 93–112, title IV, § 400","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s117"},"text":"Pub. L. 95–602, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2977"},"text":"92 Stat. 2977","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/221/tI/s141/a"},"text":"Pub. L. 98–221, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/26"},"text":"98 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tI/s103/d/2/C"},"text":"Pub. L. 99–506, title I, § 103(d)(2)(C)","children":[],"tail":", title V, § 501, title X, § 1001(e), "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1810"},"text":"100 Stat. 1810","children":[],"tail":", 1828, 1843; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s205/b"},"text":"Pub. L. 100–630, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3310"},"text":"102 Stat. 3310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s102/p/26"},"text":"Pub. L. 102–569, title I, § 102(p)(26)","children":[],"tail":", title IV, § 401, "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4360"},"text":"106 Stat. 4360","children":[],"tail":", 4421, related to establishment of the National Council on Disability, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 780, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s400"},"text":"Pub. L. 93–112, title IV, § 400","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/385"},"text":"87 Stat. 385","children":[],"tail":", related to general administrative powers of Secretary under this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/s117"},"text":"Pub. L. 95–602, § 117","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a8e5048-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/18"},"text":"Pub. L. 114–18","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b)(1) Each member of the National Council shall serve for a term of 3 years.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2)(A) No member of the National Council may serve more than two consecutive full terms beginning on the date of commencement of the first full term on the Council. Members may serve after the expiration of their terms until their successors have taken office.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) As used in this paragraph, the term ‘full term’ means a term of 3 years.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Any member appointed to fill a vacancy occurring before the expiration of the term for which such member’s predecessor was appointed shall be appointed only for the remainder of such term.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s451/1/B"},"text":"Pub. L. 113–128, § 451(1)(B)","children":[],"tail":", added subpars. (A) to (C) and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1)(A) There is established within the Federal Government a National Council on Disability (hereinafter in this subchapter referred to as the ‘National Council’), which shall be composed of fifteen members appointed by the President.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) The President shall select members of the National Council after soliciting recommendations from representatives of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) organizations representing a broad range of individuals with disabilities; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) organizations interested in individuals with disabilities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former subpar. (C) redesignated (D).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s451/1/C"},"text":"Pub. L. 113–128, § 451(1)(C)","children":[],"tail":", inserted “national leaders on disability policy,” after “guardians of individuals with disabilities,” and substituted “policy or issues that affect individuals with disabilities” for “policy or programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s451/1/A"},"text":"Pub. L. 113–128, § 451(1)(A)","children":[],"tail":", redesignated subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s451/2"},"text":"Pub. L. 113–128, § 451(2)","children":[],"tail":", which directed substitution of a period for “ ‘, except’ and all that follows”, was executed by substituting a period for “, except that the terms of service of the members initially appointed after "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"November 6, 1978","children":[],"tail":", shall be (as specified by the President) for such fewer number of years as will provide for the expiration of terms on a staggered basis.” in par. (1), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s451/3"},"text":"Pub. L. 113–128, § 451(3)","children":[],"tail":", substituted “Five” for “Eight”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" struck out “, by and with the advice and consent of the Senate” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a8e5049-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a8e504a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/18/s3/b"},"text":"Pub. L. 114–18, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-22"},"text":"May 22, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/214"},"text":"129 Stat. 214","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/18/s3/b"},"text":"“The amendment made by this section [amending this section] shall take effect as if enacted 1 day after the date of enactment of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"29 U.S.C. 3101","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a8e504b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
