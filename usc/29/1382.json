{"tag":"section","attrib":{"id":"id5b43961e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1382"},"text":null,"children":[{"tag":"num","attrib":{"value":"1382"},"text":"§ 1382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination and collection of liability; notification of employer","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When an employer withdraws from a multiemployer plan, the plan sponsor, in accordance with this part, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b43961f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1382/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the amount of the employer’s withdrawal liability,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b439620-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1382/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the employer of the amount of the withdrawal liability, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b439621-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1382/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect the amount of the withdrawal liability from the employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b439622-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4202"},"text":"Pub. L. 93–406, title IV, § 4202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1218"},"text":"94 Stat. 1218","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
