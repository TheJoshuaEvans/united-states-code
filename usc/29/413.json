{"tag":"section","attrib":{"id":"id5a46e602-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s413"},"text":null,"children":[{"tag":"num","attrib":{"value":"413"},"text":"§ 413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of existing rights of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this subchapter shall limit the rights and remedies of any member of a labor organization under any State or Federal law or before any court or other tribunal, or under the constitution and bylaws of any labor organization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a46e603-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/257/tI/s103"},"text":"Pub. L. 86–257, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/523"},"text":"73 Stat. 523","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
