{"tag":"section","attrib":{"id":"id5a9ca80d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h"},"text":null,"children":[{"tag":"num","attrib":{"value":"795h"},"text":"§ 795h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a9ca80e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9ca80f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall allot the sums appropriated for each fiscal year to carry out this subchapter among the States on the basis of relative population of each State, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9ca810-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no State shall receive less than $250,000, or ⅓ of 1 percent of the sums appropriated for the fiscal year for which the allotment is made, whichever amount is greater; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9ca811-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the sums appropriated to carry out this subchapter for the fiscal year exceed by $1,000,000 or more the sums appropriated to carry out part B of this subchapter (as in effect on ","children":[{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":") in fiscal year 1992, no State shall receive less than $300,000, or ⅓ of 1 percent of the sums appropriated for the fiscal year for which the allotment is made, whichever amount is greater."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9ca812-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain territories","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a9ca813-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this subsection, Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands shall not be considered to be States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a9ca814-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each jurisdiction described in subparagraph (A) shall be allotted not less than ⅛ of 1 percent of the amounts appropriated for the fiscal year for which the allotment is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9ca815-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Commissioner determines that any amount of an allotment to a State under subsection (a) for any fiscal year will not be expended by such State for carrying out the provisions of this subchapter, the Commissioner shall make such amount available for carrying out the provisions of this subchapter to 1 or more of the States that the Commissioner determines will be able to use additional amounts during such year for carrying out such provisions. Any amount made available to a State for any fiscal year pursuant to the preceding sentence shall, for the purposes of this section, be regarded as an increase in the allotment of the State (as determined under the preceding provisions of this section) for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9ca816-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives an allotment under this subchapter shall not use more than 2.5 percent of such allotment to pay for administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9ca817-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services for youth with the most significant disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives an allotment under this subchapter shall reserve and expend half of such allotment for the provision of supported employment services, including extended services, to youth with the most significant disabilities in order to assist those youth in achieving an employment outcome in supported employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a9ca818-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s603"},"text":"Pub. L. 93–112, title VI, § 603","children":[],"tail":", formerly § 622, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s409"},"text":"Pub. L. 105–220, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1214"},"text":"112 Stat. 1214","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/b/13"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(b)(13)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–414; renumbered § 603 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s461/3"},"text":"Pub. L. 113–128, title IV, § 461(3)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1679"},"text":"128 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a9ca819-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a9ca81a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a9ca81b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part B of this subchapter (as in effect on ","children":[{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":"), referred to in subsec. (a)(1)(B), consisted of sections 795g to 795i and related to projects with industry and business opportunities for individuals with handicaps."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a9ca81c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s795k"},"text":"section 795k of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 795h, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s622"},"text":"Pub. L. 93–112, title VI, § 622","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tII/s201"},"text":"Pub. L. 95–602, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2994"},"text":"92 Stat. 2994","children":[],"tail":", and amended, which related to business opportunities for individuals with disabilities and promulgation of regulations, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/93/112/s641"},"text":"section 641 of Pub. L. 93–112","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVI/s612/a/2"},"text":"Pub. L. 102–569, title VI, § 612(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4438"},"text":"106 Stat. 4438","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s795r"},"text":"section 795r of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a9ca81d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/5/A/i/I"},"text":"Pub. L. 113–128, § 461(5)(A)(i)(I)","children":[],"tail":", substituted “subchapter” for “part” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/5/A/i/II"},"text":"Pub. L. 113–128, § 461(5)(A)(i)(II)","children":[],"tail":", inserted “amount” after “whichever”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/5/A/i/III"},"text":"Pub. L. 113–128, § 461(5)(A)(i)(III)","children":[],"tail":", substituted “subchapter for the fiscal year” for “part for the fiscal year” and “part B of this subchapter (as in effect on "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":") in fiscal year 1992” for “this part in fiscal year 1992” and inserted “amount” after “whichever”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/5/A/ii"},"text":"Pub. L. 113–128, § 461(5)(A)(ii)","children":[],"tail":", substituted “⅛ of 1 percent” for “one-eighth of one percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/5/B"},"text":"Pub. L. 113–128, § 461(5)(B)","children":[],"tail":", inserted “under subsection (a)” after “allotment to a State”, substituted “subchapter” for “part” in two places, and substituted “1 or more” for “one or more”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/5/C"},"text":"Pub. L. 113–128, § 461(5)(C)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" made technical amendment in original to section designation and catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
