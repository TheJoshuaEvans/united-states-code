{"tag":"section","attrib":{"id":"id5a636f29-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a"},"text":null,"children":[{"tag":"num","attrib":{"value":"671a"},"text":"§ 671a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workers’ family protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a636f2a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Workers’ Family Protection Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f2b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a636f2c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636f2d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazardous chemicals and substances that can threaten the health and safety of workers are being transported out of industries on workers’ clothing and persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f2e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" these chemicals and substances have the potential to pose an additional threat to the health and welfare of workers and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f2f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional information is needed concerning issues related to employee transported contaminant releases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f30-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional regulations may be needed to prevent future releases of this type.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636f31-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636f32-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase understanding and awareness concerning the extent and possible health impacts of the problems and incidents described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f33-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent or mitigate future incidents of home contamination that could adversely affect the health and safety of workers and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f34-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarify regulatory authority for preventing and responding to such incidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f35-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist workers in redressing and responding to such incidents when they occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f36-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of employee transported contaminant releases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a636f37-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636f38-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-26"},"text":"October 26, 1992","children":[],"tail":", the Director of the National Institute for Occupational Safety and Health (hereafter in this section referred to as the “Director”), in cooperation with the Secretary of Labor, the Administrator of the Environmental Protection Agency, the Administrator of the Agency for Toxic Substances and Disease Registry, and the heads of other Federal Government agencies as determined to be appropriate by the Director, shall conduct a study to evaluate the potential for, the prevalence of, and the issues related to the contamination of workers’ homes with hazardous chemicals and substances, including infectious agents, transported from the workplaces of such workers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f39-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be evaluated","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study and evaluation under subparagraph (A), the Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a636f3a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a review of past incidents of home contamination through the utilization of literature and of records concerning past investigations and enforcement actions undertaken by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5a636f3b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute for Occupational Safety and Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a636f3c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor to enforce the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a636f3d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States to enforce occupational safety and health standards in accordance with section 18 of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s667"},"text":"29 U.S.C. 667","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a636f3e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other government agencies (including the Department of Energy and the Environmental Protection Agency), as the Director may determine to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f3f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate current statutory, regulatory, and voluntary industrial hygiene or other measures used by small, medium and large employers to prevent or remediate home contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f40-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" compile a summary of the existing research and case histories conducted on incidents of employee transported contaminant releases, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5a636f41-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of workplace housekeeping practices and personal protective equipment in preventing such incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a636f42-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health effects, if any, of the resulting exposure on workers and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a636f43-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of normal house cleaning and laundry procedures for removing hazardous materials and agents from workers’ homes and personal clothing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a636f44-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indoor air quality, as the research concerning such pertains to the fate of chemicals transported from a workplace into the home environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5a636f45-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for differentiating exposure health effects and relative risks associated with specific agents from other sources of exposure inside and outside the home;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f46-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the role of Federal and State agencies in responding to incidents of home contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f47-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Task Force established under paragraph (2) and to the appropriate committees of Congress, a report concerning the results of the matters studied or evaluated under clauses (i) through (iv); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f48-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study home contamination incidents and issues and worker and family protection policies and practices related to the special circumstances of firefighters and prepare and submit to the appropriate committees of Congress a report concerning the findings with respect to such study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636f49-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of investigative strategy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636f4a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Force","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-26"},"text":"October 26, 1992","children":[],"tail":", the Director shall establish a working group, to be known as the “Workers’ Family Protection Task Force”. The Task Force shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id5a636f4b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be composed of not more than 15 individuals to be appointed by the Director from among individuals who are representative of workers, industry, scientists, industrial hygienists, the National Research Council, and government agencies, except that not more than one such individual shall be from each appropriate government agency and the number of individuals appointed to represent industry and workers shall be equal in number;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f4c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the report submitted under paragraph (1)(B)(v);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f4d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine, with respect to such report, the additional data needs, if any, and the need for additional evaluation of the scientific issues related to and the feasibility of developing such additional data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f4e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if additional data are determined by the Task Force to be needed, develop a recommended investigative strategy for use in obtaining such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f4f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigative strategy","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a636f50-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The investigative strategy developed under subparagraph (A)(iv) shall identify data gaps that can and cannot be filled, assumptions and uncertainties associated with various components of such strategy, a timetable for the implementation of such strategy, and methodologies used to gather any required data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f51-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall publish the proposed investigative strategy under subparagraph (A)(iv) for public comment and utilize other methods, including technical conferences or seminars, for the purpose of obtaining comments concerning the proposed strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a636f52-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the peer review and public comment is conducted under clause (ii), the Director, in consultation with the heads of other government agencies, shall propose a final strategy for investigating issues related to home contamination that shall be implemented by the National Institute for Occupational Safety and Health and other Federal agencies for the period of time necessary to enable such agencies to obtain the information identified under subparagraph (A)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f53-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as precluding any government agency from investigating issues related to home contamination using existing procedures until such time as a final strategy is developed or from taking actions in addition to those proposed in the strategy after its completion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636f54-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of investigative strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the investigative strategy under subparagraph (B)(iii), each Federal agency or department shall fulfill the role assigned to it by the strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f55-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a636f56-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"1992-10-26"},"text":"October 26, 1992","children":[],"tail":", and periodically thereafter, the Secretary of Labor, based on the information developed under subsection (c) and on other information available to the Secretary, shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636f57-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine if additional education about, emphasis on, or enforcement of existing regulations or standards is needed and will be sufficient, or if additional regulations or standards are needed with regard to employee transported releases of hazardous materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f58-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the appropriate committees of Congress a report concerning the result of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636f59-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional regulations or standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of Labor determines that additional regulations or standards are needed under paragraph (1), the Secretary shall promulgate, pursuant to the Secretary’s authority under the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.), such regulations or standards as determined to be appropriate not later than 3 years after such determination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f5a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s671a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated from sums otherwise authorized to be appropriated, for each fiscal year such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a636f5b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/522/tII/s209"},"text":"Pub. L. 102–522, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-26"},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3420"},"text":"106 Stat. 3420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a636f5c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a636f5d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a636f5e-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsecs. (c)(1)(B)(i)(II) and (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a636f5f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fire Administration Authorization Act of 1992, and not as part of the Occupational Safety and Health Act of 1970 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
