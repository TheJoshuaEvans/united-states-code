{"tag":"section","attrib":{"id":"id5a230b03-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s178"},"text":null,"children":[{"tag":"num","attrib":{"value":"178"},"text":"§ 178.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions during national emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a230b04-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s178/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition to district court by Attorney General on direction of President","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receiving a report from a board of inquiry the President may direct the Attorney General to petition any district court of the United States having jurisdiction of the parties to enjoin such strike or lock-out or the continuing thereof, and if the court finds that such threatened or actual strike or lock-out—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a230b05-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s178/a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects an entire industry or a substantial part thereof engaged in trade, commerce, transportation, transmission, or communication among the several States or with foreign nations, or engaged in the production of goods for commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a230b06-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s178/a/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if permitted to occur or to continue, will imperil the national health or safety, it shall have jurisdiction to enjoin any such strike or lockout, or the continuing thereof, and to make such other orders as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a230b07-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s178/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of chapter 6","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case, the provisions of chapter 6 of this title shall not be applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a230b08-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s178/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order or orders of the court shall be subject to review by the appropriate United States court of appeals and by the Supreme Court upon writ of certiorari or certification as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a230b09-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-23/ch120"},"text":"June 23, 1947, ch. 120","children":[],"tail":", title II, § 208, "},{"tag":"ref","attrib":{"href":"/us/stat/61/155"},"text":"61 Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s32/a"},"text":"June 25, 1948, ch. 646, § 32(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s127"},"text":"May 24, 1949, ch. 139, § 127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a230b0a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a230b0b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a230b0c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 6 (§ 101 et seq.) of this title, referred to in subsec. (b), is a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-03-23/ch90"},"text":"act Mar. 23, 1932, ch. 90","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/70"},"text":"47 Stat. 70","children":[],"tail":", popularly known as the Norris-LaGuardia Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a230b0d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c), “court of appeals” substituted for “circuit court of appeals” on authority of act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":". The words “United States” immediately preceding “Court of appeals” were inserted on authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s43"},"text":"section 43 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":"” substituted for “sections 239 and 240 of the Judicial Code, as amended (U.S.C. title 28, secs. 346 and 347)” on authority of "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":", section 1 of which enacted Title 28, Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
