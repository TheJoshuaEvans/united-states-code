{"tag":"section","attrib":{"id":"id5a505c55-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s566"},"text":null,"children":[{"tag":"num","attrib":{"value":"566"},"text":"§ 566.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee drug and alcohol abuse assistance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a505c56-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s566/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall establish a program through which the Secretary shall provide grants to, or enter into contracts with, employers to enable such employers to develop employee drug and alcohol abuse assistance programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a505c57-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s566/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Employers desiring to receive a grant or contract under this section shall submit to the Secretary of Labor, an application, in such form and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a505c58-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s566/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall promulgate regulations necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a505c59-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s566/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, $4,000,000 for fiscal year 1989, and $5,000,000 for each of the fiscal years 1990 and 1991.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a505c5a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2101"},"text":"Pub. L. 100–690, title II, § 2101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4216"},"text":"102 Stat. 4216","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
