{"tag":"section","attrib":{"id":"id5a505c60-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s568"},"text":null,"children":[{"tag":"num","attrib":{"value":"568"},"text":"§ 568.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of donations by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor is authorized to accept, in the name of the Department of Labor, and employ or dispose of in furtherance of authorized activities of the Department of Labor, during the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":", and each fiscal year thereafter, any money or property, real, personal, or mixed, tangible or intangible, received by gift, devise, bequest, or otherwise."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a505c61-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/333/tI/s105"},"text":"Pub. L. 103–333, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2548"},"text":"108 Stat. 2548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a505c62-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a505c63-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a505c64-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions s