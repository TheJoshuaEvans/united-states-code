{"tag":"section","attrib":{"id":"id5b0a5e6c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1161"},"text":null,"children":[{"tag":"num","attrib":{"value":"1161"},"text":"§ 1161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans must provide continuation coverage to certain individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b0a5e6d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan sponsor of each group health plan shall provide, in accordance with this part, that each qualified beneficiary who would lose coverage under the plan as a result of a qualifying event is entitled, under the plan, to elect, within the election period, continuation coverage under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b0a5e6e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to any group health plan for any calendar year if all employers maintaining such plan normally employed fewer than 20 employees on a typical business day during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b0a5e6f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s601"},"text":"Pub. L. 93–406, title I, § 601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tX/s10002/a"},"text":"Pub. L. 99–272, title X, § 10002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/227"},"text":"100 Stat. 227","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7862(c)(1)(B), 7891(a)(1), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2432"},"text":"103 Stat. 2432","children":[],"tail":", 2445.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b0a5e70-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b0a5e71-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b0a5e72-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" struck out at end “Under regulations, rules similar to the rules of subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s52"},"text":"section 52 of title 26","children":[],"tail":" (relating to employers under common control) shall apply for purposes of this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/a/1"},"text":"Pub. L. 101–239, § 7891(a)(1)","children":[],"tail":", substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b0a5e73-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b0a5e74-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7862/c/1/B"},"text":"section 7862(c)(1)(B) of Pub. L. 101–239","children":[],"tail":" applicable to years beginning after "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"Dec. 31, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7862/c/1/C"},"text":"section 7862(c)(1)(C) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s106"},"text":"section 106 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/a/1"},"text":"section 7891(a)(1) of Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/f"},"text":"section 7891(f) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b0a5e75-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/tX/s10002/d"},"text":"Pub. L. 99–272, title X, § 10002(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/231"},"text":"100 Stat. 231","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/272/tX/s10002/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting this part and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1132"},"text":"section 1132 of this title","children":[],"tail":"] shall apply to plan years beginning on or after "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for collective bargaining agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a group health plan maintained pursuant to one or more collective bargaining agreements between employee representatives and one or more employers ratified before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":"], the amendments made by this section shall not apply to plan years beginning before the later of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the last of the collective bargaining agreements relating to the plan terminates (determined without regard to any extension thereof agreed to after the date of the enactment of this Act), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (A), any plan amendment made pursuant to a collective bargaining agreement relating to the plan which amends the plan solely to conform to any requirement added by this section shall not be treated as a termination of such collective bargaining agreement.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
