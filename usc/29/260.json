{"tag":"section","attrib":{"id":"id5a447599-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s260"},"text":null,"children":[{"tag":"num","attrib":{"value":"260"},"text":"§ 260.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidated damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any action commenced prior to or on or after ","children":[{"tag":"date","attrib":{"date":"1947-05-14"},"text":"May 14, 1947","children":[],"tail":" to recover unpaid minimum wages, unpaid overtime compensation, or liquidated damages, under the Fair Labor Standards Act of 1938, as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.], if the employer shows to the satisfaction of the court that the act or omission giving rise to such action was in good faith and that he had reasonable grounds for believing that his act or omission was not a violation of the Fair Labor Standards Act of 1938, as amended, the court may, in its sound discretion, award no liquidated damages or award any amount thereof not to exceed the amount specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s216"},"text":"section 216 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a44759a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-05-14/ch52/s11"},"text":"May 14, 1947, ch. 52, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/89"},"text":"61 Stat. 89","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/259/s6/d/2/B"},"text":"Pub. L. 93–259, § 6(d)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-08"},"text":"Apr. 8, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/62"},"text":"88 Stat. 62","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib