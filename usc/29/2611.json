{"tag":"section","attrib":{"id":"id5b628fc0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611"},"text":null,"children":[{"tag":"num","attrib":{"value":"2611"},"text":"§ 2611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b628fc1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “commerce” and “industry or activity affecting commerce” mean any activity, business, or industry in commerce or in which a labor dispute would hinder or obstruct commerce or the free flow of commerce, and include “commerce” and any “industry affecting commerce”, as defined in paragraphs (1) and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s142"},"text":"section 142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628fc2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible employee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b628fc3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible employee” means an employee who has been employed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b628fc4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for at least 12 months by the employer with respect to whom leave is requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b628fc5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for at least 1,250 hours of service with such employer during the previous 12-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b628fc6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible employee” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b628fc7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal officer or employee covered under subchapter V of chapter 63 of title 5; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b628fc8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of an employer who is employed at a worksite at which such employer employs less than 50 employees if the total number of employees employed by that employer within 75 miles of that worksite is less than 50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b628fc9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining whether an employee meets the hours of service requirement specified in subparagraph (A)(ii), the legal standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s207"},"text":"section 207 of this title","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b628fca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airline flight crews","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b628fcb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of determining whether an employee who is a flight attendant or flight crewmember (as such terms are defined in regulations of the Federal Aviation Administration) meets the hours of service requirement specified in subparagraph (A)(ii), the employee will be considered to meet the requirement if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b628fcc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has worked or been paid for not less than 60 percent of the applicable total monthly guarantee, or the equivalent, for the previous 12-month period, for or by the employer with respect to whom leave is requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b628fcd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has worked or been paid for not less than 504 hours (not counting personal commute time or time spent on vacation leave or medical or sick leave) during the previous 12-month period, for or by that employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b628fce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" File","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each employer of an employee described in clause (i) shall maintain on file with the Secretary (in accordance with such regulations as the Secretary may prescribe) containing information specifying the applicable monthly guarantee with respect to each category of employee to which such guarantee applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b628fcf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subparagraph, the term “applicable monthly guarantee” means—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b628fd0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an employee described in clause (i) other than an employee on reserve status, the minimum number of hours for which an employer has agreed to schedule such employee for any given month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b628fd1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an employee described in clause (i) who is on reserve status, the number of hours for which an employer has agreed to pay such employee on reserve status for any given month,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" as established in the applicable collective bargaining agreement or, if none exists, in the employer’s policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b628fd2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an employee of the Government Accountability Office, the requirements of subparagraph (A) shall not apply with respect to leave under section 2612(a)(1)(A) or (B) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628fd3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employ; employee; State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “employ”, “employee”, and “State” have the same meanings given such terms in subsections (c), (e), and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s203"},"text":"section 203 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628fd4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b628fd5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employer”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b6500d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any person engaged in commerce or in any industry or activity affecting commerce who employs 50 or more employees for each working day during each of 20 or more calendar workweeks in the current or preceding calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b6500d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b6500d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who acts, directly or indirectly, in the interest of an employer to any of the employees of such employer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b6500d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor in interest of an employer;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b6500da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any “public agency”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s203/x"},"text":"section 203(x) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b6500db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the Government Accountability Office and the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500dc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A)(iii), a public agency shall be considered to be a person engaged in commerce or in an industry or activity affecting commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employment benefits” means all benefits provided or made available to employees by an employer, including group life insurance, health insurance, disability insurance, sick leave, annual leave, educational benefits, and pensions, regardless of whether such benefits are provided by a practice or written policy of an employer or through an “employee benefit plan”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/3"},"text":"section 1002(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500de-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health care provider” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6500df-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a doctor of medicine or osteopathy who is authorized to practice medicine or surgery (as appropriate) by the State in which the doctor practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500e0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person determined by the Secretary to be capable of providing health care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “parent” means the biological parent of an employee or an individual who stood in loco parentis to an employee when the employee was a son or daughter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500e2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s203/a"},"text":"section 203(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduced leave schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reduced leave schedule” means a leave schedule that reduces the usual number of hours per workweek, or hours per workday, of an employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious health condition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “serious health condition” means an illness, injury, impairment, or physical or mental condition that involves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6500e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inpatient care in a hospital, hospice, or residential medical care facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing treatment by a health care provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Son or daughter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “son or daughter” means a biological, adopted, or foster child, a stepchild, a legal ward, or a child of a person standing in loco parentis, who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6500e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under 18 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18 years of age or older and incapable of self-care because of a mental or physical disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “spouse” means a husband or wife, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered active duty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered active duty” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6500ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of a regular component of the Armed Forces, duty during the deployment of the member with the Armed Forces to a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of a reserve component of the Armed Forces, duty during the deployment of the member with the Armed Forces to a foreign country under a call or order to active duty under a provision of law referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13/B"},"text":"section 101(a)(13)(B) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered servicemember","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered servicemember” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6500f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Armed Forces (including a member of the National Guard or Reserves) who is undergoing medical treatment, recuperation, or therapy, is otherwise in outpatient status, or is otherwise on the temporary disability retired list, for a serious injury or illness; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a veteran who is undergoing medical treatment, recuperation, or therapy, for a serious injury or illness and who was a member of the Armed Forces (including a member of the National Guard or Reserves) at any time during the period of 5 years preceding the date on which the veteran undergoes that medical treatment, recuperation, or therapy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outpatient status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “outpatient status”, with respect to a covered servicemember, means the status of a member of the Armed Forces assigned to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6500f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military medical treatment facility as an outpatient; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit established for the purpose of providing command and control of members of the Armed Forces receiving medical care as outpatients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Next of kin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “next of kin”, used with respect to an individual, means the nearest blood relative of that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Serious injury or illness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “serious injury or illness”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6500f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the Armed Forces (including a member of the National Guard or Reserves), means an injury or illness that was incurred by the member in line of duty on active duty in the Armed Forces (or existed before the beginning of the member’s active duty and was aggravated by service in line of duty on active duty in the Armed Forces) and that may render the member medically unfit to perform the duties of the member’s office, grade, rank, or rating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6500f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a veteran who was a member of the Armed Forces (including a member of the National Guard or Reserves) at any time during a period described in paragraph (15)(B), means a qualifying (as defined by the Secretary of Labor) injury or illness that was incurred by the member in line of duty on active duty in the Armed Forces (or existed before the beginning of the member’s active duty and was aggravated by service in line of duty on active duty in the Armed Forces) and that manifested itself before or after the member became a veteran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6500f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2611/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “veteran” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b6500fa-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tI/s101"},"text":"Pub. L. 103–3, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/7"},"text":"107 Stat. 7","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/1/tII/s202/c/1/A"},"text":"Pub. L. 104–1, title II, § 202(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/9"},"text":"109 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s585/a/1"},"text":"Pub. L. 110–181, div. A, title V, § 585(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/128"},"text":"122 Stat. 128","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s565/a/1/A"},"text":"Pub. L. 111–84, div. A, title V, § 565(a)(1)(A)","children":[],"tail":", (2), (3), "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2309"},"text":"123 Stat. 2309","children":[],"tail":", 2310; "},{"tag":"ref","attrib":{"href":"/us/pl/111/119/s2/a"},"text":"Pub. L. 111–119, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-21"},"text":"Dec. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3476"},"text":"123 Stat. 3476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXVI/s7604/b"},"text":"Pub. L. 116–92, div. F, title LXXVI, § 7604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2308"},"text":"133 Stat. 2308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b6500fb-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b6500fc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b6500fd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Par. (2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/119"},"text":"Pub. L. 111–119","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/1/A/i"},"text":"Pub. L. 111–84, § 565(a)(1)(A)(i)","children":[],"tail":", added par. (14) and struck out former par. (14). Prior to amendment, text read as follows: “The term ‘active duty’ means duty under a call or order to active duty under a provision of law referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13/B"},"text":"section 101(a)(13)(B) of title 10","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/2"},"text":"Pub. L. 111–84, § 565(a)(2)","children":[],"tail":", amended par. (15) generally. Prior to amendment, text read as follows: “The term ‘covered servicemember’ means a member of the Armed Forces, including a member of the National Guard or Reserves, who is undergoing medical treatment, recuperation, or therapy, is otherwise in outpatient status, or is otherwise on the temporary disability retired list, for a serious injury or illness.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/1/A/ii"},"text":"Pub. L. 111–84, § 565(a)(1)(A)(ii)","children":[],"tail":", redesignated par. (16) as (15) and struck out former par. (15). Prior to amendment, text read as follows: “The term ‘contingency operation’ has the same meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13"},"text":"section 101(a)(13) of title 10","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (16), (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/1/A/ii"},"text":"Pub. L. 111–84, § 565(a)(1)(A)(ii)","children":[],"tail":", redesignated pars. (17) and (18) as (16) and (17), respectively. Former par. (16) redesignated (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/3"},"text":"Pub. L. 111–84, § 565(a)(3)","children":[],"tail":", added par. (18) and struck out former par. (18). Prior to amendment, text read as follows: “The term ‘serious injury or illness’, in the case of a member of the Armed Forces, including a member of the National Guard or Reserves, means an injury or illness incurred by the member in line of duty on active duty in the Armed Forces that may render the member medically unfit to perform the duties of the member’s office, grade, rank, or rating.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/1/A/ii"},"text":"Pub. L. 111–84, § 565(a)(1)(A)(ii)","children":[],"tail":", redesignated par. (19) as (18). Former par. (18) redesignated (17)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/3"},"text":"Pub. L. 111–84, § 565(a)(3)","children":[],"tail":", added par. (19)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s565/a/1/A/ii"},"text":"Pub. L. 111–84, § 565(a)(1)(A)(ii)","children":[],"tail":", redesignated par. (19) as (18)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Pars. (14) to (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added pars. (14) to (19)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (4)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Par. (4)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":" added cl. (iv)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b6500fe-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b6500ff-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXVI/s7604/c"},"text":"Pub. L. 116–92, div. F, title LXXVI, § 7604(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2308"},"text":"133 Stat. 2308","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dF/tLXXVI/s7604/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612"},"text":"section 2612 of this title","children":[],"tail":"] shall not be effective with respect to any birth or placement occurring before "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b650100-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/1"},"text":"Pub. L. 104–1","children":[],"tail":" effective one year after transmission to Congress of the study under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1371"},"text":"section 1371 of Title 2","children":[],"tail":", The Congress, see "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1312/f/2"},"text":"section 1312(f)(2) of Title 2","children":[],"tail":". The study required under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1371"},"text":"section 1371 of Title 2","children":[],"tail":", dated "},{"tag":"date","attrib":{"date":"1996-12-31"},"text":"Dec. 31, 1996","children":[],"tail":", was transmitted to Congress by the Board of Directors of the Office of Compliance on "},{"tag":"date","attrib":{"date":"1996-12-30"},"text":"Dec. 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b650101-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", except that, in the case of collective bargaining agreements in effect on that effective date, section applicable on the earlier of (1) the date of termination of such agreement, or (2) the date that occurs 12 months after "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/3/s405/b"},"text":"section 405(b) of Pub. L. 103–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b650102-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s565/a/5"},"text":"Pub. L. 111–84, div. A, title V, § 565(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2311"},"text":"123 Stat. 2311","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tV/s565/a/5"},"text":"“In prescribing regulations to carry out the amendments made by this subsection [amending this section and sections 2612 and 2613 of this title], the Secretary of Labor shall consult with the Secretary of Defense and the Secretary of Veterans Affairs, as applicable.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b650103-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"FMLA: Including Military Service in Determining Eligibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXI/s1114/b"},"text":"Pub. L. 118–31, div. A, title XI, § 1114(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/432"},"text":"137 Stat. 432","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tXI/s1114/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered employee who has completed 12 months of service which qualifies as honorable active service in the Army, Navy, Air Force, Space Force, or Marine Corps of the United States shall be deemed to have met the service requirement in section 101(1)(A) [probably should be 101(2)(A)] of the Family and Medical Leave Act of 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2611/2/A"},"text":"29 U.S.C. 2611(2)(A)","children":[],"tail":"], notwithstanding the requirements of such section 101(1)(A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered employee defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term ‘covered employee’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal employee eligible for family and medical leave under the Family and Medical Leave Act of 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"29 U.S.C. 2601","children":[],"tail":" et seq.] based on their status as such an employee;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal employee covered by the Congressional Accountability Act of 1995 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1301"},"text":"2 U.S.C. 1301","children":[],"tail":" et seq.] eligible for family and medical leave by operation of section 202 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1312"},"text":"2 U.S.C. 1312","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal employee of the Executive Office of the President eligible for family and medical leave by operation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s412"},"text":"section 412 of title 3","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any non-judicial employee of the District of Columbia courts and any employee of the District of Columbia Public Defender Service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any member of the Commissioned Corps of the Public Health Service or the Commissioned Corps of the National Oceanic and Atmospheric Administration, [sic]”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
