{"tag":"section","attrib":{"id":"id5b2bc809-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304"},"text":null,"children":[{"tag":"num","attrib":{"value":"1304"},"text":"§ 1304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant and Plan Sponsor Advocate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b2bc80a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The board of directors of the corporation shall select a Participant and Plan Sponsor Advocate from the candidates nominated by the advisory committee to the corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1302/h/1"},"text":"section 1302(h)(1) of this title","children":[],"tail":" and without regard to the provisions of title 5 relating to appointments in the competitive service or Senior Executive Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b2bc80b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Participant and Plan Sponsor Advocate shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b2bc80c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as a liaison between the corporation, sponsors of defined benefit pension plans insured by the corporation, and participants in pension plans trusteed by the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc80d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocate for the full attainment of the rights of participants in plans trusteed by the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc80e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist pension plan sponsors and participants in resolving disputes with the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc80f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify areas in which participants and plan sponsors have persistent problems in dealings with the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc810-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible, propose changes in the administrative practices of the corporation to mitigate problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc811-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential legislative changes which may be appropriate to mitigate problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc812-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer instances of fraud, waste, and abuse, and violations of law to the Office of the Inspector General of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b2bc813-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Participant and Plan Sponsor Advocate is removed from office or is transferred to another position or location within the corporation or the Department of Labor, the board of the ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" directors of the corporation shall communicate in writing the reasons for any such removal or transfer to Congress not less than 30 days before the removal or transfer. Nothing in this subsection shall prohibit a personnel action otherwise authorized by law, other than transfer or removal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b2bc814-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual rate of basic pay for the Participant and Plan Sponsor Advocate shall be the same rate as the highest rate of basic pay established for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":" or, if the board of directors of the corporation so determines, at a rate fixed under section 9503 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b2bc815-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b2bc816-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than December 31 of each calendar year, the Participant and Plan Sponsor Advocate shall report to the Health, Education, Labor, and Pensions Committee of the Senate, the Committee on Finance of the Senate, the Committee on Education and the Workforce of the House of Representatives, and the Committee on Ways and Means of the House of Representatives on the activities of the Office of the Participant and Plan Sponsor Advocate during the fiscal year ending during such calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc817-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b2bc818-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarize the assistance requests received from participants and plan sponsors and describe the activities, and evaluate the effectiveness, of the Participant and Plan Sponsor Advocate during the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b2bc819-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify significant problems the Participant and Plan Sponsor Advocate has identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b2bc81a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include specific legislative and regulatory changes to address the problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b2bc81b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any actions taken to correct problems identified in any previous report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b2bc81c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1304/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Participant and Plan Sponsor Advocate shall submit a copy of each report to the Secretary of Labor, the Director of the corporation, and any other appropriate official at the same time such report is submitted to the committees of Congress under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b2bc81d-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4004"},"text":"Pub. L. 93–406, title IV, § 4004","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dD/tII/s40232/a"},"text":"Pub. L. 112–141, div. D, title II, § 40232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/856"},"text":"126 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b2bc81e-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b2bc81f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5b2bc820-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1304, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4004"},"text":"Pub. L. 93–406, title IV, § 4004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1008"},"text":"88 Stat. 1008","children":[],"tail":", related to appointment, within 270 days after "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", and powers and functions of a receiver to assume control of terminated plan and its assets, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXI/s11016/c/6"},"text":"Pub. L. 99–272, title XI, § 11016(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/274"},"text":"100 Stat. 274","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", with certain exceptions. See "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/s11019"},"text":"section 11019 of Pub. L. 99–272","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341"},"text":"section 1341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
