{"tag":"section","attrib":{"id":"id5b0a5e2b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1149"},"text":null,"children":[{"tag":"num","attrib":{"value":"1149"},"text":"§ 1149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on false statements and representations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No person, in connection with a plan or other arrangement that is ","children":[{"tag":"ref","attrib":{"idref":"fn002120"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002120"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “a”."}],"tail":" multiple employer welfare arrangement described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/40"},"text":"section 1002(40) of this title","children":[],"tail":", shall make a false statement or false representation of fact, knowing it to be false, in connection with the marketing or sale of such plan or arrangement, to any employee, any member of an employee organization, any beneficiary, any employer, any employee organization, the Secretary, or any State, or the representative or agent of any such person, State, or the Secretary, concerning—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b0a5e2c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1149/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial condition or solvency of such plan or arrangement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b0a5e2d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1149/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits provided by such plan or arrangement;","children":[],"tail":"\n"}],"ta