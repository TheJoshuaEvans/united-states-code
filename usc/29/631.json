teOfAmendment","id":"id5a59f9ae-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/256/s3/b"},"text":"Pub. L. 95–256, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-06"},"text":"Apr. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/190"},"text":"92 Stat. 190","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/256/s3/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 12(a), 12(c), and 12(d) of the Age Discrimination in Employment Act of 1967, as amended by subsection (a) of this section [subsecs. (a), (c), and (d) of this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12(b) of such Act, as amended by subsection (a) of this section [subsec. (b) of this section], shall take effect on ","children":[{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12(d) of such Act, as amended by subsection (a) of this section [enacting subsec. (d) of this section], is repealed on ","children":[{"tag":"date","attrib":{"date":"1982-07-01"},"text":"July 1, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5a59f9af-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5a59f9b0-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Equal Employment Opportunity Commission” substituted for “Secretary”, meaning Secretary of Labor, in subsec. (c)(2) pursuant to Reorg. Plan No. 1 of 1978, § 2, 43 F.R. 19807, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/92/3781"},"text":"92 Stat. 3781","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees, which transferred all functions vested by this section in Secretary of Labor to Equal Employment Opportunity Commission, effective "},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", as provided by section 1–101 of Ex. Ord. No. 12106, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1053."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
