{"tag":"section","attrib":{"id":"id5b8580e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162"},"text":null,"children":[{"tag":"num","attrib":{"value":"3162"},"text":"§ 3162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b8580e2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b8580e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each fiscal year for which the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/a"},"text":"section 3181(a) of this title","children":[],"tail":" exceeds $925,000,000, reserve 4 percent of the excess amount to provide youth workforce investment activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3222"},"text":"section 3222 of this title","children":[],"tail":" (relating to migrant and seasonal farmworkers); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b8580e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the remainder of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/a"},"text":"section 3181(a) of this title","children":[],"tail":" for a fiscal year to make allotments and grants in accordance with subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b8580e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment among States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b8580e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth workforce investment activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b8580e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Americans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/a"},"text":"section 3181(a) of this title","children":[],"tail":" for a fiscal year that is not reserved under subsection (a)(1), the Secretary shall reserve not more than 1½ percent of such amount to provide youth workforce investment activities under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3221"},"text":"section 3221 of this title","children":[],"tail":" (relating to Native Americans)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b8580e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outlying areas","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b8580e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/a"},"text":"section 3181(a) of this title","children":[],"tail":" for each fiscal year that is not reserved under subsection (a)(1) and subparagraph (A), the Secretary shall reserve not more than ¼ of 1 percent of such amount to provide assistance to the outlying areas to carry out youth workforce investment activities and statewide workforce investment activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b85a7fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation for outlying areas","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b85a7fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use funds reserved under clause (i) to award grants to outlying areas to carry out youth workforce investment activities and statewide workforce investment activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85a7fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants pursuant to subclause (I) on a competitive basis and pursuant to the recommendations of experts in the field of employment and training, working through the Pacific Region Educational Laboratory in Honolulu, Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85a7fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide not more than 5 percent of the funds made available for grants under subclause (I) to pay the administrative costs of the Pacific Region Educational Laboratory in Honolulu, Hawaii, regarding activities assisted under this clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b85a7fe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1469a"},"text":"section 1469a of title 48","children":[],"tail":", permitting the consolidation of grants by the outlying areas, shall not apply to assistance provided to those areas, including Palau, under this subparagraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b85a7ff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b85a800-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the remainder of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3181/a"},"text":"section 3181(a) of this title","children":[],"tail":" for a fiscal year that exists after the Secretary determines the amounts to be reserved under subsection (a)(1) and subparagraphs (A) and (B), the Secretary shall make allotments to the States in accordance with clause (ii) for youth workforce investment activities and statewide workforce investment activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b85a801-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to clauses (iii) and (iv), of the remainder—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b85a802-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative number of unemployed individuals in areas of substantial unemployment in each State, compared to the total number of unemployed individuals in areas of substantial unemployment in all States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85a803-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative excess number of unemployed individuals in each State, compared to the total excess number of unemployed individuals in all States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85a804-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33⅓ percent shall be allotted on the basis of the relative number of disadvantaged youth in each State, compared to the total number of disadvantaged youth in all States, except as described in clause (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b85cf15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining an allotment under clause (ii)(III) for any State in which there is an area that was designated as a local area as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3122/c/1/C"},"text":"section 3122(c)(1)(C) of this title","children":[],"tail":", the allotment shall be based on the higher of—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id5b85cf16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals who are age 16 through 21 in families with an income below the low-income level in such area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85cf17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of disadvantaged youth in such area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b85cf18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum and maximum percentages and minimum allotments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making allotments under this subparagraph, the Secretary shall ensure the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b85cf19-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum percentage and allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subclause (IV), the Secretary shall ensure that no State shall receive an allotment for a fiscal year that is less than the greater of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b85cf1a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount based on 90 percent of the allotment percentage of the State for the preceding fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b85cf1b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the allotments of the State under section 127(b)(1)(C) of the Workforce Investment Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2852/b/1/C"},"text":"29 U.S.C. 2852(b)(1)(C)","children":[],"tail":"] (as in effect on the day before "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":") for fiscal year 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85cf1c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small State minimum allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subclauses (I), (III), and (IV), the Secretary shall ensure that no State shall receive an allotment under this subparagraph that is less than the total of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b85cf1d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"10","children":[],"tail":" of 1 percent of $1,000,000,000 of the remainder described in clause (i) for the fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b85cf1e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the remainder described in clause (i) for the fiscal year exceeds $1,000,000,000, ⅖ of 1 percent of the excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85cf1f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subclause (I), the Secretary shall ensure that no State shall receive an allotment percentage for a fiscal year that is more than 130 percent of the allotment percentage of the State for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b85cf20-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/1/C/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any fiscal year in which the remainder described in clause (i) does not exceed $1,000,000,000, the minimum allotments under subclauses (I) and (II) shall be calculated by the methodology specified in section 127(b)(1)(C)(iv)(IV) of the Workforce Investment Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2852/b/1/C/iv/IV"},"text":"29 U.S.C. 2852(b)(1)(C)(iv)(IV)","children":[],"tail":"] (as in effect on the day before "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b85f631-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of the formula specified in paragraph (1)(C):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b85f632-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “allotment percentage”, used with respect to fiscal year 2015 or a subsequent fiscal year, means a percentage of the remainder described in paragraph (1)(C)(i) that is received through an allotment made under paragraph (1)(C) for the fiscal year. The term, used with respect to fiscal year 2014, means the percentage of the amount allotted to States under section 127(b)(1)(C) of the Workforce Investment Act of 1998 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2852/b/1/C"},"text":"29 U.S.C. 2852(b)(1)(C)","children":[],"tail":"] (as in effect on the day before "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":") that is received under such section by the State involved for fiscal year 2014."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b85f633-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area of substantial unemployment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “area of substantial unemployment” means any area that is of sufficient size and scope to sustain a program of workforce investment activities carried out under this part and that has an average rate of unemployment of at least 6.5 percent for the most recent 12 months, as determined by the Secretary. For purposes of this subparagraph, determinations of areas of substantial unemployment shall be made once each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b85f634-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged youth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), the term “disadvantaged youth” means an individual who is age 16 through 21 who received an income, or is a member of a family that received a total family income, that, in relation to family size, does not exceed the higher of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b85f635-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the poverty line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b85f636-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of the lower living standard income level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b85f637-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess number","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excess number” means, used with respect to the excess number of unemployed individuals within a State, the higher of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b85f638-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number that represents the number of unemployed individuals in excess of 4.5 percent of the civilian labor force in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b85f639-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number that represents the number of unemployed individuals in excess of 4.5 percent of the civilian labor force in areas of substantial unemployment in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b85f63a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income level” means $7,000 with respect to income in 1969, and for any later year means that amount that bears the same relationship to $7,000 as the Consumer Price Index for that year bears to the Consumer Price Index for 1969, rounded to the nearest $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b861d4b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of the formula specified in paragraph (1)(C), the Secretary shall, as appropriate and to the extent practicable, exclude college students and members of the Armed Forces from the determination of the number of disadvantaged youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b861d4c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b861d4d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in accordance with this subsection, reallot to eligible States amounts that are made available to States from allotments made under this section or a corresponding provision of the Workforce Investment Act of 1998 for youth workforce investment activities and statewide workforce investment activities (referred to individually in this subsection as a “State allotment”) and that are available for reallotment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b861d4e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount available for reallotment for a program year is equal to the amount by which the unobligated balance of the State allotment, at the end of the program year prior to the program year for which the determination under this paragraph is made, exceeds 20 percent of such allotment for the prior program year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b861d4f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making reallotments to eligible States of amounts available pursuant to paragraph (2) for a program year, the Secretary shall allot to each eligible State an amount based on the relative amount of the State allotment for the program year for which the determination is made, as compared to the total amount of the State allotments for all eligible States for such program year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b861d50-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, an eligible State means a State that does not have an amount available for reallotment under paragraph (2) for the program year for which the determination under paragraph (2) is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b861d51-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3162/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor shall prescribe uniform procedures for the obligation of funds by local areas within the State in order to avoid the requirement that funds be made available for reallotment under this subsection. The Governor shall further prescribe equitable procedures for making funds available from the State and local areas in the event that a State is required to make funds available for reallotment under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b864462-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s127"},"text":"Pub. L. 113–128, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1498"},"text":"128 Stat. 1498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b864463-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b864464-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b864465-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Workforce Investment Act of 1998, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/936"},"text":"112 Stat. 936","children":[],"tail":", and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV"},"text":"Pub. L. 113–128, title V","children":[],"tail":", §§ 506, 511(a), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1703"},"text":"128 Stat. 1703","children":[],"tail":", 1705, effective "},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":". Pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3361/a"},"text":"section 3361(a) of this title","children":[],"tail":", references to a provision of the Workforce Investment Act of 1998 are deemed to refer to the corresponding provision of the Workforce Innovation and Opportunity Act, "},{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":". For complete classification of the Workforce Investment Act of 1998 to the Code, see Tables. For complete classification of the Workforce Innovation and Opportunity Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b864466-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b864467-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
