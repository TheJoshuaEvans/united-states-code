{"tag":"section","attrib":{"id":"id5b69bb74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703"},"text":null,"children":[{"tag":"num","attrib":{"value":"2703"},"text":"§ 2703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b69bb75-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced workplace practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced workplace practices” means innovations in work organization and performance, including high-performance workplace systems, flexible production techniques, quality programs, continuous improvement, concurrent engineering, close relationships between suppliers and customers, widely diffused decisionmaking and work teams, and effective integration of production technology, worker skills and training, and workplace organization, and such other characteristics as determined appropriate by the Secretary of Labor, in consultation with the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b69bb76-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced workplace technologies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advanced workplace technologies” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b69bb77-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" numerically controlled machine tools, robots, automated process control equipment, computerized flexible manufacturing systems, associated computer software, and other technology for improving the manufacturing and industrial production of goods and commercial services, which advance the state-of-the-art; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb78-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" novel industrial and commercial techniques and processes not previously generally available that improve quality, productivity, and practices, including engineering design, quality assurance, concurrent engineering, continuous process production technology, inventory management, upgraded worker skills, communications with customers and suppliers, and promotion of sustainable economic growth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b69bb79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b69bb7a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonprofit organization” means a tax-exempt organization, as described in paragraph (3), (4), or (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b69bb7b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b69bb7c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2703/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worker organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “worker organization” means a labor organization within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/5"},"text":"section 501(c)(5) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b69bb7d-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV/s544"},"text":"Pub. L. 103–382, title V, § 544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4053"},"text":"108 Stat. 4053","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
