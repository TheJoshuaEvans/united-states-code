{"tag":"section","attrib":{"id":"id5a068286-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"§ 8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unemployment data relating to Americans of Spanish origin or descent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of Labor, in cooperation with the Department of Commerce, shall develop methods for improving and expanding the collection, analysis, and publication of unemployment data relating to Americans of Spanish origin or descent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a068287-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/311/s1"},"text":"Pub. L. 94–311, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-16"},"text":"June 16, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/688"},"text":"90 Stat. 688","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
