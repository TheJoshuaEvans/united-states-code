{"tag":"section","attrib":{"id":"id5b249ce5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1202a"},"text":"§ 1202a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee plans compliance resolution system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b249ce6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall have full authority to establish and implement the Employee Plans Compliance Resolution System (or any successor program) and any other employee plans correction policies, including the authority to waive income, excise, or other taxes to ensure that any tax, penalty, or sanction is not excessive and bears a reasonable relationship to the nature, extent, and severity of the failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b249ce7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall continue to update and improve the Employee Plans Compliance Resolution System (or any successor program), giving special attention to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b249ce8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the awareness and knowledge of small employers concerning the availability and use of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249ce9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking into account special concerns and circumstances that small employers face with respect to compliance and correction of compliance failures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249cea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extending the duration of the self-correction period under the Self-Correction Program for significant compliance failures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249ceb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding the availability to correct insignificant compliance failures under the Self-Correction Program during audit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249cec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1202a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assuring that any tax, penalty, or sanction that is imposed by reason of a compliance failure is not excessive and bears a reasonable relationship to the nature, extent, and severity of the failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b249ced-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tXI/s1101"},"text":"Pub. L. 109–280, title XI, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1055"},"text":"120 Stat. 1055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b249cee-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b249cef-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5b249cf0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Pension Protection Act of 2006, and not as part of the Employee Retirement Income Security Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
