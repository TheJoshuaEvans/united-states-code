{"tag":"section","attrib":{"id":"id5b51ed70-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451"},"text":null,"children":[{"tag":"num","attrib":{"value":"1451"},"text":"§ 1451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b51ed71-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons entitled to maintain actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b51ed72-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan fiduciary, employer, plan participant, or beneficiary, who is adversely affected by the act or omission of any party under this subtitle with respect to a multiemployer plan, or an employee organization which represents such a plan participant or beneficiary for purposes of collective bargaining, may bring an action for appropriate legal or equitable relief, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b51ed73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), this section does not authorize an action against the Secretary of the Treasury, the Secretary of Labor, or the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b51ed74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of employer to make withdrawal liability payment within prescribed time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action under this section to compel an employer to pay withdrawal liability, any failure of the employer to make any withdrawal liability payment within the time prescribed shall be treated in the same manner as a delinquent contribution (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1145"},"text":"section 1145 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b51ed75-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of Federal and State courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have exclusive jurisdiction of an action under this section without regard to the amount in controversy, except that State courts of competent jurisdiction shall have concurrent jurisdiction over an action brought by a plan fiduciary to collect withdrawal liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b51ed76-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue and service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action under this section may be brought in the district where the plan is administered or where a defendant resides or does business, and process may be served in any district where a defendant resides, does business, or may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b51ed77-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action under this section, the court may award all or a portion of the costs and expenses incurred in connection with such action, including reasonable attorney’s fees, to the prevailing party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b51ed78-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An action under this section may not be brought after the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b51ed79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 years after the date on which the cause of action arose, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b51ed7a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 years after the earliest date on which the plaintiff acquired or should have acquired actual knowledge of the existence of such cause of action; except that in the case of fraud or concealment, such action may be brought not later than 6 years after the date of discovery of the existence of such cause of action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b51ed7b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1451/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of complaint on corporation; intervention by corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the complaint in any action under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1401"},"text":"section 1401 of this title","children":[],"tail":" shall be served upon the corporation by certified mail. The corporation may intervene in any such action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b51ed7c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4301"},"text":"Pub. L. 93–406, title IV, § 4301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1263"},"text":"94 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b51ed7d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b51ed7e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b51ed7f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
