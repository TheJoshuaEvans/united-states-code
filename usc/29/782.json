{"tag":"section","attrib":{"id":"id5a90c072-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s782"},"text":null,"children":[{"tag":"num","attrib":{"value":"782"},"text":"§ 782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of National Council members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a90c073-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s782/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the National Council shall be entitled to receive compensation at a rate equal to the rate of pay for level 4 of the Senior Executive Service Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":", including travel time, for each day they are engaged in the performance of their duties as members of the National Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a90c074-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s782/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full-time officers or employees of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the National Council who are full-time officers or employees of the United States shall receive no additional pay on account of their service on the National Council except for compensation for travel expenses as provided under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a90c075-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s782/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business in the performance of services for the National Council, members of the National Council shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a90c076-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s402"},"text":"Pub. L. 93–112, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s407"},"text":"Pub. L. 105–220, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1200"},"text":"112 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a90c077-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a90c078-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a90c079-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 782, ","children"