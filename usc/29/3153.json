{"tag":"section","attrib":{"id":"id5b8559c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3153"},"text":null,"children":[{"tag":"num","attrib":{"value":"3153"},"text":"§ 3153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible providers of youth workforce investment activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b8559c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the funds allocated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3163/b"},"text":"section 3163(b) of this title","children":[],"tail":" to a local area, the local board for such area shall award grants or contracts on a competitive basis to providers of youth workforce investment activities identified based on the criteria in the State plan (including such quality criteria as the Governor shall establish for a training program that leads to a recognized postsecondary credential), and taking into consideration the ability of the providers to meet performance accountability measures based on primary indicators of performance for the youth program as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/2/A/ii"},"text":"section 3141(b)(2)(A)(ii) of this title","children":[],"tail":", as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3112/b/2/D/i/V"},"text":"section 3112(b)(2)(D)(i)(V) of this title","children":[],"tail":", and shall conduct oversight with respect to such providers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b8559c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local board may award grants or contracts on a sole-source basis if such board determines there is an insufficient number of eligible providers of youth workforce investment activities in the local area involved (such as a rural area) for grants and contracts to be awarded on a competitive basis under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b8559c7-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s123"},"text":"Pub. L. 113–128, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1498"},"text":"128 Stat. 1498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b8559c8-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b8559c9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b8559ca-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
