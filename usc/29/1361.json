{"tag":"section","attrib":{"id":"id5b3edb13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1361"},"text":null,"children":[{"tag":"num","attrib":{"value":"1361"},"text":"§ 1361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts payable by corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation shall pay benefits under a single-employer plan terminated under this subchapter subject to the limitations and requirements of subtitle B of this subchapter. The corporation shall provide financial assistance to pay benefits under a multiemployer plan which is insolvent under section 1426 or 1441(d)(2)(A) of this title, subject to the limitations and requirements of subtitles B, C, and E of this subchapter. Amounts guaranteed by the corporation under sections 1322 and 1322a of this title shall be paid by the corporation only out of the appropriate fund. The corporation shall make payments under the supplemental program to reimburse multiemployer plans for uncollectible withdrawal liability only out of the fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1305/e"},"text":"section 1305(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b3edb14-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4061"},"text":"Pub. L. 93–406, title IV, § 4061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1029"},"text":"88 Stat. 1029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIV/s403/f"},"text":"Pub. L. 96–364, title IV, § 403(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1301"},"text":"94 Stat. 1301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b3edb15-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b3edb16-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b3edb17-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" substituted provisions relating to payment of benefits under a single-employer plan terminated under this subchapter subject to limitations and requirements of subtitle B of this subchapter for provisions relating to payment of benefits under a plan terminated under this subchapter subject to limitations and requirements of subtitle B of this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b3edb18-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b3edb19-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
