{"tag":"section","attrib":{"id":"id5b5dd561-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007"},"text":null,"children":[{"tag":"num","attrib":{"value":"2007"},"text":"§ 2007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5dd562-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Test as basis for adverse employment action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd563-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under ongoing investigations exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the exemption under subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2006"},"text":"section 2006 of this title","children":[],"tail":" shall not apply if an employee is discharged, disciplined, denied employment or promotion, or otherwise discriminated against in any manner on the basis of the analysis of a polygraph test chart or the refusal to take a polygraph test, without additional supporting evidence. The evidence required by such subsection may serve as additional supporting evidence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd564-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under other exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an exemption described in subsection (e) or (f) of such section, the exemption shall not apply if the results of an analysis of a polygraph test chart are used, or the refusal to take a polygraph test is used, as the sole basis upon which an adverse employment action described in paragraph (1) is taken against an employee or prospective employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd565-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of examinee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemptions provided under subsections (d), (e), and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2006"},"text":"section 2006 of this title","children":[],"tail":" shall not apply unless the requirements described in the following paragraphs are met:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd566-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All phases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Throughout all phases of the test—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd567-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examinee shall be permitted to terminate the test at any time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd568-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examinee is not asked questions in a manner designed to degrade, or needlessly intrude on, such examinee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd569-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the examinee is not asked any question concerning—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd56a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" religious beliefs or affiliations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd56b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beliefs or opinions regarding racial matters,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd56c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" political beliefs or affiliations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd56d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any matter relating to sexual behavior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd56e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beliefs, affiliations, opinions, or lawful activities regarding unions or labor organizations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd56f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examiner does not conduct the test if there is sufficient written evidence by a physician that the examinee is suffering from a medical or psychological condition or undergoing treatment that might cause abnormal responses during the actual testing phase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd570-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pretest phase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the pretest phase, the prospective examinee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd571-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided with reasonable written notice of the date, time, and location of the test, and of such examinee’s right to obtain and consult with legal counsel or an employee representative before each phase of the test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd572-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is informed in writing of the nature and characteristics of the tests and of the instruments involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd573-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is informed, in writing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd574-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the testing area contains a two-way mirror, a camera, or any other device through which the test can be observed,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd575-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether any other device, including any device for recording or monitoring the test, will be used, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd576-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the employer or the examinee may (with mutual knowledge) make a recording of the test;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd577-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is read and signs a written notice informing such examinee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd578-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the examinee cannot be required to take the test as a condition of employment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd579-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any statement made during the test may constitute additional supporting evidence for the purposes of an adverse employment action described in subsection (a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd57a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the limitations imposed under this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd57b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the legal rights and remedies available to the examinee if the polygraph test is not conducted in accordance with this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd57c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the legal rights and remedies of the employer under this chapter (including the rights of the employer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2008/c/2"},"text":"section 2008(c)(2) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd57d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided an opportunity to review all questions to be asked during the test and is informed of the right to terminate the test at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd57e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actual testing phase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the actual testing phase, the examiner does not ask such examinee any question relevant during the test that was not presented in writing for review to such examinee before the test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd57f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-test phase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before any adverse employment action, the employer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd580-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further interview the examinee on the basis of the results of the test; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd581-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide the examinee with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd582-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written copy of any opinion or conclusion rendered as a result of the test, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd583-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the questions asked during the test along with the corresponding charted responses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd584-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum number and minimum duration of tests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The examiner shall not conduct and complete more than five polygraph tests on a calendar day on which the test is given, and shall not conduct any such test for less than a 90-minute duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd585-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications and requirements of examiners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemptions provided under subsections (d), (e), and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2006"},"text":"section 2006 of this title","children":[],"tail":" shall not apply unless the individual who conducts the polygraph test satisfies the requirements under the following paragraphs:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b604586-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The examiner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b604587-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a valid and current license granted by licensing and regulatory authorities in the State in which the test is to be conducted, if so required by the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b604588-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains a minimum of a $50,000 bond or an equivalent amount of professional liability coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b604589-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The examiner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b60458a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" renders any opinion or conclusion regarding the test—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b60458b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in writing and solely on the basis of an analysis of polygraph test charts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b60458c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not contain information other than admissions, information, case facts, and interpretation of the charts relevant to the purpose and stated objectives of the test, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b60458d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not include any recommendation concerning the employment of the examinee; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b60458e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains all opinions, reports, charts, written questions, lists, and other records relating to the test for a minimum period of 3 years after administration of the test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b60458f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s8"},"text":"Pub. L. 100–347, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/650"},"text":"102 Stat. 650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b604590-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b604591-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b604592-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", except that rules and regulations shall be issued not later than 90 days after "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/347/s11"},"text":"section 11 of Pub. L. 100–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
