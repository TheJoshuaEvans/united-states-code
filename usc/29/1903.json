{"tag":"section","attrib":{"id":"id5b5b639d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1903"},"text":null,"children":[{"tag":"num","attrib":{"value":"1903"},"text":"§ 1903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit; monitoring and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5b639e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The books and accounts of the Center shall be audited annually by an independent auditor in the manner prescribed by the Secretary and a report on each such audit shall be submitted by the auditor to the Secretary within 15 days following the completion of the audit and acceptance of the audit by the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5b639f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5b63a0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish procedures for monitoring, on a regular basis, the services performed and the training conducted by the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5b63a1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, in addition to the regular monitoring required under paragraph (1), conduct an evaluation of the operation of the Center at the end of each fiscal year. A written report of such evaluation shall be submitted to the President, the Clerk of the House of Representatives, and the Secretary of the Senate within one hundred and eighty days after the end of the fiscal year for which such evaluation was conducted. The first such report shall be submitted for fiscal year 1983.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd4a2-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/221/tII/s204"},"text":"Pub. L. 98–221, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/33"},"text":"98 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tIX/s903"},"text":"Pub. L. 102–569, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4482"},"text":"106 Stat. 4482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd4a3-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b5dd4a4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b5dd4a5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569"},"text":"Pub. L. 102–569","children":[],"tail":" substituted “within 15 days following the completion of the audit and acceptance of the audit by the Center” for “at such time as the Secretary shall prescribe”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5dd4a6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b5dd4a7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b)(2) of this section relating to submitting a written report to the Clerk of the House of Representatives and the Secretary of the Senate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 81 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
