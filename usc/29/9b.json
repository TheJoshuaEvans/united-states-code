{"tag":"section","attrib":{"id":"id5a08cb83-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s9b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9b"},"text":"§ 9b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall prescribe rules and regulations for the enforcement of sections 9 and 9a of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a08cb84-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-13/ch118/s3"},"text":"Apr. 13, 1934, ch. 118, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/583"},"text":"48 Stat. 583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-04-11/ch59"},"text":"Apr. 11, 1935, ch. 59","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/154"},"text":"49 Stat. 154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-15/ch349"},"text":"June 15, 1937, ch. 349","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/259"},"text":"50 Stat. 259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-04-15/ch71"},"text":"Apr. 15, 1939, ch. 71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/581"},"text":"53 Stat. 581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-07/ch770/s1/16"},"text":"Aug. 7, 1946, ch. 770, § 1(16)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/867"},"text":"60 Stat. 867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a08cb85-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a08cb86-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children