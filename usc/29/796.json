{"tag":"section","attrib":{"id":"id5a9f1895-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796"},"text":null,"children":[{"tag":"num","attrib":{"value":"796"},"text":"§ 796.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this part is to promote a philosophy of independent living, including a philosophy of consumer control, peer support, self-help, self-determination, equal access, and individual and system advocacy, in order to maximize the leadership, empowerment, independence, and productivity of individuals with disabilities, and the integration and full inclusion of individuals with disabilities into the mainstream of American society, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9f1896-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing financial assistance to States for providing, expanding, and improving the provision of independent living services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1897-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing financial assistance to develop and support statewide networks of centers for independent living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9f1898-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing financial assistance to States for improving working relationships among State independent living rehabilitation service programs, centers for independent living, Statewide Independent Living Councils established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d"},"text":"section 796d of this title","children":[],"tail":", State vocational rehabilitation programs receiving assistance under subchapter I, State programs of supported employment services receiving assistance under subchapter VI, client assistance programs receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s732"},"text":"section 732 of this title","children":[],"tail":", programs funded under other subchapters of this chapter, programs funded under other Federal law, and programs funded through non-Federal sources, with the goal of improving the independence of individuals with disabilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a9f1899-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s701"},"text":"Pub. L. 93–112, title VII, § 701","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1217"},"text":"112 Stat. 1217","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s471"},"text":"Pub. L. 113–128, title IV, § 471","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1685"},"text":"128 Stat. 1685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a9f189a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a9f189b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a9f189c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s701"},"text":"Pub. L. 93–112, title VII, § 701","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4443"},"text":"106 Stat. 4443","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/a"},"text":"Pub. L. 103–73, title I, § 114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/728"},"text":"107 Stat. 728","children":[],"tail":", related to purpose of program to provide assistance for independent living for individuals with severe disabilities, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 796, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s701"},"text":"Pub. L. 93–112, title VII, § 701","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tIII/s301"},"text":"Pub. L. 95–602, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2995"},"text":"92 Stat. 2995","children":[],"tail":", provided Congressional statement of purpose of former subchapter VII, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/s701/1"},"text":"Pub. L. 102–569, § 701(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a9f189d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “subchapter VI” for “part B of subchapter VI” and inserted before period at end “, with the goal of improving the independence of individuals with disabilities”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
