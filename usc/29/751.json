{"tag":"section","attrib":{"id":"id5a801ef5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751"},"text":null,"children":[{"tag":"num","attrib":{"value":"751"},"text":"§ 751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a801ef6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a801ef7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Education and the Secretary of Health and Human Services shall enter into a memorandum of understanding for the purposes of exchanging data of mutual importance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a801ef8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that concern clients of designated State agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a801ef9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that are data maintained either by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a801efa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rehabilitation Services Administration, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s710"},"text":"section 710 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a801efb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Social Security Administration, from its Summary Earnings and Records and Master Beneficiary Records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801efc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall provide the Commissioner with employment statistics specified in section 49","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–2 of this title, that facilitate evaluation by the Commissioner of the program carried out under part B, and allow the Commissioner to compare the progress of individuals with disabilities who are assisted under the program in securing, retaining, regaining, and advancing in employment with the progress made by individuals who are assisted under title I of the Workforce Innovation and Opportunity Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3111"},"text":"29 U.S.C. 3111","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a801efd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"