{"tag":"section","attrib":{"id":"id5b5dd52e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006"},"text":"§ 2006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5dd52f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No application to governmental employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall not apply with respect to the United States Government, any State or local government, or any political subdivision of a State or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd530-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National defense and security exemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd531-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National defense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to prohibit the administration, by the Federal Government, in the performance of any counterintelligence function, of any lie detector test to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd532-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expert or consultant under contract to the Department of Defense or any employee of any contractor of such Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd533-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expert or consultant under contract with the Department of Energy in connection with the atomic energy defense activities of such Department or any employee of any contractor of such Department in connection with such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd534-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to prohibit the administration, by the Federal Government, in the performance of any intelligence or counterintelligence function, of any lie detector test to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd535-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd536-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual employed by, assigned to, or detailed to, the National Security Agency, the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, or the Central Intelligence Agency,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd537-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expert or consultant under contract to any such agency,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd538-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of a contractor to any such agency,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd539-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual applying for a position in any such agency, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd53a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual assigned to a space where sensitive cryptologic information is produced, processed, or stored for any such agency; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd53b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any expert, or consultant (or employee of such expert or consultant) under contract with any Federal Government department, agency, or program whose duties involve access to information that has been classified at the level of top secret or designated as being within a special access program under section 4.2(a) of Executive Order 12356 (or a successor Executive order).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd53c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FBI contractors exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to prohibit the administration, by the Federal Government, in the performance of any counterintelligence function, of any lie detector test to an employee of a contractor of the Federal Bureau of Investigation of the Department of Justice who is engaged in the performance of any work under the contract with such Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd53d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited exemption for ongoing investigations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to sections 2007 and 2009 of this title, this chapter shall not prohibit an employer from requesting an employee to submit to a polygraph test if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd53e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the test is administered in connection with an ongoing investigation involving economic loss or injury to the employer’s business, such as theft, embezzlement, misappropriation, or an act of unlawful industrial espionage or sabotage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd53f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee had access to the property that is the subject of the investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd540-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer has a reasonable suspicion that the employee was involved in the incident or activity under investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd541-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the employer executes a statement, provided to the examinee before the test, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd542-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth with particularity the specific incident or activity being investigated and the basis for testing particular employees,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd543-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is signed by a person (other than a polygraph examiner) authorized to legally bind the employer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd544-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is retained by the employer for at least 3 years, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd545-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd546-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the specific economic loss or injury to the business of the employer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd547-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement indicating that the employee had access to the property that is the subject of the investigation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd548-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/d/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement describing the basis of the employer’s reasonable suspicion that the employee was involved in the incident or activity under investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd549-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for security services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd54a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2) and sections 2007 and 2009 of this title, this chapter shall not prohibit the use of polygraph tests on prospective employees by any private employer whose primary business purpose consists of providing armored car personnel, personnel engaged in the design, installation, and maintenance of security alarm systems, or other uniformed or plainclothes security personnel and whose function includes protection of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd54b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilities, materials, or operations having a significant impact on the health or safety of any State or political subdivision thereof, or the national security of the United States, as determined under rules and regulations issued by the Secretary within 90 days after ","children":[{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", including—"}],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd54c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities engaged in the production, transmission, or distribution of electric or nuclear power,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd54d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public water supply facilities,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd54e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipments or storage of radioactive or other toxic waste materials, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd54f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public transportation, or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd550-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" currency, negotiable securities, precious commodities or instruments, or proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd551-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exemption provided under this subsection shall not apply if the test is administered to a prospective employee who would not be employed to protect facilities, materials, operations, or assets referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd552-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for drug security, drug theft, or drug diversion investigations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd553-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2) and sections 2007 and 2009 of this title, this chapter shall not prohibit the use of a polygraph test by any employer authorized to manufacture, distribute, or dispense a controlled substance listed in schedule I, II, III, or IV of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"section 812 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd554-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemption provided under this subsection shall apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd555-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the test is administered to a prospective employee who would have direct access to the manufacture, storage, distribution, or sale of any such controlled substance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd556-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a test administered to a current employee, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd557-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the test is administered in connection with an ongoing investigation of criminal or other misconduct involving, or potentially involving, loss or injury to the manufacture, distribution, or dispensing of any such controlled substance by such employer, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd558-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2006/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee had access to the person or property that is the subject of the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd559-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s7"},"text":"Pub. L. 100–347, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/648"},"text":"102 Stat. 648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s501/n"},"text":"Pub. L. 103–359, title V, § 501(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3430"},"text":"108 Stat. 3430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1122/b/3"},"text":"Pub. L. 104–201, div. A, title XI, § 1122(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2687"},"text":"110 Stat. 2687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title IX, § 931(b)(3), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4575"},"text":"122 Stat. 4575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd55a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b5dd55b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b5dd55c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12356, referred to in subsec. (b)(2)(B), was Ex. Ord. No. 12356, ","children":[{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", 47 F.R. 14874, 15557, which was formerly set out as a note under section 435 (now section