{"tag":"section","attrib":{"id":"id5a172482-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s101"},"text":null,"children":[{"tag":"num","attrib":{"value":"101"},"text":"§ 101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of restraining orders and injunctions; limitation; public policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No court of the United States, as defined in this chapter, shall have jurisdiction to issue any restraining order or temporary or permanent injunction in a case involving or growing out of a labor dispute, except in a strict conformity with the provisions of this chapter; nor shall any such restraining order or temporary or permanent injunction be issued contrary to the public policy declared in this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a172483-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-03-23/ch90/s1"},"text":"Mar. 23, 1932, ch. 90, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/70"},"text":"47 Stat. 70","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a172484-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a172485-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id5a172486-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1932-03-23/ch90"},"text":"Act Mar. 23, 1932, ch. 90","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/70"},"text":"47 Stat. 70","children":[],"tail":", which enacted this chapter, is popularly known as the “Norris-LaGuardia Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
