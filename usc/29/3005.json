{"tag":"section","attrib":{"id":"id5b70e793-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005"},"text":null,"children":[{"tag":"num","attrib":{"value":"3005"},"text":"§ 3005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and data collection support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b70e794-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e795-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified data collection and reporting entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified data collection and reporting entity” means an entity with demonstrated expertise in data collection and reporting as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/f/2/B"},"text":"section 3003(f)(2)(B) of this title","children":[],"tail":", in order to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e796-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recipients of grants under this chapter with instruction and technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e797-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist such recipients with data collection and data requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e798-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified protection and advocacy system technical assistance provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified protection and advocacy system technical assistance provider” means an entity that has experience in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e799-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with protection and advocacy systems established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15043"},"text":"section 15043 of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e79a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to protection and advocacy agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e79b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified technical assistance provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified technical assistance provider” means an entity with demonstrated expertise in assistive technology and that has (directly or through grant or contract)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e79c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience and expertise in administering programs, including developing, implementing, and administering all of the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/e"},"text":"section 3003(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e79d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" documented experience in and knowledge about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b70e79e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistive technology device loan and demonstration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e79f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistive technology device reuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e7a0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial loans and microlending, including the activities of alternative financing programs for assistive technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e7a1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State leadership activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e7a2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and data collection support authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e7a3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for assistive technology educational activities and technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3008/b/1"},"text":"section 3008(b)(1) of this title","children":[],"tail":", the Secretary shall award, on a competitive basis, grants, contracts, or cooperative agreements—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7a4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to qualified technical assistance providers to support activities described in subsection (d)(1) for States receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7a5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to qualified protection and advocacy system technical assistance providers to support activities described in subsection (d)(1) for protection and advocacy systems receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3004"},"text":"section 3004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e7a6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for data collection and reporting assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3008/b/1"},"text":"section 3008(b)(1) of this title","children":[],"tail":", the Secretary shall award, on a competitive basis, grants, contracts, or cooperative agreements—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7a7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to qualified data collection and reporting entities, to enable the qualified data collection and reporting entities to carry out the activities described in subsection (d)(2) for States receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7a8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to qualified protection and advocacy system technical assistance providers, to enable the providers to carry out the activities described in subsection (d)(2) for protection and advocacy systems receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3004"},"text":"section 3004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e7a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e7aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant, contract, or cooperative agreement under this section, an entity shall submit an application to the Secretary at such time, in such manner, and containing the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7ab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the activities such entity will carry out with the grant, contract, or cooperative agreement under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7ac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the expertise such entity has to carry out such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7ad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an entity applying to receive a grant, contract, or cooperative agreement under subsection (b)(1), a description of such entity’s plan for complying with the requirements described in subsection (d)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7ae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of such entity’s plan to comply with all relevant State and Federal laws, regulations, and policies with respect to data privacy and security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7af-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e7b0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Input","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing grants, contracts, or cooperative agreements under this section, the Secretary shall consider the input of the recipients of grants under sections 3003 and 3004 of this title and other individuals the Secretary determines to be appropriate, especially—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7b1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with disabilities who use assistive technology and understand the barriers to the acquisition of such technology and assistive technology services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7b2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family members, guardians, advocates, and authorized representatives of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7b3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant employees from Federal departments and agencies, other than the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7b4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7b5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" venders and public and private researchers and developers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e7b6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e7b7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for assistive technology technical assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7b8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified technical assistance provider or qualified protection and advocacy system technical assistance provider receiving a grant, contract, or cooperative agreement under subsection (b)(1) shall support a technical assistance program for States or protection and advocacy systems receiving a grant under section 3003 or 3004 of this title, respectively, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b70e7b9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" addresses State-specific information requests concerning assistive technology from entities funded under this chapter and public entities not funded under this chapter, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b70e7ba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective approaches to Federal-State coordination of programs for individuals with disabilities related to improving funding for or access to assistive technology devices and assistive technology services for individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7bb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model State and local laws, regulations, policies, practices, procedures, and organizational structures, that facilitate, and overcome barriers to, funding for, and access to, assistive technology devices and assistive technology services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective approaches to developing, implementing, evaluating, and sustaining activities described in section 3003 or 3004 of this title, as the case may be, and related to improving acquisition and access to assistive technology devices and assistive technology services for individuals with disabilities, and requests for assistance in developing corrective action plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies, practices, procedures, regulations, or judicial decisions related to access to and acquisition of assistive technology devices and assistive technology services for individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7be-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective approaches to the development of consumer-controlled systems that increase access to, funding for, and awareness of, assistive technology devices and assistive technology services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7bf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other requests for information and technical assistance from entities funded under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e7c0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a program that will serve States receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id5b70e7c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assists targeted individuals and entities by disseminating information and responding to requests relating to assistive technology by providing referrals to recipients of grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":" or other public or private resources; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides State-specific, regional, and national technical assistance concerning assistive technology to entities funded under this chapter, and public and private entities not funded under this chapter, including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id5b70e7c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually providing a forum for exchanging information concerning, and promoting program and policy improvements in, required activities of the State assistive technology programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b70e7c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating onsite and electronic information sharing using state-of-the-art internet technologies such as real-time online discussions, multipoint video conferencing, and web-based audio or video broadcasts, on emerging topics that affect State assistive technology programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b70e7c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convening experts from State assistive technology programs to discuss and make recommendations with regard to national emerging issues of importance to individuals with assistive technology needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b70e7c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sharing best practice and evidence-based practices among State assistive technology programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b70e7c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or maintaining an accessible, national, and public website that includes information, tools, and resources on assistive technology devices and assistive technology services and links to State assistive technology programs, appropriate Federal departments and agencies, and private resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b70e7c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a resource that connects individuals from a State with the State assistive technology program in their State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b70e7c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"gg"},"text":"(gg)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing access to experts in the State-level activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/e/2"},"text":"section 3003(e)(2) of this title","children":[],"tail":" through site visits, teleconferences, and other means, to ensure access to information for entities that are carrying out new programs or programs that are not making progress in achieving the objectives of the programs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id5b70e7ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/A/ii/II/hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"hh"},"text":"(hh)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and coordinating activities designed to reduce the financial costs of purchasing assistive technology for the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/e"},"text":"section 3003(e) of this title","children":[],"tail":", and reducing duplication of activities among State assistive technology programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and providing technical assistance under this paragraph, a qualified technical assistance provider or qualified protection and advocacy system technical assistance provider receiving a grant, contract, or cooperative agreement under subsection (b)(1) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b70e7cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collaborate with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b70e7cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national organizations representing State assistive technology programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing State officials and agencies engaged in the delivery of assistive technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other qualified protection and advocacy system technical assistance providers and qualified technical assistance providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providers of State financing activities, including alternative financing programs for assistive technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providers of device loans, device demonstrations, and device reutilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b70e7d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other organizations determined appropriate by the provider or the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e7d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a qualified technical assistance provider, include activities identified as priorities by State advisory councils and lead agencies and implementing entities for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e7d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for assistive technology data collection and reporting assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified data collection and reporting entity or a qualified protection and advocacy system technical assistance provider receiving a grant, contract, or cooperative agreement under subsection (b)(2) shall assist States or protection and advocacy systems receiving a grant under section 3003 or 3004 of this title, respectively, to develop and implement effective and accessible data collection and reporting systems that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e7d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on quantitative and qualitative data elements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help measure the impact of the activities to individuals who need assistive technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of systems that will serve States receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id5b70e7d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measure the outcomes of all activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/e"},"text":"section 3003(e) of this title","children":[],"tail":" and the progress of the States toward achieving the measurable goals described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/d/3/C"},"text":"section 3003(d)(3)(C) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e7da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide States with the necessary information required under this chapter or by the Secretary for reports described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/f/2"},"text":"section 3003(f)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e7db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3005/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in full compliance with all relevant State and Federal laws, regulations, and policies with respect to data privacy and security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b70e7dc-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/394/s6"},"text":"Pub. L. 105–394, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/364/s2"},"text":"Pub. L. 108–364, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1727"},"text":"118 Stat. 1727","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII/s3002/c/7"},"text":"Pub. L. 110–69, title III, § 3002(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/587"},"text":"121 Stat. 587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s491"},"text":"Pub. L. 113–128, title IV, § 491","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1698"},"text":"128 Stat. 1698","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5402"},"text":"Pub. L. 117–263, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3281"},"text":"136 Stat. 3281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b70e7dd-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b70e7de-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b70e7df-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section related to awarding of grants, contracts, and cooperative agreements for various national activities designed to improve the administration of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":