{"tag":"section","attrib":{"id":"id5b69bb34-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2635"},"text":null,"children":[{"tag":"num","attrib":{"value":"2635"},"text":"§ 2635.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b69bb35-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2635/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall first meet not later than 30 days after the date on which all members are appointed, and the Commission shall meet thereafter on the call of the chairperson or a majority of the members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb36-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2635/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and sessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence as the Commission considers appropriate. The Commission may administer oaths or affirmations to witnesses appearing before it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb37-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2635/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may secure directly from any Federal agency information necessary to enable it to carry out this subchapter, if the information may be disclosed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":". Subject to the previous sentence, on the request of the chairperson or vice chairperson of the Commission, the head of such agency shall furnish such information to the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb38-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2635/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of facilities and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of the Commission, the head of any Federal agency may make available to the Commission any of the facilities and services of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb39-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2635/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel from other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of the Commission, the head of any Federal agency may detail any of the personnel of such agency to serve as an Executive Director of the Commission or assist the Commission in carrying out the duties of the Commission. Any detail shall not interrupt or otherwise affect the civil service status or privileges of the Federal employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bb3a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2635/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the chairperson of the Commission may accept for the Commission voluntary services provided by a member of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b69bb3b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tIII/s305"},"text":"Pub. L. 103–3, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/25"},"text":"107 Stat. 25","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
