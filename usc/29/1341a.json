{"tag":"section","attrib":{"id":"id5b3a1fdb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1341a"},"text":"§ 1341a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of multiemployer plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b3a1fdc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinative factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Termination of a multiemployer plan under this section occurs as a result of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3a1fdd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption after ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", of a plan amendment which provides that participants will receive no credit for any purpose under the plan for service with any employer after the date specified by such amendment;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3a1fde-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the withdrawal of every employer from the plan, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1383"},"text":"section 1383 of this title","children":[],"tail":", or the cessation of the obligation of all employers to contribute under the plan; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3a1fdf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of an amendment to the plan which causes the plan to become a plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1321/b/1"},"text":"section 1321(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3a1fe0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3a1fe1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The date on which a plan terminates under paragraph (1) or (3) of subsection (a) is the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3a1fe2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the amendment is adopted, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3a1fe3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the amendment takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3a1fe4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The date on which a plan terminates under paragraph (2) of subsection (a) is the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3a1fe5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the last employer withdraws, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3a1fe6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the first plan year for which no employer contributions were required under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3a1fe7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of plan sponsor of amended plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (f)(1), the plan sponsor of a plan which terminates under paragraph (2) of subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3a1fe8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the payment of benefits to benefits which are nonforfeitable under the plan as of the date of the termination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3a1fe9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay benefits attributable to employer contributions, other than death benefits, only in the form of an annuity, unless the plan assets are distributed in full satisfaction of all nonforfeitable benefits under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3a1fea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of plan sponsor of nonoperative plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan sponsor of a plan which terminates under paragraph (2) of subsection (a) shall reduce benefits and suspend benefit payments in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1441"},"text":"section 1441 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3a1feb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of contribution of employer under amended plan for each plan year subsequent to plan termination date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a plan which terminates under paragraph (1) or (3) of subsection (a), the rate of an employer’s contributions under the plan for each plan year beginning on or after the plan termination date shall equal or exceed the highest rate of employer contributions at which the employer had an obligation to contribute under the plan in the 5 preceding plan years ending on or before the plan termination date, unless the corporation approves a reduction in the rate based on a finding that the plan is or soon will be fully funded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3a1fec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of benefits; reporting requirements for terminated plans and rules and standards for administration of such plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3a1fed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan sponsor of a terminated plan may authorize the payment other than in the form of an annuity of a participant’s entire nonforfeitable benefit attributable to employer contributions, other than a death benefit, if the value of the entire nonforfeitable benefit does not exceed $1,750. The corporation may authorize the payment of benefits under the terms of a terminated plan other than nonforfeitable benefits, or the payment other than in the form of an annuity of benefits having a value greater than $1,750, if the corporation determines that such payment is not adverse to the interest of the plan’s participants and beneficiaries generally and does not unreasonably increase the corporation’s risk of loss with respect to the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3a1fee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1341a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation may prescribe reporting requirements for terminated plans, and rules and standards for the administration of such plans, which the corporation considers appropriate to protect the interests of plan participants and beneficiaries or to prevent unreasonable loss to the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b3a1fef-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4041A"},"text":"Pub. L. 93–406, title IV, § 4041A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s103"},"text":"Pub. L. 96–364, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1216"},"text":"94 Stat. 1216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b3a1ff0-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b3a1ff1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b3a1ff2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
