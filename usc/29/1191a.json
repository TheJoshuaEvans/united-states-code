{"tag":"section","attrib":{"id":"id5b222bce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1191a"},"text":"§ 1191a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules relating to group health plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b222bcf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General exception for certain small group health plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this part (other than sections 1185 and 1185","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title) shall not apply to any group health plan (and group health insurance coverage offered in connection with a group health plan) for any plan year if, on the first day of such plan year, such plan has less than 2 participants who are current employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bd0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this part shall not apply to any group health plan (and group health insurance coverage) in relation to its provision of excepted benefits described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/c/1"},"text":"section 1191b(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bd1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain benefits if certain conditions met","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222bd2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited, excepted benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this part shall not apply to any group health plan (and group health insurance coverage offered in connection with a group health plan) in relation to its provision of excepted benefits described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/c/2"},"text":"section 1191b(c)(2) of this title","children":[],"tail":" if the benefits—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222bd3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided under a separate policy, certificate, or contract of insurance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bd4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are otherwise not an integral part of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bd5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncoordinated, excepted benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of this part shall not apply to any group health plan (and group health insurance coverage offered in connection with a group health plan) in relation to its provision of excepted benefits described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/c/3"},"text":"section 1191b(c)(3) of this title","children":[],"tail":" if all of the following conditions are met:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222bd6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The benefits are provided under a separate policy, certificate, or contract of insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bd7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is no coordination between the provision of such benefits and any exclusion of benefits under any group health plan maintained by the same plan sponsor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bd8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such benefits are paid with respect to an event without regard to whether benefits are provided with respect to such an event under any group health plan maintained by the same plan sponsor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bd9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental excepted benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this part shall not apply to any group health plan (and group health insurance coverage) in relation to its provision of excepted benefits described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b/c/4"},"text":"section 1191b(c)(4) of this title","children":[],"tail":" if the benefits are provided under a separate policy, certificate, or contract of insurance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bda-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222bdb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as a group health plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any plan, fund, or program which would not be (but for this subsection) an employee welfare benefit plan and which is established or maintained by a partnership, to the extent that such plan, fund, or program provides medical care (including items and services paid for as medical care) to present or former partners in the partnership or to their dependents (as defined under the terms of the plan, fund, or program), directly or through insurance, reimbursement, or otherwise, shall be treated (subject to paragraph (2)) as an employee welfare benefit plan which is a group health plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bdc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a group health plan, the term “employer” also includes the partnership in relation to any partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bdd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants of group health plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a group health plan, the term “participant” also includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222bde-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with a group health plan maintained by a partnership, an individual who is a partner in relation to the partnership, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bdf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with a group health plan maintained by a self-employed individual (under which one or more employees are participants), the self-employed individual,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if such individual is, or may become, eligible to receive a benefit under the plan or such individual’s beneficiaries may be eligible to receive any such benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b222be0-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s732"},"text":"Pub. L. 93–406, title I, § 732","children":[],"tail":", formerly § 705, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s101/a"},"text":"Pub. L. 104–191, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1948"},"text":"110 Stat. 1948","children":[],"tail":"; renumbered § 732 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s603/a/3"},"text":"Pub. L. 104–204, title VI, § 603(a)(3)","children":[],"tail":", (b)(2), (3)(I)–(L), "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2935"},"text":"110 Stat. 2935","children":[],"tail":", 2937, 2938; "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dJ/tVII/s6701/b/1/C"},"text":"Pub. L. 119–75, div. J, title VII, § 6701(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/723"},"text":"140 Stat. 723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b222be1-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b222be2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b222be3-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2026—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75"},"text":"Pub. L. 119–75","children":[],"tail":" substituted “sections 1185 and 1185"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1185"},"text":"section 1185 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/s603/b/2"},"text":"Pub. L. 104–204, § 603(b)(2)","children":[],"tail":", inserted “(other than "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1185"},"text":"section 1185 of this title","children":[],"tail":")” after “part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/s603/b/3/I"},"text":"Pub. L. 104–204, § 603(b)(3)(I)","children":[],"tail":"–(L), made technical amendment to references in original act which appear in text as references to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b"},"text":"section 1191b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b222be4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b222be5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":" applicable with respect to group health plans for plan years beginning on and after "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"Jan. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/s603/c"},"text":"section 603(c) of Pub. L. 104–204","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003"},"text":"section 1003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b222be6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to group health plans for plan years beginning after ","children":[{"tag":"date","attrib":{"date":"1997-06-30"},"text":"June 30, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/s101/g"},"text":"section 101(g) of Pub. L. 104–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
