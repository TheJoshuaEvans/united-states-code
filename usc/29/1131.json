{"tag":"section","attrib":{"id":"id5b00e781-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1131"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131"},"text":"§ 1131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b00e782-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully violates any provision of part 1 of this subtitle, or any regulation or order issued under any such provision, shall upon conviction be fined not more than $100,000 or imprisoned not more than 10 years, or both; except that in the case of such violation by a person not an individual, the fine imposed upon such person shall be a fine not exceeding $500,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b00e783-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person that violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1149"},"text":"section 1149 of this title","children":[],"tail":" shall upon conviction be imprisoned not more than 10 years or fined under title 18, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b00e784-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s501"},"text":"Pub. L. 93–406, title I, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/891"},"text":"88 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIX/s904"},"text":"Pub. L. 107–204, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/805"},"text":"116 Stat. 805","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6601/b"},"text":"Pub. L. 111–148, title VI, § 6601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/779"},"text":"124 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b00e785-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b00e786-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b00e787-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":" substituted “$100,000” for “$5,000”, “10 years” for “one year”, and “$500,000” for “$100,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b00e788-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b00e789-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary authorized, effective ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", to promulgate regulations wherever provisions of this subchapter call for the promulgation of regulations, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
