{"tag":"section","attrib":{"id":"id5b222be7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1191b"},"text":"§ 1191b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b222be8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222be9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “group health plan” means an employee welfare benefit plan to the extent that the plan provides medical care (as defined in paragraph (2) and including items and services paid for as medical care) to employees or their dependents (as defined under the terms of the plan) directly or through insurance, reimbursement, or otherwise. Such term shall not include any qualified small employer health reimbursement arrangement (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9831/d/2"},"text":"section 9831(d)(2) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical care","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “medical care” means amounts paid for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222beb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the diagnosis, cure, mitigation, treatment, or prevention of disease, or amounts paid for the purpose of affecting any structure or function of the body,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts paid for transportation primarily for and essential to medical care referred to in subparagraph (A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts paid for insurance covering medical care referred to in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions relating to health insurance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222bef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health insurance coverage” means benefits consisting of medical care (provided directly, through insurance or reimbursement, or otherwise and including items and services paid for as medical care) under any hospital or medical service policy or certificate, hospital or medical service plan contract, or health maintenance organization contract offered by a health insurance issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bf0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health insurance issuer” means an insurance company, insurance service, or insurance organization (including a health maintenance organization, as defined in paragraph (3)) which is licensed to engage in the business of insurance in a State and which is subject to State law which regulates insurance (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1144/b/2"},"text":"section 1144(b)(2) of this title","children":[],"tail":"). Such term does not include a group health plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bf1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health maintenance organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “health maintenance organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222bf2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally qualified health maintenance organization (as defined in section 1301(a) of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300e/a"},"text":"42 U.S.C. 300e(a)","children":[],"tail":")),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bf3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization recognized under State law as a health maintenance organization, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bf4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a similar organization regulated under State law for solvency in the same manner and to the same extent as such a health maintenance organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222bf5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Group health insurance coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “group health insurance coverage” means, in connection with a group health plan, health insurance coverage offered in connection with such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222bf6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part, the term “excepted benefits” means benefits under one or more (or any combination thereof) of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222bf7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222bf8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage only for accident, or disability income insurance, or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bf9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage issued as a supplement to liability insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bfa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Liability insurance, including general liability insurance and automobile liability insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bfb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Workers’ compensation or similar insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bfc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Automobile medical payment insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bfd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credit-only insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bfe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage for on-site medical clinics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222bff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other similar insurance coverage, specified in regulations, under which benefits for medical care are secondary or incidental to other insurance benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c00-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements if offered separately","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c01-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Limited scope dental or vision benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c02-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits for long-term care, nursing home care, home health care, community-based care, or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c03-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other similar, limited benefits as are specified in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c04-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements if offered as independent, noncoordinated benefits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c05-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coverage only for a specified disease or illness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c06-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospital indemnity or other fixed indemnity insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c07-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits not subject to requirements if offered as separate insurance policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Medicare supplemental health insurance (as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ss/g/1"},"text":"section 1395ss(g)(1) of title 42","children":[],"tail":"), coverage supplemental to the coverage provided under chapter 55 of title 10, and similar supplemental coverage provided to coverage under a group health plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b222c08-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b222c09-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" COBRA continuation provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “COBRA continuation provision” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c0a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part 6 of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c0b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4980B"},"text":"Section 4980B of title 26","children":[],"tail":", other than subsection (f)(1) of such section insofar as it relates to pediatric vaccines."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c0c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title XXII of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300bb–1"},"text":"42 U.S.C. 300bb–1","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health status-related factor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health status-related factor” means any of the factors described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1182/a/1"},"text":"section 1182(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “network plan” means health insurance coverage offered by a health insurance issuer under which the financing and delivery of medical care (including items and services paid for as medical care) are provided, in whole or in part, through a defined set of providers under contract with the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c0f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placed for adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “placement”, or being “placed”, for adoption, has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1169/c/3/B"},"text":"section 1169(c)(3)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family member","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family member” means, with respect to an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dependent (as such term is used for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181/f/2"},"text":"section 1181(f)(2) of this title","children":[],"tail":") of such individual, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other individual who is a first-degree, second-degree, third-degree, or fourth-degree relative of such individual or of an individual described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “genetic information” means, with respect to any individual, information about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b222c15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individual’s genetic tests,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the genetic tests of family members of such individual, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manifestation of a disease or disorder in family members of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of genetic services and participation in genetic research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term includes, with respect to any individual, any request for, or receipt of, genetic services, or participation in clinical research which includes genetic services, by such individual or any family member of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c19-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “genetic information” shall not include information about the sex or age of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c1a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic test","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c1b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “genetic test” means an analysis of human DNA, RNA, chromosomes, proteins, or metabolites, that detects genotypes, mutations, or chromosomal changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c1c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “genetic test” does not mean—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b222c1d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of proteins or metabolites that does not detect genotypes, mutations, or chromosomal changes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b222c1e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of proteins or metabolites that is directly related to a manifested disease, disorder, or pathological condition that could reasonably be detected by a health care professional with appropriate training and expertise in the field of medicine involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c1f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “genetic services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c20-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a genetic test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c21-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genetic counseling (including obtaining, interpreting, or assessing genetic information); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c22-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" genetic education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b222c23-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underwriting purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “underwriting purposes” means, with respect to any group health plan, or health insurance coverage offered in connection with a group health plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b222c24-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for, or determination of, eligibility (including enrollment and continued eligibility) for benefits under the plan or coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c25-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the computation of premium or contribution amounts under the plan or coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c26-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of any pre-existing condition exclusion under the plan or coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b222c27-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1191b/d/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities related to the creation, renewal, or replacement of a contract of health insurance or health benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b222c28-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s733"},"text":"Pub. L. 93–406, title I, § 733","children":[],"tail":", formerly § 706, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s101/a"},"text":"Pub. L. 104–191, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1949"},"text":"110 Stat. 1949","children":[],"tail":"; renumbered § 733, "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s603/a/3"},"text":"Pub. L. 104–204, title VI, § 603(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2935"},"text":"110 Stat. 2935","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/233/tI/s101/d"},"text":"Pub. L. 110–233, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/885"},"text":"122 Stat. 885","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dC/tXVIII/s18001/b/1"},"text":"Pub. L. 114–255, div. C, title XVIII, § 18001(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1343"},"text":"130 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b222c29-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b222c2a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b222c2b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},