rovided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/s101/g"},"text":"section 101(g) of Pub. L. 104–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
