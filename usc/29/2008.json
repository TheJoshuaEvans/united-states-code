{"tag":"section","attrib":{"id":"id5b604593-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008"},"text":"§ 2008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b604594-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person, other than the examinee, may not disclose information obtained during a polygraph test, except as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b604595-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted disclosures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A polygraph examiner may disclose information acquired from a polygraph test only to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b604596-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examinee or any other person specifically designated in writing by the examinee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b604597-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer that requested the test; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b604598-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any court, governmental agency, arbitrator, or mediator, in accordance with due process of law, pursuant to an order from a court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b604599-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employer (other than an employer described in subsection (a), (b), or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2006"},"text":"section 2006 of this title","children":[],"tail":") for whom a polygraph test is conducted may disclose information from the test only to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b60459a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person in accordance with subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b60459b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2008/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental agency, but only insofar as the disclosed information is an admission of criminal conduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b60459c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s9"},"text":"Pub. L. 100–347, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/652"},"text":"102 Stat. 652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b60459d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b60459e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b60459f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", except that rules and regulations shall be issued not later than 90 days after "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/347/s11"},"text":"section 11 of Pub. L. 100–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
