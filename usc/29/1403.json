{"tag":"section","attrib":{"id":"id5b4ac208-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403"},"text":"§ 1403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal liability payment fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b4ac209-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of or participation in fund by plan sponsors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan sponsors of multiemployer plans may establish or participate in a withdrawal liability payment fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac20a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “withdrawal liability payment fund”, and the term “fund”, mean a trust which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4ac20b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established and maintained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/22"},"text":"section 501(c)(22) of title 26","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac20c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains agreements which cover a substantial portion of the participants who are in multiemployer plans which (under the rules of the trust instrument) are eligible to participate in the fund,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac20d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is funded by amounts paid by the plans which participate in the fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac20e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is administered by a Board of Trustees, and in the administration of the fund there is equal representation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4ac20f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trustees representing employers who are obligated to contribute to the plans participating in the fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4ac210-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trustees representing employees who are participants in plans which participate in the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac211-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to plan; amount, criteria, etc.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4ac212-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an employer withdraws from a plan which participates in a withdrawal liability payment fund, then, to the extent provided in the trust, the fund shall pay to that plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4ac213-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer’s unattributable liability,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4ac214-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer’s withdrawal liability payments which would have been due but for section 1388, 1389, 1399, or 1405 of this title,","children":[{"tag":"ref","attrib":{"idref":"fn002182"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002182"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4ac215-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer’s withdrawal liability payments to the extent they are uncollectible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac216-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The fund may provide for the payment of the employer’s attributable liability if the fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4ac217-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the payment of both the attributable and the unattributable liability of the employer in a single payment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4ac218-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subrogated to all rights of the plan against the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac219-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4ac21a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “attributable liability” means the excess, if any, determined under the provisions of a plan not inconsistent with regulations of the corporation, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b4ac21b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of vested benefits accrued as a result of service with the employer, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b4ac21c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of plan assets attributed to the employer, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4ac21d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “unattributable liability” means the excess of withdrawal liability over attributable liability.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such terms may be further defined, and the manner in which they shall be applied may be prescribed, by the corporation by regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac21e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4ac21f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The trust of a fund shall be maintained for the exclusive purpose of paying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b4ac220-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount described in paragraph (1) and paragraph (2), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b4ac221-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable and necessary administrative expenses in connection with the establishment and operation of the trust and the processing of claims against the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4ac222-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amounts paid by a plan to a fund shall be deemed a reasonable expense of administering the plan under sections 1103(c)(1) and 1104(a)(1)(A)(ii) of this title, and the payments made by a fund to a participating plan shall be deemed services necessary for the operation of the plan within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1108/b/2"},"text":"section 1108(b)(2) of this title","children":[],"tail":" or within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4975/d/2"},"text":"section 4975(d)(2) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac223-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of payments by plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4ac224-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4ac225-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only amounts paid by the fund to a plan under subsection (c)(1)(A) shall be credited to withdrawal liability otherwise payable by the employer, unless the plan otherwise provides, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4ac226-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts paid by the fund under subsection (c) to a plan shall be treated by the plan as a payment of withdrawal liability to such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac227-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of applying provisions relating to the funding standard accounts (and minimum contribution requirements), amounts paid from the plan to the fund shall be applied to reduce the amount treated as contributed to the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac228-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation of fund to rights of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fund shall be subrogated to the rights of the plan against the employer that has withdrawn from the plan for amounts paid by a fund to a plan under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4ac229-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c)(1)(A), to the extent not credited under subsection (d)(1)(A), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac22a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c)(1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac22b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of rights of fiduciary of fund; standards applicable, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, a fiduciary of the fund shall discharge the fiduciary’s duties with respect to the fund in accordance with the standards for fiduciaries prescribed by this chapter (to the extent not inconsistent with the purposes of this section), and in accordance with the documents and instruments governing the fund insofar as such documents and instruments are consistent with the provisions of this chapter (to the extent not inconsistent with the purposes of this section). The provisions of the preceding sentence shall supersede any and all State laws relating to fiduciaries insofar as they may now or hereafter relate to a fund to which this section applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac22c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on payments from fund to plan where certain labor negotiations involve employer withdrawn or partially withdrawn from plan and continuity of labor organization representing employees continues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payments shall be made from a fund to a plan on the occasion of a withdrawal or partial withdrawal of an employer from such plan if the employees representing the withdrawn contribution base units continue, after such withdrawal, to be represented under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s159"},"text":"section 159 of this title","children":[],"tail":" (or other applicable labor laws) in negotiations with such employer by the labor organization which represented such employees immediately preceding such withdrawal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac22d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of insurance by employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit the purchase of insurance by an employer from any other person, to limit the circumstances under which such insurance would be payable, or to limit in any way the terms and conditions of such insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac22e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1403/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations for establishment and maintenance of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation may provide by regulation rules not inconsistent with this section governing the establishment and maintenance of funds, but only to the extent necessary to carry out the purposes of this part (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1402"},"text":"section 1402 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4ac22f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4223"},"text":"Pub. L. 93–406, title IV, § 4223","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1241"},"text":"94 Stat. 1241","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7891/a"},"text":"Pub. L. 101–239, title VII, § 7891(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2445"},"text":"103 Stat. 2445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b4ac230-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b4ac231-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b4ac232-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", known as the Employee Retirement Income Security Act of 1974. Titles I, III, and IV of such Act are classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b4ac233-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsecs. (b)(1), (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b4ac234-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b4ac235-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/f"},"text":"section 7891(f) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
