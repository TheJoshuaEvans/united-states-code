{"tag":"section","attrib":{"id":"id5b5dd515-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2004"},"text":null,"children":[{"tag":"num","attrib":{"value":"2004"},"text":"§ 2004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5dd516-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd517-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue such rules and regulations as may be necessary or appropriate to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd518-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with regional, State, local, and other agencies, and cooperate with and furnish technical assistance to employers, labor organizations, and employment agencies to aid in effectuating the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd519-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2004/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make investigations and inspections and require the keeping of records necessary or appropriate for the administration of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd51a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of any hearing or investigation under this chapter, the Secretary shall have the authority contained in sections 49 and 50 of title 15.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd51b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s5"},"text":"Pub. L. 100–347, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/647"},"text":"102 Stat. 647","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd51c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5dd51d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b5dd51e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", except that rules and regulations shall be issued not later than 90 days after "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/347/s11"},"text":"section 11 of Pub. L. 100–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
