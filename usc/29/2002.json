{"tag":"section","attrib":{"id":"id5b5dd502-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions on lie detector use","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as provided in sections 2006 and 2007 of this title, it shall be unlawful for any employer engaged in or affecting commerce or in the production of goods for commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd503-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or indirectly, to require, request, suggest, or cause any employee or prospective employee to take or submit to any lie detector test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd504-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use, accept, refer to, or inquire concerning the results of any lie detector test of any employee or prospective employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd505-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to discharge, discipline, discriminate against in any manner, or deny employment or promotion to, or threaten to take any such action against—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd506-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee or prospective employee who refuses, declines, or fails to take or submit to any lie detector test, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd507-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee or prospective employee on the basis of the results of any lie detector test; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd508-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to discharge, discipline, discriminate against in any manner, or deny employment or promotion to, or threaten to take any such action against, any employee or prospective employee because—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd509-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such employee or prospective employee has filed any complaint or instituted or caused to be instituted any proceeding under or related to this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd50a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such employee or prospective employee has testified or is about to testify in any such proceeding, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd50b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2002/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the exercise by such employee or prospective employee, on behalf of such employee or another person, of any right afforded by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd50c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s3"},"text":"Pub. L. 100–347, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/646"},"text":"102 Stat. 646","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd50d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5dd50e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b5dd50f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", except that rules and regulations shall be issued not later than 90 days after "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/347/s11"},"text":"section 11 of Pub. L. 100–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
