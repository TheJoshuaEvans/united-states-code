{"tag":"section","attrib":{"id":"id5b4607c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389"},"text":null,"children":[{"tag":"num","attrib":{"value":"1389"},"text":"§ 1389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De minimis rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b4607c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of unfunded vested benefits allocable to employer withdrawn from plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in the case of a plan amended under subsection (b), the amount of the unfunded vested benefits allocable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1391"},"text":"section 1391 of this title","children":[],"tail":" to an employer who withdraws from a plan shall be reduced by the smaller of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4607c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ¾ of 1 percent of the plan’s unfunded vested obligations (determined as of the end of the plan year ending before the date of withdrawal), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"reduced by the amount, if any, by which the unfunded vested benefits allowable to the employer, determined without regard to this subsection, exceeds $100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4607c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of plan for reduction of amount of unfunded vested benefits allocable to employer withdrawn from plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan may be amended to provide for the reduction of the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1391"},"text":"section 1391 of this title","children":[],"tail":" by not more than the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4607c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (a), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4607c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (a)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4607c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"reduced by the amount, if any, by which the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1391"},"text":"section 1391 of this title","children":[],"tail":" for the employer, determined without regard to this subsection, exceeds $150,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4607ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4607cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an employer who withdraws in a plan year in which substantially all employers withdraw from the plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4607cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which substantially all employers withdraw from the plan during a period of one or more plan years pursuant to an agreement or arrangement to withdraw, to an employer who withdraws pursuant to such agreement or arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4607cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1389/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption of employer withdrawal from plan pursuant to agreement or arrangement applicable in action or proceeding to determine or collect withdrawal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action or proceeding to determine or collect withdrawal liability, if substantially all employers have withdrawn from a plan within a period of 3 plan years, an employer who has withdrawn from such plan during such period shall be presumed to have withdrawn from the plan pursuant to an agreement or arrangement, unless the employer proves otherwise by a preponderance of the evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4607ce-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4209"},"text":"Pub. L. 93–406, title IV, § 4209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1225"},"text":"94 Stat. 1225","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
