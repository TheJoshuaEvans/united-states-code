{"tag":"section","attrib":{"id":"id5b249cad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1193b"},"text":"§ 1193b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and disclosure requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b249cae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such regulations as may be necessary to address reporting and disclosure requirements for pension-linked emergency savings accounts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249caf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to prevent unnecessary reporting and disclosure for such accounts under this chapter, including for purposes of any reporting or disclosure related to pension plans required by this subchapter or under the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b249cb0-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s803"},"text":"Pub. L. 93–406, title I, § 803","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s127/b/1"},"text":"Pub. L. 117–328, div. T, title I, § 127(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5323"},"text":"136 Stat. 5323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b249cb1-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b249cb2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b249cb3-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in par. (2), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b249cb4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b249cb5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"Dec. 31, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s127/g"},"text":"section 127(g) of Pub. L. 117–328","children":[],"tail":", set out as an Effective Date of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
