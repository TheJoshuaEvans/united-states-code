{"tag":"section","attrib":{"id":"id5b93b212-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191"},"text":null,"children":[{"tag":"num","attrib":{"value":"3191"},"text":"§ 3191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b93b213-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to maintain a national Job Corps program, carried out in partnership with States and communities, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b93b214-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist eligible youth to connect to the labor force by providing them with intensive social, academic, career and technical education, and service-learning opportunities, in primarily residential centers, in order for such youth to obtain secondary school diplomas or recognized postsecondary credentials leading to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b93b215-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful careers, in in-demand industry sectors or occupations or the Armed Forces, that will result in economic self-sufficiency and opportunities for advancement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b93b216-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollment in postsecondary education, including an apprenticeship program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b93d927-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support responsible citizenship;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b93d928-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to set forth standards and procedures for selecting individuals as enrollees in the Job Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b93d929-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the establishment of Job Corps centers in which enrollees will participate in intensive programs of activities described in this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b93d92a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3191/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prescribe various other powers, duties, and responsibilities incident to the operation and continuing development of the Job Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b93d92b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s141"},"text":"Pub. L. 113–128, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1537"},"text":"128 Stat. 1537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b93d92c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b93d92d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b93d92e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
