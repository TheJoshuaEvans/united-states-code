{"tag":"section","attrib":{"id":"id5b9845f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b9845f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business and community participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The director of each Job Corps center shall ensure the establishment and development of the mutually beneficial business and community relationships and networks described in subsection (b), including the use of local boards, in order to enhance the effectiveness of such centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9845f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Networks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities carried out by each Job Corps center under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9845f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing and developing relationships and networks with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9845f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local and distant employers, to the extent practicable, in coordination with entities carrying out other Federal and non-Federal programs that conduct similar outreach to employers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9845f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" applicable one-stop centers and applicable local boards, for the purpose of providing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b9845f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information to, and referral of, potential enrollees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9845f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job opportunities for Job Corps graduates; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9845f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b9845f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities carrying out relevant apprenticeship programs and youth programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b986d0a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor-management organizations and local labor organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b986d0b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employers and contractors that support national training contractor programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b986d0c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based organizations, non-profit organizations, and intermediaries providing workforce development-related services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b986d0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and developing relationships with members of the community in which the Job Corps center is located, informing members of the community about the projects of the Job Corps center and changes in the rules, procedures, or activities of the center that may affect the community, and planning events of mutual interest to the community and the Job Corps center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b986d0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The director of a Job Corps center that is not yet operating shall ensure the establishment and development of the relationships and networks described in subsection (b) at least 3 months prior to the date on which the center accepts the first enrollee at the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b986d0f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s153"},"text":"Pub. L. 113–128, title I, § 153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1550"},"text":"128 Stat. 1550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b986d10-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b986d11-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b986d12-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
