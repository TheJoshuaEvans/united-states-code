{"tag":"section","attrib":{"id":"id5a17245b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s50b"},"text":null,"children":[{"tag":"num","attrib":{"value":"50b"},"text":"§ 50b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor is authorized to appoint such employees as he may from time to time find necessary for the administration of this chapter, with regard to existing laws applicable to the appointment and compensation of employees of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a17245c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-08-16/ch663/s3"},"text":"Aug. 16, 1937, ch. 663, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/665"},"text":"50 Stat. 665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1943-07-12/ch221"},"text":"July 12, 1943, ch. 221","children":[],"tail":", title VII, "},{"tag":"ref","attrib":{"href":"/us/stat/57/518"},"text":"57 Stat. 518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a17245d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a17245e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a17245f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proviso authorizing employment of certain persons in the division of apprentice training of National Youth Administration, was omitted in view of abolition of that agency by act ","children":[{"tag":"date","attrib":{"date":"1943-07-12"},"text":"July 12, 1943","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision formerly in this section relieved National Youth Administration, after ","children":[{"tag":"date","attrib":{"date":"1937-08-16"},"text":"August 16, 1937","children":[],"tail":", of responsibility for promotion of labor standards of apprenticeship, and directed transfer of records and papers to Department of Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
