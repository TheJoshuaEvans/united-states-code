{"tag":"section","attrib":{"id":"id5a90c07a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783"},"text":null,"children":[{"tag":"num","attrib":{"value":"783"},"text":"§ 783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff of National Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a90c07b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director; technical and professional employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a90c07c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairperson of the National Council may appoint and remove, without regard to the provisions of title 5 governing appointments, the provisions of chapter 75 of such title (relating to adverse actions), the provisions of chapter 77 of such title (relating to appeals), or the provisions of chapter 51 and subchapter III of chapter 53 of such title (relating to classification and General Schedule pay rates), an Executive Director to assist the National Council to carry out its duties. The Executive Director shall be appointed from among individuals who are experienced in the planning or operation of programs for individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c07d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director is authorized to hire technical and professional employees to assist the National Council to carry out its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a90c07e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary or intermittent services; voluntary and uncompensated services; gifts, etc.; contracts and agreements; official representation and reception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a90c07f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Council may procure temporary and intermittent services to the same extent as is authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":" (but at rates for individuals not to exceed the daily equivalent of the rate of pay for level 4 of the Senior Executive Service Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c080-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Council may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a90c081-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept voluntary and uncompensated services, notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a90c082-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the name of the Council, solicit, accept, employ, and dispose of, in furtherance of this chapter, any money or property, real or personal, or mixed, tangible or nontangible, received by gift, devise, bequest, or otherwise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a90c083-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts and cooperative agreements with Federal and State agencies, private firms, institutions, and individuals for the conduct of research and surveys, preparation of reports and other activities necessary to the discharge of the Council’s duties and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c084-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 10 per centum of the total amounts available to the National Council in each fiscal year may be used for official representation and reception.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a90c085-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall provide to the National Council on a reimbursable basis such administrative support services as the Council may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a90c086-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of amounts not required for current withdrawals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a90c087-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be the duty of the Secretary of the Treasury to invest such portion of the amounts made available under subsection (a)(2)(B) ","children":[{"tag":"ref","attrib":{"idref":"fn002054"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be subsection “(b)(2)(B)”."}],"tail":" as is not, in the Secretary’s judgment, required to meet current withdrawals. Such investments may be made only in interest-bearing obligations of the United States or in obligations guaranteed as to both principal and interest by the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c088-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s783/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amounts described in paragraph (1), and the interest on, and the proceeds from the sale or redemption of, the obligations described in paragraph (1) shall be available to the National Council to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a90c089-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s403"},"text":"Pub. L. 93–112, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s407"},"text":"Pub. L. 105–220, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1200"},"text":"112 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a90c08a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a90c08b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a90c08c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 783, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s403"},"text":"Pub. L. 93–112, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s117"},"text":"Pub. L. 95–602, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2978"},"text":"92 Stat. 2978","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/221/tI/s143"},"text":"Pub. L. 98–221, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"h