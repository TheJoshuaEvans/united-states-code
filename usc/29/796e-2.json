{"tag":"section","attrib":{"id":"id5aa16359-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"796e–2"},"text":"§ 796e–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aa1635a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State may use funds received under this subpart to provide the resources described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d/e"},"text":"section 796d(e) of this title","children":[],"tail":" (but may not use more than 30 percent of the funds paid to the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796e–1"},"text":"section 796e–1 of this title","children":[],"tail":" for such resources unless the State specifies that a greater percentage of the funds is needed for such resources in a State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d–1"},"text":"section 796d–1 of this title","children":[],"tail":"), relating to the Statewide Independent Living Council, may retain funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796c/c/5"},"text":"section 796c(c)(5) of this title","children":[],"tail":", and shall distribute the remainder of the funds received under this subpart in a manner consistent with the approved State plan for the activities described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa1635b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State may use the remainder of the funds described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa1635c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide independent living services to individuals with significant disabilities, particularly those in unserved areas of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa1635d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate ways to expand and improve independent living services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa1635e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the operation of centers for independent living that are in compliance with the standards and assurances set forth in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796f–4"},"text":"section 796f–4 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa1635f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support activities to increase the capacities of public or nonprofit agencies and organizations and other entities to develop comprehensive approaches or systems for providing independent living services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa3d360-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct studies and analyses, gather information, develop model policies and procedures, and present information, approaches, strategies, findings, conclusions, and recommendations to Federal, State, and local policymakers in order to enhance independent living services for individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa3d361-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train individuals with disabilities and individuals providing services to individuals with disabilities and other persons regarding the independent living philosophy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa3d362-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e–2/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide outreach to populations that are unserved or underserved by programs under this subchapter, including minority groups and urban and rural populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa3d363-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s713"},"text":"Pub. L. 93–112, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1226"},"text":"112 Stat. 1226","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s476/d"},"text":"Pub. L. 113–128, title IV, § 476(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1691"},"text":"128 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa3d364-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa3d365-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa3d366-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796e–2, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s713"},"text":"Pub. L. 93–112, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4451"},"text":"106 Stat. 4451","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/g"},"text":"Pub. L. 103–73, title I, § 114(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/730"},"text":"107 Stat. 730","children":[],"tail":", related to authorized uses of funds, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa3d367-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" added subsec. (a), redesignated existing provisions as subsec. (b), in introductory provisions, substituted “The State may use the remainder of the funds described in subsection (a)—” for “The State may use funds received under this subpart to provide the resources described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d/e"},"text":"section 796d(e) of this title","children":[],"tail":", relating to the Statewide Independent Living Council, and may use funds received under this subpart—” and, in par. (1), inserted “, particularly those in unserved areas of the State” after “disabilities”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
