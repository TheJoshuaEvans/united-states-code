{"tag":"section","attrib":{"id":"id5a5c4310-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s654"},"text":null,"children":[{"tag":"num","attrib":{"value":"654"},"text":"§ 654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of employers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a5c4311-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each employer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a5c4312-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s654/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall furnish to each of his employees employment and a place of employment which are free from recognized hazards that are causing or are likely to cause death or serious physical harm to his employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a5c4313-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s654/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall comply with occupational safety and health standards promulgated under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a5c4314-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each employee shall comply with occupational safety and health standards and all rules, regulations, and orders issued pursuant to this chapter which are applicable to his own actions and conduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a5c4315-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596/s5"},"text":"Pub. L. 91–596, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1593"},"text":"84 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
