{"tag":"section","attrib":{"id":"id5b4395fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1371"},"text":null,"children":[{"tag":"num","attrib":{"value":"1371"},"text":"§ 1371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to timely provide required information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation may assess a penalty, payable to the corporation, against any person who fails to provide any notice or other material information required under this subtitle, subtitle A, B, or C, or section 1083(k)(4) or 1085a(g)(4) of this title,,","children":[{"tag":"ref","attrib":{"idref":"fn002177"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002177"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" or any regulations prescribed under any such subtitle or such section, within the applicable time limit specified therein. Such penalty shall not exceed $1,000 for each day for which such failure continues."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b4395fd-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4071"},"text":"Pub. L. 93–406, title IV, § 4071","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9314/c/1"},"text":"Pub. L. 100–203, title IX, § 9314(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-367"},"text":"101 Stat. 1330–367","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7881/g/8"},"text":"Pub. L. 101–239, title VII, § 7881(g)(8)","children":[],"tail":", (i)(3)(B), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tai