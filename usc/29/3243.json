{"tag":"section","attrib":{"id":"id5ba2f45f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3243"},"text":null,"children":[{"tag":"num","attrib":{"value":"3243"},"text":"§ 3243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ba2f460-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to monitor all recipients of financial assistance under this subchapter to determine whether the recipients are complying with the provisions of this subchapter, including the regulations issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f461-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may investigate any matter the Secretary determines to be necessary to determine the compliance of the recipients with this subchapter, including the regulations issued under this subchapter. The investigations authorized by this subsection may include examining records (including making certified copies of the records), questioning employees, and entering any premises or onto any site in which any part of a program or activity of such a recipient is conducted or in which any of the records of the recipient are kept.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f462-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of any investigation or hearing conducted under this subchapter by the Secretary, the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s49"},"text":"section 49 of title 15","children":[],"tail":" (relating to the attendance of witnesses and the production of documents) apply to the Secretary, in the same manner and to the same extent as the provisions apply to the Federal Trade Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ba2f463-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s183"},"text":"Pub. L. 113–128, title I, § 183","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1590"},"text":"128 Stat. 1590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ba2f464-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ba2f465-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5ba2f466-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
