{"tag":"section","attrib":{"id":"id5aa64515-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"796f–5"},"text":"§ 796f–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Eligible agency” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this subpart, the term “eligible agency” means a consumer-controlled, community-based, cross-disability, nonresidential private nonprofit agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5aa64516-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s726"},"text":"Pub. L. 93–112, title VII, § 726","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1237"},"text":"112 Stat. 1237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa64517-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa64518-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa64519-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796f–5, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s726"},"text":"Pub. L. 93–112, title VII, § 726","children":[],"tail":", as added "},{"tag":"ref","