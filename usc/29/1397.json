{"tag":"section","attrib":{"id":"id5b485176-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1397"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397"},"text":"§ 1397.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of part in case of certain pre-1980 withdrawals; adjustment of covered plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b485177-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1397/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of determining the amount of unfunded vested benefits allocable to an employer for a partial or complete withdrawal from a plan which occurs after ","children":[{"tag":"date","attrib":{"date":"1980-09-25"},"text":"September 25, 1980","children":[],"tail":", and for the purpose of determining whether there has been a partial withdrawal after such date, the amount of contributions, and the number of contribution base units, of such employer properly allocable—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b485178-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1397/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work performed under a collective bargaining agreement for which there was a permanent cessation of the obligation to contribute before ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b485179-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1397/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work performed at a facility at which all covered operations permanently ceased before ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":", or for which there was a permanent cessation of the obligation to contribute before that date,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be taken into account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b48517a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1397/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan may, in a manner not inconsistent with regulations, which shall be prescribed by the corporation, adjust the amount of unfunded vested benefits allocable to other employers under a plan maintained by an employer described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b48517b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4217"},"text":"Pub. L. 93–406, title IV, § 4217","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1235"},"text":"94 Stat. 1235","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tV/s558/b/1/A"},"text":"Pub. L. 98–369, div. A, title V, § 558(b)(1)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/899"},"text":"98 Stat. 899","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b48517c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b48517d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b48517e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s558/b/1/A"},"text":"Pub. L. 98–369, § 558(b)(1)(A)","children":[],"tail":", (B), substituted “"},{"tag":"date","attrib":{"date":"1980-09-25"},"text":"September 25, 1980","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1980-04-28"},"text":"April 28, 1980","children":[],"tail":"” in provisions preceding par. (1) and “"},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"September 26, 1980","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1980-04-29"},"text":"April 29, 1980","children":[],"tail":"” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
