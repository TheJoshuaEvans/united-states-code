{"tag":"section","attrib":{"id":"id5aa16337-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e"},"text":null,"children":[{"tag":"num","attrib":{"value":"796e"},"text":"§ 796e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aa16338-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa16339-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa1633a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the reservation required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796e–0"},"text":"section 796e–0 of this title","children":[],"tail":" is made, and except as provided in subparagraphs (B) and (C), from the remainder of the sums appropriated for each fiscal year to carry out this subpart, the Administrator shall make an allotment to each State whose State plan has been approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796d–1"},"text":"section 796d–1 of this title","children":[],"tail":" of an amount bearing the same ratio to such sums as the population of the State bears to the population of all States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa1633b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of 1992 amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations to carry out this subpart, the amount of any allotment made under subparagraph (A) to a State for a fiscal year shall not be less than the amount of an allotment made to the State for fiscal year 1992 under part A of this subchapter, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa1633c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimums","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations to carry out this subpart, and except as provided in subparagraph (B), the allotment to any State under subparagraph (A) shall be not less than $275,000 or ⅓ of 1 percent of the sums made available for the fiscal year for which the allotment is made, whichever is greater, and the allotment of any State under this section for any fiscal year that is less than $275,000 or ⅓ of 1 percent of such sums shall be increased to the greater of the two amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa1633d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain territories","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa1633e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of paragraph (1)(C), Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands shall not be considered to be States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa1633f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each jurisdiction described in subparagraph (A) shall be allotted under paragraph (1)(A) not less than ⅛ of 1 percent of the remainder described in paragraph (1)(A) for the fiscal year for which the allotment is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa16340-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for inflation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year, beginning in fiscal year 1999, in which the total amount appropriated to carry out this subpart exceeds the total amount appropriated to carry out this subpart for the preceding fiscal year, the Administrator shall increase the minimum allotment under paragraph (1)(C) by a percentage that shall not exceed the percentage increase in the total amount appropriated to carry out this subpart between the preceding fiscal year and the fiscal year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16341-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proportional reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To provide allotments to States in accordance with subsection (a)(1)(B), to provide minimum allotments to States (as increased under subsection (a)(3)) under subsection (a)(1)(C), or to provide minimum allotments to States under subsection (a)(2)(B), the Administrator shall proportionately reduce the allotments of the remaining States under subsection (a)(1)(A), with such adjustments as may be necessary to prevent the allotment of any such remaining State from being reduced to less than the amount required by subsection (a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16342-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Administrator determines that any amount of an allotment to a State for any fiscal year will not be expended by such State in carrying out the provisions of this subpart, the Administrator shall make such amount available for carrying out the provisions of this subpart to one or more of the States that the Administrator determines will be able to use additional amounts during such year for carrying out such provisions. Any amount made available to a State for any fiscal year pursuant to the preceding sentence shall, for the purposes of this section, be regarded as an increase in the allotment of the State (as determined under the preceding provisions of this section) for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa16343-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds allotted or made available to a State under this section shall be administered by the designated State entity, in accordance with the approved State plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa16344-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s711"},"text":"Pub. L. 93–112, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1224"},"text":"112 Stat. 1224","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s476/a"},"text":"Pub. L. 113–128, title IV, § 476(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1690"},"text":"128 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa16345-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa16346-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5aa16347-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part A of this subchapter, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":", referred to in subsec. (a)(1)(B), means former part A (§ 796 et seq.) which was included in the repeal of subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/1"},"text":"Pub. L. 102–569, title VII, § 701(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4443"},"text":"106 Stat. 4443","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa16348-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s711"},"text":"Pub. L. 93–112, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4450"},"text":"106 Stat. 4450","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/e"},"text":"Pub. L. 103–73, title I, § 114(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/729"},"text":"107 Stat. 729","children":[],"tail":", related to allotments to provide independent living services, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 796e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s711"},"text":"Pub. L. 93–112, title VII, § 711","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tIII/s301"},"text":"Pub. L. 95–602, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2998"},"text":"92 Stat. 2998","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/221/tI/s171"},"text":"Pub. L. 98–221, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/30"},"text":"98 Stat. 30","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tI/s103/d/2/C"},"text":"Pub. L. 99–506, title I, § 103(d)(2)(C)","children":[],"tail":", title VIII, §§ 804(a)(1), (b), (c), 805, "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1810"},"text":"100 Stat. 1810","children":[],"tail":", 1838, 1839; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s208/f"},"text":"Pub. L. 100–630, title II, § 208(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3314"},"text":"102 Stat. 3314","children":[],"tail":", related to establishment and operation of independent living centers, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/s701/1"},"text":"Pub. L. 102–569, § 701(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa16349-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s476/a/1/A"},"text":"Pub. L. 113–128, § 476(a)(1)(A)","children":[],"tail":", (2), substituted “After the reservation required by "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796e–0"},"text":"section 796e–0 of this title","children":[],"tail":" is made, and except” for “Except”, inserted “the remainder of the” before “sums appropriated”, and substituted “Administrator” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s476/a/1/B"},"text":"Pub. L. 113–128, § 476(a)(1)(B)","children":[],"tail":", substituted “remainder described in paragraph (1)(A)” for “amounts made available for purposes of this subpart”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(3) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s476/a/2"},"text":"Pub. L. 113–128, § 476(a)(2)","children":[],"tail":", substituted “Administrator” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s476/a/3"},"text":"Pub. L. 113–128, § 476(a)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
