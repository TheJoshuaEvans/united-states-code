{"tag":"section","attrib":{"id":"id5a6f5642-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s713"},"text":null,"children":[{"tag":"num","attrib":{"value":"713"},"text":"§ 713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6f5643-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, no funds appropriated under this chapter for any program or activity may be used for any purpose other than that for which the funds were specifically authorized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6f5644-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No more than 1 percent of funds appropriated for discretionary grants, contracts, or cooperative agreements authorized by this chapter may be used for the purpose of providing non-Federal panels of experts to review applications for such grants, contracts, or cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6f5645-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s16"},"text":"Pub. L. 93–112, § 16","children":[],"tail":", formerly § 14, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1113"},"text":"112 Stat. 1113","children":[],"tail":"; renumbered § 16, "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/