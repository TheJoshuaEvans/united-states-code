{"tag":"section","attrib":{"id":"id5a1268ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49j"},"text":null,"children":[{"tag":"num","attrib":{"value":"49j"},"text":"§ 49j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of strikes and lockouts to applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of this chapter the Secretary is authorized and directed to provide for the giving of notice of strikes or lockouts to applicants before they are referred to employment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a1268cb-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-06/ch49"},"text":"June 6, 1933, ch. 49","children":[],"tail":", §  11, "},{"tag":"ref","attrib":{"href":"/us/stat/48/116"},"text":"48 Stat. 116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/tVI/s601/g"},"text":"Pub. L. 97–300, title VI, § 601(g)","children":[],"tail":", formerly title V, § 501(g), "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1397"},"text":"96 Stat. 1397","children":[],"tail":"; renumbered title VI, § 601(g), "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVII/s712/a/1"},"text":"Pub. L. 100–628, title VII, § 712(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3248"},"text":"102 Stat. 3248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIII/s307"},"text":"Pub. L. 105–220, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1082"},"text":"112 Stat. 1082","children":