{"tag":"section","attrib":{"id":"id5b6c2d56-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001"},"text":null,"children":[{"tag":"num","attrib":{"value":"3001"},"text":"§ 3001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b6c2d57-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ","children":[{"tag":"ref","attrib":{"idref":"fn002195"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002195"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “to” probably should not appear."}],"tail":" support State efforts to improve the provision of assistive technology to individuals with disabilities of all ages, including underrepresented populations, through comprehensive statewide programs of technology-related assistance that are designed to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b6c2d58-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the availability of, funding for, access to, provision of, and education about assistive technology devices and assistive technology services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6c2d59-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the ability of individuals with disabilities to secure and maintain possession of assistive technology devices as such individuals make the transition between services offered by educational or human service agencies or between settings of daily living (for example, between home and work);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6c2d5a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the capacity of public agencies and private entities to provide and pay for assistive technology devices and assistive technology services on a statewide basis for individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6c2d5b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the involvement of individuals with disabilities and, if appropriate, their family members, guardians, advocates, and authorized representatives, in decisions related to the provision of assistive technology devices and assistive technology services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6c2d5c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase and promote coordination among and between State and local agencies and private entities (such as managed care providers), that are involved in carrying out activities under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6c2d5d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the awareness and facilitate the change of laws, regulations, policies, practices, procedures, and organizational structures that facilitate the availability or provision of assistive technology devices and assistive technology services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b6c2d5e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase awareness and knowledge of the benefits of assistive technology devices and assistive technology services among targeted individuals and entities and the general population; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b6c2d5f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" provide States and protection and advocacy systems with financial assistance that supports programs designed to maximize the ability of individuals with disabilities and their family members, guardians, advocates, and authorized representatives to obtain assistive technology devices and assistive technology services."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b6c2d60-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/394/s2"},"text":"Pub. L. 105–394, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3628"},"text":"112 Stat. 3628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/364/s2"},"text":"Pub. L. 108–364, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1707"},"text":"118 Stat. 1707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5402"},"text":"Pub. L. 117–263, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3260"},"text":"136 Stat. 3260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b6c2d61-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b6c2d62-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b6c2d63-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text consisted of subsecs. (a) and (b) relating to findings and purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/364"},"text":"Pub. L. 108–364","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text consisted of subsecs. (a) and (b) relating to findings and purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b6c2d64-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b6c2d65-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5403"},"text":"Pub. L. 117–263, div. E, title LIV, § 5403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3289"},"text":"136 Stat. 3289","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIV/s5403"},"text":"“This title [see Short Title of 2022 Amendment note set out below], and the amendments made by this title, shall take effect on the day that is 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id5b6c2d66-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5401"},"text":"Pub. L. 117–263, div. E, title LIV, § 5401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3260"},"text":"136 Stat. 3260","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIV/s5401"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3008"},"text":"section 3008 of this title","children":[],"tail":", amending this section and sections 3002 to 3007 of this title, and enacting and amending provisions set out as notes under this section] may be cited as the ‘21st Century Assistive Technology Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id5b6c2d67-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/364/s1"},"text":"Pub. L. 108–364, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1707"},"text":"118 Stat. 1707","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/364/s1"},"text":"“This Act [enacting sections 3003 to 3007 of this title, amending this section, sections 763, 781, 792, and 3002 of this title, and sections 15024, 15025, 15043, and 15064 of Title 42, The Public Health and Welfare, omitting sections 3011 to 3015, 3031 to 3037, and 3051 to 3058 of this title, and amending provisions set out as a note under this section] may be cited as the ‘Assistive Technology Act of 2004’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id5b6c2d68-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/394/s1/a"},"text":"Pub. L. 105–394, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3627"},"text":"112 Stat. 3627","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/364/s2"},"text":"Pub. L. 108–364, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1707"},"text":"118 Stat. 1707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5402"},"text":"Pub. L. 117–263, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3260"},"text":"136 Stat. 3260","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIV/s5402"},"text":"“This Act [enacting this chapter] may be cited as the ‘Assistive Technology Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
