{"tag":"section","attrib":{"id":"id5b69bb10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632"},"text":null,"children":[{"tag":"num","attrib":{"value":"2632"},"text":"§ 2632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b69bb11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a comprehensive study of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b69bb12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing and proposed mandatory and voluntary policies relating to family and temporary medical leave, including policies provided by employers not covered under this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential costs, benefits, and impact on productivity, job creation and business growth of such policies on employers and employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possible differences in costs, benefits, and impact on productivity, job creation and business growth of such policies on employers based on business type and size;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of family and medical leave policies on the availability of employee benefits provided by employers, including employers not covered under this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternate and equivalent State enforcement of subchapter I with respect to employees described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2618/a"},"text":"section 2618(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods used by employers to reduce administrative costs of implementing family and medical leave policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the employers to recover, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2614/c/2"},"text":"section 2614(c)(2) of this title","children":[],"tail":", the premiums described in such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b69bb19-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact on employers and employees of policies that provide temporary wage replacement during periods of family and medical leave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b69bb1a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2632/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 2 years after the date on which the Commission first meets, prepare and submit, to the appropriate Committees of Congress, a report concerning the subjects listed in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b69bb1b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tIII/s302"},"text":"Pub. L. 103–3, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/23"},"text":"107 Stat. 23","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b69bb1c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b69bb1d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b69bb1e-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (1)(A), (D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":", known as the Family and Medical Leave Act of 1993, which enacted this chapter, sections 60m and 60n of Title 2, The Congress, and sections 6381 to 6387 of Title 5, Government Organization and Employees, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
