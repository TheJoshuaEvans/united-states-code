{"tag":"section","attrib":{"id":"id5acc6a35-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1030a"},"text":"§ 1030a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eliminating unnecessary plan requirements related to unenrolled participants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5acc6a36-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter, with respect to any individual account plan, no disclosure, notice, or other plan document (other than the notices and documents described in paragraphs (1) and (2)) shall be required to be furnished under this subchapter to any unenrolled participant if the unenrolled participant is furnished—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5acc6a37-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual reminder notice of such participant’s eligibility to participate in such plan and any applicable election deadlines under the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a38-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any document requested by such participant that the participant would be entitled to receive notwithstanding this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5acc6a39-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unenrolled participant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “unenrolled participant” means an employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5acc6a3a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to participate in an individual account plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a3b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been furnished—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5acc6a3c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the summary plan description pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1024/b"},"text":"section 1024(b) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5acc6a3d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other notices related to eligibility under the plan required to be furnished under this subchapter, or the Internal Revenue Code of 1986, in connection with such participant’s initial eligibility to participate in such plan;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a3e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not participating in such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a3f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies such other criteria as the Secretary of Labor may determine appropriate, as prescribed in guidance issued in consultation with the Secretary of Treasury.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this section, any eligibility to participate in the plan following any period for which such employee was not eligible to participate shall be treated as initial eligibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5acc6a40-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reminder notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “annual reminder notice” means a notice provided in accordance with section 2520.104b–1 of title 29, Code of Federal Regulations (or any successor regulation), which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5acc6a41-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is furnished in connection with the annual open season election period with respect to the plan or, if there is no such period, is furnished within a reasonable period prior to the beginning of each plan year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a42-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notifies the unenrolled participant of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5acc6a43-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unenrolled participant’s eligibility to participate in the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5acc6a44-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the key benefits and rights under the plan, with a focus on employer contributions and vesting provisions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a45-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides such information in a prominent manner calculated to be understood by the average participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5acc6a46-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s111"},"text":"Pub. L. 93–406, title I, § 111","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tIII/s320/a/1"},"text":"Pub. L. 117–328, div. T, title III, § 320(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5354"},"text":"136 Stat. 5354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5acc6a47-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5acc6a48-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5acc6a49-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (b)(2)(B), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5acc6a4a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/s111"},"text":"section 111 of Pub. L. 93–406","children":[],"tail":" was renumbered section 112 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5acc6a4b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5acc6a4c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"Dec. 31, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s320/c"},"text":"section 320(c) of Pub. L. 117–328","children":[],"tail":", set out as an Effective Date of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s414"},"text":"section 414 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
