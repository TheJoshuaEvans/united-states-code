{"tag":"section","attrib":{"id":"id5baa1fef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291"},"text":null,"children":[{"tag":"num","attrib":{"value":"3291"},"text":"§ 3291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds; grants to eligible agencies; allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5baa1ff0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the sum appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3275"},"text":"section 3275 of this title","children":[],"tail":" for a fiscal year, the Secretary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa1ff1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall reserve 2 percent to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3332"},"text":"section 3332 of this title","children":[],"tail":", except that the amount so reserved shall not exceed $15,000,000; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1ff2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall reserve 12 percent of the amount that remains after reserving funds under paragraph (1) to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3333"},"text":"section 3333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5baa1ff3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to eligible agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa1ff4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the sum appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3275"},"text":"section 3275 of this title","children":[],"tail":" and not reserved under subsection (a) for a fiscal year, the Secretary shall award a grant to each eligible agency having a unified State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3112"},"text":"section 3112 of this title","children":[],"tail":" or a combined State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3113"},"text":"section 3113 of this title","children":[],"tail":" in an amount equal to the sum of the initial allotment under subsection (c)(1) and the additional allotment under subsection (c)(2) for the eligible agency for the fiscal year, subject to subsections (f) and (g), to enable the eligible agency to carry out the activities assisted under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1ff5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant under paragraph (1) only if the eligible entity involved agrees to expend the grant for adult education and literacy activities in accordance with the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5baa1ff6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa1ff7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial allotments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the sum appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3275"},"text":"section 3275 of this title","children":[],"tail":" and not reserved under subsection (a) for a fiscal year, the Secretary shall allot to each eligible agency having a unified State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3112"},"text":"section 3112 of this title","children":[],"tail":" or a combined State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3113"},"text":"section 3113 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1ff8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000, in the case of an eligible agency serving an outlying area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1ff9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000, in the case of any other eligible agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1ffa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the sum appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3275"},"text":"section 3275 of this title","children":[],"tail":", not reserved under subsection (a), and not allotted under paragraph (1), for a fiscal year, the Secretary shall allot to each eligible agency that receives an initial allotment under paragraph (1) an additional amount that bears the same relationship to such sum as the number of qualifying adults in the State or outlying area served by the eligible agency bears to the number of such adults in all States and outlying areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5baa1ffb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying adult","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of subsection (c)(2), the term “qualifying adult” means an adult who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa1ffc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 16 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1ffd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is beyond the age of compulsory school attendance under the law of the State or outlying area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1ffe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a secondary school diploma or its recognized equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not enrolled in secondary school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5baa2000-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa2001-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available under subsection (c) for the Republic of Palau, the Secretary shall award grants to Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, or the Republic of Palau to carry out activities described in this subchapter in accordance with the provisions of this subchapter, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa2002-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants pursuant to paragraph (1) on a competitive basis and pursuant to the recommendations from the Pacific Region Educational Laboratory in Honolulu, Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa2003-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Republic of Palau shall be eligible to receive a grant under this subchapter except during the period described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102/45"},"text":"section 3102(45) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa2004-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide not more than 5 percent of the funds made available for grants under this subsection to pay the administrative costs of the Pacific Region Educational Laboratory regarding activities assisted under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5baa2005-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold-harmless provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa2006-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (c), for fiscal year 2015 and each succeeding fiscal year, no eligible agency shall receive an allotment under this section that is less than 90 percent of the allotment the eligible agency received for the preceding fiscal year under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa2007-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratable reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If for any fiscal year the amount available for allotment under this subchapter is insufficient to satisfy the provisions of paragraph (1) the Secretary shall ratably reduce the payments to all eligible agencies, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5baa2008-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3291/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallotment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The portion of any eligible agency’s allotment under this subchapter for a fiscal year that the Secretary determines will not be required for the period such allotment is available for carrying out activities under this subchapter, shall be available for reallotment from time to time, on such dates during such period as the Secretary shall fix, to other eligible agencies in proportion to the original allotments to such agencies under this subchapter for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5baa2009-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s211"},"text":"Pub. L. 113–128, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1612"},"text":"128 Stat. 1612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5baa200a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5baa200b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5baa200c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
