{"tag":"section","attrib":{"id":"id5a90c057-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781"},"text":null,"children":[{"tag":"num","attrib":{"value":"781"},"text":"§ 781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of National Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a90c058-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a90c059-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice to the Director with respect to the policies and conduct of the National Institute on Disability, Independent Living, and Rehabilitation Research, including ways to improve research concerning individuals with disabilities and the methods of collecting and disseminating findings of such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c05a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice to the Commissioner with respect to the policies of and conduct of the Rehabilitation Services Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c05b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President, the Congress, the Commissioner, the appropriate Assistant Secretary of the Department of Education, and the Director of the National Institute on Disability, Independent Living, and Rehabilitation Research on the development of the programs to be carried out under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c05c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice regarding priorities for the activities of the Interagency Disability Coordinating Council and review the recommendations of such Council for legislative and administrative changes to ensure that such recommendations are consistent with the purposes of the Council to promote the full integration, independence, and productivity of individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c05d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and evaluate on a continuing basis—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a90c05e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies, programs, practices, and procedures concerning individuals with disabilities conducted or assisted by Federal departments and agencies, including programs established or assisted under this chapter or under the Developmental Disabilities Assistance and Bill of Rights Act of 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"42 U.S.C. 15001","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a90c05f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all statutes and regulations pertaining to Federal programs which assist such individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in order to assess the effectiveness of such policies, programs, practices, procedures, statutes, and regulations in meeting the needs of individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c060-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the extent to which such policies, programs, practices, and procedures facilitate or impede the promotion of the policies set forth in subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s780/a/2"},"text":"section 780(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c061-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gather information about the implementation, effectiveness, and impact of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c062-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the President, the Congress, the Secretary, the Director of the National Institute on Disability and Rehabilitation Research, and other officials of Federal agencies or other Federal entities, respecting ways to better promote the policies set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s780/a/2"},"text":"section 780(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c063-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Congress on a continuing basis advice, recommendations, legislative proposals, and any additional information that the National Council or the Congress deems appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c064-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and evaluate on a continuing basis new and emerging disability policy issues affecting individuals with disabilities at the Federal, State, and local levels, and in the private sector, including the need for and coordination of adult services, access to personal assistance services, school reform efforts and the impact of such efforts on individuals with disabilities, access to health care, and policies that operate as disincentives for the individuals to seek and retain employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a90c065-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a90c066-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1998-10-31"},"text":"October 31, 1998","children":[],"tail":", and annually thereafter, the National Council shall prepare and submit to the President and the appropriate committees of the Congress a report entitled “National Disability Policy: A Progress Report”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c067-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report shall assess the status of the Nation in achieving the policies set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s780/a/2"},"text":"section 780(a)(2) of this title","children":[],"tail":", with particular focus on the new and emerging issues impacting on the lives of individuals with disabilities. The report shall present, as appropriate, available data on health, housing, employment, insurance, transportation, recreation, training, prevention, early intervention, and education. The report shall include recommendations for policy change."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a90c068-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s781/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining the issues to focus on and the findings, conclusions, and recommendations to include in the report, the National Council shall seek input from the public, particularly individuals with disabilities, representatives of organizations representing a broad range of individuals with disabilities, and organizations and agencies interested in individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a90c069-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s401"},"text":"Pub. L. 93–112, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s407"},"text":"Pub. L. 105–220, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1199"},"text":"112 Stat. 1199","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/394/tII/s202"},"text":"Pub. L. 105–394, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3653"},"text":"112 Stat. 3653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/b/3/B"},"text":"Pub. L. 106–402, title IV, § 401(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1737"},"text":"114 Stat. 1737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/364/s3/b/2"},"text":"Pub. L. 108–364, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1737"},"text":"118 Stat. 1737","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s452"},"text":"Pub. L. 113–128, title IV, § 452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1675"},"text":"128 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a90c06a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a90c06b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a90c06c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Developmental Disabilities Assistance and Bill of Rights Act of 2000, referred to in subsec. (a)(5)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1677"},"text":"114 Stat. 1677","children":[],"tail":", which is classified principally to chapter 144 (§ 15001 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"section 15001 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Americans with Disabilities Act of 1990, referred to in subsec. (a)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a90c06d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 781, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s401"},"text":"Pub. L. 93–112, title IV, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s117"},"text":"Pub. L. 95–602, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2977"},"text":"92 Stat. 2977","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/221/tI/s142"},"text":"Pub. L. 98–221, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/27"},"text":"98 Stat. 27","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tI/s103/d/2/C"},"text":"Pub. L. 99–506, title I, § 103(d)(2)(C)","children":[],"tail":", title III, § 302(b), title V, § 502, "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1810"},"text":"100 Stat. 1810","children":[],"tail":", 1821, 1828; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s205/c"},"text":"Pub. L. 100–630, title II, § 205(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3310"},"text":"102 Stat. 3310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s102/p/27"},"text":"Pub. L. 102–569, title I, § 102(p)(27)","children":[],"tail":", title IV, § 402, "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4360"},"text":"106 Stat. 4360","children":[],"tail":", 4422; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2131"},"text":"Pub. L. 104–66, title II, § 2131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/731"},"text":"109 Stat. 731","children":[],"tail":", related to duties of National Council on Disability, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 781, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIV/s401"},"text":"Pub. L. 93–112, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/386"},"text":"87 Stat. 386","children":[],"tail":", related to program and project evaluation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/s117"},"text":"Pub. L. 95–602, § 117","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a90c06e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s452/1"},"text":"Pub. L. 113–128, § 452(1)","children":[],"tail":", substituted “National Institute on Disability, Independent Living, and Rehabilitation Research” for “National Institute on Disability and Rehabilitation Research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s452/2"},"text":"Pub. L. 113–128, § 452(2)","children":[],"tail":", struck out subsec. (c) which required a report describing the barriers in Federal assistive technology policy to increasing the availability of and access to assistive technology devices and assistive technology services for individuals with disabilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/364"},"text":"Pub. L. 108–364","children":[],"tail":" substituted “targeted individuals and entities” for “targeted individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":", which directed substitution of “Developmental Disabilities Assistance and Bill of Rights Act of 2000” for “Developmental Disabilities Assistance and Bill of Rights Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6000"},"text":"42 U.S.C. 6000","children":[],"tail":" et seq.)”, was executed by making the substitution for “Developmental Disabilities Assistance and Bill of Rights Act” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/394"},"text":"Pub. L. 105–394","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a90c06f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5a90c070-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report to Congress required under subsec. (b) of this section is listed on page 182), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5a90c071-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions which the Director of the National Institute on Disability and Rehabilitation Research exercised before ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" (including all related functions of any officer or employee of the National Institute on Disability and Rehabilitation Research), transferred to the National Institute on Disability, Independent Living, and Rehabilitation Research, see subsection (n) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3515e"},"text":"section 3515e of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
