{"tag":"section","attrib":{"id":"id5a46e646-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s437"},"text":null,"children":[{"tag":"num","attrib":{"value":"437"},"text":"§ 437.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for making reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a46e647-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s437/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each labor organization shall file the initial report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s431/a"},"text":"section 431(a) of this title","children":[],"tail":" within ninety days after the date on which it first becomes subject to this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a46e648-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s437/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each person required to file a report under section 431(b), 432, 433(a), the second sentence of 433(b), or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s441"},"text":"section 441 of this title","children":[],"tail":" shall file such report within ninety days after the end of each of its fiscal years; except that where such person is subject to section 431(b), 432, 433(a), the second sentence of 433(b), or "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s441"},"text":"section 441 of this title","children":[],"tail":", as the case may be, for only a portion of such a fiscal year (because "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"September 14, 1959","children":[],"tail":", occurs during such person’s fiscal year) such person becomes subject to this chapter during its fiscal year or such person may consider that portion as the entire fiscal year in making such report."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a46e649-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/257/tII/s207"},"text":"Pub. L. 86–257, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/529"},"text":"73 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/216/s2/d"},"text":"Pub. L. 89–216, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-29"},"text":"Sept. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/888"},"text":"79 Stat. 888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a46e64a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a46e64b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a46e64c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/216"},"text":"Pub. L. 89–216","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s441"},"text":"section 441 of this title","children":[],"tail":" in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
