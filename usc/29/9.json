{"tag":"section","attrib":{"id":"id5a08cb79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"§ 9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of special studies, compilations, and transcripts on request; cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of Labor is authorized, within the discretion of the Secretary of Labor, upon the written request of any person, to make special statistical studies relating to employment, hours of work, wages, and other conditions of employment; to prepare from its records special statistical compilations; and to furnish transcripts of its studies, tables, and other records, upon the payment of the actual cost of such work by the person requesting it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a08cb7a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-13/ch118/s1"},"text":"Apr. 13, 1934, ch. 118, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/582"},"text":"48 Stat. 582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-04-11/ch59"},"text":"Apr. 11, 1935, ch. 59","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/154"},"text":"49 Stat. 154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-06-15/ch349"},"text":"June 15, 1937, ch. 349","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/259"},"text":"50 Stat. 259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-04-15/ch71"},"text":"Apr. 15, 1939, ch. 71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/581"},"text":"53 Stat. 581","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a08cb7b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a08cb7c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a08cb7d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section and sections 9a and 9b of this title comprised sections 1 to 3 of act ","children":[{"tag":"date","attrib":{"date":"1934-04-13"},"text":"Apr. 13, 1934","children":[],"tail":". Section 4 of that act provided as follows: "},{"tag":"quotedContent","attrib":{},"text":"“This Act shall cease to be effective one year after the date of its enactment.”","children":[],"tail":"\n The act was temporarily extended by acts "},{"tag":"date","attrib":{"date":"1935-04-11"},"text":"Apr. 11, 1935","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1937-06-15"},"text":"June 15, 1937","children":[],"tail":", and was made permanent by act "},{"tag":"date","attrib":{"date":"1939-04-15"},"text":"Apr. 15, 1939","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
