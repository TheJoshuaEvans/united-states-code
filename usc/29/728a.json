{"tag":"section","attrib":{"id":"id5a7dae3f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a"},"text":null,"children":[{"tag":"num","attrib":{"value":"728a"},"text":"§ 728a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and services for employers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State may expend payments received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s731"},"text":"section 731 of this title","children":[],"tail":" to educate and provide services to employers who have hired or are interested in hiring individuals with disabilities under programs carried out under this subchapter, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7dae40-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training and technical assistance to employers regarding the employment of individuals with disabilities, including disability awareness, and the requirements of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.) and other employment-related laws;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae41-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" working with employers to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7dae42-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide opportunities for work-based learning experiences (including internships, short-term employment, apprenticeships, and fellowships), and opportunities for pre-employment transition services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae43-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit qualified applicants who are individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae44-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train employees who are individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae45-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote awareness of disability-related obstacles to continued employment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae46-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing consultation, technical assistance, and support to employers on workplace accommodations, assistive technology, and facilities and workplace access through collaboration with community partners and employers, across States and nationally, to enable the employers to recruit, job match, hire, and retain qualified individuals with disabilities who are recipients of vocational rehabilitation services under this subchapter, or who are applicants for such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae47-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s728a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting employers with utilizing available financial support for hiring or accommodating individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a7dae48-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s109"},"text":"Pub. L. 93–112, title I, § 109","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s404"},"text":"Pub. L. 105–220, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1160"},"text":"112 Stat. 1160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s418"},"text":"Pub. L. 113–128, title IV, § 418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1655"},"text":"128 Stat. 1655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a7dae49-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a7dae4a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a7dae4b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Americans with Disabilities Act of 1990, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a7dae4c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 728a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s109"},"text":"Pub. L. 93–112, title I, § 109","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s130/a"},"text":"Pub. L. 102–569, title I, § 130(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4389"},"text":"106 Stat. 4389","children":[],"tail":", related to training of employers with respect to Americans with Disabilities Act of 1990, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a7dae4d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “A State may expend payments received under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s731"},"text":"section 731 of this title","children":[],"tail":"—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to carry out a program to train employers with respect to compliance with the requirements of title I of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12111"},"text":"42 U.S.C. 12111","children":[],"tail":" et seq.); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to inform employers of the existence of the program and the availability of the services of the program.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a7dae4e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id5a7dae4f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions of Terms in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s3"},"text":"section 3 of Pub. L. 113–128","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":", apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
