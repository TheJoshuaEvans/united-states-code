{"tag":"section","attrib":{"id":"id5ba2f3c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228"},"text":null,"children":[{"tag":"num","attrib":{"value":"3228"},"text":"§ 3228.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worker ownership, readiness, and knowledge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ba2f3c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba2f3c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “existing program” means a program, designed to promote employee ownership, that exists on the date on which the Secretary is carrying out a responsibility authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Initiative” means the Employee Ownership Initiative established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “new program” means a program, designed to promote employee ownership, that does not exist on the date on which the Secretary is carrying out a responsibility authorized under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the meaning given the term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f3cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee Ownership Initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba2f3cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Department of Labor an Employee Ownership Initiative to promote employee ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Initiative, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f3ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support within the States existing programs designed to promote employee ownership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate within the States the formation of new programs designed to promote employee ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the functions enumerated in paragraph (2), the Secretary shall support new programs and existing programs by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f3d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making Federal grants authorized under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5ba2f3d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting as a clearinghouse on techniques employed by new programs and existing programs within the States, and disseminating information relating to those techniques to the programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding projects for information gathering on those techniques, and dissemination of that information to the programs, by groups outside the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Secretary of the Treasury, or the Secretary’s delegate, in the case of any employee ownership arrangements or structures the administration and enforcement of which are within the jurisdiction of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f3d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs regarding employee ownership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba2f3d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall establish a program to encourage new programs and existing programs within the States to foster employee ownership throughout the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the program established under paragraph (1) is to encourage new and existing programs within the States that focus on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f3d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing education and outreach to inform employees and employers about the possibilities and benefits of employee ownership and business ownership succession planning, including providing information about financial education, employee teams, open-book management, and other tools that enable employees to share ideas and information about how their businesses can succeed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to assist employee efforts to become business owners, to enable employers and employees to explore and assess the feasibility of transferring full or partial ownership to employees, and to encourage employees and employers to start new employee-owned businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training employees and employers with respect to methods of employee participation in open-book management, work teams, committees, and other approaches for seeking greater employee input; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3dc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training other entities to apply for funding under this subsection, to establish new programs, and to carry out program activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program details","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may include, in the program established under paragraph (1), provisions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f3de-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of activities described in paragraph (2)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5ba2f3df-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" target key groups, such as retiring business owners, senior managers, labor organizations, trade associations, community organizations, and economic development organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3e0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage cooperation in the organization of workshops and conferences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and distribute materials concerning employee ownership, and business ownership succession planning;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3e2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of activities described in paragraph (2)(B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5ba2f3e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide preliminary technical assistance to employee groups, managers, and retiring owners exploring the possibility of employee ownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the performance of preliminary feasibility assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the funding of objective third-party feasibility studies and preliminary business valuations, and in selecting and monitoring professionals qualified to conduct such studies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a data bank to help employees find legal, financial, and technical advice in connection with business ownership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of activities described in paragraph (2)(C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5ba2f3e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for courses on employee participation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the development and fostering of networks of employee-owned companies to spread the use of successful participation techniques; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of training described in paragraph (2)(D)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5ba2f3eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for visits to existing programs by staff from new programs receiving funding under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide materials to be used for such training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue formal guidance, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f3ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recipients of grants awarded under subsection (d) and one-stop partners (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":") affiliated with the workforce development systems (as so defined) of the States, proposing that programs and other activities funded under this section be—"}],"tail":null},{"tag":"clause","attrib":{"id":"id5ba2f3ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proactive in encouraging actions and activities that promote employee ownership of businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f3f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive in emphasizing both employee ownership of businesses so as to increase productivity and broaden capital ownership; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acceptable standards and procedures to establish good faith fair market value for shares of a business to be acquired by an employee stock ownership plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1107/d/6"},"text":"section 1107(d)(6) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The guidance under subparagraph (B) shall be prescribed in consultation with the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f3f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba2f3f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (c), the Secretary may make grants for use in connection with new programs and existing programs within a State for any of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f3f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education and outreach as provided in subsection (c)(2)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical assistance as provided in subsection (c)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training activities for employees and employers as provided in subsection (c)(2)(C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities facilitating cooperation among employee-owned firms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training as provided in subsection (c)(2)(D) for new programs provided by participants in existing programs dedicated to the objectives of this section, except that, for each fiscal year, the amount of the grants made for such training shall not exceed 10 percent of the total amount of the grants made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the amount and any conditions for a grant made under this subsection. The amount of the grant shall be subject to paragraph (6), and shall reflect the capacity of the applicant for the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity desiring a grant under this subsection shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State may sponsor and submit an application under paragraph (3) on behalf of any local entity consisting of a unit of State or local government, State-supported institution of higher education, or nonprofit organization, meeting the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications by entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f3fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entity applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State fails to support or establish a program pursuant to this section during any fiscal year, the Secretary shall, in the subsequent fiscal years, allow local entities described in paragraph (4) from that State to make applications for grants under paragraph (3) on their own initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f3fe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application screening","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State failing to support or establish a program pursuant to this section during any fiscal year may submit applications under paragraph (3) in the subsequent fiscal years but may not screen applications by local entities described in paragraph (4) before submitting the applications to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f3ff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant made under this subsection shall not receive, during a fiscal year, in the aggregate, more than the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f400-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2025, $300,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f401-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2026, $330,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f402-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2027, $363,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f403-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2028, $399,300.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f404-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2029, $439,200.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f405-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each year, each recipient of a grant under this subsection shall submit to the Secretary a report describing how grant funds allocated pursuant to this subsection were expended during the 12-month period preceding the date of the submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f406-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to reserve not more than 10 percent of the funds appropriated for a fiscal year to carry out this section, for the purposes of conducting evaluations of the grant programs identified in subsection (d) and to provide related technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f407-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the expiration of the 36-month period following ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", the Secretary shall prepare and submit to Congress a report—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba2f408-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on progress related to employee ownership in businesses in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f409-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing an analysis of critical costs and benefits of activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba2f40a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba2f40b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the purpose of making grants pursuant to subsection (d) the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f40c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2025, $4,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f40d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2026, $7,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f40e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2027, $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f40f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2028, $13,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f410-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2029, $16,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba2f411-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the purpose of funding the administrative expenses related to the Initiative—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba2f412-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2024, $200,000, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba2f413-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each of fiscal years 2025 through 2029, an amount not in excess of the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5ba2f414-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $350,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba2f415-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3228/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5.0 percent of the maximum amount available under paragraph (1) for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ba2f416-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tIII/s346"},"text":"Pub. L. 117–328, div. T, title III, § 346","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5381"},"text":"136 Stat. 5381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ba2f417-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ba2f418-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5ba2f419-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the SECURE 2.0 Act of 2022, and also as part of the Consolidated Appropriations Act, 2023, and not as part of title I of the Workforce Innovation and Opportunity Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
