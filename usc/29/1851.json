{"tag":"section","attrib":{"id":"id5b591a1b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1851"},"text":null,"children":[{"tag":"num","attrib":{"value":"1851"},"text":"§ 1851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b591a1c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of chapter or regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who willfully and knowingly violates this chapter or any regulation under this chapter shall be fined not more than $1,000 or sentenced to prison for a term not to exceed one year, or both. Upon conviction for any subsequent violation of this chapter or any regulation under this chapter, the defendant shall be fined not more than $10,000 or sentenced to prison for a term not to exceed three years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b591a1d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a/a"},"text":"section 1324a(a) of title 8","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a farm labor contractor who commits a violation of paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a/a"},"text":"section 1324a(a) of title 8","children":[],"tail":" has been refused issuance or renewal of, or has failed to obtain, a certificate of registration or is a farm labor contractor whose certificate has been suspended or revoked, the contractor shall, upon conviction, be fined not more than $10,000 or sentenced to prison for a term not to exceed three years, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b591a1e-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/tV/s501"},"text":"Pub. L. 97–470, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2596"},"text":"96 Stat. 2596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/603/tI/s101/b/1/D"},"text":"Pub. L. 99–603, title I, § 101(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"Nov. 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3372"},"text":"100 Stat. 3372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b591a1f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b591a20-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b591a21-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/603"},"text":"Pub. L. 99–603","children":[],"tail":" substituted “paragraph (1) or (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a/a"},"text":"section 1324a(a) of title 8","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1816"},"text":"section 1816 of this 