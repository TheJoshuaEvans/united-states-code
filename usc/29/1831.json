{"tag":"section","attrib":{"id":"id5b5919bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831"},"text":"§ 1831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and recordkeeping requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5919bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written disclosure requirements imposed upon recruiters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5919be-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each farm labor contractor, agricultural employer, and agricultural association which recruits any seasonal agricultural worker (other than day-haul workers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1802/10/A/ii"},"text":"section 1802(10)(A)(ii) of this title","children":[],"tail":") shall ascertain and, upon request, disclose in writing the following information when an offer of employment is made to such worker:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5919bf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the place of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919c0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wage rates to be paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the crops and kinds of activities on which the worker may be employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation and any other employee benefit to be provided, if any, and any costs to be charged for each of them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existence of any strike or other concerted work stoppage, slowdown, or interruption of operations by employees at the place of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the existence of any arrangements with any owner or agent of any establishment in the area of employment under which the farm labor contractor, the agricultural employer, or the agricultural association is to receive a commission or any other benefit resulting from any sales by such establishment to the workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether State workers’ compensation insurance is provided, and, if so, the name of the State workers’ compensation insurance carrier, the name of the policyholder of such insurance, the name and the telephone number of each person who must be notified of an injury or death, and the time period within which such notice must be given.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Compliance with the disclosure requirement of subparagraph (H) may be met if such worker is given, upon request, a photocopy of any notice regarding workers’ compensation insurance required by law of the State in which such worker is employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5919c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each farm labor contractor, agricultural employer, and agricultural association which recruits seasonal agricultural workers through use of a day-haul operation described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1802/10/A/ii"},"text":"section 1802(10)(A)(ii) of this title","children":[],"tail":" shall ascertain and disclose in writing to the worker at the place of recruitment the information described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5919c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting requirements imposed upon employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each farm labor contractor, agricultural employer, and agricultural association which employs any seasonal agricultural worker shall, at the place of employment, post in a conspicuous place a poster provided by the Secretary setting forth the rights and protections afforded such workers under this chapter, including the right of a seasonal agricultural worker to have, upon request, a written statement provided by the farm labor contractor, agricultural employer, or agricultural association, of the information described in subsection (a). Such employer shall provide, upon request, a written statement of the information described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5919c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and information requirements imposed upon employers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each farm labor contractor, agricultural employer, and agricultural association which employs any seasonal agricultural worker shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5919ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to each such worker, make, keep, and preserve records for three years of the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5919cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis on which wages are paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of piecework units earned, if paid on a piecework basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours worked;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total pay period earnings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific sums withheld and the purpose of each sum withheld; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5919d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net pay; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5919d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to each such worker for each pay period, an itemized written statement of the information required by paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5919d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing of records by farm labor contractor; maintenance of records by recipient","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5919d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002191"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002191"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Each farm labor contractor shall provide to any other farm labor contractor and to any agricultural employer and agricultural association to which such farm labor contractor has furnished seasonal agricultural workers, copies of all records with respect to each such worker which such farm labor contractor is required to retain by subsection (c)(1). The recipient of these records shall keep them for a period of three years from the end of the period of employment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5919d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on knowingly providing false or misleading information to workers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No farm labor contractor, agricultural employer, or agricultural association shall knowingly provide false or misleading information to any seasonal agricultural worker concerning the terms, conditions, or existence of agricultural employment required to be disclosed by subsection (a), (b), or (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5919d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1831/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and language requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required to be disclosed by subsections (a) and (b) of this section to seasonal agricultural workers shall be provided in written form. Such information shall be provided in English or, as necessary and reasonable, in Spanish or other language common to seasonal agricultural workers who are not fluent or literate in English. The Department of Labor shall make forms available in English, Spanish, and other languages, as necessary, which may be used in providing workers with information required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5919d6-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/tIII/s301"},"text":"Pub. L. 97–470, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2592"},"text":"96 Stat. 2592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/49/s4/b"},"text":"Pub. L. 104–49, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-15"},"text":"Nov. 15, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/434"},"text":"109 Stat. 434","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5919d7-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b5919d8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b5919d9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/49"},"text":"Pub. L. 104–49","children":[],"tail":" added subpar. (H) and concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5919da-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b5919db-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/49"},"text":"Pub. L. 104–49","children":[],"tail":" effective upon expiration of 90 days after the date final regulations are issued by Secretary of Labor to implement such amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/49/s4/c"},"text":"section 4(c) of Pub. L. 104–49","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b5919dc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days from ","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/470/s524"},"text":"section 524 of Pub. L. 97–470","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
