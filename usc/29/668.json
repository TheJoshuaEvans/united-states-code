{"tag":"section","attrib":{"id":"id5a6125c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668"},"text":null,"children":[{"tag":"num","attrib":{"value":"668"},"text":"§ 668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs of Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6125c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, development, and maintenance by head of each Federal agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the responsibility of the head of each Federal agency (not including the United States Postal Service) to establish and maintain an effective and comprehensive occupational safety and health program which is consistent with the standards promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s655"},"text":"section 655 of this title","children":[],"tail":". The head of each agency shall (after consultation with representatives of the employees thereof)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6125ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide safe and healthful places and conditions of employment, consistent with the standards set under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s655"},"text":"section 655 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6125cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, maintain, and require the use of safety equipment, personal protective equipment, and devices reasonably necessary to protect employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6125cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep adequate records of all occupational accidents and illnesses for proper evaluation and necessary corrective action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6125cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary with regard to the adequacy as to form and content of rec­ords kept pursuant to subsection (a)(3) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6125ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make an annual report to the Secretary with respect to occupational accidents and injuries and the agency’s program under this section. Such report shall include any report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7902/e/2"},"text":"section 7902(e)(2) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6125cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary to President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report to the President a summary or digest of reports submitted to him under subsection (a)(5) of this section, together with his evaluations of and recommendations derived from such reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6125d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6125d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s668/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access by Secretary to records and reports required of agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have access to records and reports kept and filed by Federal agencies pursuant to subsections (a)(3) and (5) of this section unless those records and reports are specifically required by Executive order to be kept secret in the interest of the national defense or foreign policy, in which case the Secretary shall have access to such information as will not jeopardize national defense or foreign policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6125d2-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596/s19"},"text":"Pub. L. 91–596, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1609"},"text":"84 Stat. 1609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tI/s110/c"},"text":"Pub. L. 97–375, title I, § 110(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1821"},"text":"96 Stat. 1821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/241/s2/b/1"},"text":"Pub. L. 105–241, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-09-28"},"text":"Sept. 28, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1572"},"text":"112 Stat. 1572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a6125d3-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a6125d4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a6125d5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7902"},"text":"section 7902 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a6125d6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/241"},"text":"Pub. L. 105–241","children":[],"tail":" inserted “(not including the United States Postal Service)” after “each Federal agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" struck out direction that the President transmit annually to the Senate and House a report of the activities of Federal agencies under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5a6125d7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5a6125d8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Occupational Safety and Health Programs for Federal Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Occupational safety and health programs for Federal employees and continuation of Federal Advisory Council on Occupational Safety and Health, see Ex. Ord. No. 12196, ","children":[{"tag":"date","attrib":{"date":"1980-02-26"},"text":"Feb. 26, 1980","children":[],"tail":", 45 F.R. 12769, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7902"},"text":"section 7902 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
