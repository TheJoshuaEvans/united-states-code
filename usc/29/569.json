{"tag":"section","attrib":{"id":"id5a505c65-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569"},"text":null,"children":[{"tag":"num","attrib":{"value":"569"},"text":"§ 569.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security detail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a505c66-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor is authorized to employ law enforcement officers or special agents to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a505c67-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide protection for the Secretary of Labor during the workday of the Secretary and during any activity that is preliminary or postliminary to the performance of official duties by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c68-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide protection, incidental to the protection provided to the Secretary, to a member of the immediate family of the Secretary who is participating in an activity or event relating to the official duties of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c69-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide continuous protection to the Secretary (including during periods not described in paragraph (1)) and to the members of the immediate family of the Secretary if there is a unique and articulable threat of physical harm, in accordance with guidelines established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c6a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide protection to the Deputy Secretary of Labor or another senior officer representing the Secretary of Labor at a public event if there is a unique and articulable threat of physical harm, in accordance with guidelines established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a505c6b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor may authorize a law enforcement officer or special agent employed under subsection (a), for the purpose of performing the duties authorized under subsection (a), to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a505c6c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c6d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make arrests without a warrant for any offense against the United States committed in the presence of such officer or special agent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c6e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform protective intelligence work, including identifying and mitigating potential threats and conducting advance work to review security matters relating to sites and events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c6f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with local law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c70-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate criminal and other investigations into potential threats to the security of the Secretary, in coordination with the Inspector General of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a505c71-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A law enforcement officer or special agent employed under subsection (a) shall exercise any authority provided under this section in accordance with any—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a505c72-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines issued by the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a505c73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s569/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines prescribed by the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a505c74-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s12"},"text":"Mar. 4, 1913, ch. 141, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/75/dB/tI/s113/a"},"text":"Pub. L. 119–75, div. B, title I, § 113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/255"},"text":"140 Stat. 255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a505c75-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a505c76-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a505c77-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dB/s113/a"},"text":"Section 113(a) of div. B of Pub. L. 119–75","children":[],"tail":", which directed amendment of "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141"},"text":"act Mar. 4, 1913, ch. 141","children":[],"tail":", by adding this undesignated section at the end, was executed, as shown in the credit of this section, by adding section 12 to the Act, to reflect the probable intent of Congress and "},{"tag":"ref","attrib":{"href":"/us/pl/118/47/s113/a"},"text":"section 113(a) of Pub. L. 118–47","children":[],"tail":", div. D, title I, "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/646"},"text":"138 Stat. 646","children":[],"tail":", which set out an identical section designated as section 12 with the catchline “Security detail” and provided that act "},{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", was to be applied as if that section were part of it."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a505c78-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a505c79-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2026 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dB/tI/s113/b"},"text":"Pub. L. 119–75, div. B, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/256"},"text":"140 Stat. 256","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dB/tI/s113/b"},"text":"“This section [enacting this section] shall be effective on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
