{"tag":"section","attrib":{"id":"id5bac91a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3323"},"text":null,"children":[{"tag":"num","attrib":{"value":"3323"},"text":"§ 3323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local administrative cost limits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5bac91aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), of the amount that is made available under this subchapter to an eligible provider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac91ab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3323/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 95 percent shall be expended for carrying out adult education and literacy activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91ac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3323/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining amount, not to exceed 5 percent, shall be used for planning, administration (including carrying out the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141"},"text":"section 3141 of this title","children":[],"tail":"), professional development, and the activities described in paragraphs (3) and (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3322"},"text":"section 3322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac91ad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In cases where the cost limits described in subsection (a) are too restrictive to allow for the activities described in subsection (a)(2), the eligible provider shall negotiate with the eligible agency in order to determine an adequate level of funds to be used for noninstructional purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5bac91ae-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s233"},"text":"Pub. L. 113–128, title II, § 233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1620"},"text":"128 Stat. 1620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5bac91af-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5bac91b0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5bac91b1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
