{"tag":"section","attrib":{"id":"id5bac91c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332"},"text":null,"children":[{"tag":"num","attrib":{"value":"3332"},"text":"§ 3332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National leadership activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5bac91c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and carry out a program of national leadership activities to enhance the quality and outcomes of adult education and literacy activities and programs nationwide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac91c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national leadership activities described in subsection (a) shall include technical assistance, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac91c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to help States meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141"},"text":"section 3141 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request by a State, assistance provided to eligible providers in using performance accountability measures based on indicators described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141"},"text":"section 3141 of this title","children":[],"tail":", and data systems for the improvement of adult education and literacy activities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out rigorous research and evaluation on effective adult education and literacy activities, as well as estimating the number of adults functioning at the lowest levels of literacy proficiency, which shall be coordinated across relevant Federal agencies, including the Institute of Education Sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out an independent evaluation at least once every 4 years of the programs and activities under this subchapter, taking into consideration the evaluation subjects referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3224/a/2"},"text":"section 3224(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac91c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national leadership activities described in subsection (a) may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac91ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Technical assistance, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5bac91cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance related to professional development activities, and assistance for the purposes of developing, improving, identifying, and disseminating the most successful methods and techniques for providing adult education and literacy activities, based on scientifically valid research where available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in distance education and promoting and improving the use of technology in the classroom, including instruction in English language acquisition for English language learners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the development and dissemination of proven models for addressing the digital literacy needs of adults, including older adults; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting efforts aimed at strengthening programs at the State and local levels, such as technical assistance in program planning, assessment, evaluation, and monitoring of activities carried out under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funding national leadership activities either directly or through grants, contracts, or cooperative agreements awarded on a competitive basis to or with postsecondary educational institutions, institutions of higher education, public or private organizations or agencies (including public libraries), or consortia of such institutions, organizations, or agencies, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5bac91d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, improving, and identifying the most successful methods and techniques for addressing the education needs of adults, including instructional practices using the essential components of reading instruction based on the work of the National Institute of Child Health and Human Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting national, regional, or local networks of private nonprofit organizations, public libraries, or institutions of higher education to strengthen the ability of such networks’ members to meet the performance requirements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141"},"text":"section 3141 of this title","children":[],"tail":" of eligible providers;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increasing the effectiveness, and improving the quality, of adult education and literacy activities, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5bac91d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out rigorous research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out demonstration programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerating learning outcomes for eligible individuals with the lowest literacy levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and promoting career pathways for eligible individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting concurrent enrollment programs in adult education and credit bearing postsecondary coursework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing high-quality professional development activities for eligible providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing, replicating, and disseminating information on best practices and innovative programs, such as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5bac91da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of effective strategies for working with adults with learning disabilities and with adults who are English language learners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5bac91db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated education and training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5bac91dc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workplace adult education and literacy activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5bac91dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/C/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary education and training transition programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91de-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing for the conduct of an independent evaluation and assessment of adult education and literacy activities through grants and contracts awarded on a competitive basis, which shall include descriptions of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5bac91df-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of performance accountability measures and other measures of accountability on the delivery of adult education and literacy activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91e0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the adult education and literacy activities increase the literacy skills of eligible individuals, lead to involvement in education and training, enhance the employment and earnings of such participants, and, if applicable, lead to other positive outcomes, such as success in re-entry and reductions in recidivism in the case of prison-based adult education and literacy activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the provision of support services to eligible individuals enrolled in adult education and literacy activities increase the rate of enrollment in, and successful completion of, such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5bac91e2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which different types of providers measurably improve the skills of eligible individuals in adult education and literacy activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting data, such as data regarding the improvement of both local and State data systems, through technical assistance and development of model performance data collection systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining how participation in adult education and literacy activities prepares eligible individuals for entry into postsecondary education and employment and, in the case of programs carried out in correctional institutions, has an effect on recidivism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3332/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities designed to enhance the quality of adult education and literacy activities nationwide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5bac91e6-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s242"},"text":"Pub. L. 113–128, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1621"},"text":"128 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5bac91e7-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5bac91e8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5bac91e9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
