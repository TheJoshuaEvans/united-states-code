{"tag":"section","attrib":{"id":"id5a899566-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771"},"text":null,"children":[{"tag":"num","attrib":{"value":"771"},"text":"§ 771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of purpose and competitive basis of grants and contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a899567-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter to authorize grants and contracts to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a899568-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a899569-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide academic training to ensure that skilled personnel are available to provide rehabilitation services to individuals with disabilities through vocational, medical, social, and psychological rehabilitation programs (including supported employment programs), through economic and business development programs, through independent living services programs, and through client assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a89956a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training to maintain and upgrade basic skills and knowledge of personnel (including personnel specifically trained to deliver services to individuals with disabilities whose employment outcome is self-employment or telecommuting) employed to provide state-of-the-art service delivery and rehabilitation technology services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a89956b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct special projects and demonstrations that expand and improve the provision of rehabilitation and other services (including those services provided through community rehabilitation programs) authorized under this chapter, or that otherwise further the purposes of this chapter, including related research and evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a89956c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and information to individuals with disabilities and the individuals’ representatives, and other appropriate parties to develop the skills necessary for individuals with disabilities to gain access to the rehabilitation system and statewide workforce development systems and to become active decisionmakers in the rehabilitation process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a89956d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s771/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive basis of grants and contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that all grants and contracts are awarded under this subchapter on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a89956e-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIII/s301"},"text":"Pub. L. 93–112, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s406"},"text":"Pub. L. 105–220, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1183"},"text":"112 Stat. 1183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s441/a"},"text":"Pub. L. 113–128, title IV, § 441(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1672"},"text":"128 Stat. 1672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a8c056f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a8c0570-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a8c0571-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 771, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tIII/s301"},"text":"Pub. L. 93–112, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"t