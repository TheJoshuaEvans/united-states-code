128/s441/a/1"},"text":"Pub. L. 113–128, § 441(a)(1)","children":[],"tail":", inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s441/a/2"},"text":"Pub. L. 113–128, § 441(a)(2)","children":[],"tail":"–(4), redesignated par. (5) as (3), substituted “workforce development systems” for “workforce investment systems”, and struck out former pars. (3) and (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) provide vocational rehabilitation services to individuals with disabilities who are migrant or seasonal farmworkers;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) initiate recreational programs to provide recreational activities and related experiences for individuals with disabilities to aid such individuals in employment, mobility, socialization, independence, and community integration; and”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
