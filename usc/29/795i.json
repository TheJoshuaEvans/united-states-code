{"tag":"section","attrib":{"id":"id5a9ca81e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795i"},"text":null,"children":[{"tag":"num","attrib":{"value":"795i"},"text":"§ 795i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a9ca81f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supported employment services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this subchapter may be used to provide supported employment services to individuals who are eligible under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a9ca820-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9ca821-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), funds provided under this subchapter, or subchapter I, may not be used to provide extended services to individuals under this subchapter or subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9ca822-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended services for youth with the most significant disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds allotted under this subchapter, or subchapter I, and used for the provision of services under this subchapter to youth with the most significant disabilities pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s795h/d"},"text":"section 795h(d) of this title","children":[],"tail":", may be used to provide extended services to youth with the most significant disabilities. Such extended services shall be available for a period not to exceed 4 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a9ca823-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s604"},"text":"Pub. L. 93–112, title VI, § 604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s461/6"},"text":"Pub. L. 113–128, title IV, § 461(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1680"},"text":"128 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a9ca824-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a9ca825-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a9ca826-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A