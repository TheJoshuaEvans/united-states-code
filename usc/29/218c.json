{"tag":"section","attrib":{"id":"id5a4204f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c"},"text":null,"children":[{"tag":"num","attrib":{"value":"218c"},"text":"§ 218c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections for employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a4204f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No employer shall discharge or in any manner discriminate against any employee with respect to his or her compensation, terms, conditions, or other privileges of employment because the employee (or an individual acting at the request of the employee) has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a4204f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received a credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" or a subsidy under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071"},"text":"section 18071 of title 42","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a4204f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided, caused to be provided, or is about to provide or cause to be provided to the employer, the Federal Government, or the attorney general of a State information relating to any violation of, or any act or omission the employee reasonably believes to be a violation of, any provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (or an amendment made by this title); "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a4204f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testified or is about to testify in a proceeding concerning such violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a4204f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisted or participated, or is about to assist or participate, in such a proceeding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a4204fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objected to, or refused to participate in, any activity, policy, practice, or assigned task that the employee (or other such person) reasonably believed to be in violation of any provision of this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (or amendment), or any order, rule, regulation, standard, or ban under this title "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (or amendment)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a4204fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaint procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a4204fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee who believes that he or she has been discharged or otherwise discriminated against by any employer in violation of this section may seek relief in accordance with the procedures, notifications, burdens of proof, remedies, and statutes of limitation set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2087/b"},"text":"section 2087(b) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a4204fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No limitation on rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be deemed to diminish the rights, privileges, or remedies of any employee under any Federal or State law or under any collective bargaining agreement. The rights and remedies in this section may not be waived by any agreement, policy, form, or condition of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a4204fe-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676/s18C"},"text":"June 25, 1938, ch. 676, § 18C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1558"},"text":"Pub. L. 111–148, title I, § 1558","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/261"},"text":"124 Stat. 261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a4204ff-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a420500-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a420501-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071"},"text":"Section 18071 of title 42","children":[],"tail":", referred to in subsec. (a)(1), was in the original “section 1402 of this Act”, and was translated as meaning section 1402 of the Patient Protection and Affordable Care Act, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071"},"text":"section 18071 of title 42","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (a)(2), (5), probably means title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-03-23"},"text":"Mar. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":". For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2087/b"},"text":"Section 2087(b) of title 15","children":[],"tail":", referred to in subsec. (b)(1), was in the original “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2807/b"},"text":"section 2807(b) of title 15","children":[],"tail":"”, and probably should have read “section 40(b) of the Consumer Product Safety Act”, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2087/b"},"text":"section 2087(b) of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
