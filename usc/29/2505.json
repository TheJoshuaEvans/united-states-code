{"tag":"section","attrib":{"id":"id5b628f86-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2505"},"text":null,"children":[{"tag":"num","attrib":{"value":"2505"},"text":"§ 2505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To be eligible to be selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2503/b"},"text":"section 2503(b) of this title","children":[],"tail":" to receive technical assistance provided with grants made under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2503/a"},"text":"section 2503(a) of this title","children":[],"tail":", an employer or labor union shall submit an application to the Secretary at such time, in such manner and containing or accompanied by such information as the Secretary may reasonably require. At a minimum, the application should include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b628f87-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the need for technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f88-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of apprenticeable occupations or nontraditional occupations in which the employer or labor union would like to train or employ women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f89-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that there are or will be suitable and appropriate positions available in the apprenticeable occupations program or in the nontraditional occupations being targeted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b628f8a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commitments that reasonable efforts shall be made to place qualified women in apprenticeable occupations or nontraditional occupations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b628f8b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/530/s6"},"text":"Pub. L. 102–530, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3467"},"text":"106 Stat. 3467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
