"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569/s908/a"},"text":"Pub. L. 102–569, § 908(a)","children":[],"tail":", (c)(1), substituted “Youths and Adults who are Deaf-Blind” for “Deaf-Blind Youths and Adults” and “individuals who are deaf-blind” for “deaf-blind individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569/s901/2"},"text":"Pub. L. 102–569, § 901(2)","children":[],"tail":", substituted “made a substantial investment” for “invested approximately $10,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5b638f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id5b5b6390-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/221/tII/s201"},"text":"Pub. L. 98–221, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/32"},"text":"98 Stat. 32","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/221/tII/s201"},"text":"“This title [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s777"},"text":"section 777 of this title","children":[],"tail":", and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s777c"},"text":"section 777c of this title","children":[],"tail":"] may be cited as the ‘Helen Keller National Center Act’.”"}],"tail":"\n"}],"tail":"\n"}]