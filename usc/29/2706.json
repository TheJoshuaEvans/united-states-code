{"tag":"section","attrib":{"id":"id5b69bb9f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2706"},"text":null,"children":[{"tag":"num","attrib":{"value":"2706"},"text":"§ 2706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b69bba0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this chapter such sums as may be necessary for each of the fiscal years 1995 through 1997.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b69bba1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under subsection (a) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b69bba2-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV/s547"},"text":"Pub. L. 103–382, title V, § 547","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4055"},"text":"108 Stat. 4055","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
