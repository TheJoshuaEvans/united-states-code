{"tag":"section","attrib":{"id":"id5b249cb6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1193c"},"text":"§ 1193c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress on emergency savings accounts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor and the Secretary of the Treasury shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b249cb7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a study on the use of emergency savings from individual account plan accounts, including emergency savings from a pension-linked emergency savings account regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b249cb8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the amount of the dollar limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1193/d/1/A"},"text":"section 1193(d)(1)(A) of this title","children":[],"tail":" is sufficient;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249cb9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the limitation on the contribution rate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1193/d/2/A"},"text":"section 1193(d)(2)(A) of this title","children":[],"tail":" is appropriate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b249cba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which plan sponsors offer such accounts and participants participate in such accounts and the resulting impact on participant retirement savings, including the impact on retirement savings leakage and the effect of such accounts on retirement plan participation by low- and moderate-income households; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b249cbb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1193c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 7 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"December 29, 2022","children":[],"tail":", submit to Congress a report on the findings of the study under paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b249cbc-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s804"},"text":"Pub. L. 93–406, title I, § 804","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s127/b/1"},"text":"Pub. L. 117–328, div. T, title I, § 127(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5323"},"text":"136 Stat. 5323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b249cbd-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b249cbe-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b249cbf-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"Dec. 31, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s127/g"},"text":"section 127(g) of Pub. L. 117–328","children":[],"tail":", set out as an Effective Date of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
