{"tag":"section","attrib":{"id":"id5a9ca807-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795g"},"text":null,"children":[{"tag":"num","attrib":{"value":"795g"},"text":"§ 795g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this subchapter to authorize allotments, in addition to grants for vocational rehabilitation services under subchapter I, to assist States in developing collaborative programs with appropriate entities to provide supported employment services for individuals with the most significant disabilities, including youth with the most significant disabilities, to enable such individuals to achieve an employment outcome of supported employment in competitive integrated employment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a9ca808-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s602"},"text":"Pub. L. 93–112, title VI, § 602","children":[],"tail":", formerly § 621, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s409"},"text":"Pub. L. 105–220, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1214"},"text":"112 Stat. 1214","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/b/12"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(b)(12)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–414; renumbered § 602 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s461/3"},"text":"Pub. L. 113–128, title IV