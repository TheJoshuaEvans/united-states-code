{"tag":"section","attrib":{"id":"id5b56a97a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1815"},"text":null,"children":[{"tag":"num","attrib":{"value":"1815"},"text":"§ 1815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of address change; amendment of certificate of registration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"During the period for which the certificate of registration is in effect, each farm labor contractor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b56a97b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1815/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Secretary within thirty days a notice of each change of permanent place of residence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b56a97c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1815/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" apply to the Secretary to amend the certificate of registration whenever the farm labor contractor intends to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b56a97d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1815/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in another farm labor contracting activity,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b56a97e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1815/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, or cause to be used, another vehicle than that covered by the certificate to transport any migrant or seasonal agricultural worker, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b56a97f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1815/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, or cause to be used, another real property or facility to house any migrant agricultural worker than that covered by the certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b56a980-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/tI/s105"},"text":"Pub. L. 97–470, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2589"},"text":"96 Stat. 2589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b56a981-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b56a982-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b56a983-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days from ","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/470/s524"},"text":"section 524 of Pub. L. 97–470","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
