{"tag":"section","attrib":{"id":"id5a041143-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"§ 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design and duties of bureau generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The general design and duties of the Bureau of Labor Statistics shall be to acquire and diffuse among the people of the United States useful information on subjects connected with labor, in the most general and comprehensive sense of that word, and especially upon its relation to capital, the hours of labor, the earnings of laboring men and women, and the means of promoting their material, social, intellectual, and moral prosperity.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a041144-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1888-06-13/ch389/s1"},"text":"June 13, 1888, ch. 389, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/182"},"text":"25 Stat. 182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s4"},"text":"Feb. 14, 1903, ch. 552, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/826"},"text":"32 Stat. 826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1904-03-18/ch716"},"text":"Mar. 18, 1904, ch. 716","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/136"},"text":"33 Stat. 136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s3"},"text":"Mar. 4, 1913, ch. 141, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/737"},"text":"37 Stat. 737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a041145-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a041146-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a041147-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1884-06-27"},"text":"June 27, 1884","children":[],"tail":", created Bureau of Labor in Department of the Interior."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1 of act ","children":[{"tag":"date","attrib":{"date":"1888-06-13"},"text":"June 13, 1888","children":[],"tail":", created Department of Labor and outlined its general design and duties, and section 9 of that act transferred Bureau of Labor to Department of Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":", placed Department of Labor under jurisdiction and made it a part of Department of Commerce and Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1904-03-18"},"text":"Mar. 18, 1904","children":[],"tail":", changed name of Department of Labor to Bureau of Labor in Department of Commerce and Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", created Department of Labor and transferred Bureau of Labor from Department of Commerce and Labor to newly created Department of Labor, redesignating such transferred Bureau as Bureau of Labor Statistics."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id5a041148-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5a041149-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of Labor, with certain exceptions, to Secretary of Labor, with power to delegate, see Reorg. Plan No. 6 of 1950, §§ 1, 2, 15 F.R. 3174, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
