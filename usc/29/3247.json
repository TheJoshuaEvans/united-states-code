{"tag":"section","attrib":{"id":"id5ba564dc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3247"},"text":null,"children":[{"tag":"num","attrib":{"value":"3247"},"text":"§ 3247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ba564dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba564de-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3247/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any final order by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3246"},"text":"section 3246 of this title","children":[],"tail":" by which the Secretary awards, declines to award, or only conditionally awards, financial assistance under this subchapter, or any final order of the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3246"},"text":"section 3246 of this title","children":[],"tail":" with respect to a corrective action or sanction imposed under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3244"},"text":"section 3244 of this title","children":[],"tail":", any party to a proceeding that resulted in such final order may obtain review of such final order in the United States Court of Appeals having jurisdiction over the applicant for or recipient of the funds involved, by filing a review petition within 30 days after the date of issuance of such final order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564df-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3247/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action on petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The clerk of the court shall transmit a copy of the review petition to the Secretary, who shall file the record on which the final order was entered as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":". The filing of a review petition shall not stay the order of the Secretary, unless the court orders a stay. Petitions filed under this subsection shall be heard expeditiously, if possible within 10 days after the date of filing of a reply to the petition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564e0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3247/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard and scope of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No objection to the order of the Secretary shall be considered by the court unless the objection was specifically urged, in a timely manner, before the Secretary. The review shall be limited to questions of law and the findings of fact of the Secretary shall be conclusive if supported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba564e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall have jurisdiction to make and enter a decree affirming, modifying, or setting aside the order of the Secretary in whole or in part. The judgment of the court regarding the order shall be final, subject to certiorari review by the Supreme Court as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254/1"},"text":"section 1254(1) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ba564e2-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s187"},"text":"Pub. L. 113–128, title I, § 187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1597"},"text":"128 Stat. 1597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ba564e3-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ba564e4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5ba564e5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
