{"tag":"section","attrib":{"id":"id5b1d70e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1185h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1185h"},"text":"§ 1185h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of price comparison tool","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A group health plan or a health insurance issuer offering group health insurance coverage shall offer price comparison guidance by telephone and make available on the Internet website of the plan or issuer a price comparison tool that (to the extent practicable) allows an individual enrolled under such plan or coverage, with respect to such plan year, such geographic region, and participating providers with respect to such plan or coverage, to compare the amount of cost-sharing that the individual would be responsible for paying under such plan or coverage with respect to the furnishing of a specific item or service by any such provider.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b1d70e2-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s719"},"text":"Pub. L. 93–406, title I, § 719","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tI/s114/c/1"},"text":"Pub. L. 116–260, div. BB, title I, § 114(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2874"},"text":"134 Stat. 2874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b1d70e3-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b1d70e4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b1d70e5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to plan years beginning on or after ","children":[{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/s114/d"},"text":"section 114(d) of div. BB of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9819"},"text":"section 9819 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
