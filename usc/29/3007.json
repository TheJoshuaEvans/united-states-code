{"tag":"section","attrib":{"id":"id5b70e7fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b70e7fe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e7ff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Administrator of the Administration for Community Living of the Department of Health and Human Services (referred to in this section as the “Administrator”) shall be responsible for the administration of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e800-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall consult with the Office of Special Education Programs of the Department of Education, the Rehabilitation Services Administration of the Department of Education, the Office of Disability Employment Policy of the Department of Labor, and other appropriate Federal entities in the administration of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e801-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e802-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering this chapter, the Administrator shall ensure that programs funded under this chapter will address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b70e803-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of individuals with all types of disabilities and across the lifespan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b70e804-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of assistive technology in all potential environments, including employment, education, and community living.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e805-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, not more than ½ of 1 percent of the total funding appropriated for this chapter shall be used by the Administrator to support the administration of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e806-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of participating entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e807-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assess the extent to which entities that receive grants under this chapter are complying with the applicable requirements of this chapter and achieving measurable goals that are consistent with the requirements of the grant programs under which the entities received the grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e808-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Secretary in carrying out the responsibilities of the Secretary under this section, the Secretary may require States to provide relevant information, including the information required under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e809-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrective action and sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e80a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrective action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that an entity that receives a grant under this chapter fails to substantially comply with the applicable requirements of this chapter, or to make substantial progress toward achieving the measurable goals described in subsection (b)(1) with respect to the grant program, the Secretary shall assist the entity, through technical assistance funded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3005"},"text":"section 3005 of this title","children":[],"tail":" or other means, within 90 days after such determination, to develop a corrective action plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e80b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the entity fails to develop and comply with a corrective action plan described in paragraph (1) during a fiscal year, the entity shall be subject to 1 of the following corrective actions selected by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e80c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Partial or complete termination of funding under the grant program, until the entity develops and complies with such a plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e80d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ineligibility to participate in the grant program in the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e80e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduction in the amount of funding that may be used for indirect costs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":" for the following fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e80f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Required redesignation of the lead agency designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/c/1"},"text":"section 3003(c)(1) of this title","children":[],"tail":" or an entity responsible for administering the grant program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e810-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish appeals procedures for entities that are determined to be in noncompliance with the applicable requirements of this chapter, or have not made substantial progress toward achieving the measurable goals described in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e811-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the annual report required under subsection (d), the Secretary shall describe each such action taken under paragraph (1) or (2) and the outcomes of each such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e812-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after taking an action under paragraph (1) or (2), the Secretary shall notify the public, by posting on an easily accessible portion of the internet website of the Department of Health and Human Services, notification of each action taken by the Secretary under paragraph (1) or (2). As a part of such notification, the Secretary shall describe each such action taken under paragraph (1) or (2) and the outcomes of each such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e813-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e814-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than December 31 of each year, the Secretary shall prepare and submit to the President, the Committee on Health, Education, Labor, and Pensions of the Senate, and the Committee on Education and Labor of the House of Representatives a report on the activities funded under this chapter to improve the access of assistive technology devices and assistive technology services to individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e815-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e816-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compilation and summary of the information provided by the States in annual progress reports submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/f"},"text":"section 3003(f) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b70e817-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the State applications described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/d"},"text":"section 3003(d) of this title","children":[],"tail":" and an analysis of the progress of the States in meeting the measurable goals established in State applications under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003/d/3/C"},"text":"section 3003(d)(3)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e818-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the enforcement authority of the Secretary, another Federal officer, or a court under any other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e819-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3007/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter may not be construed as authorizing a Federal or State agency to reduce medical or other assistance available, or to alter eligibility for a benefit or service, under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b70e81a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/394/s8"},"text":"Pub. L. 105–394, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/364/s2"},"text":"Pub. L. 108–364, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1736"},"text":"118 Stat. 1736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5402"},"text":"Pub. L. 117–263, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3287"},"text":"136 Stat. 3287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b70e81b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b70e81c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b70e81d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section authorized appropriations to carry out sections 3003 to 3005 of this title for fiscal years 2005 through 2010."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b70e81e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5b70e81f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b70e820-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" effective on the day that is 6 months after "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5403"},"text":"section 5403 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
