{"tag":"section","attrib":{"id":"id5b412596-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365"},"text":null,"children":[{"tag":"num","attrib":{"value":"1365"},"text":"§ 1365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report of plan administrator","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For each plan year for which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1321"},"text":"section 1321 of this title","children":[],"tail":" applies to a plan, the plan administrator shall file with the corporation, on a form prescribed by the corporation, an annual report which identifies the plan and plan administrator and which includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b412597-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of each notification required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1363"},"text":"section 1363 of this title","children":[],"tail":" with respect to such year,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b412598-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement disclosing whether any reportable event (described in section 1343(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002175"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002175"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) occurred during the plan year except to the extent the corporation waives such requirement, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b412599-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a multiemployer plan, information with respect to such plan which the corporation determines is necessary for the enforcement of subtitle E and requires by regulation, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b41259a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement certified by the plan’s enrolled actuary of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b41259b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of all vested benefits under the plan as of the end of the plan year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b41259c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the plan’s assets as of the end of the plan year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b41259d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement certified by the plan sponsor of each claim for outstanding withdrawal liability (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1301/a/12"},"text":"section 1301(a)(12) of this title","children":[],"tail":") and its value as of the end of that plan year and as of the end of the preceding plan year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b41259e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1365/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employers having an obligation to contribute to the plan and the number of employers required to make withdrawal liability payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The report shall be filed within 6 months after the close of the plan year to which it relates. The corporation shall cooperate with the Secretary of the Treasury and the Secretary of Labor in an endeavor to coordinate the timing and content, and possibly obtain the combination, of reports under this section with reports required to be made by plan administrators to such Secretaries.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b41259f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4065"},"text":"Pub. L. 93–406, title IV, § 4065","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1032"},"text":"88 Stat. 1032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s106"},"text":"Pub. L. 96–364, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1266"},"text":"94 Stat. 1266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b4125a0-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b4125a1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b4125a2-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1343/b"},"text":"Section 1343(b) of this title","children":[],"tail":", referred to in par. (2), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1343/c"},"text":"section 1343(c) of this title","children":[],"tail":" and a new section 1343(b) was added by "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVII/s771/b"},"text":"Pub. L. 103–465, title VII, § 771(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5042"},"text":"108 Stat. 5042","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b4125a3-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" inserted provisions in par. (2) respecting waiver by corporation and added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b4125a4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b4125a5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
