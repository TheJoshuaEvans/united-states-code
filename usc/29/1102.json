{"tag":"section","attrib":{"id":"id5af4d9d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5af4d9d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Named fiduciaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5af4d9d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every employee benefit plan shall be established and maintained pursuant to a written instrument. Such instrument shall provide for one or more named fiduciaries who jointly or severally shall have authority to control and manage the operation and administration of the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af4d9d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subchapter, the term “named fiduciary” means a fiduciary who is named in the plan instrument, or who, pursuant to a procedure specified in the plan, is identified as a fiduciary (A) by a person who is an employer or employee organization with respect to the plan or (B) by such an employer and such an employee organization acting jointly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5af4d9d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requisite features of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every employee benefit plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5af4d9d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a procedure for establishing and carrying out a funding policy and method consistent with the objectives of the plan and the requirements of this subchapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af4d9da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe any procedure under the plan for the allocation of responsibilities for the operation and administration of the plan (including any procedure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1105/c/1"},"text":"section 1105(c)(1) of this title","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af4d9db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a procedure for amending such plan, and for identifying the persons who have authority to amend the plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af4d9dc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the basis on which payments are made to and from the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5af4d9dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional features of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any employee benefit plan may provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5af4d9de-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any person or group of persons may serve in more than one fiduciary capacity with respect to the plan (including service both as trustee and administrator);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af4d9df-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a named fiduciary, or a fiduciary designated by a named fiduciary pursuant to a plan procedure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1105/c/1"},"text":"section 1105(c)(1) of this title","children":[],"tail":", may employ one or more persons to render advice with regard to any responsibility such fiduciary has under the plan; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af4d9e0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a person who is a named fiduciary with respect to control or management of the assets of the plan may appoint an investment manager or managers to manage (including the power to acquire and dispose of) any assets of a plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5af4d9e1-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s402"},"text":"Pub. L. 93–406, title I, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/875"},"text":"88 Stat. 875","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
