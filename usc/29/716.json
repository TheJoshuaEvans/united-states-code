{"tag":"section","attrib":{"id":"id5a6f5653-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s716"},"text":null,"children":[{"tag":"num","attrib":{"value":"716"},"text":"§ 716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6f5654-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), and notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6f5655-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s716/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds appropriated for a fiscal year to carry out any grant program under part B of subchapter I, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794e"},"text":"section 794e of this title","children":[],"tail":" (except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s794e/b"},"text":"section 794e(b) of this title","children":[],"tail":"), subchapter VI, subpart 2 or 3 of part A of subchapter VII, or part B of subchapter VII (except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796k/b"},"text":"section 796k(b) of this title","children":[],"tail":"), including any funds reallotted under any such grant program, that are not obligated and expended by recipients prior to the beginning of the succeeding fiscal year; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6f5656-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s716/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts of program income, including reimbursement payments under the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.), received by recipients under any grant program specified in paragraph (1) that are not obligated and expended by recipients prior to the beginning of the fiscal year succeeding the fiscal year in which such amounts were received,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall remain available for obligation and expenditure by such recipients during such succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6f5657-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such funds shall remain available for obligation and expenditure by a recipient as provided in subsection (a) only to the extent that the recipient complied with any Federal share requirements applicable to the program for the fiscal year for which the funds were appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6f5658-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s19"},"text":"Pub. L. 93–112, § 19","children":[],"tail":", formerly § 17, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1114"},"text":"112 Stat. 1114","children":[],"tail":"; renumbered § 19 and amended "},{"tag":"re