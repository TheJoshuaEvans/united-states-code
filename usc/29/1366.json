{"tag":"section","attrib":{"id":"id5b4125a6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1366"},"text":null,"children":[{"tag":"num","attrib":{"value":"1366"},"text":"§ 1366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual notification to substantial employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The plan administrator of each single-employer plan which has at least two contributing sponsors at least two of whom are not under common control shall notify, within 6 months after the close of each plan year, any contributing sponsor of the plan who is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1301/a/2"},"text":"section 1301(a)(2) of this title","children":[],"tail":" that such contributing sponsor (alone or together with members of such contributing sponsor’s controlled group) constitutes a substantial employer for that year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b4125a7-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4066"},"text":"Pub. L. 93–406, title IV, § 4066","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1032"},"text":"88 Stat. 1032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIV/s403/j"},"text":"Pub. L. 96–364, title IV, § 403(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1301"},"text":"94 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXI/s11016/a/5/C"},"text":"Pub. L. 99–272, title XI, § 11016(a)(5)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/271"},"text":"100 Stat. 271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7893/g/2"},"text":"Pub. L. 101–239, title VII, § 7893(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2447"},"text":"103 Stat. 2447","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b4125a8-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b4125a9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b4125aa-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" inserted “any” before “contributing sponsor of the plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" substituted “each single-employer plan which has at least two contributing sponsors at least two of whom are not under common control” for “each plan under which contributions are made by more than one employer (other than a multiemployer plan)”, “contributing sponsor of the plan” for “any employer making contributions under that plan”, and “that such contributing sponsor (alone or together with members of such contributing sponsor’s controlled group) constitutes a substantial employer” for “that he is a substantial employer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","child