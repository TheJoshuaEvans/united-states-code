{"tag":"section","attrib":{"id":"id5b07ecac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1144a"},"text":"§ 1144a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of church welfare plan status under State insurance law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b07ecad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the status of a church plan that is a welfare plan under provisions of a State insurance law described in subsection (b), such a church plan (and any trust under such plan) shall be deemed to be a plan sponsored by a single employer that reimburses costs from general church assets, or purchases insurance coverage with general church assets, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ecae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State insurance law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State insurance law described in this subsection is a law that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b07ecaf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires a church plan, or an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s414/e/3/A"},"text":"section 414(e)(3)(A) of title 26","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/33/C/i"},"text":"section 1002(33)(C)(i) of this title","children":[],"tail":" to the extent that it is administering or funding such a plan, to be licensed; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ecb0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates solely to the solvency or insolvency of a church plan (including participation in State guaranty funds and associations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ecb1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b07ecb2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Church plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “church plan” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s414/e"},"text":"section 414(e) of title 26","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/33"},"text":"section 1002(33) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ecb3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimburses costs from general church assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reimburses costs from general church assets” means engaging in an activity that is not the spreading of risk solely for the purposes of the provisions of State insurance laws described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ecb4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Welfare plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “welfare plan”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ecb5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any church plan to the extent that such plan provides medical, surgical, or hospital care or benefits, or benefits in the event of sickness, accident, disability, death or unemployment, or vacation benefits, apprenticeship or other training programs, or day care centers, scholarship funds, or prepaid legal services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ecb6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any entity, such as a health insurance issuer described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9832/b/2"},"text":"section 9832(b)(2) of title 26","children":[],"tail":" or a health maintenance organization described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9832/b/3"},"text":"section 9832(b)(3) of title 26","children":[],"tail":", or any other organization that does business with the church plan or organization sponsoring or maintaining such a plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ecb7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, for purposes of enforcing provisions of State insurance laws that apply to a church plan that is a welfare plan, the church plan shall be subject to State enforcement as if the church plan were an insurer licensed by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ecb8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), the application of this section is limited to determining the status of a church plan that is a welfare plan under the provisions of State insurance laws described in subsection (b). This section shall not otherwise be construed to recharacterize the status, or modify or affect the rights, of any plan participant or beneficiary, including participants or beneficiaries who make plan contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b07ecb9-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/244/s2"},"text":"Pub. L. 106–244, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-10"},"text":"July 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/499"},"text":"114 Stat. 499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b07ecba-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b07ecbb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5b07ecbc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Employee Retirement Income Security Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b07ecbd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/244/s1"},"text":"Pub. L. 106–244, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-07-10"},"text":"July 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/499"},"text":"114 Stat. 499","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/244/s1"},"text":"“The purpose of this Act [enacting this section] is only to clarify the application to a church plan that is a welfare plan of State insurance laws that require or solely relate to licensing, solvency, insolvency, or the status of such plan as a single employer plan.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
