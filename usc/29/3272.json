{"tag":"section","attrib":{"id":"id5baa1f9f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272"},"text":null,"children":[{"tag":"num","attrib":{"value":"3272"},"text":"§ 3272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa1fa0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “adult education” means academic instruction and education services below the postsecondary level that increase an individual’s ability to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fa1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" read, write, and speak in English and perform mathematics or other activities necessary for the attainment of a secondary school diploma or its recognized equivalent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fa2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transition to postsecondary education and training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fa3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fa4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adult education and literacy activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adult education and literacy activities” means programs, activities, and services that include adult education, literacy, workplace adult education and literacy activities, family literacy activities, English language acquisition activities, integrated English literacy and civics education, workforce preparation activities, or integrated education and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fa5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible agency” means the sole entity or agency in a State or an outlying area responsible for administering or supervising policy for adult education and literacy activities in the State or outlying area, respectively, consistent with the law of the State or outlying area, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fa6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible individual” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fa7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has attained 16 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fa8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not enrolled or required to be enrolled in secondary school under State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fa9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5baa1faa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is basic skills deficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5baa1fab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a secondary school diploma or its recognized equivalent, and has not achieved an equivalent level of education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5baa1fac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an English language learner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible provider","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible provider” means an organization that has demonstrated effectiveness in providing adult education and literacy activities that may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1faf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based organization or faith-based organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a volunteer literacy organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public or private nonprofit agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a library;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public housing authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit institution that is not described in any of subparagraphs (A) through (G) and has the ability to provide adult education and literacy activities to eligible individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium or coalition of the agencies, organizations, institutions, libraries, or authorities described in any of subparagraphs (A) through (H); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fb7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership between an employer and an entity described in any of subparagraphs (A) through (I).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fb8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" English language acquisition program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “English language acquisition program” means a program of instruction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fb9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to help eligible individuals who are English language learners achieve competence in reading, writing, speaking, and comprehension of the English language; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that leads to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5baa1fbb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5baa1fbc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attainment of a secondary school diploma or its recognized equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5baa1fbd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transition to postsecondary education and training; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5baa1fbe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fbf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" English language learner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “English language learner” when used with respect to an eligible individual, means an eligible individual who has limited ability in reading, writing, speaking, or comprehending the English language, and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fc0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose native language is a language other than English; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fc1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who lives in a family or community environment where a language other than English is the dominant language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fc2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential components of reading instruction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “essential components of reading instruction” means explicit and systematic instruction in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fc3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phonemic awareness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fc4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phonics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fc5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vocabulary development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fc6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reading fluency, including oral reading skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fc7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reading comprehension strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fc8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family literacy activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “family literacy activities” means activities that are of sufficient intensity and quality, to make sustainable improvements in the economic prospects for a family and that better enable parents or family members to support their children’s learning needs, and that integrate all of the following activities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fc9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parent or family adult education and literacy activities that lead to readiness for postsecondary education or training, career advancement, and economic self-sufficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interactive literacy activities between parents or family members and their children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fcb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training for parents or family members regarding how to be the primary teacher for their children and full partners in the education of their children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fcc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An age-appropriate education to prepare children for success in school and life experiences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fcd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated education and training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “integrated education and training” means a service approach that provides adult education and literacy activities concurrently and contextually with workforce preparation activities and workforce training for a specific occupation or occupational cluster for the purpose of educational and career advancement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fcf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated English literacy and civics education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “integrated English literacy and civics education” means education services provided to English language learners who are adults, including professionals with degrees and credentials in their native countries, that enables such adults to achieve competency in the English language and acquire the basic and more advanced skills needed to function effectively as parents, workers, and citizens in the United States. Such services shall include instruction in literacy and English language acquisition and instruction on the rights and responsibilities of citizenship and civic participation, and may include workforce training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fd0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Literacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “literacy” means an individual’s ability to read, write, and speak in English, compute, and solve problems, at levels of proficiency necessary to function on the job, in the family of the individual, and in society.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fd1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postsecondary educational institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “postsecondary educational institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa1fd2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education that provides not less than a 2-year program of instruction that is acceptable for credit toward a bachelor’s degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fd3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribally controlled college or university; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa1fd4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit educational institution offering certificate or apprenticeship programs at the postsecondary level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fd5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fd6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workplace adult education and literacy activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “workplace adult education and literacy activities” means adult education and literacy activities offered by an eligible provider in collaboration with an employer or employee organization at a workplace or an off-site location that is designed to improve the productivity of the workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa1fd7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3272/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce preparation activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “workforce preparation activities” means activities, programs, or services designed to help an individual acquire a combination of basic academic skills, critical thinking skills, digital literacy skills, and self-management skills, including competencies in utilizing resources, using information, working with others, understanding systems, and obtaining skills necessary for successful transition into and completion of postsecondary education or training, or employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5baa1fd8-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s203"},"text":"Pub. L. 113–128, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1609"},"text":"128 Stat. 1609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/c"},"text":"Pub. L. 114–95, title IX, § 9215(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2166"},"text":"129 Stat. 2166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5baa1fd9-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5baa1fda-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5baa1fdb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":", which directed general amendment of “Paragraph (8) of section 203 of the Adult Education and Literacy Act”, was executed by amending par. (8) of this section, which is section 203 of the Adult Education and Family Literacy Act, "},{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", to reflect the probable intent of Congress. Prior to amendment, text read as follows: “The term ‘essential components of reading instruction’ has the meaning given the term in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6368"},"text":"section 6368 of title 20","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5baa1fdc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5baa1fdd-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5baa1fde-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
