{"tag":"section","attrib":{"id":"id5a7dae51-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730"},"text":null,"children":[{"tag":"num","attrib":{"value":"730"},"text":"§ 730.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allotments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a7dae52-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation; additional amount; minimum amount; adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7dae53-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the provisions of subsections (c) and (d),,","children":[{"tag":"ref","attrib":{"idref":"fn002048"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002048"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" for each fiscal year beginning before "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":", each State shall be entitled to an allotment of an amount bearing the same ratio to the amount authorized to be appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s720/b/1"},"text":"section 720(b)(1) of this title","children":[],"tail":" for allotment under this section as the product of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7dae54-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae55-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the square of its allotment percentage,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"bears to the sum of the corresponding products for all the States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae56-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7dae57-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year beginning on or after ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":", each State shall be entitled to an allotment in an amount equal to the amount such State received under paragraph (1) for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", and an additional amount determined pursuant to subparagraph (B) of this paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7dae58-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each fiscal year beginning on or after ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":", each State shall be entitled to an allotment, from any amount authorized to be appropriated for such fiscal year under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s720/b/1"},"text":"section 720(b)(1) of this title","children":[],"tail":" for allotment under this section in excess of the amount appropriated under section 720(b)(1)(A) "},{"tag":"ref","attrib":{"idref":"fn002049"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", in an amount equal to the sum of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id5a7dae59-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount bearing the same ratio to 50 percent of such excess amount as the product of the population of the State and the square of its allotment percentage bears to the sum of the corresponding products for all the States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a7dae5a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount bearing the same ratio to 50 percent of such excess amount as the product of the population of the State and its allotment percentage bears to the sum of the corresponding products for all the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae5b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sum of the payment to any State (other than Guam, American Samoa, the Virgin Islands, and the Commonwealth of the Northern Mariana Islands) under this subsection for any fiscal year which is less than ⅓ of 1 percent of the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s720/b/1"},"text":"section 720(b)(1) of this title","children":[],"tail":", or $3,000,000, whichever is greater, shall be increased to that amount, the total of the increases thereby required being derived by proportionately reducing the allotment to each of the remaining such States under this subsection, but with such adjustments as may be necessary to prevent the sum of the allotments made under this subsection to any such remaining State from being thereby reduced to less than that amount."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7dae5c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unused funds; redistribution; increase in amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7dae5d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 45 days prior to the end of the fiscal year, the Commissioner shall determine, after reasonable opportunity for the submission to the Commissioner of comments by the State agency administering or supervising the program established under this subchapter, that any payment of an allotment to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s731/a"},"text":"section 731(a) of this title","children":[],"tail":" for any fiscal year will not be utilized by such State in carrying out the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae5e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable but not later than the end of the fiscal year, the Commissioner shall make such amount available for carrying out the purposes of this subchapter to one or more other States to the extent the Commissioner determines such other State will be able to use such additional amount during that fiscal year or the subsequent fiscal year for carrying out such purposes. The Commissioner shall make such amount available only if such other State will be able to make sufficient payments from non-Federal sources to pay for the non-Federal share of the cost of vocational rehabilitation services under the State plan for the fiscal year for which the amount was appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae5f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this part, any amount made available to a State for any fiscal year pursuant to this subsection shall be regarded as an increase of such State’s allotment (as determined under the preceding provisions of this section) for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7dae60-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for American Indian vocational rehabilitation services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7dae61-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2015 and for each subsequent fiscal year, the Commissioner shall reserve from the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s720/b/1"},"text":"section 720(b)(1) of this title","children":[],"tail":" for allotment under this section a sum, determined under paragraph (2), to carry out the purposes of part C."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae62-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sum referred to in paragraph (1) shall be, as determined by the Secretary, not less than 1 percent and not more than 1.5 percent of the amount referred to in paragraph (1), for each of fiscal years 2015 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7dae63-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for pre-employment transition services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7dae64-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From any State allotment under subsection (a) for a fiscal year, the State shall reserve not less than 15 percent of the allotted funds for the provision of pre-employment transition services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7dae65-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s730/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such reserved funds shall not be used to pay for the administrative costs of providing pre-employment transition services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a7dae66-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s110"},"text":"Pub. L. 93–112, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s404"},"text":"Pub. L. 105–220, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1160"},"text":"112 Stat. 1160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/b/7"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(b)(7)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–413; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s419"},"text":"Pub. L. 113–128, title IV, § 419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1656"},"text":"128 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a7dae67-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a7dae68-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"references