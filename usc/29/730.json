). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s419/1"},"text":"Pub. L. 113–128, § 419(1)","children":[],"tail":", substituted “Subject to the provisions of subsections (c) and (d),” for “Subject to the provisions of subsection (c)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s419/2/A"},"text":"Pub. L. 113–128, § 419(2)(A)","children":[],"tail":", substituted “2015” for “1987”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s419/2/B"},"text":"Pub. L. 113–128, § 419(2)(B)","children":[],"tail":", substituted “Secretary,” for “Secretary—” and “2015 through 2020” for “2000 through 2003”, struck out subpar. (B) designation before “not less than 1 percent”, and struck out subpar. (A) which read as follows: “not less than three-quarters of 1 percent and not more than 1.5 percent of the amount referred to in paragraph (1), for fiscal year 1999; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s419/3"},"text":"Pub. L. 113–128, § 419(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" made technical amendment to section designation and catchline in original."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a7dae6c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id5a7dae6d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions of Terms in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s3"},"text":"section 3 of Pub. L. 113–128","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":", apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
