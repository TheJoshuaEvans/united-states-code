{"tag":"section","attrib":{"id":"id5b5dd4a8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1904"},"text":null,"children":[{"tag":"num","attrib":{"value":"1904"},"text":"§ 1904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5dd4a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to carry out the provisions of this chapter such sums as may be necessary for each of the fiscal years 1999 through 2003. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any appropriation Act containing any appropriation authorized by subsection (a) shall contain a statement of the specific amount being made available to the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd4ab-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/221/tII/s205"},"text":"Pub. L. 98–221, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/33"},"text":"98 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tIX/s901"},"text":"Pub. L. 99–506, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1840"},"text":"100 Stat. 1840","children":[],"ta