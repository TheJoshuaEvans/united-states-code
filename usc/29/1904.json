pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":" substituted “1999 through 2003” for “1993 through 1997”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569"},"text":"Pub. L. 102–569","children":[],"tail":" substituted “1993 through 1997” for “1987 through 1992”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/52"},"text":"Pub. L. 102–52","children":[],"tail":" substituted “1992” for “1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/630"},"text":"Pub. L. 100–630","children":[],"tail":" substituted “1991” for “1990”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/506"},"text":"Pub. L. 99–506","children":[],"tail":" amended first sentence generally. Prior to amendment, first sentence read as follows: “There are authorized to be appropriated $4,000,000 for the fiscal year 1984, $4,200,000 for the fiscal year 1985, and $4,300,000 for the fiscal year 1986 to carry out the provisions of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
