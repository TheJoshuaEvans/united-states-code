{"tag":"section","attrib":{"id":"id5b5dd4f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001"},"text":"§ 2001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commerce” has the meaning provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s203/b"},"text":"section 203(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employer” includes any person acting directly or indirectly in the interest of an employer in relation to an employee or prospective employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lie detector","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lie detector” includes a polygraph, deceptograph, voice stress analyzer, psychological stress evaluator, or any other similar device (whether mechanical or electrical) that is used, or the results of which are used, for the purpose of rendering a diagnostic opinion regarding the honesty or dishonesty of an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Polygraph","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “polygraph” means an instrument that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd4fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records continuously, visually, permanently, and simultaneously changes in cardiovascular, respiratory, and electrodermal patterns as minimum instrumentation standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used, or the results of which are used, for the purpose of rendering a diagnostic opinion regarding the honesty or dishonesty of an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd4fd-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s2"},"text":"Pub. L. 100–347, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/646"},"text":"102 Stat. 646","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd4fe-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5dd4ff-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b5dd500-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s11"},"text":"Pub. L. 100–347, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/653"},"text":"102 Stat. 653","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/347/s11"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this Act [enacting this chapter] shall become effective 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act, the Secretary shall issue such rules and regulations as may be necessary or appropriate to carry out this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id5b5dd501-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/347/s1"},"text":"Pub. L. 100–347, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/646"},"text":"102 Stat. 646","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/347/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Employee Polygraph Protection Act of 1988’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
