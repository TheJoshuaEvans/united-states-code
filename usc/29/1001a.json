{"tag":"section","attrib":{"id":"id5aafba65-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001a"},"text":"§ 1001a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Congressional findings and declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aafba66-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effects of multiemployer pension plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aafba67-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiemployer pension plans have a substantial impact on interstate commerce and are affected with a national public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba68-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiemployer pension plans have accounted for a substantial portion of the increase in private pension plan coverage over the past three decades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba69-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continued well-being and security of millions of employees, retirees, and their dependents are directly affected by multiemployer pension plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba6a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aafba6b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawals of contributing employers from a multiemployer pension plan frequently result in substantially increased funding obligations for employers who continue to contribute to the plan, adversely affecting the plan, its participants and beneficiaries, and labor-management relations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aafba6c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a declining industry, the incidence of employer withdrawals is higher and the adverse effects described in subparagraph (A) are exacerbated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aafba6d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of multiemployer plan termination insurance provisions and replacement of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress further finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aafba6e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is desirable to modify the current multiemployer plan termination insurance provisions in order to increase the likelihood of protecting plan participants against benefit losses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba6f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is desirable to replace the termination insurance program for multiemployer pension plans with an insolvency-based benefit protection program that will enhance the financial soundness of such plans, place primary emphasis on plan continuation, and contain program costs within reasonable limits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aafba70-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is hereby declared to be the policy of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aafba71-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster and facilitate interstate commerce,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba72-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alleviate certain problems which tend to discourage the maintenance and growth of multiemployer pension plans,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide reasonable protection for the interests of participants and beneficiaries of financially distressed multiemployer pension plans, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aafba74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1001a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a financially self-sufficient program for the guarantee of employee benefits under multiemployer plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aafba75-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/s3"},"text":"Pub. L. 96–364, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1209"},"text":"94 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aafba76-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aafba77-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5aafba78-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1208"},"text":"94 Stat. 1208","children":[],"tail":", known as the Multiemployer Pension Plan Amendments Act of 1980. For complete classification of this Act to the Code, see Short Title of 1980 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5aafba79-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Multiemployer Pension Plan Amendments Act of 1980, and not as part of the Employee Retirement Income Security Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5aafba7a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5aafba7b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e/1"},"text":"section 1461(e)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5aafba7c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report Respecting Collective Bargaining for Contributions to, and Benefits From, Multiemployer Plans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIV/s412/b"},"text":"Pub. L. 96–364, title IV, § 412(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1309"},"text":"94 Stat. 1309","children":[],"tail":", directed Secretary of Labor to study feasibility of requiring collective bargaining on both issues of contributions to, and benefits from, multiemployer plans, and submit a report on the study to Congress within 3 years of "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
