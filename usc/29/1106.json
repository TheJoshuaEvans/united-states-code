{"tag":"section","attrib":{"id":"id5af74b8d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106"},"text":null,"children":[{"tag":"num","attrib":{"value":"1106"},"text":"§ 1106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5af74b8e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions between plan and party in interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1108"},"text":"section 1108 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5af74b8f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A fiduciary with respect to a plan shall not cause the plan to engage in a transaction, if he knows or should know that such transaction constitutes a direct or indirect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5af74b90-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sale or exchange, or leasing, of any property between the plan and a party in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5af74b91-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lending of money or other extension of credit between the plan and a party in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5af74b92-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishing of goods, services, or facilities between the plan and a party in interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5af74b93-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer to, or use by or for the benefit of a party in interest, of any assets of the plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5af74b94-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition, on behalf of the plan, of any employer security or employer real property in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1107/a"},"text":"section 1107(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af74b95-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No fiduciary who has authority or discretion to control or manage the assets of a plan shall permit the plan to hold any employer security or employer real property if he knows or should know that holding such security or real property violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1107/a"},"text":"section 1107(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5af74b96-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions between plan and fiduciary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fiduciary with respect to a plan shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5af74b97-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deal with the assets of the plan in his own interest or for his own account,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af74b98-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in his individual or in any other capacity act in any transaction involving the plan on behalf of a party (or represent a party) whose interests are adverse to the interests of the plan or the interests of its participants or beneficiaries, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5af74b99-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive any consideration for his own personal account from any party dealing with such plan in connection with a transaction involving the assets of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5af74b9a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of real or personal property to plan by party in interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transfer of real or personal property by a party in interest to a plan shall be treated as a sale or exchange if the property is subject to a mortgage or similar lien which the plan assumes or if it is subject to a mortgage or similar lien which a party-in-interest placed on the property within the 10-year period ending on the date of the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5af74b9b-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s406"},"text":"Pub. L. 93–406, title I, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/879"},"text":"88 Stat. 879","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
