{"tag":"section","attrib":{"id":"id5b9c15c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223"},"text":null,"children":[{"tag":"num","attrib":{"value":"3223"},"text":"§ 3223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b9c15c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9c15c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the Department has sufficient capacity to, and does, provide, coordinate, and support the development of, appropriate training, technical assistance, staff development, and other activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9c15c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in replicating programs of demonstrated effectiveness, to States and localities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c15c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of staff providing rapid response services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c15ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of other staff of recipients of funds under this subchapter, including the staff of local boards and State boards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c15cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of members of State boards and local boards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c3cdc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the development and implementation of integrated, technology-enabled intake and case management information systems for programs carried out under this Act and programs carried out by one-stop partners, such as standard sets of technical requirements for the systems, offering interfaces that States could use in conjunction with their current (as of the first date of implementation of the systems) intake and case management information systems that would facilitate shared registration across programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c3cdd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance regarding accounting and program operations to States and localities (when such assistance would not supplant assistance provided by the State);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c3cde-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peer review activities under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c3cdf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in particular, assistance to States in making transitions to implement the provisions of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9c3ce0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9c3ce1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out paragraph (1) on behalf of a State or recipient of financial assistance under section 3221 or 3222 of this title, the Secretary, after consultation with the State or grant recipient, may award grants or enter into contracts or cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9c3ce2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants or contracts awarded under paragraph (1) to entities other than States or local units of government that are for amounts in excess of $100,000 shall only be awarded on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9c3ce3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dislocated worker technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9c3ce4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3172/a/2/A"},"text":"section 3172(a)(2)(A) of this title","children":[],"tail":", the Secretary shall reserve not more than 5 percent of such amounts to provide technical assistance to States that do not meet the State performance accountability measures for the primary indicators of performance described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/2/A/i"},"text":"section 3141(b)(2)(A)(i) of this title","children":[],"tail":" with respect to employment and training activities for dislocated workers. Using such reserved funds, the Secretary may provide such assistance to other States, local areas, and other entities involved in providing assistance to dislocated workers, to promote the continuous improvement of assistance provided to dislocated workers, under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9c3ce5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts reserved under this subsection may be used to provide for the training of staff, including specialists, who provide rapid response services. Such training shall include instruction in proven methods of promoting, establishing, and assisting labor-management committees. Such projects shall be administered through the Employment and Training Administration of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9c63f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promising and proven practices coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9c63f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a system through which States may share information regarding promising and proven practices with regard to the operation of workforce investment activities under this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9c63f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and disseminate information regarding such promising and proven practices and identify knowledge gaps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9c63f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3223/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commission research under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3224/b"},"text":"section 3224(b) of this title","children":[],"tail":" to address knowledge gaps identified under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b9c63fa-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s168"},"text":"Pub. L. 113–128, title I, § 168","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1566"},"text":"128 Stat. 1566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b9c63fb-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b9c63fc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b9c63fd-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a)(1)(E), (H) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":", known as the Workforce Innovation and Opportunity Act, which enacted this chapter, repealed chapter 30 (§ 2801 et seq.) of this title and chapter 73 (§ 9201 et seq.) of Title 20, Education, and made amendments to numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b9c63fe-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b9c63ff-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
