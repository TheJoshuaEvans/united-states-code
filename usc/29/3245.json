{"tag":"section","attrib":{"id":"id5ba564a2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245"},"text":null,"children":[{"tag":"num","attrib":{"value":"3245"},"text":"§ 3245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports; recordkeeping; investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ba564a3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient recordkeeping and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba564a4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of funds under this subchapter shall keep records that are sufficient to permit the preparation of reports required by this subchapter and to permit the tracing of funds to a level of expenditure adequate to ensure that the funds have not been spent unlawfully.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564a5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and reports regarding general performance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every such recipient shall maintain such records and submit such reports, in such form and containing such information, as the Secretary may require regarding the performance of programs and activities carried out under this subchapter. Such records and reports shall be submitted to the Secretary but shall not be required to be submitted more than once each quarter unless specifically requested by Congress or a committee of Congress, in which case an estimate regarding such information may be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564a6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of standardized records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to allow for the preparation of the reports required under subsection (c), such recipients shall maintain standardized records for all individual participants and provide to the Secretary a sufficient number of such records to provide for an adequate analysis of the records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564a7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to the public","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba564a8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), records maintained by such recipients pursuant to this subsection shall be made available to the public upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A) shall not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5ba564aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information, the disclosure of which would constitute a clearly unwarranted invasion of personal privacy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5ba564ab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" trade secrets, or commercial or financial information, that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5ba564ac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtained from a person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5ba564ad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privileged or confidential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564ae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees to recover costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such recipients may charge fees sufficient to recover costs applicable to the processing of requests for records under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba564af-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations of use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba564b0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba564b1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to evaluate compliance with the provisions of this subchapter, the Secretary shall conduct, in several States, in each fiscal year, investigations of the use of funds received by recipients under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564b2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller general of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure compliance with the provisions of this subchapter, the Comptroller General of the United States may conduct investigations of the use of funds received under this subchapter by any recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564b3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting any investigation under this subchapter, the Secretary or the Comptroller General of the United States may not request the compilation of any information that the recipient is not otherwise required to compile and that is not readily available to such recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564b4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba564b5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out any audit under this subchapter (other than any initial audit survey or any audit investigating possible criminal or fraudulent conduct), either directly or through grant or contract, the Secretary, the Inspector General of the Department of Labor, or the Comptroller General of the United States shall furnish to the State, recipient, or other entity to be audited, advance notification of the overall objectives and purposes of the audit, and any extensive recordkeeping or data requirements to be met, not later than 14 days (or as soon as practicable) prior to the commencement of the audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564b6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the scope, objectives, or purposes of the audit change substantially during the course of the audit, the entity being audited shall be notified of the change as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564b7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports on the results of such audits shall cite the law, regulation, policy, or other criteria applicable to any finding contained in the reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564b8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this subchapter shall be construed so as to be inconsistent with chapter 4 of title 5 or government auditing standards issued by the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba564b9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee information responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State, each local board, and each recipient (other than a subrecipient, subgrantee, or contractor of a recipient) receiving funds under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba564ba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make readily accessible such reports concerning its operations and expenditures as shall be prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564bb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prescribe and maintain comparable management information systems, in accordance with guidelines that shall be prescribed by the Secretary, designed to facilitate the uniform compilation, cross tabulation, and analysis of programmatic, participant, and financial data, on statewide, local area, and other appropriate bases, necessary for reporting, monitoring, and evaluating purposes, including data necessary to comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3248"},"text":"section 3248 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall monitor the performance of providers in complying with the terms of grants, contracts, or other agreements made pursuant to this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the extent practicable, submit or make available (including through electronic means) any reports, records, plans, or any other data that are required to be submitted or made available, respectively, under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba564be-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be included in reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba564bf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reports required in subsection (c) shall include information regarding programs and activities carried out under this subchapter pertaining to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5ba564c0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant demographic characteristics (including race, ethnicity, sex, and age) and other related information regarding participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs and activities in which participants are enrolled, and the length of time that participants are engaged in such programs and activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outcomes of the programs and activities for participants, including the occupations of participants, and placement for participants in nontraditional employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specified costs of the programs and activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5ba564c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information necessary to prepare reports to comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3248"},"text":"section 3248 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that all elements of the information required for the reports described in paragraph (1) are defined and that the information is reported uniformly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba564c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly financial reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba564c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each local board in a State shall submit quarterly financial reports to the Governor with respect to programs and activities carried out under this subchapter. Such reports shall include information identifying all program and activity costs by cost category in accordance with generally accepted accounting principles and by year of the appropriation involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall submit to the Secretary, and the Secretary shall submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Education and the Workforce of the House of Representatives, on a quarterly basis, a summary of the reports submitted to the Governor pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba564c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of additional records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State and local board shall maintain records with respect to programs and activities carried out under this subchapter that identify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5ba564ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any income or profits earned, including such income or profits earned by subrecipients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5ba564cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any costs incurred (such as stand-in costs) that are otherwise allowable except for funding limitations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba564cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3245/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost categories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In requiring entities to maintain records of costs by cost category under this subchapter, the Secretary shall require only that the costs be categorized as administrative or programmatic costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ba564cd-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s185"},"text":"Pub. L. 113–128, title I, § 185","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1594"},"text":"128 Stat. 1594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/48"},"text":"Pub. L. 117–286, § 4(b)(48)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4348"},"text":"136 Stat. 4348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ba564ce-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ba564cf-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5ba564d0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5” for “the Inspector General Act of 1978 (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ba564d1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5ba564d2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
