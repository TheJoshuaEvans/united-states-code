{"tag":"section","attrib":{"id":"id5b9a1a52-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210"},"text":null,"children":[{"tag":"num","attrib":{"value":"3210"},"text":"§ 3210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9a1a53-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate, with regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3204"},"text":"section 3204 of title 39","children":[],"tail":", data and information in such forms as the Secretary shall determine to be appropriate, to public agencies, private organizations, and the general public;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9a1a54-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3207/b"},"text":"section 3207(b) of this title","children":[],"tail":", collect or compromise all obligations to or held by the Secretary and exercise all legal or equitable rights accruing to the Secretary in connection with the payment of obligations until such time as such obligations may be referred to the Attorney General for suit or collection; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9a1a55-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expend funds made available for purposes of this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9a1a56-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for printing and binding, in accordance with applicable law (including regulation); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9a1a57-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without regard to any other law (including regulation), for rent of buildings and space in buildings and for repair, alteration, and improvement of buildings and space in buildings rented by the Secretary, except that the Secretary shall not expend funds under the authority of this subparagraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b9a4168-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except when necessary to obtain an item, service, or facility, that is required in the proper administration of this part, and that otherwise could not be obtained, or could not be obtained in the quantity or quality needed, or at the time, in the form, or under the conditions in which the item, service, or facility is needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b9a4169-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3210/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to having given written notification to the Administrator of General Services (if the expenditure would affect an activity that otherwise would be under the jurisdiction of the General Services Administration) of the intention of the Secretary to make the expenditure, and the reasons and justifications for the expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b9a416a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s160"},"text":"Pub. L. 113–128, title I, § 160","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1558"},"text":"128 Stat. 1558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b9a416b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b9a416c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b9a416d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
