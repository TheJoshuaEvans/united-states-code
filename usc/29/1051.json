{"tag":"section","attrib":{"id":"id5aceb479-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1051"},"text":null,"children":[{"tag":"num","attrib":{"value":"1051"},"text":"§ 1051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This part shall apply to any employee benefit plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/a"},"text":"section 1003(a) of this title","children":[],"tail":" (and not exempted under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/b"},"text":"section 1003(b) of this title","children":[],"tail":") other than—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aceb47a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1051/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee welfare benefit plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aceb47b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1051/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan which is unfunded and is maintained by an employer primarily for the purpose of providing deferred compensation for a select group of management or highly compensated employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aceb47c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1051/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aceb47d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1051/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan established and maintained by a socie