{"tag":"section","attrib":{"id":"id5b5dd4c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907"},"text":null,"children":[{"tag":"num","attrib":{"value":"1907"},"text":"§ 1907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helen Keller National Center Federal Endowment Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5dd4c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Board of Directors of the Helen Keller National Center are authorized to establish the Helen Keller National Center Federal Endowment Fund (hereafter in this section referred to as the “Endowment Fund”) in accordance with the provisions of this section, to promote the financial independence of the Helen Keller National Center. The Secretary and the Board may enter into such agreements as may be necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments to the Endowment Fund from amounts appropriated pursuant to subsection (h), consistent with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall make payments to the Endowment Fund in amounts equal to sums contributed to the Endowment Fund from non-Federal sources (excluding transfers from other endowment funds of the Center).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4c8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center, in investing the Endowment Fund corpus and income, shall exercise the judgment and care, under the prevailing circumstances, which a person of prudence, discretion, and intelligence would exercise in the management of that person’s own business affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4c9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd4ca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally insured investments and other investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Endowment Fund corpus and income shall be invested in federally insured bank savings accounts or comparable interest bearing accounts, certificates of deposit, money market funds, mutual funds, obligations of the United States, or other low-risk instruments and securities in which a regulated insurance company may invest under the laws of the State of New York.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4cb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Endowment Fund corpus and income may not be invested in real estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4cc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Endowment Fund corpus or income may not be invested in instruments or securities issued by an organization in which an executive officer is a controlling shareholder, director, or owner within the meaning of Federal securities laws and other applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4cd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encumbrances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center may not assign, hypothecate, encumber, or create a lien on the Endowment Fund corpus without specific written authorization of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4ce-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawals and expenditures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4cf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a 20-year period following the receipt of a payment under this section, the Center shall not withdraw or expend the Federal payment or matching contribution made to the Endowment Fund corpus. On the expiration of such period, the Center may use the Endowment Fund corpus plus any of the Endowment Fund income for any purpose that benefits individuals who are deaf-blind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4d0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational and commercial expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd4d1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Helen Keller National Center may withdraw or expend the Endowment Fund income for any expenses necessary for the operation of the Center, including expenses of operations and maintenance, administration, academic and support personnel, construction and renovation, community and client services programs, technical assistance, and research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center may not withdraw or expend the Endowment Fund income for any commercial purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations and waiver of limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd4d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Center shall not withdraw or expend more than 50 percent of the total aggregate Endowment Fund income earned prior to the time of withdrawal or expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4d5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may permit the Center to withdraw or expend more than 50 percent of its total aggregate endowment income where the Center demonstrates to the Secretary’s satisfaction that such withdrawal or expenditure is necessary because of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd4d6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial emergency, such as a pending insolvency or temporary liquidity problem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd4d7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life-threatening situation occasioned by a natural disaster or arson; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd4d8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another unusual occurrence or exigent circumstance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4d9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4da-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Helen Keller National Center shall keep accurate financial records relating to the operation of the Endowment Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4db-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit and report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd4dc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center shall arrange for the conduct of an annual financial and compliance audit of the Endowment Fund in the manner prescribed by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1903/a"},"text":"section 1903(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4dd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center shall submit a copy of the report on the audit required under subparagraph (A) to the Secretary within 15 days after completion of the audit and acceptance of the audit by the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4de-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the end of each fiscal year, the Center shall provide to the Secretary an annual report on the uses of funds provided by the Federal endowment program authorized under this section. Such report shall contain such information, and be in such form as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4df-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After notice and an opportunity for a hearing, the Secretary is authorized to recover any Federal payments made under this section if the Helen Keller National Center—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4e0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a withdrawal or expenditure from the Endowment Fund corpus or income which is not consistent with the provisions of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4e1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to comply with the investment standards and limitations under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4e2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to account properly to the Secretary concerning the investment of or expenditures from the Endowment Fund corpus or income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “endowment fund” means a fund, or a tax-exempt foundation, established and maintained by the Helen Keller National Center for the purpose of generating income for the support of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment Fund corpus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Endowment Fund corpus” means an amount equal to the Federal payments made to the Endowment Fund and amounts contributed to the Endowment Fund from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Endowment Fund income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Endowment Fund income” means an amount equal to the total market value of the Endowment Fund minus the Endowment Fund corpus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1907/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, such sums as may be necessary for each of the fiscal years 1999 through 2003. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd4e8-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/221/tII/s208"},"text":"Pub. L. 98–221, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tIX/s907"},"text":"Pub. L. 102–569, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4483"},"text":"106 Stat. 4483","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s412/b"},"text":"Pub. L. 105–220, title IV, § 412(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1241"},"text":"112 Stat. 1241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd4e9-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b5dd4ea-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b5dd4eb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":" substituted “1999 through 2003” for “1993 through 1997”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
