{"tag":"section","attrib":{"id":"id5a1bdf06-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s155"},"text":null,"children":[{"tag":"num","attrib":{"value":"155"},"text":"§ 155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Labor Relations Board; principal office, conducting inquiries throughout country; participation in decisions or inquiries conducted by member","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The principal office of the Board shall be in the District of Columbia, but it may meet and exercise any or all of its powers at any other place. The Board may, by one or more of its members or by such agents or agencies as it may designate, prosecute any inquiry necessary to its functions in any part of the United States. A member who participates in such an inquiry shall not be disqualified from subsequently participating in a decision of the Board in the same case.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a1bdf07-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-05/ch372/s5"},"text":"July 5, 1935, ch. 372, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/452"},"text":"49 Stat. 452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-06-23/ch120"},"text":"June 23, 1947, ch. 120","children":[],"tail":", title I, § 101, "},{"tag":"ref","attrib":{"href":"/us/stat/61/140"},"text":"61 Stat. 140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a1bdf08-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a1bdf09-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a1bdf0a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1947—Act ","children":[{"tag":"date","attrib":{"date":"1947-06-23"},"text":"June 23, 1947","children":[],"tail":", reenacted section without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a1bdf0b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a1bdf0c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1947 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by act ","children":[{"tag":"date","attrib":{"date":"1947-06-23"},"text":"June 23, 1947","children":[],"tail":", see section 104 of act "},{"tag":"date","attrib":{"date":"1947-06-23"},"text":"June 23, 1947","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
