{"tag":"section","attrib":{"id":"id5a6d0bfb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709"},"text":null,"children":[{"tag":"num","attrib":{"value":"709"},"text":"§ 709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6d0bfc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance; short-term traineeships; special projects; dissemination of information; monitoring and evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes of this chapter, the Commissioner may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0bfd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a6d0bfe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide consultative services and technical assistance to public or nonprofit private agencies and organizations, including assistance to enable such agencies and organizations to facilitate meaningful and effective participation by individuals with disabilities in workforce investment activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a6d0bff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to the designated State units on developing successful partnerships with local and multi-State businesses in an effort to increase the employment of individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a6d0c00-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to providers and organizations on developing self-employment opportunities and outcomes for individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a6d0c01-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to entities carrying out community rehabilitation programs to build their internal capacity to provide individualized services and supports leading to competitive integrated employment, and to transition individuals with disabilities away from nonintegrated settings;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c02-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide short-term training and technical instruction, including training for the personnel of community rehabilitation programs and other providers of services (including job coaches);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c03-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct special projects and demonstrations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c04-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, prepare, publish, and disseminate special educational or informational materials, including reports of the projects for which funds are provided under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c05-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide monitoring and conduct evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c06-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of services and facilities; information task forces","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0c07-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the duties under this chapter, the Commissioner may utilize the services and facilities of any agency of the Federal Government and of any other public or nonprofit agency or organization, in accordance with agreements between the Commissioner and the head thereof, and may pay therefor, in advance or by way of reimbursement, as may be provided in the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c08-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the provisions of this chapter, the Commissioner shall appoint such task forces as may be necessary to collect and disseminate information in order to improve the ability of the Commissioner to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c09-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations to carry out this chapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0c0a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education may promulgate such regulations as are considered appropriate to carry out the Commissioner’s duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c0b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In promulgating regulations to carry out this chapter, the Secretary of Education shall promulgate only regulations that are necessary to administer and ensure compliance with the specific requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c0c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations for implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0c0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education shall promulgate regulations regarding the requirements for the implementation of an order of selection for vocational rehabilitation services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/5/A"},"text":"section 721(a)(5)(A) of this title","children":[],"tail":" if such services cannot be provided to all eligible individuals with disabilities who apply for such services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", the Secretary of Education shall receive public comment and promulgate regulations to implement the amendments made by the Workforce Innovation and Opportunity Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c0f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities and responsibilities of Commissioner and Secretary of Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0c10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator of the Administration for Community Living (referred to in this subsection as the “Administrator”) may carry out the authorities and shall carry out the responsibilities of the Commissioner described in paragraphs (1)(A) and (2) through (4) of subsection (a), and subsection (b), except that, for purposes of applying subsections (a) and (b), a reference in those subsections—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a6d0c11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitating meaningful and effective participation shall be considered to be a reference to facilitating meaningful and effective collaboration with independent living programs, and promoting a philosophy of independent living for individuals with disabilities in community activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a6d0c12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to training for personnel shall be considered to be a reference to training for the personnel of centers for independent living and Statewide Independent Living Councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health and Human Services may carry out the authorities and shall carry out the responsibilities of the Secretary of Education described in subsections (c) and (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References to “this chapter”","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0c15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In subsections (a) through (d), a reference to “this chapter” means a provision of this chapter that the Secretary of Education has authority to carry out; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0c16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In subsection (e), for purposes of applying subsections (a) through (d), a reference in those subsections to “this chapter” means a provision of this chapter that the Secretary of Health and Human Services has authority to carry out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s709/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6d0c18-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s12"},"text":"Pub. L. 93–112, § 12","children":[],"tail":", formerly § 10, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1111"},"text":"112 Stat. 1111","children":[],"tail":"; renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/a/1"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–412; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s405/c"},"text":"Pub. L. 113–128, title IV, § 405(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1637"},"text":"128 Stat. 1637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a6d0c19-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a6d0c1a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a6d0c1b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":", which enacted chapter 32 (§ 3101 et seq.) of this title, repealed chapter 30 (§ 2801 et seq.) of this title and chapter 73 (§ 9201 et seq.) of Title 20, Education, and made amendments to numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a6d0c1c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s711"},"text":"section 711 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 709, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s10"},"text":"Pub. L. 93–112, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/363"},"text":"87 Stat. 363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s122/a/9"},"text":"Pub. L. 95–602, title I, § 122(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2985"},"text":"92 Stat. 2985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/630/tII/s201/d"},"text":"Pub. L. 100–630, title II, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3304"},"text":"102 Stat. 3304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s104"},"text":"Pub. L. 102–569, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4361"},"text":"106 Stat. 4361","children":[],"tail":", related to nonduplication prohibition, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1093"},"text":"112 Stat. 1093","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s707"},"text":"section 707 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s12"},"text":"section 12 of Pub. L. 93–112","children":[],"tail":" was renumbered section 14 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s711"},"text":"section 711 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s12"},"text":"section 12 of Pub. L. 93–112","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s711"},"text":"section 711 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a6d0c1d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/1/A"},"text":"Pub. L. 113–128, § 405(c)(1)(A)","children":[],"tail":", designated existing provisions as subpar. (A) and added subpars. (B) to (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/1/B"},"text":"Pub. L. 113–128, § 405(c)(1)(B)","children":[],"tail":", struck out “, centers for independent living,” after “community rehabilitation programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/6/A"},"text":"Pub. L. 113–128, § 405(c)(6)(A)","children":[],"tail":", (D), (E), designated existing provisions as par. (1) and redesignated subsec. (f) as par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/2"},"text":"Pub. L. 113–128, § 405(c)(2)","children":[],"tail":", substituted “Secretary of Education” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/6/B"},"text":"Pub. L. 113–128, § 405(c)(6)(B)","children":[],"tail":", (C), designated existing provisions as par. (1) and redesignated subsec. (e) as par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/3"},"text":"Pub. L. 113–128, § 405(c)(3)","children":[],"tail":", inserted “of Education” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/7"},"text":"Pub. L. 113–128, § 405(c)(7)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated par. (2) of subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/4"},"text":"Pub. L. 113–128, § 405(c)(4)","children":[],"tail":", amended reference in original act which resulted in substitution of “"},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":"” in text, inserted “of Education” after “Secretary”, and substituted “Workforce Innovation and Opportunity Act” for “Rehabilitation Act Amendments of 1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/7"},"text":"Pub. L. 113–128, § 405(c)(7)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated par. (2) of subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s405/c/5"},"text":"Pub. L. 113–128, § 405(c)(5)","children":[],"tail":", inserted “of Education” after “Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
