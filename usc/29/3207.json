{"tag":"section","attrib":{"id":"id5b98e16d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207"},"text":null,"children":[{"tag":"num","attrib":{"value":"3207"},"text":"§ 3207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of provisions of Federal law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b98e16e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollees not considered to be Federal employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b98e16f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subsection and in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143/a"},"text":"section 8143(a) of title 5","children":[],"tail":", enrollees shall not be considered to be Federal employees and shall not be subject to the provisions of law relating to Federal employment, including such provisions regarding hours of work, rates of compensation, leave, unemployment compensation, and Federal employee benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b98e170-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to taxes and social security benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of title 26 and title II of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq.), enrollees shall be deemed to be employees of the United States and any service performed by an individual as an enrollee shall be deemed to be performed in the employ of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b98e171-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to compensation to Federal employees for work injuries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subchapter I of chapter 81 of title 5 (relating to compensation to Federal employees for work injuries), enrollees shall be deemed to be civil employees of the Government of the United States within the meaning of the term “employee” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of title 5","children":[],"tail":", and the provisions of such subchapter shall apply as specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143/a"},"text":"section 8143(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b990882-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal tort claims provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the Federal tort claims provisions in title 28, enrollees shall be considered to be employees of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b990883-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments and settlements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Secretary finds a claim for damages to a person or property resulting from the operation of the Job Corps to be a proper charge against the United States, and the claim is not cognizable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":", the Secretary may adjust and settle the claim in an amount not exceeding $1,500."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b990884-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel of the uniformed services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Personnel of the uniformed services who are detailed or assigned to duty in the performance of agreements made by the Secretary for the support of the Job Corps shall not be counted in computing strength under any law limiting the strength of such services or in computing the percentage authorized by law for any grade in such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b990885-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s157"},"text":"Pub. L. 113–128, title I, § 157","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1552"},"text":"128 Stat. 1552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b990886-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b990887-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b990888-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title II of the Act is classified generally to subchapter II (§ 401 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b990889-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b99088a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
