{"tag":"section","attrib":{"id":"id5a4204e8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218b"},"text":null,"children":[{"tag":"num","attrib":{"value":"218b"},"text":"§ 218b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a4204e9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with regulations promulgated by the Secretary, an employer to which this chapter applies, shall provide to each employee at the time of hiring (or with respect to current employees, not later than ","children":[{"tag":"date","attrib":{"date":"2013-03-01"},"text":"March 1, 2013","children":[],"tail":"), written notice—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a4204ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informing the employee of the existence of an Exchange, including a description of the services provided by such Exchange, and the manner in which the employee may contact the Exchange to request assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a4204eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the employer plan’s share of the total allowed costs of benefits provided under the plan is less than 60 percent of such costs, that the employee may be eligible for a premium tax credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":" and a cost sharing reduction under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18071"},"text":"section 18071 of title 42","children":[],"tail":" if the employee purchases a qualified health plan through the Exchange; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a4204ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the employee purchases a qualified health plan through the Exchange, the employee may lose the employer contribution (if any) to any health benefits plan offered by the employer and that all or a portion of such contribution may be excludable from income for Federal income tax purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a4204ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall take effect with respect to employers in a State beginning on ","children":[{"tag":"date","attrib":{"date":"2013-03-01"},"text":"March 1, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a4204ee-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676/s18B"},"text":"June 25, 1938, ch. 676, § 18B","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1512"},"text":"Pub. L. 111–148, title I, § 1512","children":[],"tail":", title X, § 10108(i)(2), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/252"},"text":"124 Stat. 252","children":[],"tail":", 914; "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tVIII/s1858/c"},"text":"Pub. L. 112–10, div. B, title VIII, § 1858(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/169"},"text":"125 Stat. 169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a4204ef-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a4204f0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a4204f1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10"},"text":"Pub. L. 112–10","children":[],"tail":" struck out “and the employer does not offer a free choice voucher” after “Exchange”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10108/i/2"},"text":"Pub. L. 111–148, § 10108(i)(2)","children":[],"tail":", inserted “and the employer does not offer a free choice voucher” after “Exchange” and substituted “may lose” for “will lose”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a4204f2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a4204f3-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10"},"text":"Pub. L. 112–10","children":[],"tail":" effective as if included in the provisions of, and the amendments made by, the provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" to which it relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/s1858/d"},"text":"section 1858(d) of Pub. L. 112–10","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
