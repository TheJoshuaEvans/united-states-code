{"tag":"section","attrib":{"id":"id5baa202b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302"},"text":null,"children":[{"tag":"num","attrib":{"value":"3302"},"text":"§ 3302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State distribution of funds; matching requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5baa202c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State distribution of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible agency receiving a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3291/b"},"text":"section 3291(b) of this title","children":[],"tail":" for a fiscal year—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa202d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use not less than 82.5 percent of the grant funds to award grants and contracts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3321"},"text":"section 3321 of this title","children":[],"tail":" and to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3305"},"text":"section 3305 of this title","children":[],"tail":", of which not more than 20 percent of such amount shall be available to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3305"},"text":"section 3305 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa202e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use not more than 12.5 percent of the grant funds to carry out State leadership activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3303"},"text":"section 3303 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa202f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use not more than 5 percent of the grant funds, or $85,000, whichever is greater, for the administrative expenses of the eligible agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5baa2030-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa2031-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to receive a grant from the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3291/b"},"text":"section 3291(b) of this title","children":[],"tail":" each eligible agency shall provide, for the costs to be incurred by the eligible agency in carrying out the adult education and literacy activities for which the grant is awarded, a non-Federal contribution in an amount that is not less than—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5baa2032-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible agency serving an outlying area, 12 percent of the total amount of funds expended for adult education and literacy activities in the outlying area, except that the Secretary may decrease the amount of funds required under this subparagraph for an eligible agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5baa2033-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible agency serving a State, 25 percent of the total amount of funds expended for adult education and literacy activities in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa2034-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible agency’s non-Federal contribution required under paragraph (1) may be provided in cash or in kind, fairly evaluated, and shall include only non-Federal funds that are used for adult education and literacy activities in a manner that is consistent with the purpose of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5baa2035-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s222"},"text":"Pub. L. 113–128, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1614"},"text":"128 Stat. 1614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5baa2036-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5baa2037-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5baa2038-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
