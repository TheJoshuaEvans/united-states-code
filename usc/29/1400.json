{"tag":"section","attrib":{"id":"id5b4ac1c4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1400"},"text":null,"children":[{"tag":"num","attrib":{"value":"1400"},"text":"§ 1400.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of amendments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b4ac1c5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1400/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of covered multiemployer plan; procedures applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), if an amendment to a multiemployer plan authorized by any preceding section of this part is adopted more than 36 months after the effective date of this section, the amendment shall be effective only if the corporation approves the amendment, or, within 90 days after the corporation receives notice and a copy of the amendment from the plan sponsor, fails to disapprove the amendment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac1c6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1400/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment respecting methods for computing withdrawal liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amendment permitted by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1391/c/5"},"text":"section 1391(c)(5) of this title","children":[],"tail":" may be adopted only in accordance with that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac1c7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1400/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for disapproval by corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall disapprove an amendment referred to in subsection (a) or (b) only if the corporation determines that the amendment creates an unreasonable risk of loss to plan participants and beneficiaries or to the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4ac1c8-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4220"},"text":"Pub. L. 93–406, title IV, § 4220","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1239"},"text":"94 Stat. 1239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b4ac1c9-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b4ac1ca-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b4ac1cb-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this section, referred to in subsec. (a), see 1461(e)(2) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
