{"tag":"section","attrib":{"id":"id5b4125af-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1367"},"text":null,"children":[{"tag":"num","attrib":{"value":"1367"},"text":"§ 1367.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of liability for plan termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation is authorized to make arrangements with contributing sponsors and members of their controlled groups who are or may become liable under section 1362, 1363, or 1364 of this title for payment of their liability, including arrangements for deferred payment of amounts of liability to the corporation accruing as of the termination date on such terms and for such periods as the corporation deems equitable and appropriate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b4125b0-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4067"},"text":"Pub. L. 93–406, title IV, § 4067","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1032"},"text":"88 Stat. 1032","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXI/s11016/a/6/A"},"text":"Pub. L. 99–272, title XI, § 11016(a)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/271"},"text":"100 Stat. 271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIX/s9313/b/6"},"text":"Pub. L. 100–203, title IX, § 9313(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-366"},"text":"101 Stat. 1330–366","children":[],"tail":"; "},{"tag":"ref"