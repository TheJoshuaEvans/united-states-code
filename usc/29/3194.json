{"tag":"section","attrib":{"id":"id5b94748b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194"},"text":null,"children":[{"tag":"num","attrib":{"value":"3194"},"text":"§ 3194.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals eligible for the Job Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b94748c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to become an enrollee, an individual shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b94748d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not less than age 16 and not more than age 21 on the date of enrollment, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b94748e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 20 percent of the individuals enrolled in the Job Corps may be not less than age 22 and not more than age 24 on the date of enrollment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b94748f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either such maximum age limitation may be waived by the Secretary, in accordance with regulations of the Secretary, in the case of an individual with a disability;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b947490-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a low-income individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b947491-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual who is one or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b947492-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Basic skills deficient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b947493-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A school dropout.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b947494-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A homeless individual (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12473/6"},"text":"section 12473(6) of title 34","children":[],"tail":"), a homeless child or youth (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a/2"},"text":"section 11434a(2) of title 42","children":[],"tail":"), a runaway, an individual in foster care, or an individual who was in foster care and has aged out of the foster care system."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b949ba5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A parent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b949ba6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who requires additional education, career and technical education or training, or workforce preparation skills to be able to obtain and retain employment that leads to economic self-sufficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b949ba7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A victim of a severe form of trafficking in persons (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"). Notwithstanding paragraph (2), an individual described in this subparagraph shall not be required to demonstrate eligibility under such paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b949ba8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for veterans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the requirement of subsection (a)(2), a veteran shall be eligible to become an enrollee under subsection (a) if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b949ba9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of paragraphs (1) and (3) of such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b949baa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3194/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not meet the requirement of subsection (a)(2) because the military income earned by such individual within the 6-month period prior to the individual’s application for Job ","children":[{"tag":"ref","attrib":{"idref":"fn002205"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002205"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" Corps prevents the individual from meeting such requirement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b949bab-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s144"},"text":"Pub. L. 113–128, title I, § 144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1539"},"text":"128 Stat. 1539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tVI/s604"},"text":"Pub. L. 114–22, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/260"},"text":"129 Stat. 260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b949bac-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b949bad-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b949bae-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22"},"text":"Pub. L. 114–22","children":[],"tail":" added subpar. (F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b949baf-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b949bb0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5b94c2c1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Job Corps Flexibilities During Qualifying Emergency","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVI/s601"},"text":"Pub. L. 116–260, div. N, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2091"},"text":"134 Stat. 2091","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dN/tVI/s601"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enrollment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"] and ending when all qualifying emergencies have expired, notwithstanding any other provision of law, the requirements described in sections 145(a)(2)(A) and 152(b)(2)(B) of the Workforce Innovation and Opportunity Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3195/a/2/A"},"text":"29 U.S.C. 3195(a)(2)(A)","children":[],"tail":", 3202(b)(2)(B)) shall be applicable only for enrollees in the Job Corps—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating on-site at a Job Corps center; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returning to on-site participation at a Job Corps center after participating in distance learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During a qualifying emergency or the 1-year period immediately following the expiration of the qualifying emergency, an individual who would be older than the age of 24 on the date the individual enrolls in the Job Corps is eligible to enroll in the Job Corps, notwithstanding section 144(a)(1)(A) of the Workforce Innovation and Opportunity Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3194/a/1/A"},"text":"29 U.S.C. 3194(a)(1)(A)","children":[],"tail":"), as long as—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual applies for enrollment by the date that is 6 months after the date of enactment of this Act, and is not older than age 24 on the date of application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual attains the age of 25 during the qualifying emergency or the 1-year period immediately following the expiration of the qualifying emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Emergency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘qualifying emergency’ has the meaning given the term in section 3502(a)(4) of the Coronavirus Aid, Relief, and Economic Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Public Law 116–136","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"20 U.S.C. 1001","children":[],"tail":" note]).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
