ns of this chapter as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300/s601/d/5"},"text":"Pub. L. 97–300, § 601(d)(5)","children":[],"tail":", added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300/s601/d/3"},"text":"Pub. L. 97–300, § 601(d)(3)","children":[],"tail":", designated provisions relating to the inclusion in State plans of provision for handicapped persons employment opportunities and coordination with State agencies similarly concerned as subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300/s601/d/4"},"text":"Pub. L. 97–300, § 601(d)(4)","children":[],"tail":", designated provisions relating to approval and notice by the Secretary of the State plans as subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-03"},"text":"Aug. 3, 1954","children":[],"tail":", inserted provisions relating to promotion and development of employment opportunities and for job counseling and placement of handicapped persons."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a1268a2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a1268a3-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" effective o