{"tag":"section","attrib":{"id":"id5a6f564e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s715"},"text":null,"children":[{"tag":"num","attrib":{"value":"715"},"text":"§ 715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Applications for grants in excess of $100,000 in the aggregate authorized to be funded under this chapter, other than grants primarily for the purpose of conducting dissemination or conferences, shall be reviewed by panels of experts which shall include a majority of non-Federal members. Non-Federal members may be provided travel, per diem, and consultant fees not to exceed the daily equivalent of the rate of pay for level 4 of the Senior Executive Service Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a6f564f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s18"},"text":"Pub. L. 93–112, § 18","children":[],"tail":", formerly § 16, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1114"},"text":"112 Stat. 1114","children":[],"tail":"; renumbered § 18, "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/a/1"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–412.)"}],"tail":"\n"},{"tag":"notes","at