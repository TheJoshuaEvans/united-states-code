{"tag":"section","attrib":{"id":"id5b56a902-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1801"},"text":null,"children":[{"tag":"num","attrib":{"value":"1801"},"text":"§ 1801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of this chapter to remove the restraints on commerce caused by activities detrimental to migrant and seasonal agricultural workers; to require farm labor contractors to register under this chapter; and to assure necessary protections for migrant and seasonal agricultural workers, agricultural associations, and agricultural employers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b56a903-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/s2"},"text":"Pub. L. 97–470, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2584"},"text":"96 Stat. 2584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b56a904-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b56a905-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b56a906-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/tV/s524"},"text":"Pub. L. 97–470, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2600"},"text":"96 Stat. 2600","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/470/tV/s524"},"text":"“The provisions of this Act [enacting this chapter and repealing chapter 52 (§ 2041 et seq.) of Title 7, Agriculture] shall take effect ninety days from the date of enactment [","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id5b56a907-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/s1"},"text":"Pub. L. 97–470, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2584"},"text":"96 Stat. 2584","children":[],"tail":", provided in part that this Act [enacting this chapter and repealing chapter 52 (§ 2041 et seq.) of Title 7, Agriculture] may be cited as the “Migrant and Seasonal Agricultural Worker Protection Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
