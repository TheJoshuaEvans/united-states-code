{"tag":"section","attrib":{"id":"id5b07ec63-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1143a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1143a"},"text":"§ 1143a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies by Comptroller General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b07ec64-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1143a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States may, pursuant to the request of any Member of Congress, study employee benefit plans, including the effects of such plans on employees, participants, and their beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec65-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1143a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to books, documents, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of conducting studies under this section, the Comptroller General, or any of his duly authorized representatives, shall have access to and the right to examine and copy any books, documents, papers, records, or other recorded information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ec66-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1143a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the possession or control of the administrator, sponsor, or employer of and persons providing services to any employee benefit plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec67-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1143a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which the Comptroller General or his representative finds, in his own judgment, pertinent to such study.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Comptroller General shall not disclose the identity of any individual or employer in making any information obtained under this section available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec68-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1143a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “employee benefit plan”, “participant”, “administrator”, “beneficiary”, “plan sponsor”, “employee”, and “employer” are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec69-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1143a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The preceding provisions of this section shall be effective on ","children":[{"tag":"date","attrib":{"date":"1986-04-07"},"text":"April 7, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b07ec6a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXI/s11016/d"},"text":"Pub. L. 99–272, title XI, § 11016(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/275"},"text":"100 Stat. 275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b07ec6b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b07ec6c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5b07ec6d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Single-Employer Pension Plan Amendments Act of 1986, and also as part of the Consolidated Omnibus Budget Reconciliation Act of 1985, and not as part of the Employee Retirement Income Security Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
