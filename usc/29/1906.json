{"tag":"section","attrib":{"id":"id5b5dd4bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1906"},"text":null,"children":[{"tag":"num","attrib":{"value":"1906"},"text":"§ 1906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction; effect on agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall not be construed as modifying or affecting any agreement between the Department of Education or any other department or agency of the United States and the Helen Keller Services for the Blind, Incorporated, or any successor to or assignee of such corporation, with respect to the Center.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5b5dd4be-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/221/tII/s207"},"text":"Pub. L. 98–221, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/34"},"text":"98 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tIX/s906"},"text":"Pub. L. 102–569, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4483"},"text":"106 Stat. 4483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd4bf-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b5dd4c0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b5dd4c1-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569"},"text":"Pub. L. 102–569","children":[],"tail":" substituted “Helen Keller Services for the Blind, Incorporated” for “Industrial Home for the Blind, Incorporated”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
