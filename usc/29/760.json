{"tag":"section","attrib":{"id":"id5a801f0a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760"},"text":null,"children":[{"tag":"num","attrib":{"value":"760"},"text":"§ 760.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subchapter is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a801f0b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for research, demonstration projects, training, technical assistance, and related activities to maximize the full inclusion and integration into society, employment, independent living, family support, and economic and social self-sufficiency of individuals with disabilities of all ages, with particular emphasis on improving the effectiveness of services authorized under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801f0c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a comprehensive and coordinated approach to the support and conduct of such research, demonstration projects, training, technical assistance, and related activities and to ensure that the approach is in accordance with the 5-year plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s762/h"},"text":"section 762(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801f0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote the transfer and use of rehabilitation technology to individuals with disabilities, in a timely and efficient manner, through research and demonstration projects relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a801f0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement process for the purchase of rehabilitation technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a801f0f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utilization of rehabilitation technology on a national basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a801f10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific adaptations or customizations of products to enable individuals with disabilities to live more independently; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a801f11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development or transfer of assistive technology;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801f12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure the widespread dissemination, in usable formats, of practical scientific and technological information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a801f13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generated by research, demonstration projects, training, and related activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a801f14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding state-of-the-art practices, improvements in the services authorized under this chapter, rehabilitation technology, and new knowledge regarding disabilities,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to rehabilitation professionals, individuals with disabilities, and other interested parties, including the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801f15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify effective strategies that enhance the opportunities of individuals with disabilities, including individuals with intellectual and psychiatric disabilities, to engage in employment, including employment involving telecommuting and self-employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801f16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify strategies for effective coordination of services to job seekers with disabilities available through programs of one-stop partners, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801f17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase opportunities for researchers who are members of traditionally underserved populations, including researchers who are members of minority groups and researchers who are individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801f18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s760/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify effective strategies for supporting the employment of individuals with disabilities in competitive integrated employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a801f19-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tII/s200"},"text":"Pub. L. 93–112, title II, § 200","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s405"},"text":"Pub. L. 105–220, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1167"},"text":"112 Stat. 1167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s401/16"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 401(16)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–412; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s431"},"text":"Pub. L. 113–128, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1660"},"text":"128 Stat. 1660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a801f1a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a801f1b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a801f1c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 760, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tII/s200"},"text":"Pub. L. 93–112, title II, § 200","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/374"},"text":"87 Stat. 374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s107"},"text":"Pub. L. 95–602, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2962"},"text":"92 Stat. 2962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/506/tI/s103/d/2/C"},"text":"Pub. L. 99–506, title I, § 103(d)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1810"},"text":"100 Stat. 1810","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tII/s201"},"text":"Pub. L. 102–569, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4398"},"text":"106 Stat. 4398","children":[],"tail":", contained congressional declaration of purpose, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a801f1d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s431/1"},"text":"Pub. L. 113–128, § 431(1)","children":[],"tail":", (2), inserted “technical assistance,” after “training,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s431/3"},"text":"Pub. L. 113–128, § 431(3)","children":[],"tail":", in introductory provisions, inserted “and use” after “transfer” and “, in a timely and efficient manner,” after “disabilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s431/4"},"text":"Pub. L. 113–128, § 431(4)","children":[],"tail":", substituted “dissemination” for “distribution” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s431/5"},"text":"Pub. L. 113–128, § 431(5)","children":[],"tail":", inserted “, including individuals with intellectual and psychiatric disabilities,” after “disabilities” and struck out “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s431/7"},"text":"Pub. L. 113–128, § 431(7)","children":[],"tail":", added par. (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s431/6"},"text":"Pub. L. 113–128, § 431(6)","children":[],"tail":", redesignated par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s431/8"},"text":"Pub. L. 113–128, § 431(8)","children":[],"tail":", (9), added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/s405"},"text":"Pub. L. 105–220, § 405","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
