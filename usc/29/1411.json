{"tag":"section","attrib":{"id":"id5b4ac255-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411"},"text":null,"children":[{"tag":"num","attrib":{"value":"1411"},"text":"§ 1411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mergers and transfers between multiemployer plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b4ac256-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of plan sponsor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise provided in regulations prescribed by the corporation, a plan sponsor may not cause a multiemployer plan to merge with one or more multiemployer plans, or engage in a transfer of assets and liabilities to or from another multiemployer plan, unless such merger or transfer satisfies the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4ac257-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A merger or transfer satisfies the requirements of this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4ac258-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with regulations of the corporation, the plan sponsor of a multiemployer plan notifies the corporation of a merger with or transfer of plan assets or liabilities to another multiemployer plan at least 120 days before the effective date of the merger or transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac259-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no participant’s or beneficiary’s accrued benefit will be lower immediately after the effective date of the merger or transfer than the benefit immediately before that date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac25a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of participants and beneficiaries are not reasonably expected to be subject to suspension under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1426"},"text":"section 1426 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4ac25b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an actuarial valuation of the assets and liabilities of each of the affected plans has been performed during the plan year preceding the effective date of the merger or transfer, based upon the most recent data available as of the day before the start of that plan year, or other valuation of such assets and liabilities performed under such standards and procedures as the corporation may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4d325c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions not deemed violation of section 1106(a) or (b)(2) of this title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The merger of multiemployer plans or the transfer of assets or liabilities between multiemployer plans, shall be deemed not to constitute a violation of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1106/a"},"text":"section 1106(a) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1106/b/2"},"text":"section 1106(b)(2) of this title","children":[],"tail":" if the corporation determines that the merger or transfer otherwise satisfies the requirements of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4d325d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of plan to which liabilities are transferred","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan to which liabilities are transferred under this section is a successor plan for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1322a/b/2/B"},"text":"section 1322a(b)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4d325e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitated mergers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4d325f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When requested to do so by the plan sponsors, the corporation may take such actions as it deems appropriate to promote and facilitate the merger of two or more multiemployer plans if it determines, after consultation with the Participant and Plan Sponsor Advocate selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1304"},"text":"section 1304 of this title","children":[],"tail":", that the transaction is in the interests of the participants and beneficiaries of at least one of the plans and is not reasonably expected to be adverse to the overall interests of the participants and beneficiaries of any of the plans. Such facilitation may include training, technical assistance, mediation, communication with stakeholders, and support with related requests to other government agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4d3260-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to facilitate a merger which it determines is necessary to enable one or more of the plans involved to avoid or postpone insolvency, the corporation may provide financial assistance (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1431"},"text":"section 1431 of this title","children":[],"tail":") to the merged plan if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b4d3261-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more of the multiemployer plans participating in the merger is in critical and declining status (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1085/b/4"},"text":"section 1085(b)(4) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4d3262-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the corporation reasonably expects that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b4d3263-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial assistance will reduce the corporation’s expected long-term loss with respect to the plans involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b4d3264-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial assistance is necessary for the merged plan to become or remain solvent;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4d3265-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corporation certifies that its ability to meet existing financial assistance obligations to other plans will not be impaired by such financial assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b4d3266-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1411/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such financial assistance is paid exclusively from the fund for basic benefits guaranteed for multiemployer plans.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Not later than 14 days after the provision of such financial assistance, the corporation shall provide notice of such financial assistance to the Committee on Education and the Workforce of the House of Representatives, the Committee on Ways and Means of the House of Representatives, the Committee on Finance of the Senate, and the Committee on Health, Education, Labor, and Pensions of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4d3267-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4231"},"text":"Pub. L. 93–406, title IV, § 4231","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1244"},"text":"94 Stat. 1244","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dO/tI/s121/a"},"text":"Pub. L. 113–235, div. O, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2794"},"text":"128 Stat. 2794","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b4d3268-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b4d3269-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b4d326a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b4d326b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b4d326c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dO/tI/s121/b"},"text":"Pub. L. 113–235, div. O, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2794"},"text":"128 Stat. 2794","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dO/tI/s121/b"},"text":"“The amendments made by this section [amending this section] shall apply with respect to plan years beginning after ","children":[{"tag":"date","attrib":{"date":"2014-12-31"},"text":"December 31, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b4d326d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
