{"tag":"section","attrib":{"id":"id5a3fbae8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218"},"text":null,"children":[{"tag":"num","attrib":{"value":"218"},"text":"§ 218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a3fbae9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No provision of this chapter or of any order thereunder shall excuse noncompliance with any Federal or State law or municipal ordinance establishing a minimum wage higher than the minimum wage established under this chapter or a maximum work week lower than the maximum workweek established under this chapter, and no provision of this chapter relating to the employment of child labor shall justify noncompliance with any Federal or State law or municipal ordinance establishing a higher standard than the standard established under this chapter. No provision of this chapter shall justify any employer in reducing a wage paid by him which is in excess of the applicable minimum wage under this chapter, or justify any employer in increasing hours of employment maintained by him which are shorter than the maximum hours applicable under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a3fbaea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this chapter (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s213/f"},"text":"section 213(f) of this title","children":[],"tail":") or any other law—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a3fbaeb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal employee in the Canal Zone engaged in employment of the kind described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102/c/7"},"text":"section 5102(c)(7) of title 5","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a3fbaec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee employed in a nonappropriated fund instrumentality under the jurisdiction of the Armed Forces,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall have his basic compensation fixed or adjusted at a wage rate that is not less than the appropriate wage rate provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"section 206(a)(1) of this title","children":[],"tail":" (except that the wage rate provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/b"},"text":"section 206(b) of this title","children":[],"tail":" shall apply to any employee who performed services during the workweek in a work place within the Canal Zone), and shall have his overtime compensation set at an hourly rate not less than the overtime rate provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s207/a/1"},"text":"section 207(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a4204dd-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676/s18"},"text":"June 25, 1938, ch. 676, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1069"},"text":"52 Stat. 1069","children":[],"tail":"; "},{"tag":"ref"