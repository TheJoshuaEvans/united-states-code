{"tag":"section","attrib":{"id":"id5aa6452b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k"},"text":null,"children":[{"tag":"num","attrib":{"value":"796k"},"text":"§ 796k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aa6452c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa6452d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), the Commissioner may make grants to States for the purpose of providing the services described in subsection (d) to older individuals who are blind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6452e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated State agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may not make a grant under this subsection unless the State involved agrees that the grant will be administered solely by the agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/2/A/i"},"text":"section 721(a)(2)(A)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa6452f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent competitive grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning with fiscal year 1993, in the case of any fiscal year for which the amount appropriated under section 796","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title is less than $13,000,000, grants made under subsection (a) shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa64530-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discretionary grants made on a competitive basis to States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64531-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" grants made on a noncompetitive basis to pay for the continuation costs of activities for which a grant was awarded—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa64532-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64533-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under part C, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa64534-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent formula grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa64535-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any fiscal year for which the amount appropriated under section 796","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title is equal to or greater than $13,000,000, grants under subsection (a) shall be made only to States and shall be made only from allotments under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64536-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For grants under subsection (a) for a fiscal year described in paragraph (1), the Commissioner shall make an allotment to each State in an amount determined in accordance with subsection (i), and shall make a grant to the State of the allotment made for the State if the State submits to the Commissioner an application in accordance with subsection (h).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa64537-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner may not make a grant under subsection (a) unless the State involved agrees that the grant will be expended only for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa64538-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing independent living services to older individuals who are blind;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64539-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting activities that will improve or expand services for such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6453a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting activities to help improve public understanding of the problems of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa6453b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent living services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Independent living services for purposes of subsection (d)(1) include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa6453c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" services to help correct blindness, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa6453d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa6453e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" visual screening;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa6453f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surgical or therapeutic treatment to prevent, correct, or modify disabling eye conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64540-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hospitalization related to such services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64541-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of eyeglasses and other visual aids;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64542-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of services and equipment to assist an older individual who is blind to become more mobile and more self-sufficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64543-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mobility training, braille instruction, and other services and equipment to help an older individual who is blind adjust to blindness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64544-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guide services, reader services, and transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64545-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate service designed to assist an older individual who is blind in coping with daily living activities, including supportive services and rehabilitation teaching services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64546-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent living skills training, information and referral services, peer counseling, and individual advocacy training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64547-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other independent living services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa64548-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa64549-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may not make a grant under subsection (a) unless the State involved agrees, with respect to the costs of the program to be carried out by the State pursuant to such subsection, to make available (directly or through donations from public or private entities) non-Federal contributions toward such costs in an amount that is not less than $1 for each $9 of Federal funds provided in the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6454a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount contributed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions required in paragraph (1) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa6454b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain expenditures of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may expend a grant under subsection (a) to carry out the purposes specified in subsection (d) through grants to, or contracts or cooperative agreements with, public and nonprofit private agencies or organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa6454c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa6454d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may not make a grant under subsection (a) unless an application for the grant is submitted to the Commissioner and the application is in such form, is made in such manner, and contains such agreements, assurances, and information as the Commissioner determines to be necessary to carry out this section (including agreements, assurances, and information with respect to any grants under subsection (i)(4)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6454e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for a grant under this section shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa6454f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that the agency described in subsection (a)(2) will prepare and submit to the Commissioner a report, at the end of each fiscal year, with respect to each project or program the agency operates or administers under this section, whether directly or through a grant or contract, which report shall contain, at a minimum, information on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa64550-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of older individuals who are blind and are receiving services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64551-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of services provided and the number of older individuals who are blind and are receiving each type of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64552-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sources and amounts of funding for the operation of each project or program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64553-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts and percentages of resources committed to each type of service provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64554-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on actions taken to employ, and advance in employment, qualified individuals with significant disabilities, including older individuals who are blind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64555-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison, if appropriate, of prior year activities with the activities of the most recent year; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64556-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that the agency will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa64557-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide services that contribute to the maintenance of, or the increased independence of, older individuals who are blind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64558-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engage in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5aa64559-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capacity-building activities, including collaboration with other agencies and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5aa6455a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to promote community awareness, involvement, and assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5aa6455b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/h/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa6455c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of formula grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa6455d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the amount of an allotment under subsection (a) for a State for a fiscal year shall be the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa6455e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa6455f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64560-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allotment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa64561-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of the several States, the District of Columbia, and the Commonwealth of Puerto Rico, the amount referred to in subparagraph (A) of paragraph (1) for a fiscal year is the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa64562-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $225,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64563-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to ⅓ of 1 percent of the amount appropriated under section 796","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, and not reserved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796j–1"},"text":"section 796j–1 of this title","children":[],"tail":", for the fiscal year and available for allotments under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64564-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of Guam, American Samoa, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands, the amount referred to in subparagraph (A) of paragraph (1) for a fiscal year is $40,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64565-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount referred to in subparagraph (B) of paragraph (1) for a State for a fiscal year is the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa64566-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount appropriated under section 796","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, and not reserved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796j–1"},"text":"section 796j–1 of this title","children":[],"tail":", and available for allotments under subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64567-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a percentage equal to the quotient of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa64568-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the number of individuals residing in the State who are not less than 55 years of age; divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa64569-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the number of individuals residing in the United States who are not less than 55 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6456a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of certain amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa6456b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts specified in subparagraph (B), the Commissioner may make grants to States whose population of older individuals who are blind has a substantial need for the services specified in subsection (d) relative to the populations in other States of older individuals who are blind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa6456c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts referred to in subparagraph (A) are any amounts that are not paid to States under subsection (a) as a result of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5aa6456d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of any State to submit an application under subsection (h);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa6456e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of any State to prepare within a reasonable period of time such application in compliance with such subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5aa6456f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State informing the Commissioner that the State does not intend to expend the full amount of the allotment made for the State under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64570-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796k/i/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may not make a grant under subparagraph (A) unless the State involved agrees that the grant is subject to the same conditions as grants made under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa64571-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s752"},"text":"Pub. L. 93–112, title VII, § 752","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1237"},"text":"112 Stat. 1237","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s487"},"text":"Pub. L. 113–128, title IV, § 487","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1694"},"text":"128 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa64572-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa64573-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5aa64574-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part C, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":", referred to in subsec. (b)(2)(B), means former part C (§ 796f) which was included in the repeal of subchapter VII of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/1"},"text":"Pub. L. 102–569, title VII, § 701(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4443"},"text":"106 Stat. 4443","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa64575-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796k, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s752"},"text":"Pub. L. 93–112, title VII, § 752","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s703/a"},"text":"Pub. L. 102–569, title VII, § 703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4465"},"text":"106 Stat. 4465","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/m"},"text":"Pub. L. 103–73, title I, § 114(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/732"},"text":"107 Stat. 732","children":[],"tail":", authorized grants to provide independent living services for older individuals who are blind, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa64576-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/3"},"text":"Pub. L. 113–128, § 487(3)","children":[],"tail":", substituted “subsection (i)” for “subsection (j)” and “subsection (h)” for “subsection (i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/4"},"text":"Pub. L. 113–128, § 487(4)","children":[],"tail":", inserted “, or contracts or cooperative agreements with,” after “grants to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/1"},"text":"Pub. L. 113–128, § 487(1)","children":[],"tail":", (2), redesignated subsec. (i) as (h) and struck out former subsec. (h). Prior to amendment, text read as follows: “The Commissioner may not make a grant under subsection (a) unless the State involved agrees that, in carrying out subsection (d)(1), the State will seek to incorporate into the State plan under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796c"},"text":"section 796c of this title","children":[],"tail":" any new methods and approaches relating to independent living services for older individuals who are blind.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/5/A"},"text":"Pub. L. 113–128, § 487(5)(A)","children":[],"tail":", substituted “subsection (i)(4)” for “subsection (j)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(A)(vi) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/5/B"},"text":"Pub. L. 113–128, § 487(5)(B)","children":[],"tail":", inserted “and” after semicolon at end of subpar. (A)(vi), substituted a period for “; and” at end of subpar. (B)(ii)(III), and struck out subpar. (C) which read as follows: “an assurance that the application is consistent with the State plan for providing independent living services required by "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796c"},"text":"section 796c of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/2"},"text":"Pub. L. 113–128, § 487(2)","children":[],"tail":", redesignated subsec. (j) as (i). Former subsec. (i) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2)(A)(ii), (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/6/A"},"text":"Pub. L. 113–128, § 487(6)(A)","children":[],"tail":", (B), inserted “, and not reserved under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796j–1"},"text":"section 796j–1 of this title","children":[],"tail":",” after “section 796"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/6/C"},"text":"Pub. L. 113–128, § 487(6)(C)","children":[],"tail":", substituted “subsection (h)” for “subsection (i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s487/2"},"text":"Pub. L. 113–128, § 487(2)","children":[],"tail":", redesignated subsec. (j) as (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
