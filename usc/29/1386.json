{"tag":"section","attrib":{"id":"id5b460790-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386"},"text":null,"children":[{"tag":"num","attrib":{"value":"1386"},"text":"§ 1386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for partial withdrawal; determination of amount; reduction for partial withdrawal liability; procedures applicable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b460791-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of an employer’s liability for a partial withdrawal, before the application of sections 1399(c)(1) and 1405 of this title, is equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b460792-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1391"},"text":"section 1391 of this title","children":[],"tail":", and adjusted under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1389"},"text":"section 1389 of this title","children":[],"tail":" if appropriate, determined as if the employer had withdrawn from the plan in a complete withdrawal—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b460793-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date of the partial withdrawal, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b460794-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a partial withdrawal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1385/a/1"},"text":"section 1385(a)(1) of this title","children":[],"tail":" (relating to 70-percent contribution decline), on the last day of the first plan year in the 3-year testing period,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b460795-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fraction which is 1 minus a fraction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b460796-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numerator of which is the employer’s contribution base units for the plan year following the plan year in which the partial withdrawal occurs, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b460797-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the denominator of which is the average of the employer’s contribution base units for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b460798-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in clause (ii), the 5 plan years immediately preceding the plan year in which the partial withdrawal occurs, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b460799-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a partial withdrawal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1385/a/1"},"text":"section 1385(a)(1) of this title","children":[],"tail":" (relating to 70-percent contribution decline), the 5 plan years immediately preceding the beginning of the 3-year testing period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b46079a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b46079b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an employer that has withdrawal liability for a partial withdrawal from a plan, any withdrawal liability of that employer for a partial or complete withdrawal from that plan in a subsequent plan year shall be reduced by the amount of any partial withdrawal liability (reduced by any abatement or reduction of such liability) of the employer with respect to the plan for a previous plan year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b46079c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The corporation shall prescribe such regulations as may be necessary to provide for proper adjustments in the reduction provided by paragraph (1) for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b46079d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in unfunded vested benefits arising after the close of the prior year for which partial withdrawal liability was determined,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b46079e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in contribution base units occurring after the close of the prior year for which partial withdrawal liability was determined, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b46079f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1386/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factors for which it determines adjustment to be appropriate,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"so that the liability for any complete or partial withdrawal in any subsequent year (after the application of the reduction) properly reflects the employer’s share of liability with respect to the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4607a0-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4206"},"text":"Pub. L. 93–406, title IV, § 4206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1222"},"text":"94 Stat. 1222","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
