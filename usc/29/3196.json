{"tag":"section","attrib":{"id":"id5b95ad4c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3196"},"text":null,"children":[{"tag":"num","attrib":{"value":"3196"},"text":"§ 3196.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b95ad4d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3196/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship between enrollment and military obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Enrollment in the Job Corps shall not relieve any individual of obligations under the Military Selective Service Act (50 U.S.C. App. 451 et seq.) [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"50 U.S.C. 3801","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b95ad4e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3196/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of enrollment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No individual may be enrolled in the Job Corps for more than 2 years, except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b95ad4f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3196/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which completion of an advanced career training program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3198/c"},"text":"section 3198(c) of this title","children":[],"tail":" would require an individual to participate in the Job Corps for not more than one additional year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b95d460-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3196/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual with a disability who would reasonably be expected to meet the standards for a Job Corps graduate, as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3192/5"},"text":"section 3192(5) of this title","children":[],"tail":", if allowed to participate in the Job Corps for not more than 1 additional year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b95d461-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3196/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who participates in national service, as authorized by a Civilian Conservation Center program, who would be granted an enrollment extension in the Job Corps for the amount of time equal to the period of national service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b95d462-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3196/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Secretary may authorize in a special case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b95d463-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s146"},"text":"Pub. L. 113–128, title I, § 146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1542"},"text":"128 Stat. 1542","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b95d464-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b95d465-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b95d466-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Military Selective Service Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"act June 24, 1948, ch. 625","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/604"},"text":"62 Stat. 604","children":[],"tail":", which was classified principally to section 451 et seq. of the former Appendix to Title 50, War and National Defense, prior to editorial reclassification and renumbering as chapter 49 (§ 3801 et seq.) of Title 50. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b95d467-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b95d468-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
