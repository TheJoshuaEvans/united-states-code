{"tag":"section","attrib":{"id":"id5b9956bb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209"},"text":null,"children":[{"tag":"num","attrib":{"value":"3209"},"text":"§ 3209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b9956bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial management information system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9956bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish procedures to ensure that each operator, and each service provider, maintains a financial management information system that will provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b9956be-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurate, complete, and current disclosures of the costs of Job Corps operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b9956bf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient data for the effective evaluation of activities carried out through the Job Corps program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9956c0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each operator and service provider shall maintain funds received under this part in accounts in a manner that ensures timely and accurate reporting as required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9956c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Operators shall remain fiscally responsible and control costs, regardless of whether the funds made available for Job Corps centers are incrementally increased or decreased between fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b9956c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b9956c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the Inspector General of the Department of Labor, the Comptroller General of the United States, and any of their duly authorized representatives, shall have access to any books, documents, papers, and records of the operators and service providers described in subsection (a) that are pertinent to the Job Corps program, for purposes of conducting surveys, audits, and evaluations of the operators and service providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b997dd4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveys, audits, and evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall survey, audit, or evaluate, or arrange for the survey, audit, or evaluation of, the operators and service providers, using Federal auditors or independent public accountants. The Secretary shall conduct such surveys, audits, or evaluations not less often than once every 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b997dd5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on indicators of performance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b997dd6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Levels of performance and indicators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually establish expected levels of performance for a Job Corps center and the Job Corps program relating to each of the primary indicators of performance for eligible youth described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/2/A/ii"},"text":"section 3141(b)(2)(A)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b997dd7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of recruiters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall also establish performance indicators, and expected levels of performance on the performance indicators, for recruitment service providers serving the Job Corps program. The performance indicators shall relate to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b997dd8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of enrollees recruited, compared to the established goals for such recruitment, and the number of enrollees who remain committed to the program for 90 days after enrollment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b997dd9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measurements described in subparagraphs (I), (L), and (M) of subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b997dda-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of career transition service providers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall also establish performance indicators, and expected performance levels on the performance indicators, for career transition service providers serving the Job Corps program. The performance indicators shall relate to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b997ddb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary indicators of performance for eligible youth described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/2/A/ii"},"text":"section 3141(b)(2)(A)(ii) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b997ddc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measurements described in subparagraphs (D), (E), (H), (J), and (K) of subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b997ddd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect, and annually submit to the Committee on Education and the Workforce of the House of Representatives and the Committee on Health, Education, Labor, and Pensions of the Senate, a report including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b997dde-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the performance of each Job Corps center, and the Job Corps program, based on the performance indicators described in paragraph (1), as compared to the expected level of performance established under such paragraph for each performance indicator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the performance of the service providers described in paragraphs (2) and (3) on the performance indicators established under such paragraphs, as compared to the expected level of performance established for each performance indicator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b99a4f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b99a4f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall also collect, and submit in the report described in subsection (c)(4), information on the performance of each Job Corps center, and the Job Corps program, regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b99a4f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of enrollees served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demographic information on the enrollees served, including age, race, gender, and education and income level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of graduates of a Job Corps center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of graduates who entered the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of graduates who entered apprenticeship programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of graduates who received a regular secondary school diploma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of graduates who received a State recognized equivalent of a secondary school diploma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of graduates who entered unsubsidized employment related to the career and technical education and training received through the Job Corps program and the number who entered unsubsidized employment not related to the education and training received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage and number of former enrollees, including the number dismissed under the zero tolerance policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3202/b"},"text":"section 3202(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage and number of graduates who enter postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the average wage of graduates who enter unsubsidized employment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b99a4fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the first day of such employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b99a4fe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the day that is 6 months after such first day;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a4ff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentages of enrollees described in subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3195/c/1"},"text":"section 3195(c)(1) of this title","children":[],"tail":", as compared to the percentage targets established by the Secretary under such section for the center;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a500-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost per enrollee, which is calculated by comparing the number of enrollees at the center in a program year to the total budget for such center in the same program year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99a501-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost per graduate, which is calculated by comparing the number of graduates of the center in a program year compared to the total budget for such center in the same program year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99cc12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional information required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b99cc13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for reporting of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The disaggregation of data under this subsection shall not be required when the number of individuals in a category is insufficient to yield statistically reliable information or when the results would reveal personally identifiable information about an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b99cc14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall collect the information described in subsections (c) and (d), using methods described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/i/2"},"text":"section 3141(i)(2) of this title","children":[],"tail":" and consistent with State law, by entering into agreements with the States to access such data for Job Corps enrollees, former enrollees, and graduates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b99cc15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance assessments and improvements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b99cc16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct an annual assessment of the performance of each Job Corps center. Based on the assessment, the Secretary shall take measures to continuously improve the performance of the Job Corps program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b99cc17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance improvement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a Job Corps center that fails to meet the expected levels of performance relating to the primary indicators of performance specified in subsection (c)(1), the Secretary shall develop and implement a performance improvement plan. Such a plan shall require action to be taken during a 1-year period, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b99cc18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99cc19-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changing the career and technical education and training offered at the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99cc1a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changing the management staff of the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99cc1b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replacing the operator of the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99cc1c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the capacity of the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99cc1d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relocating the center; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b99cc1e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closing the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b99cc1f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional performance improvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the performance improvement plans required under paragraph (2), the Secretary may develop and implement additional performance improvement plans. Such a plan shall require improvements, including the actions described in such paragraph, for a Job Corps center that fails to meet criteria established by the Secretary other than the expected levels of performance described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b99f330-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian Conservation Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a Civilian Conservation Center that fails to meet the expected levels of performance relating to the primary indicators of performance specified in subsection (c)(1) or fails to improve performance as described in paragraph (2) after 3 program years, the Secretary, in consultation with the Secretary of Agriculture, shall select an entity to operate the Civilian Conservation Center on a competitive basis, in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3197"},"text":"section 3197 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b99f331-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant health and safety","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b99f332-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that a review by an appropriate Federal, State, or local entity of the physical condition and health-related activities of each Job Corps center occurs annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b99f333-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work-based learning locations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that an entity that has entered into a contract to provide work-based learning activities for any Job Corps enrollee under this part shall comply with the Occupational Safety and Health Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.) or, as appropriate, under the corresponding State Occupational Safety and Health Act of 1970 requirements in the State in which such activities occur."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b99f334-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings and facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect, and submit in the report described in subsection (c)(4), information regarding the state of Job Corps buildings and facilities. Such report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b99f335-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of requested construction, rehabilitation, and acquisition projects, by each Job Corps center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b99f336-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of new facilities under construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b99f337-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National and community service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include in the report described in subsection (c)(4) available information regarding the national and community service activities of enrollees, particularly those enrollees at Civilian Conservation Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b99f338-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closure of Job Corps center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to the closure of any Job Corps center, the Secretary shall ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b99f339-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the proposed decision to close the center is announced in advance to the general public through publication in the Federal Register or other appropriate means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9a1a4a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of a reasonable comment period, not to exceed 30 days, for interested individuals to submit written comments to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b9a1a4b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3209/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Member of Congress who represents the district in which such center is located is notified within a reasonable period of time in advance of any final decision to close the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b9a1a4c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s159"},"text":"Pub. L. 113–128, title I, § 159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1554"},"text":"128 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b9a1a4d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b9a1a4e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b9a1a4f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (g)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b9a1a50-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b9a1a51-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
