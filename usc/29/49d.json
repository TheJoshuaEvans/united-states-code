{"tag":"section","attrib":{"id":"id5a0ff84c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d"},"text":null,"children":[{"tag":"num","attrib":{"value":"49d"},"text":"§ 49d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations; certification for payment to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a0ff84d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, such amounts from time to time as the Congress may deem necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a0ff84e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification for payment to States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall from time to time certify to the Secretary of the Treasury for payment to each State which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a0ff84f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in the case of Guam, has an unemployment compensation law approved by the Secretary under the Federal Unemployment Tax Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3301"},"text":"26 U.S.C. 3301","children":[],"tail":" et seq.] and is found to be in compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s503"},"text":"section 503 of title 42","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff850-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is found to have coordinated the public employment services with the provision of unemployment insurance claimant services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff851-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is found to be in compliance with this chapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such amounts as the Secretary determines to be necessary for allotment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s49e"},"text":"section 49e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a0ff852-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a0ff853-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning with fiscal year 1985 and thereafter appropriations for any fiscal year for programs and activities assisted or conducted under this chapter shall be available for obligation only on the basis of a program year. The program year shall begin on July 1 in the fiscal year for which the appropriation is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a0ff854-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds obligated for any program year may be expended by the State during that program year and the two succeeding program years and no amount shall be deobligated on account of a rate of expenditure which is consistent with the program plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a0ff855-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-06/ch49/s5"},"text":"June 6, 1933, ch. 49, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/114"},"text":"48 Stat. 114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-05-10/ch102"},"text":"May 10, 1935, ch. 102","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/216"},"text":"49 Stat. 216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-29/ch816"},"text":"June 29, 1938, ch. 816","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1244"},"text":"52 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-08/ch933/s2"},"text":"Sept. 8, 1950, ch. 933, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/822"},"text":"64 Stat. 822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch852/s17/b"},"text":"Aug. 1, 1956, ch. 852, § 17(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/910"},"text":"70 Stat. 910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/778/tV/s543/c"},"text":"Pub. L. 86–778, title V, § 543(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/987"},"text":"74 Stat. 987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/tI/s116/c"},"text":"Pub. L. 94–566, title I, § 116(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2672"},"text":"90 Stat. 2672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVII/s702"},"text":"Pub. L. 97–35, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/521"},"text":"95 Stat. 521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/tVI/s601/b"},"text":"Pub. L. 97–300, title VI, § 601(b)","children":[],"tail":", formerly title V, § 501(b), "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1392"},"text":"96 Stat. 1392","children":[],"tail":"; renumbered title VI, § 601(b), "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVII/s712/a/1"},"text":"Pub. L. 100–628, title VII, § 712(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3248"},"text":"102 Stat. 3248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIII/s304"},"text":"Pub. L. 105–220, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1081"},"text":"112 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a0ff856-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a0ff857-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a0ff858-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Unemployment Tax Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-16/ch736"},"text":"act Aug. 16, 1954, ch. 736","children":[],"tail":", §§ 3301 to 3311, "},{"tag":"ref","attrib":{"href":"/us/stat/68A/454"},"text":"68A Stat. 454","children":[],"tail":", which is classified generally to chapter 23 (§ 3301 et seq.) of Title 26, Internal Revenue Code. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3311"},"text":"section 3311 of Title 26","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a0ff859-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":" struck out par. (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3)(A) Appropriations for fiscal year 1984 shall be available both to fund activities for the period between ","children":[{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1984-07-01"},"text":"July 1, 1984","children":[],"tail":", and for the program year beginning "},{"tag":"date","attrib":{"date":"1984-07-01"},"text":"July 1, 1984","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) There are authorized to be appropriated such additional sums as may be necessary to carry out the provisions of this paragraph for the transition to program year funding.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300"},"text":"Pub. L. 97–300","children":[],"tail":" added subsec. (b). Former subsec. (b), which related to certification of compliance by the Secretary to the Secretary of the Treasury with regard to the Federal Unemployment Tax Act by State programs and payment of monies for the operation of the State systems, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300"},"text":"Pub. L. 97–300","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" inserted provisions authorizing appropriations for fiscal year beginning "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", and definition of “proper and efficient administration of its public employment offices”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566"},"text":"Pub. L. 94–566","children":[],"tail":" substituted “Guam” for “Guam and the Virgin Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/778"},"text":"Pub. L. 86–778","children":[],"tail":" substituted “Guam and the Virgin Islands” for “Puerto Rico, Guam, and the Virgin Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", inserted “Guam” after “Puerto Rico”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Subsec. (a). Act, ","children":[{"tag":"date","attrib":{"date":"1950-09-08"},"text":"Sept. 8, 1950","children":[],"tail":", struck out apportionment formula and requirement that States match the funds granted them."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1938—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1938-06-29"},"text":"June 29, 1938","children":[],"tail":", substituted “The annual appropriation under this chapter shall designate the amount to” for “Seventy-five per centum of the amounts appropriated under this chapter shall”, at beginning of second sentence, and “the said amount among the several States” for “said 75 per centum of amounts appropriated after "},{"tag":"date","attrib":{"date":"1935-01-01"},"text":"January 1, 1935","children":[],"tail":", under this chapter” in proviso."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1935-05-10"},"text":"May 10, 1935","children":[],"tail":", inserted proviso."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a0ff85a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a0ff85b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-07-01"},"text":"July 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/s311"},"text":"section 311 of Pub. L. 105–220","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s49a"},"text":"section 49a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a0ff85c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300"},"text":"Pub. L. 97–300","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", but with Secretary authorized to use funds appropriated for fiscal 1983 to plan for orderly implementation of amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/s181/i"},"text":"section 181(i) of Pub. L. 97–300","children":[],"tail":", which was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1591/i"},"text":"section 1591(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a0ff85d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566"},"text":"Pub. L. 94–566","children":[],"tail":" effective on later of "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", or day after day on which Secretary of Labor approves under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304/a"},"text":"section 3304(a) of Title 26","children":[],"tail":", Internal Revenue Code, an unemployment compensation law submitted to him by Virgin Islands for approval, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/s116/f/1"},"text":"section 116(f)(1) of Pub. L. 94–566","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of Title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a0ff85e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1960 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/778/tV/s543/c"},"text":"Pub. L. 86–778, title V, § 543(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/987"},"text":"74 Stat. 987","children":[],"tail":", provided that the amendment made by that section is effective on and after "},{"tag":"date","attrib":{"date":"1961-01-01"},"text":"Jan. 1, 1961","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5a0ff85f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Suspension of State Appropriation Requirements Until ","children":[{"tag":"date","attrib":{"date":"1952-07-01"},"text":"July 1, 1952","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-06/ch896"},"text":"Act Sept. 6, 1950, ch. 896","children":[],"tail":", Ch. V, title I, "},{"tag":"ref","attrib":{"href":"/us/stat/64/643"},"text":"64 Stat. 643","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1950-09-06/ch896"},"text":"“No State shall be required to make any appropriation as provided in section 5(a) of said Act of ","children":[{"tag":"date","attrib":{"date":"1933-06-06"},"text":"June 6, 1933","children":[],"tail":" [subsec. (a) of this section], prior to "},{"tag":"date","attrib":{"date":"1952-07-01"},"text":"July 1, 1952","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions suspending the requirement until ","children":[{"tag":"date","attrib":{"date":"1950-07-01"},"text":"July 1, 1950","children":[],"tail":" were contained in acts "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-16/ch472"},"text":"June 16, 1948, ch. 472","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/62/445"},"text":"62 Stat. 445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-29/ch275"},"text":"June 29, 1949, ch. 275","children":[],"tail":", title II, "},{"tag":"ref","attrib":{"href":"/us/stat/63/284"},"text":"63 Stat. 284","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
