{"tag":"section","attrib":{"id":"id5acc6a26-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030"},"text":null,"children":[{"tag":"num","attrib":{"value":"1030"},"text":"§ 1030.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative methods of compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5acc6a27-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary on his own motion or after having received the petition of an administrator may prescribe an alternative method for satisfying any requirement of this part with respect to any pension plan, or class of pension plans (including pension-linked emergency savings account features within a pension plan), subject to such requirement if he determines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5acc6a28-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the use of such alternative method is consistent with the purposes of this subchapter and that it provides adequate disclosure to the participants and beneficiaries in the plan, and adequate reporting to the Secretary,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a29-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the application of such requirement of this part would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5acc6a2a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the costs to the plan, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5acc6a2b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose unreasonable administrative burdens with respect to the operation of the plan, having regard to the particular characteristics of the plan or the type of plan involved; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5acc6a2c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the application of this part would be adverse to the interests of plan participants in the aggregate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5acc6a2d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1030/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alternative method may be prescribed under subsection (a) by regulation or otherwise. If an alternative method is prescribed other than by regulation, the Secretary shall provide notice and an opportunity for interested persons to present their views, and shall publish in the Federal Register the provisions of such alternative method.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5acc6a2e-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s110"},"text":"Pub. L. 93–406, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/851"},"text":"88 Stat. 851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dT/tI/s127/c/1"},"text":"Pub. L. 117–328, div. T, title I, § 127(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5324"},"text":"136 Stat. 5324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5acc6a2f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5acc6a30-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5acc6a31-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “(including pension-linked emergency savings account features within a pension plan)” after “class of pension plans” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5acc6a32-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5acc6a33-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" applicable to plan years beginning after "},{"tag":"date","attrib":{"date":"2023-12-31"},"text":"Dec. 31, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s127/g"},"text":"section 127(g) of Pub. L. 117–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5acc6a34-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary authorized, effective ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", to promulgate regulations wherever provisions of this subchapter call for the promulgation of regulations, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
