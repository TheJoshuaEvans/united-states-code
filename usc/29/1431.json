{"tag":"section","attrib":{"id":"id5b4f7d0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1431"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431"},"text":"§ 1431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance by corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b4f7d0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority; procedure applicable; amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, upon receipt of an application for financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1426/f"},"text":"section 1426(f) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1441/d"},"text":"section 1441(d) of this title","children":[],"tail":", the corporation verifies that the plan is or will be insolvent and unable to pay basic benefits when due, the corporation shall provide the plan financial assistance in an amount sufficient to enable the plan to pay basic benefits under the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4f7d0f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions; repayment terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b4f7d10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial assistance shall be provided under such conditions as the corporation determines are equitable and are appropriate to prevent unreasonable loss to the corporation with respect to the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b4f7d11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan which has received financial assistance shall repay the amount of such assistance to the corporation on reasonable terms consistent with regulations prescribed by the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b4f7d12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance pending final determination of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pending determination of the amount described in subsection (a), the corporation may provide financial assistance in such amounts as it considers appropriate in order to avoid undue hardship to plan participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b4f7d13-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4261"},"text":"Pub. L. 93–406, title IV, § 4261","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tI/s104/2"},"text":"Pub. L. 96–364, title I, § 104(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1261"},"text":"94 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b4f7d14-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b4f7d15-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b4f7d16-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective ","children":[{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", except as specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1461/e"},"text":"section 1461(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
