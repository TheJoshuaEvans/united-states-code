{"tag":"section","attrib":{"id":"id5a493098-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial transactions between labor organization and officers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a493099-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct and indirect loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No labor organization shall make directly or indirectly any loan or loans to any officer or employee of such organization which results in a total indebtedness on the part of such officer or employee to the labor organization in excess of $2,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a49309a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct or indirect payment of fines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No labor organization or employer shall directly or indirectly pay the fine of any officer or employee convicted of any willful violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a49309b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates this section shall be fined not more than $5,000 or imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a49309c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/257/tV/s503"},"text":"Pub. L. 86–257, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/536"},"text":"73 Stat. 536","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
