{"tag":"section","attrib":{"id":"id5b270d0b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222"},"text":null,"children":[{"tag":"num","attrib":{"value":"1222"},"text":"§ 1222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b270d0c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Joint Pension, Profit-Sharing, and Employee Stock Ownership Plan Task Force shall, within 24 months after ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"September 2, 1974","children":[],"tail":", make a full study and review of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b270d0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s411"},"text":"section 411 of title 26","children":[],"tail":" and of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1053"},"text":"section 1053 of this title","children":[],"tail":" to determine the extent of discrimination, if any, among employees in various age groups resulting from the application of such requirements;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b270d0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of providing for the portability of pension rights among different pension plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b270d0f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate treatment under subchapter III of this chapter (relating to termination insurance) of plans established and maintained by small employers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b270d10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the broadening of stock ownership, particularly with regard to employee stock ownership plans (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4975/e/7"},"text":"section 4975(e)(7) of title 26","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1107/d/6"},"text":"section 1107(d)(6) of this title","children":[],"tail":") and all other alternative methods for broadening stock ownership to the American labor force and others;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b270d11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects and desirability of the Federal preemption of State and local law with respect to matters relating to pension and similar plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b270d12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matter as any of the committees referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1221"},"text":"section 1221 of this title","children":[],"tail":" may refer to it."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b270d13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Pension, Profit-Sharing, and Employee Stock Ownership Plan Task Force shall report the results of its study and review to each of the committees referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1221"},"text":"section 1221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b270d14-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIII/s3022"},"text":"Pub. L. 93–406, title III, § 3022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/999"},"text":"88 Stat. 999","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tVIII/s803/i/1"},"text":"Pub. L. 94–455, title VIII, § 803(i)(1)","children":[],"tail":", (2)(A)(iii), "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1590"},"text":"90 Stat. 1590","children":[],"tail":", 1591; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7891/a/1"},"text":"Pub. L. 101–239, title VII, § 7891(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2445"},"text":"103 Stat. 2445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b270d15-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b270d16-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":