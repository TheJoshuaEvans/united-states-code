{"tag":"section","attrib":{"id":"id5a636f60-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672"},"text":null,"children":[{"tag":"num","attrib":{"value":"672"},"text":"§ 672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a636f61-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of State agency to assist State in identifying State needs and responsibilities and in developing State plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized, during the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", and the two succeeding fiscal years, to make grants to the States which have designated a State agency under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s667"},"text":"section 667 of this title","children":[],"tail":" to assist them—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a636f62-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in identifying their needs and responsibilities in the area of occupational safety and health,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636f63-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing State plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s667"},"text":"section 667 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a636f64-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in developing plans for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a636f65-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing systems for the collection of information concerning the nature and frequency of occupational injuries and diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f66-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the expertise and enforcement capabilities of their personnel engaged in occupational safety and health programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a636f67-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise improving the administration and enforcement of State occupational safety and health laws, including standards thereunder, consistent with the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f68-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experimental and demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized, during the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1971-06-30"},"text":"June 30, 1971","children":[],"tail":", and the two succeeding fiscal years, to make grants to the States for experimental and demonstration projects consistent with the objectives set forth in subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f69-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation by Governor of appropriate State agency for receipt of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of the State shall designate the appropriate State agency for receipt of any grant made by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f6a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State agency designated by the Governor of the State desiring a grant under this section shall submit an application therefor to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f6b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval or rejection of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review the application, and shall, after consultation with the Secretary of Health and Human Services, approve or reject such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f6c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share for each State grant under subsection (a) or (b) of this section may not exceed 90 per centum of the total cost of the application. In the event the Federal share for all States under either such subsection is not the same, the differences among the States shall be established on the basis of objective criteria.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a636f6d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and enforcement of programs contained in approved State plans; Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to the States to assist them in administering and enforcing programs for occupational safety and health contained in State plans approved by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s667"},"text":"section 667 of this title","children":[],"tail":". The Federal share for each State grant under this subsection may not exceed 50 per centum of the total cost to the State of such a program. The last sentence of subsection (f) shall be applicable in determining the Federal share under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a65e06e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s672/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to ","children":[{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", the Secretary shall, after consultation with the Secretary of Health and Human Services, transmit a report to the President and to the Congress, describing the experience under the grant programs authorized by this section and making any recommendations he may deem appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a65e06f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596/s23"},"text":"Pub. L. 91–596, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1613"},"text":"84 Stat. 1613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a65e070-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a65e071-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5a65e072-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (c), pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
