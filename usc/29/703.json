{"tag":"section","attrib":{"id":"id5a6829d2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s703"},"text":null,"children":[{"tag":"num","attrib":{"value":"703"},"text":"§ 703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6829d3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of affording adequate notice of funding available under this chapter, appropriations under this chapter are authorized to be included in the appropriation Act for the fiscal year preceding the fiscal year for which they are available for obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6829d4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to effect a transition to the advance funding method of timing appropriation action, the authority provided by subsection (a) of this section shall apply notwithstanding that its initial application will result in the enactment in the same year (whether in the same appropriation Act or otherwise) of two separate appropriations, one for the then current fiscal year and one for the succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6829d5-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s4"},"text":"Pub. L. 93–112, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1097"},"text":"112 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a6829d6-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a6829d7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a6829d8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 703, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s4"},"text":"Pub. L. 93–112, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/358"},"text":"87 Stat. 358","children":[],"tail":", related to advance funding, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1093"},"text":"112 Stat. 1093","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
