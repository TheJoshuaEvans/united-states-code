{"tag":"section","attrib":{"id":"id5a6d0be9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s707"},"text":null,"children":[{"tag":"num","attrib":{"value":"707"},"text":"§ 707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In determining the amount of any State’s Federal share of expenditures for planning, administration, and services incurred by it under a State plan approved in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721"},"text":"section 721 of this title","children":[],"tail":", there shall be disregarded—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0bea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s707/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any portion of such expenditures which are financed by Federal funds provided under any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a6d0beb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s707/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any non-Federal funds required to be expended as a condition of receipt of such Federal funds.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"No payment may be made from funds provided under one provision of this chapter relating to any cost with respect to which any payment is made under any other provision of this chapter, except that this section shall not be construed to limit or reduce fees for services rendered by community rehabilitation programs.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6d0bec-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/