{"tag":"section","attrib":{"id":"id5aa644e3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"796f–3"},"text":"§ 796f–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers operated by State agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State that receives assistance for fiscal year 2015 with respect to a center in accordance with subsection (a) of this section (as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":") may continue to receive assistance under this subpart for fiscal year 2015 or a succeeding fiscal year if, for such fiscal year—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa644e4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–3/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" no nonprofit private agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa644e5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–3/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits an acceptable application to operate a center for independent living for the fiscal year before a date specified by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa644e6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–3/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtains approval of the application under section 796f–1 or 796f–2 of this title; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644e7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–3/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after funding all applications so submitted and approved, the Administrator determines that funds remain available to provide such assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa644e8-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s724"},"text":"Pub. L. 93–112, title VII, § 724","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1234"},"text":"112 Stat. 1234","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s482/c"},"text":"Pub. L. 113–128, title IV, § 482(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1693"},"text":"128 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa644e9-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa644ea-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa644eb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796f–3, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s724"},"text":"Pub. L. 93–112, title VII, § 724","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4461"},"text":"106 Stat. 4461","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114/k"},"text":"Pub. L. 103–73, title I, § 114(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/731"},"text":"107 Stat. 731","children":[],"tail":", related to centers operated by State agencies, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa644ec-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s482/c/1"},"text":"Pub. L. 113–128, § 482(c)(1)","children":[],"tail":", in introductory provisions, substituted “2015” for “1993” in two places and “"},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"August 7, 1998","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (1)(A), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s482/c/2"},"text":"Pub. L. 113–128, § 482(c)(2)","children":[],"tail":", substituted “Administrator” for “Commissioner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
