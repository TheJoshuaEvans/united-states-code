{"tag":"section","attrib":{"id":"id5a1e5049-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s158a"},"text":null,"children":[{"tag":"num","attrib":{"value":"158a"},"text":"§ 158a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing facilities for operations of Federal Credit Unions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Provision by an employer of facilities for the operations of a Federal Credit Union on the premises of such employer shall not be deemed to be intimidation, coercion, interference, restraint or discrimination within the provisions of sections 157 and 158 of this title, or acts amendatory thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a1e504a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-12-06/ch3/s5"},"text":"Dec. 6, 1937, ch. 3, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/51/5"},"text":"51 Stat. 5","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a1e504b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a1e504c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5a1e504d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was not enacted either as part of the Labor Management Relations Act, 1947, which comprises this chapter, or as part of the National Labor Relations Act, which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
