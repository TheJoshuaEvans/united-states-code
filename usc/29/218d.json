{"tag":"section","attrib":{"id":"id5a420502-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d"},"text":null,"children":[{"tag":"num","attrib":{"value":"218d"},"text":"§ 218d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breastfeeding accommodations in the workplace","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a420503-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employer shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a420504-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable break time for an employee to express breast milk for such employee’s nursing child for 1 year after the child’s birth each time such employee has need to express the milk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a420505-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place, other than a bathroom, that is shielded from view and free from intrusion from coworkers and the public, which may be used by an employee to express breast milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a420506-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a420507-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), an employer shall not be required to compensate an employee receiving reasonable break time under subsection (a)(1) for any time spent during the workday for such purpose unless otherwise required by Federal or State law or municipal ordinance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a420508-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief from duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Break time provided under subsection (a)(1) shall be considered hours worked if the employee is not completely relieved from duty during the entirety of such break.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a420509-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for small employers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer that employs less than 50 employees shall not be subject to the requirements of this section, if such requirements would impose an undue hardship by causing the employer significant difficulty or expense when considered in relation to the size, financial resources, nature, or structure of the employer’s business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a42050a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for crewmembers of air carriers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a42050b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employer that is an air carrier shall not be subject to the requirements of this section with respect to an employee of such air carrier who is a crewmember ","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a42050c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a42050d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air carrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “air carrier” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a42050e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crewmember","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “crewmember” has the meaning given such term in section 1.1 of title 14, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a42050f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to rail carriers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a420510-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), an employer that is a rail carrier shall be subject to the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a420511-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employer that is a rail carrier shall be subject to the requirements of this section with respect to an employee of such rail carrier who is a member of a train crew involved in the movement of a locomotive or rolling stock or who is an employee who maintains the right of way, provided that compliance with the requirements of this section does not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a420512-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the employer to incur significant expense, such as through the addition of such a member of a train crew in response to providing a break described in subsection (a)(1) to another such member of a train crew, removal or retrofitting of seats, or the modification or retrofitting of a locomotive or rolling stock; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a420513-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in unsafe conditions for an individual who is an employee who maintains the right of way.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a420514-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (2)(A), it shall not be considered a significant expense to modify or retrofit a locomotive or rolling stock by installing a curtain or other screening protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a420515-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a420516-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee who maintains the right of way","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee who maintains the right of way” means an employee who is a safety-related railroad employee described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102/4/C"},"text":"section 20102(4)(C) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a420517-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail carrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rail carrier” means an employer described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s213/b/2"},"text":"section 213(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a420518-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Train crew","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “train crew” has the meaning given such term as used in chapter II of subtitle B of title 49, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a420519-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to motorcoach services operators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a42051a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), an employer that is a motorcoach services operator shall be subject to the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a42051b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees who are involved in the movement of a motorcoach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employer that is a motorcoach services operator shall be subject to the requirements of this section with respect to an employee of such motorcoach services operator who is involved in the movement of a motorcoach provided that compliance with the requirements of this section does not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a42051c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the employer to incur significant expense, such as through the removal or retrofitting of seats, the modification or retrofitting of a motorcoach, or unscheduled stops; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a42051d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in unsafe conditions for an employee of a motorcoach services operator or a passenger of a motorcoach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a42051e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant expense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2)(A), it shall not be considered a significant expense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a42051f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to modify or retrofit a motorcoach by installing a curtain or other screening protection if an employee requests such a curtain or other screening protection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a420520-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an employee to use scheduled stop time to express breast milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a420521-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a420522-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorcoach; motorcoach services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “motorcoach” and “motorcoach services” have the meanings given the terms in section 32702 of the Motorcoach Enhanced Safety Act of 2012 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31136"},"text":"49 U.S.C. 31136","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a420523-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorcoach services operator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “motorcoach services operator” means an entity that offers motorcoach services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a420524-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification prior to commencement of action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a420525-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), before commencing an action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s216/b"},"text":"section 216(b) of this title","children":[],"tail":" for a violation of subsection (a)(2), an employee shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a420526-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the employer of such employee of the failure to provide the place described in such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a420527-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the employer with 10 days after such notification to come into compliance with such subsection with respect to the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a420528-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply in a case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a420529-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the employee has been discharged because the employee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a42052a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made a request for the break time or place described in subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a42052b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has opposed any employer conduct related to this section; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a42052c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer has indicated that the employer has no intention of providing the place described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a42052d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interaction with State and Federal law","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a42052e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws providing greater protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preempt a State law or municipal ordinance that provides greater protections to employees than the protections provided for under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a42052f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s218d/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on title 49 preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall have no effect on the preemption of a State law or municipal ordinance that is preempted under subtitle IV, V, or VII of title 49.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a420530-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676/s18D"},"text":"June 25, 1938, ch. 676, § 18D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dKK/s102/a/2"},"text":"Pub. L. 117–328, div. KK, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6093"},"text":"136 Stat. 6093","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a420531-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a420532-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a420533-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Motorcoach Enhanced Safety Act of 2012, referred to in subsec. (f)(4)(A), is subtitle G of title II of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31136"},"text":"section 31136 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a420534-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsecs. (a) to (c) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s207/r"},"text":"section 207(r) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s102/a/1"},"text":"Pub. L. 117–328, § 102(a)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a420535-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5a420536-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dKK/s103/a"},"text":"section 103(a) of div. KK of Pub. L. 117–328","children":[],"tail":", set out as an Effective Date of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s207"},"text":"section 207 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5a420537-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Application of Law to Employees of Rail Carriers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dKK/s103/d"},"text":"Pub. L. 117–328, div. KK, § 103(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6096"},"text":"136 Stat. 6096","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dKK/s103/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 18D of the Fair Labor Standards Act of 1938 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s218d"},"text":"29 U.S.C. 218d","children":[],"tail":"] (as added by section 102(a)) shall not apply to employees who are members of a train crew involved in the movement of a locomotive or rolling stock or who are employees who maintain the right of way of an employer that is a rail carrier until the date that is 3 years after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee; employer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘employee’ and ‘employer’ have the meanings given such terms in section 3 of the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s203"},"text":"29 U.S.C. 203","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees ","children":[],"tail":"[sic]"},{"tag":"inline","attrib":{},"text":" who maintains the right of way; rail carrier; train crew","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘employee who maintains the right of way’, ‘rail carrier’, and ‘train crew’ have the meanings given such terms in section 18D(e)(4) of the Fair Labor Standards Act of 1938 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s218d/e/4"},"text":"29 U.S.C. 218d(e)(4)","children":[],"tail":"], as added by section 102(a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5a420538-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delayed Application of Law to Employees of Motorcoach Services Operators","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dKK/s103/e"},"text":"Pub. L. 117–328, div. KK, § 103(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6097"},"text":"136 Stat. 6097","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dKK/s103/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 18D of the Fair Labor Standards Act of 1938 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s218d"},"text":"29 U.S.C. 218d","children":[],"tail":"] (as added by section 102(a)) shall not apply to employees who are involved in the movement of a motorcoach of an employer that is a motorcoach services operator until the date that is 3 years after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee; employer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘employee’ and ‘employer’ have the meanings given such terms in section 3 of the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s203"},"text":"29 U.S.C. 203","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motorcoach; motorcoach services operator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘motorcoach’ and ‘motorcoach services operator’ have the meanings given such terms in section 18D(f)(4) of the Fair Labor Standards Act of 1938 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s218d/f/4"},"text":"29 U.S.C. 218d(f)(4)","children":[],"tail":"], as added by section 102(a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
