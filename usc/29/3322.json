{"tag":"section","attrib":{"id":"id5bac919d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322"},"text":null,"children":[{"tag":"num","attrib":{"value":"3322"},"text":"§ 3322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local application","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each eligible provider desiring a grant or contract from an eligible agency shall submit an application to the eligible agency containing such information and assurances as the eligible agency may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac919e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how funds awarded under this subchapter will be spent consistent with the requirements of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac919f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any cooperative arrangements the eligible provider has with other agencies, institutions, or organizations for the delivery of adult education and literacy activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91a0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible provider will provide services in alignment with the local plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3123"},"text":"section 3123 of this title","children":[],"tail":", including how such provider will promote concurrent enrollment in programs and activities under subchapter I, as appropriate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91a1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible provider will meet the State adjusted levels of performance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/b/3"},"text":"section 3141(b)(3) of this title","children":[],"tail":", including how such provider will collect data to report on such performance indicators;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91a2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible provider will fulfill one-stop partner responsibilities as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3151/b/1/A"},"text":"section 3151(b)(1)(A) of this title","children":[],"tail":", as appropriate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91a3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the eligible provider will provide services in a manner that meets the needs of eligible individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91a4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3322/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that addresses the considerations described under ","children":[{"