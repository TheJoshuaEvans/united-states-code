{"tag":"section","attrib":{"id":"id5a257c18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s182"},"text":null,"children":[{"tag":"num","attrib":{"value":"182"},"text":"§ 182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of Railway Labor Act from subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall not be applicable with respect to any matter which is subject to the provisions of the Railway Labor Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.], as amended from time to time."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a257c19-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-23/ch120"},"text":"June 23, 1947, ch. 120","children":[],"tail":", title II, § 212, "},{"tag":"ref","attrib":{"href":"/us/stat/61/156"},"text":"61 Stat. 156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a257c1a-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a257c1b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a257c1c-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Railway Labor Act, as amended, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347"},"text":"act May 20, 1926, ch. 347","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":", which is classified principally to chapter 8 (§ 151 et seq.) of Title 45, Railroads. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"section 151 of Title 45","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
