{"tag":"section","attrib":{"id":"id5a1268b9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i"},"text":null,"children":[{"tag":"num","attrib":{"value":"49i"},"text":"§ 49i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a1268ba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall keep records that are sufficient to permit the preparation of reports required by this chapter and to permit the tracing of funds to a level of expenditure adequate to insure that the funds have not been spent unlawfully.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a1268bb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a1268bc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may investigate such facts, conditions, practices, or other matters which the Secretary finds necessary to determine whether any State receiving funds under this chapter or any official of such State has violated any provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a1268bd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a1268be-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to evaluate compliance with the provisions of this chapter, the Secretary shall conduct investigations of the use of funds received by States under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a1268bf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to insure compliance with the provisions of this chapter, the Comptroller General of the United States may conduct investigations of the use of funds received under this chapter by any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a1268c0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In conducting any investigation under this chapter, the Secretary or the Comptroller General of the United States may not request new compilation of information not readily available to such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a1268c1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State receiving funds under this chapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a1268c2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such reports concerning its operations and expenditures in such form and containing such information as shall be prescribed by the Secretary, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a1268c3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s49i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a management information system in accordance with guidelines established by the Secretary designed to facilitate the compilation and analysis of programmatic and financial data necessary for reporting, monitoring, and evaluating purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a1268c4-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-06/ch49/s10"},"text":"June 6, 1933, ch. 49, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/116"},"text":"48 Stat. 116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/tVI/s601/f"},"text":"Pub. L. 97–300, title VI, § 601(f)","children":[],"tail":", formerly title V, § 501(f), "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1396"},"text":"96 Stat. 1396","children":[],"tail":"; renumbered title VI, § 601(f), "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tVII/s712/a/1"},"text":"Pub. L. 100–628, title VII, § 712(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3248"},"text":"102 Stat. 3248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a1268c5-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a1268c6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a1268c7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300"},"text":"Pub. L. 97–300","children":[],"tail":" amended section generally, substituting provisions relating to State maintenance of records and investigations by the Secretary and Comptroller General for provisions which limited expenditures in States prior to adoption of State systems to the current fiscal year and two fiscal years thereafter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a1268c8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5a1268c9-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/300"},"text":"Pub. L. 97–300","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", but with Secretary authorized to use funds appropriated for fiscal 1983 to plan for orderly implementation of amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/s181/i"},"text":"section 181(i) of Pub. L. 97–300","children":[],"tail":", which was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1591/i"},"text":"section 1591(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
