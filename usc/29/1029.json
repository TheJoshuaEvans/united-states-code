{"tag":"section","attrib":{"id":"id5acc6a1e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1029"},"text":null,"children":[{"tag":"num","attrib":{"value":"1029"},"text":"§ 1029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5acc6a1f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required on forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b) of this section, the Secretary may require that any information required under this subchapter to be submitted to him, including but not limited to the information required to be filed by the administrator pursuant to section 1023(b)(3) and (c) of this title, must be submitted on such forms as he may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5acc6a20-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information not required on forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The financial statement and opinion required to be prepared by an independent qualified public accountant pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1023/a/3/A"},"text":"section 1023(a)(3)(A) of this title","children":[],"tail":", the actuarial statement required to be prepared by an enrolled actuary pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1023/a/4/A"},"text":"section 1023(a)(4)(A) of this title","children":[],"tail":" and the summary plan description required by "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1022/a"},"text":"section 1022(a) of this title","children":[],"tail":" shall not be required to be submitted on forms."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5acc6a21-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1029/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format and content of summary plan description, annual report, etc., required to be furnished to plan participants and beneficiaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe the format and content of the summary plan description, the summary of the annual report described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1024/b/3"},"text":"section 1024(b)(3) of this title","children":[],"tail":" and any other report, statements or documents (other than the bargaining agreement, trust agreement, contract, or other instrument under which the plan is established or operated), which are required to be furnished or made available to plan participants and beneficiaries receiving benefits under the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5acc6a22-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s109"},"text":"Pub. L. 93–406, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/850"},"text":"88 Stat. 850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5acc6a23-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5acc6a24-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5acc6a25-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary authorized, effective ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", to promulgate regulations wherever provisions of this subchapter call for the promulgation of regulations, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1031"},"text":"section 1031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
