{"tag":"section","attrib":{"id":"id5bac9163-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305"},"text":null,"children":[{"tag":"num","attrib":{"value":"3305"},"text":"§ 3305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs for corrections education and other institutionalized individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5bac9164-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3302/a/1"},"text":"section 3302(a)(1) of this title","children":[],"tail":" for a fiscal year, each eligible agency shall carry out corrections education and education for other institutionalized individuals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac9165-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funds described in subsection (a) shall be used for the cost of educational programs for criminal offenders in correctional institutions and for other institutionalized individuals, including academic programs for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac9166-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adult education and literacy activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac9167-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special education, as determined by the eligible agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac9168-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary school credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac9169-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac916a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career pathways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac916b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concurrent enrollment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac916c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peer tutoring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac916d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transition to re-entry initiatives and other postrelease services with the goal of reducing recidivism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac916e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible agency that is using assistance provided under this section to carry out a program for criminal offenders within a correctional institution shall give priority to serving individuals who are likely to leave the correctional institution within 5 years of participation in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac916f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141"},"text":"section 3141 of this title","children":[],"tail":", each eligible agency that receives assistance provided under this section shall annually prepare and submit to the Secretary a report on the progress, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141"},"text":"section 3141 of this title","children":[],"tail":", of the eligible agency with respect to the programs and activities carried out under this section, including the relative rate of recidivism for the criminal offenders served."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac9170-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac9171-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correctional institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “correctional institution” means any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5bac9172-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prison;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac9173-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac9174-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reformatory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac9175-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3305/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","chil