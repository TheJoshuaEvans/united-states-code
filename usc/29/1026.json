{"tag":"section","attrib":{"id":"id5ac9f905-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1026"},"text":null,"children":[{"tag":"num","attrib":{"value":"1026"},"text":"§ 1026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports made public information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ac9f906-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), the contents of the annual reports, statements, and other documents filed with the Secretary pursuant to this part shall be public information and the Secretary shall make any such information and data available for inspection in the public document room of the Department of Labor. The Secretary may use the information and data for statistical and research purposes, and compile and publish such studies, analyses, reports, and surveys based thereon as he may deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ac9f907-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information described in sections 1025(a) and 1025(c) of this title with respect to a participant may be disclosed only to the extent that information respecting that participant’s benefits under title II of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq.] may be disclosed under such Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ac9f908-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s106"},"text":"Pub. L. 93–406, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/850"},"text":"88 Stat. 850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII/s7894/b/6"},"text":"Pub. L. 101–239, title VII, § 7894(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2448"},"text":"103 Stat. 2448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/34/tXV/s1503/d/4"},"text":"Pub. L. 105–34, title XV, § 1503(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1062"},"text":"111 Stat. 1062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ac9f909-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5ac9f90a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5ac9f90b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title II of the Social Security Act is classified generally to subchapter II (§ 401 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5ac9f90c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/34"},"text":"Pub. L. 105–34","children":[],"tail":" struck out “descriptions,” before “annual reports,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" substituted “sections” for “section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ac9f90d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5ac9f90e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if originally included in the provision of the Employee Retirement Income Security Act of 1974, "},{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/i"},"text":"section 7894(i) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
