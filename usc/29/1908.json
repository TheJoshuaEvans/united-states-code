{"tag":"section","attrib":{"id":"id5b5dd4ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1908"},"text":null,"children":[{"tag":"num","attrib":{"value":"1908"},"text":"§ 1908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5dd4ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Center in providing services to individuals who are deaf-blind, the Center may establish and maintain registries of such individuals in each of the regional field offices of the network of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual who is deaf-blind may be required to provide information to the Center for any purpose with respect to a registry established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center (including the network of the Center) may not disclose information contained in a registry established under subsection (a) to any individual or organization that is not affiliated with the Center, unless the individual to whom the information relates provides specific written authorization for the Center to disclose the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly known as the “Privacy Act of 1974”) shall apply to personally identifiable information contained in the registries established by the Center under subsection (a), in the same manner and to the same extent as such requirements apply to a record of an agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5dd4f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of an individual, the Center shall remove all information relating to the individual from any registry established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd4f2-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/221/tII/s209"},"text":"Pub. L. 98–221, title II, § 209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s412/c"},"text":"Pub. L. 105–220, title IV, § 412(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1241"},"text":"112 Stat. 1241","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
