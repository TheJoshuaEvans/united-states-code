{"tag":"section","attrib":{"id":"id5b67718e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2616"},"text":null,"children":[{"tag":"num","attrib":{"value":"2616"},"text":"§ 2616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigative authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b67718f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure compliance with the provisions of this subchapter, or any regulation or order issued under this subchapter, the Secretary shall have, subject to subsection (c), the investigative authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s211/a"},"text":"section 211(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b677190-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation to keep and preserve records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employer shall make, keep, and preserve records pertaining to compliance with this subchapter in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s211/c"},"text":"section 211(c) of this title","children":[],"tail":" and in accordance with regulations issued by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b677191-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2616/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required submissions generally limited to annual basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not under the authority of this section require any employer or any plan, fund, or program to submit to the Secretary any books or records more than once during any 12-month period, unless the Secretary has reasonable cause to believe there may exist a violation of this subchapter or any regulation or order issued pursuant to this subchapter, or is investigating a charge pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2617/b"},"text":"section 2617(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b677192-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s2616/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of any investigation provided for in this section, the Secretary shall have the subpoena authority provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s209"},"text":"section 209 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b677193-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tI/s106"},"text":"Pub. L. 103–3, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/15"},"text":"107 Stat. 15","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b677194-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b677195-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b677196-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", except that, in the case of collective bargaining agreements in effect on that effective date, section applicable on the earlier of (1) the date of termination of such agreement, or (2) the date that occurs 12 months after "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/3/s405/b"},"text":"section 405(b) of Pub. L. 103–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
