{"tag":"section","attrib":{"id":"id5baedb14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3344"},"text":null,"children":[{"tag":"num","attrib":{"value":"3344"},"text":"§ 3344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of reporting burdens and requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to simplify reporting requirements and reduce reporting burdens, the Secretary of Labor, the Secretary of Education, and the Secretary of Health and Human Services shall establish procedures and criteria under which a State board and local board may reduce reporting burdens and requirements under this Act (including the amendments made by this Act).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5baedb15-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s504"},"text":"Pub. L. 113–128, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1702"},"text":"128 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5baedb16-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5baedb17-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5baedb18-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"tex