{"tag":"section","attrib":{"id":"id5b3edae8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350"},"text":null,"children":[{"tag":"num","attrib":{"value":"1350"},"text":"§ 1350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Missing participants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b3edae9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edaea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment to the corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan administrator satisfies ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341/b/3/A"},"text":"section 1341(b)(3)(A) of this title","children":[],"tail":" in the case of a missing participant only if the plan administrator—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3edaeb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers the participant’s designated benefit to the corporation or purchases an irrevocable commitment from an insurer in accordance with clause (i) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341/b/3/A"},"text":"section 1341(b)(3)(A) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edaec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the corporation such information and certifications with respect to such designated benefits or irrevocable commitments as the corporation shall specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edaed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of transferred assets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transfer to the corporation under this section shall be treated as a transfer of assets from a terminated plan to the corporation as trustee, and shall be held with assets of terminated plans for which the corporation is trustee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1342"},"text":"section 1342 of this title","children":[],"tail":", subject to the rules set forth in that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edaee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment by the corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After a missing participant whose designated benefit was transferred to the corporation is located—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3edaef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case in which the plan could have distributed the benefit of the missing participant in a single sum without participant or spousal consent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1055/g"},"text":"section 1055(g) of this title","children":[],"tail":", the corporation shall pay the participant or beneficiary a single sum benefit equal to the designated benefit paid the corporation plus interest as specified by the corporation, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edaf0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, the corporation shall pay a benefit based on the designated benefit and the assumptions prescribed by the corporation at the time that the corporation received the designated benefit.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The corporation shall make payments under subparagraph (B) available in the same forms and at the same times as a guaranteed benefit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1322"},"text":"section 1322 of this title","children":[],"tail":" would be available to be paid, except that the corporation may make a benefit available in the form of a single sum if the plan provided a single sum benefit (other than a single sum described in subsection (b)(2)(A))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3edaf1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edaf2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Missing participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “missing participant” means a participant or beneficiary under a terminating plan whom the plan administrator cannot locate after a diligent search.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edaf3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated benefit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “designated benefit” means the single sum benefit the participant would receive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3edaf4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the plan’s assumptions, in the case of a distribution that can be made without participant or spousal consent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1055/g"},"text":"section 1055(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edaf5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the assumptions of the corporation in effect on the date that the designated benefit is transferred to the corporation, in the case of a plan that does not pay any single sums other than those described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edaf6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the assumptions of the corporation or of the plan, whichever provides the higher single sum, in the case of a plan that pays a single sum other than those described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3edaf7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiemployer plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall prescribe rules similar to the rules in subsection (a) for multiemployer plans covered by this subchapter that terminate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341a"},"text":"section 1341a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3edaf8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans not otherwise subject to subchapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edaf9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan administrator of a plan described in paragraph (4) may elect to transfer a missing participant’s benefits to the corporation upon termination of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edafa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to the corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent provided in regulations, the plan administrator of a plan described in paragraph (4) shall, upon termination of the plan, provide the corporation information with respect to benefits of a missing participant if the plan transfers such benefits—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3edafb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the corporation, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edafc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an entity other than the corporation or a plan described in paragraph (4)(B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edafd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment by the corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If benefits of a missing participant were transferred to the corporation under paragraph (1), the corporation shall, upon location of the participant or beneficiary, pay to the participant or beneficiary the amount transferred (or the appropriate survivor benefit) either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3edafe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a single sum (plus interest), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edaff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such other form as is specified in regulations of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edb00-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan is described in this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b3edb01-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the plan is a pension plan (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/2"},"text":"section 1002(2) of this title","children":[],"tail":")—"}],"tail":null},{"tag":"clause","attrib":{"id":"id5b3edb02-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the provisions of this section do not apply (without regard to this subsection),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b3edb03-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is not a plan described in paragraph (2), (3), (4), (6), (7), (8), (9), (10), or (11) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1321/b"},"text":"section 1321(b) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b3edb04-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which,","children":[{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" was a plan described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s401/a"},"text":"section 401(a) of title 26","children":[],"tail":" which includes a trust exempt from tax under section 501(a) of such title, and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b3edb05-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time the assets are to be distributed upon termination, the plan—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b3edb06-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has missing participants, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b3edb07-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not provided for the transfer of assets to pay the benefits of all missing participants to another pension plan (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/2"},"text":"section 1002(2) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edb08-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain provisions not to apply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a)(1) and (a)(3) shall not apply to a plan described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3edb09-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1350/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporation shall prescribe such regulations as are necessary to carry out the purposes of this section, including rules relating to what will be considered a diligent search, the amount payable to the corporation, and the amount to be paid by the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b3edb0a-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4050"},"text":"Pub. L. 93–406, title IV, § 4050","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tVII/s776/a"},"text":"Pub. L. 103–465, title VII, § 776(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5047"},"text":"108 Stat. 5047","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tIV/s410/a"},"text":"Pub. L. 109–280, title IV, § 410(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/934"},"text":"120 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/458/tI/s104/e"},"text":"Pub. L. 110–458, title I, § 104(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5104"},"text":"122 Stat. 5104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b3edb0b-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b3edb0c-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b3edb0d-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(4)(A)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/458"},"text":"Pub. L. 110–458","children":[],"tail":" added cls. (ii) and (iii) and struck out former cl. (ii) which read as follows: “which is not a plan described in paragraphs (2) through (11) of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1321/b"},"text":"section 1321(b) of this title","children":[],"tail":", and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" added subsecs. (c) and (d) and redesignated former subsec. (c) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b3edb0e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b3edb0f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/458"},"text":"Pub. L. 110–458","children":[],"tail":" effective as if included in the provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" to which the amendment relates, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/458/s112"},"text":"section 112 of Pub. L. 110–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b3edb10-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" applicable to distributions made after final regulations implementing subsections (c) and (d) of this section are prescribed, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/s410/c"},"text":"section 410(c) of Pub. L. 109–280","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1056"},"text":"section 1056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b3edb11-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to distributions that occur in plan years commencing on or after ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s776/e"},"text":"section 776(e) of Pub. L. 103–465","children":[],"tail":", set out as an Effective Date of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1056"},"text":"section 1056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
