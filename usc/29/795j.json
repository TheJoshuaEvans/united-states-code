{"tag":"section","attrib":{"id":"id5a9ca827-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795j"},"text":null,"children":[{"tag":"num","attrib":{"value":"795j"},"text":"§ 795j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An individual, including a youth with a disability, shall be eligible under this subchapter to receive supported employment services authorized under this chapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a9ca828-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is eligible for vocational rehabilitation services under subchapter I;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9ca829-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is determined to be an individual with a most significant disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9ca82a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of activities carried out with funds described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s795h/d"},"text":"section 795h(d) of this title","children":[],"tail":", the individual is a youth with a disability, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/42"},"text":"section 705(42) of this title","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002062"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002062"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a9ca82b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s795j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive assessment of the rehabilitation needs of the individual described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/2/B"},"text":"section 705(2)(B) of this title","children":[],"tail":", including an evaluation of rehabilitation, career, and job needs, identifies supported employment as the appropriate employment outcome for the individual."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a9ca82c-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVI/s605"},"text":"Pub. L. 93–112, title VI, § 605","children":[],"tail":", formerly § 624, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s409"},"text":"Pub. L. 105–220, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1215"},"text":"112 Stat. 1215","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/b/15"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(b)(15)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–414; renumbered § 605 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s461/3"},"text":"Pub. L. 113–128, title IV, § 461(3)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1679"},"text":"128 Stat. 1679","children":[],"tail":", 1680.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a9ca82d-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a9ca82e-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a9ca82f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/42"},"text":"Section 705(42) of this title","children":[],"tail":", referred to in par. (3), was in the original “section (7)(42)”, and was translated as meaning section 7(42) of the Rehabilitation Act of 1973, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s705/42"},"text":"section 705(42) of this title","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a9ca830-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s795m"},"text":"section 795m of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 795j, ","children":[{"tag":