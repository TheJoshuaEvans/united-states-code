 including a youth with a disability,” after “An individual” and substituted “this subchapter” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/7/B"},"text":"Pub. L. 113–128, § 461(7)(B)","children":[],"tail":", inserted “under subchapter I” after “rehabilitation services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s461/7/C"},"text":"Pub. L. 113–128, § 461(7)(C)","children":[],"tail":"–(F), added par. (3), redesignated former par. (3) as (4), and, in par. (4), substituted “assessment of the rehabilitation needs” for “assessment of rehabilitation needs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" made technical amendment to section designation and catchline in original."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
