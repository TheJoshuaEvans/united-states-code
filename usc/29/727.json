{"tag":"section","attrib":{"id":"id5a7b3cfb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727"},"text":null,"children":[{"tag":"num","attrib":{"value":"727"},"text":"§ 727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a7b3cfc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7b3cfd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties of the Commissioner under this subchapter, the Commissioner shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3cfe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the annual review and periodic onsite monitoring of programs under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3cff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether, in the administration of the State plan, a State is complying substantially with the provisions of such plan and with evaluation standards and performance indicators established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s726"},"text":"section 726 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d00-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for reviews","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting reviews under this section the Commissioner shall consider, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3d01-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State policies and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d02-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d03-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decisions resulting from hearings conducted in accordance with due process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d04-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State goals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/15"},"text":"section 721(a)(15) of this title","children":[],"tail":" and the extent to which the State has achieved such goals;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d05-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans and reports prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s726/b"},"text":"section 726(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d06-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer satisfaction reviews and analyses described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s725/c/4"},"text":"section 725(c)(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d07-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information provided by the State Rehabilitation Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s725"},"text":"section 725 of this title","children":[],"tail":", if the State has such a Council, or by the commission described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/21/A/i"},"text":"section 721(a)(21)(A)(i) of this title","children":[],"tail":", if the State has such a commission;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d08-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d09-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget and financial management data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d0a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for monitoring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting monitoring under this section the Commissioner shall conduct—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3d0b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" onsite visits, including onsite reviews of records to verify that the State is following requirements regarding the order of selection set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/5/A"},"text":"section 721(a)(5)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d0c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public hearings and other strategies for collecting information from the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meetings with the State Rehabilitation Council, if the State has such a Council or with the commission described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/21/A/i"},"text":"section 721(a)(21)(A)(i) of this title","children":[],"tail":", if the State has such a commission;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviews of individual case files, including individualized plans for employment and ineligibility determinations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d0f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meetings with qualified vocational rehabilitation counselors and other personnel, including personnel of a client assistance program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s732"},"text":"section 732 of this title","children":[],"tail":", and past or current recipients of vocational rehabilitation services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas of inquiry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the review and monitoring, the Commissioner shall examine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3d11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility process, including the process related to the determination of ineligibility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s722/a/5"},"text":"section 722(a)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of services, including supported employment services and pre-employment transition services, and, if applicable, the order of selection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other areas as may be identified by the public or through meetings with the State Rehabilitation Council, if the State has such a Council or with the commission described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/21/A/i"},"text":"section 721(a)(21)(A)(i) of this title","children":[],"tail":", if the State has such a commission;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data reported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/10/C/i"},"text":"section 721(a)(10)(C)(i) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other areas of inquiry as the Commissioner may consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commissioner issues a report detailing the findings of an annual review or onsite monitoring conducted under this section, the report shall be made available to the State Rehabilitation Council, if the State has such a Council, for use in the development and modification of the State plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721"},"text":"section 721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7b3d17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7b3d18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to programs under this subchapter regarding improving the quality of vocational rehabilitation services provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d19-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and establish a corrective action plan for a program under this subchapter if the Commissioner finds that the program fails to comply substantially with the provisions of the State plan, or with evaluation standards or performance indicators established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s726"},"text":"section 726 of this title","children":[],"tail":", in order to ensure that such failure is corrected as soon as practicable; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d1a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical assistance to programs under this subchapter to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3d1b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote high-quality employment outcomes for individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d1c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate veterans who are individuals with disabilities into their communities and to support the veterans to obtain and retain competitive integrated employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d1d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, improve, and disseminate information on procedures, practices, and strategies, including for the preparation of personnel, to better enable individuals with intellectual disabilities and other individuals with disabilities to participate in postsecondary educational experiences and to obtain and retain competitive integrated employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d1e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply evidence-based findings to facilitate systemic improvements in the transition of youth with disabilities to postsecondary life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7b3d1f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7b3d20-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Commissioner, after providing reasonable notice and an opportunity for a hearing to the State agency administering or supervising the administration of the State plan approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721"},"text":"section 721 of this title","children":[],"tail":", finds that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3d21-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan has been so changed that it no longer complies with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a"},"text":"section 721(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d22-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the administration of the plan there is a failure to comply substantially with any provision of such plan or with an evaluation standard or performance indicator established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s726"},"text":"section 726 of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Commissioner shall notify such State agency that no further payments will be made to the State under this subchapter (or, in the discretion of the Commissioner, that such further payments will be reduced, in accordance with regulations the Commissioner shall prescribe, or that further payments will not be made to the State only for the projects under the parts of the State plan affected by such failure), until the Commissioner is satisfied there is no longer any such failure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d23-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until the Commissioner is so satisfied, the Commissioner shall make no further payments to such State under this subchapter (or shall reduce payments or limit payments to projects under those parts of the State plan in which there is no such failure).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d24-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disbursal of withheld funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner may, in accordance with regulations the Secretary shall prescribe, disburse any funds withheld from a State under paragraph (1) to any public or nonprofit private organization or agency within such State or to any political subdivision of such State submitting a plan meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a"},"text":"section 721(a) of this title","children":[],"tail":". The Commissioner may not make any payment under this paragraph unless the entity to which such payment is made has provided assurances to the Commissioner that such entity will contribute, for purposes of carrying out such plan, the same amount as the State would have been obligated to contribute if the State received such payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a7b3d25-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a7b3d26-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State that is dissatisfied with a final determination of the Commissioner under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/b"},"text":"section 721(b) of this title","children":[],"tail":" or subsection (c) may file a petition for judicial review of such determination in the United States Court of Appeals for the circuit in which the State is located. Such a petition may be filed only within the 30-day period beginning on the date that notice of such final determination was received by the State. The clerk of the court shall transmit a copy of the petition to the Commissioner or to any officer designated by the Commissioner for that purpose. In accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":", the Commissioner shall file with the court a record of the proceeding on which the Commissioner based the determination being appealed by the State. Until a record is so filed, the Commissioner may modify or set aside any determination made under such proceedings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d27-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submissions and determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, in an action under this subsection to review a final determination of the Commissioner under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/b"},"text":"section 721(b) of this title","children":[],"tail":" or subsection (c), the petitioner or the Commissioner applies to the court for leave to have additional oral submissions or written presentations made respecting such determination, the court may, for good cause shown, order the Commissioner to provide within 30 days an additional opportunity to make such submissions and presentations. Within such period, the Commissioner may revise any findings of fact, modify or set aside the determination being reviewed, or make a new determination by reason of the additional submissions and presentations, and shall file such modified or new determination, and any revised findings of fact, with the return of such submissions and presentations. The court shall thereafter review such new or modified determination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a7b3d28-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5a7b3d29-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the filing of a petition under paragraph (1) for judicial review of a determination, the court shall have jurisdiction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5a7b3d2a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to grant appropriate relief as provided in chapter 7 of title 5, except for interim relief with respect to a determination under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5a7b3d2b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided in subparagraph (B), to review such determination in accordance with chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5a7b3d2c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s727/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"Section 706 of title 5","children":[],"tail":" shall apply to the review of any determination under this subsection, except that the standard for review prescribed by paragraph (2)(E) of such section 706 shall not apply and the court shall hold unlawful and set aside such determination if the court finds that the determination is not supported by substantial evidence in the record of the proceeding submitted pursuant to paragraph (1), as supplemented by any additional submissions and presentations filed under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a7dae2d-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s107"},"text":"Pub. L. 93–112, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s404"},"text":"Pub. L. 105–220, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1157"},"text":"112 Stat. 1157","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s417/a"},"text":"Pub. L. 113–128, title IV, § 417(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1654"},"text":"128 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a7dae2e-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a7dae2f-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a7dae30-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 727, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s107"},"text":"Pub. L. 93–112, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s128/a"},"text":"Pub. L. 102–569, title I, § 128(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4386"},"text":"106 Stat. 4386","children":[],"tail":", related to monitoring and review, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a7dae31-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s417/a/1/A"},"text":"Pub. L. 113–128, § 417(a)(1)(A)","children":[],"tail":", inserted “, including personnel of a client assistance program under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s732"},"text":"section 732 of this title","children":[],"tail":", and past or current recipients of vocational rehabilitation services” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s417/a/1/B/i"},"text":"Pub. L. 113–128, § 417(a)(1)(B)(i)","children":[],"tail":", added subpars. (A) and (B) and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the eligibility process;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the provision of services, including, if applicable, the order of selection;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s417/a/1/B/ii"},"text":"Pub. L. 113–128, § 417(a)(1)(B)(ii)","children":[],"tail":"–(iv), added subpar. (D) and redesignated former subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s417/a/2"},"text":"Pub. L. 113–128, § 417(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a7dae32-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id5a7dae33-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions of Terms in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s3"},"text":"section 3 of Pub. L. 113–128","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":", apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
