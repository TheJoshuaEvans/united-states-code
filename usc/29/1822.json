{"tag":"section","attrib":{"id":"id5b5919a9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1822"},"text":null,"children":[{"tag":"num","attrib":{"value":"1822"},"text":"§ 1822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages, supplies, and other working arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5919aa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each farm labor contractor, agricultural employer, and agricultural association which employs any migrant agricultural worker shall pay the wages owed to such worker when due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5919ab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of goods or services by worker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No farm labor contractor, agricultural employer, or agricultural association shall require any migrant agricultural worker to purchase any goods or services solely from such farm labor contractor, agricultural employer, or agricultural association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5919ac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1822/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of terms of working arrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No farm labor contractor, agricultural employer, or agricultural association shall, without justification, violate the terms of any working arrangement made by that contractor, employer, or association with any migrant agricultural worker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5919ad-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/tII/s202"},"text":"Pub. L. 97–470, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2591"},"text":"96 Stat. 2591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5919ae-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5919af-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b5919b0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days from ","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/470/s524"},"text":"section 524 of Pub. L. 97–470","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
