{"tag":"section","attrib":{"id":"id5b5b636b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1863"},"text":null,"children":[{"tag":"num","attrib":{"value":"1863"},"text":"§ 1863.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements with Federal and State agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b5b636c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1863/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into agreements with Federal and State agencies (1) to use their facilities and services, (2) to delegate, subject to subsection (b), to Federal and State agencies such authority, other than rulemaking, as may be useful in carrying out this chapter, and (3) to allocate or transfer funds to, or otherwise pay or reimburse, such agencies for expenses incurred pursuant to agreements under clause (1) or (2) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b5b636d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1863/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority pursuant to written State plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any delegation to a State agency pursuant to subsection (a)(2) shall be made only pursuant to a written State plan which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5b636e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1863/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a description of the functions to be performed, the methods of performing such functions, and the resources to be devoted to the performance of such functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5b636f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1863/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides assurances satisfactory to the Secretary that the State agency will comply with its description under paragraph (1) and that the State agency’s performance of functions so delegated will be at least comparable to the performance of such functions by the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5b6370-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/470/tV/s513"},"text":"Pub. L. 97–470, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2599"},"text":"96 Stat. 2599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5b6371-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b5b6372-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b5b6373-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days from ","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/470/s524"},"text":"section 524 of Pub. L. 97–470","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1801"},"text":"section 1801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
