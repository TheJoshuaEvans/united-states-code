{"tag":"section","attrib":{"id":"id5ba7af2b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3251"},"text":null,"children":[{"tag":"num","attrib":{"value":"3251"},"text":"§ 3251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State legislative authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5ba7af2c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of State legislature","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be interpreted to preclude the enactment of State legislation providing for the implementation, consistent with the provisions of this subchapter, of the activities assisted under this subchapter. Any funds received by a State under this subchapter shall be subject to appropriation by the State legislature, consistent with the terms and conditions required under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5ba7af2d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate compacts and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that compliance with provisions of this subchapter would be enhanced by compacts and cooperative agreements between States, the consent of Congress is given to States to enter into such compacts and agreements to facilitate such compliance, subject to the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5ba7af2e-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s191"},"text":"Pub. L. 113–128, title I, § 191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1603"},"text":"128 Stat. 1603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5ba7af2f-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5ba7af30-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5ba7af31-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
