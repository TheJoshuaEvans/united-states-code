{"tag":"section","attrib":{"id":"id5baa1fdf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3273"},"text":null,"children":[{"tag":"num","attrib":{"value":"3273"},"text":"§ 3273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home schools","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to affect home schools, whether a home school is treated as a home school or a private school under State law, or to compel a parent or family member engaged in home schooling to participate in adult education and literacy activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5baa1fe0-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s204"},"text":"Pub. L. 113–128, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1611"},"text":"128 Stat. 1611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5baa1fe1-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5baa1fe2-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5baa1fe3-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
