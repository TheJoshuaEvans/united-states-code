{"tag":"section","attrib":{"id":"id5baa2023-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each eligible agency shall be responsible for the State or outlying area administration of activities under this subchapter, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5baa2024-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, implementation, and monitoring of the relevant components of the unified State plan in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3112"},"text":"section 3112 of this title","children":[],"tail":" or the combined State plan in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3113"},"text":"section 3113 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa2025-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation with other appropriate agencies, groups, and individuals that are involved in, or interested in, the development and implementation of activities assisted under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5baa2026-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination and nonduplication with other Federal and State education, training, corrections, public housing, and social service programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5baa2027-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s221"},"text":"Pub. L. 113–128, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1614"},"text":"128 Stat. 1614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5baa2028-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5baa2029-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5baa202a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
