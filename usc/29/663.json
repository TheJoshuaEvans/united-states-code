{"tag":"section","attrib":{"id":"id5a61259e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s663"},"text":null,"children":[{"tag":"num","attrib":{"value":"663"},"text":"§ 663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation in civil litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s518/a"},"text":"section 518(a) of title 28","children":[],"tail":" relating to litigation before the Supreme Court, the Solicitor of Labor may appear for and represent the Secretary in any civil litigation brought under this chapter but all such litigations shall be subject to the direction and control of the Attorney General."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5a61259f-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596/s14"},"text":"Pub. L. 91–596, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1606"},"text":"84 Stat. 1606","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
