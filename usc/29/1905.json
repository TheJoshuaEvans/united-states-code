{"tag":"section","attrib":{"id":"id5b5dd4af-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905"},"text":null,"children":[{"tag":"num","attrib":{"value":"1905"},"text":"§ 1905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b5dd4b0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “Helen Keller National Center for Youths and Adults who are Deaf-Blind” and “Center” mean the Helen Keller National Center for Youths and Adults who are Deaf-Blind, and its affiliated network, operated pursuant to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4b1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “individual who is deaf-blind” means any individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b5dd4b2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b5dd4b3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has a central visual acuity of 20/200 or less in the better eye with corrective lenses, or a field defect such that the peripheral diameter of visual field subtends an angular distance no greater than 20 degrees, or a progressive visual loss having a prognosis leading to one or both these conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd4b4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has a chronic hearing impairment so severe that most speech cannot be understood with optimum amplification, or a progressive hearing loss having a prognosis leading to this condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b5dd4b5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for whom the combination of impairments described in clauses (i) and (ii) cause extreme difficulty in attaining independence in daily life activities, achieving psychosocial adjustment, or obtaining a vocation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4b6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who despite the inability to be measured accurately for hearing and vision loss due to cognitive or behavioral constraints, or both, can be determined through functional and performance assessment to have severe hearing and visual disabilities that cause extreme difficulty in attaining independence in daily life activities, achieving psychosocial adjustment, or obtaining vocational objectives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b5dd4b7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other requirements as the Secretary may prescribe by regulation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b5dd4b8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1905/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b5dd4b9-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/221/tII/s206"},"text":"Pub. L. 98–221, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-22"},"text":"Feb. 22, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/34"},"text":"98 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tIX"},"text":"Pub. L. 102–569, title IX","children":[],"tail":", §§ 905, 908(c)(1), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4482"},"text":"106 Stat. 4482","children":[],"tail":", 4486.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b5dd4ba-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b5dd4bb-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b5dd4bc-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569"},"text":"Pub. L. 102–569","children":[],"tail":", §§ 905(1), 908(c)(1), substituted “Youths and Adults who are Deaf-Blind” for “Deaf-Blind Youths and Adults” in two places and struck out “section 313 of the Rehabilitation Act of 1973 and continued under” after “operated pursuant to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569/s905/2"},"text":"Pub. L. 102–569, § 905(2)","children":[],"tail":", amended par. (2) generally, substituting present provisions for provisions defining “deaf-blind individual”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
