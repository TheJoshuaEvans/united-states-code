{"tag":"section","attrib":{"id":"id5b70e821-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008"},"text":null,"children":[{"tag":"num","attrib":{"value":"3008"},"text":"§ 3008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; reservations and distribution of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b70e822-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e823-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $44,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e824-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,980,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e825-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $48,049,100 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e826-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,211,310 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e827-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $52,470,819 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b70e828-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservations and distribution of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), for each fiscal year for which funds are made available under subsection (a) to carry out this chapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b70e829-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve an amount equal to 3 percent of the funds made available for each such fiscal year to carry out paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3005/b"},"text":"section 3005(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b70e82a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from the amounts remaining after making the reservation under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b70e82b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use 85.5 percent of such amounts to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3003"},"text":"section 3003 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b73582c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use 14.5 percent of such amounts to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3004"},"text":"section 3004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b73582d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit for projects of national significance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any fiscal year for which the amount made available under subsection (a) exceeds $49,000,000 the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b73582e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reserve for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3006"},"text":"section 3006 of this title","children":[],"tail":", an amount of such available funds that does not exceed the lesser of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b73582f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the excess amount made available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b735830-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b735831-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3008/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the reservation under paragraph (1) before carrying out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b735832-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/394/s9"},"text":"Pub. L. 105–394, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIV/s5402"},"text":"Pub. L. 117–263, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3289"},"text":"136 Stat. 3289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b735833-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b735834-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b735835-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect