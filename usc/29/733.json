{"tag":"section","attrib":{"id":"id5a801eba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733"},"text":null,"children":[{"tag":"num","attrib":{"value":"733"},"text":"§ 733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of pre-employment transition services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a801ebb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the funds reserved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s730/d"},"text":"section 730(d) of this title","children":[],"tail":", and any funds made available from State, local, or private funding sources, each State shall ensure that the designated State unit, in collaboration with the local educational agencies involved, shall provide, or arrange for the provision of, pre-employment transition services for all students with disabilities in need of such services who are eligible or potentially eligible for services under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a801ebc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds available under subsection (a) shall be used to make available to students with disabilities described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a801ebd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job exploration counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ebe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work-based learning experiences, which may include in-school or after school opportunities, or experience outside the traditional school setting (including internships), that is provided in an integrated environment to the maximum extent possible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ebf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling on opportunities for enrollment in comprehensive transition or postsecondary educational programs at institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workplace readiness training to develop social skills and independent living; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruction in self-advocacy, which may include peer mentoring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a801ec2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds available under subsection (a) and remaining after the provision of the required activities described in subsection (b) may be used to improve the transition of students with disabilities described in subsection (a) from school to postsecondary education or an employment outcome by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a801ec3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing effective strategies to increase the likelihood of independent living and inclusion in communities and competitive integrated workplaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and improving strategies for individuals with intellectual disabilities and individuals with significant disabilities to live independently, participate in postsecondary education experiences, and obtain and retain competitive integrated employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing instruction to vocational rehabilitation counselors, school transition personnel, and other persons supporting students with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating information about innovative, effective, and efficient approaches to achieve the goals of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating activities with transition services provided by local educational agencies under the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying evidence-based findings to improve policy, procedure, practice, and the preparation of personnel, in order to better achieve the goals of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ec9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing model transition demonstration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801eca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or supporting multistate or regional partnerships involving States, local educational agencies, designated State units, developmental disability agencies, private businesses, or other participants to achieve the goals of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ecb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating information and strategies to improve the transition to postsecondary activities of individuals who are members of traditionally unserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a801ecc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pre-employment transition coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each local office of a designated State unit shall carry out responsibilities consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a801ecd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attending individualized education program meetings for students with disabilities, when invited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ece-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with the local workforce development boards, one-stop centers, and employers to develop work opportunities for students with disabilities, including internships, summer employment and other employment opportunities available throughout the school year, and apprenticeships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ecf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with schools, including those carrying out activities under section 614(d)(1)(A)(i)(VIII) of the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1414/d/1/A/i/VIII"},"text":"20 U.S.C. 1414(d)(1)(A)(i)(VIII)","children":[],"tail":"), to coordinate and ensure the provision of pre-employment transition services under this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5a801ed0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when invited, attend person-centered planning meetings for individuals receiving services under title XIX of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a801ed1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National pre-employment transition coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall support designated State agencies providing services under this section, highlight best State practices, and consult with other Federal agencies to advance the goals of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a801ed2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s733/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, States shall address the transition needs of all students with disabilities, including such students with physical, sensory, intellectual, and mental health disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a801ed3-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tI/s113"},"text":"Pub. L. 93–112, title I, § 113","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s422"},"text":"Pub. L. 113–128, title IV, § 422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1657"},"text":"128 Stat. 1657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a801ed4-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a801ed5-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5a801ed6-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (c)(5), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":", which is classified generally to chapter 33 (§ 1400 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (d)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XIX of the Act is classified generally to subchapter XIX (§ 1396 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a801ed7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id5a801ed8-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions of Terms in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s3"},"text":"section 3 of Pub. L. 113–128","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3102"},"text":"section 3102 of this title","children":[],"tail":", apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
