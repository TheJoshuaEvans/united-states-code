{"tag":"section","attrib":{"id":"id5b986d13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204"},"text":null,"children":[{"tag":"num","attrib":{"value":"3204"},"text":"§ 3204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce councils","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b986d14-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Job Corps center shall have a workforce council, appointed by the director of the center, in accordance with procedures established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b986d15-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce council composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b986d16-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A workforce council shall be comprised of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b986d17-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a majority of members who shall be owners of business concerns, chief executives or chief operating officers of nongovernmental employers, or other private sector employers, who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b986d18-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have substantial management, hiring, or policy responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b986d19-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent businesses with employment opportunities that reflect the employment opportunities of the applicable local areas in which enrollees will be seeking employment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b986d1a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of labor organizations (where present) and representatives of employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b98942b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrollees and graduates of the Job Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b98942c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The workforce council may include members of the applicable local boards who meet the requirements described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b98942d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employers outside of local area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The workforce council for a Job Corps center may include, or otherwise provide for consultation with, employers from outside the local area who are likely to hire a significant number of enrollees from the Job Corps center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b98942e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for single State local areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a single State local area designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3121/d"},"text":"section 3121(d) of this title","children":[],"tail":", the workforce council shall include a representative of the State Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b98942f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of the workforce council shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b989430-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work closely with all applicable local boards in order to determine, and recommend to the Secretary, appropriate career and technical education and training for the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b989431-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to review all the relevant labor market information, including related information in the State plan or the local plan, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b989432-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend the in-demand industry sectors or occupations in the area in which the Job Corps center operates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b989433-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the employment opportunities in the local areas in which the enrollees intend to seek employment after graduation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b989434-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the skills and education that are necessary to obtain the employment opportunities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b989435-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Secretary the type of career and technical education and training that should be implemented at the center to enable the enrollees to obtain the employment opportunities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b989436-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet at least once every 6 months to reevaluate the labor market information, and other relevant information, to determine, and recommend to the Secretary, any necessary changes in the career and technical education and training provided at the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b989437-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The workforce council for a Job Corps center that is not yet operating shall carry out the responsibilities described in subsection (c) at least 3 months prior to the date on which the center accepts the first enrollee at the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b98ba48-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tI/s154"},"text":"Pub. L. 113–128, title I, § 154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1551"},"text":"128 Stat. 1551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b98ba49-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b98ba4a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5b98ba4b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
