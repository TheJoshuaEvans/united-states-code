{"tag":"section","attrib":{"id":"id5b3edad3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348"},"text":null,"children":[{"tag":"num","attrib":{"value":"1348"},"text":"§ 1348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination date","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b3edad4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subchapter the termination date of a single-employer plan is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edad5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan terminated in a standard termination in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341/b"},"text":"section 1341(b) of this title","children":[],"tail":", the termination date proposed in the notice provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341/a/2"},"text":"section 1341(a)(2) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edad6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan terminated in a distress termination in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341/c"},"text":"section 1341(c) of this title","children":[],"tail":", the date established by the plan administrator and agreed to by the corporation,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edad7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan terminated in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1342"},"text":"section 1342 of this title","children":[],"tail":", the date established by the corporation and agreed to by the plan administrator, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edad8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan terminated under section 1341(c) or 1342 of this title in any case in which no agreement is reached between the plan administrator and the corporation (or the trustee), the date established by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b3edad9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subchapter, the date of termination of a multiemployer plan is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b3edada-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan terminated in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341a"},"text":"section 1341a of this title","children":[],"tail":", the date determined under subsection (b) of that section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b3edadb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1348/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a plan terminated in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1342"},"text":"section 1342 of this title","children":[],"tail":", the date agreed to between the plan administrator and the corporation (or the trustee appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1342/b/2"},"text":"section 1342(b)(2) of this title","children":[],"tail":", if any), or, if no agreement is reached, the date established by the court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b3edadc-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tIV/s4048"},"text":"Pub. L. 93–406, title IV, § 4048","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1028"},"text":"88 Stat. 1028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIV/s402/a/8"},"text":"Pub. L. 96–364, title IV, § 402(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1299"},"text":"94 Stat. 1299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXI/s11016/a/4"},"text":"Pub. L. 99–272, title XI, § 11016(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/268"},"text":"100 Stat. 268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b3edadd-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b3edade-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b3edadf-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" in provisions preceding par. (1) substituted “termination date” for “date of termination”, redesignated pars. (1) to (3) as (2) to (4), respectively, added par. (1), in par. (2), as so redesignated, inserted “in a distress termination” after “terminated” and substituted “section 1341(c)” for “section 1341”, and in par. (4), as so redesignated, substituted “under section 1341(c) or 1342 of this title” for “in accordance with the provisions of either section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/s402/a/8/A"},"text":"Pub. L. 96–364, § 402(a)(8)(A)","children":[],"tail":", (B), designated existing provisions as subsec. (a), and inserted applicability to a single-employer plan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/s402/a/8/C"},"text":"Pub. L. 96–364, § 402(a)(8)(C)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b3edae0-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b3edae1-3a70