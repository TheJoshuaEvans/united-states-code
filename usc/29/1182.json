{"tag":"section","attrib":{"id":"id5b13faa5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182"},"text":null,"children":[{"tag":"num","attrib":{"value":"1182"},"text":"§ 1182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibiting discrimination against individual participants and beneficiaries based on health status","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b13faa6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In eligibility to enroll","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b13faa7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a group health plan, and a health insurance issuer offering group health insurance coverage in connection with a group health plan, may not establish rules for eligibility (including continued eligibility) of any individual to enroll under the terms of the plan based on any of the following health status-related factors in relation to the individual or a dependent of the individual:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b13faa8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13faa9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical condition (including both physical and mental illnesses).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13faaa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13faab-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Receipt of health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13faac-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical history.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13faad-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Genetic information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13faae-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidence of insurability (including conditions arising out of acts of domestic violence).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13faaf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fab0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No application to benefits or exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of this title","children":[],"tail":", paragraph (1) shall not be construed—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b13fab1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a group health plan, or group health insurance coverage, to provide particular benefits other than those provided under the terms of such plan or coverage, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fab2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent such a plan or coverage from establishing limitations or restrictions on the amount, level, extent, or nature of the benefits or coverage for similarly situated individuals enrolled in the plan or coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fab3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), rules for eligibility to enroll under a plan include rules defining any applicable waiting periods for such enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b13fab4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In premium contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b13fab5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan, and a health insurance issuer offering health insurance coverage in connection with a group health plan, may not require any individual (as a condition of enrollment or continued enrollment under the plan) to pay a premium or contribution which is greater than such premium or contribution for a similarly situated individual enrolled in the plan on the basis of any health status-related factor in relation to the individual or to an individual enrolled under the plan as a dependent of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fab6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in paragraph (1) shall be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b13fab7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict the amount that an employer may be charged for coverage under a group health plan except as provided in paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fab8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent a group health plan, and a health insurance issuer offering group health insurance coverage, from establishing premium discounts or rebates or modifying otherwise applicable copayments or deductibles in return for adherence to programs of health promotion and disease prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fab9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No group-based discrimination on basis of genetic information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b13faba-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, a group health plan, and a health insurance issuer offering group health insurance coverage in connection with a group health plan, may not adjust premium or contribution amounts for the group covered under such plan on the basis of genetic information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fabb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subparagraph (A) or in paragraphs (1) and (2) of subsection (d) shall be construed to limit the ability of a health insurance issuer offering health insurance coverage in connection with a group health plan to increase the premium for an employer based on the manifestation of a disease or disorder of an individual who is enrolled in the plan. In such case, the manifestation of a disease or disorder in one individual cannot also be used as genetic information about other group members and to further increase the premium for the employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b13fabc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic testing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b13fabd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on requesting or requiring genetic testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan, and a health insurance issuer offering health insurance coverage in connection with a group health plan, shall not request or require an individual or a family member of such individual to undergo a genetic test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fabe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not be construed to limit the authority of a health care professional who is providing health care services to an individual to request that such individual undergo a genetic test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fabf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction regarding payment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b13fac0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to preclude a group health plan, or a health insurance issuer offering health insurance coverage in connection with a group health plan, from obtaining and using the results of a genetic test in making a determination regarding payment (as such term is defined for the purposes of applying the regulations promulgated by the Secretary of Health and Human Services under part C of title XI of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d"},"text":"42 U.S.C. 1320d","children":[],"tail":" et seq.] and section 264 of the Health Insurance Portability and Accountability Act of 1996, as may be revised from time to time) consistent with subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fac1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subparagraph (A), a group health plan, or a health insurance issuer offering health insurance coverage in connection with a group health plan, may request only the minimum amount of information necessary to accomplish the intended purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fac2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), a group health plan, or a health insurance issuer offering health insurance coverage in connection with a group health plan, may request, but not require, that a participant or beneficiary undergo a genetic test if each of the following conditions is met:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b13fac3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The request is made, in writing, pursuant to research that complies with part 46 of title 45, Code of Federal Regulations, or equivalent Federal regulations, and any applicable State or local law or regulations for the protection of human subjects in research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fac4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The plan or issuer clearly indicates to each participant or beneficiary, or in the case of a minor child, to the legal guardian of such beneficiary, to whom the request is made that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b13fac5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the request is voluntary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b13fac6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-compliance will have no effect on enrollment status or premium or contribution amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fac7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No genetic information collected or acquired under this paragraph shall be used for underwriting purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fac8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan or issuer notifies the Secretary in writing that the plan or issuer is conducting activities pursuant to the exception provided for under this paragraph, including a description of the activities conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b13fac9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The plan or issuer complies with such other conditions as the Secretary may by regulation require for activities conducted under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b13faca-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on collection of genetic information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b13facb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan, and a health insurance issuer offering health insurance coverage in connection with a group health plan, shall not request, require, or purchase genetic information for underwriting purposes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191b"},"text":"section 1191b of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13facc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on collection of genetic information prior to enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A group health plan, and a health insurance issuer offering health insurance coverage in connection with a group health plan, shall not request, require, or purchase genetic information with respect to any individual prior to such individual’s enrollment under the plan or coverage in connection with such enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13facd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incidental collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a group health plan, or a health insurance issuer offering health insurance coverage in connection with a group health plan, obtains genetic information incidental to the requesting, requiring, or purchasing of other information concerning any individual, such request, requirement, or purchase shall not be considered a violation of paragraph (2) if such request, requirement, or purchase is not in violation of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b13face-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to all plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (a)(1)(F), (b)(3), (c), and (d), and subsection (b)(1) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of this title","children":[],"tail":" with respect to genetic information, shall apply to group health plans and health insurance issuers without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191a/a"},"text":"section 1191a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b13facf-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Genetic information of a fetus or embryo","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any reference in this part to genetic information concerning an individual or family member of an individual shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b13fad0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such an individual or family member of an individual who is a pregnant woman, include genetic information of any fetus carried by such pregnant woman; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b13fad1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1182/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an individual or family member utilizing an assisted reproductive technology, include genetic information of any embryo legally held by the individual or family member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b13fad2-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s702"},"text":"Pub. L. 93–406, title I, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s101/a"},"text":"Pub. L. 104–191, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1945"},"text":"110 Stat. 1945","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/233/tI/s101/a"},"text":"Pub. L. 110–233, title I, § 101(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/883"},"text":"122 Stat. 883","children":[],"tail":", 885.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5b13fad3-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5b13fad4-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5b13fad5-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (c)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Part C of title XI of the Act is classified generally to part C (§ 1320d et seq.) of subchapter XI of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 264 of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (c)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264"},"text":"section 264 of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5b13fad6-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/s101/a/1"},"text":"Pub. L. 110–233, § 101(a)(1)","children":[],"tail":", inserted “except as provided in paragraph (3)” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/s101/a/2"},"text":"Pub. L. 110–233, § 101(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/s101/b"},"text":"Pub. L. 110–233, § 101(b)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233/s101/c"},"text":"Pub. L. 110–233, § 101(c)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5b13fad7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5b13fad8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233"},"text":"Pub. L. 110–233","children":[],"tail":" applicable with respect to group health plans for plan years beginning after the date that is one year after "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/233/s101/f/2"},"text":"section 101(f)(2) of Pub. L. 110–233","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1132"},"text":"section 1132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
