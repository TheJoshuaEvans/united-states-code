:[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/200/s401/h/2/A/ii"},"text":"Pub. L. 105–200, § 401(h)(2)(A)(ii)","children":[],"tail":", substituted “they apply to” for “enforced by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/200/s401/h/2/A/i"},"text":"Pub. L. 105–200, § 401(h)(2)(A)(i)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s4301/c/4/A"},"text":"Pub. L. 103–66, § 4301(c)(4)(A)","children":[],"tail":". See 1993 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191"},"text":"section 1191 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":" added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s4301/c/4/A"},"text":"Pub. L. 103–66, § 4301(c)(4)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/200/s401/h/1/A/i"},"text":"Pub. L. 105–200, § 401(h)(1)(A)(i)","children":[],"tail":", inserted “, qualified medical child support orders (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1169/a/2/A"},"text":"section 1169(a)(2)(A) of this title","children":[],"tail":"), and the provisions of law referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1169/a/2/B/ii"},"text":"section 1169(a)(