{"tag":"section","attrib":{"id":"id5b07ec6e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144"},"text":null,"children":[{"tag":"num","attrib":{"value":"1144"},"text":"§ 1144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5b07ec6f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supersedure; effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b) of this section, the provisions of this subchapter and subchapter III shall supersede any and all State laws insofar as they may now or hereafter relate to any employee benefit plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/a"},"text":"section 1003(a) of this title","children":[],"tail":" and not exempt under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/b"},"text":"section 1003(b) of this title","children":[],"tail":". This section shall take effect on "},{"tag":"date","attrib":{"date":"1975-01-01"},"text":"January 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ec70-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b07ec71-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply with respect to any cause of action which arose, or any act or omission which occurred, before ","children":[{"tag":"date","attrib":{"date":"1975-01-01"},"text":"January 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec72-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ec73-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), nothing in this subchapter shall be construed to exempt or relieve any person from any law of any State which regulates insurance, banking, or securities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec74-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Neither an employee benefit plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/a"},"text":"section 1003(a) of this title","children":[],"tail":", which is not exempt under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/b"},"text":"section 1003(b) of this title","children":[],"tail":" (other than a plan established primarily for the purpose of providing death benefits), nor any trust established under such a plan, shall be deemed to be an insurance company or other insurer, bank, trust company, or investment company or to be engaged in the business of insurance or banking for purposes of any law of any State purporting to regulate insurance companies, insurance contracts, banks, trust companies, or investment companies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec75-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to prohibit use by the Secretary of services or facilities of a State agency as permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1136"},"text":"section 1136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec76-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall not apply to any generally applicable criminal law of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec77-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ec78-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), subsection (a) shall not apply to the Hawaii Prepaid Health Care Act (Haw. Rev. Stat. §§ 393–1 through 393–51).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec79-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in subparagraph (A) shall be construed to exempt from subsection (a)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b07ec7a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State tax law relating to employee benefit plans, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b07ec7b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amendment of the Hawaii Prepaid Health Care Act enacted after ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"September 2, 1974","children":[],"tail":", to the extent it provides for more than the effective administration of such Act as in effect on such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec7c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subparagraph (A), parts 1 and 4 of this subtitle, and the preceding sections of this part to the extent they govern matters which are governed by the provisions of such parts 1 and 4, shall supersede the Hawaii Prepaid Health Care Act (as in effect on or after ","children":[{"tag":"date","attrib":{"date":"1983-01-14"},"text":"January 14, 1983","children":[],"tail":"), but the Secretary may enter into cooperative arrangements under this paragraph and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1136"},"text":"section 1136 of this title","children":[],"tail":" with officials of the State of Hawaii to assist them in effectuating the policies of provisions of such Act which are superseded by such parts 1 and 4 and the preceding sections of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec7d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ec7e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b07ec7f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an employee welfare benefit plan which is a multiple employer welfare arrangement and is fully insured (or which is a multiple employer welfare arrangement subject to an exemption under subparagraph (B)), any law of any State which regulates insurance may apply to such arrangement to the extent that such law provides—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5b07ec80-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards, requiring the maintenance of specified levels of reserves and specified levels of contributions, which any such plan, or any trust established under such a plan, must meet in order to be considered under such law able to pay benefits in full when due, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5b07ec81-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions to enforce such standards, and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b07ec82-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other employee welfare benefit plan which is a multiple employer welfare arrangement, in addition to this subchapter, any law of any State which regulates insurance may apply to the extent not inconsistent with the preceding sections of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec83-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, under regulations which may be prescribed by the Secretary, exempt from subparagraph (A)(ii), individually or by class, multiple employer welfare arrangements which are not fully insured. Any such exemption may be granted with respect to any arrangement or class of arrangements only if such arrangement or each arrangement which is a member of such class meets the requirements of section 1002(1) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003"},"text":"section 1003 of this title","children":[],"tail":" necessary to be considered an employee welfare benefit plan to which this subchapter applies."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec84-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in subparagraph (A) shall affect the manner or extent to which the provisions of this subchapter apply to an employee welfare benefit plan which is not a multiple employer welfare arrangement and which is a plan, fund, or program participating in, subscribing to, or otherwise using a multiple employer welfare arrangement to fund or administer benefits to such plan’s participants and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec85-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph, a multiple employer welfare arrangement shall be considered fully insured only if the terms of the arrangement provide for benefits the amount of all of which the Secretary determines are guaranteed under a contract, or policy of insurance, issued by an insurance company, insurance service, or insurance organization, qualified to conduct business in a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec86-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall not apply to qualified domestic relations orders (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1056/d/3/B/i"},"text":"section 1056(d)(3)(B)(i) of this title","children":[],"tail":"), qualified medical child support orders (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1169/a/2/A"},"text":"section 1169(a)(2)(A) of this title","children":[],"tail":"), and the provisions of law referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1169/a/2/B/ii"},"text":"section 1169(a)(2)(B)(ii) of this title","children":[],"tail":" to the extent they apply to qualified medical child support orders."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec87-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) of this section shall not be construed to preclude any State cause of action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ec88-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the State exercises its acquired rights under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1169/b/3"},"text":"section 1169(b)(3) of this title","children":[],"tail":" with respect to a group health plan (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1167/1"},"text":"section 1167(1) of this title","children":[],"tail":"), or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec89-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for recoupment of payment with respect to items or services pursuant to a State plan for medical assistance approved under title XIX of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.] which would not have been payable if such acquired rights had been executed before payment with respect to such items or services by the group health plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec8a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For additional provisions relating to group health plans, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1191"},"text":"section 1191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ec8b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b07ec8c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State law” includes all laws, decisions, rules, regulations, or other State action having the effect of law, of any State. A law of the United States applicable only to the District of Columbia shall be treated as a State law rather than a law of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec8d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes a State, any political subdivisions thereof, or any agency or instrumentality of either, which purports to regulate, directly or indirectly, the terms and conditions of employee benefit plans covered by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ec8e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alteration, amendment, modification, invalidation, impairment, or supersedure of any law of the United States prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to alter, amend, modify, invalidate, impair, or supersede any law of the United States (except as provided in sections 1031 and 1137(b) of this title) or any rule or regulation issued under any such law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5b07ec8f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic contribution arrangements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5b07ec90-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section, this subchapter shall supersede any law of a State which would directly or indirectly prohibit or restrict the inclusion in any plan of an automatic contribution arrangement. The Secretary may prescribe regulations which would establish minimum standards that such an arrangement would be required to satisfy in order for this subsection to apply in the case of such arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec91-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, the term “automatic contribution arrangement” means an arrangement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ec92-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which a participant may elect to have the plan sponsor make payments as contributions under the plan on behalf of the participant, or to the participant directly in cash,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec93-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which a participant is treated as having elected to have the plan sponsor make such contributions in an amount equal to a uniform percentage of compensation provided under the plan until the participant specifically elects not to have such contributions made (or specifically elects to have such contributions made at a different percentage), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec94-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which such contributions are invested in accordance with regulations prescribed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1104/c/5"},"text":"section 1104(c)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5b07ec95-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5b07ec96-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The plan administrator of an automatic contribution arrangement shall, within a reasonable period before such plan year, provide to each participant to whom the arrangement applies for such plan year notice of the participant’s rights and obligations under the arrangement which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b07ec97-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is sufficiently accurate and comprehensive to apprise the participant of such rights and obligations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b07ec98-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is written in a manner calculated to be understood by the average participant to whom the arrangement applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5b07ec99-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notice shall not be treated as meeting the requirements of subparagraph (A) with respect to a participant unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5b07ec9a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice includes an explanation of the participant’s right under the arrangement not to have elective contributions made on the participant’s behalf (or to elect to have such contributions made at a different percentage),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b07ec9b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant has a reasonable period of time, after receipt of the notice described in clause (i) and before the first elective contribution is made, to make such election, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5b07ec9c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1144/e/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice explains how contributions made under the arrangement will be invested in the absence of any investment election by the participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5b07ec9d-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s514"},"text":"Pub. L. 93–406, title I, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/897"},"text":"88 Stat. 897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/473/tIII"},"text":"Pub. L. 97–473, title III","children":[],"tail":", §§ 301(a), 302(b), "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2611"},"text":"96 Stat. 2611","children":[],"tail":", 2613; "},{"tag":"ref","attrib":{"href":"/us/pl/98/397/tI/s104/b"},"text":"Pub. L. 98–397, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-23"},"text":"Aug. 23, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/st