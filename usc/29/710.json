{"tag":"section","attrib":{"id":"id5a6d0c1e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s710"},"text":null,"children":[{"tag":"num","attrib":{"value":"710"},"text":"§ 710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5a6d0c1f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one hundred and eighty days after the close of each fiscal year, the Commissioner shall prepare and submit to the President and to the Congress a full and complete report on the activities carried out under this chapter, including the activities and staffing of the information clearinghouse under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s712"},"text":"section 712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c20-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall collect information to determine whether the purposes of this chapter are being met and to assess the performance of programs carried out under this chapter. The Commissioner shall take whatever action is necessary to assure that the identity of each individual for which information is supplied under this section is kept confidential, except as otherwise required by law (including regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c21-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be included in reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5a6d0c22-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no par. (2)."}],"tail":" In preparing the report, the Commissioner shall annually collect and include in the report information based on the information submitted by States in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/10"},"text":"section 721(a)(10) of this title","children":[],"tail":", including information on administrative costs as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s721/a/10/D"},"text":"section 721(a)(10)(D) of this title","children":[],"tail":". The Commissioner shall, to the maximum extent appropriate, include in the report all information that is required to be submitted in the reports described in "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/d/2"},"text":"section 3141(d)(2) of this title","children":[],"tail":" and that pertains to the employment of individuals with disabilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5a6d0c23-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall ensure that the report described in this section is made publicly available in a timely manner, including through electronic means, in order to inform the public about the administration and performance of programs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5a6d0c24-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s13"},"text":"Pub. L. 93–112, § 13","children":[],"tail":", formerly § 11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1111"},"text":"112 Stat. 1111","children":[],"tail":"; renumbered § 13, "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s402/a/1"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 402(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–412; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s406"},"text":"Pub. L. 113–128, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1638"},"text":"128 Stat. 1638","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5a6d0c25-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5a6d0c26-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5a6d0c27-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s712"},"text":"section 712 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 710, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s11"},"text":"Pub. L. 93–112, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/602/tI/s121"},"text":"Pub. L. 95–602, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2984"},"text":"92 Stat. 2984","children":[],"tail":", related to application of other laws, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s403"},"text":"Pub. L. 105–220, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1093"},"text":"112 Stat. 1093","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s708"},"text":"section 708 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s13"},"text":"section 13 of Pub. L. 93–112","children":[],"tail":" was renumbered section 15 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s712"},"text":"section 712 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/s13"},"text":"section 13 of Pub. L. 93–112","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s712"},"text":"section 712 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5a6d0c28-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s406/1"},"text":"Pub. L. 113–128, § 406(1)","children":[],"tail":", designated existing provisions as par. (1) and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3141/d/2"},"text":"section 3141(d)(2) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2871/d"},"text":"section 2871(d) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s406/2"},"text":"Pub. L. 113–128, § 406(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5a6d0c29-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5a6d0c2a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exchange of Data","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/569/tI/s137"},"text":"Pub. L. 102–569, title I, § 137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4397"},"text":"106 Stat. 4397","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/569/tI/s137"},"text":"“The Secretary of Education and the Secretary of Health and Human Services shall enter into a memorandum of understanding for the purpose of exchanging data of mutual importance, regarding clients of State vocational rehabilitation agencies, that are contained in databases maintained by the Rehabilitation Services Administration, as required under section 13 of the Rehabilitation Act of 1973 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s712"},"text":"29 U.S.C. 712","children":[],"tail":"), and the Social Security Administration, from its Summary Earnings and Records and Master Beneficiary Records. For purposes of the exchange, the Social Security data shall not be considered tax information and, as appropriate, the confidentiality of all client information shall be maintained by both agencies.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
