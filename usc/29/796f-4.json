{"tag":"section","attrib":{"id":"id5aa644ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"796f–4"},"text":"§ 796f–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and assurances for centers for independent living","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5aa644ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each center for independent living that receives assistance under this subpart shall comply with the standards set out in subsection (b) and provide and comply with the assurances set out in subsection (c) in order to ensure that all programs and activities under this subpart are planned, conducted, administered, and evaluated in a manner consistent with the purposes of this part and the objective of providing assistance effectively and efficiently.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa644ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa644f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Philosophy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The center shall promote and practice the independent living philosophy of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa644f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer control of the center regarding decisionmaking, service delivery, management, and establishment of the policy and direction of the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa644f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-help and self-advocacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa644f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of peer relationships and peer role models; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa644f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal access for individuals with significant disabilities, within their communities, to all services, programs, activities, resources, and facilities, whether public or private and regardless of the funding source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644f5-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The center shall provide services to individuals with a range of significant disabilities. The center shall provide services on a cross-disability basis (for individuals with all different types of significant disabilities, including individuals with significant disabilities who are members of populations that are unserved or underserved by programs under this subchapter). Eligibility for services at any center for independent living shall be determined by the center, and shall not be based on the presence of any one or more specific significant disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644f6-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent living goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The center shall facilitate the development and achievement of independent living goals selected by individuals with significant disabilities who seek such assistance by the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644f7-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community options","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The center shall work to increase the availability and improve the quality of community options for independent living in order to facilitate the development and achievement of independent living goals by individuals with significant disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644f8-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent living core services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The center shall provide independent living core services and, as appropriate, a combination of any other independent living services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644f9-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities to increase community capacity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The center shall conduct activities to increase the capacity of communities within the service area of the center to meet the needs of individuals with significant disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644fa-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource development activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The center shall conduct resource development activities to obtain funding from sources other than this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5aa644fb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assurances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The eligible agency shall provide at such time and in such manner as the Administrator may require, such satisfactory assurances as the Administrator may require, including satisfactory assurances that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5aa644fc-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is an eligible agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644fd-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the center will be designed and operated within local communities by individuals with disabilities, including an assurance that the center will have a Board that is the principal governing body of the center and a majority of which shall be composed of individuals with significant disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644fe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will comply with the standards set forth in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa644ff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will establish clear priorities through annual and 3-year program and financial planning objectives for the center, including overall goals or a mission for the center, a work plan for achieving the goals or mission, specific objectives, service priorities, and types of services to be provided, and a description that shall demonstrate how the proposed activities of the applicant are consistent with the most recent 3-year State plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796c"},"text":"section 796c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64500-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will use sound organizational and personnel assignment practices, including taking affirmative action to employ and advance in employment qualified individuals with significant disabilities on the same terms and conditions required with respect to the employment of individuals with disabilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s793"},"text":"section 793 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64501-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will ensure that the majority of the staff, and individuals in decisionmaking positions, of the applicant are individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64502-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will practice sound fiscal management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa64503-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant will conduct annual self-evaluations, prepare an annual report, and maintain records adequate to measure performance with respect to the standards, containing information regarding, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5aa64504-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the center is in compliance with the standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64505-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and types of individuals with significant disabilities receiving services through the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64506-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of services provided through the center and the number of individuals with significant disabilities receiving each type of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64507-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sources and amounts of funding for the operation of the center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64508-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals with significant disabilities who are employed by, and the number who are in management and decisionmaking positions in, the center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5aa64509-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/8/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison, when appropriate, of the activities of the center in prior years with the activities of the center in the most recent year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6450a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with significant disabilities who are seeking or receiving services at the center will be notified by the center of the existence of, the availability of, and how to contact, the client assistance program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6450b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggressive outreach regarding services provided through the center will be conducted in an effort to reach populations of individuals with significant disabilities that are unserved or underserved by programs under this subchapter, especially minority groups and urban and rural populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6450c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff at centers for independent living will receive training on how to serve such unserved and underserved populations, including minority groups and urban and rural populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6450d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the center will submit to the Statewide Independent Living Council a copy of its approved grant application and the annual report required under paragraph (8);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6450e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the center will prepare and submit a report to the designated State unit or the Administrator, as the case may be, at the end of each fiscal year that contains the information described in paragraph (8) and information regarding the extent to which the center is in compliance with the standards set forth in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5aa6450f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s796f–4/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent living plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796c/e"},"text":"section 796c(e) of this title","children":[],"tail":" will be developed unless the individual who would receive services under the plan signs a waiver stating that such a plan is unnecessary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5aa64510-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s725"},"text":"Pub. L. 93–112, title VII, § 725","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/220/tIV/s410"},"text":"Pub. L. 105–220, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-07"},"text":"Aug. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1234"},"text":"112 Stat. 1234","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/332/s5/c"},"text":"Pub. L. 105–332, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3127"},"text":"112 Stat. 3127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tIV/s483"},"text":"Pub. L. 113–128, title IV, § 483","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1693"},"text":"128 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5aa64511-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5aa64512-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5aa64513-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 796f–4, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112/tVII/s725"},"text":"Pub. L. 93–112, title VII, § 725","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/569/tVII/s701/2"},"text":"Pub. L. 102–569, title VII, § 701(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4462"},"text":"106 Stat. 4462","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/73/tI/s114"},"text":"Pub. L. 103–73, title I, § 114","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/731"},"text":"107 Stat. 731","children":[],"tail":", related to standards and assurances for centers for independent living, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/105/220"},"text":"Pub. L. 105–220","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5aa64514-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s483/1"},"text":"Pub. L. 113–128, § 483(1)","children":[],"tail":", substituted “access for” for “access of” and “, within their communities,” for “to society and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/s483/2"},"text":"Pub. L. 113–128, § 483(2)","children":[],"tail":", substituted “Administrator” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/332"},"text":"Pub. L. 105–332","children":[],"tail":" substituted “management;” for “management, including making arrangements for an annual independent fiscal audit, notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7502/a/2/A"},"text":"section 7502(a)(2)(A) of title 31","children":[],"tail":";”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
