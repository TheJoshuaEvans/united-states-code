{"tag":"section","attrib":{"id":"id5bac91ea-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333"},"text":null,"children":[{"tag":"num","attrib":{"value":"3333"},"text":"§ 3333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated English literacy and civics education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5bac91eb-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3291/a/2"},"text":"section 3291(a)(2) of this title","children":[],"tail":" for each fiscal year, the Secretary shall award grants to States, from allotments under subsection (b), for integrated English literacy and civics education, in combination with integrated education and training activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac91ec-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac91ed-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), from amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3291/a/2"},"text":"section 3291(a)(2) of this title","children":[],"tail":" for a fiscal year, the Secretary shall allocate—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5bac91ee-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 65 percent to the States on the basis of a State’s need for integrated English literacy and civics education, as determined by calculating each State’s share of a 10-year average of the data of the Office of Immigration Statistics of the Department of Homeland Security for immigrants admitted for legal permanent residence for the 10 most recent years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5bac91ef-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 35 percent to the States on the basis of whether the State experienced growth, as measured by the average of the 3 most recent years for which the data of the Office of Immigration Statistics of the Department of Homeland Security for immigrants admitted for legal permanent residence are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91f0-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall receive an allotment under paragraph (1) in an amount that is less than $60,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac91f1-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each program that receives funding under this section shall be designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5bac91f2-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare adults who are English language learners for, and place such adults in, unsubsidized employment in in-demand industries and occupations that lead to economic self-sufficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5bac91f3-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate with the local workforce development system and its functions to carry out the activities of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5bac91f4-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s3333/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prepare and submit to the Committee on Education and the Workforce of the House of Representatives, and the Committee on Health, Education, Labor, and Pensions of the Senate and make available to the public, a report on the activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5bac91f5-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128/tII/s243"},"text":"Pub. L. 113–128, title II, § 243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1623"},"text":"128 Stat. 1623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5bac91f6-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5bac91f7-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5bac91f8-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first full program year after ","children":[{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
