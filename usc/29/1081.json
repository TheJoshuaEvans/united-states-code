{"tag":"section","attrib":{"id":"id5adf7cfe-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081"},"text":null,"children":[{"tag":"num","attrib":{"value":"1081"},"text":"§ 1081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5adf7cff-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans excepted from applicability of this part","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This part shall apply to any employee pension benefit plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/a"},"text":"section 1003(a) of this title","children":[],"tail":", (and not exempted under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1003/b"},"text":"section 1003(b) of this title","children":[],"tail":"), other than—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5adf7d00-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee welfare benefit plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d01-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insurance contract plan described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d02-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan which is unfunded and is maintained by an employer primarily for the purpose of providing deferred compensation for a select group of management or highly compensated employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d03-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5adf7d04-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan which is established and maintained by a society, order, or association described in section 501(c)(8) or (9) of title 26, if no part of the contributions to or under such plan are made by employers of participants in such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5adf7d05-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/18"},"text":"section 501(c)(18) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d06-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan which has not at any time after ","children":[{"tag":"date","attrib":{"date":"1974-09-02"},"text":"September 2, 1974","children":[],"tail":", provided for employer contributions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d07-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement providing payments to a retired partner or deceased partner or a deceased partner’s successor in interest as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s736"},"text":"section 736 of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d08-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual retirement account or annuity as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s408/a"},"text":"section 408(a) of title 26","children":[],"tail":", or a retirement bond described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s409"},"text":"section 409 of title 26","children":[],"tail":" (as effective for obligations issued before "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d09-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual account plan (other than a money purchase plan) and a defined benefit plan to the extent it is treated as an individual account plan (other than a money purchase plan) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/35/B"},"text":"section 1002(35)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d0a-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an excess benefit plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d0b-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plan, fund or program under which an employer, all of whose stock is directly or indirectly owned by employees, former employees or their beneficiaries, proposes through an unfunded arrangement to compensate retired employees for benefits which were forfeited by such employees under a pension plan maintained by a former employer prior to the date such pension plan became subject to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5adf7d0c-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Insurance contract plan” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of paragraph (2) of subsection (a) a plan is an “insurance contract plan” if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5adf7d0d-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is funded exclusively by the purchase of individual insurance contracts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d0e-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contracts provide for level annual premium payments to be paid extending not later than the retirement age for each individual participating in the plan, and commencing with the date the individual became a participant in the plan (or, in the case of an increase in benefits, commencing at the time such increase became effective),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d0f-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits provided by the plan are equal to the benefits provided under each contract at normal retirement age under the plan and are guaranteed by an insurance carrier (licensed under the laws of a State to do business with the plan) to the extent premiums have been paid,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d10-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premiums payable for the plan year, and all prior plan years under such contracts have been paid before lapse or there is reinstatement of the policy,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d11-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no rights under such contracts have been subject to a security interest at any time during the plan year, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5adf7d12-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no policy loans are outstanding at any time during the plan year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A plan funded exclusively by the purchase of group insurance contracts which is determined under regulations prescribed by the Secretary of the Treasury to have the same characteristics as contracts described in the preceding sentence shall be treated as a plan described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5adf7d13-3a70-11f1-8704-e0e66b400d7c","identifier":"/us/usc/t29/s1081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of this part to terminated multiemployer plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part applies, with respect to a terminated multiemployer plan to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1321"},"text":"section 1321 of this title","children":[],"tail":" applies, until the last day of the plan year in which the plan terminates, within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1341a/a/2"},"text":"section 1341a(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5adf7d14-3a70-11f1-8704-e0e66b400d7c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406/tI/s301"},"text":"Pub. L. 93–406, title I, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/868"},"text":"88 Stat. 868","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIII/s304/a"},"text":"Pub. L. 96–364, title III, § 304(a)","children":[],"tail":", title IV, § 411(b), "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1293"},"text":"94 Stat. 1293","children":[],"tail":", 1308; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVII"},"text":"Pub. L. 101–239, title VII","children":[],"tail":", §§ 7891(a)(1), 7894(d)(1)(A), (4)(A), "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2445"},"text":"103 Stat. 2445","children":[],"tail":", 2449; "},{"tag":"ref","attrib":{"href":"/us/pl/109/280/tII/s201/c/1"},"text":"Pub. L. 109–280, title II, § 201(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/868"},"text":"120 Stat. 868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5adf7d15-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5adf7d16-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5adf7d17-3a70-11f1-8704-e0e66b400d7c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s409"},"text":"Section 409 of title 26","children":[],"tail":", referred to in subsec. (a)(7), means "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s409"},"text":"section 409 of Title 26","children":[],"tail":", Internal Revenue Code, prior to its repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s491/b"},"text":"Pub. L. 98–369, div. A, title IV, § 491(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/848"},"text":"98 Stat. 848","children":[],"tail":", applicable to obligations issued after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(10), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", known as the Employee Retirement Income Security Act of 1974. Titles I, III, and IV of such Act are classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5adf7d18-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280"},"text":"Pub. L. 109–280","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows: “Any amount of any financial assistance from the Pension Benefit Guaranty Corporation to any plan, and any repayment of such amount, shall be taken into account under this section in such manner as determined by the Secretary of the Treasury.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(4)(A), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/a/1"},"text":"Pub. L. 101–239, § 7891(a)(1)","children":[],"tail":", substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/d/4/A"},"text":"Pub. L. 101–239, § 7894(d)(4)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t26/s409"},"text":"section 409 of title 26","children":[],"tail":" (as effective for obligations issued before "},{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t26/s409"},"text":"section 409 of title 26","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/d/1/A/i"},"text":"Pub. L. 101–239, § 7894(d)(1)(A)(i)","children":[],"tail":", struck out “or” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/d/1/A/ii"},"text":"Pub. L. 101–239, § 7894(d)(1)(A)(ii)","children":[],"tail":", substituted “; or” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/d/1/A/iii"},"text":"Pub. L. 101–239, § 7894(d)(1)(A)(iii)","children":[],"tail":", substituted “any” for “Any”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/s411/b"},"text":"Pub. L. 96–364, § 411(b)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364/s304/a"},"text":"Pub. L. 96–364, § 304(a)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5adf7d19-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5adf7d1a-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/280/tII/s201/d"},"text":"Pub. L. 109–280, title II, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/868"},"text":"120 Stat. 868","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/280/tII/s201/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1084"},"text":"section 1084 of this title","children":[],"tail":" and amending this section] shall apply to plan years beginning after 2007."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for certain amortization extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of the Treasury grants an extension under section 304 of the Employee Retirement Income Security Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1084"},"text":"29 U.S.C. 1084","children":[],"tail":"] and section 412(e) of the Internal Revenue Code of 1986 [former "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s412/e"},"text":"26 U.S.C. 412(e)","children":[],"tail":"] with respect to any application filed with the Secretary of the Treasury on or before "},{"tag":"date","attrib":{"date":"2005-06-30"},"text":"June 30, 2005","children":[],"tail":", the extension (and any modification thereof) shall be applied and administered under the rules of such sections as in effect before the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-08-17"},"text":"Aug. 17, 2006","children":[],"tail":"], including the use of the rate of interest determined under section 6621(b) of such Code ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621/b"},"text":"26 U.S.C. 6621(b)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5adf7d1b-3a70-11f1-8704-e0e66b400d7c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/a/1"},"text":"section 7891(a)(1) of Pub. L. 101–239","children":[],"tail":" effective, except as otherwise provided, as if included in the provision of the Tax Reform Act of 1986, "},{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":", to which such amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7891/f"},"text":"section 7891(f) of Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s7894/d/1/B"},"text":"Section 7894(d)(1)(B) of Pub. L. 101–239","children":[],"tail":" provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/239/s7894/d/1/B"},"text":"“The amendments made by subparagraph (A) [amending