{"tag":"section","attrib":{"id":"id7aa1f6e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058"},"text":null,"children":[{"tag":"num","attrib":{"value":"9058"},"text":"§ 9058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary moratorium on eviction filings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa1f6e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f6e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered dwelling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered dwelling” means a dwelling that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is occupied by a tenant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa1f6e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to a residential lease; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa1f6e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without a lease or with a lease terminable under State law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on or in a covered property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered property","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered property” means any property that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participates in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa1f6e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered housing program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491/a"},"text":"section 12491(a) of title 34","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa1f6ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rural housing voucher program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1490r"},"text":"section 1490r of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has a—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa1f6ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federally backed mortgage loan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa1f6ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federally backed multifamily mortgage loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dwelling","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “dwelling”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3602"},"text":"section 3602 of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes houses and dwellings described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3603/b"},"text":"section 3603(b) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally backed mortgage loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federally backed mortgage loan” includes any loan (other than temporary financing such as a construction loan) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is secured by a first or subordinate lien on residential real property (including individual units of condominiums and cooperatives) designed principally for the occupancy of from 1 to 4 families, including any such secured loan, the proceeds of which are used to prepay or pay off an existing loan secured by the same property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made in whole or in part, or insured, guaranteed, supplemented, or assisted in any way, by any officer or agency of the Federal Government or under or in connection with a housing or urban development program administered by the Secretary of Housing and Urban Development or a housing or related program administered by any other such officer or agency, or is purchased or securitized by the Federal Home Loan Mortgage Corporation or the Federal National Mortgage Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally backed multifamily mortgage loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federally backed multifamily mortgage loan” includes any loan (other than temporary financing such as a construction loan) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is secured by a first or subordinate lien on residential multifamily real property designed principally for the occupancy of 5 or more families, including any such secured loan, the proceeds of which are used to prepay or pay off an existing loan secured by the same property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made in whole or in part, or insured, guaranteed, supplemented, or assisted in any way, by any officer or agency of the Federal Government or under or in connection with a housing or urban development program administered by the Secretary of Housing and Urban Development or a housing or related program administered by any other such officer or agency, or is purchased or securitized by the Federal Home Loan Mortgage Corporation or the Federal National Mortgage Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f6f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moratorium","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 120-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", the lessor of a covered dwelling may not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f6f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make, or cause to be made, any filing with the court of jurisdiction to initiate a legal action to recover possession of the covered dwelling from the tenant for nonpayment of rent or other fees or charges; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge fees, penalties, or other charges to the tenant related to such nonpayment of rent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f6fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The lessor of a covered dwelling unit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f6fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not require the tenant to vacate the covered dwelling unit before the date that is 30 days after the date on which the lessor provides the tenant with a notice to vacate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not issue a notice to vacate under paragraph (1) until after the expiration of the period described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa1f6fd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4024"},"text":"Pub. L. 116–136, div. A, title IV, § 4024","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/492"},"text":"134 Stat. 492","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
