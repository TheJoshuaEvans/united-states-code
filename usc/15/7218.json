{"tag":"section","attrib":{"id":"id7a6feb0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218"},"text":null,"children":[{"tag":"num","attrib":{"value":"7218"},"text":"§ 7218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6feb0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6feb10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall promulgate such rules and regulations to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s/b"},"text":"section 77s(b) of this title","children":[],"tail":" as it deems necessary or appropriate in the public interest or for the protection of investors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6feb11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on Commission powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act, including this section and the amendment made by this section, shall be construed to impair or limit the authority of the Commission to establish accounting principles or standards for purposes of enforcement of the securities laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6feb12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on adopting principles-based accounting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6feb13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6feb14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall conduct a study on the adoption by the United States financial reporting system of a principles-based accounting system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6feb15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study topics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study required by subparagraph (A) shall include an examination of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6feb16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which principles-based accounting and financial reporting exists in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6feb17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time required for change from a rules-based to a principles-based financial reporting system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6feb18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of and proposed methods by which a principles-based system may be implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6feb19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a thorough economic analysis of the implementation of a principles-based system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6feb1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7218/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", the Commission shall submit a report on the results of the study required by paragraph (1) to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6feb1b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tI/s108"},"text":"Pub. L. 107–204, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/768"},"text":"116 Stat. 768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6feb1c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6feb1d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a6feb1e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/745"},"text":"116 Stat. 745","children":[],"tail":", known as the Sarbanes-Oxley Act of 2002. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a6feb1f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s108"},"text":"section 108 of Pub. L. 107–204","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/204/s108"},"text":"section 108 of Pub. L. 107–204","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s"},"text":"section 77s of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
