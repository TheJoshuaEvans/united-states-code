{"tag":"section","attrib":{"id":"id7a912e8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854"},"text":null,"children":[{"tag":"num","attrib":{"value":"8854"},"text":"§ 8854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy Quantum User Expansion for Science and Technology program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912e90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy (referred to in this section as the “Secretary”) shall establish and carry out a program, to be known as the “Quantum User Expansion for Science and Technology program” or “QUEST program”, to encourage and facilitate access to United States quantum computing hardware and quantum computing clouds for research purposes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the United States quantum research enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate the future quantum computing workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accelerate the advancement of United States quantum computing capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the relevant domestic supply chains, manufacturing processes, and associated simulations or modeling capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chair of the Subcommittee on Quantum Information Science of the National Science and Technology Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8813/a"},"text":"section 8813(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chair of the Subcommittee on the Economic and Security Implications of Quantum Science;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide researchers based within the United States with access to, and use of, United States quantum computing resources through a competitive, merit-reviewed process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider applications from the National Laboratories, multi-institutional collaborations, institutions of higher education, industry stakeholders, and any other entities that the Secretary determines are appropriate to provide national leadership on quantum computing related issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with private sector stakeholders, the user community, and interagency partners on program development and best management practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, balance user access to commercial prototypes available for use across a broad class of applications and Federal research prototypes that enable benchmarking a wider variety of early-stage devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall leverage resources and expertise across the Department of Energy and from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912ea0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ea1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ea2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ea3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ea4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ea5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ea6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ea7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Quantum Information Science Research Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912ea8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities authorized by this section, the Secretary, in consultation with the Director of the National Science Foundation and the Director of the National Institute of Standards and Technology, shall ensure proper security controls are in place to protect sensitive information, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912ea9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds authorized to be appropriated for the Department of Energy’s Office of Science, there are authorized to be appropriated to the Secretary to carry out the activities under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912eaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912eab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $31,500,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912eac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $33,075,000 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ead-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $34,728,750 for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912eae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8854/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $36,465,188 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912eaf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tIV/s404"},"text":"Pub. L. 115–368, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10104/b/2/A"},"text":"Pub. L. 117–167, div. B, title I, § 10104(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1440"},"text":"136 Stat. 1440","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
