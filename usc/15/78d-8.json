{"tag":"section","attrib":{"id":"id78063da5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"78d–8"},"text":"§ 78d–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual financial controls audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78063da6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063da7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the end of each fiscal year, the Commission shall publish and submit to Congress a report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063da8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the responsibility of the management of the Commission for establishing and maintaining an adequate internal control structure and procedures for financial reporting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063da9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an assessment of the effectiveness of the internal control structure and procedures for financial reporting of the Commission during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063daa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attestation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports required under paragraph (1) shall be attested to by the Chairman and chief financial officer of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063dab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Comptroller General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063dac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the end of the first fiscal year after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the Comptroller General of the United States shall submit a report to Congress that assesses—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063dad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the internal control structure and procedures of the Commission for financial reporting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063dae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of the Commission under subsection (a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063daf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attestation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall attest to, and report on, the assessment made by the Commission under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063db0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements for cost of reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063db1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall reimburse the Government Accountability Office for the full cost of making the reports under subsection (b), as billed therefor by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063db2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting and use of reimbursements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such reimbursements shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063db3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the appropriation account “Salaries and Expenses, Government Accountability Office” current when the payment is received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063db4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–8/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78063db5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s963"},"text":"Pub. L. 111–203, title IX, § 963","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1910"},"text":"124 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78063db6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78063db7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78063db8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Investor Protection and Securities Reform Act of 2010 and also as part of the Dodd-Frank Wall Street Reform and Consumer Protection Act, and not as part of the Securities Exchange Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78063db9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78063dba-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id78063dbb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Commission” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
