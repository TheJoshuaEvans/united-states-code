{"tag":"section","attrib":{"id":"id79731426-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276"},"text":null,"children":[{"tag":"num","attrib":{"value":"1276"},"text":"§ 1276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional veto of hazardous substances regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79731427-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall transmit to the Secretary of the Senate and the Clerk of the House of Representatives a copy of any regulation promulgated by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261/q/1"},"text":"section 1261(q)(1) of this title","children":[],"tail":" or subsection (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1262"},"text":"section 1262 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79731428-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval by concurrent resolution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any regulation specified in subsection (a) shall not take effect if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79731429-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the ninety calendar days of continuous session of the Congress which occur after the date of the promulgation of such regulation, both Houses of the Congress adopt a concurrent resolution, the matter after the resolving clause of which is as follows (with the blank spaces appropriately filled): “That the Congress disapproves the regulation which was promulgated under the Federal Hazardous Substances Act by the Consumer Product Safety Commission with respect to          and which was transmitted to the Congress on            and disapproves the regulation for the following reasons:           .”; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7973142a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the sixty calendar days of continuous session of the Congress which occur after the date of the promulgation of such regulation, one House of the Congress adopts such concurrent resolution and transmits such resolution to the other House and such resolution is not disapproved by such other House within the thirty calendar days of continuous session of the Congress which occur after the date of such transmittal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7973142b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumptions from Congressional action or inaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congressional inaction on, or rejection of, a concurrent resolution of disapproval under this section shall not be construed as an expression of approval of the regulation involved, and shall not be construed to create any presumption of validity with respect to such regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7973142c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuous session of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7973142d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuity of session is broken only by an adjournment of the Congress sine die; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7973142e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1276/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days on which either House is not in session because of an adjournment of more than three days to a day certain are excluded in the computation of the periods of continuous session of the Congress specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7973142f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s21"},"text":"Pub. L. 86–613, § 21","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXII/s1207/c"},"text":"Pub. L. 97–35, title XII, § 1207(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/718"},"text":"95 Stat. 718","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s204/b/4/H"},"text":"Pub. L. 110–314, title II, § 204(b)(4)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3042"},"text":"122 Stat. 3042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79731430-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79731431-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79731432-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Hazardous Substances Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613"},"text":"Pub. L. 86–613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/372"},"text":"74 Stat. 372","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261"},"text":"section 1261 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79731433-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":", which directed the substitution of “Commission” for “Consumer Product Safety Commission” in this section, was executed by making the substitution in subsec. (a), before “shall transmit”, but not in subsec. (b)(1), to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79731434-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79731435-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to consumer product safety rules under chapter 47 of this title and regulations under this chapter and chapter 25 of this title promulgated after ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1215"},"text":"section 1215 of Pub. L. 97–35","children":[],"tail":", set out as an Effective Date of 1981 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052"},"text":"section 2052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
