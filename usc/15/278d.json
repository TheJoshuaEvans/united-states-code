{"tag":"section","attrib":{"id":"id7890a2a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278d"},"text":null,"children":[{"tag":"num","attrib":{"value":"278d"},"text":"§ 278d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and improvement of buildings and facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7890a2a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the limits of funds which are appropriated for the Institute, the Secretary of Commerce is authorized to undertake such construction of buildings and other facilities and to make such improvements to existing buildings, grounds, and other facilities occupied or used by the Institute as are necessary for the proper and efficient conduct of the activities authorized herein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a2a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to retain all building use and depreciation surcharge fees collected pursuant to OMB Circular A–25. Such fees shall be collected and credited to the Construction of Research Facilities Appropriation Account for use in maintenance and repair of the Institute’s existing facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7890a2a3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag"