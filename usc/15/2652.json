{"tag":"section","attrib":{"id":"id7a047f32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2652"},"text":null,"children":[{"tag":"num","attrib":{"value":"2652"},"text":"§ 2652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asbestos Ombudsman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a047f33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2652/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall appoint an Asbestos Ombudsman, who shall carry out the duties described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047f34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2652/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Asbestos Ombudsman are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047f35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2652/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive complaints, grievances, and requests for information submitted by any person with respect to any aspect of this subchapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2652/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to render assistance with respect to the complaints, grievances, and requests received, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2652/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such recommendations to the Administrator as the Ombudsman considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a047f38-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tII/s212"},"text":"Pub. L. 94–469, title II, § 212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s2"},"text":"Pub. L. 99–519, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2987"},"text":"100 Stat. 2987","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
