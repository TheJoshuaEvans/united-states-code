{"tag":"section","attrib":{"id":"id79e585a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2223c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2223c"},"text":"§ 2223c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The working group established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2223b"},"text":"section 2223b of this title","children":[],"tail":" shall, within 1 year after "},{"tag":"date","attrib":{"date":"1990-10-22"},"text":"October 22, 1990","children":[],"tail":", submit a report to the Administrator and to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate presenting the results of the review carried out under sections 2223a to 2223e of this title, along with recommendations to ensure that response information disseminated to emergency response personnel is appropriate for operational personnel at the local level."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79e585a3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/446/s4"},"text":"Pub. L. 101–446, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-22"},"text":"Oct. 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1045"},"text":"104 Stat. 1045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e585a4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e585a5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79e585a6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Firefighters’ Safety Study Act, and not as part of the Federal Fire Prevention and Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
