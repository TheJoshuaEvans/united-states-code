{"tag":"section","attrib":{"id":"id7a1ebcdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607"},"text":null,"children":[{"tag":"num","attrib":{"value":"3607"},"text":"§ 3607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of self-dealing contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1ebcdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation, maintenance, and management contracts; penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract or portion thereof which is entered into after ","children":[{"tag":"date","attrib":{"date":"1980-10-08"},"text":"October 8, 1980","children":[],"tail":", and which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1ebcde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for operation, maintenance, or management of a condominium or cooperative association in a conversion project, or of property serving the condominium or cooperative unit owners in such project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ebcdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is between such unit owners or such association and the developer or an affiliate of the developer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ebce0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was entered into while such association was controlled by the developer through special developer control or because the developer held a majority of the votes in such association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ebce1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for a period of more than three years, including any automatic renewal provisions which are exercisable at the sole option of the developer or an affiliate of the developer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may be terminated without penalty by such unit owners or such association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ebce2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any termination under this section may occur only during the two-year period beginning on the date on which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1ebce3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special developer control over the association is terminated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ebce4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the developer owns 25 per centum or less of the units in the conversion project,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ebce5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote of owners of units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A termination under this section shall be by a vote of owners of not less than two-thirds of the units other than the units owned by the developer or an affiliate of the developer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ebce6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3607/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following the unit owners’ vote, the termination shall be effective ninety days after hand delivering notice or mailing notice by prepaid United States mail to the parties to the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1ebce7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s608"},"text":"Pub. L. 96–399, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1676"},"text":"94 Stat. 1676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1ebce8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1ebce9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a1ebcea-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"date","attrib":{"date":"1980-10-08"},"text":"October 8, 1980","children":[],"tail":"” was substituted for “the effective date of this title”. See Effective Date note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
