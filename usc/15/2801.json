{"tag":"section","attrib":{"id":"id7a0baae4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801"},"text":null,"children":[{"tag":"num","attrib":{"value":"2801"},"text":"§ 2801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0baae5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0baae6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “franchise” means any contract—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0baae7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a refiner and a distributor,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0baae8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a refiner and a retailer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0baae9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a distributor and another distributor, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0baaea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a distributor and a retailer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"under which a refiner or distributor (as the case may be) authorizes or permits a retailer or distributor to use, in connection with the sale, consignment, or distribution of motor fuel, a trademark which is owned or controlled by such refiner or by a refiner which supplies motor fuel to the distributor which authorizes or permits such use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0baaeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “franchise” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0baaec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract under which a retailer or distributor (as the case may be) is authorized or permitted to occupy leased marketing premises, which premises are to be employed in connection with the sale, consignment, or distribution of motor fuel under a trademark which is owned or controlled by such refiner or by a refiner which supplies motor fuel to the distributor which authorizes or permits such occupancy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0baaed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any contract pertaining to the supply of motor fuel which is to be sold, consigned or distributed—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a0baaee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a trademark owned or controlled by a refiner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a0baaef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a contract which has existed continuously since ","children":[{"tag":"date","attrib":{"date":"1973-05-15"},"text":"May 15, 1973","children":[],"tail":", and pursuant to which, on "},{"tag":"date","attrib":{"date":"1973-05-15"},"text":"May 15, 1973","children":[],"tail":", motor fuel was sold, consigned or distributed under a trademark owned or controlled on such date by a refiner; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0baaf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unexpired portion of any franchise, as defined by the preceding provisions of this paragraph, which is transferred or assigned as authorized by the provisions of such franchise or by any applicable provision of State law which permits such transfer or assignment without regard to any provision of the franchise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baaf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “franchise relationship” means the respective motor fuel marketing or distribution obligations and responsibilities of a franchisor and a franchisee which result from the marketing of motor fuel under a franchise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baaf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “franchisor” means a refiner or distributor (as the case may be) who authorizes or permits, under a franchise, a retailer or distributor to use a trademark in connection with the sale, consignment, or distribution of motor fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baaf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “franchisee” means a retailer or distributor (as the case may be) who is authorized or permitted, under a franchise, to use a trademark in connection with the sale, consignment, or distribution of motor fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baaf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “refiner” means any person engaged in the refining of crude oil to produce motor fuel, and includes any affiliate of such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baaf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “distributor” means any person, including any affiliate of such person, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0baaf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchases motor fuel for sale, consignment, or distribution to another; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0baaf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives motor fuel on consignment for consignment or distribution to his own motor fuel accounts or to accounts of his supplier, but shall not include a person who is an employee of, or merely serves as a common carrier providing transportation service for, such supplier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baaf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “retailer” means any person who purchases motor fuel for sale to the general public for ultimate consumption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baaf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “marketing premises” means, in the case of any franchise, premises which, under such franchise, are to be employed by the franchisee in connection with sale, consignment, or distribution of motor fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baafa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “leased marketing premises” means marketing premises owned, leased, or in any way controlled by a franchisor and which the franchisee is authorized or permitted, under the franchise, to employ in connection with the sale, consignment, or distribution of motor fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baafb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contract” means any oral or written agreement. For supply purposes, delivery levels during the same month of the previous year shall be prima facie evidence of an agreement to deliver such levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baafc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “trademark” means any trademark, trade name, service mark, or other identifying symbol or name.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baafd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “motor fuel” means gasoline and diesel fuel of a type distributed for use as a fuel in self-propelled vehicles designed primarily for use on public streets, roads, and highways.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0baafe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “failure” does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0baaff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure which is only technical or unimportant to the franchise relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure for a cause beyond the reasonable control of the franchisee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any failure based on a provision of the franchise which is illegal or unenforceable under the law of any State (or subdivision thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The terms “fail to renew” and “nonrenewal” mean, with respect to any franchise relationship, a failure to reinstate, continue, or extend the franchise relationship—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0bab03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the conclusion of the term, or on the expiration date, stated in the relevant franchise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time, in the case of the relevant franchise which does not state a term of duration or an expiration date; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" following a termination (on or after ","children":[{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":") of the relevant franchise which was entered into prior to "},{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":", and has not been renewed after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “affiliate” means any person who (other than by means of a franchise) controls, is controlled by, or is under common control with, any other person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “relevant geographic market area” includes a State or a standard metropolitan statistical area as periodically established by the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “termination” includes cancellation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “commerce” means any trade, traffic, transportation, exchange, or other commerce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0bab0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between any State and any place outside of such State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which affects any trade, transportation, exchange, or other commerce described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2801/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, Guam, and any other commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0bab0d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/297/tI/s101"},"text":"Pub. L. 95–297, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/322"},"text":"92 Stat. 322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/371/s6"},"text":"Pub. L. 103–371, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-19"},"text":"Oct. 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3486"},"text":"108 Stat. 3486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s241/c/1"},"text":"Pub. L. 110–140, title II, § 241(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1540"},"text":"121 Stat. 1540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0bab0e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0bab0f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0bab10-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Par. (13)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" aligned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (13)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/371"},"text":"Pub. L. 103–371","children":[],"tail":" added subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a0bab11-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a0bab12-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a0bab13-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/371/s1"},"text":"Pub. L. 103–371, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-19"},"text":"Oct. 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3484"},"text":"108 Stat. 3484","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/371/s1"},"text":"“This Act [amending this section and sections 2802, 2805, and 2806 of this title] may be cited as the ‘Petroleum Marketing Practices Act Amendments of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a0bab14-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/297/s1"},"text":"Pub. L. 95–297, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/322"},"text":"92 Stat. 322","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/297/s1"},"text":"“That this Act [enacting this chapter and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2822"},"text":"section 2822 of this title","children":[],"tail":"] may be cited as the ‘Petroleum Marketing Practices Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
