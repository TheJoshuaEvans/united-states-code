{"tag":"section","attrib":{"id":"id7a8ee517-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841"},"text":null,"children":[{"tag":"num","attrib":{"value":"8841"},"text":"§ 8841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantum information science research and education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8ee518-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall carry out a basic research and education program on quantum information science and engineering, including the competitive award of grants to institutions of higher education or eligible nonprofit organizations (or consortia thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee519-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program components","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee51a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Director of the National Science Foundation shall carry out activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8ee51b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support basic interdisciplinary quantum information science and engineering research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee51c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support human resources development in all aspects of quantum information science and engineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee51d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8ee51e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" using the existing programs of the National Science Foundation, in collaboration with other Federal departments and agencies, as appropriate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a8ee51f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the teaching and learning of quantum information science and engineering at the undergraduate, graduate, and postgraduate levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a8ee520-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase participation in the quantum fields, including by individuals identified in sections 1885a and 1885b of title 42;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee521-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulating goals for quantum information science and engineering research and education activities to be supported by the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee522-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging the collective body of knowledge from existing quantum information science and engineering research and education activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee523-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating research efforts funded through existing programs across the directorates of the National Science Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee524-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging with other Federal departments and agencies, research communities, and potential users of information produced under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee525-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graduate traineeships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation may establish a program to provide traineeships to graduate students at institutions of higher education within the United States who are citizens of the United States and who choose to pursue masters or doctoral degrees in quantum information science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee526-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporating QISE into STEM curriculum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee527-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall, through programs carried out or supported by the National Science Foundation, seek to increase the integration of quantum information science and engineering (referred to in this subsection as “QISE”) into the STEM curriculum at all education levels, including community colleges, as considered appropriate by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee528-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curriculum integration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The curriculum integration under paragraph (1) may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8ee529-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods to conceptualize QISE for elementary, middle, and high school curricula.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee52a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods for strengthening foundational mathematics and science curricula.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee52b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods for integrating students who are underserved or historically underrepresented groups in STEM.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee52c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Age-appropriate materials that apply the principles of quantum information science in STEM fields.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee52d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for the standardization of key concepts, definitions, and curriculum criteria across government, academia, and industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee52e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Materials that specifically address the findings and outcomes of the study to evaluate and make recommendations for the quantum information science workforce pursuant to subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19261"},"text":"section 19261 of title 42","children":[],"tail":" and strategies to account for the skills and workforce needs identified through such study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee52f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Director shall coordinate with relevant Federal agencies, and consult with nongovernmental entities with expertise in QISE, as appropriate, which may include institutions eligible to participate in the Established Program to Stimulate Competitive Research (EPSCoR).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee530-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8841/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “STEM” means the academic and professional disciplines of science, technology, engineering, and mathematics, including computer science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee531-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tIII/s301"},"text":"Pub. L. 115–368, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5099"},"text":"132 Stat. 5099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10661/e/1"},"text":"Pub. L. 117–167, div. B, title VI, § 10661(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1685"},"text":"136 Stat. 1685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a8ee532-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a8ee533-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a8ee534-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
