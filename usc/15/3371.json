{"tag":"section","attrib":{"id":"id7a1a027f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371"},"text":null,"children":[{"tag":"num","attrib":{"value":"3371"},"text":"§ 3371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of certain sales and transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1a0280-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission approval of transportation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1a0281-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate pipelines","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a0282-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission may, by rule or order, authorize any interstate pipeline to transport natural gas on behalf of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a0283-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any intrastate pipeline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a0284-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local distribution company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a0285-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Just and reasonable rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rates and charges of any interstate pipeline with respect to any transportation authorized under subparagraph (A) shall be just and reasonable (within the meaning of the Natural Gas Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s717"},"text":"15 U.S.C. 717","children":[],"tail":" et seq.])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a0286-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intrastate pipelines","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a0287-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may, by rule or order, authorize any intrastate pipeline to transport natural gas on behalf of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a0288-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interstate pipeline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a0289-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local distribution company served by any interstate pipeline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a028a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates and charges","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a028b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum fair and equitable price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rates and charges of any intrastate pipeline with respect to any transportation authorized under subparagraph (A), including any amount computed in accordance with the rule prescribed under clause (ii), shall be fair and equitable and may not exceed an amount which is reasonably comparable to the rates and charges which interstate pipelines would be permitted to charge for providing similar transportation service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a028c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall, by rule, establish the method for calculating an amount necessary to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a1a028d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably compensate any intrastate pipeline for expenses incurred by the pipeline and associated with the providing of any gathering, treatment, processing, transportation, delivery, or similar service provided by such pipeline in connection with any transportation of natural gas authorized under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1a028e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for such pipeline to earn a reasonable profit on such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1a028f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission approval of sales","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1a0290-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may, by rule or order, authorize any intrastate pipeline to sell natural gas to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a0291-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interstate pipeline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a0292-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local distribution company served by any interstate pipeline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a0293-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates and charges","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a0294-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum fair and equitable price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rates and charges of any intrastate pipeline with respect to any sale of natural gas authorized under paragraph (1) shall be fair and equitable and may not exceed the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a0295-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such intrastate pipeline’s weighted average acquisition cost of natural gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a0296-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount, computed in accordance with the rule prescribed under subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a0297-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any adjustment permitted under subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a0298-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall, by rule, establish the method for calculating an amount necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a0299-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably compensate any intrastate pipeline for expenses incurred by the pipeline and associated with the providing of any gathering, treatment, processing, transportation, or delivery service provided by such pipeline in connection with any sale of natural gas authorized under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a029a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for such pipeline to earn a reasonable profit on such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a029b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a029c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subparagraph shall apply in any case in which, in order to deliver any volume of natural gas pursuant to any sale authorized under paragraph (1), any intrastate pipeline acquires quantities of natural gas under any existing contract, if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a1a029d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such intrastate pipeline acquires any volume of natural gas under such contract in excess of that which such pipeline would otherwise have acquired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a1a029e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price paid for such additional volume of natural gas acquired under such contract is greater than such pipeline’s weighted average acquisition cost of natural gas, computed without regard to the acquisition of such additional volume of natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a029f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case to which this subparagraph applies, the Commission shall permit an adjustment to the maximum fair and equitable price provided under subparagraph (A) to increase the revenue to the intrastate pipeline under such sale by an amount determined by the Commission to be adequate to offset the additional cost incurred by such pipeline due to any increase in such pipeline’s weighted average acquisition cost of natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a02a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a02a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Two-year duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No authorization of any sale (or any extension thereof) under paragraph (1) may be for a period exceeding two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any authorization of any sale under paragraph (1), and any extension of any such authorization under this subparagraph, may be extended by the Commission if such extension satisfies the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a02a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequacy of service to intrastate customers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any sale authorized under paragraph (1) shall be subject to interruption to the extent that natural gas subject to such sale is required to enable the intrastate pipeline involved to provide adequate service to such pipeline’s customers at the time of such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a02a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a02a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affidavit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any application for authorization of any sale under paragraph (1) shall be accompanied by an affidavit filed by the intrastate pipeline involved and setting forth—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a02a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the interstate pipeline or local distribution company involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a02a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each point of delivery of the natural gas from the intrastate pipeline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a02a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total and daily volumes of natural gas subject to such sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a02a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price or prices of such volumes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a02aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Commission may, by rule, require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any application for authorization of any sale under paragraph (1) shall be accompanied by a statement by the intrastate pipeline involved verifying by oath or affirmation that such sale, if authorized, would comply with all requirements applicable to such sale under this subsection and all terms and conditions established, by rule or order, by the Commission and applicable to such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a02ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of sales","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a02ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon complaint of any interested person, or upon the Commission’s own motion, the Commission shall, after affording an opportunity for oral presentation of views and arguments, terminate any sale authorized under paragraph (1) if the Commission determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1a02ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such termination is required to enable the intrastate pipeline involved to provide adequate service to the customers of such pipeline at the time of such sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a02af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale involves the sale of natural gas acquired by the intrastate pipeline involved solely or primarily for the purpose of resale of such natural gas pursuant to a sale authorized under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a02b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale violates any requirement of this subsection or any term or condition established, by rule or order, by the Commission and applicable to such sale; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1a02b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale circumvents or violates any provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension pending hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to any hearing or determination required under subparagraph (A), upon complaint of any interested person or upon the Commission’s own motion, the Commission may suspend any sale authorized under paragraph (1) if the Commission finds that it is likely that the determinations described in subparagraph (A) will be made following the hearing required under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determination of whether any interruption of any sale authorized under paragraph (1) is required under subparagraph (A)(i) shall be made by the Commission without regard to the character of the use of natural gas by any customer of the intrastate pipeline involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any interested State may intervene as a matter of right in any proceeding before the Commission relating to any determination under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a02b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall disapprove any application for authorization of any sale under paragraph (1) if the Commission determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a02b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale would impair the ability of the intrastate pipeline involved to provide adequate service to its customers at the time of such sale (without regard to the character of the use of natural gas by such customer);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale would involve the sale of natural gas acquired by the intrastate pipeline involved solely or primarily for the purpose of resale of such natural gas pursuant to a sale authorized under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale would violate any requirement of this subsection or any term or condition established, by rule or order, by the Commission and applicable to such sale; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a02b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sale would circumvent or violate any provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1a02ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any authorization granted under this section shall be under such terms and conditions as the Commission may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1a02bb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tIII/s311"},"text":"Pub. L. 95–621, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3388"},"text":"92 Stat. 3388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1a02bc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1a02bd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1a02be-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Natural Gas Act, referred to in subsec. (a)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556"},"text":"act June 21, 1938, ch. 556","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/821"},"text":"52 Stat. 821","children":[],"tail":", which is classified generally to chapter 15B (§ 717 et seq.) of this title. For complete classification of this act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717w"},"text":"section 717w of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
