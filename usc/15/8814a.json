{"tag":"section","attrib":{"id":"id7a8ee4d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8814a"},"text":"§ 8814a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcommittee on the Economic and Security Implications of Quantum Information Science","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8ee4d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish, through the National Science and Technology Council, the Subcommittee on the Economic and Security Implications of Quantum Information Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee4d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Subcommittee shall include a representative of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee4d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Director of National Intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Science and Technology Policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other Federal department or agency as the President considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee4e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Subcommittee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee4e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the Director of the Office and ","children":[{"tag":"ref","attrib":{"idref":"fn002610"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002610"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of”."}],"tail":" Management and Budget, the Director of the National Quantum Coordination Office, and the Subcommittee on Quantum Information Science, track investments of the Federal Government in quantum information science research and development;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and assess any economic or security implications of such investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and assess any counterintelligence risks or other foreign threats to such investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend goals and priorities for the Federal Government and make recommendations to Federal departments and agencies and the Director of the National Quantum Coordination Office to address any counterintelligence risks or other foreign threats identified as a result of an assessment under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the export of technology associated with quantum information science and recommend to the Secretary of Commerce and the Secretary of State export controls necessary to protect the economic and security interests of the United States as a result of such assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to Federal departments and agencies investment strategies in quantum information science that advance the economic and security interest of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Director of National Intelligence and the Secretary of Energy appropriate protections to address counterintelligence risks or other foreign threats identified as a result of the assessment under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the Subcommittee on Quantum Information Science, ensure the approach of the United States to investments of the Federal Government in quantum information science research and development reflects a balance between scientific progress and the potential economic and security implications of such progress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee4ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical and administrative support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee4ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, the Director of National Intelligence, and the Director of the National Quantum Coordination Office may provide to the Subcommittee personnel, equipment, facilities, and such other technical and administrative support as may be necessary for the Subcommittee to carry out the responsibilities of the Subcommittee under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee4ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8814a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support related to classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy and the Director of National Intelligence shall provide to the Subcommittee technical and administrative support related to the responsibilities of the Subcommittee that involve classified information, including support related to sensitive compartmented information facilities and the storage of classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee4f0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tI/s105"},"text":"Pub. L. 115–368, title I, § 105","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXVI/s6606/a/2"},"text":"Pub. L. 117–81, div. F, title LXVI, § 6606(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2442"},"text":"135 Stat. 2442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a8ee4f1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id7a8ee4f2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8815"},"text":"section 8815 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a8ee4f3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a8ee4f4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/s105"},"text":"section 105 of Pub. L. 115–368","children":[],"tail":" was renumbered section 106 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8815"},"text":"section 8815 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a8ee4f5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a8ee4f6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXVI/s6606/b/2"},"text":"Pub. L. 117–81, div. F, title LXVI, § 6606(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2443"},"text":"135 Stat. 2443","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dF/tLXVI/s6606/b/2"},"text":"“The amendments made by subsection (a) [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8815"},"text":"section 8815 of this title","children":[],"tail":"] shall take effect as if included in the enactment of the National Quantum Initiative Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8801"},"text":"15 U.S.C. 8801","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
