{"tag":"section","attrib":{"id":"id7aa923a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301"},"text":null,"children":[{"tag":"num","attrib":{"value":"9301"},"text":"§ 9301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National coordinating entity for sustainable chemistry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa923a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Director of the Office of Science and Technology Policy shall convene an interagency entity (referred to in this chapter as the “Entity”) under the National Science and Technology Council with the responsibility to coordinate Federal programs and activities in support of sustainable chemistry, including those described in sections 9303 and 9304 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa923a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with existing groups","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In convening the Entity, the Director of the Office of Science and Technology Policy shall consider overlap and possible coordination with existing committees, subcommittees, or other groups of the National Science and Technology Council, such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa923a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa923a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa923a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Science; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa923a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related groups or subcommittees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa923aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-chairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Entity shall be co-chaired by the Director of the Office of Science and Technology Policy and a representative from the Environmental Protection Agency, the National Institute of Standards and Technology, the National Science Foundation, or the Department of Energy, as selected by the Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa923ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Entity shall include representatives, including subject matter experts, from the Environmental Protection Agency, the National Institute of Standards and Technology, the National Science Foundation, the Department of Energy, the Department of Agriculture, the Department of Defense, the National Institutes of Health, the Centers for Disease Control and Prevention, the Food and Drug Administration, and other related Federal agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa923ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Entity shall terminate on the date that is 10 years after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa923ad-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tII/s261"},"text":"Pub. L. 116–283, div. A, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3497"},"text":"134 Stat. 3497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa923ae-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa923af-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7aa923b0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this subtitle”, meaning subtitle E (§§ 261–267) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA"},"text":"Pub. L. 116–283, div. A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3497"},"text":"134 Stat. 3497","children":[],"tail":", which is classified principally to this chapter. For complete classification of subtitle E to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
