{"tag":"section","attrib":{"id":"id7a533b4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6107"},"text":null,"children":[{"tag":"num","attrib":{"value":"6107"},"text":"§ 6107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a533b50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), the Federal Trade Commission may bring a criminal contempt action for violations of orders of the Commission obtained in cases brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s53/b"},"text":"section 53(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action authorized by subsection (a) may be brought by the Federal Trade Commission only after, and pursuant to, the appointment by the Attorney General of an attorney employed by the Commission, as a special assistant United States Attorney.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment upon request or motion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A special assistant United States Attorney may be appointed under subsection (b) upon the request of the Federal Trade Commission or the court which has entered the order for which contempt is sought or upon the Attorney General’s own motion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall act upon any request made under paragraph (1) within 45 days of the receipt of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Federal Trade Commission to bring a criminal contempt action under subsection (a) expires 2 years after the date of the first promulgation of rules under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6102"},"text":"section 6102 of this title","children":[],"tail":". The expiration of such authority shall have no effect on an action brought before the expiration date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a533b56-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/297/s9"},"text":"Pub. L. 103–297, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-16"},"text":"Aug. 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1550"},"text":"108 Stat. 1550","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
