{"tag":"section","attrib":{"id":"id7a49c4fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5101"},"text":null,"children":[{"tag":"num","attrib":{"value":"5101"},"text":"§ 5101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a49c4fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c4fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining viable domestic steel, aluminum, copper, and other metals industries is vital to the national security and economic well being of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of technology competitiveness and energy conservation in the American steel and aluminum industries by the Federal Government through a program of joint research and development will help maintain viable domestic steel and aluminum industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c500-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c501-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the energy efficiency and enhance the competitiveness of American steel, aluminum, and copper industries by providing Federal incentives for the establishment of public-private sector research and development partnerships to undertake scientific research and development to develop advanced technologies utilizing the expertise of the steel, aluminum, copper, and other metals industries, Government-owned laboratories of the Department of Energy and the National Institute of Standards and Technology, universities, State development agencies, and others; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c502-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue steel research and development initiative efforts begun under title II of the Interior and Related Agencies portion of the joint resolution entitled “Joint Resolution making further continuing appropriations for the fiscal year 1986, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1985-12-19"},"text":"December 19, 1985","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Public Law 99–190","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c503-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/680/s2"},"text":"Pub. L. 100–680, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4073"},"text":"102 Stat. 4073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a49c504-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a49c505-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a49c506-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title II of the Interior and Related Agencies portion of the joint resolution entitled “Joint Resolution making further continuing appropriations for the fiscal year 1986, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1985-12-19"},"text":"December 19, 1985","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Public Law 99–190","children":[],"tail":"), referred to in subsec. (b)(2), is "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/d/tII"},"text":"Pub. L. 99–190, § 101(d) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1224"},"text":"99 Stat. 1224","children":[],"tail":", 1244. The provisions relating to steel research and development are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a49c507-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a49c508-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/680/s1"},"text":"Pub. L. 100–680, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4073"},"text":"102 Stat. 4073","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/680/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Steel and Aluminum Energy Conservation and Technology Competitiveness Act of 1988’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
