{"tag":"section","attrib":{"id":"id7a1c739d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3432"},"text":null,"children":[{"tag":"num","attrib":{"value":"3432"},"text":"§ 3432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1c739e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3432/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to prescribe maximum lawful prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall affect the authority of any State to establish or enforce any maximum lawful price for the first sale of natural gas produced in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c739f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3432/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common carriers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall be subject to regulation as a common carrier under any provision of Federal or State law by reason of any transportation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c73a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3432/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to any order under section 3362(c) or section 3363(b), (c), (d), or (i) of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c73a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3432/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3371/a"},"text":"section 3371(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c73a2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tVI/s602"},"text":"Pub. L. 95–621, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3411"},"text":"92 Stat. 3411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b/8"},"text":"Pub. L. 101–60, § 3(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-07-26"},"text":"July 26, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/159"},"text":"103 Stat. 159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1c73a3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1c73a4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1c73a5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60"},"text":"Pub. L. 101–60","children":[],"tail":" struck out “lower” after “prescribe” in heading and struck out before period at end “which does not exceed the applicable maximum lawful price, if any, under subchapter I of this chapter”."}],"tail":"\n"}],"tail