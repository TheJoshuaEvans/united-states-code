{"tag":"section","attrib":{"id":"id7a7bd1d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7606"},"text":null,"children":[{"tag":"num","attrib":{"value":"7606"},"text":"§ 7606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of certain waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A prescriber may not place on the prescription, or require the patient to sign, or deliver to the patient a form or notice waiving or disclaiming the liability or responsibility of the prescriber for the accuracy of the eye examination. The preceding sentence does not impose liability on a prescriber for the ophthalmic goods and services dispensed by another seller pursuant to the prescriber’s correctly verified prescription.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a7bd1d4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s7"},"text":"Pub. L. 108–164, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2026"},"text":"117 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd1d5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a7bd1d6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a7bd1d7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/164/s12"},"text":"section 12 of Pub. L. 108–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7601"},"text":"section 7601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
