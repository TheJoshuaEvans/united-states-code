{"tag":"section","attrib":{"id":"id7ab04fc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9542"},"text":null,"children":[{"tag":"num","attrib":{"value":"9542"},"text":"§ 9542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency study on alternative financing solutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab04fc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to provide information relating to alternative financing solutions to minority business enterprises, as those business enterprises are more likely to struggle in accessing, particularly at affordable rates, traditional sources of capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04fc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Under Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04fc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9542/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a study on opportunities for providing alternative financing solutions to minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fc7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9542/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress, and publish on the website of the Agency, a report describing the findings of the study carried out under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04fc8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tII/s100202"},"text":"Pub. L. 117–58, div. K, title II, § 100202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1456"},"text":"135 Stat. 1456","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
