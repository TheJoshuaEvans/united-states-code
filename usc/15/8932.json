{"tag":"section","attrib":{"id":"id7a912f17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932"},"text":null,"children":[{"tag":"num","attrib":{"value":"8932"},"text":"§ 8932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance standard for the detection of highly fluorinated compounds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912f18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Administrator, shall establish a performance standard for the detection of highly fluorinated compounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912f19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the performance standard under subsection (a), the Director shall emphasize the ability to detect as many highly fluorinated compounds present in the environment as possible using validated analytical methods that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve limits of quantitation (as defined in the document of the United States Geological Survey entitled “Analytical Methods for Chemical Analysis of Geologic and Other Materials, U.S. Geological Survey” and dated 2002); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are as sensitive as is feasible and practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the performance standard under subsection (a), the Director may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop quality assurance and quality control measures to ensure accurate sampling and testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a training program with respect to the appropriate method of sample collection and analysis of highly fluorinated compounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8932/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate as necessary with the Administrator, including, if appropriate, to develop methods to detect individual and different highly fluorinated compounds simultaneously.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912f21-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7332"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2282"},"text":"133 Stat. 2282","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
