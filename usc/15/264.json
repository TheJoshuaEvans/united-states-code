{"tag":"section","attrib":{"id":"id788bc180-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s264"},"text":null,"children":[{"tag":"num","attrib":{"value":"264"},"text":"§ 264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part of Idaho in fourth zone","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the division of territory, and in the definition of the limits of each zone, as provided in sections 261 to 264 of this title, so much of the State of Idaho as lies south of the Salmon River, traversing the State from east to west near forty-five degrees thirty minutes latitude shall be embraced in the fourth zone: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That common carriers within such portion of the State of Idaho may conduct their operations on Pacific time."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788bc181-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-03-19/ch24/s3"},"text":"Mar. 19, 1918, ch. 24, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-03/ch216"},"text":"Mar. 3, 1923, ch. 216","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1434"},"text":"42 Stat. 1434","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch631/s1"},"text":"June 24, 1948, ch. 631, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/646"},"text":"62 Stat. 646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII/s3013/c/4"},"text":"Pub. L. 110–69, title III, § 3013(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/599"},"text":"121 Stat. 599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788bc182-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788bc183-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id788bc184-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The original section 3 of act ","children":[{"tag":"date","attrib":{"date":"1918-03-19"},"text":"Mar. 19, 1918","children":[],"tail":", providing for daylight-savings, was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1919-08-20/ch51"},"text":"act Aug. 20, 1919, ch. 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/280"},"text":"41 Stat. 280","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788bc185-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" substituted “fourth zone” for “third zone”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-24"},"text":"June 24, 1948","children":[],"tail":", inserted proviso relating to common carriers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788bc186-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id788bc187-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch631/s2"},"text":"Act June 24, 1948, ch. 631, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/646"},"text":"62 Stat. 646","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1948-06-24/ch631/s2"},"text":"“This Act [amending this section] shall take effect at 2 o’clock antemeridian of the second Monday following the date of its enactment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
