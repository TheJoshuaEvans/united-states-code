{"tag":"section","attrib":{"id":"id78b1e70d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c"},"text":null,"children":[{"tag":"num","attrib":{"value":"631c"},"text":"§ 631c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small Business Manufacturing Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b1e70e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Small Business Administration (referred to in this subtitle ","children":[{"tag":"ref","attrib":{"idref":"fn002171"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002171"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" as the “Administrator”) shall establish a Small Business Manufacturing Task Force (referred to in this section as the “Task Force”) to address the concerns of small manufacturers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e70f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall assign a member of the Task Force to serve as chair of the Task Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e710-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b1e711-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and identify whether programs and services are sufficient to serve the needs of small manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e712-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively promote the programs and services of the Small Business Administration that serve small manufacturers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e713-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and study the unique conditions facing small manufacturers and develop and propose policy initiatives to support and assist small manufacturers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e714-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b1e715-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall meet not less than 4 times per year, and more frequently if necessary to perform its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e716-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Task Force shall constitute a quorum to approve recommendations or reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e717-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b1e718-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Task Force shall serve without compensation in addition to that received for services rendered as an officer or employee of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e719-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of SBA employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee of the Small Business Administration may be detailed to the Task Force without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e71a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2004-12-08"},"text":"December 8, 2004","children":[],"tail":", and annually thereafter, the Task Force shall submit a report containing the findings and recommendations of the task force to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b1e71b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e71c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Small Business and Entrepreneurship of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e71d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631c/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Small Business of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b1e71e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dK/tI/s147"},"text":"Pub. L. 108–447, div. K, title I, § 147","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3455"},"text":"118 Stat. 3455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b1e71f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b1e720-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78b1e721-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in subsec. (a), is subtitle D (§§ 141–147) of title I of div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3453"},"text":"118 Stat. 3453","children":[],"tail":", which enacted this section, amended sections 637, 648, 657b, and 657c of this title, enacted provisions set out as note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637"},"text":"section 637 of this title","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s657b"},"text":"section 657b of this title","children":[],"tail":". For complete classification of subtitle D to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78b45722-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Small Business Reauthorization and Manufacturing Assistance Act of 2004, and also as part of the Consolidated Appropriations Act, 2005, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
