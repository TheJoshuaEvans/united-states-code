{"tag":"section","attrib":{"id":"id7aa1f79d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c"},"text":null,"children":[{"tag":"num","attrib":{"value":"9058c"},"text":"§ 9058c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency rental assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa1f79e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f79f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary of the Treasury for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $21,550,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":", for making payments to eligible grantees under this section—"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f7a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under paragraph (1), the Secretary shall reserve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f7a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $305,000,000 for making payments under this section to the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, the Commonwealth of the Northern Mariana Islands, and American Samoa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f7a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for costs of the Secretary for the administration of emergency rental assistance programs and technical assistance to recipients of any grants made by the Secretary to provide financial and other assistance to renters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f7a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for administrative expenses of the Inspector General relating to oversight of funds provided in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f7a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,500,000,000 for payments to high-need grantees as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f7a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds to eligible grantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f7a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation for States and units of local government","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f7a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount appropriated under paragraph (1) of subsection (a) that remains after the application of paragraph (2) of such subsection shall be allocated to eligible grantees described in subparagraphs (A) and (B) of subsection (f)(1) in the same manner as the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a"},"text":"section 9058a of this title","children":[],"tail":" is allocated to States and units of local government under subsection (b)(1) of such section, except that "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/b"},"text":"section 9058a(b) of this title","children":[],"tail":" shall be applied—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7aa1f7a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to clause (i) of paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa1f7a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by deeming the amount appropriated under paragraph (1) of subsection (a) of this Act ","children":[{"tag":"ref","attrib":{"idref":"fn002642"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002642"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this section”."}],"tail":" that remains after the application of paragraph (2) of such subsection to be the amount deemed to apply for purposes of applying clause (ii) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/b/1/A"},"text":"section 9058a(b)(1)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa1f7aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by substituting “$152,000,000” for “$200,000,000” each place such term appears;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa1f7ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subclause (I) of such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/b/1/A/v"},"text":"section 9058a(b)(1)(A)(v) of this title","children":[],"tail":", by substituting “under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058c"},"text":"section 9058c of title 15","children":[],"tail":"” for “under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a"},"text":"section 9058a of title 15","children":[],"tail":"”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa1f7ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subclause (II) of such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/b/1/A/v"},"text":"section 9058a(b)(1)(A)(v) of this title","children":[],"tail":", by substituting “local government elects to receive funds from the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058c"},"text":"section 9058c of title 15","children":[],"tail":" and will use the funds in a manner consistent with such section” for “local government elects to receive funds from the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a"},"text":"section 9058a of title 15","children":[],"tail":" and will use the funds in a manner consistent with such section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f7ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make pro rata adjustments in the amounts of the allocations determined under subparagraph (A) of this paragraph for entities described in such subparagraph as necessary to ensure that the total amount of allocations made pursuant to such subparagraph does not exceed the remainder appropriated amount described in such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f7ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations for territories","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount reserved under subsection (a)(2)(A) shall be allocated to eligible grantees described in subsection (f)(1)(C) in the same manner as the amount appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/a/2/A"},"text":"section 9058a(a)(2)(A) of this title","children":[],"tail":" is allocated under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/b/3"},"text":"section 9058a(b)(3) of this title","children":[],"tail":" to eligible grantees described under subparagraph (C) of such "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/b/3"},"text":"section 9058a(b)(3) of this title","children":[],"tail":", except that "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/b/3"},"text":"section 9058a(b)(3) of this title","children":[],"tail":" shall be applied—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f7af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subparagraph (A), by inserting “of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058c"},"text":"section 9058c of this title","children":[],"tail":"” after “the amount reserved under subsection (a)(2)(A)”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f7b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in clause (i) of subparagraph (B), by substituting “the amount equal to 0.3 percent of the amount appropriated under subsection (a)(1)” with “the amount equal to 0.3 percent of the amount appropriated under subsection (a)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058c"},"text":"section 9058c of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f7b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall allocate funds reserved under subsection (a)(2)(D) to eligible grantees with a high need for assistance under this section, with the number of very low-income renter households paying more than 50 percent of income on rent or living in substandard or overcrowded conditions, rental market costs, and change in employment since February 2020 used as the factors for allocating funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f7b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment schedule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f7b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay all eligible grantees not less than 40 percent of each such eligible grantee’s total allocation provided under subsection (b) within 60 days of ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f7b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay to eligible grantees additional amounts in tranches up to the full amount of each such eligible grantee’s total allocation in accordance with a procedure established by the Secretary, provided that any such procedure established by the Secretary shall require that an eligible grantee must have obligated not less than 75 percent of the funds already disbursed by the Secretary pursuant to this section prior to disbursement of additional amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f7b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f7b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible grantee shall only use the funds provided from payments made under this section as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f7b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa1f7b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to clause (ii) of this subparagraph, funds received by an eligible grantee from payments made under this section shall be used to provide financial assistance to eligible households, not to exceed 18 months, including the payment of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7aa1f7b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa1f7ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental arrears;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa1f7bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilities and home energy costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa1f7bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilities and home energy costs arrears; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa1f7bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other expenses related to housing, as defined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa440ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of financial assistance an eligible household may receive under this section, when combined with financial assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a"},"text":"section 9058a of this title","children":[],"tail":", shall not exceed 18 months."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa440af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing stability services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of funds received by an eligible grantee from payments made under this section may be used to provide case management and other services intended to help keep households stably housed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa440b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 15 percent of the total amount paid to an eligible grantee under this section may be used for administrative costs attributable to providing financial assistance, housing stability services, and other affordable rental housing and eviction prevention activities, including for data collection and reporting requirements related to such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa440b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other affordable rental housing and eviction prevention activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible grantee may use any funds from payments made under this section that are unobligated on ","children":[{"tag":"date","attrib":{"date":"2022-10-01"},"text":"October 1, 2022","children":[],"tail":", for purposes in addition to those specified in this paragraph, provided that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7aa440b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other purposes are affordable rental housing and eviction prevention purposes, as defined by the Secretary, serving very low-income families (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b"},"text":"section 1437a(b) of title 42","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa440b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to obligating any funds for such purposes, the eligible grantee has obligated not less than 75 percent of the total funds allocated to such eligible grantee in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under subsection (a)(1) of this section shall be subject to the same terms and conditions that apply under paragraph (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a/c"},"text":"section 9058a(c) of this title","children":[],"tail":" to amounts appropriated under subsection (a)(1) of such "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a"},"text":"section 9058a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa440b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa440b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"2022-03-31"},"text":"March 31, 2022","children":[],"tail":", the Secretary shall reallocate funds allocated to eligible grantees in accordance with subsection (b) but not yet paid in accordance with subsection (c)(2) according to a procedure established by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for reallocated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require an eligible grantee to have obligated 50 percent of the total amount of funds allocated to such eligible grantee under subsection (b) to be eligible to receive funds reallocated under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of reallocated funds by the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay to each eligible grantee eligible for a payment of reallocated funds described in paragraph (2) of this subsection the amount allocated to such eligible grantee in accordance with the procedure established by the Secretary in accordance with paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of reallocated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eligible grantees may use any funds received in accordance with this subsection only for purposes specified in paragraph (1) of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa440ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa440bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible grantee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible grantee” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa440bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 50 States of the United States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa440bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A unit of local government (as defined in paragraph (5)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa440be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, the Commonwealth of the Northern Mariana Islands, and American Samoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible household","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible household” means a household of 1 or more individuals who are obligated to pay rent on a residential dwelling and with respect to which the eligible grantee involved determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa440c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 or more individuals within the household has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa440c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified for unemployment benefits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa440c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experienced a reduction in household income, incurred significant costs, or experienced other financial hardship during or due, directly or indirectly, to the coronavirus pandemic;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa440c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more individuals within the household can demonstrate a risk of experiencing homelessness or housing instability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa440c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the household is a low-income family (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b"},"text":"section 1437a(b) of title 42","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002643"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002643"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. A closing parenthesis probably should precede the period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Inspector General” means the Inspector General of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa440c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit of local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit of local government” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9058a"},"text":"section 9058a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa440c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided to an eligible grantee under a payment made under this section shall remain available through ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa440c9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIII/s3201"},"text":"Pub. L. 117–2, title III, § 3201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/54"},"text":"135 Stat. 54","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa440ca-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa440cb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":nu