{"tag":"section","attrib":{"id":"id791ae1d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"657f–1"},"text":"§ 657f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of small business concerns owned and controlled by veterans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791ae1d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s8127"},"text":"section 8127 of title 38","children":[],"tail":", the Administrator shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae1d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify the status of a concern as a small business concern owned and controlled by veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the periodic recertification of such status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae1d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement; penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae1d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification of eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Administrator shall establish procedures relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae1da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the filing, investigation, and disposition by the Administration of any challenge to the eligibility of a small business concern to receive assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657f"},"text":"section 657f of this title","children":[],"tail":" (including a challenge, filed by an interested party, relating to the veracity of a certification made or information provided to the Administration by a small business concern under subsection (a)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae1db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verification by the Administrator of the accuracy of any certification made or information provided to the Administration by a small business concern under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657f–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The procedures established under paragraph (1) shall provide for a program of examinations by the Administrator of any small business concern making a certification or providing information to the Administrator under subsection (a), to determine the veracity of any statements or information provided as part of such certification or otherwise provided under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791ae1dd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s36A"},"text":"Pub. L. 85–536, § 2[36A]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s862/e"},"text":"Pub. L. 116–283, div. A, title VIII, § 862(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3781"},"text":"134 Stat. 3781","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
