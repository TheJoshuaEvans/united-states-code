{"tag":"section","attrib":{"id":"id7a49c4dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4910"},"text":null,"children":[{"tag":"num","attrib":{"value":"4910"},"text":"§ 4910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that information systems created or developed pursuant to this chapter do not unnecessarily duplicate information systems available from other Federal agencies or from the private sector.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a49c4de-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5410"},"text":"Pub. L. 100–418, title V, § 5410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1467"},"text":"102 Stat. 1467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
