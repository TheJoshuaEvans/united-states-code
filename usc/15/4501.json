{"tag":"section","attrib":{"id":"id7a38fcea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501"},"text":null,"children":[{"tag":"num","attrib":{"value":"4501"},"text":"§ 4501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restitutionary amounts covered","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38fceb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4504"},"text":"section 4504 of this title","children":[],"tail":")—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fcec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the procedure for the disbursement of funds collected, including interest thereon, by the Secretary or the courts pursuant to the Emergency Petroleum Allocation Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s751"},"text":"15 U.S.C. 751","children":[],"tail":" et seq.] or the Economic Stabilization Act of 1970 (and the regulations issued thereunder) as restitution for actual or alleged violations of such Acts or regulations; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fced-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subsection (c), applies to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38fcee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount of such funds held in escrow by the Secretary through accounts administered by the Secretary of the Treasury on or after ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"October 21, 1986","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fcef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount of such funds determined at any time, pursuant to judicial or administrative proceedings (including any settlement agreement or declaratory judgment) instituted by the Secretary to enforce such Acts and regulations, to be amounts paid for such actual or alleged violations, including any such amounts held in escrow by any court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts described in subsection (a)(2) and held in an escrow account by a court before ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"October 21, 1986","children":[],"tail":", may continue to be held by such court but shall be disbursed, together with any interest thereon, by the Secretary or, as appropriate, by the court only in accordance with the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(2) does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fcf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount actually disbursed before ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"October 21, 1986","children":[],"tail":", to any person or class of persons pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/97/377/s155"},"text":"section 155 of Public Law 97–377","children":[],"tail":" or any final judicial or administrative order or judgment (including any settlement agreement or declaratory judgment);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fcf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount to which any person or class of persons has an enforceable right, created or vested, or governed by the terms and conditions of the settlement approved on ","children":[{"tag":"date","attrib":{"date":"1986-07-07"},"text":"July 7, 1986","children":[],"tail":", in In Re: the Department of Energy Stripper Well Exemption Litigation, M.D.L. No. 378, in the United States District Court for the District of Kansas; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fcf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any amount designated by judicial or administrative order or judgment (including any settlement agreement or declaratory judgment) for disbursement at any time to any specific person or class of persons—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38fcf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified in such order or judgment as injured by the violation or alleged violation of the Acts described in subsection (a)(1) (including the regulations thereunder); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fcf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified in such order or judgment issued before ","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"October 21, 1986","children":[],"tail":", for indirect restitution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Escrow accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c), the amounts covered by subsection (a) shall be held in appropriate escrow accounts administered for the Secretary by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the disbursement requirements of this chapter, the Secretary of the Treasury shall provide that amounts described in subsection (a) shall earn interest at the maximum rate earned on investments of Federal trust funds by the Secretary of the Treasury in short-term and long-term securities issued by the Federal Government (including minority bank investments).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38fcf9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIII/s3002"},"text":"Pub. L. 99–509, title III, § 3002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1881"},"text":"100 Stat. 1881","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a38fcfa-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a38fcfb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a38fcfc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Emergency Petroleum Allocation Act of 1973, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/159"},"text":"Pub. L. 93–159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-27"},"text":"Nov. 27, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/628"},"text":"87 Stat. 628","children":[],"tail":", which was classified generally to chapter 16A (§ 751 et seq.) of this title, was omitted from the Code pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s760g"},"text":"section 760g of this title","children":[],"tail":", which provided for the expiration of the President’s authority under that chapter on "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Economic Stabilization Act of 1970, referred to in subsec. (a)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/379"},"text":"Pub. L. 91–379","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-15"},"text":"Aug. 15, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/799"},"text":"84 Stat. 799","children":[],"tail":", formerly set out as an Economic Stabilization Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1904"},"text":"section 1904 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/377/s155"},"text":"Section 155 of Public Law 97–377","children":[],"tail":", referred to in subsec. (c)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/97/377/s155"},"text":"section 155 of Pub. L. 97–377","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1919"},"text":"96 Stat. 1919","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a38fcfd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a38fcfe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIII/s3001"},"text":"Pub. L. 99–509, title III, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1881"},"text":"100 Stat. 1881","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/509/tIII/s3001"},"text":"“This subtitle [subtitle A (§§ 3001–3008) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":", enacting this chapter] may be cited as the ‘Petroleum Overcharge Distribution and Restitution Act of 1986’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
