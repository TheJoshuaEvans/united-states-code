{"tag":"section","attrib":{"id":"id788e3231-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s273a"},"text":null,"children":[{"tag":"num","attrib":{"value":"273a"},"text":"§ 273a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Commerce for Standards and Technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id788e3232-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s273a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Commerce an Under Secretary of Commerce for Standards and Technology (in this section referred to as the “Under Secretary”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e3233-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s273a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall be appointed by the President by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e3234-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s273a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall be compensated at the rate in effect for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e3235-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s273a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall serve as the Director of the Institute and shall perform such duties as required of the Director by the Secretary under this chapter or by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e3236-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s273a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual serving as the Director of the Institute on ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", shall also serve as the Under Secretary until such time as a successor is appointed under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788e3237-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s4"},"text":"Mar. 3, 1901, ch. 872, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV/s403/a"},"text":"Pub. L. 111–358, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4000"},"text":"124 Stat. 4000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788e3238-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788e3239-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id788e323a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872"},"text":"act Mar. 3, 1901, ch. 872","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1449"},"text":"31 Stat. 1449","children":[],"tail":", which was not classified to the Code, was repealed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
