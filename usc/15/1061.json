{"tag":"section","attrib":{"id":"id7958d5ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1061"},"text":null,"children":[{"tag":"num","attrib":{"value":"1061"},"text":"§ 1061.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution of acknowledgments and verifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Acknowledgments and verifications required under this chapter may be made before any person within the United States authorized by law to administer oaths, or, when made in a foreign country, before any diplomatic or consular officer of the United States or before any official authorized to administer oaths in the foreign country concerned whose authority is proved by a certificate of a diplomatic or consular officer of the United States, or apostille of an official designated by a foreign country which, by treaty or convention, accords like effect to apostilles of designated officials in the United States, and shall be valid if they comply with the laws of the state or country where made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7958d5ae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title I, § 11, "},{"tag":"ref","attrib":{"href":"/us/stat/60/432"},"text":"60 Stat. 432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s14/c"},"text":"Pub. L. 97–247, § 14(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/321"},"text":"96 Stat. 321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7958d5af-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7958d5b0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7958d5b1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-20/ch592/s2"},"text":"Feb. 20, 1905, ch. 592, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/724"},"text":"33 Stat. 724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1909-02-18/ch144"},"text":"Feb. 18, 1909, ch. 144","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/627"},"text":"35 Stat. 627","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7958d5b2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" substituted “is” for “shall be” after “whose authority”, and inserted “, or apostille of an official designated by a foreign country which, by treaty or convention, accords like effect to apostilles of designated officials in the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7958d5b3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d5b4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s17/a"},"text":"section 17(a) of Pub. L. 97–247","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41"},"text":"section 41 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7958d5b5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal and Effect on Existing Rights","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Repeal of inconsistent provisions, effect of this chapter on pending proceedings and existing registrations and rights under prior acts, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
