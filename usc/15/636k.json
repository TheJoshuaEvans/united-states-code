{"tag":"section","attrib":{"id":"id78e1a9a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k"},"text":null,"children":[{"tag":"num","attrib":{"value":"636k"},"text":"§ 636k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on disaster assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78e1a9a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monthly accounting report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e1a9a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the fifth business day of each month during the applicable period for a major disaster, the Administrator shall submit to the Committee on Small Business and Entrepreneurship and the Committee on Appropriations of the Senate and to the Committee on Small Business and the Committee on Appropriations of the House of Representatives a report on the operation of the disaster loan program authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":" for that major disaster during the preceding month."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e1a9a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e1a9a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily average lending volume, in number of loans and dollars, and the percent by which each category has increased or decreased since the previous report under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the weekly average lending volume, in number of loans and dollars, and the percent by which each category has increased or decreased since the previous report under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding spent over the month for loans, both in appropriations and program level, and the percent by which each category has increased or decreased since the previous report under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding available for loans, both in appropriations and program level, and the percent by which each category has increased or decreased since the previous report under paragraph (1), noting the source of any additional funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of how long the available funding for such loans will last, based on the spending rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding spent over the month for staff, along with the number of staff, and the percent by which each category has increased or decreased since the previous report under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding spent over the month for administrative costs, and the percent by which such spending has increased or decreased since the previous report under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding available for salaries and expenses combined, and the percent by which such funding has increased or decreased since the previous report under paragraph (1), noting the source of any additional funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of how long the available funding for salaries and expenses will last, based on the spending rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e1a9ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weekly disaster updates to Congress for presidentially declared disasters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e1a9af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each week during a disaster update period, the Administration shall submit to the Committee on Small Business and Entrepreneurship of the Senate and to the Committee on Small Business of the House of Representatives a report on the operation of the disaster loan program of the Administration for the area in which the President declared a major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e1a9b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e1a9b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Administration staff performing loan processing, field inspection, and other duties for the declared disaster, and the allocations of such staff in the disaster field offices, disaster recovery centers, workshops, and other Administration offices nationwide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily number of applications received from applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily number of applications pending application entry from applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily number of applications withdrawn by applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily number of applications summarily declined by the Administration from applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily number of applications declined by the Administration from applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily number of applications in process from applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily number of applications approved by the Administration from applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily dollar amount of applications approved by the Administration from applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily amount of loans dispersed, both partially and fully, by the Administration to applicants in the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the daily dollar amount of loans disbursed, both partially and fully, from the relevant area, as well as a breakdown of such figures by State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications approved, including dollar amount approved, as well as applications partially and fully disbursed, including dollar amounts, since the last report under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declaration date, physical damage closing date, economic injury closing date, and number of counties included in the declaration of a major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e1a9be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periods when additional disaster assistance is made available","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e1a9bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During any period for which the Administrator declares eligibility for additional disaster assistance under paragraph (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b"},"text":"section 636(b) of this title","children":[],"tail":", as amended by this Act, the Administrator shall, on a monthly basis, submit to the Committee on Small Business and Entrepreneurship of the Senate and to the Committee on Small Business of the House of Representatives a report on the disaster assistance operations of the Administration with respect to the applicable major disaster."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e1a9c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e1a9c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications for disaster assistance distributed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications for disaster assistance received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average time for the Administration to approve or disapprove an application for disaster assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of disaster loans approved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average time for initial disbursement of disaster loan proceeds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of disaster loan proceeds disbursed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e1a9c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of the need for supplemental funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the same date that the Administrator notifies any committee of the Senate or the House of Representatives that supplemental funding is necessary for the disaster loan program of the Administration in any fiscal year, the Administrator shall notify in writing the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives regarding the need for supplemental funds for that loan program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e1a9c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on contracting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e1a9c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the date on which the President declares a major disaster, and every 6 months thereafter until the date that is 18 months after the date on which the major disaster was declared, the Administrator shall submit a report to the Committee on Small Business and Entrepreneurship of the Senate and to the Committee on Small Business of the House of Representatives regarding Federal contracts awarded as a result of that major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e1a9ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e1a9cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of contracts awarded as a result of that major disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of contracts awarded to small business concerns as a result of that major disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of contracts awarded to women and minority-owned businesses as a result of that major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of contracts awarded to local businesses as a result of that major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78e1a9cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on loan approval rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78e1a9d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the date of enactment of this Act, the Administrator shall submit a report to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives detailing how the Administration can improve the processing of applications under the disaster loan program of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78e1a9d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78e1a9d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations, if any, regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78e1a9d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staffing levels during a major disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e1a9d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to improve the process for processing, approving, and disbursing loans under the disaster loan program of the Administration, to ensure that the maximum assistance is provided to victims in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e1a9d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the viability of using alternative methods for assessing the ability of an applicant to repay a loan, including the credit score of the applicant on the day before the date on which the disaster for which the applicant is seeking assistance was declared;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e1a9d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods, if any, for the Administration to expedite loss verification and loan processing of disaster loans during a major disaster for businesses affected by, and located in the area for which the President declared, the major disaster that are a major source of employment in the area or are vital to recovery efforts in the region (including providing debris removal services, manufactured housing, or building materials);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e1a9d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislative changes, if any, needed to implement findings from the Accelerated Disaster Response Initiative of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78e1a9d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the Administration plans to integrate and coordinate the response to a major disaster with the technical assistance programs of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78e1a9d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636k/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plans of the Administrator for implementing any recommendation made under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78e1a9da-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12091"},"text":"Pub. L. 110–234, title XII, § 12091","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1423"},"text":"122 Stat. 1423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12091, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"re