{"tag":"section","attrib":{"id":"id799df4e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665c"},"text":"§ 1665c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest rate reduction on open end consumer credit plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799df4e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a creditor increases the annual percentage rate applicable to a credit card account under an open end consumer credit plan, based on factors including the credit risk of the obligor, market conditions, or other factors, the creditor shall consider changes in such factors in subsequently determining whether to reduce the annual percentage rate for such obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799df4e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any credit card account under an open end consumer credit plan, the creditor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799df4e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain reasonable methodologies for assessing the factors described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799df4e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than once every 6 months, review accounts as to which the annual percentage rate has been increased since ","children":[{"tag":"date","attrib":{"date":"2009-01-01"},"text":"January 1, 2009","children":[],"tail":", to assess whether such factors have changed (including whether any risk has declined);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799df4ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the annual percentage rate previously increased when a reduction is indicated by the review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799df4eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event of an increase in the annual percentage rate, provide in the written notice required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637/i"},"text":"section 1637(i) of this title","children":[],"tail":" a statement of the reasons for the increase."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799df4ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed to require a reduction in any specific amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799df4ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau ","children":[{"tag":"ref","attrib":{"idref":"fn002361"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002361"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Board”."}],"tail":" shall issue final rules not later than 9 months after "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", to implement the requirements of and evaluate compliance with this section, and subsections (a), (b), and (c) shall become effective 15 months after "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799df4ee-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s148"},"text":"Pub. L. 90–321, title I, § 148","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tI/s101/c"},"text":"Pub. L. 111–24, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1737"},"text":"123 Stat. 1737","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df4ef-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799df4f0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799df4f1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df4f2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799df4f3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799df4f4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/s3"},"text":"section 3 of Pub. L. 111–24","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
