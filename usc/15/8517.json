{"tag":"section","attrib":{"id":"id7a87b84f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517"},"text":null,"children":[{"tag":"num","attrib":{"value":"8517"},"text":"§ 8517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observing System Simulation Experiments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b850-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In support of the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8516"},"text":"section 8516 of this title","children":[],"tail":", the Assistant Administrator for Oceanic and Atmospheric Research shall undertake Observing System Simulation Experiments, or such other quantitative assessments as the Assistant Administrator considers appropriate, to quantitatively assess the relative value and benefits of observing capabilities and systems. Technical and scientific Observing System Simulation Experiment evaluations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b851-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include assessments of the impact of observing capabilities on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b852-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global weather prediction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b853-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hurricane track and intensity forecasting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b854-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tornado warning lead times and accuracy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b855-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prediction of mid-latitude severe local storm outbreaks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b856-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prediction of storms that have the potential to cause extreme precipitation and flooding lasting from 6 hours to 1 week; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b857-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted in cooperation with other appropriate entities within the National Oceanic and Atmospheric Administration, other Federal agencies, the United States weather industry, and academic partners to ensure the technical and scientific merit of results from Observing System Simulation Experiments or other appropriate quantitative assessment methodologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b858-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Observing System Simulation Experiments shall quantitatively—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b859-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the potential impact of proposed space-based, suborbital, and in situ observing systems on analyses and forecasts, including potential impacts on extreme weather events across all parts of the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b85a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and compare observing system design options; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b85b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the relative capabilities and costs of various observing systems and combinations of observing systems in providing data necessary to protect life and property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b85c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Observing System Simulation Experiments—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b85d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted prior to the acquisition of major Government-owned or Government-leased operational observing systems, including polar-orbiting and geostationary satellite systems, with a lifecycle cost of more than $500,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b85e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted prior to the purchase of any major new commercially provided data with a lifecycle cost of more than $500,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b85f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority Observing System Simulation Experiments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b860-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global Navigation Satellite System Radio Occultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2017-04-18"},"text":"April 18, 2017","children":[],"tail":", the Assistant Administrator for Oceanic and Atmospheric Research shall complete an Observing System Simulation Experiment to assess the value of data from Global Navigation Satellite System Radio Occultation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b861-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geostationary hyperspectral sounder global constellation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2017-04-18"},"text":"April 18, 2017","children":[],"tail":", the Assistant Administrator for Oceanic and Atmospheric Research shall complete an Observing System Simulation Experiment to assess the value of data from a geostationary hyperspectral sounder global constellation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b862-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8517/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of all Observing System Simulation Experiments, the Assistant Administrator shall make available to the public the results an assessment ","children":[{"tag":"ref","attrib":{"idref":"fn002599"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002599"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" of related private and public sector weather data sourcing options, including their availability, affordability, and cost-effectiveness. Such assessments shall be developed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s50503"},"text":"section 50503 of title 51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b863-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tI/s107"},"text":"Pub. L. 115–25, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/96"},"text":"131 Stat. 96","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
