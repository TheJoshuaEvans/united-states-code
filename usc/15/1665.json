{"tag":"section","attrib":{"id":"id799df4bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665"},"text":"§ 1665.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonliability of advertising media","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is no liability under this part on the part of any owner or personnel, as such, of any medium in which an advertisement appears or through which it is disseminated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799df4be-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s145"},"text":"Pub. L. 90–321, title I, § 145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/159"},"text":"82 Stat. 159","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
