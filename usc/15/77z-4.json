{"tag":"section","attrib":{"id":"id77ebfed7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"77z–4"},"text":"§ 77z–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77ebfed8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, by rule, adopt data standards for all registration statements, and for all prospectuses included in registration statements, required to be filed with the Commission under this subchapter, except that the Commission may exempt exhibits, signatures, and certifications from those data standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77ebfed9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data standards required under subsection (a) shall incorporate, and ensure compatibility with (to the extent feasible), all applicable data standards established in the rules promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5334"},"text":"section 5334 of title 12","children":[],"tail":", including, to the extent practicable, by having the characteristics described in clauses (i) through (vi) of subsection (c)(1)(B) of such section 5334."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77ebfeda-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 29, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVIII/s5821/e"},"text":"Pub. L. 117–263, div. E, title LVIII, § 5821(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3426"},"text":"136 Stat. 3426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ebfedb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ebfedc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77ebfedd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5821/e"},"text":"Section 5821(e) of Pub. L. 117–263","children":[],"tail":" directed that this section be added at the end of title I of the Securities Act of 1933, which is classified to this subchapter. For purposes of codification, however, this section was added after "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77z–3"},"text":"section 77z–3 of this title","children":[],"tail":" and before Schedules A and B set out at "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77aa"},"text":"section 77aa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77ebfede-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77ebfedf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction—No New Disclosure Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of section not to be construed to require certain additional information to be collected or disclosed, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5826"},"text":"section 5826 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77g"},"text":"section 77g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
