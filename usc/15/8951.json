{"tag":"section","attrib":{"id":"id7a912f40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951"},"text":null,"children":[{"tag":"num","attrib":{"value":"8951"},"text":"§ 8951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contaminant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contaminant” means any physical, chemical, biological, or radiological substance or matter in water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contaminant of emerging concern; emerging contaminant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “contaminant of emerging concern” and “emerging contaminant” mean a contaminant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the Administrator has not promulgated a national primary drinking water regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may have an adverse effect on the health of individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal research strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal research strategy” means the coordinated cross-agency plan for addressing critical research gaps related to detecting, assessing exposure to, and identifying the adverse health effects of emerging contaminants in drinking water developed by the Office of Science and Technology Policy in response to the report of the Committee on Appropriations of the Senate accompanying S. 1662 of the 115th Congress (S. Rept. 115–139).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “technical assistance and support” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying appropriate analytical methods for the detection of contaminants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding the strengths and limitations of the analytical methods described in clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" troubleshooting the analytical methods described in clause (i);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing advice on laboratory certification program elements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpreting sample analysis results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training with respect to proper analytical techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying appropriate technology for the treatment of contaminants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" analyzing samples, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the analysis cannot be otherwise ","children":[{"tag":"ref","attrib":{"idref":"fn002612"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002612"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" obtained in a practicable manner otherwise; "},{"tag":"ref","attrib":{"idref":"fn002612"},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/4/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability and capacity to perform the analysis is available at a Federal facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8951/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working Group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Working Group” means the Working Group established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8952/b/1"},"text":"section 8952(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912f53-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7341"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2283"},"text":"133 Stat. 2283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a912f54-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a912f55-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a912f56-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"S. 1662 of the 115th Congress, referred to in par. (3), is the Commerce, Justice, Science, and Related Agencies Appropriations Act, 2018, which became div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/400"},"text":"132 Stat. 400","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
