{"tag":"section","attrib":{"id":"id7a68befa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6906"},"text":null,"children":[{"tag":"num","attrib":{"value":"6906"},"text":"§ 6906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a68befb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance under this chapter shall be matched with funds from sources other than the Federal Government on the basis of not less than 50 percent of each dollar provided by the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68befc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources of matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees, grants, gifts, funds from loan sources, and in-kind resources of a grant recipient from public or private sources may be used to comply with the matching requirement in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68befd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68befe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6906/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an applicant for assistance under this chapter with severe constraints on available sources of matching funds, the Administrator may reduce or eliminate the matching requirements of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68beff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6906/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of the total funds made available from the Administration in any fiscal year to carry out this chapter may be excepted from the matching requirements of subsection (a), as authorized by paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bf00-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s177"},"text":"Pub. L. 103–325, title I, § 177","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1474"},"text":"113 Stat. 1474","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
