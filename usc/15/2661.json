{"tag":"section","attrib":{"id":"id7a047f5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2661"},"text":null,"children":[{"tag":"num","attrib":{"value":"2661"},"text":"§ 2661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The national long-term goal of the United States with respect to radon levels in buildings is that the air within buildings in the United States should be as free of radon as the ambient air outside of buildings.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a047f5f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tIII/s301"},"text":"Pub. L. 94–469, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/551/s1/a"},"text":"Pub. L. 100–551, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2755"},"text":"102 Stat. 2755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a047f60-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a047f61-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a047f62-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Recommended Policy for Dealing With Radon in Assisted Housing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628/tX/s1091"},"text":"Pub. L. 100–628, title X, § 1091","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3283"},"text":"102 Stat. 3283","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/628/tX/s1091"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the Department of Housing and Urban Development to develop an effective departmental policy for dealing with radon contamination that utilizes any Environmental Protection Agency guidelines and standards to ensure that occupants of housing covered by this section are not exposed to hazardous levels of radon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the Department of Housing and Urban Development to assist the Environmental Protection Agency in reducing radon contamination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The housing covered by this section is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multifamily housing owned by the Department of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public housing and Indian housing assisted under the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing receiving project-based assistance under section 8 of the United States Housing Act of 1937 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"42 U.S.C. 1437f","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing assisted under section 236 of the National Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715z–1"},"text":"12 U.S.C. 1715z–1","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing assisted under section 221(d)(3) of the National Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1715"},"text":"12 U.S.C. 1715","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(d)(3)]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Housing and Urban Development shall develop and recommend to the Congress a policy for dealing with radon contamination that specifies programs for education, research, testing, and mitigation of radon hazards in housing covered by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the policy, the Secretary shall utilize any guidelines, information, or standards established by the Environmental Protection Agency for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testing residential and nonresidential structures for radon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying elevated radon levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying when remedial actions should be taken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying geographical areas that are likely to have elevated levels of radon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the policy, the Secretary shall coordinate the efforts of the Department of Housing and Urban Development with the Environmental Protection Agency, and other appropriate Federal agencies, and shall consult with State and local governments, the housing industry, consumer groups, health organizations, appropriate professional organizations, and other appropriate experts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit a report to the Congress within 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":"] that describes the Secretary’s recommended policy for dealing with radon contamination and the Secretary’s reasons for recommending such policy. The report shall include an estimate of the housing covered by this section that is likely to have hazardous levels of radon."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation With Environmental Protection Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":"], the Secretary and the Administrator of the Environmental Protection Agency shall enter into a memorandum of understanding describing the Secretary’s plan to assist the Administrator in carrying out the Environmental Protection Agency’s authority to assess the extent of radon contamination in the United States and assist in the development of measures to avoid and reduce radon contamination."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Administrator’ means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds available for housing covered by this section shall be available to carry out this section with respect to such housing.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
