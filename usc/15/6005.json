{"tag":"section","attrib":{"id":"id7a533ade-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6005"},"text":null,"children":[{"tag":"num","attrib":{"value":"6005"},"text":"§ 6005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the National Highway Traffic Safety Administration to carry out the grant program authorized by this chapter, there are authorized to be appropriated $2,000,000 for fiscal year 1995, $3,000,000 for fiscal year 1996, and $4,000,000 for fiscal year 1997.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a533adf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/267/tII/s206"},"text":"Pub. L. 103–267, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/728"},"text":"108 Stat. 728","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
