{"tag":"section","attrib":{"id":"id7a15475c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3059"},"text":null,"children":[{"tag":"num","attrib":{"value":"3059"},"text":"§ 3059.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfair or deceptive acts or practices","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The sale of a covered horse, or of any other horse in anticipation of its future participation in a covered race, shall be considered an unfair or deceptive act or practice in or affecting commerce under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/a"},"text":"section 45(a) of this title","children":[],"tail":" if the seller—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a15475d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3059/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knows or has reason to know the horse has been administered—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a15475e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3059/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bisphosphonate prior to the horse’s fourth birthday; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15475f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3059/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other substance or method the Authority determines has a long-term degrading effect on the soundness of the covered horse; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154760-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3059/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to disclose to the buyer the administration of the bisphosphonate or other substance or method described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a154761-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1210"},"text":"Pub. L. 116–260, div. FF, title XII, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3274"},"text":"134 Stat. 3274","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
