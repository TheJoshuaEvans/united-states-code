{"tag":"section","attrib":{"id":"id79e5854c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2220"},"text":null,"children":[{"tag":"num","attrib":{"value":"2220"},"text":"§ 2220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arson prevention, detection, and control","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e5854d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2220/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop arson detection techniques to assist Federal agencies and States and local jurisdictions in improving arson prevention, detection, and control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5854e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2220/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and instructional materials in the skills and knowledge necessary to assist Federal, State, and local fire service and law enforcement personnel in arson prevention, detection, and control, with particular emphasis on the needs of volunteer firefighters for improved and more widely available arson training courses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5854f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2220/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate methods for collection of arson data which would be compatible with methods of collection used for the uniform crime statistics of the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58550-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2220/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement programs for improved collection of nationwide arson statistics within the National Fire Incident Reporting System at the National Fire Data Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58551-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2220/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop programs for public education on the extent, causes, and prevention of arson; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58552-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2220/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop handbooks to assist Federal, State, and local fire service and law enforcement personnel in arson prevention and detection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e58553-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498/s24"},"text":"Pub. L. 93–498, § 24","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/422/s3/a"},"text":"Pub. L. 95–422, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/932"},"text":"92 Stat. 932","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/254/s4"},"text":"Pub. L. 103–254, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-19"},"text":"May 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/682"},"text":"108 Stat. 682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/503/tI/s110/a/1/C"},"text":"Pub. L. 106–503, title I, § 110(a)(1)(C)","children":[],"tail":", (D), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2302"},"text":"114 Stat. 2302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e58554-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e58555-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79e58556-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503"},"text":"Pub. L. 106–503","children":[],"tail":" struck out subsec. (a) designation and struck out subsec. (b) which required the Administrator to submit a report to Congress by "},{"tag":"date","attrib":{"date":"1979-03-15"},"text":"Mar. 15, 1979","children":[],"tail":", on ways to assist the States and local jurisdictions with arson control."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/254"},"text":"Pub. L. 103–254","children":[],"tail":" inserted before semicolon at end “, with particular emphasis on the needs of volunteer firefighters for improved and more widely available arson training courses”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79e58557-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79e58558-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of all functions, personnel, assets, components, authorities, grant programs, and liabilities of the Federal Emergency Management Agency, including the functions of the Under Secretary for Federal Emergency Management relating thereto, to the Federal Emergency Management Agency, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s315/a/1"},"text":"section 315(a)(1) of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Federal Emergency Management Agency, including the functions of the Director of the Federal Emergency Management Agency relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see former section 313(1) and sections 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79e58559-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79e5855a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Administrator of United States Fire Administration under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2221"},"text":"section 2221 of this title","children":[],"tail":" to remain vested in Administrator and not to be transferred to Director of Federal Emergency Management Agency, pursuant to Reorg. Plan No. 3 of 1978, §§ 201, 301, "},{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":", 43 F.R. 41944, "},{"tag":"ref","attrib":{"href":"/us/stat/92/3788"},"text":"92 Stat. 3788","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2201"},"text":"section 2201 of this title","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1979-04-01"},"text":"Apr. 1, 1979","children":[],"tail":", pursuant to Ex. Ord. No. 12127, § 1–103(a), "},{"tag":"date","attrib":{"date":"1979-03-31"},"text":"Mar. 31, 1979","children":[],"tail":", 44 F.R. 19367."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
