{"tag":"section","attrib":{"id":"id7a38fc6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401"},"text":null,"children":[{"tag":"num","attrib":{"value":"4401"},"text":"§ 4401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38fc70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fc71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Health and Human Services shall establish and carry out a program to inform the public of any dangers to human health resulting from the use of smokeless tobacco products. In carrying out such program the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38fc72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop educational programs and materials and public service announcements respecting the dangers to human health from the use of smokeless tobacco;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fc73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such programs, materials, and announcements available to States, local governments, school systems, the media, and such other entities as the Secretary determines appropriate to further the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fc74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support research on the effect of smokeless tobacco on human health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fc75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, analyze, and disseminate information and studies on smokeless tobacco and health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fc76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing programs, materials, and announcements under paragraph (1) the Secretary shall consult with the Secretary of Education, medical and public health entities, consumer groups, representatives of manufacturers of smokeless tobacco products, and other appropriate entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fc77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services may provide technical assistance and may make grants to States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fc78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the development of educational programs and materials and public service announcements respecting the dangers to human health from the use of smokeless tobacco,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fc79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the distribution of such programs, materials, and announcements throughout the States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fc7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish 18 as the minimum age for the purchase of smokeless tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38fc7b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/252/s2"},"text":"Pub. L. 99–252, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/30"},"text":"100 Stat. 30","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a38fc7c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a38fc7d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a38fc7e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/252/s11"},"text":"Pub. L. 99–252, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/35"},"text":"100 Stat. 35","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/252/s11"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in sections 3(f) and 5(b) [sections 4402(f) and 4404(b) of this title] and subsection (b), this Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s342"},"text":"section 342 of Title 21","children":[],"tail":", Food and Drugs] shall take effect one year after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 2, 3(b), 3(c), 3(d), 3(e), 4(b), 7, 8, 9 [sections 4401, 4402(b) to (e), 4403(b), and 4406 to 4408 of this title], and 10 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s342"},"text":"section 342 of Title 21","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a38fc7f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/252/s1"},"text":"Pub. L. 99–252, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/30"},"text":"100 Stat. 30","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/252/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s342"},"text":"section 342 of Title 21","children":[],"tail":", Food and Drugs] may be cited as the ‘Comprehensive Smokeless Tobacco Health Education Act of 1986’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
