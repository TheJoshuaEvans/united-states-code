{"tag":"section","attrib":{"id":"id7ab04ee9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502"},"text":null,"children":[{"tag":"num","attrib":{"value":"9502"},"text":"§ 9502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority Business Development Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab04eea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is within the Department of Commerce the Minority Business Development Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04eeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04eec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Agency shall be headed by the Under Secretary of Commerce for Minority Business Development, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04eed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President, by and with the advice and consent of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04eee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise expressly provided, be responsible for the administration of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04eef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04ef0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04ef1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall be compensated at an annual rate of basic pay prescribed for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04ef2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04ef3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Director of the Agency shall be deemed to be a reference to the Under Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04ef4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall submit to Congress a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04ef5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organizational structure of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04ef6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organizational position of the Agency within the Department of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04ef7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the Agency shall function in relation to the operations carried out by each other component of the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04ef8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Business Centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04ef9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Agency the Office of Business Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04efa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Business Centers shall be administered by a Director, who shall be appointed by the Under Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04efb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offices of the Agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04efc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the regional offices that the Under Secretary is required to establish under paragraph (2), the Under Secretary shall establish such other offices within the Agency as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04efd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional offices","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04efe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out this chapter, the Under Secretary shall establish a regional office of the Agency for each of the regions of the United States, as determined by the Under Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04eff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each regional office established under subparagraph (A) shall expand the reach of the Agency and enable the Federal Government to better serve the needs of minority business enterprises in the region served by the office, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding and participating in the business environment of that region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" working with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7ab04f02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" MBDA Business Centers that are located in that region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7ab04f03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource and lending partners of other appropriate Federal agencies that are located in that region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7ab04f04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and local procurement offices that are located in that region;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being aware of business retention or expansion programs that are specific to that region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeking out opportunities to collaborate with regional public and private programs that focus on minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9502/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting business continuity and preparedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04f08-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/s100003"},"text":"Pub. L. 117–58, div. K, § 100003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1448"},"text":"135 Stat. 1448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab04f09-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab04f0a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab04f0b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(1)(B) and (e)(1), (2)(A), was in the original “this division”, meaning div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1445"},"text":"135 Stat. 1445","children":[],"tail":", which is classified prinicpally to this chapter. For complete classification of division K to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7ab04f0c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s100003"},"text":"section 100003 of Pub. L. 117–58","children":[],"tail":". Subsec. (b)(2)(B) of section 100003 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
