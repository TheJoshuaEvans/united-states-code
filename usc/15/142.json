{"tag":"section","attrib":{"id":"id78824bed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s142"},"text":null,"children":[{"tag":"num","attrib":{"value":"142"},"text":"§ 142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter, unless the context otherwise indicates—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78824bee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes individual, partnership, corporation, and association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824bef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “China” means (1) China including Manchuria, Tibet, Mongolia, and any territory leased by China to any foreign government, (2) the Crown Colony of Hong Kong, and (3) the Province of Macao;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824bf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “China Trade Act corporation” and “corporation” mean a corporation chartered under the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824bf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal district court” means any Federal district court, and the United States District Court for the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824bf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s142/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824bf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s142/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “registrar” means the China Trade Act registrar appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s143"},"text":"section 143 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78824bf4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-19/ch346/s2"},"text":"Sept. 19, 1922, ch. 346, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/849"},"text":"42 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch804"},"text":"June 25, 1936, ch. 804","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1921"},"text":"49 Stat. 1921","children":[],"tail":"; Treaty "},{"tag":"date","attrib":{"date":"1943-01-11"},"text":"Jan. 11, 1943","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/767"},"text":"57 Stat. 767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s32/a"},"text":"June 25, 1948, ch. 646, § 32(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s127"},"text":"May 24,