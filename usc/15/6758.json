{"tag":"section","attrib":{"id":"id7a64044d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6758"},"text":null,"children":[{"tag":"num","attrib":{"value":"6758"},"text":"§ 6758.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of the Association and the Board members, officers, and employees of the Association","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a64044e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6758/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Association shall not be deemed to be an insurer or insurance producer within the meaning of any State law, rule, regulation, or order regulating or taxing insurers, insurance producers, or other entities engaged in the business of insurance, including provisions imposing premium taxes, regulating insurer solvency or financial condition, establishing guaranty funds and levying assessments, or requiring claims settlement practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a64044f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6758/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of Board members, officers, and employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Board member, officer, or employee of the Association shall be personally liable to any person for any action taken or omitted in good faith in any matter within the scope of their responsibilities in connection with the Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a640450-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s328"},"text":"Pub. L. 106–102, title III, § 328","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/25"},"text":"129 Stat. 25","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a640451-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a640452-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a640453-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6761"},"text":"section 6761 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6758, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s328"},"text":"Pub. L. 106–102, title III, § 328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1427"},"text":"113 Stat. 1427","children":[],"tail":", related to bylaws, rules, and disciplinary action, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6755"},"text":"section 6755 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
