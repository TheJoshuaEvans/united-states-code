{"tag":"section","attrib":{"id":"id7926c891-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s687h"},"text":null,"children":[{"tag":"num","attrib":{"value":"687h"},"text":"§ 687h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any suit or action brought under section 687, 687a, 687c, 687e, or 687g of this title by the Administration at law or in equity to enforce any liability or duty created by, or to enjoin any violation of, this chapter, or any rule, regulation, or order promulgated thereunder, shall be brought in the district wherein the licensee maintains its principal office, and process in such cases may be served in any district in which the defendant maintains its principal office or transacts business, or wherever the defendant may be found.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7926c892-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s316"},"text":"Pub. L. 85–699, title III, § 316","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/779/s7"},"text":"Pub. L. 89–779, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-06"},"text":"Nov. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1364"},"text":"80 Stat. 1364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7926c893-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7926c894-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7926c895-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in text, see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
