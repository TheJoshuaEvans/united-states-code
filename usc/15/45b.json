{"tag":"section","attrib":{"id":"id77c38f65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b"},"text":null,"children":[{"tag":"num","attrib":{"value":"45b"},"text":"§ 45b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer review protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77c38f66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c38f67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered communication” means a written, oral, or pictorial review, performance assessment of, or other similar analysis of, including by electronic means, the goods, services, or conduct of a person by an individual who is party to a form contract with respect to which such person is also a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form contract","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “form contract” means a contract with standardized terms—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77c38f6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used by a person in the course of selling or leasing the person’s goods or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposed on an individual without a meaningful opportunity for such individual to negotiate the standardized terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “form contract” does not include an employer-employee or independent contractor contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pictorial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pictorial” includes pictures, photographs, video, illustrations, and symbols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38f6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invalidity of contracts that impede consumer reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c38f70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraphs (2) and (3), a provision of a form contract is void from the inception of such contract if such provision—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits or restricts the ability of an individual who is a party to the form contract to engage in a covered communication;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposes a penalty or fee against an individual who is a party to the form contract for engaging in a covered communication; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers or requires an individual who is a party to the form contract to transfer to any person any intellectual property rights in review or feedback content, with the exception of a non-exclusive license to use the content, that the individual may have in any otherwise lawful covered communication about such person or the goods or services provided by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in paragraph (1) shall be construed to affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any duty of confidentiality imposed by law (including agency guidance);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any civil cause of action for defamation, libel, or slander, or any similar cause of action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any party’s right to remove or refuse to display publicly on an Internet website or webpage owned, operated, or otherwise controlled by such party any content of a covered communication that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77c38f78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the personal information or likeness of another person, or is libelous, harassing, abusive, obscene, vulgar, sexually explicit, or is inappropriate with respect to race, gender, sexuality, ethnicity, or other intrinsic characteristic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unrelated to the goods or services offered by or available at such party’s Internet website or webpage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is clearly false or misleading; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party’s right to establish terms and conditions with respect to the creation of photographs or video of such party’s property when those photographs or video are created by an employee or independent contractor of a commercial entity and solely intended for commercial purposes by that entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to the extent that a provision of a form contract prohibits disclosure or submission of, or reserves the right of a person or business that hosts online consumer reviews or comments to remove—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade secrets or commercial or financial information obtained from a person and considered privileged or confidential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel and medical files and similar information the disclosure of which would constitute a clearly unwarranted invasion of personal privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records or information compiled for law enforcement purposes, the disclosure of which would constitute a clearly unwarranted invasion of personal privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" content that is unlawful or otherwise meets the requirements of paragraph (2)(C); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" content that contains any computer viruses, worms, or other potentially damaging computer code, processes, programs, applications, or files.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38f82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for a person to offer a form contract containing a provision described as void in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38f83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c38f84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfair or deceptive acts or practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of subsection (c) by a person with respect to which the Commission is empowered under section 5(a)(2) of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/a/2"},"text":"15 U.S.C. 45(a)(2)","children":[],"tail":") shall be treated as a violation of a rule defining an unfair or deceptive act or practice prescribed under section 18(a)(1)(B) of the Federal Trade Commission Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a/a/1/B"},"text":"15 U.S.C. 57a(a)(1)(B)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall enforce this section in the same manner, by the same means, and with the same jurisdiction, powers, and duties as though all applicable terms and provisions of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.) were incorporated into and made a part of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileges and immunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates this section shall be subject to the penalties and entitled to the privileges and immunities provided in the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38f88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c38f89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), in any case in which the attorney general of a State has reason to believe that an interest of the residents of the State has been or is threatened or adversely affected by the engagement of any person subject to subsection (c) in a practice that violates such subsection, the attorney general of the State may, as parens patriae, bring a civil action on behalf of the residents of the State in an appropriate district court of the United States to obtain appropriate relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of Federal Trade Commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Federal Trade Commission","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77c38f8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (iii), the attorney general of a State shall notify the Commission in writing that the attorney general intends to bring a civil action under paragraph (1) before initiating the civil action against a person described in subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notification required by clause (i) with respect to a civil action shall include a copy of the complaint to be filed to initiate the civil action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If it is not feasible for the attorney general of a State to provide the notification required by clause (i) before initiating a civil action under paragraph (1), the attorney general shall notify the Commission immediately upon instituting the civil action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention by Federal Trade Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77c38f90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intervene in any civil action brought by the attorney general of a State under paragraph (1) against a person described in subsection (d)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon intervening—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77c38f92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be heard on all matters arising in the civil action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77c38f93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file petitions for appeal of a decision in the civil action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigatory powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed to prevent the attorney general of a State from exercising the powers conferred on the attorney general by the laws of the State to conduct investigations, to administer oaths or affirmations, or to compel the attendance of witnesses or the production of documentary or other evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemptive action by Federal Trade Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Federal Trade Commission institutes a civil action or an administrative action with respect to a violation of subsection (c), the attorney general of a State may not, during the pendency of such action, bring a civil action under paragraph (1) against any defendant named in the complaint of the Commission for the violation with respect to which the Commission instituted such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue; service of process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any action brought under paragraph (1) may be brought in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77c38f98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district court of the United States that meets applicable requirements relating to venue under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under paragraph (1), process may be served in any district in which the defendant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77c38f9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an inhabitant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77c38f9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38f9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by other State officials","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c38f9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to civil actions brought by attorneys general under paragraph (1), any other consumer protection officer of a State who is authorized by the State to do so may bring a civil action under paragraph (1), subject to the same requirements and limitations that apply under this subsection to civil actions brought by attorneys general.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c38f9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed to prohibit an authorized official of a State from initiating or continuing any proceeding in a court of the State for a violation of any civil or criminal law of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38fa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and outreach for businesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-14"},"text":"December 14, 2016","children":[],"tail":", the Commission shall commence conducting education and outreach that provides businesses with non-binding best practices for compliance with this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38fa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to State causes of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect any cause of action brought by a person that exists or may exist under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38fa2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit, impair, or supersede the operation of the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.] or any other provision of Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c38fa3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective dates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2016-12-14"},"text":"December 14, 2016","children":[],"tail":", except that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c38fa4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b) and (c) shall apply with respect to contracts in effect on or after the date that is 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-14"},"text":"December 14, 2016","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c38fa5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45b/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (d) and (e) shall apply with respect to contracts in effect on or after the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-14"},"text":"December 14, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c38fa6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/258/s2"},"text":"Pub. L. 114–258, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1355"},"text":"130 Stat. 1355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c38fa7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c38fa8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77c38fa9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsecs. (d)(2) and (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to this subchapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (d)(2)(A) and (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/258"},"text":"Pub. L. 114–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1355"},"text":"130 Stat. 1355","children":[],"tail":", known as the Consumer Review Fairness Act of 2016, which enacted this section and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2016 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77c38faa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consumer Review Fairness Act of 2016, and not as part of the Federal Trade Commission Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
