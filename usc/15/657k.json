{"tag":"section","attrib":{"id":"id791ae26d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657k"},"text":null,"children":[{"tag":"num","attrib":{"value":"657k"},"text":"§ 657k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster processing redundancy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791ae26e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that the Administration has in place a facility for disaster loan processing that, whenever the Administration’s primary facility for disaster loan processing becomes unavailable, is able to take over all disaster loan processing from that primary facility within 2 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d526f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d5270-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s39"},"text":"Pub. L. 85–536, § 2[39]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12069"},"text":"Pub. L. 110–234, title XII, § 12069","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"