{"tag":"section","attrib":{"id":"id7a36b2ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4110"},"text":null,"children":[{"tag":"num","attrib":{"value":"4110"},"text":"§ 4110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; new spending authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a36b2bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated such sums as may be necessary for carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a36b2bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any new spending authority (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s651"},"text":"section 651 of title 2","children":[],"tail":") which is provided under this chapter shall be effective for any fiscal year only to such extent or in such amounts as may be provided in appropriation Acts."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a36b2bd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373/tI/s111"},"text":"Pub. L. 98–373, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-31"},"text":"July 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1248"},"text":"98 Stat. 1248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
