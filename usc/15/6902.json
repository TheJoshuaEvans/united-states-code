{"tag":"section","attrib":{"id":"id7a68bedf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6902"},"text":null,"children":[{"tag":"num","attrib":{"value":"6902"},"text":"§ 6902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a microenterprise technical assistance and capacity building grant program to provide assistance from the Administration in the form of grants to qualified organizations in accordance with this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a68bee0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s173"},"text":"Pub. L. 103–325, title I, § 173","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1473"},"text":"113 Stat. 1473","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
