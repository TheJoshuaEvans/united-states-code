{"tag":"section","attrib":{"id":"id78a5ffc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377"},"text":null,"children":[{"tag":"num","attrib":{"value":"377"},"text":"§ 377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a5ffc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5ffc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), whoever knowingly violates this chapter shall be imprisoned for not more than 3 years, fined under title 18, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5ffc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a5ffc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to a State, local, or tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A common carrier or independent delivery service, or employee of a common carrier or independent delivery service, shall be subject to criminal penalties under paragraph (1) for a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a/e"},"text":"section 376a(e) of this title","children":[],"tail":" only if the violation is committed knowingly—"}],"tail":null},{"tag":"clause","attrib":{"id":"id78a5ffc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as consideration for the receipt of, or as consideration for a promise or agreement to pay, anything of pecuniary value; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a5ffc7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of assisting a delivery seller to violate, or otherwise evading compliance with, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a"},"text":"section 376a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5ffc8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5ffc9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), whoever violates this chapter shall be subject to a civil penalty in an amount not to exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a5ffca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a delivery seller, the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a5ffcb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000 in the case of the first violation, or $10,000 for any other violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a5ffcc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any violation, 2 percent of the gross sales of cigarettes or smokeless tobacco of the delivery seller during the 1-year period ending on the date of the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffcd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a common carrier or other delivery service, $2,500 in the case of a first violation, or $5,000 for any violation within 1 year of a prior violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5ffce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil penalty imposed under paragraph (1) for a violation of this chapter shall be imposed in addition to any criminal penalty under subsection (a) and any other damages, equitable relief, or injunctive relief awarded by the court, including the payment of any unpaid taxes to the appropriate Federal, State, local, or tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5ffcf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a5ffd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee of a common carrier or independent delivery service shall be subject to civil penalties under paragraph (1) for a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a/e"},"text":"section 376a(e) of this title","children":[],"tail":" only if the violation is committed intentionally—"}],"tail":null},{"tag":"clause","attrib":{"id":"id78a5ffd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as consideration for the receipt of, or as consideration for a promise or agreement to pay, anything of pecuniary value; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a5ffd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the purpose of assisting a delivery seller to violate, or otherwise evading compliance with, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a"},"text":"section 376a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No common carrier or independent delivery service shall be subject to civil penalties under paragraph (1) for a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a/e"},"text":"section 376a(e) of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"clause","attrib":{"id":"id78a5ffd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the common carrier or independent delivery service has implemented and enforces effective policies and practices for complying with that section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a5ffd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s377/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation consists of an employee of the common carrier or independent delivery service who physically receives and processes orders, picks up packages, processes packages, or makes deliveries, taking actions that are outside the scope of employment of the employee, or that violate the implemented and enforced policies of the common carrier or independent delivery service described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a5ffd6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-19/ch699/s3"},"text":"Oct. 19, 1949, ch. 699, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/154/s2/d"},"text":"Pub. L. 111–154, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1100"},"text":"124 Stat. 1100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a5ffd7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a5ffd8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78a5ffd9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 377, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-19/ch699/s3"},"text":"act Oct. 19, 1949, ch. 699, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/885"},"text":"63 Stat. 885","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch695/s1"},"text":"Aug. 9, 1955, ch. 695, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/628"},"text":"69 Stat. 628","children":[],"tail":", which related to penalties for violations of any provision of this chapter, was repealed, effective on the date that is 90 days after "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"March 31, 2010","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/111/154"},"text":"Pub. L. 111–154","children":[],"tail":", §§ 2(d), 6, "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1100"},"text":"124 Stat. 1100","children":[],"tail":", 1110."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a5ffda-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78a5ffdb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-03-31"},"text":"March 31, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/154/s6"},"text":"section 6 of Pub. L. 111–154","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s375"},"text":"section 375 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
