{"tag":"section","attrib":{"id":"id7a57f5b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307d"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307d"},"text":"§ 6307d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required disclosures to State boxing commissions by sanctioning organizations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A sanctioning organization shall not be entitled to receive any compensation directly or indirectly in connection with a boxing match until it provides to the boxing commission responsible for regulating the match in a State a statement of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all charges, fees, and costs the organization will assess any boxer participating in that match;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all payments, benefits, complimentary benefits, and fees the organization will receive for its affiliation with the event, from the promoter, host of the event, and all other sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information as the commission may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f5b8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s12"},"text":"Pub. L. 104–272, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/2"},"text":"Pub. L. 106–210, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/324"},"text":"114 Stat. 324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f5b9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a57f5ba-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a57f5bb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s12"},"text":"section 12 of Pub. L. 104–272","children":[],"tail":" was renumbered section 20 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6311"},"text":"section 6311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
