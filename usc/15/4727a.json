{"tag":"section","attrib":{"id":"id7a44e334-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4727a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4727a"},"text":"§ 4727a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of primary objectives of TPCC","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Trade Promotion Coordinating Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a44e335-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4727a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report on the actions taken or efforts currently underway to eliminate the areas of overlap and duplication identified among Federal export promotion activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a44e336-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4727a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate efforts to sponsor or promote any trade show or trade fair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a44e337-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4727a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with all relevant State and national organizations, including the National Governors’ Association, that have established trade promotion offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a44e338-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4727a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report on actions taken or efforts currently underway to promote better coordination between State, Federal, and private sector export promotion activities, including co-location, cost sharing between Federal, State, and private sector export promotion programs, and sharing of market research data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a44e339-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4727a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not later than ","children":[{"tag":"date","attrib":{"date":"2000-03-30"},"text":"March 30, 2000","children":[],"tail":", and annually thereafter, include the matters addressed in paragraphs (1), (2), (3), and (4) in the annual report required to be submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4727/f"},"text":"section 4727(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a44e33a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/158/s6"},"text":"Pub. L. 106–158, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1746"},"text":"113 Stat. 1746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a44e33b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a44e33c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a44e33d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Export Enhancement Act of 1999, and not as part of the Export Enhancement Act of 1988 which enacted this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
