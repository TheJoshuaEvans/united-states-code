{"tag":"section","attrib":{"id":"id7a82fdba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8303"},"text":null,"children":[{"tag":"num","attrib":{"value":"8303"},"text":"§ 8303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abusive swaps","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commodity Futures Trading Commission or the Securities and Exchange Commission, or both, individually may, by rule or order—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a82fdbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect information as may be necessary concerning the markets for any types of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fdbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8303/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" swap (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of title 7","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fdbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8303/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security-based swap (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of title 7","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fdbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" issue a report with respect to any types of swaps or security-based swaps that the Commodity Futures Trading Commission or the Securities and Exchange Commission determines to be detrimental to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fdbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8303/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stability of a financial market; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fdc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8303/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participants in a financial market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a82fdc1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s714"},"text":"Pub. L. 111–203, title VII, § 714","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1647"},"text":"124 Stat. 1647","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
