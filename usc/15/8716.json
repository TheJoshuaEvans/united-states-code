{"tag":"section","attrib":{"id":"id7a8ee433-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716"},"text":null,"children":[{"tag":"num","attrib":{"value":"8716"},"text":"§ 8716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report by the Government Accountability Office","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", the Comptroller General of the United States shall prepare a study, and not later than 8 years after "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", the Comptroller General shall submit to Congress and the Secretary a report, examining—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee434-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Board spends assessments collected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee435-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the reported activities of the Board help achieve the annual objectives of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee436-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes in demand for concrete masonry products relative to other building materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee437-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any impact of the activities of the Board on the market share of competing products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee438-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any impact of the activities of the Board on the overall size of the market for building products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee439-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any impact of the activities of the Board on the total number of concrete-masonry-related jobs, including manufacturing, sales, and installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee43a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any significant effects of the activities of the Board on downstream purchasers of concrete masonry products and real property into which concrete masonry products are incorporated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee43b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects on prices of concrete masonry products as a result of the activities of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee43c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to the Federal Government of an increase in concrete masonry product prices, if any, as a result of the program established by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee43d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which key statutory requirements are met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee43e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and strength of Federal oversight of the program established by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee43f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriateness of administering the program from within the Office of the Secretary of Commerce and the appropriateness of administering the program from within any division of the Department, including whether the Department has the expertise, knowledge, or other capabilities necessary to adequately administer the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee440-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8716/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other topic that the Comptroller General considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee441-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1317"},"text":"Pub. L. 115–254, div. E, § 1317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3484"},"text":"132 Stat. 3484","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
