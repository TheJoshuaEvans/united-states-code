{"tag":"section","attrib":{"id":"id7a3440cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021"},"text":null,"children":[{"tag":"num","attrib":{"value":"4021"},"text":"§ 4021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3440ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “export trade” means trade or commerce in goods, wares, merchandise, or services exported, or in the course of being exported, from the United States or any territory thereof to any foreign nation,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “service” means intangible economic output, including, but not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3440d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business, repair, and amusement services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management, legal, engineering, architectural, and other professional services, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial, insurance, transportation, informational and any other data-based services, and communication services,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “export trade activities” means activities or agreements in the course of export trade,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “methods of operation” means any method by which a person conducts or proposes to conduct export trade,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means an individual who is a resident of the United States; a partnership that is created under and exists pursuant to the laws of any State or of the United States; a State or local government entity; a corporation, whether organized as a profit or nonprofit corporation, that is created under and exists pursuant to the laws of any State or of the United States; or any association or combination, by contract or other arrangement, between or among such persons,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “antitrust laws” means the antitrust laws, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":" (to the extent that "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":" prohibits unfair methods of competition), and any State antitrust or unfair competition law,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Commerce or his designee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4021/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Attorney General” means the Attorney General of the United States or his designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3440d9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/290/tIII/s311"},"text":"Pub. L. 97–290, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1245"},"text":"96 Stat. 1245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3440da-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a3440db-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a3440dc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/290/s312"},"text":"section 312 of Pub. L. 97–290","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4011"},"text":"section 4011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
