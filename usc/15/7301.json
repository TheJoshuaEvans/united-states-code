{"tag":"section","attrib":{"id":"id7a7234f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301"},"text":null,"children":[{"tag":"num","attrib":{"value":"7301"},"text":"§ 7301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Construction Safety Teams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7234f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Standards and Technology (in this chapter referred to as the “Director”) is authorized to establish National Construction Safety Teams (in this chapter referred to as a “Team”) for deployment after events causing the failure of a building or buildings that has resulted in substantial loss of life or that posed significant potential for substantial loss of life. To the maximum extent practicable, the Director shall establish and deploy a Team within 48 hours after such an event. The Director shall promptly publish in the Federal Register notice of the establishment of each Team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of investigation; duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of investigations by Teams is to improve the safety and structural integrity of buildings in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Team shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7234f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the likely technical cause or causes of the building failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the technical aspects of evacuation and emergency response procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend, as necessary, specific improvements to building standards, codes, and practices based on the findings made pursuant to subparagraphs (A) and (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend any research and other appropriate actions needed to improve the structural safety of buildings, and improve evacuation and emergency response procedures, based on the findings of the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 months after ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":", the Director, in consultation with the United States Fire Administration and other appropriate Federal agencies, shall develop procedures for the establishment and deployment of Teams. The Director shall update such procedures as appropriate. Such procedures shall include provisions—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7234fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding conflicts of interest related to service on the Team;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining the circumstances under which the Director will establish and deploy a Team;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing the appropriate size of Teams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723500-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guiding the disclosure of information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7306"},"text":"section 7306 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723501-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guiding the conduct of investigations under this chapter, including procedures for providing written notice of inspection authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7303/a"},"text":"section 7303(a) of this title","children":[],"tail":" and for ensuring compliance with any other applicable law;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723502-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and prescribing appropriate conditions for the provision by the Director of additional resources and services Teams may need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723503-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that investigations under this chapter do not impede and are coordinated with any search and rescue efforts being undertaken at the site of the building failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723504-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for regular briefings of the public on the status of the investigative proceedings and findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723505-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guiding the Teams in moving and preserving evidence as described in section 7303(a)(4), (b)(2), and (d)(4) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723506-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for coordination with Federal, State, and local entities that may sponsor research or investigations of building failures, including research conducted under the Earthquake Hazards Reduction Act of 1977 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7701"},"text":"42 U.S.C. 7701","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723507-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding such other issues as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723508-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall publish promptly in the Federal Register final procedures, and subsequent updates thereof, developed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a723509-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231/s2"},"text":"Pub. L. 107–231, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1471"},"text":"116 Stat. 1471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/305/s15"},"text":"Pub. L. 107–305, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2381"},"text":"116 Stat. 2381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a72350a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a72350b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a72350c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c)(1)(E), (G), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231"},"text":"Pub. L. 107–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1471"},"text":"116 Stat. 1471","children":[],"tail":", known as the National Construction Safety Team Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Earthquake Hazards Reduction Act of 1977, referred to in subsec. (c)(1)(J), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/124"},"text":"Pub. L. 95–124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-07"},"text":"Oct. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1098"},"text":"91 Stat. 1098","children":[],"tail":", which is classified generally to chapter 86 (§ 7701 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7701"},"text":"section 7701 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a72350d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/305"},"text":"Pub. L. 107–305","children":[],"tail":", which directed the substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7306"},"text":"section 7306 of this title","children":[],"tail":";” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7307"},"text":"section 7307 of this title","children":[],"tail":";” in subsec. (c)(1)(d), was executed to subsec. (c)(1)(D), to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a72350e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a72350f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231/s1"},"text":"Pub. L. 107–231, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1471"},"text":"116 Stat. 1471","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/231/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s281a"},"text":"section 281a of this title","children":[],"tail":"] may be cited as the ‘National Construction Safety Team Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
