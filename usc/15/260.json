{"tag":"section","attrib":{"id":"id7889775e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s260"},"text":null,"children":[{"tag":"num","attrib":{"value":"260"},"text":"§ 260.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy; adoption and observance of uniform standard of time; authority of Secretary of Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States to promote the adoption and observance of uniform time within the standard time zones prescribed by sections 261 to 264 of this title, as modified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s265"},"text":"section 265 of this title","children":[],"tail":". To this end the Secretary of Transportation is authorized and directed to foster and promote widespread and uniform adoption and observance of the same standard of time within and throughout each such standard time zone."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7889775f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/387/s2"},"text":"Pub. L. 89–387, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-13"},"text":"Apr. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/107"},"text":"80 Stat. 107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/449/s2/c"},"text":"Pub. L. 97–449, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2439"},"text":"96 Stat. 2439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78897760-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78897761-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78897762-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":" substituted “Secretary of Transportation” for “Interstate Commerce Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78897763-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78897764-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/387/s6"},"text":"Pub. L. 89–387, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-13"},"text":"Apr. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/108"},"text":"80 Stat. 108","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/387/s6"},"text":"“This Act [enacting this section and sections 260a, 266, and 267 of this title and amending sections 261 to 263 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1967-04-01"},"text":"April 1, 1967","children":[],"tail":"; except that if any State, the District of Columbia, the Commonwealth of Puerto Rico, or any possession of the United States, or any political subdivision thereof, observes daylight saving time in the year 1966, such time shall advance the standard time otherwise applicable in such place by one hour and shall commence at 2 o’clock antemeridian on the last Sunday in April of the year 1966 and shall end at 2 o’clock antemeridian on the last Sunday in October of the year 1966.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78897765-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/387/s1"},"text":"Pub. L. 89–387, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-13"},"text":"Apr. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/107"},"text":"80 Stat. 107","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/387/s1"},"text":"“That this Act [enacting this section and sections 260a, 266, and 267 of this title and amending sections 261 to 263 of this title] may be cited as the ‘Uniform Time Act of 1966’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
