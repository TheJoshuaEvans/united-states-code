{"tag":"section","attrib":{"id":"id7a57f674-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6407"},"text":null,"children":[{"tag":"num","attrib":{"value":"6407"},"text":"§ 6407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lobbying restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds collected by the Council shall be used in any manner for influencing legislation or elections, except that the Council may recommend to the Secretary changes in this chapter or other statutes that would further the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a57f675-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/284/s8"},"text":"Pub. L. 104–284, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3375"},"text":"110 Stat. 3375","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
