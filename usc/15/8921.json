"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the threshold for reporting the chemicals described in paragraph (1) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023"},"text":"section 11023 of title 42","children":[],"tail":" is 100 pounds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912edf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Administrator shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a912ee0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether revision of the threshold under subparagraph (A) is warranted for any chemical described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912ee1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator determines a revision to be warranted under clause (i), initiate a revision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/f/2"},"text":"section 11023(f)(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912ee2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion following assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912ee3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912ee4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (e), notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023"},"text":"section 11023 of title 42","children":[],"tail":", a perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances not described in subsection (b)(1) shall be deemed to be included in the toxics release inventory beginning January 1 of the calendar year after any of the following dates:"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a912ee5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final toxicity value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The date on which the Administrator finalizes a toxicity value for the perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912ee6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant new use rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The date on which the Administrator makes a covered determination for the perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912ee7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition to existing significant new use rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The date on which the perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances is added to a list of substances covered by a covered determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912ee8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition as active chemical substance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The date on which the perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances to which a covered determination applies is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a912ee9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" added to the list published under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2607/b"},"text":"section 2607(b) of this title","children":[],"tail":" and designated as an active chemical substance under paragraph (5)(A) of such section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912eea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated as an active chemical substance on such list under paragraph (5)(B) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912eeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, a covered determination is a determination made, by rule, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2604/a/2"},"text":"section 2604(a)(2) of this title","children":[],"tail":" that a use of a perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances is a significant new use (except such a determination made in connection with a determination described in section 2604(a)(3)(B) or "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2604/a/3/C"},"text":"section 2604(a)(3)(C) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912eec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threshold for reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912eed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), notwithstanding subsection (f)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023"},"text":"section 11023 of title 42","children":[],"tail":", the threshold for reporting under such "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023"},"text":"section 11023 of title 42","children":[],"tail":" the substances and classes of substances included in the toxics release inventory under paragraph (1) is 100 pounds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912eee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after the date on which a perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances is included in the toxics release inventory under paragraph (1), the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912eef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether revision of the threshold under subparagraph (A) is warranted for the substance or class of substances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912ef0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator determines a revision to be warranted under clause (i), initiate a revision under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/f/2"},"text":"section 11023(f)(2) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912ef1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion following determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912ef2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Administrator shall determine whether the substances and classes of substances described in paragraph (2) meet any one of the criteria described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/d/2"},"text":"section 11023(d)(2) of title 42","children":[],"tail":" for inclusion in the toxics release inventory."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ef3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substances described","children":[],"tail":null},{"tag":"chapea