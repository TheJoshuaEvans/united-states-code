{"tag":"section","attrib":{"id":"id7a912ecc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921"},"text":null,"children":[{"tag":"num","attrib":{"value":"8921"},"text":"§ 8921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additions to toxics release inventory","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912ecd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of toxics release inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “toxics release inventory” means the list of toxic chemicals subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/c"},"text":"section 11023(c) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912ece-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate inclusion","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912ecf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (e), beginning January 1 of the calendar year following ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the following chemicals shall be deemed to be included in the toxics release inventory:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912ed0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perfluorooctanoic acid (commonly referred to as “PFOA”) (Chemical Abstracts Service No. 335–67–1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ed1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The salts associated with the chemical described in subparagraph (A) (Chemical Abstracts Service Nos. 3825–26–1, 335–95–5, and 68141–02–6).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ed2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perfluorooctane sulfonic acid (commonly referred to as “PFOS”) (Chemical Abstracts Service No. 1763–23–1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ed3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The salts associated with the chemical described in subparagraph (C) (Chemical Abstracts Service Nos. 2795–39–3, 29457–72–5, 56773–42–3, 29081–56–9, and 70225–14–8).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ed4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912ed5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listed as an active chemical substance in the February 2019 update to the inventory under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2607/b/1"},"text":"section 2607(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912ed6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", subject to the provisions of—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id7a912ed7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 721.9582 of title 40, Code of Federal Regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912ed8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 721.10536 of title 40, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ed9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hexafluoropropylene oxide dimer acid (