1-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salts associated with the chemical described in subparagraph (D) (Chemical Abstracts Service Nos. 958445–44–8, 1087271–46–2, and NOCAS 892452);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ef9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1-octanesulfonic acid 3,3,4,4,5,5,6,6,7,7,8,8-tridecafluoro-potassium salt (Chemical Abstracts Service No. 59587–38–1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912efa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perfluorobutanesulfonic acid (Chemical Abstracts Service No. 375–73–5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912efb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1–Butanesulfonic acid, 1,1,2,2,3,3,4,4,4-nonafluoro-potassium salt (Chemical Abstracts Service No. 29420–49–3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912efc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the component associated with the chemical described in subparagraph (H) (Chemical Abstracts Service No. 45187–15–3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912efd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heptafluorobutyric acid (Chemical Abstracts Service No. 375–22–4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912efe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perfluorohexanoic acid (Chemical Abstracts Service No. 307–24–4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912eff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compound associated with the chemical described in subsection (b)(1)(F) identified by Chemical Abstracts Service No. 2062–98–8;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perfluoroheptanoic acid (commonly referred to as “PFHpA”) (Chemical Abstracts Service No. 375–85–9);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances for which a method to measure levels in drinking water has been validated by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perfluoroalkyl and polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances other than the chemicals described in subparagraphs (A) through (N) that is used to manufacture fluorinated polymers, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addition to toxics release inventory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), if the Administrator determines under paragraph (1) that a substance or a class of substances described in paragraph (2) meets any one of the criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/d/2"},"text":"section 11023(d)(2) of title 42","children":[],"tail":", the Administrator shall revise the toxics release inventory in accordance with such "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023/d"},"text":"section 11023(d) of title 42","children":[],"tail":" to include that substance or class of substances not later than 2 years after the date on which the Administrator makes the determination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912f04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential business information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to including on the toxics release inventory pursuant to subsection (b)(1), (c)(1), or (d)(3) any perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances the chemical identity of which is subject to a claim of a person of protection from disclosure under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", pursuant to subsection (b)(4) of that section, the Administrator shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review any such claim of protection from disclosure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that person to reassert and substantiate or resubstantiate that claim in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2613/f"},"text":"section 2613(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8921/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of protection information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator determines that the chemical identity of a perfluoroalkyl or polyfluoroalkyl substance or class of perfluoroalkyl or polyfluoroalkyl substances qualifies for protection from disclosure pursuant to paragraph (1), the Administrator shall include the substance or class of substances, as applicable, on the toxics release inventory in a manner that does not disclose the protected information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912f09-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7321"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2277"},"text":"133 Stat. 2277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a912f0a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a912f0b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a912f0c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s7321"},"text":"section 7321 of Pub. L. 116–92","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s7321"},"text":"section 7321 of Pub. L. 116–92","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11023"},"text":"section 11023 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
