{"tag":"section","attrib":{"id":"id79541ac5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1025"},"text":null,"children":[{"tag":"num","attrib":{"value":"1025"},"text":"§ 1025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing of monthly publication by Joint Economic Committee entitled “Economic Indicators”; distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Joint Economic Committee is authorized to issue a monthly publication entitled “Economic Indicators”, and a sufficient quantity shall be printed to furnish one copy to each Member of Congress; the Secretary and the Sergeant at Arms of the Senate; the Clerk, Sergeant at Arms, and Chief Administrative Officer of the House of Representatives; two copies to the libraries of the Senate and House, and the Congressional Library; seven hundred copies to the Joint Economic Committee; and the required number of copies to the Superintendent of Documents for distribution to depository libraries; and the Superintendent of Documents is authorized to have copies printed for sale to the public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79541ac6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-23/ch237"},"text":"June 23, 1949, ch. 237","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/264"},"text":"63 Stat. 264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s217"},"text":"Pub. L. 104–186, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1747"},"text":"110 Stat. 1747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79541ac7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79541ac8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79541ac9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of the Employment Act of 1946 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Joint Economic Committee” substituted in text for “Joint Committee on the Economic Report” to conform to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-18/ch399/s2"},"text":"act June 18, 1956, ch. 399, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/290"},"text":"70 Stat. 290","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1024/a"},"text":"section 1024(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79541aca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Doorkeeper”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
