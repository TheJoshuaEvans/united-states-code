{"tag":"section","attrib":{"id":"id7a7bd1f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610"},"text":null,"children":[{"tag":"num","attrib":{"value":"7610"},"text":"§ 7610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd1f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contact lens fitting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “contact lens fitting” means the process that begins after the initial eye examination and ends when a successful fit has been achieved or, in the case of a renewal prescription, ends when the prescriber determines that no change in prescription is required, and such term may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7bd1f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination to determine lens specifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd1f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in the case of a renewal of a prescription, an initial evaluation of the fit of the lens on the eye; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd1fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medically necessary follow up examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescriber","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prescriber” means, with respect to contact lens prescriptions, an ophthalmologist, optometrist, or other person permitted under State law to issue prescriptions for contact lenses in compliance with any applicable requirements established by the Food and Drug Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contact lens prescription","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “contact lens prescription” means a prescription, issued in accordance with State and Federal law, that contains sufficient information for the complete and accurate filling of a prescription, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7bd1fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Name of the patient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd1fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Date of examination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd1ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issue date and expiration date of prescription.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd200-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Name, postal address, telephone number, and facsimile telephone number of prescriber.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd201-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Power, material or manufacturer or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd202-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Base curve or appropriate designation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd203-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Diameter, when appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd204-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7610/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a private label contact lens, name of manufacturer, trade name of private label brand, and, if applicable, trade name of equivalent brand name.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7bd205-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s11"},"text":"Pub. L. 108–164, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2027"},"text":"117 Stat. 2027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd206-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a7bd207-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a7bd208-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/164/s12"},"text":"section 12 of Pub. L. 108–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7601"},"text":"section 7601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
