{"tag":"section","attrib":{"id":"id79d7544c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070"},"text":null,"children":[{"tag":"num","attrib":{"value":"2070"},"text":"§ 2070.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d7544d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2068"},"text":"section 2068 of this title","children":[],"tail":" is punishable by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d7544e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for not more than 5 years for a knowing and willful violation of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7544f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fine determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3571"},"text":"section 3571 of title 18","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75450-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d75451-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual director, officer, or agent of a corporation who knowingly and willfully authorizes, orders, or performs any of the acts or practices constituting in whole or in part a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2068"},"text":"section 2068 of this title","children":[],"tail":" shall be subject to penalties under this section without regard to any penalties to which that corporation may be subject under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d75452-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d75453-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the penalties provided by subsection (a), the penalty for a criminal violation of this chapter or any other Act enforced by the Commission may include the forfeiture of assets associated with the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75454-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2070/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “criminal violation” means a violation of this chapter or any other Act enforced by the Commission for which the violator is sentenced to pay a fine, be imprisoned, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d75455-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s21"},"text":"Pub. L. 