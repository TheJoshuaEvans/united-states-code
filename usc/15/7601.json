{"tag":"section","attrib":{"id":"id7a79619a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601"},"text":null,"children":[{"tag":"num","attrib":{"value":"7601"},"text":"§ 7601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of contact lens prescriptions to patients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a79619b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a prescriber completes a contact lens fitting, the prescriber—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a79619c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not requested by the patient, shall provide to the patient a copy of the contact lens prescription; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd19d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, as directed by any person designated to act on behalf of the patient, provide or verify the contact lens prescription by electronic or other means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd19e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A prescriber may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd19f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require purchase of contact lenses from the prescriber or from another person as a condition of providing a copy of a prescription under subsection (a)(1) or (a)(2) or verification of a prescription under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require payment in addition to, or as part of, the fee for an eye examination, fitting, and evaluation as a condition of providing a copy of a prescription under subsection (a)(1) or (a)(2) or verification of a prescription under subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the patient to sign a waiver or release as a condition of verifying or releasing a prescription.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7bd1a2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s2"},"text":"Pub. L. 108–164, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2024"},"text":"117 Stat. 2024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd1a3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a7bd1a4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a7bd1a5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s12"},"text":"Pub. L. 108–164, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2028"},"text":"117 Stat. 2028","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/164/s12"},"text":"“This Act [enacting this chapter and provisions set out as a note below] shall take effect 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a7bd1a6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s1"},"text":"Pub. L. 108–164, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2024"},"text":"117 Stat. 2024","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/164/s1"},"text":"“This Act [enacting this chapter and provisions set out as a note above] may be cited as the ‘Fairness to Contact Lens Consumers Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
