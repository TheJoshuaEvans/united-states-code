{"tag":"section","attrib":{"id":"id7a68bf49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002"},"text":null,"children":[{"tag":"num","attrib":{"value":"7002"},"text":"§ 7002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption to preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a68bf4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State statute, regulation, or other rule of law may modify, limit, or supersede the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":" with respect to State law only if such statute, regulation, or rule of law—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bf4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitutes an enactment or adoption of the Uniform Electronic Transactions Act as approved and recommended for enactment in all the States by the National Conference of Commissioners on Uniform State Laws in 1999, except that any exception to the scope of such Act enacted by a State under section 3(b)(4) of such Act shall be preempted to the extent such exception is inconsistent with this subchapter or subchapter II, or would not be permitted under paragraph (2)(A)(ii) of this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bf4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68bf4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specifies the alternative procedures or requirements for the use or acceptance (or both) of electronic records or electronic signatures to establish the legal effect, validity, or enforceability of contracts or other records, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a68bf4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such alternative procedures or requirements are consistent with this subchapter and subchapter II; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a68bf4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such alternative procedures or requirements do not require, or accord greater legal status or effect to, the implementation or application of a specific technology or technical specification for performing the functions of creating, storing, generating, receiving, communicating, or authenticating electronic records or electronic signatures; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bf50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if enacted or adopted after ","children":[{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", makes specific reference to this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bf51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions for actions by States as market participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a)(2)(A)(ii) shall not apply to the statutes, regulations, or other rules of law governing procurement by any State, or any agency or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bf52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of circumvention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) does not permit a State to circumvent this subchapter or subchapter II through the imposition of nonelectronic delivery methods under section 8(b)(2) of the Uniform Electronic Transactions Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bf53-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/229/tI/s102"},"text":"Pub. L. 106–229, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/467"},"text":"114 Stat. 467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a68bf54-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a68bf55-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a68bf56-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"Oct. 1, 2000","children":[],"tail":", with exceptions relating to record retention and certain loans, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/229/s107"},"text":"section 107 of Pub. L. 106–229","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
