{"tag":"section","attrib":{"id":"id7a1c731a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3394"},"text":null,"children":[{"tag":"num","attrib":{"value":"3394"},"text":"§ 3394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on revoking or amending certain pre-1969 certificates of public convenience and necessity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1c731b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3394/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may not, during the 10-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":", revoke or amend any certificate of public convenience and necessity issued before "},{"tag":"date","attrib":{"date":"1969-01-01"},"text":"January 1, 1969","children":[],"tail":", under section 7 of the Natural Gas Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717f"},"text":"15 U.S.C. 717f","children":[],"tail":"] for the transportation of natural gas owned by any electric utility except upon the application of the person to whom such certificate was issued."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c731c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3394/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission curtailment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation under subsection (a) shall not affect the authority of the Commission to enforce any curtailment of deliveries of natural gas under the Natural Gas Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s717"},"text":"15 U.S.C. 717","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c731d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tIV/s404"},"text":"Pub. L. 95–621, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3396"},"text":"92 Stat. 3396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1c731e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1c731f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1c7320-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Natural Gas Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556"},"text":"act June 21, 1938, ch. 556","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/821"},"text":"52 Stat. 821","children":[],"tail":", which is classified generally to chapter 15B (§ 717 et seq.) of this title. For complete classification of this act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717w"},"text":"section 717w of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
