{"tag":"section","attrib":{"id":"id7a6192e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712"},"text":null,"children":[{"tag":"num","attrib":{"value":"6712"},"text":"§ 6712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance underwriting in national banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6192e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6713"},"text":"section 6713 of this title","children":[],"tail":", a national bank and the subsidiaries of a national bank may not provide insurance in a State as principal except that this prohibition shall not apply to authorized products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6192e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, a product is authorized if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6192e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", the Comptroller of the Currency had determined in writing that national banks may provide such product as principal, or national banks were in fact lawfully providing such product as principal;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6192e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no court of relevant jurisdiction had, by final judgment, overturned a determination of the Comptroller of the Currency that national banks may provide such product as principal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6192e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product is not title insurance, or an annuity contract the income of which is subject to tax treatment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6192e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “insurance” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6192ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any product regulated as insurance as of ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", in accordance with the relevant State insurance law, in the State in which the product is provided;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6192eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any product first offered after ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6192ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State insurance regulator determines shall be regulated as insurance in the State in which the product is provided because the product insures, guarantees, or indemnifies against liability, loss of life, loss of health, or loss through damage to or destruction of property, including, but not limited to, surety bonds, life insurance, health insurance, title insurance, and property and casualty insurance (such as private passenger or commercial automobile, homeowners, mortgage, commercial multiperil, general liability, professional liability, workers’ compensation, fire and allied lines, farm owners multiperil, aircraft, fidelity, surety, medical malpractice, ocean marine, inland marine, and boiler and machinery insurance); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6192ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not a product or service of a bank that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6192ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a deposit product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6192ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan, discount, letter of credit, or other extension of credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6192f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust or other fiduciary service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6192f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified financial contract (as defined in or determined pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1821/e/8/D/i"},"text":"section 1821(e)(8)(D)(i) of title 12","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6192f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a financial guaranty, except that this subparagraph (B) shall not apply to a product that includes an insurance component such that if the product is offered or proposed to be offered by the bank as principal—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a6192f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it would be treated as a life insurance contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7702"},"text":"section 7702 of title 26","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a6192f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/2/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event that the product is not a letter of credit or other similar extension of credit, a qualified financial contract, or a financial guaranty, it would qualify for treatment for losses incurred with respect to such product under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s832/b/5"},"text":"section 832(b)(5) of title 26","children":[],"tail":", if the bank were subject to tax as an insurance company under section 831 of that title; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6192f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any annuity contract, the income on which is subject to tax treatment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s72"},"text":"section 72 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6192f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, providing insurance (including reinsurance) outside the United States that insures, guarantees, or indemnifies insurance products provided in a State, or that indemnifies an insurance company with regard to insurance products provided in a State, shall be considered to be providing insurance as principal in that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6192f7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s302"},"text":"Pub. L. 106–102, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1407"},"text":"113 Stat. 1407","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
