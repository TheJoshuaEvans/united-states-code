{"tag":"section","attrib":{"id":"id7a808c5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8101"},"text":null,"children":[{"tag":"num","attrib":{"value":"8101"},"text":"§ 8101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this Act, the term “United States person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808c5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any United States resident or national,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any domestic concern (including any permanent domestic establishment of any foreign concern), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign subsidiary or affiliate (including any permanent foreign establishment) of any domestic concern that is controlled in fact by such domestic concern,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that such term does not include an individual who resides outside the United States and is employed by an individual or entity other than an individual or entity described in paragraph (1), (2), or (3).","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a808c61-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s3"},"text":"Pub. L. 110–403, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4257"},"text":"122 Stat. 4257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a808c62-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a808c63-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a808c64-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403"},"text":"Pub. L. 110–403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4256"},"text":"122 Stat. 4256","children":[],"tail":", known as the Prioritizing Resources and Organization for Intellectual Property Act of 2008, which enacted this chapter and enacted, amended, and repealed numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a808c65-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a808c66-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/s1/a"},"text":"Pub. L. 110–403, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4256"},"text":"122 Stat. 4256","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/403/s1/a"},"text":"“This Act [enacting this chapter, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2323"},"text":"section 2323 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and sections 3713a to 3713d of Title 42, The Public Health and Welfare, amending sections 1116 and 1117 of this title, sections 109, 111, 115, 119, 122, 411, 412, 503, 506, 601, and 602 of Title 17, Copyrights, sections 1834 and 2318 to 2320 of Title 18, "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1595a"},"text":"section 1595a of Title 19","children":[],"tail":", Customs Duties, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3713"},"text":"section 3713 of Title 42","children":[],"tail":", and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1128"},"text":"section 1128 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s509"},"text":"section 509 of Title 17","children":[],"tail":"] may be cited as the ‘Prioritizing Resources and Organization for Intellectual Property Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
