{"tag":"section","attrib":{"id":"id796271b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1119"},"text":null,"children":[{"tag":"num","attrib":{"value":"1119"},"text":"§ 1119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of court over registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In any action involving a registered mark the court may determine the right to registration, order the cancelation of registrations, in whole or in part, restore canceled registrations, and otherwise rectify the register with respect to the registrations of any party to the action. Decrees and orders shall be certified by the court to the Director, who shall make appropriate entry upon the records of the Patent and Trademark Office, and shall be controlled thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796271b7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title VI, § 37, "},{"tag":"ref","attrib":{"href":"/us/stat/60/440"},"text":"60 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–583.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796271b8