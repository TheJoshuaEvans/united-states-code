{"tag":"section","attrib":{"id":"id7a6b0908-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7105"},"text":null,"children":[{"tag":"num","attrib":{"value":"7105"},"text":"§ 7105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the National Women’s Business Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established a council to be known as the National Women’s Business Council, which shall serve as an independent source of advice and policy recommendations to the Interagency Committee, to the Administrator through the Assistant Administrator of the Office of Women’s Business Ownership, to the Congress, and to the President.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a6b0909-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/tIV/s405"},"text":"Pub. L. 100–533, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tIV/s413"},"text":"Pub. L. 103–403, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4195"},"text":"108 Stat. 4195","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6b090a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6b090b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a6b090c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","att