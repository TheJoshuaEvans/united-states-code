{"tag":"section","attrib":{"id":"id7a796190-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7509"},"text":null,"children":[{"tag":"num","attrib":{"value":"7509"},"text":"§ 7509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a796191-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7509/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Panel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Advisory Panel” means the President’s National Nanotechnology Advisory Panel established or designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7503"},"text":"section 7503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796192-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7509/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nanotechnology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nanotechnology” means the science and technology that will enable one to understand, measure, manipulate, and manufacture at the atomic, molecular, and supramolecular levels, aimed at creating materials, devices, and systems with fundamentally new molecular organization, properties, and functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796193-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7509/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the National Nanotechnology Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7501"},"text":"section 7501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796194-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7509/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the National Science and Technology Council or an appropriate subgroup designated by the Council under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7501/c"},"text":"section 7501(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796195-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7509/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced technology user facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced technology user facility” means a nanotechnology research and development facility supported, in whole or in part, by Federal funds that is open to all United States researchers on a competitive, merit-reviewed basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796196-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7509/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program component area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program component area” means a major subject area established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7501/c/2"},"text":"section 7501(c)(2) of this title","children":[],"tail":" under which is "},{"tag":"ref","attrib":{"idref":"fn002580"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002580"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “are”."}],"tail":" grouped related individual projects and activities carried out under the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a796197-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/153/s10"},"text":"Pub. L. 108–153, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1931"},"text":"117 Stat. 1931","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
