{"tag":"section","attrib":{"id":"id7a533ac1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6002"},"text":null,"children":[{"tag":"num","attrib":{"value":"6002"},"text":"§ 6002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes for grants","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A grant made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6001"},"text":"section 6001 of this title","children":[],"tail":" may be used by a grantee to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533ac2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce a law that requires individuals under the age of 16 to wear approved bicycle helmets on their heads while riding on bicycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ac3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance, to individuals under the age of 16 who may not be able to afford approved bicycle helmets, to enable such individuals to acquire such helmets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ac4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and administer a program to educate individuals under the age of 16 and their families on the importance of wearing such helmets in order to improve bicycle safety; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ac5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any combination of the activities described in paragraphs (1), (2), and (3).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Administrator shall review grant applications for compliance with this section prior to awarding grants.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a533ac6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/267/tII/s203"},"text":"Pub. L. 103–267, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/727"},"text":"108 Stat. 727","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
