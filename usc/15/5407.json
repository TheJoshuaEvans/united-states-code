{"tag":"section","attrib":{"id":"id7a4c0f4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5407"},"text":null,"children":[{"tag":"num","attrib":{"value":"5407"},"text":"§ 5407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturers’ insignias","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4c0f4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the specifications provide otherwise, fasteners that are required by the applicable consensus standard or standards to bear an insignia identifying their manufacturer shall not be offered for sale or sold in commerce unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4c0f4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fasteners bear such insignia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer has complied with the insignia recordation requirements established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0f4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, by regulation, a program to provide for the recordation of the insignias of manufacturers described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4c0f50-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s5"},"text":"Pub. L. 101–592, § 5","children":[],"tail":", formerly § 8, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2950"},"text":"104 Stat. 2950","children":[],"tail":"; renumbered § 5 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/34/s5"},"text":"Pub. L. 106–34, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/122"},"text":"113 Stat. 122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4c0f51-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4c0f52-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a4c0f53-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s5"},"text":"section 5 of Pub. L. 101–592","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5404"},"text":"section 5404 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/34"},"text":"Pub. L. 106–34","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a4c0f54-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/34/s5/1"},"text":"Pub. L. 106–34, § 5(1)","children":[],"tail":", reenacted subsec. heading without change and amended text generally. Prior to amendment, text read as follows: “No fastener which is required by the standards and specifications to which it was manufactured to bear a raised or depressed insignia identifying its manufacturer or private label distributor shall be offered for sale or sold in commerce unless the manufacturer or private label distributor of such fastener has complied with the requirements prescribed by the Secretary in connection with the program established under subsection (b) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/34/s5/2"},"text":"Pub. L. 106–34, § 5(2)","children":[],"tail":", substituted “described in subsection (a)” for “and private label distributors described in subsection (a), to ensure the traceability of a fastener to its manufacturer or private label distributor”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
