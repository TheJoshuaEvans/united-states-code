{"tag":"section","attrib":{"id":"id78c03f37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634e"},"text":null,"children":[{"tag":"num","attrib":{"value":"634e"},"text":"§ 634e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of Government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each department, agency, and instrumentality of the Federal Government is authorized and directed to furnish to the Chief Counsel for Advocacy such reports and other information as he deems necessary to carry out his functions under sections 634a to 634g of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78c03f38-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305/tII/s205"},"text":"Pub. L. 94–305, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/670"},"text":"90 Stat. 670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c03f39-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c03f3a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c03f3b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
