{"tag":"section","attrib":{"id":"id7a8ee45c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802"},"text":null,"children":[{"tag":"num","attrib":{"value":"8802"},"text":"§ 8802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to ensure the continued leadership of the United States in quantum information science and its technology applications by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee45d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supporting research, development, demonstration, and application of quantum information science and technology—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8ee45e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand the number of researchers, educators, and students with training in quantum information science and technology to develop a workforce pipeline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee45f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the development and inclusion of multidisciplinary curriculum and research opportunities for quantum information science at the undergraduate, graduate, and postdoctoral level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee460-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address basic research knowledge gaps, including computational research gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee461-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the further development of facilities and centers available for quantum information science and technology research, testing and education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee462-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate research on and promote more rapid development of quantum-based technologies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee463-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the interagency planning and coordination of Federal research and development of quantum information science and technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee464-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the effectiveness of the Federal Government’s quantum information science and technology research, development, and demonstration programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee465-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting collaboration among the Federal Government, Federal laboratories, industry, and universities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee466-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promoting the development of international standards for quantum information science and technology security—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8ee467-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate technology innovation and private sector commercialization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee468-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8802/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet economic and national security goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee469-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/s3"},"text":"Pub. L. 115–368, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5093"},"text":"132 Stat. 5093","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
