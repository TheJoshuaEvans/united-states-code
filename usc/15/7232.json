{"tag":"section","attrib":{"id":"id7a6feb5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7232"},"text":null,"children":[{"tag":"num","attrib":{"value":"7232"},"text":"§ 7232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of mandatory rotation of registered public accounting firms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6feb5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and review required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall conduct a study and review of the potential effects of requiring the mandatory rotation of registered public accounting firms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6feb5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", the Comptroller General shall submit a report to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives on the results of the study and review required by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6feb5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7232/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “mandatory rotation” refers to the imposition of a limit on the period of years in which a particular registered public accounting firm may be the auditor of record for a particular issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6feb5f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tII/s207"},"text":"Pub. L. 107–204, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/775"},"text":"116 Stat. 775","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
