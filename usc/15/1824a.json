{"tag":"section","attrib":{"id":"id79c44136-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1824a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1824a"},"text":"§ 1824a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export of horses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c44137-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1824a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on export of horses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no horse may be exported by sea from the United States, or any of its territories or possessions, unless such horse is part of a consignment of horses with respect to which a waiver has been granted under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c44138-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1824a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Granting of waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, in consultation with the Secretary of Agriculture, may issue regulations providing for the granting of waivers permitting the export by sea of a specified consignment of horses, if the Secretary of Commerce, in consultation with the Secretary of Agriculture, determines that no horse in that consignment is being exported for purposes of slaughter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c44139-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1824a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c4413a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1824a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly violates this section or any regulation, order, or license issued under this section shall be fined not more than 5 times the value of the consignment of horses involved or $50,000, whichever is greater, or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c4413b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1824a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, after providing notice and an opportunity for an agency hearing on the record, may impose a civil penalty of not to exceed $10,000 for each violation of this section or any regulation, order, or license issued under this section, either in addition to or in lieu of any other liability or penalty which may be imposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c4413c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch521/s3"},"text":"Mar. 3, 1891, ch. 521, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/64/tI/s125"},"text":"Pub. L. 99–64, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-07-12"},"text":"July 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/156"},"text":"99 Stat. 156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c4413d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c4413e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79c4413f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Horse Protection Act of 1970 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 466c of the former Appendix to Title 46, prior to the completion of the enactment of Title 46, Shipping, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1485"},"text":"120 Stat. 1485","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79c44140-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72/s7/j"},"text":"section 7(j) of Pub. L. 96–72","children":[],"tail":", formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4606/j"},"text":"section 4606(j) of Title 50","children":[],"tail":", War and National Defense, prior to the amendment of section 7(j) of that Act by "},{"tag":"ref","attrib":{"href":"/us/pl/99/64"},"text":"Pub. L. 99–64","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
