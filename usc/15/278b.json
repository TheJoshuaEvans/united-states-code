7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “Institute” for “National Bureau of Standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/73"},"text":"Pub. L. 99–73","children":[],"tail":" struck out “first” after “may be applied”, and inserted provisions relating to working capital for replacement of equipment and inventories."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/322"},"text":"Pub. L. 95–322","children":[],"tail":" struck out “, and additional amounts as from time to time may be required for the purposes of said fund are authorized to be appropriated” after “("},{"tag":"ref","attrib":{"href":"/us/stat/64/275"},"text":"64 Stat. 275","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788e3298-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id788e3299-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/73"},"text":"Pub. L. 99–73","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/73/s5/c"},"text":"section 5(c) of Pub. L. 99–73","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s275c"},"text":"section 275c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
