{"tag":"section","attrib":{"id":"id788e328b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278b"},"text":null,"children":[{"tag":"num","attrib":{"value":"278b"},"text":"§ 278b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working Capital Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id788e328c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute is authorized to utilize in the performance of its functions the Working Capital Fund established by the Act of ","children":[{"tag":"date","attrib":{"date":"1950-06-29"},"text":"June 29, 1950","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/64/275"},"text":"64 Stat. 275","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e328d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The working capital of the fund shall be available for obligation and payment for any activities authorized by this chapter, and for any activities for which provision is made in the appropriations which reimburse the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e328e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the performance of authorized activities, the Working Capital Fund shall be available and may be reimbursed for expenses of hire of automobile, hire of consultants, and travel to meetings, to the extent that such expenses are authorized for the appropriations of the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e328f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fund may be credited with advances and reimbursements, including receipts from non-Federal sources, for services performed under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s273"},"text":"section 273 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e3290-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Cost” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “cost” shall be construed to include directly related expenses and appropriate charges for indirect and administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id788e3291-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of earnings; restoration of prior impairment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any earned net income resulting from the operation of the fund at the close of each fiscal year shall be paid into the general fund of the Treasury: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such earned net income may be applied to restore any prior impairment of the fund, and to ensure the availability of working capital necessary to replace equipment and inventories."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788e3292-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s12"},"text":"Mar. 3, 1901, ch. 872, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch906/s2"},"text":"Aug. 3, 1956, ch. 906, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/959"},"text":"70 Stat. 959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/322/s2/a"},"text":"Pub. L. 95–322, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-07-21"},"text":"July 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/395"},"text":"92 Stat. 395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/73/s5/a"},"text":"Pub. L. 99–73, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-07-29"},"text":"July 29, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/172"},"text":"99 Stat. 172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/a/1"},"text":"Pub. L. 100–418, title V, § 5115(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","child