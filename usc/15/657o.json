{"tag":"section","attrib":{"id":"id791d52a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657o"},"text":null,"children":[{"tag":"num","attrib":{"value":"657o"},"text":"§ 657o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports on disaster assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after the end of a fiscal year, the Administrator shall submit to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives a report on the disaster assistance operations of the Administration for that fiscal year. The report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d52a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657o/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the number of Administration personnel involved in such operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657o/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe any material changes to those operations, such as changes to technologies used or to personnel responsibilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657o/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe and assess the effectiveness of the Administration in responding to disasters during that fiscal year, including a description of the number and amounts of loans made for damage and for economic injury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657o/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the plans of the Administration for preparing to respond to disasters during the next fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d52a5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s43"},"text":"Pub. L. 85–536, § 2[43]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12091/g"},"text":"Pub. L. 110–234, title XII, § 12091(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1426"},"text":"122 Stat. 1426","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12091(g), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2188.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791d52a6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id791d52a7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id791d52a8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href"