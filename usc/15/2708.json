{"tag":"section","attrib":{"id":"id7a0baace-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2708"},"text":null,"children":[{"tag":"num","attrib":{"value":"2708"},"text":"§ 2708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General audit and examination of books, etc.; statutory provisions applicable; contracts or grants covered","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5876"},"text":"Section 5876 of title 42","children":[],"tail":" shall apply with respect to the authority of the Comptroller General to have access to and rights of examination of books, documents, papers, and records of recipients of financial assistance under this chapter; except that for the purposes of this chapter, the term “contract” (as used in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2206"},"text":"section 2206 of title 42","children":[],"tail":", insofar as it relates to such "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5876"},"text":"section 5876 of title 42","children":[],"tail":") means “contract or grant”."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a0baacf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/238/tIII/s309"},"text":"Pub. L. 95–238, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-25"},"text":"Feb. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/82"},"text":"92 Stat. 82","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
