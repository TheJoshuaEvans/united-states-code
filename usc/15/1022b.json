{"tag":"section","attrib":{"id":"id79541a4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1022b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1022b"},"text":"§ 1022b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of analysis respecting short-term and medium-term goals in Economic Report of President; mutually reinforcing means","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79541a50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1022b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis of goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To aid in determining the short-term and medium-term goals for employment, production, real income, and prices, analysis shall be presented in the Economic Report with respect to major aspects of the appropriate composition or structure of each goal, and as to the appropriate apportionment of total national production among its major components (private investment, consumer expenditures, and public outlays) as affected by relative income flows and other factors, in order to promote balanced growth and a balanced Federal budget, reduce cyclical disturbances, and achieve the other purposes of this chapter and the Full Employment and Balanced Growth Act of 1978 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3101"},"text":"15 U.S.C. 3101","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79541a51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1022b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means to achieve goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In choosing means to achieve the goal for the reduction of unemployment and choosing means to achieve the goal of reasonable price stability, those means which are mutually reinforcing shall be used to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79541a52-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-02-20/ch33/s5"},"text":"Feb. 20, 1946, ch. 33, § 5","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/523/tI/s105"},"text":"Pub. L. 95–523, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1895"},"text":"92 Stat. 1895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79541a53-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79541a54-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79541a55-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Full Employment and Balanced Growth Act of 1978, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/523"},"text":"Pub. L. 95–523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1887"},"text":"92 Stat. 1887","children":[],"tail":", which is classified principally to chapter 58 (§ 3101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79541a56-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5 of act ","children":[{"tag":"date","attrib":{"date":"1946-02-20"},"text":"Feb. 20, 1946","children":[],"tail":", was renumbered section 11 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1024"},"text":"section 1024 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
