{"tag":"section","attrib":{"id":"id7aa44109-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060"},"text":null,"children":[{"tag":"num","attrib":{"value":"9060"},"text":"§ 9060.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa4410a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of transactions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 72 hours after any transaction by the Secretary under paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":", the Secretary shall publish on the website of the Department of the Treasury—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa4410b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plain-language description of the transaction, including the date of application, date of application approval, and identity of the counterparty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4410c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the loan or loan guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4410d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest rate, conditions, and any other material or financial terms associated with the transaction, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4410e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the relevant and final term sheet, if applicable, and contract or other relevant documentation regarding the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa4410f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44110-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa44111-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to such reports as are required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302/c"},"text":"section 5302(c) of title 31","children":[],"tail":", not later than 7 days after the Secretary makes any loan or loan guarantee under paragraph (1), (2), or (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":", the Secretary shall submit to the Chairmen and Ranking Members of the Committee on Banking, Housing, and Urban Affairs and the Committee on Finance of the Senate and the Chairmen and Ranking Members of the Committee on Financial Services and the Committee on Ways and Means of the House of Representatives a report summarizing—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7aa44112-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of actions taken by the Secretary under paragraph (1), (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":" during such period;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa44113-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual obligation, expenditure, and disbursements of the funds during such period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa44114-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed financial statement with respect to the exercise of authority under paragraph (1), (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":" showing—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id7aa44115-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all loans and loan guarantees made, renewed, or restructured;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa44116-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all transactions during such period, including the types of parties involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa44117-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the assets purchased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa44118-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the vehicles established to exercise such authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aa44119-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/A/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any or all repayment activity, delinquencies or defaults on loans and loan guarantees issued under paragraph (1), (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa4411a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 days after the date on which the Secretary submits a report under subparagraph (A) to the committees of Congress described in such subparagraph, the Secretary shall publish such report on the website of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa4411b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 30-day reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every 30 days during such time as a loan or loan guarantee under paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":" is outstanding, the Secretary shall publish on the website of the Department of the Treasury a report summarizing the information set forth in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4411c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Governors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa4411d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any program or facility described in paragraph (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":", the Board of Governors of the Federal Reserve System shall provide to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives such reports as are required to be provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3"},"text":"section 343(3) of title 12","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7aa4411e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 7 days after the Board authorizes a new facility or other financial assistance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3/C/i"},"text":"section 343(3)(C)(i) of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa4411f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" once every 30 days with respect to outstanding loans or financial assistance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3/C/ii"},"text":"section 343(3)(C)(ii) of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa44120-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 7 days after the Board of Governors of the Federal Reserve System submits a report under subparagraph (A) to the committees of Congress described in subparagraph (A), the Board shall publish on its website such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44121-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Chairman of the Board of Governors of the Federal Reserve System shall testify, on a semiannual basis, before the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives regarding the obligations of the Department of the Treasury and the Federal Reserve System, and transactions entered into, under this Act. This subsection shall have no force or effect after ","children":[{"tag":"date","attrib":{"date":"2027-12-31"},"text":"December 31, 2027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44122-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program descriptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall post on the website of the Department of the Treasury all criteria, guidelines, eligibility requirements, and application materials for the making of any loan or loan guarantee under paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44123-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 hours after the Secretary enters into a contract in connection with the administration of any loan or loan guarantee authorized to be made under paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":", the Secretary shall post on the website of the Department of the Treasury a copy of the contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44124-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44125-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall conduct a study on the loans, loan guarantees, and other investments provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042"},"text":"section 9042 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44126-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9060/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 9 months after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and annually thereafter through the year succeeding the last year for which loans, loan guarantees, or other investments made under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042"},"text":"section 9042 of this title","children":[],"tail":" are outstanding, the Comptroller General shall submit to the Committee on Financial Services, the Committee on Transportation and Infrastructure, the Committee on Appropriations, and the Committee on the Budget of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs, the Committee on Commerce, Science, and Transportation, the Committee on Appropriations, and the Committee on the Budget of the Senate a report on the loans, loan guarantees, and other investments made under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042"},"text":"section 9042 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa44127-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4026"},"text":"Pub. L. 116–136, div. A, title IV, § 4026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/494"},"text":"134 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dHH/tIII/s301"},"text":"Pub. L. 117–103, div. HH, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1113"},"text":"136 Stat. 1113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa44128-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa44129-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7aa4412a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c), probably means subtitle A (§§ 4001–4029) of title IV of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", known as the Coronavirus Economic Stabilization Act of 2020, which is classified principally to this part. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4001"},"text":"section 4001 of Pub. L. 116–136","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7aa4412b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" substituted “semiannual” for “quarterly” and inserted at end “This subsection shall have no force or effect after "},{"tag":"date","attrib":{"date":"2027-12-31"},"text":"December 31, 2027","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
