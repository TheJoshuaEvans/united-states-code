{"tag":"section","attrib":{"id":"id7a7960b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463"},"text":null,"children":[{"tag":"num","attrib":{"value":"7463"},"text":"§ 7463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cloud computing strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7960b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in coordination with the Office of Management and Budget, in collaboration with the Federal Chief Information Officers Council, and in consultation with other relevant Federal agencies and stakeholders from the private sector, shall continue to develop and encourage the implementation of a comprehensive strategy for the use and adoption of cloud computing services by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7960ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the strategy described under subsection (a), the Director shall give consideration to activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7960bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate the development, in collaboration with the private sector, of standards that address interoperability and portability of cloud computing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7960bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the development of conformance testing performed by the private sector in support of cloud computing standardization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7960bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support, in coordination with the Office of Management and Budget, and in consultation with the private sector, the development of appropriate security frameworks and reference materials, and the identification of best practices, for use by Federal agencies to address security and privacy requirements to enable the use and adoption of cloud computing services, including activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7960be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the physical security of cloud computing data centers and the data stored in such centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7960bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure secure access to the data stored in cloud computing data centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7960c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop security standards as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"section 278g–3 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7960c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7463/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the development of the automation of continuous monitoring systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7960c2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/274/tV/s503"},"text":"Pub. L. 113–274, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2986"},"text":"128 Stat. 2986","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
