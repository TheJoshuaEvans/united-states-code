{"tag":"section","attrib":{"id":"id7a55abab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6201"},"text":null,"children":[{"tag":"num","attrib":{"value":"6201"},"text":"§ 6201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to foreign antitrust authority of antitrust evidence","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In accordance with an antitrust mutual assistance agreement in effect under this chapter, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6207"},"text":"section 6207 of this title","children":[],"tail":", and except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6204"},"text":"section 6204 of this title","children":[],"tail":", the Attorney General of the United States and the Federal Trade Commission may provide to a foreign antitrust authority with respect to which such agreement is in effect under this chapter, antitrust evidence to assist the foreign antitrust authority—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55abac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining whether a person has violated or is about to violate any of the foreign antitrust laws administered or enforced by the foreign antitrust authority, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55abad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in enforcing any of such foreign antitrust laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a55abae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/438/s2"},"text":"Pub. L. 103–438, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4597"},"text":"108 Stat. 4597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a55abaf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a55abb0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a55abb1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/438"},"text":"Pub. L. 103–438","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4597"},"text":"108 Stat. 4597","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55abb2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a55abb3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/438/s1"},"text":"Pub. L. 103–438, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4597"},"text":"108 Stat. 4597","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/438/s1"},"text":"“This Act [enacting this chapter and amending sections 46, 57b–1, 1311, and 1312 of this title] may be cited as the ‘International Antitrust Enforcement Assistance Act of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
