{"tag":"section","attrib":{"id":"id77e4d318-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77m"},"text":null,"children":[{"tag":"num","attrib":{"value":"77m"},"text":"§ 77m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No action shall be maintained to enforce any liability created under section 77k or 77","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a)(2) of this title unless brought within one year after the discovery of the untrue statement or the omission, or after such discovery should have been made by the exercise of reasonable diligence, or, if the action is to enforce a liability created under section 77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a)(1) of this title, unless brought within one year after the violation upon which it is based. In no event shall any such action be brought to enforce a liability created under section 77k or 77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a)(1) of this title more than three years after the security was bona fide offered to the public, or under section 77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a)(2) of this title more than three years after the sale."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77e4d319-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 13, "},{"tag":"ref","attrib":{"href":"/us/stat/48/84"},"text":"48 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title II, § 207, "},{"tag":"ref","attrib":{"href":"/us/stat/48/908"},"text":"48 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/353/tIII/s301/a/3"},"text":"Pub. L. 105–353, title III, § 301(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3235"},"text":"112 Stat. 3235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e4d31a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e4d31b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e4d31c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353"},"text":"Pub. L. 105–353","children":[],"tail":" substituted “77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a)(2)” for “77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(2)” in two places and “77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a)(1)” for “77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(1)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1934—Act ","children":[{"tag":"date","attrib":{"date":"1934-06-06"},"text":"June 6, 1934","children":[],"tail":", substituted “one year” for “two years”, “three years” for “ten years”, and inserted “or under section 77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(2) of this title more than three years after the sale”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
