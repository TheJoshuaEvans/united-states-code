{"tag":"section","attrib":{"id":"id798d5252-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616"},"text":null,"children":[{"tag":"num","attrib":{"value":"1616"},"text":"§ 1616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board review of consumer credit plans and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798d5253-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the effective date of this Act and every 2 years thereafter, except as provided in subsection (c)(2), the Board shall conduct a review, within the limits of its existing resources available for reporting purposes, of the consumer credit card market, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798d5254-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of credit card agreements and the practices of credit card issuers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5255-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of disclosure of terms, fees, and other expenses of credit card plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5256-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of protections against unfair or deceptive acts or practices relating to credit card plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5257-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether or not, and to what extent, the implementation of this Act and the amendments made by this Act has affected—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798d5258-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost and availability of credit, particularly with respect to non-prime borrowers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798d5259-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety and soundness of credit card issuers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798d525a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of risk-based pricing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798d525b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit card product innovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798d525c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with conducting the review required by subsection (a), the Board shall solicit comment from consumers, credit card issuers, and other interested parties, such as through hearings or written comments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798d525d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798d525e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following the review required by subsection (a), the Board shall publish a notice in the Federal Register that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798d525f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizes the review, the comments received from the public solicitation, and other evidence gathered by the Board, such as through consumer testing or other research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798d5260-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id798d5261-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposes new or revised regulations or interpretations to update or revise disclosures and protections for consumer credit cards, as appropriate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id798d5262-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the reason for the determination of the Board that new or revised regulations are not necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5263-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of review period following material revision of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that the Board materially revises regulations on consumer credit card plans, a review need not be conducted until 2 years after the effective date of the revised regulations, which thereafter shall be treated as the new date for the biennial review required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798d5264-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board report to the Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall report to Congress not less frequently than every 2 years, except as provided in subsection (c)(2), on the status of its most recent review, its efforts to address any issues identified from the review, and any recommendations for legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798d5265-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal banking agencies (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":") and the Federal Trade Commission shall provide annually to the Board, and the Board shall include in its annual report to Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s247"},"text":"section 247 of title 12","children":[],"tail":", information about the supervisory and enforcement activities of the agencies with respect to compliance by credit card issuers with applicable Federal consumer protection statutes and regulations, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id798d5266-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this Act, the amendments made by this Act, and regulations prescribed under this Act and such amendments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5267-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1616/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 5 of the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"15 U.S.C. 45","children":[],"tail":"], and regulations prescribed under the Federal Trade Commission Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.], including part 227 of title 12 of the Code of Federal Regulations, as prescribed by the Board (referred to as “Regulation AA”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798d5268-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/tV/s502"},"text":"Pub. L. 111–24, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1755"},"text":"123 Stat. 1755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798d5269-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798d526a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id798d526b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this Act, referred to in subsec. (a), is 9 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", except as otherwise specifically provided in "},{"tag":"ref","attrib":{"href":"/us/pl/111/24"},"text":"Pub. L. 111–24","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/s3"},"text":"section 3 of Pub. L. 111–24","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a)(4) and (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24"},"text":"Pub. L. 111–24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1734"},"text":"123 Stat. 1734","children":[],"tail":", known as the Credit Card Accountability Responsibility and Disclosure Act of 2009, and also as the Credit CARD Act of 2009, which enacted this section and sections 1651, 1665c to 1665e, 1666i–1, 1666i–2, and 1693"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1a–7b"},"text":"section 1a–7b of Title 16","children":[],"tail":", Conservation, amended sections 1602, 1632, 1637, 1640, 1650, 1666b, 1666c, 1666j, 1681b, 1681j, and 1693m to 1693r of this title, enacted provisions set out as notes under sections 1602, 1637, 1638, 1666b, 1681j, and 1693"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5311"},"text":"section 5311 of Title 31","children":[],"tail":", Money and Finance, and amended provisions set out as notes under sections 1638 and 1693 of this title. For complete classification of this Act to the Code, see Short Title of 2009 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798d526c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Credit Card Accountability Responsibility and Disclosure Act of 2009, also known as the Credit CARD Act of 2009, and not as part of the Consumer Credit Protection Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id798d526d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id798d526e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/s3"},"text":"section 3 of Pub. L. 111–24","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id798d526f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Board”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/s2"},"text":"section 2 of Pub. L. 111–24","children":[],"tail":", set out as a Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
