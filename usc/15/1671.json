{"tag":"section","attrib":{"id":"id79a0660d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1671"},"text":null,"children":[{"tag":"num","attrib":{"value":"1671"},"text":"§ 1671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a0660e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1671/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantages of garnishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a0660f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1671/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The unrestricted garnishment of compensation due for personal services encourages the making of predatory extensions of credit. Such extensions of credit divert money into excessive credit payments and thereby hinder the production and flow of goods in interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06610-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1671/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The application of garnishment as a creditors’ remedy frequently results in loss of employment by the debtor, and the resulting disruption of employment, production, and consumption constitutes a substantial burden on interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06611-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1671/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The great disparities among the laws of the several States relating to garnishment have, in effect, destroyed the uniformity of the bankruptcy laws and frustrated the purposes thereof in many areas of the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06612-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1671/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessity for regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the basis of the findings stated in subsection (a) of this section, the Congress determines that the provisions of this subchapter are necessary and proper for the purpose of carrying into execution the powers of the Congress to regulate commerce and to establish uniform bankruptcy laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a06613-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIII/s301"},"text":"Pub. L. 90–321, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/163"},"text":"82 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a06614-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a06615-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a06616-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tV/s504/c"},"text":"Pub. L. 90–321, title V, § 504(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/167"},"text":"82 Stat. 167","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/321/tV/s504/c"},"text":"“Title III [enacting this section and sections 1672 to 1677 of this title] takes effect on ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
