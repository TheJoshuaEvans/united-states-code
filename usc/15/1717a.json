{"tag":"section","attrib":{"id":"id79c440b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1717a"},"text":"§ 1717a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil money penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c440b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c440b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever any person knowingly and materially violates any of the provisions of this chapter or any rule, regulation, or order issued under this chapter, the Director may impose a civil money penalty on such person in accordance with the provisions of this section. The penalty shall be in addition to any other available civil remedy or any available criminal penalty, and may be imposed whether or not the Director imposes other administrative sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c440b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the penalty, as determined by the Director, may not exceed $1,000 for each violation, except that the maximum penalty for all violations by a particular person during any 1-year period shall not exceed $1,000,000. Each violation of this chapter, or any rule, regulation, or order issued under this chapter, shall constitute a separate violation with respect to each sale or lease or offer to sell or lease. In the case of a continuing violation, as determined by the Director, each day shall constitute a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c440b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish standards and procedures governing the imposition of civil money penalties under subsection (a). The standards and procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c440b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide for the imposition of a penalty only after a person has been given an opportunity for a hearing on the record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c440b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for review by the Director of any determination or order, or interlocutory ruling, arising from a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c440b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no hearing is requested within 15 days of receipt of the notice of opportunity for hearing, the imposition of the penalty shall constitute a final and unappealable determination. If the Director reviews the determination or order, the Director may affirm, modify, or reverse that determination or order. If the Director does not review the determination or order within 90 days of the issuance of the determination or order, the determination or order shall be final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c440b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors in determining amount of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of a penalty under subsection (a), consideration shall be given to such factors as the gravity of the offense, any history of prior offenses (including offenses occurring before ","children":[{"tag":"date","attrib":{"date":"1989-12-15"},"text":"December 15, 1989","children":[],"tail":"), ability to pay the penalty, injury to the public, benefits received, deterrence of future violations, and such other factors as the Director may determine in regulations to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c440ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewability of imposition of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary’s ","children":[{"tag":"ref","attrib":{"idref":"fn002416"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002416"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Director’s”."}],"tail":" determination or order imposing a penalty under subsection (a) shall not be subject to review, except as provided in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of agency determination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c440bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After exhausting all administrative remedies established by the Director under subsection (b)(1), a person aggrieved by a final order of the Director assessing a penalty under this section may seek judicial review pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1710"},"text":"section 1710 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c440bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order to pay penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in any such review, the court shall have the power to order payment of the penalty imposed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action to collect penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person fails to comply with the determination or order of the Director imposing a civil money penalty under subsection (a), after the determination or order is no longer subject to review as provided by subsections (b) and (c), the Director may request the Attorney General of the United States to bring an action in any appropriate United States district court to obtain a monetary judgment against the person and such other relief as may be available. The monetary judgment may, in the discretion of the court, include any attorneys fees and other expenses incurred by the United States in connection with the action. In an action under this subsection, the validity and appropriateness of the Secretary’s ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" determination or order imposing the penalty shall not be subject to review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement by Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may compromise, modify, or remit any civil money penalty which may be, or has been, imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Knowingly” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly” means having actual knowledge of or acting with deliberate ignorance of or reckless disregard for the prohibitions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall issue such regulations as the Director deems appropriate to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1717a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of penalties for administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Civil money penalties collected under this section shall be paid to the Director and, upon approval in an appropriation Act, may be used by the Director to cover all or part of the cost of rendering services under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c440c3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIV/s1418a"},"text":"Pub. L. 90–448, title XIV, § 1418a","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/235/tI/s111/a"},"text":"Pub. L. 101–235, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2014"},"text":"103 Stat. 2014","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1098A/1"},"text":"Pub. L. 111–203, title X, § 1098A(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2105"},"text":"124 Stat. 2105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c440c4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c440c5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c440c6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Director” for “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c440c7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79c440c8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79c440c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/235/tI/s111/b"},"text":"Pub. L. 101–235, title I, § 111(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2016"},"text":"103 Stat. 2016","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/235/tI/s111/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a) [enacting this section] shall apply only with respect to—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violations referred to in the amendment that occur on or after the effective date of this section [","children":[{"tag":"date","attrib":{"date":"1989-12-15"},"text":"Dec. 15, 1989","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a continuing violation (as determined by the Secretary of Housing and Urban Development), any portion of violation referred to in the amendment that occurs on or after such date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
