{"tag":"section","attrib":{"id":"id7a664e98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851"},"text":null,"children":[{"tag":"num","attrib":{"value":"6851"},"text":"§ 6851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action relating to disclosure of intimate images","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a664e99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a664e9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial pornographic content","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commercial pornographic content” means any material that is subject to the record keeping requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2257"},"text":"section 2257 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664e9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consent” means an affirmative, conscious, and voluntary authorization made by the individual free from force, fraud, misrepresentation, or coercion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664e9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depicted individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depicted individual” means an individual whose body appears in whole or in part in an intimate visual depiction and who is identifiable by virtue of the person’s face, likeness, or other distinguishing characteristic, such as a unique birthmark or other recognizable feature, or from information displayed in connection with the visual depiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68be9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “disclose” means to transfer, publish, distribute, or make accessible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68be9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intimate visual depiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “intimate visual depiction”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68be9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a visual depiction, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2256/5"},"text":"section 2256(5) of title 18","children":[],"tail":", that depicts—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a68bea0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uncovered genitals, pubic area, anus, or post-pubescent female nipple of an identifiable individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a68bea1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the display or transfer of bodily sexual fluids—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a68bea2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on to any part of the body of an identifiable individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a68bea3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the body of an identifiable individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a68bea4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identifiable individual engaging in sexually explicit conduct and ","children":[{"tag":"ref","attrib":{"idref":"fn002565"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002565"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bea5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes any visual depictions described in subparagraph (A) produced while the identifiable individual was in a public place only if the individual did not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a68bea6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntarily display the content depicted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a68bea7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consent to the sexual conduct depicted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bea8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexually explicit conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexually explicit conduct” has the meaning given the term in subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2256/2"},"text":"section 2256(2) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bea9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68beaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of action","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68beab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4), an individual whose intimate visual depiction is disclosed, in or affecting interstate or foreign commerce or using any means or facility of interstate or foreign commerce, without the consent of the individual, where such disclosure was made by a person who knows that, or recklessly disregards whether, the individual has not consented to such disclosure, may bring a civil action against that person in an appropriate district court of the United States for relief as set forth in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68beac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights on behalf of certain individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an individual who is under 18 years of age, incompetent, incapacitated, or deceased, the legal guardian of the individual or representative of the identifiable individual’s estate, another family member, or any other person appointed as suitable by the court, may assume the identifiable individual’s’ ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" rights under this section, but in no event shall the defendant be named as such representative or guardian."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bead-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of an action under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68beae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact that the individual consented to the creation of the depiction shall not establish that the person consented to its distribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68beaf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact that the individual disclosed the intimate visual depiction to someone else shall not establish that the person consented to the further disclosure of the intimate visual depiction by the person alleged to have violated paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68beb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68beb1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a civil action filed under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a68beb2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual may recover the actual damages sustained by the individual or liquidated damages in the amount of $150,000, and the cost of the action, including reasonable attorney’s fees and other litigation costs reasonably incurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a68beb3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court may, in addition to any other relief available at law, order equitable relief, including a temporary restraining order, a preliminary injunction, or a permanent injunction ordering the defendant to cease display or disclosure of the visual depiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68beb4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of anonymity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In ordering relief under subparagraph (A), the court may grant injunctive relief maintaining the confidentiality of a plaintiff using a pseudonym.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68beb5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An identifiable individual may not bring an action for relief under this section relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68beb6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intimate image that is commercial pornographic content, unless that content was produced by force, fraud, misrepresentation, or coercion of the depicted individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68beb7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a disclosure made in good faith—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a68beb8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a law enforcement officer or agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a68beb9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of a legal proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a68beba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of medical education, diagnosis, or treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a68bebb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the reporting or investigation of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a68bebc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unlawful content; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a68bebd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsolicited or unwelcome conduct;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bebe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matter of public concern or public interest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bebf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6851/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disclosure reasonably intended to assist the identifiable individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bec0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXIII/s1309"},"text":"Pub. L. 117–103, div. W, title XIII, § 1309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/929"},"text":"136 Stat. 929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a68bec1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a68bec2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a68bec3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4"},"text":"Pub. L. 117–103, div. W, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/846"},"text":"136 Stat. 846","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dW/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this Act [div. W of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", see Tables for classification] and the amendments made by this Act shall not take effect until October 1 of the first fiscal year beginning after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective on Date of Enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 106, 107, 304, 606, 803, and 1306 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2265"},"text":"section 2265 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1302a"},"text":"section 1302a of Title 25","children":[],"tail":", Indians, and "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21308"},"text":"section 21308 of Title 34","children":[],"tail":", Crime Control and Law Enforcement] and any amendments made by such sections shall take effect on the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id7a68bec4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s6"},"text":"Pub. L. 117–103, div. W, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/846"},"text":"136 Stat. 846","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dW/s6"},"text":"“If any provision of this Act [div. W of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", see Tables for classification], an amendment made by this Act, or the application of such provision or amendment to any person or circumstance is held to be unconstitutional, the remainder of this Act and the amendments made by this Act, and the application of the provisions or amendment to any other person or circumstance, shall not be affected.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a68bec5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, as made applicable by "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s2/b"},"text":"section 2(b) of div. W of Pub. L. 117–103","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of Title 34","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
