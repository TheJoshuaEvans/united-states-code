{"tag":"section","attrib":{"id":"id788e323b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s274"},"text":null,"children":[{"tag":"num","attrib":{"value":"274"},"text":"§ 274.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director; powers and duties; report; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall report directly to the Secretary and shall have the general supervision of the Institute, its equipment, and the exercise of its functions. The Director shall make an annual report to the Secretary of Commerce. The Director may issue, when necessary, bulletins for public distribution, containing such information as may be of value to the public or facilitate the exercise of the functions of the Institute.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788e323c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s5"},"text":"Mar. 3, 1901, ch. 872, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1449"},"text":"31 Stat. 1449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/73/s6/a"},"text":"Pub. L. 99–73, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-07-29"},"text":"July 29, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/172"},"text":"99 Stat. 172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5112/c/1"},"text":"Pub. L. 100–418, title V, § 5112(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1431"},"text":"102 Stat. 1431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII/s3002/c/2/B"},"text":"Pub. L. 110–69, title III, § 3002(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/586"},"text":"121 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV/s403/b/2"},"text":"Pub. L. 111–358, title IV, § 403(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4000"},"text":"124 Stat. 4000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788e323d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788e323e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788e323f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" struck out at beginning “The Director shall be appointed by the President, by and with the advice and consent of the Senate.” and struck out at end “The Director shall be compensated at the rate in effect for level IV of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":". Until such time as the Director assumes office under this section, the most recent Director of the National Bureau of Standards shall serve as Director.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" substituted “The Director shall report directly to the Secretary and shall have the general” for “The Director shall have the general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" amended section generally, substituting provisions relating to appointment, powers and duties, and compensation of, and reports by, Director of the Institute for similar provisions relating to Director of the Bureau of Standards, striking out requirement that the annual report include an abstract of the work done during the year and a financial statement, and inserting provision that until such time as the Director assumes office under this section, the most recent Director of the National Bureau of Standards shall serve as Director."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/73"},"text":"Pub. L. 99–73","children":[],"tail":" substituted “The Director” for “He” at beginning of second, third, and fourth sentences, and inserted provisions relating to compensation for the Director."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788e3240-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id788e3241-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/73"},"text":"Pub. L. 99–73","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/73/s6/c"},"text":"section 6(c) of Pub. L. 99–73","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
