{"tag":"section","attrib":{"id":"id7a108c80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2902"},"text":null,"children":[{"tag":"num","attrib":{"value":"2902"},"text":"§ 2902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the purpose of the Congress in this chapter to establish a national climate program that will assist the Nation and the world to understand and respond to natural and man-induced climate processes and their implications.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a108c81-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/367/s3"},"text":"Pub. L. 95–367, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-17"},"text":"Sept. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/601"},"text":"92 Stat. 601","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
