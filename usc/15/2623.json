{"tag":"section","attrib":{"id":"id79ffc32f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623"},"text":null,"children":[{"tag":"num","attrib":{"value":"2623"},"text":"§ 2623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment effects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ffc330-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall evaluate on a continuing basis the potential effects on employment (including reductions in employment or loss of employment from threatened plant closures) of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ffc331-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of a rule or order under section 2603, 2604, or 2605 of this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ffc332-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement of section 2604 or 2605 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ffc333-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ffc334-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any employee (or any representative of an employee) may request the Administrator to make an investigation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ffc335-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discharge or layoff or threatened discharge or layoff of the employee, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ffc336-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adverse or threatened adverse effects on the employee’s employment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"allegedly resulting from a rule or order under section 2603, 2604, or 2605 of this title or a requirement of section 2604 or 2605 of this title. Any such request shall be made in writing, shall set forth with reasonable particularity the grounds for the request, and shall be signed by the employee, or representative of such employee, making the request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ffc337-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ffc338-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon receipt of a request made in accordance with paragraph (1) the Administrator shall (i) conduct the investigation requested, and (ii) if requested by any interested person, hold public hearings on any matter involved in the investigation unless the Administrator, by order issued within 45 days of the date such hearings are requested, denies the request for the hearings because the Administrator determines there are no reasonable grounds for holding such hearings. If the Administrator makes such a determination, the Administrator shall notify in writing the person requesting the hearing of the determination and the reasons therefor and shall publish the determination and the reasons therefor in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ffc339-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If public hearings are to be held on any matter involved in an investigation conducted under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79ffc33a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least five days’ notice shall be provided the person making the request for the investigation and any person identified in such request, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79ffc33b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each employee who made or for whom was made a request for such hearings and the employer of such employee shall be required to present information respecting the applicable matter referred to in paragraph (1)(A) or (1)(B) together with the basis for such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ffc33c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon completion of an investigation under paragraph (2), the Administrator shall make findings of fact, shall make such recommendations as the Administrator deems appropriate, and shall make available to the public such findings and recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ffc33d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2623/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not be construed to require the Administrator to amend or repeal any rule or order in effect under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ffc33e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tI/s24"},"text":"Pub. L. 94–469, title I, § 24","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2045"},"text":"90 Stat. 2045","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s3/c/1"},"text":"Pub. L. 99–519, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2989"},"text":"100 Stat. 2989","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/182/tI/s19/p"},"text":"Pub. L. 114–182, title I, § 19(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/510"},"text":"130 Stat. 510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ffc33f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ffc340-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ffc341-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2)(B)(ii), (iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182"},"text":"Pub. L. 114–182","children":[],"tail":" redesignated cl. (iii) as (ii) and struck out former cl. (ii) which read as follows: “such hearings shall be held in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2605/c/3"},"text":"section 2605(c)(3) of this title","children":[],"tail":", and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ffc342-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79ffc343-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"Jan. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/469/s31"},"text":"section 31 of Pub. L. 94–469","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
