{"tag":"section","attrib":{"id":"id77e9b535-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77x"},"text":null,"children":[{"tag":"num","attrib":{"value":"77x"},"text":"§ 77x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates any of the provisions of this subchapter, or the rules and regulations promulgated by the Commission under authority thereof, or any person who willfully, in a registration statement filed under this subchapter, makes any untrue statement of a material fact or omits to state any material fact required to be stated therein or necessary to make the statements therein not misleading, shall upon conviction be fined not more than $10,000 or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77e9b536-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 24, "},{"tag":"ref","attrib":{"href":"/us/stat/48/87"},"text":"48 Stat. 87","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s27/a"},"text":"Pub. L. 94–29, § 27(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/163"},"text":"89 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e9b537-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e9b538-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note