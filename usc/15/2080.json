{"tag":"section","attrib":{"id":"id79dc0e41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080"},"text":null,"children":[{"tag":"num","attrib":{"value":"2080"},"text":"§ 2080.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on jurisdiction of Consumer Product Safety Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dc0e42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to regulate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall have no authority under this chapter to regulate any risk of injury associated with a consumer product if such risk could be eliminated or reduced to a sufficient extent by actions taken under the Occupational Safety and Health Act of 1970 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.]; the Atomic Energy Act of 1954 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"42 U.S.C. 2011","children":[],"tail":" et seq.]; or the Clean Air Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.]. The Commission shall have no authority under this chapter to regulate any risk of injury associated with electronic product radiation emitted from an electronic product (as such terms are defined by sections 355(1) and (2) "},{"tag":"ref","attrib":{"idref":"fn002435"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002435"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Public Health Service Act) if such risk of injury may be subjected to regulation under subpart 3 "},{"tag":"ref","attrib":{"idref":"fn002435"},"text":"1","children":[],"tail":" of part F of title III of the Public Health Service Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dc0e43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain notices of proposed rulemaking; duties of Chronic Hazard Advisory Panel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dc0e44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission may not issue—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dc0e45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advance notice of proposed rulemaking for a consumer product safety rule,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice of proposed rulemaking for a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2076/e"},"text":"section 2076(e) of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advance notice of proposed rulemaking for regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261/q/1"},"text":"section 1261(q)(1) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"relating to a risk of cancer, birth defects, or gene mutations from a consumer product unless a Chronic Hazard Advisory Panel, established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2077"},"text":"section 2077 of this title","children":[],"tail":", has, in accordance with paragraph (2), submitted a report to the Commission with respect to whether a substance contained in such product is a carcinogen, mutagen, or teratogen."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dc0e48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dc0e49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before the Commission issues an advance notice of proposed rulemaking for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79dc0e4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consumer product safety rule,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dc0e4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2076/e"},"text":"section 2076(e) of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79dc0e4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regulation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261/q/1"},"text":"section 1261(q)(1) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"relating to a risk of cancer, birth defects, or gene mutations from a consumer product, the Commission shall request the Panel to review the scientific data and other relevant information relating to such risk to determine if any substance in the product is a carcinogen, mutagen, or a teratogen and to report its determination to the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Commission appoints a Panel, the Panel shall convene within 30 days after the date the final appointment is made to the Panel. The Panel shall report its determination to the Commission not later than 120 days after the date the Panel is convened or, if the Panel requests additional time, within a time period specified by the Commission. If the determination reported to the Commission states that a substance in a product is a carcinogen, mutagen, or a teratogen, the Panel shall include in its report an estimate, if such an estimate is feasible, of the probable harm to human health that will result from exposure to the substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Panel appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2077"},"text":"section 2077 of this title","children":[],"tail":" shall terminate when it has submitted its report unless the Commission extends the existence of the Panel."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 10 of title 5 shall not apply with respect to any Panel established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dc0e50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2080/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panel report; incorporation into advance notice and final rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Panel’s report shall contain a complete statement of the basis for the Panel’s determination. The Commission shall consider the report of the Panel and incorporate such report into the advance notice of proposed rulemaking and final rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dc0e51-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s31"},"text":"Pub. L. 92–573, § 31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1232"},"text":"86 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXII/s1206/b"},"text":"Pub. L. 97–35, title XII, § 1206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/717"},"text":"95 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/414/s9/j/5"},"text":"Pub. L. 97–414, § 9(j)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2064"},"text":"96 Stat. 2064","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/67"},"text":"Pub. L. 117–286, § 4(a)(67)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4313"},"text":"136 Stat. 4313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dc0e52-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dc0e53-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dc0e54-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", which is classified principally to chapter 23 (§ 2011 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Clean Air Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"act July 14, 1955, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/322"},"text":"69 Stat. 322","children":[],"tail":", which is classified generally to chapter 85 (§ 7401 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":". Subpart 3 of part F of title III of the Public Health Service Act, which was classified to subpart 3 (§ 263b et seq.) of part F of subchapter II of chapter 6A of Title 42, was redesignated as subchapter C of chapter V of "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", the Federal Food, Drug, and Cosmetic Act, by "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/4"},"text":"Pub. L. 101–629, § 19(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4530"},"text":"104 Stat. 4530","children":[],"tail":", and was transferred to part C ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360hh"},"text":"21 U.S.C. 360hh","children":[],"tail":" et seq.) of subchapter V of chapter 9 of Title 21, Food and Drugs. Section 355 of the Public Health Service Act, which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s263c"},"text":"section 263c of Title 42","children":[],"tail":", was renumbered as section 531 of "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/101/629/s19/a/3"},"text":"Pub. L. 101–629, § 19(a)(3)","children":[],"tail":", (4), "},{"tag":"ref","attrib":{"href":"/us/stat/104/4530"},"text":"104 Stat. 4530","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s360hh"},"text":"section 360hh of Title 21","children":[],"tail":". For complete classification of the Public Health Service Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79dc0e55-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414"},"text":"Pub. L. 97–414","children":[],"tail":" struck out introductory text “an advance notice of proposed rulemaking for” after “issue”, inserted in subpar. (A) “an advance notice of proposed rulemaking for” before “a consumer” and in subpar. (B) “a notice of proposed rulemaking for” before “a rule”, and substituted in subpar. (C) “an advance notice of proposed rulemaking for regulations” for “a regulation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79dc0e56-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79dc0e57-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" applicable with respect to regulations under this chapter and chapters 25 and 30 of this title for which notices of proposed rulemaking are issued after "},{"tag":"date","attrib":{"date":"1981-08-14"},"text":"Aug. 14, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1215"},"text":"section 1215 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052"},"text":"section 2052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79dc0e58-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the sixtieth day following ","children":[{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/573/s34"},"text":"section 34 of Pub. L. 92–573","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79dc0e59-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Manufacture or Sale of Firearms or Firearms Ammunition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/284/s3/e"},"text":"Pub. L. 94–284, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/504"},"text":"90 Stat. 504","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/284/s3/e"},"text":"“The Consumer Product Safety Commission shall make no ruling or order that restricts the manufacture or sale of firearms, firearms ammunition, or components of firearms ammunition, including black powder or gunpowder for firearms.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
