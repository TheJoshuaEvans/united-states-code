{"tag":"section","attrib":{"id":"id7970c9ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1272"},"text":null,"children":[{"tag":"num","attrib":{"value":"1272"},"text":"§ 1272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicity; reports; dissemination of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7970c9ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summaries of judgments, decrees, orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may cause to be published from time to time reports summarizing any judgments, decrees, or court orders which have been rendered under this chapter, including the nature of the charge and the disposition thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c9ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information as to health dangers and investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may also cause to be disseminated information regarding hazardous substances in situations involving, in the opinion of the Commission, imminent danger to health. Nothing in this section shall be construed to prohibit the Commission from collecting, reporting, and illustrating the results of the investigations of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7970c9ef-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s13"},"text":"Pub. L. 