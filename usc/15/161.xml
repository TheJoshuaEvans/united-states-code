<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id7884956c-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s161"><num value="161">§ 161.</num><heading> Alteration, amendment, or repeal</heading><content>
