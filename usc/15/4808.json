{"tag":"section","attrib":{"id":"id7a475459-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4808"},"text":null,"children":[{"tag":"num","attrib":{"value":"4808"},"text":"§ 4808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each of the fiscal years 1991 and 1992 such sums as may be necessary not to exceed $5,000,000 to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a47545a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5209"},"text":"Pub. L. 100–418, title V, § 5209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1461"},"text":"102 Stat. 1461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/382/tI/s133/e"},"text":"Pub. L. 101–382, title I, § 133(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/649"},"text":"104 Stat. 649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a47545b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a47545c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a47545d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","a