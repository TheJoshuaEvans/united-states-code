{"tag":"section","attrib":{"id":"id7a68bee7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6904"},"text":null,"children":[{"tag":"num","attrib":{"value":"6904"},"text":"§ 6904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified organizations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of eligibility for assistance under this chapter, a qualified organization shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bee8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6904/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit microenterprise development organization or program (or a group or collaborative thereof) that has a demonstrated record of delivering microenterprise services to disadvantaged entrepreneurs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bee9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6904/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intermediary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68beea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6904/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a microenterprise development organization or program that is accountable to a local community, working in conjunction with a State or local government or Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68beeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6904/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe acting on its own, if the Indian tribe can certify that no private organization or program referred to in this paragraph exists within its jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68beec-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s175"},"text":"Pub. L. 103–325, title I, § 175","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1473"},"text":"113 Stat. 1473","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
