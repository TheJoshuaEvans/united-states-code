{"tag":"section","attrib":{"id":"id7a8a2982-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8544"},"text":null,"children":[{"tag":"num","attrib":{"value":"8544"},"text":"§ 8544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visiting fellows at National Weather Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8a2983-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Weather Service may establish a program to host postdoctoral fellows and academic researchers at any of the National Centers for Environmental Prediction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a2984-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This program shall be designed to provide direct interaction between forecasters and talented academic and private sector researchers in an effort to bring innovation to forecasting tools and techniques to the National Weather Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a2985-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8544/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection and appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such fellows shall be competitively selected and appointed for a term not to exceed 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8a2986-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tIV/s404"},"text":"Pub. L. 115–25, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/107"},"text":"131 Stat. 107","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
