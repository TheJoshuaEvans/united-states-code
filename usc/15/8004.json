{"tag":"section","attrib":{"id":"id7a808c06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004"},"text":null,"children":[{"tag":"num","attrib":{"value":"8004"},"text":"§ 8004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swimming pool safety grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a808c07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations authorized by subsection (e), the Commission shall carry out a grant program to provide assistance to eligible covered entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under the program, a covered entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808c09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate to the satisfaction of the Commission that, as of the date on which the covered entity submits an application to the Commission for a grant under this section, the covered entity has enacted and provides for the enforcement of a statute that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808c0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8005/a/1/A/i"},"text":"section 8005(a)(1)(A)(i) of this title","children":[],"tail":", applies to all swimming pools constructed in the State or in the jurisdiction of the Indian Tribe (as the case may be) on or after such date; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the minimum State law requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8005"},"text":"section 8005 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an application to the Commission at such time, in such form, and containing such additional information as the Commission may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall determine the amount of a grant awarded under this section, and shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808c0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of the covered entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative enforcement and implementation needs of the covered entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocation of grant funds in a manner designed to provide the maximum benefit from the program in terms of protecting children from drowning or entrapment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or an Indian Tribe receiving a grant under this section shall use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808c12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at least 25 percent of amounts made available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808c13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire and train personnel for implementation and enforcement of standards under the swimming pool and spa safety law of the State or Indian Tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defray administrative costs associated with the hiring and training programs under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the remainder—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808c16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate pool owners, pool operators, and other members of the public about the standards under the swimming pool and spa safety law of the State or Indian Tribe and about the prevention of drowning or entrapment of children using swimming pools and spas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defray administrative costs associated with the education programs under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Commission for fiscal year 2023 $2,500,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a808c19-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXIV/s1405"},"text":"Pub. L. 110–140, title XIV, § 1405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1796"},"text":"121 Stat. 1796","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tV/s1576/b"},"text":"Pub. L. 112–10, div. B, title V, § 1576(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/139"},"text":"125 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dC/tV/s502"},"text":"Pub. L. 112–74, div. C, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/908"},"text":"125 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dE/tV/s501/1"},"text":"Pub. L. 113–76, div. E, title V, § 501(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/208"},"text":"128 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tIV/s402/a"},"text":"Pub. L. 117–328, div. BB, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5562"},"text":"136 Stat. 5562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a808c1a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a808c1b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a808c1c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended section generally. Prior to amendment, section related to State swimming pool safety grant program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/s501/1/A"},"text":"Pub. L. 113–76, § 501(1)(A)","children":[],"tail":", substituted “all swimming pools constructed in the State after the date the State submits an application to the Commission for a grant under this section” for “all swimming pools constructed after the date that is 6 months after "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":", in the State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/s501/1/B"},"text":"Pub. L. 113–76, § 501(1)(B)","children":[],"tail":", substituted “There is authorized to be appropriated to the Commission such sums as may be necessary to carry out this section through fiscal year 2016.” for “There are authorized to be appropriated to the Commission for each of fiscal years 2009 and 2010 $2,000,000 to carry out this section, such sums to remain available until expended.” and “the end of fiscal year 2016” for “the end of fiscal year 2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s502/b"},"text":"Pub. L. 112–74, § 502(b)","children":[],"tail":", inserted “constructed after the date that is 6 months after "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":",” after “swimming pools”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/s502/a"},"text":"Pub. L. 112–74, § 502(a)","children":[],"tail":", substituted “2012” for “2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10"},"text":"Pub. L. 112–10","children":[],"tail":", which directed substitution of “2011” for “2010”, was executed by making the substitution for “2010” the second place appearing to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a808c1d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a808c1e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
