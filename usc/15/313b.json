{"tag":"section","attrib":{"id":"id789ed458-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313b"},"text":null,"children":[{"tag":"num","attrib":{"value":"313b"},"text":"§ 313b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute for Aviation Weather Prediction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration shall establish an Institute for Aviation Weather Prediction. The Institute shall provide forecasts, weather warnings, and other weather services to the United States aviation community. The Institute shall expand upon the activities of the aviation unit currently at the National Severe Storms Forecast Center in Kansas City, Missouri, and shall be established in the Kansas City ","children":[{"tag":"ref","attrib":{"idref":"fn002163"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002163"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" Missouri "},{"tag":"ref","attrib":{"idref":"fn002163"},"text":"1","children":[],"tail":" area. The Administrator of the National Oceanic and Atmospheric Administration shall provide a full and fair opportunity for employees at the National Severe Storms Center to assume comparable duties and responsibilities within the Institute."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a14459-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/588/tII/s222"},"text":"Pub. L. 102–588, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5119"},"text":"106 Stat. 5119","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a1445a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a1445b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id78a1445c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tI/s112"},"text":"Pub. L. 102–567, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4278"},"text":"106 Stat. 4278","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
