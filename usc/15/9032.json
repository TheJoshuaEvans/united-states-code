{"tag":"section","attrib":{"id":"id7a9d3c4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9032"},"text":null,"children":[{"tag":"num","attrib":{"value":"9032"},"text":"§ 9032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9d3c4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-application of the Paperwork Reduction Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 35 of title 44 (commonly referred to as the “Paperwork Reduction Act of 1995”),","children":[{"tag":"ref","attrib":{"idref":"fn002633"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002633"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" shall not apply to the provisions of, and the amendments made by, this subtitle."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating instructions or other guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of Labor may issue any operating instructions or other guidance necessary to carry out the provisions of, or the amendments made by, this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9d3c4f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2116"},"text":"Pub. L. 116–136, div. A, title II, § 2116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/335"},"text":"134 Stat. 335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9d3c50-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9d3c51-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9d3c52-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in text, is subtitle A (§ 2101 et seq.) of title II of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/313"},"text":"134 Stat. 313","children":[],"tail":", known as the Relief for Workers Affected by Coronavirus Act. For complete classification of subtitle A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
