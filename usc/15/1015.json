{"tag":"section","attrib":{"id":"id7951a900-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1015"},"text":null,"children":[{"tag":"num","attrib":{"value":"1015"},"text":"§ 1015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “State” includes the several States, Alaska, Hawaii, Puerto Rico, Guam, and the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7951a901-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-03-09/ch20/s5"},"text":"Mar. 9, 1945, ch. 20, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/34"},"text":"59 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch852/s4"},"text":"Aug. 1, 1956, ch. 852, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/908"},"text":"70 Stat. 908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7951a902-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7951a903-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7951a904-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", included “Guam” in definition of State."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id"