{"tag":"section","attrib":{"id":"id788495c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s182"},"text":null,"children":[{"tag":"num","attrib":{"value":"182"},"text":"§ 182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistics of manufactures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Foreign and Domestic Commerce shall collect, digest, and arrange, for the use of Congress, the statistics of the manufactures of the United States, their localities, sources of raw material, markets, exchanges with the producing regions of the country, transportation of products, wages, and such other conditions as are found to affect their prosperity.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788495c6-552d-11f1-9071-ff305b7c3ff0"},"text":"(R.S. § 342; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/407"},"text":"37 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-03-01/ch86"},"text":"Mar. 1, 1919, ch. 86","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1256"},"text":"40 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788495c7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788495c8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id788495c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 342 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-28/ch298/s13"},"text":"act July 28, 1866, ch. 298, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/330"},"text":"14 Stat. 330","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788495ca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id788495cb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1919-03-01"},"text":"Mar. 1, 1919","children":[],"tail":", substituted “Director” for “Chief”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788495cc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1912-08-23"},"text":"Aug. 23, 1912","children":[],"tail":", transferred certain duties of Department or Bureau of Labor to Bureau of Foreign and Domestic Commerce."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788495cd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788495ce-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Bureau of Foreign and Domestic Commerce, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s172"},"text":"section 172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
