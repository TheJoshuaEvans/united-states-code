{"tag":"section","attrib":{"id":"id7a9610c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9009b"},"text":"§ 9009b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeted EIDL advance for small business continuity, adaptation, and resiliency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9610c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9610c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural enterprise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural enterprise” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s647/b"},"text":"section 647(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9610ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered entity”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9610cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an eligible entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a9610cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies for a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":" during the covered period, including before "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9610cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a low-income community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9610ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has suffered an economic loss of greater than 30 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9610cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs not more than 300 employees; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9610d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except with respect to an entity included under section 123.300(c) of title 13, Code of Federal Regulations, or any successor regulation, does not include an agricultural enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9610d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered period” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/a/1"},"text":"section 9009(a)(1) of this title","children":[],"tail":", as amended by section 332 of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9610d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “economic loss” means, with respect to a covered entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9610d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the gross receipts of the covered entity declined during an 8-week period between ","children":[{"tag":"date","attrib":{"date":"2020-03-02"},"text":"March 2, 2020","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", relative to a comparable 8-week period immediately preceding "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"March 2, 2020","children":[],"tail":", or during 2019; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9610d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the covered entity is a seasonal business concern, such other amount determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9610d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means an entity that, during the covered period, is eligible for a loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":", as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/b"},"text":"section 9009(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9610d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income community” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s45D/e"},"text":"section 45D(e) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9610d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement to full amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9610d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a covered entity, after submitting a request to the Administrator that the Administrator verifies under subsection (c), shall receive a total of $10,000 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/e"},"text":"section 9009(e) of this title","children":[],"tail":", without regard to whether—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9610d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable loan for which the covered entity applies or applied under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":" is or was approved;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9610da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered entity accepts or accepted the offer of the Administrator with respect to an approved loan described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9610db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered entity has previously received a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a/36"},"text":"section 636(a)(36) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9610dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of previously received amounts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9610dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a covered entity that received an emergency grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/e"},"text":"section 9009(e) of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the amount of the payment that the covered entity shall receive under this subsection (after satisfaction of the procedures required under subparagraph (B)) shall be the difference between $10,000 and the amount of that previously received grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9610de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Administrator receives a request under paragraph (1) from a covered entity described in subparagraph (A) of this paragraph, the Administrator shall, not later than 21 days after the date on which the Administrator receives the request—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a9610df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the verification required under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9610e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator, under subsection (c), verifies that the entity is a covered entity, provide to the covered entity a payment in the amount described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9610e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a covered entity that the Administrator determines is not entitled to a payment under this section, provide the covered entity with a notification explaining why the Administrator reached that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9610e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph may be construed to require any entity that received an emergency grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/e"},"text":"section 9009(e) of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", to repay any amount of that grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9610e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Administrator shall require any information, including any tax records, from an entity submitting a request under subsection (b) that the Administrator determines to be necessary to verify that the entity is a covered entity, without regard to whether the entity has previously submitted such information to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9610e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of processing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall process and approve requests for payments under subsection (b) in the order that the Administrator receives the requests, except that the Administrator shall give—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9610e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first priority to covered entities described in subsection (b)(2)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9610e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" second priority to covered entities that have not received emergency grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/e"},"text":"section 9009(e) of this title","children":[],"tail":", as of the date on which the Administrator receives such a request, because of the unavailability of funding to carry out such section 9009(e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9610e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other restriction imposed under this section, any eligibility restriction applicable to a loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":", including any restriction under section 123.300 or 123.301 of title 13, Code of Federal Regulations, or any successor regulation, shall apply with respect to funding provided under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9859d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall provide notice to each of the following entities stating that the entity may be eligible for a payment under this section if the entity satisfies the requirements under clauses (ii), (iii), and (iv) of subsection (a)(2)(A):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9859d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each entity that received an emergency grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/e"},"text":"section 9009(e) of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each entity that, before ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9859db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied for a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9859dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not receive an emergency grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009/e"},"text":"section 9009(e) of this title","children":[],"tail":" because of the unavailability of funding to carry out such section 9009(e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9859dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Administrator may rely on loan officers and other personnel of the Office of Disaster Assistance of the Administration and other resources of the Administration, including contractors of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9859de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Administrator $20,000,000,000 to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9859df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which shall remain available through ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of which $20,000,000 is authorized to be appropriated to the Inspector General of the Administration to prevent waste, fraud, and abuse with respect to funding provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9859e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any criminal charge or civil enforcement action alleging that a borrower engaged in fraud with respect to the use of any amount received pursuant to this section shall be filed not later than 10 years after the offense was committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9859e2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIII/s331"},"text":"Pub. L. 116–260, div. N, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2043"},"text":"134 Stat. 2043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/165/s2/c"},"text":"Pub. L. 117–165, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-05"},"text":"Aug. 5, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1363"},"text":"136 Stat. 1363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9859e3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9859e4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9859e5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 332 of this Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s332"},"text":"section 332 of div. N of Pub. L. 116–260","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a9859e6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Economic Aid to Hard-Hit Small Businesses, Nonprofits, and Venues Act, and not as part of the CARES Act which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a9859e7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/165"},"text":"Pub. L. 117–165","children":[],"tail":" added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a9859e8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a9859e9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", and applicable to loans and grants made on or after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s348"},"text":"section 348 of Pub. L. 116–260","children":[],"tail":", set out as an Effective Date of 2020 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a9859ea-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tax Treatment of Targeted EIDL Advances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9672"},"text":"Pub. L. 117–2, title IX, § 9672","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/184"},"text":"135 Stat. 184","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tIX/s9672"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For purposes of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received from the Administrator of the Small Business Administration in the form of a targeted EIDL advance under section 331 of the Economic Aid to Hard-Hit Small Businesses, Nonprofits, and Venues Act (title III of division N of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009b"},"text":"15 U.S.C. 9009b","children":[],"tail":"] shall not be included in the gross income of the person that receives such amounts,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no deduction shall be denied, no tax attribute shall be reduced, and no basis increase shall be denied, by reason of the exclusion from gross income provided by paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a partnership or S corporation that receives such amounts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount excluded from income by reason of paragraph (1) shall be treated as tax exempt income for purposes of sections 705 and 1366 of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s705"},"text":"26 U.S.C. 705","children":[],"tail":", 1366], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury (or the Secretary’s delegate) shall prescribe rules for determining a partner’s distributive share of any amount described in subparagraph (A) for purposes of section 705 of the Internal Revenue Code of 1986.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a9859eb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Clarification of Tax Treatment of Certain Loan Forgiveness and Other Business Financial Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Funding under this section not included in gross income of recipient, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s278"},"text":"section 278 of div. N of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9008"},"text":"section 9008 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a9859ec-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Administration” and “Administrator” mean the Small Business Administration and Administrator of the Small Business Administration, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s302"},"text":"section 302 of div. N of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
