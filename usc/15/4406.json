{"tag":"section","attrib":{"id":"id7a38fcd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4406"},"text":null,"children":[{"tag":"num","attrib":{"value":"4406"},"text":"§ 4406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38fcd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in the Family Smoking Prevention and Tobacco Control Act (and the amendments made by that Act), no statement relating to the use of smokeless tobacco products and health, other than the statements required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4402"},"text":"section 4402 of this title","children":[],"tail":", shall be required by any Federal agency to appear on any package or in any advertisement (unless the advertisement is an outdoor billboard advertisement) of a smokeless tobacco product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No statement relating to the use of smokeless tobacco products and health, other than the statements required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4402"},"text":"section 4402 of this title","children":[],"tail":", shall be required by any State or local statute or regulation to be included on any package or in any advertisement (unless the advertisement is an outdoor billboard advertisement) of a smokeless tobacco product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on liability law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall relieve any person from liability at common law or under State statutory law to any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38fcd4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/252/s7"},"text":"Pub. L. 99–252, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/34"},"text":"100 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dA/tII/s205/b"},"text":"Pub. L. 111–31, div. A, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1849"},"text":"123 Stat. 1849","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a38fcd5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a38fcd6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a38fcd7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family Smoking Prevention and Tobacco Control Act, referred to in subsec. (a), is div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1776"},"text":"123 Stat. 1776","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2009 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":", Food and Drugs, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a38fcd8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":" substituted “Except as provided in the Family Smoking Prevention and Tobacco Control Act (and the amendments made by that Act), no” for “No”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
