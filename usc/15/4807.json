{"tag":"section","attrib":{"id":"id7a475445-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807"},"text":null,"children":[{"tag":"num","attrib":{"value":"4807"},"text":"§ 4807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a475446-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall annually on March 1 submit to the President, the Senate Governmental Affairs Committee, and the appropriate Committees of the House of Representatives and the Senate a report setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475447-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals to achieve a more competitive United States economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475448-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies needed to meet such goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475449-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of existing policies of the Federal Government or State and local governments significantly affecting the competitiveness of the United States economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47544a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of significant economic and technological developments, in the United States and abroad, affecting the competitive position of United States industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47544b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a47544c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and describe actual or foreseeable developments, in the United States and abroad, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a47544d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a significant likelihood of a competitive challenge to, or of substantial dislocation in, an established United States industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47544e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present significant opportunities for United States industries to compete in new geographical markets or product markets, or to expand the position of such industries in established markets; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47544f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a significant risk that United States industries shall be unable to compete successfully in significant markets;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475450-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the industry sectors affected by the developments described in the report under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475451-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain a statement of the findings and recommendations of the Council during the previous fiscal year, including any recommendations of the Council for (a) such legislative or administrative actions as the Council considers appropriate, and (b) including the elimination, consolidation, reorganization of government agencies especially such agencies that specifically deal with research, science, technology, and international trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475452-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall consult with each committee to which a report is submitted under this section and after such consultation, each such committee shall submit to its respective House a report setting forth the views and recommendations of such committee with respect to the report of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a475453-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5208"},"text":"Pub. L. 100–418, title V, § 5208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1461"},"text":"102 Stat. 1461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/382/tI/s133/d"},"text":"Pub. L. 101–382, title I, § 133(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/649"},"text":"104 Stat. 649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a475454-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a475455-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a475456-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382"},"text":"Pub. L. 101–382","children":[],"tail":" substituted “on March 1” for “prepare and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a475457-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a475458-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
