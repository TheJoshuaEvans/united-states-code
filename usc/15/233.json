{"tag":"section","attrib":{"id":"id7889771e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s233"},"text":null,"children":[{"tag":"num","attrib":{"value":"233"},"text":"§ 233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person, firm, or corporation, or association who shall knowingly pack or cause to be packed apples in barrels, or who shall knowingly sell or offer for sale such barrels in violation of the provisions of this Act shall be liable to a penalty of $1 and costs for each such barrel so sold or offered for sale, to be recovered at the suit of the United States in any court of the United States having jurisdiction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7889771f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-03/ch273/s6"},"text":"Aug. 3, 1912, ch. 273, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/251"},"text":"37 Stat. 251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78897720-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78897721-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78897722-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1912-08-03/ch273"},"text":"act Aug. 3, 1912, ch. 273","children":[],"tail":", §§ 1–6, "},{"tag":"ref","attrib":{"href":"/us/stat/37/250"},"text":"37 Stat. 250","children":[],"tail":", 251, which is classified to sections 231 to 233 of this title and to sections 20 to 23 of Title 21, Food and Drugs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78897723-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is also set out as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s23"},"text":"section 23 of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
