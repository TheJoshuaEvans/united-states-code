{"tag":"section","attrib":{"id":"id77c849b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s52"},"text":null,"children":[{"tag":"num","attrib":{"value":"52"},"text":"§ 52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of false advertisements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77c849b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s52/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawfulness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person, partnership, or corporation to disseminate, or cause to be disseminated, any false advertisement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c849b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s52/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By United States mails, or in or having an effect upon commerce, by any means, for the purpose of inducing, or which is likely to induce, directly or indirectly the purchase of food, drugs, devices, services, or cosmetics; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c849ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s52/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By any means, for the purpose of inducing, or which is likely to induce, directly or indirectly, the purchase in or having an effect upon commerce, of food, drugs, devices, services, or cosmetics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c849bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s52/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfair or deceptive act or practice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The dissemination or the causing to be disseminated of any false advertisement within the provisions of subsection (a) of this section shall be an unfair or deceptive act or practice in or affecting commerce within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c849bc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s12"},"text":"Sept. 26, 1914, ch. 311, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1938-03-21/ch49/s4"},"text":"Mar. 21, 1938, ch. 49, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/114"},"text":"52 Stat. 114","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/637/tII/s201/c"},"text":"Pub. L. 93–637, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2193"},"text":"88 Stat. 2193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/297/s8"},"text":"Pub. L. 103–297, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-16"},"text":"Aug. 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1550"},"text":"108 Stat. 1550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c849bd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c849be-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77c849bf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/297"},"text":"Pub. L. 103–297","children":[],"tail":" inserted “services,” after “devices,” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/637"},"text":"Pub. L. 93–637","children":[],"tail":" substituted “in or having an effect upon commerce,” for “in commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/637"},"text":"Pub. L. 93–637","children":[],"tail":" substituted “in or affecting commerce” for “in commerce”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77c849c0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77c849c1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information About Scams Related to COVID–19","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/287/s2"},"text":"Pub. L. 116–287, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4882"},"text":"134 Stat. 4882","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/287/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissemination of Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As expeditiously as possible after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":"], the Commission, in consultation with the Attorney General, the Secretary of Health and Human Services, the Postmaster General, the Chief Postal Inspector, and the Internet Crime Complaint Center, shall develop and disseminate information to the public about scams related to the novel coronavirus (COVID–19)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding mail, telemarketing, and internet fraud and illegal robocalls related to COVID–19 that identifies the most common scams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding where and how to report instances of scams related to COVID–19, including instructions on how to file a complaint with the appropriate law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate information under such paragraph in a manner that prioritizes, and that is easily accessible by and user-friendly to, senior citizens and people with infirmities and disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate information under such paragraph on an internet website of the Commission that serves as a source of information for the public about scams related to COVID–19; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly update the information developed and disseminated under such paragraph to keep pace with the changing nature of scams related to COVID–19.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Database","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As expeditiously as possible after the date of the enactment of this Act, the Commission shall, in consultation with State law enforcement agencies, the Director of the Bureau of Consumer Financial Protection, the Attorney General, the Secretary of Health and Human Services, and other relevant Federal officials, establish a comprehensive national database, either within or separate from the Consumer Sentinel Network, that tracks instances of scams related to COVID–19.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Commission’ means the Federal Trade Commission.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
