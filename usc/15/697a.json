{"tag":"section","attrib":{"id":"id79306585-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a"},"text":null,"children":[{"tag":"num","attrib":{"value":"697a"},"text":"§ 697a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private debenture sales","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79306586-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other law, rule, or regulation, the Administration shall sell to investors, either publicly or by private placement, debentures pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":" as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79306587-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the program levels otherwise authorized by law for fiscal year 1986, an amount not to exceed $200,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79306588-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the program levels otherwise authorized by law for each of fiscal years 1987 and 1988, an amount not to exceed $425,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79306589-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All of the program levels authorized for fiscal year 1989 and subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7930658a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in any provision of law shall be construed to authorize the Federal Financing Bank to acquire—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7930658b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligation the payment of principal or interest on which at any time has been guaranteed in whole or in part under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":" and which is being sold pursuant to the provisions of the program authorized in this section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7930658c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligation which is an interest in any obligation described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7930658d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any obligation which is secured by, or substantially all of the value of which is attributable to, any obligation described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7930658e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tV/s504"},"text":"Pub. L. 85–699, title V, § 504","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXVIII/s18008/a"},"text":"Pub. L. 99–272, title XVIII, § 18008(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/366"},"text":"100 Stat. 366","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/72/s2"},"text":"Pub. L. 100–72, § 2","children":[],"tail":" "},{"tag":"date","attrib":{"date":"1987-07-11"},"text":"July 11, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/477"},"text":"101 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/590/tI/s112/a"},"text":"Pub. L. 100–590, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2996"},"text":"102 Stat. 2996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7930658f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79306590-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79306591-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/590"},"text":"Pub. L. 100–590","children":[],"tail":" inserted “Private debenture sales” as section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Notwithstanding any other law, rule, or regulation, the Administration shall conduct a pilot program involving the sale to investors, either publicly or by private placement, of debentures guaranteed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":" as follows—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) of the program levels otherwise authorized by law for fiscal year 1986, an amount not to exceed $200,000,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) of the program levels otherwise authorized by law for fiscal year 1987, an amount not to exceed $425,000,000; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) of the program levels otherwise authorized by law for fiscal year 1988, an amount not to exceed $425,000,000.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Nothing in any provision of law shall be construed to authorize the Federal Financing Bank to acquire—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any obligation the payment of principal or interest on which at any time has been guaranteed in whole or in part under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":" and which is being sold pursuant to the provisions of the pilot program authorized in this section,"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any obligation which is an interest in any obligation described in paragraph (1), or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) any obligation which is secured by, or substantially all of the value of which is attributable to, any obligation described in paragraph (1) or (2).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/72"},"text":"Pub. L. 100–72","children":[],"tail":" struck out “and” at end of par. (1), substituted “$425,000,000; and” for “$295,000,000.” in par. (2), and added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79306592-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79306593-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Small Business Administration to promulgate final rules and regulations to implement this section within 60 days of ","children":[{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/s18008/d/2"},"text":"section 18008(d)(2) of Pub. L. 99–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s697b"},"text":"section 697b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79306594-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXVIII/s18008/b"},"text":"Pub. L. 99–272, title XVIII, § 18008(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/367"},"text":"100 Stat. 367","children":[],"tail":", required the Small Business Administration to report to the President and Congress on the pilot program under former "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s697a"},"text":"15 U.S.C. 697a","children":[],"tail":" involving debenture sales to investors not later than 90 days after the date of the last debenture sale in each fiscal year, and unless a report was made by Oct. 1 of 1986 and 1987, the Administration was to make an interim report by such dates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
