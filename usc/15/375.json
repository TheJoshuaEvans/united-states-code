{"tag":"section","attrib":{"id":"id78a3b605-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375"},"text":null,"children":[{"tag":"num","attrib":{"value":"375"},"text":"§ 375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a3b606-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “attorney general”, with respect to a State, means the attorney general or other chief law enforcement officer of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b607-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cigarette","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a3b608-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cigarette”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a3b609-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2341"},"text":"section 2341 of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b60a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78a3b60b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" roll-your-own tobacco (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702"},"text":"section 5702 of title 26","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78a3b60c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic nicotine delivery system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a3b60d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cigarette” does not include a cigar (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5702"},"text":"section 5702 of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b60e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common carrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “common carrier” means any person (other than a local messenger service or the United States Postal Service) that holds itself out to the general public as a provider for hire of the transportation by water, land, or air of merchandise (regardless of whether the person actually operates the vessel, vehicle, or aircraft by which the transportation is provided) between a port or place and a port or place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b60f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “consumer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a3b610-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any person that purchases cigarettes or smokeless tobacco; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a3b611-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any person lawfully operating as a manufacturer, distributor, wholesaler, or retailer of cigarettes or smokeless tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b612-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery sale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “delivery sale” means any sale of cigarettes or smokeless tobacco to a consumer if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a3b613-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer submits the order for the sale by means of a telephone or other method of voice transmission, the mails, or the Internet or other online service, or the seller is otherwise not in the physical presence of the buyer when the request for purchase or order is made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a3b614-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cigarettes or smokeless tobacco are delivered to the buyer by common carrier, private delivery service, or other method of remote delivery, or the seller is not in the physical presence of the buyer when the buyer obtains possession of the cigarettes or smokeless tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b615-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery seller","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “delivery seller” means a person who makes a delivery sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b616-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic nicotine delivery system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “electronic nicotine delivery system”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a3b617-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any electronic device that, through an aerosolized solution, delivers nicotine, flavor, or any other substance to the user inhaling from the device;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a3b618-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a3b619-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an e-cigarette;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b61a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an e-hookah;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b61b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an e-cigar;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b61c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vape pen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b61d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advanced refillable personal vaporizer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b61e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic pipe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b61f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any component, liquid, part, or accessory of a device described in subparagraph (A), without regard to whether the component, liquid, part, or accessory is sold separately from the device; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a3b620-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include a product that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78a3b621-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" approved by the Food and Drug Administration for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78a3b622-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sale as a tobacco cessation product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78a3b623-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other therapeutic purpose; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78a3b624-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketed and sold solely for a purpose described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b625-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Indian country”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a3b626-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":", except that within the State of Alaska that term applies only to the Metlakatla Indian Community, Annette Island Reserve; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a3b627-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any other land held by the United States in trust or restricted status for one or more Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b628-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe”, “tribe”, or “tribal” refers to an Indian tribe as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":" or as listed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5131"},"text":"section 5131 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b629-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate commerce","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a3b62a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interstate commerce” means commerce between a State and any place outside the State, commerce between a State and any Indian country in the State, or commerce between points in the same State but through any place outside the State or through any Indian country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a3b62b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Into a State, place, or locality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sale, shipment, or transfer of cigarettes or smokeless tobacco that is made in interstate commerce, as defined in this paragraph, shall be deemed to have been made into the State, place, or locality in which such cigarettes or smokeless tobacco are delivered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b62c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual, corporation, company, association, firm, partnership, society, State government, local government, Indian tribal government, governmental organization of such a government, or joint stock company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b62d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b62e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smokeless tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “smokeless tobacco” means any finely cut, ground, powdered, or leaf tobacco, or other product containing tobacco, that is intended to be placed in the oral or nasal cavity or otherwise consumed without being combusted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b62f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tobacco tax administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tobacco tax administrator” means the State, local, or tribal official duly authorized to collect the tobacco tax or administer the tax law of a State, locality, or tribe, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a3b630-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s375/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “use” includes the consumption, storage, handling, or disposal of cigarettes or smokeless tobacco.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a3b631-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-19/ch699/s1"},"text":"Oct. 19, 1949, ch. 699, § 1","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/154/s2/a"},"text":"Pub. L. 111–154, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1088"},"text":"124 Stat. 1088","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVI/s602/a/1"},"text":"Pub. L. 116–260, div. FF, title VI, § 602(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3136"},"text":"134 Stat. 3136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a3b632-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a3b633-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78a3b634-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 375, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-19/ch699/s1"},"text":"act Oct. 19, 1949, ch. 699, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/884"},"text":"63 Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch695/s1"},"text":"Aug. 9, 1955, ch. 695, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/627"},"text":"69 Stat. 627","children":[],"tail":", set out definitions for this chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/154/s2/a"},"text":"Pub. L. 111–154, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1088"},"text":"124 Stat. 1088","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78a3b635-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s602/a/1/A"},"text":"Pub. L. 116–260, § 602(a)(1)(A)","children":[],"tail":", substituted “includes—” for “includes”, inserted subcl. (I) designation before “roll-your-own tobacco”, and added subcl. (II)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s602/a/1/B"},"text":"Pub. L. 116–260, § 602(a)(1)(B)","children":[],"tail":", (C), added par. (7) and redesignated former pars. (7) to (14) as (8) to (15), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a3b636-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78a3b637-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVI/s602/b"},"text":"Pub. L. 116–260, div. FF, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3137"},"text":"134 Stat. 3137","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dFF/tVI/s602/b"},"text":"“This section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a"},"text":"section 376a of this title","children":[],"tail":" and enacting provisions set out as a note under this section], and the amendments made by this section, shall take effect on the date that is 90 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78a3b638-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/154/s6"},"text":"Pub. L. 111–154, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1110"},"text":"124 Stat. 1110","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/154/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this Act [see Short Title of 2010 Amendment note below] shall take effect on the date that is 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"BATFE Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by section 4 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2343"},"text":"section 2343 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] shall take effect on the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78a3b639-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVI/s601"},"text":"Pub. L. 116–260, div. FF, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3136"},"text":"134 Stat. 3136","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dFF/tVI/s601"},"text":"“This title [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a"},"text":"section 376a of this title","children":[],"tail":" and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1716E"},"text":"section 1716E of Title 18","children":[],"tail":", Crimes and Criminal Procedure] may be cited as the ‘Preventing Online Sales of E-Cigarettes to Children Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id78a3b63a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/154/s1/a"},"text":"Pub. L. 111–154, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1087"},"text":"124 Stat. 1087","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/154/s1/a"},"text":"“This Act [enacting this section, sections 376a, 377, and 378 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1716E"},"text":"section 1716E of Title 18","children":[],"tail":", Crimes and Criminal Procedure, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s376"},"text":"section 376 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2343"},"text":"section 2343 of Title 18","children":[],"tail":", repealing former sections 375, 377, and 378 of this title, and enacting provisions set out as notes under this section] may be cited as the ‘Prevent All Cigarette Trafficking Act of 2009’ or ‘PACT Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78a3b63b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-19/ch699"},"text":"Act Oct. 19, 1949, ch. 699","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/884"},"text":"63 Stat. 884","children":[],"tail":", which is classified generally to this chapter, is popularly known as the Jenkins Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id78a3b63c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/154/s7"},"text":"Pub. L. 111–154, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1111"},"text":"124 Stat. 1111","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/154/s7"},"text":"“If any provision of this Act [see Short Title of 2010 Amendment note above], or any amendment made by this Act, or the application thereof to any person or circumstance, is held invalid, the remainder of the Act and the application of the Act to any other person or circumstance shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78a3b63d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVI/s602/c"},"text":"Pub. L. 116–260, div. FF, title VI, § 602(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3137"},"text":"134 Stat. 3137","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dFF/tVI/s602/c"},"text":"“Nothing in this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a"},"text":"section 376a of this title","children":[],"tail":" and enacting provisions set out as a note under this section], or an amendment made by this section, may be construed to affect or otherwise alter any provision of the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.), including its implementing regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78a3b63e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/154/s1/b"},"text":"Pub. L. 111–154, § 1(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1087"},"text":"124 Stat. 1087","children":[],"tail":", 1088, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/154/s1/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of illegal cigarettes and smokeless tobacco products significantly reduces Federal, State, and local government revenues, with Internet sales alone accounting for billions of dollars of lost Federal, State, and local tobacco tax revenue each year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hezbollah, Hamas, al Qaeda, and other terrorist organizations have profited from trafficking in illegal cigarettes or counterfeit cigarette tax stamps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terrorist involvement in illicit cigarette trafficking will continue to grow because of the large profits such organizations can earn;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of illegal cigarettes and smokeless tobacco over the Internet, and through mail, fax, or phone orders, makes it cheaper and easier for children to obtain tobacco products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the majority of Internet and other remote sales of cigarettes and smokeless tobacco are being made without adequate precautions to protect against sales to children, without the payment of applicable taxes, and without complying with the nominal registration and reporting requirements in existing Federal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unfair competition from illegal sales of cigarettes and smokeless tobacco is taking billions of dollars of sales away from law-abiding retailers throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with rising State and local tobacco tax rates, the incentives for the illegal sale of cigarettes and smokeless tobacco have increased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of active tobacco investigations being conducted by the Bureau of Alcohol, Tobacco, Firearms, and Explosives rose to 452 in 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Internet vendors in the United States and in foreign countries that sell cigarettes and smokeless tobacco to buyers in the United States increased from only about 40 in 2000 to more than 500 in 2005; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intrastate sale of illegal cigarettes and smokeless tobacco over the Internet has a substantial effect on interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this Act [see Short Title of 2010 Amendment note above] to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require Internet and other remote sellers of cigarettes and smokeless tobacco to comply with the same laws that apply to law-abiding tobacco retailers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create strong disincentives to illegal smuggling of tobacco products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide government enforcement officials with more effective enforcement tools to combat tobacco smuggling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make it more difficult for cigarette and smokeless tobacco traffickers to engage in and profit from their illegal activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase collections of Federal, State, and local excise taxes on cigarettes and smokeless tobacco; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent and reduce youth access to inexpensive cigarettes and smokeless tobacco through illegal Internet or contraband sales.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78a3b63f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exclusions Regarding Indian Tribes and Tribal Matters","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/154/s5"},"text":"Pub. L. 111–154, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1109"},"text":"124 Stat. 1109","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/154/s5"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act [see Short Title of 2010 Amendment note above] or the amendments made by this Act shall be construed to amend, modify, or otherwise affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agreements, compacts, or other intergovernmental arrangements between any State or local government and any government of an Indian tribe (as that term is defined in section 4(e) of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b/e"},"text":"25 U.S.C. 450b(e)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"25 U.S.C. 5304(e)","children":[],"tail":"] relating to the collection of taxes on cigarettes or smokeless tobacco sold in Indian country;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State laws that authorize or otherwise pertain to any such intergovernmental arrangements or create special rules or procedures for the collection of State, local, or tribal taxes on cigarettes or smokeless tobacco sold in Indian country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any limitations under Federal or State law, including Federal common law and treaties, on State, local, and tribal tax and regulatory authority with respect to the sale, use, or distribution of cigarettes and smokeless tobacco by or to Indian tribes, tribal members, tribal enterprises, or in Indian country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal law, including Federal common law and treaties, regarding State jurisdiction, or lack thereof, over any tribe, tribal members, tribal enterprises, tribal reservations, or other lands held by the United States in trust for one or more Indian tribes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State or local government authority to bring enforcement actions against persons located in Indian country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination of Law Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act or the amendments made by this Act shall be construed to inhibit or otherwise affect any coordinated law enforcement effort by 1 or more States or other jurisdictions, including Indian tribes, through interstate compact or otherwise, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the administration of tobacco product laws or laws pertaining to interstate sales or other sales of tobacco products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the seizure of tobacco products or other property related to a violation of such laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes cooperative programs for the administration of such laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of State and Local Governments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this Act or the amendments made by this Act shall be construed to authorize, deputize, or commission States or local governments as instrumentalities of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement Within Indian Country","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this Act or the amendments made by this Act shall prohibit, limit, or restrict enforcement by the Attorney General of the United States of this Act or an amendment made by this Act within Indian country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ambiguity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any ambiguity between the language of this section or its application and any other provision of this Act shall be resolved in favor of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Indian country’ has the meaning given that term in section 1 of the Jenkins Act [Act of ","children":[{"tag":"date","attrib":{"date":"1949-10-19"},"text":"October 19, 1949","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s375"},"text":"15 U.S.C. 375","children":[],"tail":"], as amended by this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘tribal enterprise’ means any business enterprise, regardless of whether incorporated or unincorporated under Federal or tribal law, of an Indian tribe or group of Indian tribes.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
