{"tag":"section","attrib":{"id":"id79b107e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681t"},"text":"§ 1681t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to State laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b107ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b) and (c), this subchapter does not annul, alter, affect, or exempt any person subject to the provisions of this subchapter from complying with the laws of any State with respect to the collection, distribution, or use of any information on consumers, or for the prevention or mitigation of identity theft, except to the extent that those laws are inconsistent with any provision of this subchapter, and then only to the extent of the inconsistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b107eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No requirement or prohibition may be imposed under the laws of any State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b107ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to any subject matter regulated under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b107ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of this title","children":[],"tail":", relating to the prescreening of consumer reports;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b107ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681i"},"text":"section 1681i of this title","children":[],"tail":", relating to the time by which a consumer reporting agency must take any action, including the provision of notification to a consumer or other person, in any procedure related to the disputed accuracy of information in a consumer’s file, except that this subparagraph shall not apply to any State law in effect on "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b107ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681m"},"text":"section 1681m of this title","children":[],"tail":", relating to the duties of a person who takes any adverse action with respect to a consumer;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b107f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681t/b/1/D"},"text":null,"children":[{"tag":"num","at