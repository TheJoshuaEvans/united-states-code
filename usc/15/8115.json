{"tag":"section","attrib":{"id":"id7a808cbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115"},"text":null,"children":[{"tag":"num","attrib":{"value":"8115"},"text":"§ 8115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings and repeals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a808cc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition from NIPLECC to IPEC","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808cc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808cc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuity of performance of duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon confirmation by the Senate, and notwithstanding paragraph (1), the IPEC may use the services and personnel of the National Intellectual Property Law Enforcement Coordination Council, for such time as is reasonable, to perform any functions or duties which in the discretion of the IPEC are necessary to facilitate the orderly transition of any functions or duties transferred from the Council to the IPEC pursuant to any provision of this Act or any amendment made by this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808cc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current authorities not affected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (a), nothing in this subchapter shall alter the authority of any department or agency of the United States (including any independent agency) that relates to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808cc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation and prosecution of violations of laws that protect intellectual property rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808cc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative enforcement, at the borders of the United States, of laws that protect intellectual property rights; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808cc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States trade agreements program or international trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808cc7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808cc8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall derogate from the powers, duties, and functions of any of the agencies, departments, or other entities listed or included under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8111/b/3/A"},"text":"section 8111(b)(3)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fcc9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be construed to transfer authority regarding the control, use, or allocation of law enforcement resources, or the initiation or prosecution of individual cases or types of cases, from the responsible law enforcement department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a82fcca-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/tIII/s305"},"text":"Pub. L. 110–403, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4270"},"text":"122 Stat. 4270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a82fccb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a82fccc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail