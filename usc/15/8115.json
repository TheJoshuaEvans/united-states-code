110–403","children":[],"tail":". Subsec. (a)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/403/s305"},"text":"section 305 of Pub. L. 110–403","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1128"},"text":"section 1128 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
