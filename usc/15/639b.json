{"tag":"section","attrib":{"id":"id7900a28d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s639b"},"text":null,"children":[{"tag":"num","attrib":{"value":"639b"},"text":"§ 639b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7900a28e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s639b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with oversight requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7900a28f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s639b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), on and after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Administrator shall comply with any data or information requests or inquiries made by the Comptroller General of the United States not later than 15 days (or such later date as the Comptroller General may specify) after receiving the request or inquiry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7900a290-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s639b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator is unable to comply with a request or inquiry described in paragraph (1) before the applicable date described in that paragraph, the Administrator shall, before such applicable date, submit to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives a notification that includes a detailed justification for the inability of the Administrator to comply with the request or inquiry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7900a291-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s639b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 120 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and not less than twice each year thereafter until the date that is 2 years after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Administrator and the Secretary of the Treasury shall testify before the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives regarding implementation of this Act and the amendments made by this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7900a292-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIII/s321"},"text":"Pub. L. 116–260, div. N, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2017"},"text":"134 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7900a293-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7900a294-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7900a295-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), probably means title III of div. N of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1993"},"text":"134 Stat. 1993","children":[],"tail":", known as the Economic Aid to Hard-Hit Small Businesses, Nonprofits, and Venues Act. For complete classification of title III to the Code, see Short Title of 2020 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7900a296-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Economic Aid to Hard-Hit Small Businesses, Nonprofits, and Venues Act, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7900a297-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7900a298-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", and applicable to loans and grants made on or after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s348"},"text":"section 348 of Pub. L. 116–260","children":[],"tail":", set out as an Effective Date of 2020 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7900a299-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Administrator”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Administrator” means the Administrator of the Small Business Administration, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s302"},"text":"section 302 of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
