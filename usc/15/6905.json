{"tag":"section","attrib":{"id":"id7a68beed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905"},"text":null,"children":[{"tag":"num","attrib":{"value":"6905"},"text":"§ 6905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of assistance; subgrants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a68beee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68beef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall allocate assistance from the Administration under this chapter to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68bef0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6903/1"},"text":"section 6903(1) of this title","children":[],"tail":" are funded using not less than 75 percent of amounts made available for such assistance; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bef1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6903/2"},"text":"section 6903(2) of this title","children":[],"tail":" are funded using not less than 15 percent of amounts made available for such assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bef2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on individual assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No single person may receive more than 10 percent of the total funds appropriated under this chapter in a single fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bef3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeted assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that not less than 50 percent of the grants made under this chapter are used to benefit very low-income persons, including those residing on Indian reservations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bef4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bef5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified organization receiving assistance under this chapter may provide grants using that assistance to qualified small and emerging microenterprise organizations and programs, subject to such rules and regulations as the Administrator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bef6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 7.5 percent of assistance received by a qualified organization under this chapter may be used for administrative expenses in connection with the making of subgrants under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bef7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this chapter, the Administrator shall ensure that grant recipients include both large and small microenterprise organizations, serving urban, rural, and Indian tribal communities serving diverse populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bef8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on preferential consideration of certain SBA program participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this chapter, the Administrator shall ensure that any application made by a qualified organization that is a participant in the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/m"},"text":"section 636(m) of this title","children":[],"tail":" does not receive preferential consideration over applications from other qualified organizations that are not participants in such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bef9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s176"},"text":"Pub. L. 103–325, title I, § 176","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1473"},"text":"113 Stat. 1473","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
