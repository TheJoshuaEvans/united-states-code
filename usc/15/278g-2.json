{"tag":"section","attrib":{"id":"id7890a30a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"278g–2"},"text":"§ 278g–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-doctoral fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7890a30b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute and the National Academy of Sciences, jointly, shall establish and conduct a post-doctoral fellowship program, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a30c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The post-doctoral fellowship program shall include not less than 20 new fellows per fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a30d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In evaluating applications for post-doctoral fellowships under this section, the Director of the Institute and the President of the National Academy of Sciences shall give consideration to the goal of promoting the participation of individuals identified in sections 1885a and 1885b of title 42 in research areas supported by the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7890a30e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s19"},"text":"Mar. 3, 1901, ch. 872, § 19","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/574/s8/a"},"text":"Pub. L. 99–574, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3238"},"text":"100 Stat. 3238","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/a/1"},"text":"Pub. L. 100–418, title V, § 5115(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/113/s8/3"},"text":"Pub. L. 104–113, § 8(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-07"},"text":"Mar. 7, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/779"},"text":"110 Stat. 779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII/s3015"},"text":"Pub. L. 110–69, title III, § 3015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/599"},"text":"121 Stat. 599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV"},"text":"Pub. L. 111–358, title IV","children":[],"tail":", §§ 406(b), 407(a), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4004"},"text":"124 Stat. 4004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s306/c"},"text":"Pub. L. 114–329, title III, § 306(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3010"},"text":"130 Stat. 3010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7890a30f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7890a310-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7890a311-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 19 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872"},"text":"act Mar. 3, 1901, ch. 872","children":[],"tail":", was renumbered section 32 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278q"},"text":"section 278q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7890a312-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Institute shall establish and conduct a post-doctoral fellowship program, subject to the availability of appropriations, which shall be organized and carried out in substantially the same manner as the National Academy of Sciences/National Research Council Post-Doctoral Research Associate Program that was in effect prior to 1986, and which shall include not less than twenty nor more than 120 new fellows per fiscal year. In evaluating applications for fellowships under this section, the Director shall give consideration to the goal of promoting the participation of underrepresented minorities in research areas supported by the Institute.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s407/a"},"text":"Pub. L. 111–358, § 407(a)","children":[],"tail":", struck out “, in conjunction with the National Academy of Sciences,” after “The Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s406/b"},"text":"Pub. L. 111–358, § 406(b)","children":[],"tail":", inserted at end “In evaluating applications for fellowships under this section, the Director shall give consideration to the goal of promoting the participation of underrepresented minorities in research areas supported by the Institute.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" substituted “nor more than 120 new fellows” for “nor more than 60 new fellows”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113"},"text":"Pub. L. 104–113","children":[],"tail":" inserted “, subject to the availability of appropriations,” after “post-doctoral fellowship program” and substituted “nor more than 60” for “nor more than forty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “Institute” for “National Bureau of Standards”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7890a313-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7890a314-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/574/s8/b"},"text":"Pub. L. 99–574, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3238"},"text":"100 Stat. 3238","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/574/s8/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall be effective ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id7890a315-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause for Post-Doctoral Fellowship Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s306/d/2"},"text":"Pub. L. 114–329, title III, § 306(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3010"},"text":"130 Stat. 3010","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/329/tIII/s306/d/2"},"text":"“The amendment made by subsection (c) of this section [amending this section] shall not affect any award of a post-doctoral fellowship or other form of financial assistance made under section 19 of the National Institute of Standards and Technology Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–2"},"text":"15 U.S.C. 278g–2","children":[],"tail":") before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":"]. Such awards shall continue to be subject to the requirements to which such funds were subject under that section before the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
