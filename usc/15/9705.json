{"tag":"section","attrib":{"id":"id7ab29a06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705"},"text":null,"children":[{"tag":"num","attrib":{"value":"9705"},"text":"§ 9705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving National Oceanic and Atmospheric Administration communication of future flood risks and hazardous flash flood events","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab29a07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of flash flood watches and warnings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29a08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", the Administrator shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29a09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab29a0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flash flood watches and warnings of the National Weather Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29a0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information delivery to support preparation and responses to floods; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report on the findings of the Administrator with respect to the assessment required by subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment required by paragraph (1)(A) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29a0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An evaluation of whether the watches, warnings, and information described in paragraph (1)(A) effectively—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab29a0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate risk to the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29a10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform action to prevent loss of life and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29a11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform action to support flood preparation and response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29a12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver information in a manner designed to lead to appropriate action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b)(2), such recommendations as the Administrator may have for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab29a14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislative and administrative action to improve the watches and warnings described in paragraph (1)(A)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29a15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such research as the Administrator considers necessary to address the focus areas described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment required by paragraph (1)(A) shall focus on the following areas:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29a17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ways to communicate the risks posed by hazardous flash flood events to the public that are most likely to result in informed decision making regarding the mitigation of those risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ways to provide actionable geographic information to the recipient of a watch or warning for a flash flood, including partnering with emergency response agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluation of information delivery to support the preparation for and response to floods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the assessment required by paragraph (1)(A), the Administrator shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29a1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals in the academic sector, including individuals in the field of social and behavioral sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other weather services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" media outlets and other entities that distribute the watches and warnings described in paragraph (1)(A)(i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" floodplain managers and emergency planners and responders, including State, local, and Tribal emergency management agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other government users of the watches and warnings described in paragraph (1)(A)(i), including the Federal Highway Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other Federal agencies as the Administrator determines rely on watches and warnings regarding flash floods for operational decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Academy of Sciences","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall engage with the National Academy of Sciences, as the Administrator considers necessary and practicable, including by contracting with the National Research Council to review the scientific and technical soundness of the assessment required by paragraph (1)(A), including the recommendations under paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the assessment required by paragraph (1)(A), the Administrator shall use such methodologies as the Administrator considers are generally accepted by the weather enterprise, including social and behavioral sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29a23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements to flash flood watches and warnings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29a24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Based on the assessment required by subsection (a)(1)(A), the Administrator shall make such improvements to the watches and warnings described in that subsection as the Administrator considers necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29a25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the communication of the risks posed by hazardous flash flood events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide actionable geographic information to the recipient of a watch or warning for a flash flood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the assessment required by subsection (a)(1)(A), the Administrator shall ensure that any recommendation under subsection (a)(2)(B) that the Administrator considers a major change—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29a28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is validated by social and behavioral science using a generalizable sample;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts for the needs of various demographics, vulnerable populations, and geographic regions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responds to the needs of Federal, State, local, and Tribal government partners and media partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts for necessary changes to federally operated watch and warning propagation and dissemination infrastructure and protocols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29a2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29a2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Watch; warning","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29a2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the terms “watch” and “warning”, with respect to a hazardous flash flood event, mean products issued by the National Oceanic and Atmospheric Administration, intended for use by the general public—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab29a2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alert the general public to the potential for or presence of the event; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29a30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inform action to prevent loss of life and property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “watch” and “warning” do not include technical or specialized meteorological and hydrological forecasts, outlooks, or model guidance products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weather enterprise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “weather enterprise” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8501"},"text":"section 8501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab29a33-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s6"},"text":"Pub. L. 117–316, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4410"},"text":"136 Stat. 4410","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
