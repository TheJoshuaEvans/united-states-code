{"tag":"section","attrib":{"id":"id7a1547a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115"},"text":null,"children":[{"tag":"num","attrib":{"value":"3115"},"text":"§ 3115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth employment policies and programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1547aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1547ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That ","children":[{"tag":"ref","attrib":{"idref":"fn002481"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002481"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" serious unemployment and economic disadvantage of a unique nature exist among youths even under generally favorable economic conditions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1547ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that this group constitutes a substantial portion of the Nation’s unemployment, and that this significantly contributes to crime, alcoholism and drug abuse, and other social and economic problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1547ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that many youths have special employment needs and problems which, if not promptly addressed, will substantially contribute to more severe unemployment problems in the long run.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1547ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement and expansion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent deemed necessary in fulfillment of the purposes of this chapter, the President shall improve and expand existing youth employment programs, recommending legislation where required. In formulating any such program, the President shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1547af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions designed to fully coordinate youth employment activities with other employment and training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1547b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a smoother transition from school to work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1547b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare disadvantaged and other youths with employability handicaps for regular self-sustaining employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1547b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop realistic methods for combining training with work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1547b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3115/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop provisions designed to attract structurally unemployed youth into productive full-time employment through incentives to private and independent sector businesses; ","children":[{"tag":"ref","attrib":{"idref":"fn002482"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002482"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1547b4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/523/tII/s205"},"text":"Pub. L. 95–523, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1901"},"text":"92 Stat. 1901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1547b5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1547b6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1547b7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (b), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
