{"tag":"section","attrib":{"id":"id79293a7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689m"},"text":null,"children":[{"tag":"num","attrib":{"value":"689m"},"text":"§ 689m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional penalties for noncompliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79293a80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any New Markets Venture Capital company that violates or fails to comply with any of the provisions of this chapter, of any regulation issued under this chapter, or of any participation agreement entered into under this chapter, the Administrator may in accordance with this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" void the participation agreement between the Administrator and the company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause the company to forfeit all of the rights and privileges derived by the company from this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication of noncompliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the Administrator may cause a New Markets Venture Capital company to forfeit rights or privileges under subsection (a), a court of the United States of competent jurisdiction must find that the company committed a violation, or failed to comply, in a cause of action brought for that purpose in the district, territory, or other place subject to the jurisdiction of the United States, in which the principal office of the company is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parties authorized to file causes of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each cause of action brought by the United States under this subsection shall be brought by the Administrator or by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293a86-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s364"},"text":"Pub. L. 85–699, title III, § 364","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–663.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79293a87-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79293a88-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79293a89-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (a), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
