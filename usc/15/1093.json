{"tag":"section","attrib":{"id":"id795db6e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1093"},"text":null,"children":[{"tag":"num","attrib":{"value":"1093"},"text":"§ 1093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration certificates for marks on principal and supplemental registers to be different","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The certificates of registration for marks registered on the supplemental register shall be conspicuously different from certificates issued for marks registered on the principal register.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795db6e3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title II, § 25, "},{"tag":"ref","attrib":{"href":"/us/stat/60/436"},"text":"60 Stat. 436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795db6e4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id795db6e5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id795db6e6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal and Effect on Existing Rights","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Repeal of inconsistent provisions, effect of this chapter on pending proceedings and existing registrations and rights under prior acts, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
