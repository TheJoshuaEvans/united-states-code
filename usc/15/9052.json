{"tag":"section","attrib":{"id":"id7a9f8627-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052"},"text":null,"children":[{"tag":"num","attrib":{"value":"9052"},"text":"§ 9052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional temporary relief from current expected credit losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9f8628-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8629-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate Federal banking agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Federal banking agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f862a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f862b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the National Credit Union Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f862c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insured depository institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “insured depository institution”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f862d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f862e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a credit union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f862f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary relief from CECL standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, no insured depository institution, bank holding company, or any affiliate thereof shall be required to comply with the Financial Accounting Standards Board Accounting Standards Update No. 2016–13 (“Measurement of Credit Losses on Financial Instruments”), including the current expected credit losses methodology for estimating allowances for credit losses, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and ending on the earlier of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8630-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the fiscal year of the insured depository institution, bank holding company, or any affiliate thereof that begins after the date on which the national emergency concerning the novel coronavirus disease (COVID–19) outbreak declared by the President on ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":" under the National Emergencies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.) terminates; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8631-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9052/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9f8632-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4014"},"text":"Pub. L. 116–136, div. A, title IV, § 4014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/480"},"text":"134 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tV/s540/a/1"},"text":"Pub. L. 116–260, div. N, title V, § 540(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2090"},"text":"134 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9f8633-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9f8634-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9f8635-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Emergencies Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412"},"text":"Pub. L. 94–412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":", which is classified principally to chapter 34 (§ 1601 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"section 1601 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a9f8636-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s540/a/1/A"},"text":"Pub. L. 116–260, § 540(a)(1)(A)","children":[],"tail":", inserted “the first day of the fiscal year of the insured depository institution, bank holding company, or any affiliate thereof that begins aft