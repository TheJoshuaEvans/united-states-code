{"tag":"section","attrib":{"id":"id7a57f59a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307c"},"text":"§ 6307c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctioning organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a57f59b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objective criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 2 years after ","children":[{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", the Association of Boxing Commissions shall develop and shall approve by a vote of no less than a majority of its member State boxing commissioners, guidelines for objective and consistent written criteria for the ratings of professional boxers. It is the sense of the Congress that sanctioning bodies and State boxing commissions should follow these ABC guidelines."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f59c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sanctioning organization shall not be entitled to receive any compensation, directly or indirectly, in connection with a boxing match, until it provides the boxers with notice that the sanctioning organization shall, within 7 days after receiving a request from a boxer questioning that organization’s rating of the boxer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f59d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the boxer a written explanation of the organization’s criteria, its rating of the boxer, and the rationale or basis for its rating (including a response to any specific questions submitted by the boxer); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f59e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a copy of its explanation to the Association of Boxing Commissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f59f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of change in rating","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sanctioning organization shall not be entitled to receive any compensation, directly or indirectly, in connection with a boxing match, until, with respect to a change in the rating of a boxer previously rated by such organization in the top 10 boxers, the organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" posts a copy, within 7 days of such change, on its Internet website or home page, if any, including an explanation of such change, for a period of not less than 30 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a copy of the rating change and explanation to an association to which at least a majority of the State boxing commissions belong.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Trade Commission filing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sanctioning organization shall not be entitled to receive any compensation directly or indirectly in connection with a boxing match unless, not later than January 31 of each year, it submits to the Federal Trade Commission and to the ABC—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete description of the organization’s ratings criteria, policies, and general sanctioning fee schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bylaws of the organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appeals procedure of the organization for a boxer’s rating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list and business address of the organization’s officials who vote on the ratings of boxers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format; updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sanctioning organization shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the information required under paragraph (1) in writing, and, for any document greater than 2 pages in length, also in electronic form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly notify the Federal Trade Commission of any material change in the information submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Trade Commission to make information available to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission shall make information received under this subsection available to the public. The Commission may assess sanctioning organizations a fee to offset the costs it incurs in processing the information and making it available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet alternative","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In lieu of submitting the information required by paragraph (1) to the Federal Trade Commission, a sanctioning organization may provide the information to the public by maintaining a website on the Internet that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is readily accessible by the general public using generally available search engines and does not require a password or payment of a fee for full access to all the information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains all the information required to be submitted to the Federal Trade Commission by paragraph (1) in an easy to search and use format; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307c/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is updated whenever there is a material change in the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f5b0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s11"},"text":"Pub. L. 104–272, § 11","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/2"},"text":"Pub. L. 106–210, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/323"},"text":"114 Stat. 323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f5b1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a57f5b2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a57f5b3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s11"},"text":"section 11 of Pub. L. 104–272","children":[],"tail":" was renumbered section 19 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6310"},"text":"section 6310 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
