{"tag":"section","attrib":{"id":"id7a9d3be7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027"},"text":null,"children":[{"tag":"num","attrib":{"value":"9027"},"text":"§ 9027.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary financing of short-time compensation agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9d3be8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal-State agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3be9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State which desires to do so may enter into, and participate in, an agreement under this section with the Secretary provided that such State’s law does not provide for the payment of short-time compensation under a short-time compensation program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ability to terminate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State which is a party to an agreement under this section may, upon providing 30 days’ written notice to the Secretary, terminate such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3beb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of Federal-State agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agreement under this section shall provide that the State agency of the State will make payments of short-time compensation under a plan approved by the State. Such plan shall provide that payments are made in accordance with the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on plans","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3bee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General payment limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A short-time compensation plan approved by a State shall not permit the payment of short-time compensation to an individual by the State during a benefit year in excess of 26 times the amount of regular compensation (including dependents’ allowances) under the State law payable to such individual for a week of total unemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3bef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A short-time compensation plan approved by a State shall not provide payments to an individual if such individual is employed by the participating employer on a seasonal, temporary, or intermittent basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer payment of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any short-time compensation plan entered into by an employer must provide that the employer will pay the State an amount equal to one-half of the amount of short-time compensation paid under such plan. Such amount shall be deposited in the State’s unemployment fund and shall not be used for purposes of calculating an employer’s contribution rate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3303/a/1"},"text":"section 3303(a)(1) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be paid to each State with an agreement under this section an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3bf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of the amount of short-time compensation paid to individuals by the State pursuant to such agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3bf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional administrative expenses incurred by the State by reason of such agreement (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments made to a State under paragraph (1) shall be payable by way of reimbursement in such amounts as the Secretary estimates the State will be entitled to receive under this section for each calendar month, reduced or increased, as the case may be, by any amount by which the Secretary finds that the Secretary’s estimates for any prior calendar month were greater or less than the amounts which should have been paid to the State. Such estimates may be made on the basis of such statistical, sampling, or other method as may be agreed upon by the Secretary and the State agency of the State involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are appropriated, out of moneys in the Treasury not otherwise appropriated, such sums as may be necessary for purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall from time to time certify to the Secretary of the Treasury for payment to each State the sums payable to such State under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into under this section shall apply to weeks of unemployment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on or after the date on which such agreement is entered into; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bfa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on or before ","children":[{"tag":"date","attrib":{"date":"2021-09-06"},"text":"September 6, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bfb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State has entered into an agreement under this section and subsequently enacts a State law providing for the payment of short-time compensation under a short-time compensation program that meets the definition of such a program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":", the State—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bfc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be eligible for payments under this section for weeks of unemployment beginning after the effective date of such State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bfd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9026/b/2"},"text":"section 9026(b)(2) of this title","children":[],"tail":", shall be eligible to receive payments under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9026"},"text":"section 9026 of this title","children":[],"tail":" after the effective date of such State law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bfe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9027/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State; State agency; State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “State”, “State agency”, and “State law” have the meanings given those terms in section 205 of the Federal-State Extended Unemployment Compensation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"26 U.S.C. 3304","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9d3c01-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2109"},"text":"Pub. L. 116–136, div. A, title II, § 2109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/329"},"text":"134 Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tII/s208"},"text":"Pub. L. 116–260, div. N, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1956"},"text":"134 Stat. 1956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9018"},"text":"Pub. L. 117–2, title IX, § 9018","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/120"},"text":"135 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9d3c02-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9d3c03-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9d3c04-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205 of the Federal-State Extended Unemployment Compensation Act of 1970, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s205"},"text":"section 205 of Pub. L. 91–373","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a9d3c05-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-09-06"},"text":"September 6, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2021-03-14"},"text":"March 14, 2021","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-03-14"},"text":"March 14, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
