{"tag":"section","attrib":{"id":"id7a5cd855-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6613"},"text":null,"children":[{"tag":"num","attrib":{"value":"6613"},"text":"§ 6613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of special masters or magistrate judges for Y2K actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any district court of the United States in which a Y2K action is pending may appoint a special master or a magistrate judge to hear the matter and to make findings of fact and conclusions of law in accordance with Rule 53 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a5cd856-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s14"},"text":"Pub. L. 106–37, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/201"},"text":"113 Stat. 201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a5cd857-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a5cd858-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a5cd859-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Rule 53 of the Federal Rules of Civil Procedure, referred to in text, is set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
