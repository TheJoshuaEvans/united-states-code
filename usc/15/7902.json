{"tag":"section","attrib":{"id":"id7a7e1ba5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7902"},"text":null,"children":[{"tag":"num","attrib":{"value":"7902"},"text":"§ 7902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on bringing of qualified civil liability actions in Federal or State court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7e1ba6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified civil liability action may not be brought in any Federal or State court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7e1ba7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal of pending actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified civil liability action that is pending on ","children":[{"tag":"date","attrib":{"date":"2005-10-26"},"text":"October 26, 2005","children":[],"tail":", shall be immediately dismissed by the court in which the action was brought or is currently pending."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7e1ba8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/92/s3"},"text":"Pub. L. 109–92, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-10-26"},"text":"Oct. 26, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2096"},"text":"119 Stat. 2096","children":[],"tail":".)"}],"tail":"\n"}],