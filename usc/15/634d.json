{"tag":"section","attrib":{"id":"id78c03f29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634d"},"text":null,"children":[{"tag":"num","attrib":{"value":"634d"},"text":"§ 634d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff and powers of Office of Advocacy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of sections 634a to 634g of this title, the Chief Counsel for Advocacy may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78c03f2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ and fix the compensation of such additional staff personnel as is deemed necessary, without regard to the provisions of title 5, governing appointments in the competitive service, and without regard to chapter 51, and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates but at rates not in excess of the lowest rate for GS–15 of the General Schedule: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That not more than 14 staff personnel at any one time may be employed and compensated at a rate not in excess of GS–15, step 10, of the General Schedule;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure temporary and intermittent services to the same extent as is authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with experts and authorities in the fields of small business investment, venture capital, investment and commercial banking and other comparable financial institutions involved in the financing of business, and with individuals with regulatory, legal, economic, or financial expertise, including members of the academic community, and individuals who generally represent the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the services of the National Advisory Council established pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/b/13"},"text":"section 637(b)(13) of this title","children":[],"tail":" and in accordance with the provisions of such statute, also appoint such other advisory boards or committees as is reasonably appropriate and necessary to carry out the provisions of sections 634a to 634g of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold hearings and sit and act at such times and places as he may deem advisable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78c03f2f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305/tII/s204"},"text":"Pub. L. 94–305, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/669"},"text":"90 Stat. 669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/302/tIV/s402"},"text":"Pub. L. 96–302, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-02"},"text":"July 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/850"},"text":"94 Stat. 850","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tVI"},"text":"Pub. L. 103–403, title VI","children":[],"tail":", §§ 605(b), 610, "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4203"},"text":"108 Stat. 4203","children":[],"tail":", 4204.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c03f30-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c03f31-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78c03f32-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in par. (1), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c03f33-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78c03f34-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/403"},"text":"Pub. L. 103–403","children":[],"tail":", §§ 605(b), 610(1), in introductory provisions substituted “provisions of sections 634a to 634g of this title, the Chief” for “provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s634b"},"text":"section 634b of this title","children":[],"tail":", after consultation with and subject to the approval of the Administrator, the Chief”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/403/s610/2"},"text":"Pub. L. 103–403, § 610(2)","children":[],"tail":", substituted “14” for “ten” before “staff personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/302"},"text":"Pub. L. 96–302","children":[],"tail":" authorized employment at any one time of ten staff personnel at rate of compensation not in excess of GS–15, step 10, of the General Schedule."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78c03f35-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78c03f36-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/302"},"text":"Pub. L. 96–302","children":[],"tail":" effective "},{"tag":"date","attrib":{"