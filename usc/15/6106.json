{"tag":"section","attrib":{"id":"id7a533b42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106"},"text":null,"children":[{"tag":"num","attrib":{"value":"6106"},"text":"§ 6106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “attorney general” means the chief legal officer of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any State of the United States, the District of Columbia, Puerto Rico, the Northern Mariana Islands, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “telemarketing” means a plan, program, or campaign which is conducted to induce purchases of goods or services, or a charitable contribution, donation, or gift of money or any other thing of value, by use of one or more telephones and which involves more than one interstate telephone call. The term does not include the solicitation of sales through the mailing of a catalog which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a written description, or illustration of the goods or services offered for sale,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the business address of the seller,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes multiple pages of written material or illustrations, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6106/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been issued not less frequently than once a year,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"where the person making the solicitation does not solicit customers by telephone but only receives calls initiated by customers in response to the catalog and during those calls takes orders only without further solicitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a533b4b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/297/s7"},"text":"Pub. L. 103–297, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-16"},"text":"Aug. 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1550"},"text":"108 Stat. 1550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1011/b/3"},"text":"Pub. L. 107–56, title X, § 1011(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/396"},"text":"115 Stat. 396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a533b4c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a533b4d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a533b4e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" inserted “, or a charitable contribution, donation, or gift of money or any other thing of value,” after “services” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
