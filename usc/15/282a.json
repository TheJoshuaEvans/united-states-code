{"tag":"section","attrib":{"id":"id789c89b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s282a"},"text":null,"children":[{"tag":"num","attrib":{"value":"282a"},"text":"§ 282a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of emerging technologies requiring research in metrology","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board of Assessment of the National Institute of Standards and Technology shall include, as part of its annual review, an assessment of emerging technologies which are expected to require research in metrology to keep the Institute abreast of its mission, including process and quality control, engineering databases, advanced materials, electronics and fiber optics, bioprocess engineering, and advanced computing concepts. Such review shall include estimates of the cost of the required effort, required staffing levels, appropriate interaction with industry, including technology transfer, and the period over which the research will be required.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789c89b1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5163/a"},"text":"Pub. L. 100–418, title V, § 5163(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1450"},"text":"102 Stat. 1450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789c89b2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789c89b3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id789c89b4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s5163/a"},"text":"section 5163(a) of Pub. L. 100–418","children":[],"tail":". Section 5163(b)–(d) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s272"},"text":"section 272 of this title","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710"},"text":"section 3710 of this title","children":[],"tail":", and enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1533"},"text":"section 1533 of this title","children":[],"tail":", respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id789c89b5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 282a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/574/s7"},"text":"Pub. L. 99–574, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3237"},"text":"100 Stat. 3237","children":[],"tail":", consisted of provisions substantially identical to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
