{"tag":"section","attrib":{"id":"id7873f3c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–47"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–47"},"text":"§ 80a–47.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of controlling persons; preventing compliance with subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7873f3c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–47/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person, directly or indirectly, to cause to be done any act or thing through or by means of any other person which it would be unlawful for such person to do under the provisions of this subchapter or any rule, regulation, or order thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7873f3c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–47/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantially assisting a violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of any action brought by the Commission under subsection (d) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–41"},"text":"section 80a–41 of this title","children":[],"tail":", any person that knowingly or recklessly provides substantial assistance to another person in violation of a provision of this subchapter, or of any rule or regulation issued under this subchapter, shall be deemed to be in violation of such provision to the same extent as the person to whom such assistance is provided."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7873f3c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–47/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obstructing compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person without just cause to hinder, delay, or obstruct the making, filing, or keeping of any information, document, report, record, or account required to be made, filed, or kept under any provision of this subchapter or any rule, regulation, or order thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7873f3c7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 48, "},{"tag":"ref","attrib":{"href":"/us/stat/54/846"},"text":"54 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s929M/b"},"text":"Pub. L. 111–203, title IX, § 929M(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1861"},"text":"124 Stat. 1861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7873f3c8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7873f3c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7873f3ca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7873f3cb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7873f3cc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
