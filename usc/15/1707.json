{"tag":"section","attrib":{"id":"id79c1d038-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1707"},"text":null,"children":[{"tag":"num","attrib":{"value":"1707"},"text":"§ 1707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c1d039-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A property report relating to the lots in a subdivision shall contain such of the information contained in the statement of record, and any amendments thereto, as the Director may deem necessary, but need not include the documents referred to in paragraphs (7) to (11), inclusive, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1705"},"text":"section 1705 of this title","children":[],"tail":". A property report shall also contain such other information as the Director may by rules or regulations require as being necessary or appropriate in the public interest or for the protection of purchasers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c1d03a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotional use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The property report shall not be used for any promotional purposes before the statement of record becomes effective and then only if it is used in its entirety. No person may advertise or represent that the Director approves or recommends the subdivision or the sale or lease of lots therein. No portion of the property report shall be underscored, italicized, or printed in larger or bolder type than the balance of the statement unless the Director requires or permits it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c1d03b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIV/s1408"},"text":"Pub. L. 90–448, title XIV, § 1408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/594"},"text":"82 Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1098A/1"},"text":"Pub. L. 111–203, title X, § 1098A(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2105"},"text":"124 Stat. 2105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c1d03c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c1d03d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c1d03e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Director” for “Secretary” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c1d03f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79c1d040-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79c1d041-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of two hundred and seventy days after ","children":[{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/s1423"},"text":"section 1423 of Pub. L. 90–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
