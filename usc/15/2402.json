{"tag":"section","attrib":{"id":"id79ecb15c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2402"},"text":null,"children":[{"tag":"num","attrib":{"value":"2402"},"text":"§ 2402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ecb15d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a national policy which will encourage productivity growth consistent with needs of the economy, the natural environment, and the needs, rights, and best interests of management, the work force, and consumers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ecb15e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish as an independent establishment of the executive branch a National Center for Productivity and Quality of Working Life to focus, coordinate, and promote efforts to improve the rate of productivity growth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ecb15f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/136/tI/s102"},"text":"Pub. L. 94–136, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/734"},"text":"89 Stat. 734","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
