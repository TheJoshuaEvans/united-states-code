{"tag":"section","attrib":{"id":"id7a3b6dfe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4630"},"text":null,"children":[{"tag":"num","attrib":{"value":"4630"},"text":"§ 4630.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Department of Energy for fiscal year 1988 the sum of $25,000,000 for general science and research activities of the Department of Energy under the Initiative.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a3b6dff-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dC/tI/s3150"},"text":"Pub. L. 100–180, div. C, title I, § 3150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1244"},"text":"101 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
