{"tag":"section","attrib":{"id":"id7a9f85ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9048"},"text":null,"children":[{"tag":"num","attrib":{"value":"9048"},"text":"§ 9048.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary Government in the Sunshine Act relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9f85f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9048/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), notwithstanding any other provision of law, if the Chairman of the Board of Governors of the Federal Reserve System determines, in writing, that unusual and exigent circumstances exist, the Board may conduct meetings without regard to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" during the period beginning on "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and ending on the earlier of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f85f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9048/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the national emergency concerning the novel coronavirus disease (COVID–19) outbreak declared by the President on ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":" under the National Emergencies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.) terminates; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f85f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9048/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f85f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9048/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Governors of the Federal Reserve System shall keep a record of all Board votes and the reasons for such votes during the period described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9f85f4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4009"},"text":"Pub. L. 116–136, div. A, title IV, § 4009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/478"},"text":"134 Stat. 478","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9f85f5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9f85f6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9f85f7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","a