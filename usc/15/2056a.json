{"tag":"section","attrib":{"id":"id79cdb759-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2056a"},"text":"§ 2056a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and consumer registration of durable nursery products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79cdb75a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Danny Keysar Child Product Safety Notification Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb75b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb75c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb75d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with representatives of consumer groups, juvenile product manufacturers, and independent child product engineers and experts, examine and assess the effectiveness of any voluntary consumer product safety standards for durable infant or toddler products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb75e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", promulgate consumer product safety standards that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79cdb75f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are substantially the same as such voluntary standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb760-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are more stringent than such voluntary standards, if the Commission determines that more stringent standards would further reduce the risk of injury associated with such products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb761-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timetable for rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Commission shall commence the rulemaking required under paragraph (1) and shall promulgate standards for no fewer than 2 categories of durable infant or toddler products every 6 months thereafter, beginning with the product categories that the Commission determines to be of highest priority, until the Commission has promulgated standards for all such product categories. Thereafter, the Commission shall periodically review and revise the standards set forth under this subsection to ensure that such standards provide the highest level of safety for such products that is feasible."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb762-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person adversely affected by such standards may file a petition for review under the procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2060/g"},"text":"section 2060(g) of this title","children":[],"tail":", as added by section 236 of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb763-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for considering subsequent revisions to voluntary standard","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb764-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of adoption of voluntary standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Commission promulgates a consumer product safety standard under this subsection that is based, in whole or in part, on a voluntary standard, the Commission shall notify the organization that issued the voluntary standard of the Commission’s action and shall provide a copy of the consumer product safety standard to the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb765-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission action on revised voluntary standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an organization revises a standard that has been adopted, in whole or in part, as a consumer product safety standard under this subsection, it shall notify the Commission. The revised voluntary standard shall be considered to be a consumer product safety standard issued by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2058"},"text":"section 2058 of this title","children":[],"tail":", effective 180 days after the date on which the organization notifies the Commission (or such later date specified by the Commission in the Federal Register) unless, within 90 days after receiving that notice, the Commission notifies the organization that it has determined that the proposed revision does not improve the safety of the consumer product covered by the standard and that the Commission is retaining the existing consumer product safety standard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb766-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cribs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb767-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2068/a/1"},"text":"section 2068(a)(1) of this title","children":[],"tail":" for any person to which this subsection applies to manufacture, sell, contract to sell or resell, lease, sublet, offer, provide for use, or otherwise place in the stream of commerce a crib that is not in compliance with a standard promulgated under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb768-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons to which subsection applies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection applies to any person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb769-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactures, distributes in commerce, or contracts to sell cribs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb76a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the person’s occupation, holds itself out as having knowledge or skill peculiar to cribs, including child care facilities and family child care homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb76b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the business of contracting to sell or resell, lease, sublet, or otherwise place cribs in the stream of commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb76c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns or operates a place of public accommodation affecting commerce (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2203"},"text":"section 2203 of this title","children":[],"tail":" applied without regard to the phrase “not owned by the Federal Government”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb76d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of any revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any revision of the standard promulgated under subsection (b)(1)(B) subsequent to the initial promulgation of a standard under such subsection, paragraph (1) shall apply only to a person that manufactures or imports cribs, unless the Commission determines that application to any other person described in paragraph (2) is necessary to protect against an unreasonable risk to health or safety. If the Commission determines that application to a person described in paragraph (2) is necessary, it shall provide not less than 12 months for such person to come into compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb76e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crib defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “crib” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb76f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new and used cribs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb770-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-sized or nonfull-sized cribs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb771-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" portable cribs and crib-pens.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb772-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer registration requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb773-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of chapter 6 of title 5 or the Paperwork Reduction Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" et seq.), not later than 1 year after "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Commission shall, pursuant to its authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2065/b"},"text":"section 2065(b) of this title","children":[],"tail":", promulgate a final consumer product safety rule to require each manufacturer of a durable infant or toddler product—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb774-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide consumers with a postage-paid consumer registration form with each such product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb775-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain a record of the names, addresses, e-mail addresses, and other contact information of consumers who register their ownership of such products with the manufacturer in order to improve the effectiveness of manufacturer campaigns to recall such products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb776-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permanently place the manufacturer name and contact information, model name and number, and the date of manufacture on each durable infant or toddler product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb777-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for registration form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The registration form required to be provided to consumers under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb778-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include spaces for a consumer to provide the consumer’s name, address, telephone number, and e-mail address;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb779-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include space sufficiently large to permit easy, legible recording of all desired information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb77a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be attached to the surface of each durable infant or toddler product so that, as a practical matter, the consumer must notice and handle the form after purchasing the product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb77b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the manufacturer’s name, model name and number for the product, and the date of manufacture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb77c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a message explaining the purpose of the registration and designed to encourage consumers to complete the registration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb77d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an option for consumers to register through the Internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb77e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a statement that information provided by the consumer shall not be used for any purpose other than to facilitate a recall of or safety alert regarding that product.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In issuing regulations under this section, the Commission may prescribe the exact text and format of the required registration form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb77f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record keeping and notification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules required under this section shall require each manufacturer of a durable infant or toddler product to maintain a record of registrants for each product manufactured that includes all of the information provided by each consumer registered, and to use such information to notify such consumers in the event of a voluntary or involuntary recall of or safety alert regarding such product. Each manufacturer shall maintain such a record for a period of not less than 6 years after the date of manufacture of the product. Consumer information collected by a manufacturer under this Act may not be used by the manufacturer, nor disseminated by such manufacturer to any other party, for any purpose other than notification to such consumer in the event of a product recall or safety alert.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb780-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall conduct a study at such time as it considers appropriate on the effectiveness of the consumer registration forms required by this section in facilitating product recalls and whether such registration forms should be required for other children’s products. Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Commission shall report its findings to the appropriate Congressional committees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb781-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of alternative recall notification technology","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb782-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology assessment and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb783-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning 2 years after a rule is promulgated under subsection (d), regularly review recall notification technology and assess the effectiveness of such technology in facilitating recalls of durable infant or toddler products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb784-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", and periodically thereafter as the Commission considers appropriate, transmit a report on such assessments to the appropriate Congressional committees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb785-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, based on the assessment required by paragraph (1), the Commission determines by rule that a recall notification technology is likely to be as effective or more effective in facilitating recalls of durable infant or toddler products as the registration forms required by subsection (d), the Commission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb786-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit to the appropriate Congressional committees a report on such determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb787-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall permit a manufacturer of durable infant or toddler products to use such technology in lieu of such registration forms to facilitate recalls of durable infant or toddler products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb788-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of durable infant or toddler product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term “durable infant or toddler product”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb789-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a durable product intended for use, or that may be reasonably expected to be used, by children under the age of 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb78a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb78b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-size cribs and nonfull-size cribs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb78c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" toddler beds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb78d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high chairs, booster chairs, and hook-on chairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb78e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bath seats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb78f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gates and other enclosures for confining a child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb790-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" play yards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb791-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stationary activity centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb792-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infant carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb793-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strollers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb794-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" walkers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb795-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" swings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb796-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056a/f/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bassinets and cradles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79cdb797-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/tI/s104"},"text":"Pub. L. 110–314, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3028"},"text":"122 Stat. 3028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/28/s3"},"text":"Pub. L. 112–28, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-12"},"text":"Aug. 12, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/279"},"text":"125 Stat. 279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79cdb798-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79cdb799-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79cdb79a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2060/g"},"text":"Section 2060(g) of this title","children":[],"tail":", as added by section 236 of this Act, referred to in subsec. (b)(3), is "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2060/g"},"text":"section 2060(g) of this title","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/s236"},"text":"section 236 of Pub. L. 110–314","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Paperwork Reduction Act of 1980, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511"},"text":"Pub. L. 96–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2812"},"text":"94 Stat. 2812","children":[],"tail":", which was classified principally to chapter 35 (§ 3501 et seq.) of Title 44, Public Printing and Documents, prior to the general amendment of that chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/163"},"text":"109 Stat. 163","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1980 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s101"},"text":"section 101 of Title 44","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3016"},"text":"122 Stat. 3016","children":[],"tail":", known as the Consumer Product Safety Improvement Act of 2008. For complete classification of this Act to the Code, see Short Title of 2008 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79cdb79b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consumer Product Safety Improvement Act of 2008, and not as part of the Consumer Product Safety Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79cdb79c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/28/s3/a"},"text":"Pub. L. 112–28, § 3(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/28/s3/b"},"text":"Pub. L. 112–28, § 3(b)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79cdb79d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id79cdb79e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Commission” and “appropriate Congressional committees” used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s2/a"},"text":"section 2(a) of Pub. L. 110–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
