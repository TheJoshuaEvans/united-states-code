{"tag":"section","attrib":{"id":"id7a108ceb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932"},"text":null,"children":[{"tag":"num","attrib":{"value":"2932"},"text":"§ 2932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee on Earth and Environmental Sciences","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a108cec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, through the Council, shall establish a Committee on Earth and Environmental Sciences. The Committee shall carry out Council functions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6651"},"text":"section 6651 of title 42","children":[],"tail":" relating to global change research, for the purpose of increasing the overall effectiveness and productivity of Federal global change research efforts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108ced-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall consist of at least one representative from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108cee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Oceanic and Atmospheric Administration of the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Science and Technology Policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cfa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council on Environmental Quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cfb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Environmental Health Sciences of the National Institutes of Health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cfc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other agencies and departments of the United States as the President or the Chairman of the Council considers appropriate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such representatives shall be high ranking officials of their agency or department, wherever possible the head of the portion of that agency or department that is most revelant ","children":[{"tag":"ref","attrib":{"idref":"fn002475"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002475"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “relevant”."}],"tail":" to the purpose of the subchapter described in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2931/b"},"text":"section 2931(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108cfd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman of the Council, in consultation with the Committee, biennially shall select one of the Committee members to serve as Chairperson. The Chairperson shall be knowledgeable and experienced with regard to the administration of scientific research programs, and shall be a representative of an agency that contributes substantially, in terms of scientific research capability and budget, to the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108cfe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Executive Secretary shall be appointed by the Chairperson of the Committee, with the approval of the Committee. The Executive Secretary shall be a permanent employee of one of the agencies or departments represented on the Committee, and shall remain in the employ of such agency or department. The Chairman of the Council shall have the authority to make personnel decisions regarding any employees detailed to the Council for purposes of working on business of the Committee pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6651"},"text":"section 6651 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108cff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions relative to global change","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council, through the Committee, shall be responsible for planning and coordinating the Program. In carrying out this responsibility, the Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the forum for developing the Plan and for overseeing its implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve cooperation among Federal agencies and departments with respect to global change research activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide budgetary advice as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2935"},"text":"section 2935 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with academic, State, industry, and other groups conducting global change research, to provide for periodic public and peer review of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cooperate with the Secretary of State in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a108d05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing representation at international meetings and conferences on global change research in which the United States participates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a108d06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the Federal activities of the United States with programs of other nations and with international global change research activities such as the International Geosphere-Biosphere Program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with actual and potential users of the results of the Program to ensure that such results are useful in developing national and international policy responses to global change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2932/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report at least annually to the President and the Congress, through the Chairman of the Council, on Federal global change research priorities, policies, and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108d09-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/tI/s102"},"text":"Pub. L. 101–606, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3097"},"text":"104 Stat. 3097","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
