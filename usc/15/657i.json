{"tag":"section","attrib":{"id":"id791ae246-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657i"},"text":null,"children":[{"tag":"num","attrib":{"value":"657i"},"text":"§ 657i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of disaster assistance programs with FEMA","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791ae247-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that the disaster assistance programs of the Administration are coordinated, to the maximum extent practicable, with the disaster assistance programs of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae248-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in consultation with the Administrator of the Federal Emergency Management Agency, shall establish regulations to ensure that each application for disaster assistance is submitted as quickly as practicable to the Administration or directed to the appropriate agency under the circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae249-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion; revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial regulations shall be completed not later than 270 days after the date of the enactment of the Small Business Disaster Response and Loan Improvements Act of 2008. Thereafter, the regulations shall be revised on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae24a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall include a report on the regulations whenever the Administration submits the report required by section 657","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791ae24b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s37"},"text":"Pub. L. 85–536, § 2[37]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12062/2"},"text":"Pub. L. 110–234, title XII, § 12062(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1407"},"text":"122 Stat. 1407","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12062(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2169.)"}],"tail":"\n"},{"tag":"notes","attrib":{"typ