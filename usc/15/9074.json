{"tag":"section","attrib":{"id":"id7aa44184-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074"},"text":null,"children":[{"tag":"num","attrib":{"value":"9074"},"text":"§ 9074.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required assurances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa44185-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for financial assistance under this part, an air carrier or contractor shall enter into an agreement with the Secretary, or otherwise certify in such form and manner as the Secretary shall prescribe, that the air carrier or contractor shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44186-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refrain from conducting involuntary furloughs or reducing pay rates and benefits until ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44187-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":", ensure that neither the air carrier or contractor nor any affiliate of the air carrier or contractor may, in any transaction, purchase an equity security of the air carrier or contractor or the parent company of the air carrier or contractor that is listed on a national securities exchange;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44188-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":", ensure that the air carrier or contractor shall not pay dividends, or make other capital distributions, with respect to the common stock (or equivalent interest) of the air carrier or contractor; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44189-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements of sections 9075 and 9076 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa4418a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Transportation Authority to condition assistance on continuation of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa4418b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation is authorized to require, to the extent reasonable and practicable, an air carrier provided financial assistance under this part to maintain scheduled air transportation service, as the Secretary of Transportation deems necessary, to ensure services to any point served by that carrier before ","children":[{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4418c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When considering whether to exercise the authority provided by this section, the Secretary of Transportation shall take into consideration the air transportation needs of small and remote communities and the need to maintain well-functioning health care supply chains, including medical devices and supplies, and pharmaceutical supply chains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4418d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided under this subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2022-03-01"},"text":"March 1, 2022","children":[],"tail":", and any requirements issued by the Secretary of Transportation under this subsection shall cease to apply after that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa4418e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa4418f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", a contractor expends any funds made available pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9072"},"text":"section 9072 of this title","children":[],"tail":" and distributed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9073"},"text":"section 9073 of this title","children":[],"tail":", the assurances in paragraphs (1) through (3) of subsection (a) shall continue to apply until the dates included in such paragraphs, or the date on which the contractor fully expends such financial assistance, whichever is later."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44190-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-04-05"},"text":"April 5, 2021","children":[],"tail":", each contractor described in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9071/3/A/i"},"text":"section 9071(3)(A)(i) of this title","children":[],"tail":" that has received funds pursuant to such "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9072"},"text":"section 9072 of this title","children":[],"tail":" shall report to the Secretary on the amount of such funds that the contractor has expended through "},{"tag":"date","attrib":{"date":"2021-03-31"},"text":"March 31, 2021","children":[],"tail":". If the contractor has expended an amount that is less than 100 percent of the total amount of funds the contractor received under such section, the Secretary shall initiate an action to recover any funds that remain unexpended as of "},{"tag":"date","attrib":{"date":"2021-04-30"},"text":"April 30, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44191-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall of employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44192-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), any contractor that has unspent financial assistance provided under this part as of ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and conducted involuntary furloughs or reduced pay rates and benefits, between "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and the date on which the contractor entered into an agreement with the Secretary related to financial assistance under this part, shall recall (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9071"},"text":"section 9071 of this title","children":[],"tail":") employees who were involuntarily furloughed during such period by not later than "},{"tag":"date","attrib":{"date":"2021-01-04"},"text":"January 4, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44193-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall waive the requirement under paragraph (1) for a contractor to recall employees if the contractor certifies that the contractor has or will have insufficient remaining financial assistance provided under this part to keep recalled employees employed for more than two weeks upon returning to work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44194-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9074/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of the Treasury shall audit certifications made under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa44195-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4114"},"text":"Pub. L. 116–136, div. A, title IV, § 4114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/499"},"text":"134 Stat. 499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIV/s412/a"},"text":"Pub. L. 116–260, div. N, title IV, § 412(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2060"},"text":"134 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa44196-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa44197-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7aa44198-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
