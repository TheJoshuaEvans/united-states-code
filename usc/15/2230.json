{"tag":"section","attrib":{"id":"id79ea404f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2230"},"text":null,"children":[{"tag":"num","attrib":{"value":"2230"},"text":"§ 2230.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus and excess Federal equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall make publicly available, including through the Internet, information on procedures for acquiring surplus and excess equipment or property that may be useful to State and local fire, emergency, and hazardous material handling service providers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ea4050-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498/s35"},"text":"Pub. L. 93–498, § 35","children":[],"tail":", formerly § 33, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/503/tI/s105"},"text":"Pub. L. 106–503, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2301"},"text":"114 Stat. 2301","children":[],"tail":"; renumbered § 35, "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1057"},"text":"Pub. L. 108–136, div. A, title X, § 1057","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1616"},"text":"117 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
