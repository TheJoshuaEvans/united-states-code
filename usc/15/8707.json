{"tag":"section","attrib":{"id":"id7a8c73f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707"},"text":null,"children":[{"tag":"num","attrib":{"value":"8707"},"text":"§ 8707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8c73f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to an order issued under this chapter may file with the Secretary a petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8c73f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the order, any provision of the order, or any obligation imposed in connection with the order, is not established in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting a modification of the order or an exemption from the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give the petitioner an opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the hearing, the Secretary shall make a ruling on the petition. The ruling shall be final, subject to review as set forth in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any petition filed under this subsection challenging an order, any provision of the order, or any obligation imposed in connection with the order, shall be filed not less than 2 years after the effective date of the order, provision, or obligation subject to challenge in the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States in any district in which a person who is a petitioner under subsection (a) resides or conducts business shall have jurisdiction to review the ruling of the Secretary on the petition of the person, if a complaint requesting the review is filed no later than 30 days after the date of the entry of the ruling by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service of process in proceedings under this subsection shall be conducted in accordance with the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court in a proceeding under this subsection determines that the ruling of the Secretary on the petition of the person is not in accordance with law, the court shall remand the matter to the Secretary with directions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8c73fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such ruling as the court shall determine to be in accordance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such further action as, in the opinion of the court, the law requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c7400-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pendency of proceedings instituted under this section shall not impede, hinder, or delay the Attorney General or the Secretary from obtaining relief under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8708"},"text":"section 8708 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8c7401-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1308"},"text":"Pub. L. 115–254, div. E, § 1308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3480"},"text":"132 Stat. 3480","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
