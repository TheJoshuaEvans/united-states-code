{"tag":"section","attrib":{"id":"id7913b618-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654"},"text":null,"children":[{"tag":"num","attrib":{"value":"654"},"text":"§ 654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paul D. Coverdell drug-free workplace program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7913b619-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7913b61a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug-free workplace program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “drug-free workplace program” means a program that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7913b61b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written policy, including a clear statement of expectations for workplace behavior, prohibitions against reporting to work or working under the influence of illegal drugs or alcohol, prohibitions against the use or possession of illegal drugs in the workplace, and the consequences of violating those expectations and prohibitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b61c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug and alcohol abuse prevention training for a total of not less than 2 hours for each employee, and additional voluntary drug and alcohol abuse prevention training for employees who are parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b61d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee illegal drug testing, with analysis conducted by a drug testing laboratory certified by the Substance Abuse and Mental Health Services Administration, or approved by the College of American Pathologists for forensic drug testing, and a review of each positive test result by a medical review officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b61e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee access to an employee assistance program, including confidential assessment, referral, and short-term problem resolution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b61f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing alcohol and drug abuse prevention education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b620-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible intermediary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible intermediary” means an organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7913b621-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has not less than 2 years of experience in carrying out drug-free workplace programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b622-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has a drug-free workplace policy in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b623-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in a State, the District of Columbia, or a territory of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b624-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7913b625-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the purpose of which is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7913b626-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop comprehensive drug-free workplace programs or to supply drug-free workplace services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7913b627-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide other forms of assistance and services to small business concerns; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7913b628-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is eligible to receive a grant under chapter 2 of the National Narcotics Leadership Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1521"},"text":"21 U.S.C. 1521","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b629-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employee” includes any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7913b62a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicant for employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b62b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b62c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervisor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b62d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manager;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b62e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officer of a small business concern who is active in management of the concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b62f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owner of a small business concern who is active in management of the concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b630-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical review officer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “medical review officer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7913b631-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a licensed physician with knowledge of substance abuse disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b632-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7913b633-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee of the small business concern; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7913b634-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee or agent of, or any person having a financial interest in, the laboratory for which the illegal drug test results are being reviewed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7913b635-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7913b636-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a drug-free workplace demonstration program, under which the Administrator may make grants to, or enter into cooperative agreements or contracts with, eligible intermediaries for the purpose of providing financial and technical assistance to small business concerns seeking to establish a drug-free workplace program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b637-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional grants for technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to grants under paragraph (1), the Administrator may make grants to, or enter into cooperative agreements or contracts with, any grantee for the purpose of providing, in cooperation with one or more small business development centers, technical assistance to small business concerns seeking to establish a drug-free workplace program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b638-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2-year grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant made under this subsection shall be for a period of 2 years, subject to an annual performance review by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7913b639-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of effective practices of eligible intermediaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7913b63a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, after consultation with the Director of the Center for Substance Abuse and Prevention, shall provide technical assistance and information to each eligible intermediary under subsection (b) regarding the most effective practices in establishing and carrying out drug-free workplace programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b63b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7913b63c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection and analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible intermediary receiving a grant under this section shall establish a system to collect and analyze information regarding the effectiveness of drug-free workplace programs established with assistance provided under this section through the intermediary, including information regarding any increase or decrease among employees in drug use, awareness of the adverse consequences of drug use, and absenteeism, injury, and disciplinary problems related to drug use. Such system shall conform to such requirements as the Administrator, after consultation with the Director of the Center for Substance Abuse and Prevention, may prescribe. Not more than 5 percent of the amount of each grant made under subsection (b) shall be used by the eligible intermediary to carry out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7913b63d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, after consultation with the Director of the Center for Substance Abuse and Prevention, shall provide technical assistance and guidance to each eligible intermediary receiving a grant under subsection (b) regarding the collection and analysis of information to evaluate the effectiveness of drug-free workplace programs established with assistance provided under this section, including the information referred to in paragraph (1). Such assistance shall include the identification of additional information suitable for measuring the benefits of drug-free workplace programs to the small business concern and to the concern’s employees and the identification of methods suitable for analyzing such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7913b63e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", the Administrator, in coordination with the Secretary of Labor, the Secretary of Health and Human Services, and the Director of National Drug Control Policy, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7913b63f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the drug-free workplace programs established with assistance made available under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b640-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report describing the results of the evaluation under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7913b641-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7913b642-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract with public and private entities to provide assistance related to carrying out the program under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b643-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensate those entities for provision of that assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7913b644-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to require an employer who attends a program offered by an intermediary to contract for any service offered by the intermediary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7913b645-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7913b646-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section (other than subsection (b)(2)), $5,000,000 for each of fiscal years 2005 and 2006. Amounts made available under this paragraph shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b647-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business development centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount made available under paragraph (1) for each of fiscal years 2005 and 2006, not more than the greater of 10 percent or $500,000 may be used to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/c/3/T"},"text":"section 648(c)(3)(T) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b648-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization for technical assistance grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out subsection (b)(2), $1,500,000 for each of fiscal years 2005 and 2006. Amounts made available under this paragraph shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7913b649-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s654/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the total amount made available under this subsection for any fiscal year shall be used for administrative costs (determined without regard to the administrative costs of eligible intermediaries).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7913b64a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s27"},"text":"Pub. L. 85–536, § 2[27]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/574/tIII/s310"},"text":"Pub. L. 101–574, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2831"},"text":"104 Stat. 2831","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tIX/s904"},"text":"Pub. L. 105–277, div. C, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-708"},"text":"112 Stat. 2681–708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tV/s503/a"},"text":"Pub. L. 106–554, § 1(a)(9) [title V, § 503(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–695; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dK/tI"},"text":"Pub. L. 108–447, div. K, title I","children":[],"tail":", §§ 123–126, "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3449-3451"},"text":"118 Stat. 3449–3451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7913b64b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7913b64c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7913b64d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Narcotics Leadership Act of 1988, referred to in subsec. (a)(2)(D)(ii), is subtitle A of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4181"},"text":"102 Stat. 4181","children":[],"tail":". Chapter 2 of the Act is classified generally to subchapter II (§ 1521 et seq.) of chapter 20 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under former "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1501"},"text":"section 1501 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7913b64e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s125"},"text":"Pub. L. 108–447, § 125","children":[],"tail":", amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “the purpose of which is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) to develop comprehensive drug-free workplace programs or to supply drug-free workplace services; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) to provide other forms of assistance and services to small business concerns.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s124"},"text":"Pub. L. 108–447, § 124","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s126"},"text":"Pub. L. 108–447, § 126","children":[],"tail":", amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “Each drug-free workplace program established with assistance made available under this section shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) include, as reasonably necessary and appropriate, practices and procedures to ensure the confidentiality of illegal drug test results and of any participation by an employee in a rehabilitation program;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) prohibit the mandatory disclosure of medical information by an employee prior to a confirmed positive illegal drug test; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) require that a medical review officer reviewing illegal drug test results shall report only the final results, limited to those drugs for which the employee tests positive, in writing and in a manner designed to ensure the confidentiality of the results.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s123/a"},"text":"Pub. L. 108–447, § 123(a)","children":[],"tail":", substituted “(other than subsection (b)(2)), $5,000,000 for each of fiscal years 2005 and 2006. Amounts made available under this paragraph” for “, $5,000,000 for each of fiscal years 2001 through 2003. Amounts made available under this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s123/b"},"text":"Pub. L. 108–447, § 123(b)","children":[],"tail":", substituted “paragraph (1) for each of fiscal years 2005 and 2006, not more than the greater of 10 percent or $500,000” for “this subsection, not more than the greater of 10 percent or $1,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s123/c"},"text":"Pub. L. 108–447, § 123(c)","children":[],"tail":", (d), added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tV/s503/a/1"},"text":"Pub. L. 106–554, § 1(a)(9) [title V, § 503(a)(1)]","children":[],"tail":", substituted “Paul D. Coverdell drug-free workplace program” for “Drug-free workplace demonstration program” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tV/s503/a/2"},"text":"Pub. L. 106–554, § 1(a)(9) [title V, § 503(a)(2)]","children":[],"tail":", substituted “$5,000,000 for each of fiscal years 2001 through 2003” for “$10,000,000 for fiscal years 1999 and 2000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text consisted of subsecs. (a) to (c) authorizing Administration to make grants to conduct tourism demonstration programs, establishing purpose of program, placing a condition on grant recipients, authorizing appropriations, and requiring report to President and Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7913b64f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7913b650-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purposes of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tIX/s902"},"text":"Pub. L. 105–277, div. C, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-707"},"text":"112 Stat. 2681–707","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dC/tIX/s902"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 74 percent of adults who use illegal drugs are employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns employ over 50 percent of the Nation’s workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in more than 88 percent of families with children under the age of 18, at least 1 parent is employed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" employees who use and abuse addictive illegal drugs and alcohol increase costs for businesses and risk the health and safety of all employees because—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" absenteeism is 66 percent higher among drug users than individuals who do not use drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health benefit utilization is 300 percent higher among drug users than individuals who do not use drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 47 percent of workplace accidents are drug-related;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disciplinary actions are 90 percent higher among drug users than among individuals who do not use drugs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee turnover is significantly higher among drug users than among individuals who do not use drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this title [see Short Title of 1998 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"] are to—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate small business concerns about the advantages of a drug-free workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants and technical assistance in addition to financial incentives to enable small business concerns to create a drug-free workplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist working parents in keeping their children drug-free; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage small business employers and employees alike to participate in drug-free workplace programs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7913b651-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress for 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tIX/s903"},"text":"Pub. L. 105–277, div. C, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-708"},"text":"112 Stat. 2681–708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dC/tIX/s903"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of Congress that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" businesses should adopt drug-free workplace programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States should consider incentives to encourage businesses to adopt drug-free workplace programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such incentives may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" financial incentives, including—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in workers’ compensation premiums;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in unemployment insurance premiums; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tax deductions in an amount equal to the amount of expenditures for employee assistance programs, treatment, or illegal drug testing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other incentives, such as the adoption of liability limitations, as recommended by the President’s Commission on Model State Drug Laws.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
