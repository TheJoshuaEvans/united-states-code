{"tag":"section","attrib":{"id":"id7a68bf8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7005"},"text":null,"children":[{"tag":"num","attrib":{"value":"7005"},"text":"§ 7005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a68bf8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 12 months after ","children":[{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", the Secretary of Commerce shall conduct an inquiry regarding the effectiveness of the delivery of electronic records to consumers using electronic mail as compared with delivery of written records via the United States Postal Service and private express mail services. The Secretary shall submit a report to the Congress regarding the results of such inquiry by the conclusion of such 12-month period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bf8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of electronic consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 12 months after ","children":[{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", the Secretary of Commerce and the Federal Trade Commission shall submit a report to the Congress evaluating any benefits provided to consumers by the procedure required by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001/c/1/C/ii"},"text":"section 7001(c)(1)(C)(ii) of this title","children":[],"tail":"; any burdens imposed on electronic commerce by that provision; whether the benefits outweigh the burdens; whether the absence of the procedure required by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001/c/1/C/ii"},"text":"section 7001(c)(1)(C)(ii) of this title","children":[],"tail":" would increase the incidence of fraud directed against consumers; and suggesting any revisions to the provision deemed appropriate by the Secretary and the Commission. In conducting this evaluation, the Secretary and the Commission shall solicit comment from the general public, consumer representatives, and electronic commerce businesses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bf90-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/229/tI/s105"},"text":"Pub. L. 106–229, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/471"},"text":"114 Stat. 471","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a68bf91-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a68bf92-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a68bf93-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"Oct. 1, 2000","children":[],"tail":", with exceptions relating to record retention and certain loans, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/229/s107"},"text":"section 107 of Pub. L. 106–229","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
