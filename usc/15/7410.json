{"tag":"section","attrib":{"id":"id7a74a677-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7410"},"text":null,"children":[{"tag":"num","attrib":{"value":"7410"},"text":"§ 7410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant eligibility requirements and compliance with immigration laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a74a678-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immigration status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant or fellowship may be awarded under this chapter, directly or indirectly, to any individual who is in violation of the terms of his or her status as a nonimmigrant under section 1101(a)(15)(F), (M), or (J) of title 8.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a74a679-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aliens from certain countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant or fellowship may be awarded under this chapter, directly or indirectly, to any alien from a country that is a state sponsor of international terrorism, as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1735/b"},"text":"section 1735(b) of title 8","children":[],"tail":", unless the Secretary of State determines, in consultation with the Attorney General and the heads of other appropriate agencies, that such alien does not pose a threat to the safety or national security of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a74a67a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7410/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-complying institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No grant or fellowship may be awarded under this chapter, directly or indirectly, to any institution of higher education or non-profit institution (or consortia thereof) that has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a74a67b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7410/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materially failed to comply with the recordkeeping and reporting requirements to receive nonimmigrant students or exchange visitor program participants under section 1101(a)(15)(F), (M), or (J) of title 8, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1372"},"text":"section 1372 of title 8","children":[],"tail":", as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1762"},"text":"section 1762 of title 8","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a67c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7410/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" been suspended or terminated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1762/c"},"text":"section 1762(c) of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a74a67d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/305/s16"},"text":"Pub. L. 107–305, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2381"},"text":"116 Stat. 2381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a74a67e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a74a67f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a74a680-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/305"},"text":"Pub. L. 107–305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2367"},"text":"116 Stat. 2367","children":[],"tail":", known as the Cyber Security Research and Development Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7401"},"text":"section 7401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
