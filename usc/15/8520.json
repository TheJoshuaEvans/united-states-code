{"tag":"section","attrib":{"id":"id7a87b898-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520"},"text":null,"children":[{"tag":"num","attrib":{"value":"8520"},"text":"§ 8520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Weather Research Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b899-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce, in cooperation with the Federal Coordinating Council for Science, Engineering, and Technology through the Committee on Earth and Environmental Sciences, shall establish a United States Weather Research Program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b89a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase benefits to the Nation from the substantial investment in modernizing the public weather warning and forecast system in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b89b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve local and regional weather forecasts and warnings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b89c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address critical weather-related scientific issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b89d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate governmental, university, and private-sector efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b89e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science, Space, and Technology of the House of Representatives, not less frequently than once each year, a report, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b89f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of ongoing research projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b8a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project goals and a point of contact for each project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b8a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the five projects related to weather observations, short-term weather, or subseasonal forecasts within Office of Oceanic and Atmospheric Research that are closest to operationalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b8a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each project referred to in subparagraph (C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a87b8a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b8a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barrier to operationalization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b8a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/5/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan for operationalization, including which line office will financially support the project and how much the line office intends to spend;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish teams with staff from the Office of Oceanic and Atmospheric Research and the National Weather Service to oversee the operationalization of research products developed by the Office of Oceanic and Atmospheric Research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop mechanisms for research priorities of the Office of Oceanic and Atmospheric Research to be informed by the relevant line offices within the National Oceanic and Atmospheric Administration, the relevant user community, and the weather enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an internal mechanism to track the progress of each research project within the Office of Oceanic and Atmospheric Research and mechanisms to terminate a project that is not adequately progressing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement a system to track whether extramural research grant goals were accomplished;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide facilities for products developed by the Office of Oceanic and Atmospheric Research to be tested in operational simulations, such as test beds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage academic collaboration with the Office of Oceanic and Atmospheric Research and the National Weather Service by facilitating visiting scholars; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the activities of the Earth Prediction Innovation Center as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8512/b/2"},"text":"section 8512(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b8ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce, in cooperation with the Committee on Earth and Environmental Sciences, shall prepare and submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a plan for implementation of the United States Weather Research Program which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b8ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, for the 10-year period beginning in the year the plan is submitted, the goals and priorities for Federal weather research which most effectively advance the scientific understanding of weather processes and provide information to improve weather warning and forecast systems in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe specific activities, including research activities, data collection and data analysis requirements, predictive modeling, participation in international research efforts, demonstration of potential operational forecast applications, and education and training required to achieve such goals and priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b8b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the role of each Federal agency and department to be involved in the United States Weather Research Program, identifying and addressing, as appropriate, relevant programs and activities of the Federal agencies and departments that would contribute to such Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b8b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8520/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subseasonal defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “subseasonal” means the time range between 2 weeks and 3 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b8b2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tI/s108"},"text":"Pub. L. 102–567, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4276"},"text":"106 Stat. 4276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/25/tI/s109"},"text":"Pub. L. 115–25, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/97"},"text":"131 Stat. 97","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/423/s4/b"},"text":"Pub. L. 115–423, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5457"},"text":"132 Stat. 5457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a87b8b3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a87b8b4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a87b8b5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25"},"text":"Pub. L. 115–25","children":[],"tail":", which directed amendment of section 108 of the “Oceanic and Atmospheric Administration Authorization Act of 1992”, was executed to this section, which is section 108 of the National Oceanic and Atmospheric Administration Authorization Act of 1992, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s313"},"text":"section 313 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Oceanic and Atmospheric Administration Authorization Act of 1992, and not as part of the Weather Research and Forecasting Innovation Act of 2017 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a87b8b6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423"},"text":"Pub. L. 115–423","children":[],"tail":" added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(5) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s109/1"},"text":"Pub. L. 115–25, § 109(1)","children":[],"tail":", added pars. (5) to (11). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s109/2"},"text":"Pub. L. 115–25, § 109(2)","children":[],"tail":", substituted “The” for “Not later than 90 days after "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"October 29, 1992","children":[],"tail":", the” in introductory provisions. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s109/3"},"text":"Pub. L. 115–25, § 109(3)","children":[],"tail":", added subsec. (c). See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
