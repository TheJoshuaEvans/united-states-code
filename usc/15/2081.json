{"tag":"section","attrib":{"id":"id79dc0e5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081"},"text":null,"children":[{"tag":"num","attrib":{"value":"2081"},"text":"§ 2081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dc0e5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dc0e5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Commission for the purpose of carrying out the provisions of this chapter and any other provision of law the Commission is authorized or directed to carry out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dc0e5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $118,200,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $115,640,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $123,994,000 for fiscal year 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $131,783,000 for fiscal year 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79dc0e61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $136,409,000 for fiscal year 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dc0e62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel allowance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts appropriated pursuant to paragraph (1), there shall be made available $1,200,000 for fiscal year 2010, $1,248,000 for fiscal year 2011, $1,297,000 for fiscal year 2012, $1,350,000 for fiscal year 2013, and $1,403,000 for fiscal year 2014, for travel, subsistence, and related expenses incurred in furtherance of the official duties of Commissioners and employees with respect to attendance at meetings or similar functions, which shall be used by the Commission for such purposes in lieu of acceptance of payment or reimbursement for such expenses from any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79dc0e63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2081/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"