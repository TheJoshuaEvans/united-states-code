{"tag":"section","attrib":{"id":"id7a5a6727-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6553"},"text":null,"children":[{"tag":"num","attrib":{"value":"6553"},"text":"§ 6553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall submit a report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives not later than March 31 of each year that describes the activities carried out under section 6552 ","children":[{"tag":"ref","attrib":{"idref":"fn002552"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002552"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title by the Commission during the preceding calendar year."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a5a6728-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/385/tII/s213"},"text":"Pub. L. 110–385, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4103"},"text":"122 Stat. 4103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a5a6729-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a5a672a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a5a672b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n"