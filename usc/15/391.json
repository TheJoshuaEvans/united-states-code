{"tag":"section","attrib":{"id":"id78a60016-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s391"},"text":null,"children":[{"tag":"num","attrib":{"value":"391"},"text":"§ 391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax on or with respect to generation or transmission of electricity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No State, or political subdivision thereof, may impose or assess a tax on or with respect to the generation or transmission of electricity which discriminates against out-of-State manufacturers, producers, wholesalers, retailers, or consumers of that electricity. For purposes of this section a tax is discriminatory if it results, either directly or indirectly, in a greater tax burden on electricity which is generated and transmitted in interstate commerce than on electricity which is generated and transmitted in intrastate commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a60017-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/272/tII/s201"},"text":"Pub. L. 86–272, title II, § 201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2121/a"},"text":"Pub. L. 94–455, title XXI, § 2121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1914"},"text":"90 Stat. 1914","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a60018-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a60019-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78a6001a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXXI/s2121/b"},"text":"Pub. L. 94–455, title XXI, § 2121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1914"},"text":"90 Stat. 1914","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/455/tXXI/s2121/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect beginning ","children":[{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
