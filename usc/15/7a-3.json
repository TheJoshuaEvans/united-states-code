{"tag":"section","attrib":{"id":"id77b07cab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"7a–3"},"text":"§ 7a–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-retaliation protection for whistleblowers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77b07cac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Whistleblower protections for employees, contractors, subcontractors, and agents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77b07cad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No employer may discharge, demote, suspend, threaten, harass, or in any other manner discriminate against a covered individual in the terms and conditions of employment of the covered individual because of any lawful act done by the covered individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77b07cae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide or cause to be provided to the Federal Government or a person with supervisory authority over the covered individual (or such other person working for the employer who has the authority to investigate, discover, or terminate misconduct) information relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77b07caf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any violation of, or any act or omission the covered individual reasonably believes to be a violation of, the antitrust laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77b07cb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any violation of, or any act or omission the covered individual reasonably believes to be a violation of, another criminal law committed in conjunction with a potential violation of the antitrust laws or in conjunction with an investigation by the Department of Justice of a potential violation of the antitrust laws; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cb1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to cause to be filed, testify in, participate in, or otherwise assist a Federal Government investigation or a Federal Government proceeding filed or about to be filed (with any knowledge of the employer) relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77b07cb2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any violation of, or any act or omission the covered individual reasonably believes to be a violation of, the antitrust laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77b07cb3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any violation of, or any act or omission the covered individual reasonably believes to be a violation of, another criminal law committed in conjunction with a potential violation of the antitrust laws or in conjunction with an investigation by the Department of Justice of a potential violation of the antitrust laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77b07cb4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on protections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to any covered individual if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77b07cb5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered individual planned and initiated a violation or attempted violation of the antitrust laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cb6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered individual planned and initiated a violation or attempted violation of another criminal law in conjunction with a violation or attempted violation of the antitrust laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cb7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered individual planned and initiated an obstruction or attempted obstruction of an investigation by the Department of Justice of a violation of the antitrust laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77b07cb8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77b07cb9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “antitrust laws” means section 1 or 3 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered individual” means an employee, contractor, subcontractor, or agent of an employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employer” means a person, or any officer, employee, contractor, subcontractor, or agent of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal Government” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77b07cbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal regulatory or law enforcement agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77b07cbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Member of Congress or committee of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” has the same meaning as in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77b07cc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “violation”, with respect to the antitrust laws, shall not be construed to include a civil violation of any law that is not also a criminal violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77b07cc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77b07cc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered individual who alleges discharge or other discrimination by any employer in violation of subsection (a) may seek relief under subsection (c) by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77b07cc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filing a complaint with the Secretary of Labor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary of Labor has not issued a final decision within 180 days of the filing of the complaint and there is no showing that such delay is due to the bad faith of the claimant, bringing an action at law or equity for de novo review in the appropriate district court of the United States, which shall have jurisdiction over such an action without regard to the amount in controversy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77b07cc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77b07cc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A complaint filed with the Secretary of Labor under paragraph (1)(A) shall be governed under the rules and procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42121/b"},"text":"section 42121(b) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cc7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notification made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42121/b/1"},"text":"section 42121(b)(1) of title 49","children":[],"tail":" shall be made to any individual named in the complaint and to the employer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cc8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burdens of proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action brought under paragraph (1)(B) shall be governed by the legal burdens of proof set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42121/b"},"text":"section 42121(b) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cc9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A complaint under paragraph (1)(A) shall be filed with the Secretary of Labor not later than 180 days after the date on which the violation occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions to enforce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person fails to comply with an order or preliminary order issued by the Secretary of Labor pursuant to the procedures set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42121/b"},"text":"section 42121(b) of title 49","children":[],"tail":", the Secretary of Labor or the person on whose behalf the order was issued may bring a civil action to enforce the order in the district court of the United States for the judicial district in which the violation occurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77b07ccb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77b07ccc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered individual prevailing in any action under subsection (b)(1) shall be entitled to all relief necessary to make the covered individual whole.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77b07ccd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensatory damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Relief for any action under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77b07cce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reinstatement with the same seniority status that the covered individual would have had, but for the discrimination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07ccf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of back pay, with interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b07cd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for any special damages sustained as a result of the discrimination including litigation costs, expert witness fees, and reasonable attorney’s fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77b07cd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights retained by whistleblowers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be deemed to diminish the rights, privileges, or remedies of any covered individual under any Federal or State law, or under any collective bargaining agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77b07cd2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237/tII/s216"},"text":"Pub. L. 108–237, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/257/s2"},"text":"Pub. L. 116–257, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-23"},"text":"Dec. 23, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1147"},"text":"134 Stat. 1147","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
