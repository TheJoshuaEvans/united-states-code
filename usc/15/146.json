{"tag":"section","attrib":{"id":"id78824c19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146"},"text":null,"children":[{"tag":"num","attrib":{"value":"146"},"text":"§ 146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers of corporation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to the powers granted elsewhere in this chapter, a China Trade Act corporation—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78824c1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shall have the right of succession during the existence of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824c1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shall have a corporate seal and may, with the approval of the Secretary, alter it;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824c1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" May sue and be sued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824c1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shall have the right to transact the business authorized by its articles of incorporation and such further business as is properly connected therewith or necessary and incidental thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824c1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" May make contracts and incur liabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824c1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" May acquire and hold real or personal property, necessary to effect the purpose for which it is formed, and dispose of such property when no longer needed for such purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824c20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" May borrow money and issue its notes, coupon or registered bonds, or other evidences of debt, and secure their payment by a mortgage of its property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824c21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s146/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" May establish such branch offices at such places in China as it deems advisable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78824c22-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-19/ch346/s6"},"text":"Sept. 19, 1922, ch. 346, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/851"},"text":"42 Stat. 851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-26/ch345/s6"},"text":"Feb. 26, 1925, ch. 345, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/996"},"text":"43 Stat. 996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78824c23-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78824c24-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78824c25-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1925—Par. (b). Act ","children":[{"tag":"date","attrib":{"date":"1925-02-26"},"text":"Feb. 26, 1925","children":[],"tail":", substituted “Shall” for “May”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78824c26-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78824c27-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treaty","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Par. (h) of this section has been affected by the 1943 Treaty between United States of America and the Republic of China, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/57/767"},"text":"57 Stat. 767","children":[],"tail":", in which the United States relinquished all extraterritorial jurisdiction and rights in China. See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s142"},"text":"section 142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
