{"tag":"section","attrib":{"id":"id7a179187-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3209"},"text":null,"children":[{"tag":"num","attrib":{"value":"3209"},"text":"§ 3209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports respecting standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a179188-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State authorities and nonregulated utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":", and annually thereafter for 10 years, each State regulatory authority (with respect to each gas utility for which it has ratemaking authority), and each nonregulated gas utility, shall report to the Secretary, in such manner as the Secretary shall prescribe, respecting its consideration of the standards established by this chapter. Such report shall include a summary of the determinations made and actions taken with respect to each of such standards on a utility-by-utility basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a179189-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1978-11-09"},"text":"November 9, 1978","children":[],"tail":", and annually thereafter for 10 years, the Secretary shall submit a report to the President and the Congress containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a17918a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3209/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the reports submitted under subsection (a),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a17918b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3209/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his analysis of such reports, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a17918c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3209/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his actions under this chapter, and his recommendations for such further Federal actions, including any legislation, regarding retail gas utility rates (and other practices) as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a17918d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIII/s309"},"text":"Pub. L. 95–617, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3153"},"text":"92 Stat. 3153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a17918e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a17918f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a179190-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of Secretary in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602"},"text":"section 2602 of Title 16","children":[],"tail":", Conservation, applies to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
