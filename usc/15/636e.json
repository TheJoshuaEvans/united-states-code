ref","attrib":{"href":"/us/usc/t15/s636/b"},"text":"section 636(b) of this title","children":[],"tail":", as amended by this Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78df384c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “disaster update period” means the period beginning on the date on which the President declares a major disaster (including any major disaster relating to which the Administrator declares eligibility for additional disaster assistance under paragraph (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b"},"text":"section 636(b) of this title","children":[],"tail":", as added by this Act) and ending on the date on which such declaration terminates;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78df384d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “major disaster” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78df384e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business concern” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78df384f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636e/7"},"text":null,"children":[{"tag":