{"tag":"section","attrib":{"id":"id7939db33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s714h"},"text":null,"children":[{"tag":"num","attrib":{"value":"714h"},"text":"§ 714h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees; appointment; duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint such officers and employees as may be necessary for the conduct of the business of the Corporation, define their authority and duties, delegate to them such of the powers vested in the Corporation as he may determine. With the exception of experts, appointments shall be made pursuant to the civil-service laws and chapter 51 and subchapter III of chapter 53 of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7939db34-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704/s10"},"text":"June 29, 1948, ch. 704, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1073"},"text":"62 Stat. 1073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-07/ch175/s4"},"text":"June 7, 1949, ch. 175, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/156"},"text":"63 Stat. 156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title XI, § 1106(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s224/b"},"text":"Pub. L. 92–310, title II, § 224(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/206"},"text":"86 Stat. 206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"typ