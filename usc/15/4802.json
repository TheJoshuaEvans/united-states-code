{"tag":"section","attrib":{"id":"id7a4753cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4802"},"text":null,"children":[{"tag":"num","attrib":{"value":"4802"},"text":"§ 4802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council established","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established the Competitiveness Policy Council (hereafter in this chapter referred to as the “Council”), an advisory committee under the provisions of chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a4753ce-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5203"},"text":"Pub. L. 100–418, title V, § 5203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1456"},"text":"102 Stat. 1456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/73"},"text":"Pub. L. 117–286, § 4(a)(73)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4313"},"text":"136 Stat. 4313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4753cf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4753d0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a4753d1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a4753d2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a4753d3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Councils","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory councils established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a council established by the President or an officer of the Federal Government, such council is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a council established by the Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
