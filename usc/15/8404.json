{"tag":"section","attrib":{"id":"id7a87b7a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8404"},"text":null,"children":[{"tag":"num","attrib":{"value":"8404"},"text":"§ 8404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by Federal Trade Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b7a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Violation of this chapter or any regulation prescribed under this chapter shall be treated as a violation of a rule under section 18 of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"15 U.S.C. 57a","children":[],"tail":") regarding unfair or deceptive acts or practices. The Federal Trade Commission shall enforce this chapter in the same manner, by the same means, and with the same jurisdiction, powers, and duties as though all applicable terms and provisions of the Federal Trade Commission Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.) were incorporated into and made a part of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who violates this chapter or any regulation prescribed under this chapter shall be subject to the penalties and entitled to the privileges and immunities provided in the Federal Trade Commission Act as though all applicable terms and provisions of the Federal Trade Commission Act were incorporated in and made part of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority preserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit the authority of the Commission under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b7ac-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/345/s5"},"text":"Pub. L. 111–345, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-29"},"text":"Dec. 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3620"},"text":"124 Stat. 3620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a87b7ad-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a87b7ae-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a87b7af-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
