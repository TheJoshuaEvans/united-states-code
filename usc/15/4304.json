{"tag":"section","attrib":{"id":"id7a38fc41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304"},"text":null,"children":[{"tag":"num","attrib":{"value":"4304"},"text":"§ 4304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of costs, including attorney’s fees, to substantially prevailing party; offset","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38fc42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding sections 15 and 26 of this title, in any claim under the antitrust laws, or any State law similar to the antitrust laws, based on the conducting of a joint venture, or of a standards development activity engaged in by a standards development organization, the court shall, at the conclusion of the action—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fc43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award to a substantially prevailing claimant the cost of suit attributable to such claim, including a reasonable attorney’s fee, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fc44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award to a substantially prevailing party defending against any such claim the cost of suit attributable to such claim, including a reasonable attorney’s fee, if the claim, or the claimant’s conduct during the litigation of the claim, was frivolous, unreasonable, without foundation, or in bad faith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fc45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The award made under subsection (a) may be offset in whole or in part by an award in favor of any other party for any part of the cost of suit, including a reasonable attorney’s fee, attributable to conduct during the litigation by any prevailing party that the court finds to be frivolous, unreasonable, without foundation, or in bad faith.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fc46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsections (a) and (b) shall not apply with respect to any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fc47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly participates in a standards development activity with respect to which a violation of any of the antitrust laws is found,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fc48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a fulltime employee of a standards development organization that engaged in such activity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fc49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, or is an employee or agent of a person who is, engaged in a line of commerce that is likely to benefit directly from the operation of the standards development activity with respect to which such violation is found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38fc4a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/462/s5"},"text":"Pub. L. 98–462, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-11"},"text":"Oct. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1817"},"text":"98 Stat. 1817","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/42/s3/e/2"},"text":"Pub. L. 103–42, § 3(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/119"},"text":"107 Stat. 119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/237/tI/s106"},"text":"Pub. L. 108–237, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-22"},"text":"June 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/664"},"text":"118 Stat. 664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a38fc4b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a38fc4c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a38fc4d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237/s106/1"},"text":"Pub. L. 108–237, § 106(1)","children":[],"tail":", inserted “, or of a standards development activity engaged in by a standards development organization” after “joint venture” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237/s106/2"},"text":"Pub. L. 108–237, § 106(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/42"},"text":"Pub. L. 103–42","children":[],"tail":" substituted “joint venture” for “joint research and development venture” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
