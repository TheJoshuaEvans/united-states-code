{"tag":"section","attrib":{"id":"id7a2f85dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724"},"text":null,"children":[{"tag":"num","attrib":{"value":"3724"},"text":"§ 3724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crowdsourcing and citizen science","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2f85de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Crowdsourcing and Citizen Science Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f85df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f85e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority granted to Federal agencies under the America COMPETES Reauthorization Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Public Law 111–358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/124/3982"},"text":"124 Stat. 3982","children":[],"tail":") to pursue the use of incentive prizes and challenges has yielded numerous benefits;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crowdsourcing and citizen science projects have a number of additional unique benefits, including accelerating scientific research, increasing cost effectiveness to maximize the return on taxpayer dollars, addressing societal needs, providing hands-on learning in STEM, and connecting members of the public directly to Federal science agency missions and to each other; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" granting Federal science agencies the direct, explicit authority to use crowdsourcing and citizen science will encourage its appropriate use to advance Federal science agency missions and stimulate and facilitate broader public participation in the innovation process, yielding numerous benefits to the Federal Government and citizens who participate in such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f85e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f85e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen science","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “citizen science” means a form of open collaboration in which individuals or organizations participate voluntarily in the scientific process in various ways, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f85e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling the formulation of research questions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating and refining project design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting scientific experiments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and analyzing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpreting the results of data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing technologies and applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making discoveries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solving problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crowdsourcing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “crowdsourcing” means a method to obtain needed services, ideas, or content by soliciting voluntary contributions from a group of individuals or organizations, especially from an online community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participant” means any individual or other entity that has volunteered in a crowdsourcing or citizen science project under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f85ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crowdsourcing and citizen science","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f85f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Federal science agency, or the heads of multiple Federal science agencies working cooperatively, may utilize crowdsourcing and citizen science to conduct projects designed to advance the mission of the respective Federal science agency or the joint mission of Federal science agencies, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the head of a Federal science agency may accept, subject to regulations issued by the Director of the Office of Personnel Management, in coordination with the Director of the Office of Science and Technology Policy, services from participants under this section if such services—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f85f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are performed voluntarily as a part of a crowdsourcing or citizen science project authorized under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not financially compensated for their time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be used to displace any employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Federal science agency engaged in a crowdsourcing or citizen science project under this section shall make public and promote such project to encourage broad participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent, registration, and terms of use","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f85f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal science agency shall determine the appropriate level of consent, registration, or acknowledgment of the terms of use that are required from participants in crowdsourcing or citizen science projects under this section on a per-project basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In seeking consent, conducting registration, or developing terms of use for a project under this subsection, a Federal science agency shall disclose the privacy, intellectual property, data ownership, compensation, service, program, and other terms of use to the participant in a clear and reasonable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mode of consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency or Federal science agencies, as applicable, may obtain consent electronically or in written form from participants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections for human subjects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any crowdsourcing or citizen science project under this section that involves research involving human subjects shall be subject to part 46 of title 28, Code of Federal Regulations (or any successor regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f85fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal science agency shall, where appropriate and to the extent practicable, make data collected through a crowdsourcing or citizen science project under this section available to the public, in a machine readable format, unless prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the consent process, the Federal science agency shall notify all participants—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2f85fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the expected uses of the data compiled through the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f85ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Federal science agency will retain ownership of such data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f8600-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if and how the data and results from the project would be made available for public or third party use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f8601-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if participants are authorized to publish such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8602-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technologies and applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal science agencies shall endeavor to make technologies, applications, code, and derivations of such intellectual property developed through a crowdsourcing or citizen science project under this section available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8603-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each participant in a crowdsourcing or citizen science project under this section shall agree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f8604-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assume any and all risks associated with such participation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8605-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to waive all claims against the Federal Government and its related entities, except for claims based on willful misconduct, for any injury, death, damage, or loss of property, revenue, or profits (whether direct, indirect, or consequential) arising from participation in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8606-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research misconduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal science agencies coordinating crowdsourcing or citizen science projects under this section shall make all practicable efforts to ensure that participants adhere to all relevant Federal research misconduct policies and other applicable ethics policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8607-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-sector partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each Federal science agency engaged in crowdsourcing or citizen science under this section, or the heads of multiple Federal science agencies working cooperatively, may enter into a contract or other agreement to share administrative duties for such projects with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f8608-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a for profit or nonprofit private sector entity, including a private institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8609-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, tribal, local, or foreign government agency, including a public institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f860a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public-private partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f860b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out crowdsourcing and citizen science projects under this section, the head of a Federal science agency, or the heads of multiple Federal science agencies working cooperatively—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f860c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use funds appropriated by Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f860d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may publicize projects and solicit and accept funds or in-kind support for such projects, to be available to the extent provided by appropriations Acts, from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2f860e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f860f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for profit or nonprofit private sector entities, including private institutions of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f8610-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/11/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, tribal, local, or foreign government agencies, including public institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8611-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not give any special consideration to any entity described in subparagraph (B) in return for such funds or in-kind support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8612-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f8613-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Services Administration assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the General Services Administration, in coordination with the Director of the Office of Personnel Management and the Director of the Office of Science and Technology Policy, shall, at no cost to Federal science agencies, identify and develop relevant products, training, and services to facilitate the use of crowdsourcing and citizen science projects under this section, including by specifying the appropriate contract vehicles and technology and organizational platforms to enhance the ability of Federal science agencies to carry out the projects under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8614-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each Federal science agency engaged in crowdsourcing or citizen science under this section may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2f8615-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/12/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult any guidance provided by the Director of the Office of Science and Technology Policy, including the Federal Crowdsourcing and Citizen Science Toolkit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f8616-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/12/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a coordinator for that Federal science agency’s crowdsourcing and citizen science projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f8617-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/d/12/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share best practices with other Federal agencies, including participation of staff in the Federal Community of Practice for Crowdsourcing and Citizen Science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f8618-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f8619-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2017-01-06"},"text":"January 6, 2017","children":[],"tail":", the Director of the Office of Science and Technology Policy shall include, as a component of an annual "},{"tag":"ref","attrib":{"idref":"fn002509"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002509"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. As amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719/p"},"text":"section 3719(p) of this title","children":[],"tail":" requires biennial reports."}],"tail":" report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719/p"},"text":"section 3719(p) of this title","children":[],"tail":", a report on the projects and activities carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f861a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f861b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of each crowdsourcing and citizen science project conducted by a Federal science agency during the most recently completed 2 fiscal years, including a description of the proposed goals of each crowdsourcing and citizen science project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f861c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of why the utilization of a crowdsourcing or citizen science project summarized in subparagraph (A) was the preferable method of achieving the goals described in subparagraph (A) as opposed to other authorities available to the Federal science agency, such as contracts, grants, cooperative agreements, and prize competitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f861d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation rates, submission levels, number of consents, and any other statistic that might be considered relevant in each crowdsourcing and citizen science project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f861e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2f861f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources, including personnel and funding, that were used in the execution of each crowdsourcing and citizen science project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f8620-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project activities for which such resources were used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2f8621-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the obligations and expenditures relating to the project’s execution were allocated among the accounts of the Federal science agency, including a description of the amount and source of all funds, private, public, and in-kind, contributed to each crowdsourcing and citizen science project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8622-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the use of crowdsourcing and citizen science by all Federal science agencies, including interagency and multi-sector partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8623-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how each crowdsourcing and citizen science project advanced the mission of each participating Federal science agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8624-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of each crowdsourcing or citizen science project where data collected through such project was not made available to the public, including the reasons for such action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f8625-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/e/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Director of the Office of Science and Technology Policy considers relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f8626-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f8627-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect the authority to conduct crowdsourcing and citizen science authorized by any other provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8628-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3724/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to displace Federal Government resources allocated to the Federal science agencies that use crowdsourcing or citizen science authorized under this section to carry out a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2f8629-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIV/s402"},"text":"Pub. L. 114–329, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3019"},"text":"130 Stat. 3019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2f862a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2f862b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a2f862c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The America COMPETES Reauthorization Act of 2010, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3982"},"text":"124 Stat. 3982","children":[],"tail":", also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010. For complete classification of this Act to the Code, see Short Title of 2011 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"section 1861 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a2f862d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Innovation and Competitiveness Act, and not as part of the Stevenson-Wydler Technology Innovation Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a2f862e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a2f862f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s2"},"text":"section 2 of Pub. L. 114–329","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862s"},"text":"section 1862s of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
