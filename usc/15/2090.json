{"tag":"section","attrib":{"id":"id79de5913-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090"},"text":null,"children":[{"tag":"num","attrib":{"value":"2090"},"text":"§ 2090.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for carbon monoxide poisoning prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79de5914-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations authorized under subsection (f), the Commission shall establish a grant program to provide assistance to States and Tribal organizations that are eligible under subsection (b) to carry out the carbon monoxide poisoning prevention activities described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de5915-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, an eligible State or Tribal organization is any State or Tribal organization that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de5916-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the satisfaction of the Commission that the State or Tribal organization has adopted a statute or a rule, regulation, or similar measure with the force and effect of law, requiring compliant carbon monoxide alarms to be installed in dwelling units in accordance with NFPA 72, the IFC, or the IRC; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de5917-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submits an application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de5918-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Commission at such time, in such form, and containing such additional information as the Commission may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5919-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may be filed on behalf of the State or Tribal organization by the fire safety code enforcement agency of that State or Tribal organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de591a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall determine the amount of each grant awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de591b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of grant recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible States and Tribal organizations for the award of grants under this section, the Commission shall give favorable consideration to an eligible State or Tribal organization that demonstrates a reasonable need for funding under this section and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de591c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requires the installation of one or more compliant carbon monoxide alarms in a new or existing educational facility, childcare facility, health care facility, adult dependent care facility, government building, restaurant, theater, lodging establishment, or dwelling unit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de591d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within which a fuel-burning appliance, including a furnace, boiler, water heater, fireplace, or any other apparatus, appliance, or device that burns fuel, is installed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de591e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has an attached garage; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de591f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has developed a strategy to protect vulnerable populations, such as children, the elderly, or low-income households, from exposure to unhealthy levels of carbon monoxide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de5920-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de5921-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), an eligible State or Tribal organization to which a grant is awarded under this section may use the grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de5922-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase and install compliant carbon monoxide alarms in the dwelling units of low-income families or elderly individuals, facilities that commonly serve children or the elderly (including childcare facilities, public schools, and senior centers);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5923-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the development and dissemination of training materials, instructors, and any other costs relating to the training sessions authorized under this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5924-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to educate the public about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79de5925-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk associated with carbon monoxide as a poison; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79de5926-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of proper carbon monoxide alarm use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de5927-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de5928-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible State or Tribal organization to which a grant is awarded under this section may use not more than 5 percent of the grant amount to cover administrative costs that are not directly related to training described in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5929-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible State or Tribal organization to which a grant is awarded under this section may use not more than 25 percent of the grant amount to cover the costs of activities described in paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de592a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible State to which a grant is awarded under this section shall, with respect to the costs incurred by the State in carrying out activities under the grant, provide non-Federal contributions in an amount equal to not less than 25 percent of the amount of Federal funds provided under the grant to administer the program. This subparagraph shall not apply to Tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de592b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de592c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall carry out this title ","children":[{"tag":"ref","attrib":{"idref":"fn002440"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002440"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" using amounts appropriated to the Commission for each of fiscal years 2022 through 2026, to extent such funds are available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de592d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a fiscal year, not more than 10 percent of the amounts appropriated or otherwise made available to carry out this title ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" may be used for administrative expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de592e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2090/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the last day of each fiscal year in which grants are awarded under this section, the Commission shall submit to Congress a report that evaluates the implementation of the grant program required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79de592f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dQ/tII/s204"},"text":"Pub. L. 117–103, div. Q, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/814"},"text":"136 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79de5930-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79de5931-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79de5932-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (f), is title II of div. Q of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", which enacted this section and provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79de5933-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Nicholas and Zachary Burt Memorial Carbon Monoxide Poisoning Prevention Act of 2022 and also as part of the Consolidated Appropriations Act, 2022, and not as part of the Consumer Product Safety Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79de5934-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79de5935-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dQ/tII/s202"},"text":"Pub. L. 117–103, div. Q, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/813"},"text":"136 Stat. 813","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dQ/tII/s202"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carbon monoxide is a colorless, odorless gas produced by burning any fuel. Exposure to unhealthy levels of carbon monoxide can lead to carbon monoxide poisoning, a serious health condition that could result in death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unintentional carbon monoxide poisoning from motor vehicles and improper operation of fuel-burning appliances, such as furnaces, water heaters, portable generators, and stoves, annually kills more than 400 individuals and sends approximately 15,000 individuals to hospital emergency rooms for treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research shows that installing carbon monoxide alarms close to the sleeping areas in residential homes and other dwelling units can help avoid fatalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that Congress should promote the installation of carbon monoxide alarms in residential homes and dwelling units across the United States in order to promote the health and public safety of citizens throughout the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id79de5936-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dQ/tII/s203"},"text":"Pub. L. 117–103, div. Q, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/813"},"text":"136 Stat. 813","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dQ/tII/s203"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Carbon monoxide alarm","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘carbon monoxide alarm’ means a device or system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detects carbon monoxide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended to sound an alarm at a carbon monoxide concentration below a concentration that could cause a loss of the ability to react to the dangers of carbon monoxide exposure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Commission’ means the Consumer Product Safety Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliant carbon monoxide alarm","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘compliant carbon monoxide alarm’ means a carbon monoxide alarm that complies with the most current version of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Standard for Single and Multiple Station Carbon Monoxide Alarms of the American National Standards Institute and UL (ANSI/UL 2034), or any successor standard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Standard for Gas and Vapor Detectors and Sensors of the American National Standards Institute and UL (ANSI/UL 2075), or any successor standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dwelling unit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘dwelling unit’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a room or suite of rooms used for human habitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"nu