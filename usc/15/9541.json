{"tag":"section","attrib":{"id":"id7ab04faf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541"},"text":null,"children":[{"tag":"num","attrib":{"value":"9541"},"text":"§ 9541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual diverse business forum on capital formation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab04fb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", and annually thereafter, the Under Secretary shall conduct a Government-business forum to review the current status of problems and programs relating to capital formation by minority business enterprises."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04fb1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in forum planning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall invite the heads of other Federal agencies, such as the Chairman of the Securities and Exchange Commission, the Secretary of the Treasury, and the Chairman of the Board of Governors of the Federal Reserve System, organizations representing State securities commissioners, representatives of leading minority chambers of commerce, not less than 1 certified owner of a minority business enterprise, business organizations, and professional organizations concerned with capital formation to participate in the planning of each forum conducted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04fb2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of statements and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04fb3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may request that any head of a Federal agency, department, or organization, including those described in subsection (b), or any other group or individual, prepare a statement or report to be delivered at any forum conducted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fb4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any head of a Federal agency, department, or organization who receives a request under paragraph (1) shall, to the greatest extent practicable, cooperate with the Under Secretary to fulfill that request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04fb5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of proceedings and findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04fb6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a summary of the proceedings of each forum conducted under subsection (a), which shall include the findings and recommendations of the forum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fb7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transmit the summary described in paragraph (1) with respect to each forum conducted under subsection (a) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04fb8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participants in the forum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04fb9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04fba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public, through a publicly available website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04fbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of findings and recommendations; public statements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04fbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Federal agency to which a finding or recommendation described in subsection (d)(1) relates shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04fbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review that finding or recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04fbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promptly after the finding or recommendation is transmitted under subsection (d)(2)(C), issue a public statement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04fbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the finding or recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04fc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosing the action, if any, the Federal agency intends to take with respect to the finding or recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9541/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint statement permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a finding or recommendation described in subsection (d)(1) relates to more than 1 Federal agency, the applicable Federal agencies may, for the purposes of the public statement required under paragraph (1)(B), issue a joint statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04fc2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tII/s100201"},"text":"Pub. L. 117–58, div. K, title II, § 100201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1455"},"text":"135 Stat. 1455","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
