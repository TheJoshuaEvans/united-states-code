{"tag":"section","attrib":{"id":"id7a047ee8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647"},"text":null,"children":[{"tag":"num","attrib":{"value":"2647"},"text":"§ 2647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a047ee9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any local educational agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047eea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which fails to conduct an inspection pursuant to regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643/b"},"text":"section 2643(b) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2644/b"},"text":"section 2644(b) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047eeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which knowingly submits false information to the Governor regarding any inspection pursuant to regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643/i"},"text":"section 2643(i) of this title","children":[],"tail":" or knowingly includes false information in any inspection statement under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2644/d/3"},"text":"section 2644(d)(3) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047eec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which fails to develop a management plan pursuant to regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643/i"},"text":"section 2643(i) of this title","children":[],"tail":" or under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2644/d"},"text":"section 2644(d) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047eed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which carries out any activity prohibited by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2655"},"text":"section 2655 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047eee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which knowingly submits false information to the Governor regarding a deferral request under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2645/d"},"text":"section 2645(d) of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002468"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002468"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a comma."}],"tail":null}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is liable for a civil penalty of not more than $5,000 for each day during which the violation continues. Any civil penalty under this subsection shall be assessed and collected in the same manner, and subject to the same provisions, as in the case of civil penalties assessed and collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2615"},"text":"section 2615 of this title","children":[],"tail":". For purposes of this subsection, a “violation” means a failure to comply with respect to a single school building. The court shall order that any civil penalty collected under this subsection be used by the local educational agency for purposes of complying with this subchapter. Any portion of a civil penalty remaining unspent after compliance by a local educational agency is completed shall be deposited into the Asbestos Trust Fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4022"},"text":"section 4022 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047eef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to subchapter I of this chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A local educational agency is not liable for any civil penalty under subchapter I of this chapter for failing or refusing to comply with any rule promulgated or order issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047ef0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement considerations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047ef1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining the amount of a civil penalty to be assessed under subsection (a) against a local educational agency, the Administrator shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a047ef2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a047ef3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the culpability of the violator, including any history of previous violations under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a047ef4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the violator to pay the penalty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a047ef5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the violator to continue to provide educational services to the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047ef6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action ordered by a court in fashioning relief under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2619"},"text":"section 2619 of this title","children":[],"tail":" shall be consistent with regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643"},"text":"section 2643 of this title","children":[],"tail":" (or with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2644"},"text":"section 2644 of this title","children":[],"tail":" if there are no regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047ef7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen complaints","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person may file a complaint with the Administrator or with the Governor of the State in which the school building is located with respect to asbestos-containing material in a school building. If the Administrator or Governor receives a complaint under this subsection containing allegations which provide a reasonable basis to believe that a violation of this chapter has occurred, the Administrator or Governor shall investigate and respond (including taking enforcement action where appropriate) to the complaint within a reasonable period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047ef8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen petitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047ef9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person may petition the Administrator to initiate a proceeding for the issuance, amendment, or repeal of a regulation or order under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047efa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such petition shall be filed in the principal office of the Administrator and shall set forth the facts which it is claimed establish that it is necessary to issue, amend, or repeal a regulation or order under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047efb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may hold a public hearing or may conduct such investigation or proceeding as the Administrator deems appropriate in order to determine whether or not such petition should be granted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047efc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 90 days after filing of a petition described in paragraph (1), the Administrator shall either grant or deny the petition. If the Administrator grants such petition, the Administrator shall promptly commence an appropriate proceeding in accordance with this subchapter. If the Administrator denies such petition, the Administrator shall publish in the Federal Register the Administrator’s reasons for such denial. The granting or denial of a petition under this subsection shall not affect any deadline or other requirement of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047efd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizen civil actions with respect to EPA regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047efe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person may commence a civil action without prior notice against the Administrator to compel the Administrator to meet the deadlines in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643"},"text":"section 2643 of this title","children":[],"tail":" for issuing advanced notices of proposed rulemaking, proposing regulations, and promulgating regulations. Any such action shall be brought in the district court of the United States for the District of Columbia."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047eff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any action brought under paragraph (1) in which the court finds the Administrator to be in violation of any deadline in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643"},"text":"section 2643 of this title","children":[],"tail":", the court shall set forth a schedule for promulgating the regulations required by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643"},"text":"section 2643 of this title","children":[],"tail":" and shall order the Administrator to comply with such schedule. The court may extend any deadline (which has not already occurred) in section 2644(b), (c), or (d) of this title for a period of not more than 6 months, if the court-ordered schedule will result in final promulgation of the pertinent regulations within the extended period. Such deadline extensions may not be granted by the court beginning 720 days after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2619"},"text":"Section 2619 of this title","children":[],"tail":" shall apply to civil actions described in this subsection, except to the extent inconsistent with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047f01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to attain accreditation; penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contractor who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047f02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspects for asbestos-containing material in a school, public or commercial building;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designs or conducts response actions with respect to friable asbestos-containing material in a school, public or commercial building; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2647/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs individuals to conduct response actions with respect to friable asbestos-containing material in a school, public or commercial building;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and who fails to obtain the accreditation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646"},"text":"section 2646 of this title","children":[],"tail":", or in the case of employees to require or provide for the accreditation required, is liable for a civil penalty of not more than $5,000 for each day during which the violation continues, unless such contractor is a direct employee of the Federal Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a047f05-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tII/s207"},"text":"Pub. L. 94–469, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s2"},"text":"Pub. L. 99–519, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2983"},"text":"100 Stat. 2983","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/368/s5"},"text":"Pub. L. 100–368, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-18"},"text":"July 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/833"},"text":"102 Stat. 833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/637/s15/a/4"},"text":"Pub. L. 101–637, § 15(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4596"},"text":"104 Stat. 4596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a047f06-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a047f07-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a047f08-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/368"},"text":"Pub. L. 100–368","children":[],"tail":" added pars. (4) and (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a047f09-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a047f0a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":" effective upon expiration of 12-month period following "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", with provisions for extension, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/637/s15/c"},"text":"section 15(c) of Pub. L. 101–637","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646"},"text":"section 2646 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a047f0b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"EPA Administrator Not Exercising “Statutory Authority” Under OSHA Law in Exercising Authority Under This Chapter","children":[],"tail":null},{"tag":"p","attrib":{},"text":"In exercising any authority under this chapter in connection with amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637"},"text":"Pub. L. 101–637","children":[],"tail":", Administrator of Environmental Protection Agency not, for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s653/b/1"},"text":"section 653(b)(1) of Title 29","children":[],"tail":", Labor, to be considered to be exercising statutory authority to prescribe or enforce standards or regulations affecting occupational safety and health, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/637/s15/b"},"text":"section 15(b) of Pub. L. 101–637","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646"},"text":"section 2646 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
