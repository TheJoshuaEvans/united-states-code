{"tag":"section","attrib":{"id":"id7a7bd24c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703"},"text":null,"children":[{"tag":"num","attrib":{"value":"7703"},"text":"§ 7703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against predatory and abusive commercial e-mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7bd24d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd24e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Sentencing Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd24f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to its authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s994/p"},"text":"section 994(p) of title 28","children":[],"tail":" and in accordance with this section, the United States Sentencing Commission shall review and, as appropriate, amend the sentencing guidelines and policy statements to provide appropriate penalties for violations of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1037"},"text":"section 1037 of title 18","children":[],"tail":", as added by this section, and other offenses that may be facilitated by the sending of large quantities of unsolicited electronic mail."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd250-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Sentencing Commission shall consider providing sentencing enhancements for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7bd251-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" those convicted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1037"},"text":"section 1037 of title 18","children":[],"tail":" who—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a7bd252-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtained electronic mail addresses through improper means, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a7bd253-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harvesting electronic mail addresses of the users of a website, proprietary service, or other online public forum operated by another person, without the authorization of such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a7bd254-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" randomly generating electronic mail addresses by computer; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a7bd255-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knew that the commercial electronic mail messages involved in the offense contained or advertised an Internet domain for which the registrant of the domain had provided false registration information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7bd256-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those convicted of other offenses, including offenses involving fraud, identity theft, obscenity, child pornography, and the sexual exploitation of children, if such offenses involved the sending of large quantities of electronic mail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd257-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd258-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Spam has become the method of choice for those who distribute pornography, perpetrate fraudulent schemes, and introduce viruses, worms, and Trojan horses into personal and business computer systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd259-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice should use all existing law enforcement tools to investigate and prosecute those who send bulk commercial e-mail to facilitate the commission of Federal crimes, including the tools contained in chapters 47 and 63 of title 18 (relating to fraud and false statements); chapter 71 of title 18 (relating to obscenity); chapter 110 of title 18 (relating to the sexual exploitation of children); and chapter 95 of title 18 (relating to racketeering), as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7bd25a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/187/s4"},"text":"Pub. L. 108–187, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2703"},"text":"117 Stat. 2703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd25b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a7bd25c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a7bd25d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/187/s4"},"text":"section 4 of Pub. L. 108–187","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/187/s4"},"text":"section 4 of Pub. L. 108–187","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1037"},"text":"section 1037 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and amended analysis for chapter 47 of Title 18. The provisions of subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/187/s4"},"text":"section 4 of Pub. L. 108–187","children":[],"tail":" are also listed in a table relating to sentencing guidelines set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a7bd25e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a7bd25f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-01-01"},"text":"Jan. 1, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/187/s16"},"text":"section 16 of Pub. L. 108–187","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7701"},"text":"section 7701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
