{"tag":"section","attrib":{"id":"id7ab2995b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9582"},"text":null,"children":[{"tag":"num","attrib":{"value":"9582"},"text":"§ 9582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of Federal departments and agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab2995c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9582/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with other Federal agencies and departments as appropriate to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab2995d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9582/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop policies, comprehensive plans, and specific program goals for the programs carried out under part B of subchapter I and subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab2995e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9582/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish regular performance monitoring and reporting systems to ensure that goals established by the Under Secretary with respect to the implementation of this chapter are being achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab2995f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9582/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the impact of Federal support of socially or economically disadvantaged business concerns in achieving the objectives of this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29960-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9582/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a coordinated review of all proposed Federal training and technical assistance activities in direct support of the programs carried out under part B of subchapter I and subchapter III to ensure consistency with program goals and to avoid duplication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29961-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9582/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convene, for purposes of coordination, meetings of the heads of such Federal agencies and departments, or their designees, the programs and activities of which may affect or contribute to the carrying out of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab29962-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tVI/s100602"},"text":"Pub. L. 117–58, div. K, title VI, § 100602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1464"},"text":"135 Stat. 1464","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab29963-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab29964-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab29965-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in pars. (1)(B), (C), and (3), was in the original “this division”, meaning div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1445"},"text":"135 Stat. 1445","children":[],"tail":", which is classified principally to this chapter. For complete classification of division K to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
