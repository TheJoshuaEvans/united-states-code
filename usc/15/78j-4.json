{"tag":"section","attrib":{"id":"id780fda7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78j–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"78j–4"},"text":"§ 78j–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of erroneously awarded compensation policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id780fda7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78j–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Listing standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, by rule, direct the national securities exchanges and national securities associations to prohibit the listing of any security of an issuer that does not comply with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id780fda7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78j–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules of the Commission under subsection (a) shall require each issuer to develop and implement a policy providing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id780fda7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78j–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for disclosure of the policy of the issuer on incentive-based compensation that is based on financial information required to be reported under the securities laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780fda7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78j–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, in the event that the issuer is required to prepare an accounting restatement due to the material noncompliance of the issuer with any financial reporting requirement under the securities laws, the issuer will recover from any current or former executive officer of the issuer who received incentive-based compensation (including stock options awarded as compensation) during the 3-year period preceding the date on which the issuer is required to prepare an accounting restatement, based on the erroneous data, in ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “compensation in”."}],"tail":" excess of what would have been paid to the executive officer under the accounting restatement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780fda80-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 10D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s954"},"text":"Pub. L. 111–203, title IX, § 954","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1904"},"text":"124 Stat. 1904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780fda81-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id780fda82-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id780fda83-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
