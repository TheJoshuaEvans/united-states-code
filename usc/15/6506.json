{"tag":"section","attrib":{"id":"id7a5a6714-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6506"},"text":null,"children":[{"tag":"num","attrib":{"value":"6506"},"text":"§ 6506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after the effective date of the regulations initially issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6502"},"text":"section 6502 of this title","children":[],"tail":", the Commission shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a6715-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6506/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the implementation of this chapter, including the effect of the implementation of this chapter on practices relating to the collection and disclosure of information relating to children, children’s ability to obtain access to information of their choice online, and on the availability of websites directed to children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6716-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6506/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to Congress a report on the results of the review under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5a6717-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tXIII/s1307"},"text":"Pub. L. 105–277, div. C, title XIII, § 1307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-735"},"text":"112 Stat. 2681–735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
