{"tag":"section","attrib":{"id":"id797cb19f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1477"},"text":null,"children":[{"tag":"num","attrib":{"value":"1477"},"text":"§ 1477.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by State Attorneys General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The attorney general of a State, or other authorized State officer, alleging a violation of a standard or rule promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1472"},"text":"section 1472 of this title","children":[],"tail":" that affects or may affect such State or its residents, may bring an action on behalf of the residents of the State in any United States district court for the district in which the defendant is found or transacts business to obtain appropriate injunctive relief. The procedural requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2073/b"},"text":"section 2073(b) of this title","children":[],"tail":" shall apply to any such action."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797cb1a0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/601/s9"},"text":"Pub. L. 91–601, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s218/b/1"},"text":"Pub. L. 110–314, title II, § 218(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3062"},"text":"122 Stat. 3062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797cb1a1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797cb1a2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id797cb1a3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/601/s9"},"text":"section 9 of Pub. L. 91–601","children":[],"tail":" was renumbered section 8 and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1471"},"text":"section 1471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
