{"tag":"section","attrib":{"id":"id7a4299de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724"},"text":null,"children":[{"tag":"num","attrib":{"value":"4724"},"text":"§ 4724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade shows","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4299df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to facilitate exporting by United States businesses, the Secretary of Commerce shall provide assistance for trade shows in the United States which bring together representatives of United States businesses seeking to export goods or services produced in the United States and representatives of foreign companies or governments seeking to buy such goods or services from these United States businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipients of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance under subsection (a) may be provided to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit industry organizations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade associations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign trade zones, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private industry firms or groups of firms in cases where no entity described in paragraph (1), (2), or (3) represents that industry,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to provide the services necessary to operate trade shows described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to small businesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this section, the Secretary of Commerce shall, in consultation with the Administrator of the Small Business Administration, make special efforts to facilitate participation by small businesses and companies new to export.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds appropriated to carry out this section shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential participants for trade show organizers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information on trade shows to potential participants,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply language services for participants, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information on trade shows to small businesses and companies new to export.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “United States business” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4299ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4299ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, partnership, or other association created under the laws of the United States or of any State (including the District of Columbia or any commonwealth, territory, or possession of the United States); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4299ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign corporation, partnership, or other association, more than 95 percent of which is owned by persons described in subparagraphs (A) and (B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4724/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business” means any small business concern as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4299f1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII/s2304"},"text":"Pub. L. 100–418, title II, § 2304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1343"},"text":"102 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
