{"tag":"section","attrib":{"id":"id7939db48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s714j"},"text":null,"children":[{"tag":"num","attrib":{"value":"714j"},"text":"§ 714j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of associations and trade facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Corporation may, in the conduct of its business, utilize on a contract or fee basis, committees or associations of producers, producer-owned and producer-controlled cooperative associations, and trade facilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7939db49-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704/s12"},"text":"June 29, 1948, ch. 704, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1073"},"text":"62 Stat. 1073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7939db4a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7939db4b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7939db4c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exceptions From Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For exception of functions of corporations of Department of Agriculture from transfer of functions to Secretary of Agriculture by Reorg. Plan No. 2 of 1953, see Exceptions From Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s712a"},"text":"section 712a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
