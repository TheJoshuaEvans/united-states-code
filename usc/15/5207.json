{"tag":"section","attrib":{"id":"id7a49c584-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207"},"text":null,"children":[{"tag":"num","attrib":{"value":"5207"},"text":"§ 5207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a49c585-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Focus of research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conformance with the Superconductivity Action Plan, the Secretary of Defense, in the superconductivity research and development activities of the Department of Defense, shall give emphasis to fundamental research, materials processing, and applications of new superconducting materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c586-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting research under subsection (a), the Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c587-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systematically define the engineering parameters for high-temperature superconducting materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c588-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct the necessary development, engineering, and operational prototype testing considered appropriate to the overall mission of the Department of Defense. Such operational prototype testing shall, where appropriate, utilize criteria developed by the Defense Advanced Research Projects Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c589-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense Advanced Research Projects Agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Defense Advanced Research Projects Agency shall, in conformance with the Superconductivity Action Plan, conduct activities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c58a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" augment, as appropriate, basic and applied superconductivity research conducted in other Federal agencies and industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c58b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5207/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop criteria for operational prototype testing within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c58c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/697/s8"},"text":"Pub. L. 100–697, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4615"},"text":"102 Stat. 4615","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
