{"tag":"section","attrib":{"id":"id7a108d3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2938"},"text":null,"children":[{"tag":"num","attrib":{"value":"2938"},"text":"§ 2938.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a108d3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2938/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Climate Program research activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, the Chairman of the Council, and the Secretary of Commerce shall ensure that relevant research activities of the National Climate Program, established by the National Climate Program Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2901"},"text":"15 U.S.C. 2901","children":[],"tail":" et seq.), are considered in developing national global change research efforts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108d40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2938/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of research findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, the Chairman of the Council, and the heads of the agencies and departments represented on the Committee, shall ensure that the research findings of the Committee, and of Federal agencies and departments, are available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2938/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency for use in the formulation of a coordinated national policy on global climate change pursuant to section 1103 of the Global Climate Protection Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2901"},"text":"15 U.S.C. 2901","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2938/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all Federal agencies and departments for use in the formulation of coordinated national policies for responding to human-induced and natural processes of global change pursuant to other statutory responsibilities and obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108d43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2938/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Federal response actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed, interpreted, or applied to preclude or delay the planning or implementation of any Federal action designed, in whole or in part, to address the threats of stratospheric ozone depletion or global climate change.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108d44-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/tI/s108"},"text":"Pub. L. 101–606, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3101"},"text":"104 Stat. 3101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a108d45-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a108d46-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a108d47-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Climate Program Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/367"},"text":"Pub. L. 95–367","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-17"},"text":"Sept. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/601"},"text":"92 Stat. 601","children":[],"tail":", which is classified principally to chapter 56 (§ 2901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2901"},"text":"section 2901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
