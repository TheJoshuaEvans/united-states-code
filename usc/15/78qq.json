{"tag":"section","attrib":{"id":"id7854fa2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq"},"text":null,"children":[{"tag":"num","attrib":{"value":"78qq"},"text":"§ 78qq.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small Business Capital Formation Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7854fa2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Commission the Small Business Capital Formation Advisory Committee (hereafter in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall provide the Commission with advice on the Commission’s rules, regulations, and policies with regard to the Commission’s mission of protecting investors, maintaining fair, orderly, and efficient markets, and facilitating capital formation, as such rules, regulations, and policies relate to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7854fa31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital raising by emerging, privately held small businesses (“emerging companies”) and publicly traded companies with less than $250,000,000 in public market capitalization (“smaller public companies”) through securities offerings, including private and limited offerings and initial and other public offerings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trading in the securities of emerging companies and smaller public companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public reporting and corporate governance requirements of emerging companies and smaller public companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall not provide any advice with respect to any policies, practices, actions, or decisions concerning the Commission’s enforcement program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Committee shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advocate for Small Business Capital Formation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not fewer than 10, and not more than 20, members appointed by the Commission, from among individuals—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7854fa39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who represent—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7854fa3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emerging companies engaging in private and limited securities offerings or considering initial public offerings (“IPO”) (including the companies’ officers and directors);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7854fa3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional advisors of such companies (including attorneys, accountants, investment bankers, and financial advisors); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7854fa3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investors in such companies (including angel investors, venture capital funds, and family offices);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are officers or directors of minority-owned small businesses or women-owned small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who represent—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7854fa3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" smaller public companies (including the companies’ officers and directors);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7854fa40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional advisors of such companies (including attorneys, auditors, underwriters, and financial advisors); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7854fa41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pre-IPO and post-IPO investors in such companies (both institutional, such as venture capital funds, and individual, such as angel investors); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who represent participants in the marketplace for the securities of emerging companies and smaller public companies, such as securities exchanges, alternative trading systems, analysts, information processors, and transfer agents; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" three non-voting members—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7854fa44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be appointed by the Investor Advocate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be appointed by the North American Securities Administrators Association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be appointed by the Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Committee appointed under subparagraph (B), (C)(ii), or (C)(iii) of paragraph (1) shall serve for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members not Commission employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members appointed under subparagraph (B), (C)(ii), or (C)(iii) of paragraph (1) shall not be treated as employees or agents of the Commission solely because of membership on the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; vice chairman; secretary; assistant secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Committee shall elect, from among the members of the Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vice chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assistant secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member elected under paragraph (1) shall serve for a term of 3 years in the capacity for which the member was elected under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency of meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall meet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than four times annually, at the call of the chairman of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from time to time, at the call of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairman of the Committee shall give the members of the Committee written notice of each meeting, not later than 2 weeks before the date of the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Committee who is not a full-time employee of the United States shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be entitled to receive compensation at a rate not to exceed the daily equivalent of the annual rate of basic pay in effect for a position at level V of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":" for each day during which the member is engaged in the actual performance of the duties of the Committee; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while away from the home or regular place of business of the member in the performance of services for the Committee, be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make available to the Committee such staff as the chairman of the Committee determines are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the findings and recommendations of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each time the Committee submits a finding or recommendation to the Commission, promptly issue a public statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the finding or recommendation of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosing the action, if any, the Commission intends to take with respect to the finding or recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78qq/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Advisory Committee Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002115"},"text":"1","chil