{"tag":"section","attrib":{"id":"id7a212e4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703"},"text":null,"children":[{"tag":"num","attrib":{"value":"3703"},"text":"§ 3703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, unless the context otherwise requires, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a212e4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Centers” means the Cooperative Research Centers established under section 3705 or 3707 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Nonprofit institution” means an organization owned and operated exclusively for scientific or educational purposes, no part of the net earnings of which inures to the benefit of any private shareholder or individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal laboratory” means any laboratory, any federally funded research and development center, or any center established under section 3705 or 3707 of this title that is owned, leased, or otherwise used by a Federal agency and funded by the Federal Government, whether operated by the Government or by a contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Supporting agency” means either the Department of Commerce or the National Science Foundation, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal agency” means any executive agency as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":" and the military departments as defined in section 102 of such title, as well as any agency of the legislative branch of the Federal Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Invention” means any invention or discovery which is or may be patentable or otherwise protected under title 35 or any novel variety of plant which is or may be protectable under the Plant Variety Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2321"},"text":"7 U.S.C. 2321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Made” when used in conjunction with any invention means the conception or first actual reduction to practice of such invention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Small business firm” means a small business concern as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":" and implementing regulations of the Administrator of the Small Business Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Training technology” means computer software and related materials which are developed by a Federal agency to train employees of such agency, including but not limited to software for computer-based instructional systems and for interactive video disc systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3703/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Clearinghouse” means the Clearinghouse for State and Local Initiatives on Productivity, Technology, and Innovation established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3704a"},"text":"section 3704a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a212e5a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s4"},"text":"Pub. L. 96–480, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2312"},"text":"94 Stat. 2312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/2"},"text":"Pub. L. 99–502, § 9(b)(2)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1986-10-20"},"text":"Oct. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1795"},"text":"100 Stat. 1795","children":[],"tail":", 1796; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5122/b"},"text":"Pub. L. 100–418, title V, § 5122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1439"},"text":"102 Stat. 1439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/519/tII/s201/d/1"},"text":"Pub. L. 100–519, title II, § 201(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2594"},"text":"102 Stat. 2594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/245/tIII/s304"},"text":"Pub. L. 102–245, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-14"},"text":"Feb. 14, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/20"},"text":"106 Stat. 20","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/404/s7/1"},"text":"Pub. L. 106–404, § 7(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1745"},"text":"114 Stat. 1745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII/s3002/c/3"},"text":"Pub. L. 110–69, title III, § 3002(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/586"},"text":"121 Stat. 586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a212e5b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a212e5c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a212e5d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Plant Variety Protection Act, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577"},"text":"Pub. L. 91–577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1542"},"text":"84 Stat. 1542","children":[],"tail":", which is classified principally to chapter 57 (§ 2321 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2321"},"text":"section 2321 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a212e5e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" redesignated pars. (2) and (4) to (13) as (1) and (2) to (11), respectively, and struck out pars. (1) and (3) which defined “Office” and “Under Secretary”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Pars. (4), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/404"},"text":"Pub. L. 106–404","children":[],"tail":" made technical amendments to references in original act which appear in text as references to sections 3705 and 3707 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/245"},"text":"Pub. L. 102–245","children":[],"tail":" inserted before period at end “, as well as any agency of the legislative branch of the Federal Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/519/s201/d/1/A"},"text":"Pub. L. 100–519, § 201(d)(1)(A)","children":[],"tail":", substituted “Technology Policy” for “Productivity, Technology, and Innovation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/519/s201/d/1/B"},"text":"Pub. L. 100–519, § 201(d)(1)(B)","children":[],"tail":", amended par. (3) generally, substituting provisions defining “Under Secretary” for provisions defining “Assistant Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/2/A"},"text":"Pub. L. 99–502, § 9(b)(2)(A)","children":[],"tail":", substituted “Productivity, Technology, and Innovation” for “Industrial Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/2/B"},"text":"Pub. L. 99–502, § 9(b)(2)(B)","children":[],"tail":", substituted “ ‘Assistant Secretary’ means the Assistant Secretary for Productivity, Technology, and Innovation” for “ ‘Director’ means the Director of the Office of Industrial Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/2/C"},"text":"Pub. L. 99–502, § 9(b)(2)(C)","children":[],"tail":", substituted “Cooperative Research Centers” for “Centers for Industrial Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/2/D"},"text":"Pub. L. 99–502, § 9(b)(2)(D)","children":[],"tail":", (E), redesignated par. (7) as (6), substituted “owned, leased, or otherwise used by a Federal agency and funded” for “owned and funded”, and struck out former par. (6) which defined “Board” to mean the National Industrial Technology Board established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3709"},"text":"section 3709 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/2/D"},"text":"Pub. L. 99–502, § 9(b)(2)(D)","children":[],"tail":", (d), redesignated pars. (7) and (8) as (6) and (7), respectively, and added pars. (8) to (12)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
