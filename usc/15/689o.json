{"tag":"section","attrib":{"id":"id79293a98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689o"},"text":null,"children":[{"tag":"num","attrib":{"value":"689o"},"text":"§ 689o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal or suspension of directors or officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Using the procedures for removing or suspending a director or an officer of a licensee set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s687e"},"text":"section 687e of this title","children":[],"tail":" (to the extent such procedures are not inconsistent with the requirements of this part), the Administrator may remove or suspend any director or officer of any New Markets Venture Capital company."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79293a99-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s366"},"text":"Pub. L. 85–699, title III, § 366","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–664.)"}],"tail":"\n"}],"tail":null}
