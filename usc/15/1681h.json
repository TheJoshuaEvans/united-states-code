{"tag":"section","attrib":{"id":"id79aa02c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681h"},"text":"§ 1681h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions and form of disclosure to consumers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79aa02c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79aa02c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proper identification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A consumer reporting agency shall require, as a condition of making the disclosures required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681g"},"text":"section 1681g of this title","children":[],"tail":", that the consumer furnish proper identification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aa02c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure in writing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the disclosures required to be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681g"},"text":"section 1681g of this title","children":[],"tail":" shall be provided under that section in writing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa02c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other forms of disclosure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79aa02c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If authorized by a consumer, a consumer reporting agency may make the disclosures required under ","children":[{"tag":"ref","attrib":{"idref":"fn002379"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002379"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “section”."}],"tail":" 1681g of this title—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aa02c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other than in writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa02ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in such form as may be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79aa02cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specified by the consumer in accordance with paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79aa02cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available from the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aa02cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A consumer may specify pursuant to paragraph (1) that disclosures under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681g"},"text":"section 1681g of this title","children":[],"tail":" shall be made—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aa02ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in person, upon the appearance of the consumer at the place of business of the consumer reporting agency where disclosures are regularly provided, during normal business hours, and on reasonable notice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa02cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by telephone, if the consumer has made a written request for disclosure by telephone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa02d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by electronic means, if available from the agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa02d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any other reasonable means that is available from the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa02d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trained personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any consumer reporting agency shall provide trained personnel to explain to the consumer any information furnished to him pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681g"},"text":"section 1681g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa02d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons accompanying consumer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The consumer shall be permitted to be accompanied by one other person of his choosing, who shall furnish reasonable identification. A consumer reporting agency may require the consumer to furnish a written statement granting permission to the consumer reporting agency to discuss the consumer’s file in such person’s presence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa02d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 1681n and 1681","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title, no consumer may bring any action or proceeding in the nature of defamation, invasion of privacy, or negligence with respect to the reporting of information against any consumer reporting agency, any user of information, or any person who furnishes information to a consumer reporting agency, based on information disclosed pursuant to section 1681g, 1681h, or 1681m of this title, or based on information disclosed by a user of a consumer report to or for a consumer against whom the user has taken adverse action, based in whole or in part on the report "},{"tag":"ref","attrib":{"idref":"fn002380"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002380"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" except as to false information furnished with malice or willful intent to injure such consumer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79aa02d5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s610"},"text":"Pub. L. 90–321, title VI, § 610","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tVI/s601"},"text":"Pub. L. 91–508, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1131"},"text":"84 Stat. 1131","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2408/e/1"},"text":"Pub. L. 104–208, div. A, title II, § 2408(e)(1)","children":[],"tail":", (4), (5)(B), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-438"},"text":"110 Stat. 3009–438","children":[],"tail":", 3009–439.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79aa02d6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79aa02d7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79aa02d8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2408/e/5/B"},"text":"Pub. L. 104–208, § 2408(e)(5)(B)","children":[],"tail":", inserted “and form” after “Conditions” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2408/e/1"},"text":"Pub. L. 104–208, § 2408(e)(1)","children":[],"tail":", inserted heading and amended text of subsec. (a) generally. Prior to amendment, text read as follows: “A consumer reporting agency shall make the disclosures required under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681g"},"text":"section 1681g of this title","children":[],"tail":" during normal business hours and on reasonable notice.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2408/e/1"},"text":"Pub. L. 104–208, § 2408(e)(1)","children":[],"tail":", inserted heading and amended text of subsec. (b) generally. Prior to amendment, text read as follows: “The disclosures required under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681g"},"text":"section 1681g of this title","children":[],"tail":" shall be made to the consumer—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in person if he appears in person and furnishes proper identification; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) by telephone if he has made a written request, with proper identification, for telephone disclosure and the toll charge, if any, for the telephone call is prepaid by or charged directly to the consumer.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2408/e/4"},"text":"Pub. L. 104–208, § 2408(e)(4)","children":[],"tail":", inserted “or based on information disclosed by a user of a consumer report to or for a consumer against whom the user has taken adverse action, based in whole or in part on the report” before “except”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79aa02d9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79aa02da-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective 365 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", with special rule for early compliance, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2420"},"text":"section 2420 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a"},"text":"section 1681a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79aa02db-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of one hundred and eighty days following ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s504/d"},"text":"section 504(d) of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/508"},"text":"Pub. L. 91–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
