{"tag":"section","attrib":{"id":"id7a3440de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051"},"text":null,"children":[{"tag":"num","attrib":{"value":"4051"},"text":"§ 4051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of prior authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3440df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, money appropriated to the Department of Commerce for expenses to carry out any export promotion program may be obligated or expended only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3440e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriation thereof has been previously authorized by law enacted on or after ","children":[{"tag":"date","attrib":{"date":"1985-07-12"},"text":"July 12, 1985","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of all such obligations and expenditures does not exceed an amount previously prescribed by law enacted on or after such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3440e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for later legislation authorizing obligations or expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that legislation enacted after the making of an appropriation to carry out any export promotion program authorizes the obligation or expenditure thereof, the limitation contained in subsection (a) shall have no effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3440e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions must be specifically superseded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall not be superseded except by a provision of law enacted after ","children":[{"tag":"date","attrib":{"date":"1985-07-12"},"text":"July 12, 1985","children":[],"tail":", which specifically repeals, modifies, or supersedes the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3440e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Export promotion program” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “export promotion program” means any activity of the Department of Commerce designed to stimulate or assist United States businesses in marketing their goods and services abroad competitively with businesses from other countries, including, but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3440e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade development (except for the trade adjustment assistance program) and dissemination of foreign marketing opportunities and other marketing information to United States producers of goods and services, including the expansion of foreign markets for United States textiles and apparel and any other United States products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of regional and multilateral economic policies which enhance United States trade and investment interests, and the provision of marketing services with respect to foreign countries and regions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exhibition of United States goods in other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operations of the United States and Foreign Commercial Service, or any successor agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Market Development Cooperator Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4723"},"text":"section 4723 of this title","children":[],"tail":", and assistance for trade shows provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4724"},"text":"section 4724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3440ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing outside United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3440eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":", and consistent with other applicable law, the Secretary of Commerce, in carrying out any export promotion program, may authorize—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3440ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the printing, distribution, and sale of documents outside the contiguous United States, if the Secretary finds that the implementation of such export promotion program would be more efficient, and if such documents will be distributed primarily and sold exclusively outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acceptance of private notices and advertisements in connection with the printing and distribution of such documents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4051/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any fees received by the Secretary pursuant to paragraph (1) shall be deposited in a separate account or accounts which may be used to defray directly the costs incurred in conducting activities authorized by paragraph (1) or to repay or make advances to appropriations or other funds available for such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3440ef-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/64/tII/s201"},"text":"Pub. L. 99–64, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-07-12"},"text":"July 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/157"},"text":"99 Stat. 157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII"},"text":"Pub. L. 100–418, title II","children":[],"tail":", §§ 2305(a), 2308(a), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1344"},"text":"102 Stat. 1344","children":[],"tail":", 1346.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3440f0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3440f1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a3440f2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Export Administration Amendments Act of 1985, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/290"},"text":"Pub. L. 97–290","children":[],"tail":" which enacted this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a3440f3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s2305/a"},"text":"Pub. L. 100–418, § 2305(a)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s2308/a"},"text":"Pub. L. 100–418, § 2308(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
