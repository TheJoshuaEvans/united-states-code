{"tag":"section","attrib":{"id":"id7964bbae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1141b"},"text":"§ 1141b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of the international application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7964bbaf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the filing of an application for international registration and payment of the prescribed fees, the Director shall examine the international application for the purpose of certifying that the information contained in the international application corresponds to the information contained in the basic application or basic registration at the time of the certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7964bbb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon examination and certification of the international application, the Director shall transmit the international application to the International Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7964bbb1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title XII, § 62, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13402"},"text":"Pub. L. 107–273, div. C, title III, § 13402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1915"},"text":"116 Stat. 1915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
