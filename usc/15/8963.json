{"tag":"section","attrib":{"id":"id7a939ed2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963"},"text":null,"children":[{"tag":"num","attrib":{"value":"8963"},"text":"§ 8963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency body on research related to per- and polyfluoroalkyl substances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a939ed3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy, acting through the National Science and Technology Council, shall establish, or designate, an interagency working group to coordinate Federal activities related to PFAS research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939ed4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interagency working group shall include a representative of each of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939ed5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ed6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Environmental Health Sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ed7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agency for Toxic Substances and Disease Registry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ed8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ed9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939eda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institutes of Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939edb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939edc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939edd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ede-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939edf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Toxicology Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Geological Survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Information and Regulatory Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Management and Budget; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ee8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/b/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such other Federal department or agency as the Director of the Office of Science and Technology Policy considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939ee9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-chairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency working group shall be co-chaired by the Director of the Office of Science and Technology Policy and, on a biannual rotating basis, a representative from a member agency, as selected by the Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939eea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the working group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interagency working group established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939eeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for interagency coordination of federally funded PFAS research and development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939eec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", develop and make publicly available a strategic plan for Federal support for PFAS research and development (to be updated not less frequently than once every three years) that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939eed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies all current federally funded PFAS research and development, including the nature and scope of such research and development and the amount of funding associated with such research and development during the current fiscal year, disaggregated by agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939eee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies all federally funded PFAS research and development having taken place in the last three years, excluding the research listed under subparagraph (A), including the nature and scope of such research and development and the amount of funding associated with such research and development during the current fiscal year, disaggregated by agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939eef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies scientific and technological challenges that must be addressed to understand and to significantly reduce the environmental and human health impacts of PFAS and to identify cost-effective—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939ef0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternatives to PFAS that are designed to be safer and more environmentally friendly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939ef1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for removal of PFAS from the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939ef2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to safely destroy or degrade PFAS;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939ef3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes goals, priorities, and metrics for federally funded PFAS research and development that takes into account the current state of research and development identified in subparagraph (A) and the challenges identified in subparagraph (C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939ef4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation plan for Federal agencies and, for each update to the strategic plan under this paragraph, a description of how Federal agencies have been following the implementation plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939ef5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the strategic plan under subsection (d)(2), the interagency working group shall consult with States, tribes, territories, local governments, appropriate industries, academic institutions and nongovernmental organizations with expertise in PFAS research and development, treatment, management, and alternative development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939ef6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategic plan requirement described under section ","children":[{"tag":"ref","attrib":{"idref":"fn002613"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002613"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (d)(2) shall cease on the date that is 20 years after the initial strategic plan is developed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939ef7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939ef8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PFAS","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “PFAS” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939ef9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" man-made chemicals of which all of the carbon atoms are fully fluorinated carbon atoms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939efa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" man-made chemicals containing a mix of fully fluorinated carbon atoms, partially fluorinated carbon atoms, and nonfluorinated carbon atoms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939efb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PFAS research and development defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “PFAS research and development” includes any research or project that has the goal of accomplishing the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939efc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The removal of PFAS from the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939efd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The safe destruction or degradation of PFAS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939efe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development and deployment of safer and more environmentally friendly alternative substances that are functionally similar to those made with PFAS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939eff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The understanding of sources of environmental PFAS contamination and pathways to exposure for the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8963/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The understanding of the toxicity of PFAS to humans and animals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a939f01-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s332"},"text":"Pub. L. 116–283, div. A, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3529"},"text":"134 Stat. 3529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a939f02-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a939f03-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a939f04-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, and not as part of the PFAS Act of 2019 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a939f05-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a939f06-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guaranteeing Equipment Safety for Firefighters","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s338"},"text":"Pub. L. 116–283, div. A, title III, § 338","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3533"},"text":"134 Stat. 3533","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tIII/s338"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section may be cited as the ‘Guaranteeing Equipment Safety for Firefighters Act of 2020’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Institute of Standards and Technology Study on Per- and Polyfluoroalkyl Substances in Personal Protective Equipment Worn by Firefighters.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"], the Director of the National Institute of Standards and Technology shall, subject to availability of appropriations, in consultation with the Director of the National Institute for Occupational Safety and Health, complete a study of the contents and composition of new and unused personal protective equipment worn by firefighters."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study required by paragraph (1), the Director of the National Institute of Standards and Technology shall examine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity, prevalence, and concentration of per- and polyfluoroalkyl substances (commonly known as ‘PFAS’) in the personal protective equipment worn by firefighters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions and extent to which per- and polyfluoroalkyl substances are released into the environment over time from the degradation of personal protective equipment from normal use by firefighters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the relative risk of exposure to per- and polyfluoroalkyl substances faced by firefighters from—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their use of personal protective equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" degradation of personal protective equipment from normal use by firefighters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Progress reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than once each year for the duration of the study conducted under paragraph (1), the Director shall submit to Congress a report on the progress of the Director in conducting such study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the Director completes the study required by paragraph (1), the Director shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the Director with respect to the study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on what additional research or technical improvements to personal protective equipment materials or components should be pursued to avoid unnecessary occupational exposure among firefighters to per- and polyfluoroalkyl substances through personal protective equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated $2,500,000 for each of fiscal years 2021 and 2022.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research on Per- and Polyfluoroalkyl Substances in Personal Protective Equipment Worn by Firefighters.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the submittal of the report required by subsection (b)(3)(B), the Director of the National Institute of Standards and Technology shall, subject to the availability of appropriations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a solicitation for research proposals to carry out the research recommendations identified in the report submitted under subsection (b)(3)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants to applicants that submit research proposals to develop safe alternatives to per- and polyfluoroalkyl substances in personal protective equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall select research proposals to receive a grant under paragraph (1) on the basis of merit, using criteria identified by the Director, including the likelihood that the research results will address the findings of the Director with respect to the study conducted under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any entity or group of 2 or more entities may submit to the Director a research proposal in response to the solicitation for research proposals under paragraph (1), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public institutions, including public institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private corporations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for fiscal year 2023, $5,000,000 for fiscal year 2024, and $5,000,000 for fiscal year 2025 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Director of the National Institute of Standards and Technology to Consult With Experts on Matters Relating to Per- and Polyfluoroalkyl Substances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Director of the National Institute of Standards and Technology may consult with Federal agencies, nongovernmental organizations, State and local governments, and science and research institutions determined by the Director to have scientific or material interest in reducing unnecessary occupational exposure to per- and polyfluoroalkyl substances by firefighters.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
