{"tag":"section","attrib":{"id":"id7a68bf03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6908"},"text":null,"children":[{"tag":"num","attrib":{"value":"6908"},"text":"§ 6908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4714"},"text":"section 4714 of title 12","children":[],"tail":" shall apply to a qualified organization receiving assistance from the Administration under this chapter as if it were a community development financial institution receiving assistance from the Fund under subtitle A."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a68bf04-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s179"},"text":"Pub. L. 103–325, title I, § 179","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1474"},"text":"113 Stat. 1474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a68bf05-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a68bf06-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a68bf07-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subtitle A, referred to in text, is subtitle A (§§ 101–121) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2163"},"text":"108 Stat. 2163","children":[],"tail":", known as the Community Development Banking and Financial Institutions Act of 1994, which is classified principally to subchapter I (§ 4701 et seq.) of chapter 47 of Title 12, Banks and Banking. For complete classification of subtitle A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4701"},"text":"section 4701 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
