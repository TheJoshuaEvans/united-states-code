{"tag":"section","attrib":{"id":"id7a1c7308-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392"},"text":null,"children":[{"tag":"num","attrib":{"value":"3392"},"text":"§ 3392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural gas for essential industrial process and feedstock uses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1c7309-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall prescribe and make effective a rule which provides that, notwithstanding any other provision of law (other than subsection (b)) and to the maximum extent practicable, no interstate pipeline may curtail deliveries of natural gas for any essential industrial process or feedstock use, unless such curtailment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c730a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not reduce the quantity of natural gas delivered for such use below the use requirement specified in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c730b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary in order to meet the requirements of high-priority users; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c730c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary in order to meet the requirements for essential agricultural uses of natural gas for which curtailment priority is established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3391"},"text":"section 3391 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c730d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curtailment priority applicable only if alternative fuel not available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsection (a) shall apply with respect to any curtailment of deliveries for any essential industrial process or feedstock use only if the Commission determines that use of a fuel (other than natural gas) is not economically practicable and that no fuel is reasonably available as an alternative for such use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c730e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of essential industrial use requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall determine and certify to the Commission the natural gas requirements (expressed either as volumes or percentages of use) of persons (or classes thereof) for essential industrial process and feedstock uses (other than those referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3391/f/1/B"},"text":"section 3391(f)(1)(B) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c730f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c7310-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential industrial process or feedstock use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “essential industrial process or feedstock use” means any use of natural gas in an industrial process or as a feedstock which the Secretary determines is essential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7311-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3392/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-priority user","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-priority user” has the same meaning as given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3391/f/2"},"text":"section 3391(f)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c7312-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tIV/s402"},"text":"Pub. L. 95–621, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3395"},"text":"92 Stat. 3395","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
