{"tag":"section","attrib":{"id":"id7a239f21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3706"},"text":null,"children":[{"tag":"num","attrib":{"value":"3706"},"text":"§ 3706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a239f22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants and enter into cooperative agreements according to the provisions of this section in order to assist any activity consistent with this chapter, including activities performed by individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a239f23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility and procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person or institution may apply to the Secretary for a grant or cooperative agreement available under this section. Application shall be made in such form and manner, and with such content and other submissions, as the Assistant Secretary shall prescribe. The Secretary shall act upon each such application within 90 days after the date on which all required information is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a239f24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a239f25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any grant made, or cooperative agreement entered into, under this section shall be subject to the limitations and provisions set forth in paragraph (2) of this subsection, and to such other terms, conditions, and requirements as the Secretary deems necessary or appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a239f26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who receives or utilizes any proceeds of any grant made or cooperative agreement entered into under this section shall keep such records as the Secretary shall by regulation prescribe as being necessary and appropriate to facilitate effective audit and evaluation, including records which fully disclose the amount and disposition by such recipient of such proceeds, the total cost of the program or project in connection with which such proceeds were used, and the amount, if any, of such costs which was provided through other sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a239f27-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s8"},"text":"Pub. L. 96–480, § 8","children":[],"tail":", formerly § 7, "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2315"},"text":"94 Stat. 2315","children":[],"tail":"; renumbered § 8 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV"},"text":"Pub. L. 100–418, title V","children":[],"tail":", §§ 5115(b)(1), 5122(a)(1), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":", 1438; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tII/s203"},"text":"Pub. L. 114–329, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2998"},"text":"130 Stat. 2998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a239f28-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a239f29-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a239f2a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s8"},"text":"section 8 of Pub. L. 96–480","children":[],"tail":" was renumbered section 9 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3707"},"text":"section 3707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a239f2b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":" struck out at end “The total amount of any such grant or cooperative agreement may not exceed 75 percent of the total cost of the program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s5115/b/1"},"text":"Pub. L. 100–418, § 5115(b)(1)","children":[],"tail":", substituted “Assistant Secretary” for “Director”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
