{"tag":"section","attrib":{"id":"id790a3f8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a"},"text":null,"children":[{"tag":"num","attrib":{"value":"645a"},"text":"§ 645a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on suspensions and debarments proposed by Small Business Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id790a3f8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Small Business Administration shall submit each year to the Committee on Small Business and Entrepreneurship of the Senate, and the Committee on Small Business of the House of Representatives a report on the suspension and debarment actions taken by the Administrator during the year preceding the year of submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790a3f90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include the following information for the year covered by the report:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id790a3f91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of contractors proposed for suspension or debarment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The office within a Federal agency that originated each proposal for suspension or debarment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reason for each proposal for suspension or debarment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The result of each proposal for suspension or debarment, and the reason for such result.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s645a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referrals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The number of suspensions or debarments referred to the Inspector General of the Small Business Administration or another agency, or to the Attorney General (for purposes of this paragraph, the Administrator may redact identifying information on names of companies or other information in order to protect the integrity of any ongoing criminal or civil investigation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id790a3f96-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1683"},"text":"Pub. L. 112–239, div. A, title XVI, § 1683","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2086"},"text":"126 Stat. 2086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id790a3f97-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id790a3f98-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id790a3f99-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2013, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
