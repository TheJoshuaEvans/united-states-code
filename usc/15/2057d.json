{"tag":"section","attrib":{"id":"id79d0289b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2057d"},"text":"§ 2057d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banning of inclined sleepers for infants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d0289c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-05-16"},"text":"May 16, 2022","children":[],"tail":", inclined sleepers for infants, regardless of the date of manufacture, shall be considered a banned hazardous product under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2057"},"text":"section 2057 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d0289d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclined sleeper for infants defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “inclined sleeper for infants” means a product with an inclined sleep surface greater than ten degrees that is intended, marketed, or designed to provide sleeping accommodations for an infant up to 1 year old.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d0289e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/126/s2"},"text":"Pub. L. 117–126, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-05-16"},"text":"May 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1208"},"text":"136 Stat. 1208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d0289f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d028a0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d028a1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Safe Sleep for Babies Act of 2021, and not as part of the Consumer Product Safety Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
