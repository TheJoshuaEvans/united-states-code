{"tag":"section","attrib":{"id":"id7a3b6d4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4506"},"text":null,"children":[{"tag":"num","attrib":{"value":"4506"},"text":"§ 4506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3b6d4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3b6d4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), the provisions of this chapter (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4504"},"text":"section 4504 of this title","children":[],"tail":") shall terminate 90 days after the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3b6d4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4506/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that all of the restitutionary amounts to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4501/a"},"text":"section 4501(a) of this title","children":[],"tail":" applies have been collected and disbursed as provided in this chapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4506/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to Congress the final report required by ","children":[{"tag":"ref","attrib":{"href":"/u