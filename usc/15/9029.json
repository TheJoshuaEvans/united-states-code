{"tag":"section","attrib":{"id":"id7a9d3c2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029"},"text":null,"children":[{"tag":"num","attrib":{"value":"9029"},"text":"§ 9029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance and guidance in implementing programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9d3c2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to assist States in establishing, qualifying, and implementing short-time compensation programs (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":"), the Secretary of Labor (in this section referred to as the “Secretary”) shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop model legislative language, or disseminate existing model legislative language, which may be used by States in developing and enacting such programs, and periodically review and revise such model legislative language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and guidance in developing, enacting, and implementing such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish reporting requirements for States, including reporting on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of estimated averted layoffs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of participating employers and workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other items as the Secretary of Labor determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model language and guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The model language and guidance developed under subsection (a) shall allow sufficient flexibility by States and participating employers while ensuring accountability and program integrity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9029/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the model legislative language and guidance under subsection (a), and in order to meet the requirements of subsection (b), the Secretary shall consult with employers, labor organizations, State workforce agencies, and other program experts. Existing model legislative language that has been developed through such a consultative process shall be deemed to meet the consultation requirement of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9d3c37-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2111"},"text":"Pub. L. 116–136, div. A, title II, § 2111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/333"},"text":"134 Stat. 333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9d3c38-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9d3c39-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a9d3c3a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s2111"},"text":"section 2111 of Pub. L. 116–136","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s2111"},"text":"section 2111 of Pub. L. 116–136","children":[],"tail":" repealed provisions formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306"},"text":"section 3306 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
