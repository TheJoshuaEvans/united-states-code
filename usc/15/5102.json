{"tag":"section","attrib":{"id":"id7a49c509-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5102"},"text":null,"children":[{"tag":"num","attrib":{"value":"5102"},"text":"§ 5102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c50a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c50b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “domestic company” means a company which is substantially involved in the United States domestic production, processing, or use of steel, aluminum, copper, or other metals and has a substantial percentage of its operations located within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c50c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “management plan” and “plan” mean the Steel Initiative Management Plan issued on ","children":[{"tag":"date","attrib":{"date":"1987-04-01"},"text":"April 1, 1987","children":[],"tail":", by the Department of Energy, which establishes the management framework for the steel research and development initiative, and updates to that plan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c50d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “research plan” means the Steel Initiative Research Plan issued in April 1988 by the Department of Energy, and updates to that plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c50e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/680/s3"},"text":"Pub. L. 100–680, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4073"},"text":"102 Stat. 4073","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
