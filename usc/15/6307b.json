{"tag":"section","attrib":{"id":"id7a55ac9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307b"},"text":"§ 6307b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection from coercive contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a55ac9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a55ac9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A contract provision shall be considered to be in restraint of trade, contrary to public policy, and unenforceable against any boxer to the extent that it—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a55ac9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a coercive provision described in subparagraph (B) and is for a period greater than 12 months; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a55aca0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a coercive provision described in subparagraph (B) and the other boxer under contract to the promoter came under that contract pursuant to a coercive provision described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55aca1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A coercive provision described in this subparagraph is a contract provision that grants any rights between a boxer and a promoter, or between promoters with respect to a boxer, if the boxer is required to grant such rights, or a boxer’s promoter is required to grant such rights with respect to a boxer to another promoter, as a condition precedent to the boxer’s participation in a professional boxing match against another boxer who is under contract to the promoter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55aca2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall only apply to contracts entered into after ","children":[{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55aca3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No subsequent contract provision extending any rights or compensation covered in paragraph (1) shall be enforceable against a boxer if the effective date of the contract containing such provision is earlier than 3 months before the expiration of the relevant time period set forth in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a55aca4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotional rights under mandatory bout contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No boxing service provider may require a boxer to grant any future promotional rights as a requirement of competing in a professional boxing match that is a mandatory bout under the rules of a sanctioning organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f595-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection from coercive contracts with broadcasters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) of this section applies to any contract between a commercial broadcaster and a boxer, or granting any rights with respect to that boxer, involving a broadcast in or affecting interstate commerce, regardless of the broadcast medium. For the purpose of this subsection, any reference in subsection (a)(1)(B) to “promoter” shall be considered a reference to “commercial broadcaster”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f596-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s10"},"text":"Pub. L. 104–272, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/2"},"text":"Pub. L. 106–210, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/322"},"text":"114 Stat. 322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f597-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a57f598-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a57f599-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s10"},"text":"section 10 of Pub. L. 104–272","children":[],"tail":" was renumbered section 18 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6309"},"text":"section 6309 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
