{"tag":"section","attrib":{"id":"id791d5289-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657m"},"text":null,"children":[{"tag":"num","attrib":{"value":"657m"},"text":"§ 657m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans to secure sufficient office space","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791d528a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop long-term plans to secure sufficient office space to accommodate an expanded workforce in times of disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d528b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall include a report on the plans developed under subsection (a) each time the Administration submits a report required under section 657","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d528c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s41"},"text":"Pub. L. 85–536, § 2[41]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12076"},"text":"Pub. L. 110–234, title XII, § 12076","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "}