{"tag":"section","attrib":{"id":"id79aebcec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681p"},"text":"§ 1681p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts; limitation of actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An action to enforce any liability created under this subchapter may be brought in any appropriate United States district court, without regard to the amount in controversy, or in any other court of competent jurisdiction, not later than the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79aebced-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681p/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 years after the date of discovery by the plaintiff of the violation that is the basis for such liability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aebcee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681p/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 years after the date on which the violation that is the basis for such liability occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79aebcef-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s618"},"text":"Pub. L. 90–321, title VI, § 618","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tVI/s601"},"text":"Pub. L. 91–508, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1134"},"text":"84 Stat. 1134","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/159/tI/s156"},"text":"Pub. L. 108–159, title I, § 156","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1968"},"text":"117 Stat. 1968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79aebcf0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79aebcf1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79aebcf2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159"},"text":"Pub. L. 108–159","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “An action to enforce any liability created under this subchapter may be brought in any appropriate United States district court without regard to the amount in controversy, or in any other court of competent jurisdiction, within two years from the date on which the liability arises, except that where a defendant has materially and willfully misrepresented any information required under this subchapter to be disclosed to an individual and the information so misrepresented is material to the establishment of the defendant’s liability to that individual under this subchapter, the action may be brought at any time within two years after discovery by the individual of the misrepresentation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79aebcf3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79aebcf4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159"},"text":"Pub. L. 108–159","children":[],"tail":" subject to joint regulations establishing effective dates as prescribed by Federal Reserve Board and Federal Trade Commission, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/159/s3"},"text":"section 3 of Pub. L. 108–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79aebcf5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of one hundred and eighty days following ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s504/d"},"text":"section 504(d) of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/508"},"text":"Pub. L. 91–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
