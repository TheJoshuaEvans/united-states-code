{"tag":"section","attrib":{"id":"id7a87b7cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8511"},"text":null,"children":[{"tag":"num","attrib":{"value":"8511"},"text":"§ 8511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In conducting research, the Under Secretary shall prioritize improving weather data, modeling, computing, forecasting, and warnings for the protection of life and property and for the enhancement of the national economy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a87b7cd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tI/s101"},"text":"Pub. L. 115–25, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/92"},"text":"131 Stat. 92","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
