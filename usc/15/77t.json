{"tag":"section","attrib":{"id":"id77e743f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t"},"text":null,"children":[{"tag":"num","attrib":{"value":"77t"},"text":"§ 77t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions and prosecution of offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e743f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever it shall appear to the Commission, either upon complaint or otherwise, that the provisions of this subchapter, or of any rule or regulation prescribed under authority thereof, have been or are about to be violated, it may, in its discretion, either require or permit such person to file with it a statement in writing, under oath, or otherwise, as to all the facts and circumstances concerning the subject matter which it believes to be in the public interest to investigate, and may investigate such facts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e743f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action for injunction or criminal prosecution in district court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever it shall appear to the Commission that any person is engaged or about to engage in any acts or practices which constitute or will constitute a violation of the provisions of this subchapter, or of any rule or regulation prescribed under authority thereof, the Commission may, in its discretion, bring an action in any district court of the United States, or United States court of any Territory, to enjoin such acts or practices, and upon a proper showing, a permanent or temporary injunction or restraining order shall be granted without bond. The Commission may transmit such evidence as may be available concerning such acts or practices to the Attorney General who may, in his discretion, institute the necessary criminal proceedings under this subchapter. Any such criminal proceeding may be brought either in the district wherein the transmittal of the prospectus or security complained of begins, or in the district wherein such prospectus or security is received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e743f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Writ of mandamus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon application of the Commission, the district courts of the United States and the United States courts of any Territory shall have jurisdiction to issue writs of mandamus commanding any person to comply with the provisions of this subchapter or any order of the Commission made in pursuance thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e743f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Money penalties in civil actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e743fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever it shall appear to the Commission that any person has violated any provision of this subchapter, the rules or regulations thereunder, or a cease-and-desist order entered by the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77h–1"},"text":"section 77h–1 of this title","children":[],"tail":", other than by committing a violation subject to a penalty pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78u–1"},"text":"section 78u–1 of this title","children":[],"tail":", the Commission may bring an action in a United States district court to seek, and the court shall have jurisdiction to impose, upon a proper showing, a civil penalty to be paid by the person who committed such violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e743fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of penalty","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e743fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of the penalty shall be determined by the court in light of the facts and circumstances. For each violation, the amount of the penalty shall not exceed the greater of (i) $5,000 for a natural person or $50,000 for any other person, or (ii) the gross amount of pecuniary gain to such defendant as a result of the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e743fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second tier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the amount of penalty for each such violation shall not exceed the greater of (i) $50,000 for a natural person or $250,000 for any other person, or (ii) the gross amount of pecuniary gain to such defendant as a result of the violation, if the violation described in paragraph (1) involved fraud, deceit, manipulation, or deliberate or reckless disregard of a regulatory requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e743fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third tier","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraphs (A) and (B), the amount of penalty for each such violation shall not exceed the greater of (i) $100,000 for a natural person or $500,000 for any other person, or (ii) the gross amount of pecuniary gain to such defendant as a result of the violation, if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77e743ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/2/C/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation described in paragraph (1) involved fraud, deceit, manipulation, or deliberate or reckless disregard of a regulatory requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77e74400-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/2/C/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such violation directly or indirectly resulted in substantial losses or created a significant risk of substantial losses to other persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e74401-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for collection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e74402-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of penalty to Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A penalty imposed under this section shall be payable into the Treasury of the United States, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7246"},"text":"section 7246 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78u–6"},"text":"section 78u–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e74403-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person upon whom such a penalty is imposed shall fail to pay such penalty within the time prescribed in the court’s order, the Commission may refer the matter to the Attorney General who shall recover such penalty by action in the appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e74404-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedy not exclusive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The actions authorized by this subsection may be brought in addition to any other action that the Commission or the Attorney General is entitled to bring.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e74405-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77v"},"text":"section 77v of this title","children":[],"tail":", actions under this section shall be actions to enforce a liability or a duty created by this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e74406-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions relating to a violation of a cease-and-desist order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an action to enforce a cease-and-desist order entered by the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77h–1"},"text":"section 77h–1 of this title","children":[],"tail":", each separate violation of such order shall be a separate offense, except that in the case of a violation through a continuing failure to comply with such an order, each day of the failure to comply with the order shall be deemed a separate offense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e74407-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of court to prohibit persons from serving as officers and directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding under subsection (b), the court may prohibit, conditionally or unconditionally, and permanently or for such period of time as it shall determine, any person who violated ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77q/a/1"},"text":"section 77q(a)(1) of this title","children":[],"tail":" from acting as an officer or director of any issuer that has a class of securities registered pursuant to section 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title or that is required to file reports pursuant to section 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title if the person’s conduct demonstrates unfitness to serve as an officer or director of any such issuer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e74408-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of attorneys’ fees paid from Commission disgorgement funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise ordered by the court upon motion by the Commission, or, in the case of an administrative action, as otherwise ordered by the Commission, funds disgorged as the result of an action brought by the Commission in Federal court, or as a result of any Commission administrative action, shall not be distributed as payment for attorneys’ fees or expenses incurred by private parties seeking distribution of the disgorged funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e74409-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of a court to prohibit persons from participating in an offering of penny stock","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e7440a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding under subsection (a) against any person participating in, or, at the time of the alleged misconduct, who was participating in, an offering of penny stock, the court may prohibit that person from participating in an offering of penny stock, conditionally or unconditionally, and permanently or for such period of time as the court shall determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b50b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77t/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “person participating in an offering of penny stock” includes any person engaging in activities with a broker, dealer, or issuer for purposes of issuing, trading, or inducing or attempting to induce the purchase or sale of, any penny stock. The Commission may, by rule or regulation, define such term to include other activities, and may, by rule, regulation, or order, exempt any person or class of persons, in whole or in part, conditionally or unconditionally, from inclusion in such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e9b50c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 20, "},{"tag":"ref","attrib":{"href":"/us/stat/48/86"},"text":"48 Stat. 86","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/181/tII/s208"},"text":"Pub. L. 100–181, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1253"},"text":"101 Stat. 1253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/429/tI/s101"},"text":"Pub. L. 101–429, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/932"},"text":"104 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/67/tI/s103/b/1"},"text":"Pub. L. 104–67, title I, § 103(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/756"},"text":"109 Stat. 756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIII"},"text":"Pub. L. 107–204, title III","children":[],"tail":", §§ 305(a)(2), 308(d)(3), title VI, § 603(b), "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/779"},"text":"116 Stat. 779","children":[],"tail":", 785, 795; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s923/a/1"},"text":"Pub. L. 111–203, title IX, § 923(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1849"},"text":"124 Stat. 1849","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e9b50d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e9b50e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e9b50f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78u–6"},"text":"section 78u–6 of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7246"},"text":"section 7246 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s308/d/3"},"text":"Pub. L. 107–204, § 308(d)(3)","children":[],"tail":", inserted “, except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7246"},"text":"section 7246 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s305/a/2"},"text":"Pub. L. 107–204, § 305(a)(2)","children":[],"tail":", substituted “unfitness” for “substantial unfitness”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s603/b"},"text":"Pub. L. 107–204, § 603(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/67"},"text":"Pub. L. 104–67","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/429"},"text":"Pub. L. 101–429","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/181/s208/a"},"text":"Pub. L. 100–181, § 208(a)","children":[],"tail":", inserted first sentence and struck out former first sentence containing similar provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/181/s208/b"},"text":"Pub. L. 100–181, § 208(b)","children":[],"tail":", amended subsec. (c) generally."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e9b510-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e9b511-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e9b512-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/67"},"text":"Pub. L. 104–67","children":[],"tail":" not to affect or apply to any private action arising under this subchapter or title I of the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.), commenced before and pending on "},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/67/s108"},"text":"section 108 of Pub. L. 104–67","children":[],"tail":", set out as a note under section 77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e9b513-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","childre