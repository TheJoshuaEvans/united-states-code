{"tag":"section","attrib":{"id":"id7a6feb41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220"},"text":null,"children":[{"tag":"num","attrib":{"value":"7220"},"text":"§ 7220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6feb42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “audit” means an examination of the financial statements, reports, documents, procedures, controls, or notices of any issuer, broker, or dealer by an independent public accounting firm in accordance with the rules of the Board or the Commission, for the purpose of expressing an opinion on the financial statements or providing an audit report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6feb43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “audit report” means a document, report, notice, or other record—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6feb44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared following an audit performed for purposes of compliance by an issuer, broker, or dealer with the requirements of the securities laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6feb45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in which a public accounting firm either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6feb46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the opinion of that firm regarding a financial statement, report, notice, or other document, procedures, or controls; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6feb47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asserts that no such opinion can be expressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6feb48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “broker” means a broker (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/4"},"text":"section 78c(a)(4) of this title","children":[],"tail":") that is required to file a balance sheet, income statement, or other financial statement under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78q/e/1/A"},"text":"section 78q(e)(1)(A) of this title","children":[],"tail":", where such balance sheet, income statement, or financial statement is required to be certified by a registered public accounting firm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6feb49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dealer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dealer” means a dealer (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/5"},"text":"section 78c(a)(5) of this title","children":[],"tail":") that is required to file a balance sheet, income statement, or other financial statement under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78q/e/1/A"},"text":"section 78q(e)(1)(A) of this title","children":[],"tail":", where such balance sheet, income statement, or financial statement is required to be certified by a registered public accounting firm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6feb4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “professional standards” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6feb4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accounting principles that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6feb4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established by the standard setting body described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s/b"},"text":"section 77s(b) of this title","children":[],"tail":", as amended by this Act, or prescribed by the Commission under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s/a"},"text":"section 77s(a) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m/b"},"text":"section 78m(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6feb4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant to audit reports for particular issuers, brokers, or dealers, or dealt with in the quality control system of a particular registered public accounting firm; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6feb4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" auditing standards, standards for attestation engagements, quality control policies and procedures, ethical and competency standards, and independence standards (including rules implementing title II) that the Board or the Commission determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6feb4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relate to the preparation or issuance of audit reports for issuers, brokers, or dealers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6feb50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are established or adopted by the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7213/a"},"text":"section 7213(a) of this title","children":[],"tail":", or are promulgated as rules of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6feb51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7220/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-regulatory organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “self-regulatory organization” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6feb52-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tI/s110"},"text":"Pub. L. 107–204, title I, § 110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s982/a/1"},"text":"Pub. L. 111–203, title IX, § 982(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1927"},"text":"124 Stat. 1927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6feb53-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6feb54-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a6feb55-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s/b"},"text":"Section 77s(b) of this title","children":[],"tail":", as amended by this Act, referred to in par. (5)(A)(i), means "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s/b"},"text":"section 77s(b) of this title","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title II, referred to in par. (5)(B), means title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/771"},"text":"116 Stat. 771","children":[],"tail":", which enacted subchapter II of this chapter and amended sections 78c, 78j–1, 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" and 78q of this title. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a6feb56-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a6feb57-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":