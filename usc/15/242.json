{"tag":"section","attrib":{"id":"id7889773e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s242"},"text":null,"children":[{"tag":"num","attrib":{"value":"242"},"text":"§ 242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty of United States attorney to enforce law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of each United States attorney, to whom satisfactory evidence of any violation of sections 237 to 242 of this title is presented, to cause appropriate proceedings to be commenced and prosecuted in the United States court having jurisdiction of such offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7889773f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-23/ch396/s6"},"text":"Aug. 23, 1916, ch. 396, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/531"},"text":"39 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78897740-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78897741-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78897742-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", substituted “United States attorney” for “district attorney”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
