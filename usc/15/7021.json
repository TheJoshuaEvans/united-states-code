{"tag":"section","attrib":{"id":"id7a68bfa9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021"},"text":null,"children":[{"tag":"num","attrib":{"value":"7021"},"text":"§ 7021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferable records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a68bfaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bfab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferable record","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “transferable record” means an electronic record that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68bfac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be a note under Article 3 of the Uniform Commercial Code if the electronic record were in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bfad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer of the electronic record expressly has agreed is a transferable record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bfae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to a loan secured by real property.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A transferable record may be executed using an electronic signature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bfaf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “electronic record”, “electronic signature”, and “person” have the same meanings provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7006"},"text":"section 7006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bfb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person has control of a transferable record if a system employed for evidencing the transfer of interests in the transferable record reliably establishes that person as the person to which the transferable record was issued or transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bfb1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A system satisfies subsection (b), and a person is deemed to have control of a transferable record, if the transferable record is created, stored, and assigned in such a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bfb2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single authoritative copy of the transferable record exists which is unique, identifiable, and, except as otherwise provided in paragraphs (4), (5), and (6), unalterable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bfb3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the authoritative copy identifies the person asserting control as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68bfb4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person to which the transferable record was issued; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bfb5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the authoritative copy indicates that the transferable record has been transferred, the person to which the transferable record was most recently transferred;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bfb6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authoritative copy is communicated to and maintained by the person asserting control or its designated custodian;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bfb7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies or revisions that add or change an identified assignee of the authoritative copy can be made only with the consent of the person asserting control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bfb8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each copy of the authoritative copy and any copy of a copy is readily identifiable as a copy that is not the authoritative copy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bfb9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any revision of the authoritative copy is readily identifiable as authorized or unauthorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as holder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise agreed, a person having control of a transferable record is the holder, as defined in section 1–201(20) of the Uniform Commercial Code, of the transferable record and has the same rights and defenses as a holder of an equivalent record or writing under the Uniform Commercial Code, including, if the applicable statutory requirements under section 3–302(a), 9–308, or revised section 9–330 of the Uniform Commercial Code are satisfied, the rights and defenses of a holder in due course or a purchaser, respectively. Delivery, possession, and endorsement are not required to obtain or exercise any of the rights under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligor rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise agreed, an obligor under a transferable record has the same rights and defenses as an equivalent obligor under equivalent records or writings under the Uniform Commercial Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If requested by a person against which enforcement is sought, the person seeking to enforce the transferable record shall provide reasonable proof that the person is in control of the transferable record. Proof may include access to the authoritative copy of the transferable record and related business records sufficient to review the terms of the transferable record and to establish the identity of the person having control of the transferable record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7021/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" UCC references","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, all references to the Uniform Commercial Code are to the Uniform Commercial Code as in effect in the jurisdiction the law of which governs the transferable record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b08ae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/229/tII/s201"},"text":"Pub. L. 106–229, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/473"},"text":"114 Stat. 473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6b08af-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a6b08b0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a6b08b1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/229/tII/s202"},"text":"Pub. L. 106–229, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/475"},"text":"114 Stat. 475","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/229/tII/s202"},"text":"“This title [enacting this subchapter] shall be effective 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
