{"tag":"section","attrib":{"id":"id77bc636d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"§ 27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of partial invalidity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any clause, sentence, paragraph, or part of this Act shall, for any reason, be adjudged by any court of competent jurisdiction to be in­valid, such judgment shall not affect, impair, or invalidate the remainder thereof, but shall be confined in its operation to the clause, sentence, paragraph, or part thereof directly involved in the controversy in which such judgment shall have been rendered.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77bc636e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323/s28"},"text":"Oct. 15, 1914, ch. 323, § 28","children":[],"tail":", formerly § 26, "},{"tag":"ref","attrib":{"href":"/us/stat/38/740"},"text":"38 Stat. 740","children":[],"tail":"; renumbered § 27, "},{"tag":"ref","attrib":{"href":"/us/pl/96/493/s2"},"text":"Pub. L. 96–493, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-02"},"text":"Dec. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2568"},"text":"94 Stat. 2568","children":[],"tail":"; renumbered § 28, "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIV/s14102/d"},"text":"Pub. L. 107–273, div. C, title IV, § 14102(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1922"},"text":"116 Stat. 1922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77bc636f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"r