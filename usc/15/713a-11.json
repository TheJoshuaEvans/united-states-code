{"tag":"section","attrib":{"id":"id79352101-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s713a–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"713a–11"},"text":"§ 713a–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual appropriations to reimburse Commodity Credit Corporation for net realized loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated annually for each fiscal year by means of a current, indefinite appropriation, out of any money in the Treasury not otherwise appropriated, an amount sufficient to reimburse Commodity Credit Corporation for its net realized loss incurred during such fiscal year, as reflected in its accounts and shown in its report of its financial condition as of the close of such fiscal year. Reimbursement of net realized loss shall be with appropriated funds, as provided herein, rather than through the cancellation of notes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79352102-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/155/s2"},"text":"Pub. L. 87–155, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-17"},"text":"Aug. 17, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/391"},"text":"75 Stat. 391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1506/a"},"text":"Pub. L. 100–203, title I, § 1506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-28"},"text":"101 Stat. 1330–28","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79352103-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79352104-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79352105-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “by means of a current, indefinite appropriation” for “, commencing with the fiscal year ending "},{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79352106-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79352107-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1506/c"},"text":"Pub. L. 100–203, title I, § 1506(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-29"},"text":"101 Stat. 1330–29","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tI/s1506/c"},"text":"“This section and the amendment made by this section [amending this section and enacting provisions set out as a note below] shall apply beginning with fiscal year 1988.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79352108-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Operating Expenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1506/b"},"text":"Pub. L. 100–203, title I, § 1506(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-29"},"text":"101 Stat. 1330–29","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tI/s1506/b"},"text":"“No funds may be appropriated for operating expenses of the Commodity Credit Corporation except as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/155/s2"},"text":"section 2 of Public Law 87–155","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–11"},"text":"15 U.S.C. 713a–11","children":[],"tail":"] to reimburse the Corporation for net realized losses.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
