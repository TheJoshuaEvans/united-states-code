{"tag":"section","attrib":{"id":"id7a7234a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261"},"text":null,"children":[{"tag":"num","attrib":{"value":"7261"},"text":"§ 7261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures in periodic reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7234aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission rules on pro forma figures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", the Commission shall issue final rules providing that pro forma financial information included in any periodic or other report filed with the Commission pursuant to the securities laws, or in any public disclosure or press or other release, shall be presented in a manner that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not contain an untrue statement of a material fact or omit to state a material fact necessary in order to make the pro forma financial information, in light of the circumstances under which it is presented, not misleading; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reconciles it with the financial condition and results of operations of the issuer under generally accepted accounting principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on special purpose entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall, not later than 1 year after the effective date of adoption of off-balance sheet disclosure rules required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m/j"},"text":"section 78m(j) of this title","children":[],"tail":", complete a study of filings by issuers and their disclosures to determine—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7234b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of off-balance sheet transactions, including assets, liabilities, leases, losses, and the use of special purpose entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether generally accepted accounting rules result in financial statements of issuers reflecting the economics of such off-balance sheet transactions to investors in a transparent fashion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the date of completion of the study required by paragraph (1), the Commission shall submit a report to the President, the Committee on Banking, Housing, and Urban Affairs of the Senate, and the Committee on Financial Services of the House of Representatives, setting forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7234b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount or an estimate of the amount of off-balance sheet transactions, including assets, liabilities, leases, and losses of, and the use of special purpose entities by, issuers filing periodic reports pursuant to section 78m or 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which special purpose entities are used to facilitate off-balance sheet transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether generally accepted accounting principles or the rules of the Commission result in financial statements of issuers reflecting the economics of such transactions to investors in a transparent fashion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether generally accepted accounting principles specifically result in the consolidation of special purpose entities sponsored by an issuer in cases in which the issuer has the majority of the risks and rewards of the special purpose entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7261/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Commission for improving the transparency and quality of reporting off-balance sheet transactions in the financial statements and disclosures required to be filed by an issuer with the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7234b8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIV/s401"},"text":"Pub. L. 107–204, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/785"},"text":"116 Stat. 785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7234b9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a7234ba-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a7234bb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s401"},"text":"section 401 of Pub. L. 107–204","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/204/s401"},"text":"section 401 of Pub. L. 107–204","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m"},"text":"section 78m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
