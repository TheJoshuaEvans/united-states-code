{"tag":"section","attrib":{"id":"id7a723512-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303"},"text":null,"children":[{"tag":"num","attrib":{"value":"7303"},"text":"§ 7303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a723513-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry and inspection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In investigating a building failure under this chapter, members of a Team, and any other person authorized by the Director to support a Team, on display of appropriate credentials provided by the Director and written notice of inspection authority, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723514-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter property where a building failure being investigated has occurred, or where building components, materials, and artifacts with respect to the building failure are located, and take action necessary, appropriate, and reasonable in light of the nature of the property to be inspected to carry out the duties of the Team under section 7301(b)(2)(A) and (B) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723515-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during reasonable hours, inspect any record (including any design, construction, or maintenance record), process, or facility related to the investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723516-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and test any building components, materials, and artifacts related to the building failure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723517-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" move such records, components, materials, and artifacts as provided by the procedures developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7301/c/1"},"text":"section 7301(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a723518-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoiding unnecessary interference and preserving evidence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An inspection, test, or other action taken by a Team under this section shall be conducted in a way that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723519-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not interfere unnecessarily with services provided by the owner or operator of the building components, materials, or artifacts, property, records, process, or facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72351a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent feasible, preserves evidence related to the building failure, consistent with the ongoing needs of the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a72351b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a72351c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" With search and rescue efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Team shall not impede, and shall coordinate its investigation with, any search and rescue efforts being undertaken at the site of the building failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72351d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" With other research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Team shall coordinate its investigation, to the extent practicable, with qualified researchers who are conducting engineering or scientific (including social science) research relating to the building failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72351e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memoranda of understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Institute of Standards and Technology shall enter into a memorandum of understanding with each Federal agency that may conduct or sponsor a related investigation, providing for coordination of investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72351f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" With State and local authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Team shall cooperate with State and local authorities carrying out any activities related to a Team’s investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723520-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil suits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where practicable, a Team shall cooperate with civil litigants without compromising a Team’s investigation or the evidence preservation activities as described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a723521-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation priorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723522-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2) or (3), a Team investigation shall have priority over any other investigation of any other Federal agency or any civil suit or civil action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723523-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Transportation Safety Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the National Transportation Safety Board is conducting an investigation related to an investigation of a Team, the National Transportation Safety Board investigation shall have priority over the Team investigation. Such priority shall not otherwise affect the authority of the Team to continue its investigation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723524-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General, in consultation with the Director, determines, and notifies the Director, that circumstances reasonably indicate that the building failure being investigated by a Team may have been caused by a criminal act, the Team shall relinquish investigative priority to the appropriate law enforcement agency. The relinquishment of investigative priority by the Team shall not otherwise affect the authority of the Team to continue its investigation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723525-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7303/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Federal law enforcement agency suspects and notifies the Director that a building failure being investigated by a Team under this chapter may have been caused by a criminal act, the Team, in consultation with the Federal law enforcement agency, shall take necessary actions to ensure that evidence of the criminal act is preserved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a723526-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231/s4"},"text":"Pub. L. 107–231, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1472"},"text":"116 Stat. 1472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10246/h"},"text":"Pub. L. 117–167, div. B, title II, § 10246(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1494"},"text":"136 Stat. 1494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a723527-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a723528-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a723529-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (d)(2) to (4), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231"},"text":"Pub. L. 107–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1471"},"text":"116 Stat. 1471","children":[],"tail":", known as the National Construction Safety Team Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7301"},"text":"section 7301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a72352a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10246/h/1"},"text":"Pub. L. 117–167, § 10246(h)(1)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10246/h/2/A"},"text":"Pub. L. 117–167, § 10246(h)(2)(A)","children":[],"tail":", substituted “Investigation” for “Interagency” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10246/h/2/B"},"text":"Pub. L. 117–167, § 10246(h)(2)(B)","children":[],"tail":", inserted “or any civil suit or civil action” after “Federal agency”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
