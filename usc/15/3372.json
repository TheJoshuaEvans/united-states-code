{"tag":"section","attrib":{"id":"id7a1a02bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3372"},"text":null,"children":[{"tag":"num","attrib":{"value":"3372"},"text":"§ 3372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of contractual rights to receive surplus natural gas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1a02c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assignments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, by rule or order, authorize any intrastate pipeline to assign, without compensation, to any interstate pipeline or local distribution company all or any portion of such intrastate pipeline’s right to receive surplus natural gas at any first sale, upon such terms and conditions as the Commission determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1a02c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of authorization under subsection (a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the effect of an authorization under subsection (a), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3431"},"text":"section 3431 of this title","children":[],"tail":" (relating to the coordination of this chapter with the Natural Gas Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717"},"text":"15 U.S.C. 717","children":[],"tail":" et seq.])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1a02c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus natural gas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “surplus natural gas” means any natural gas which is determined, by the State agency having regulatory jurisdiction over the intrastate pipeline which would be entitled to receive such natural gas in the absence of any assignment to exceed the then current demands on such pipeline for natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1a02c3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tIII/s312"},"text":"Pub. L. 95–621, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3392"},"text":"92 Stat. 3392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b/2"},"text":"Pub. L. 101–60, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-07-26"},"text":"July 26, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/158"},"text":"103 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1a02c4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1a02c5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1a02c6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Natural Gas Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556"},"text":"act June 21, 1938, ch. 556","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/821"},"text":"52 Stat. 821","children":[],"tail":", which is classified generally to chapter 15B (§ 717 et seq.) of this title. For complete classification of this act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717w"},"text":"section 717w of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1a02c7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60"},"text":"Pub. L. 101–60","children":[],"tail":" substituted “any natural gas” for “any natural gas—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) which is not committed or dedicated to interstate commerce on ","children":[{"tag":"date","attrib":{"date":"1978-11-08"},"text":"November 8, 1978","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the first sale of which is subject to a maximum lawful price established under subchapter I of this chapter; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3)”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1a02c8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a1a02c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b"},"text":"Section 3(b) of Pub. L. 101–60","children":[],"tail":" provided in part that the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b/2"},"text":"section 3(b)(2) of Pub. L. 101–60","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
