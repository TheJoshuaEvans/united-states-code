{"tag":"section","attrib":{"id":"id7a2aa453-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722"},"text":null,"children":[{"tag":"num","attrib":{"value":"3722"},"text":"§ 3722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional innovation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2aa454-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa455-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible recipient” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa456-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa457-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa458-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a city or other political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa459-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2aa45a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a nonprofit organization, an institution of higher education, a public-private partnership, a science or research park, a Federal laboratory, a venture development organization, or an economic development organization or similar entity that is focused primarily on improving science, technology, innovation, or entrepreneurship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa45b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an application submitted under subsection (c)(4) that is supported by a State or a political subdivision of a State; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa45c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of any of the entities described in subparagraphs (A) through (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa45d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional innovation initiative","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “regional innovation initiative” means a geographically-bounded public or nonprofit activity or program to address issues in the local innovation systems in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa45e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the success of innovation-driven industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa45f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the competitiveness of industry through new product innovation and new technology adoption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa460-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the pace of market readiness and overall commercialization of innovative research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa461-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the overall innovation capacity and long-term resilience of the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa462-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage the region’s unique competitive strengths to stimulate innovation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa463-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of full-time equivalent employment opportunities within innovation-based business ventures in the geographic region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa464-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means one of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, or any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa465-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venture development organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “venture development organization” means a State or nonprofit organization that contributes to regional or sector-based economic prosperity by providing services for the purposes of accelerating the commercialization of research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa466-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a regional innovation program to encourage and support the development of regional innovation strategies designed to increase innovation-driven economic opportunity within their respective regions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa467-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional innovation grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa468-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the program established pursuant to subsection (b), the Secretary may award grants, on a competitive basis, to eligible recipients for activities designed to develop and support a regional innovation initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa469-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this subsection shall be used for multiple activities determined appropriate by the Secretary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa46a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning, technical assistance, and communication among participants of a regional innovation initiative to improve the connectedness and strategic orientation of the regional innovation initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa46b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attracting additional participants to a regional innovation initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa46c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the availability and investment of private and philanthropic financing that supports innovation-based business ventures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa46d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating commercialization of products, processes, and services, including through demonstration, deployment, technology transfer, and entrepreneurial activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa46e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this subsection may not be used to pay for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa46f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs related to the recruitment, inducement, or associated financial or tangible incentives that might be offered to relocate an existing business from a geographic area to another geographic area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa470-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with offsetting revenues forgone by 1 or more taxing authorities through tax incentives, tax increment financing, special improvement districts, tax abatements for private development within designated zones or geographic areas, or other reduction in revenues resulting from tax credits affecting the geographic region of the eligible recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa471-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa472-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible recipient shall submit an application to the Secretary at such time, in such manner, and containing such information and assurances as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa473-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2aa474-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the regional innovation initiative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa475-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate whether the regional innovation initiative is supported by the private sector, State and local governments, and other relevant stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa476-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify what activities the regional innovation initiative will undertake;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa477-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the expected outcomes of the regional innovation initiative and the metrics the eligible recipient will use to assess progress toward those outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa478-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate whether the participants in the regional innovation initiative have access to, or contribute to, a well-trained workforce and other innovation assets that are critical to the successful outcomes specified in the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa479-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate whether the participants in the regional innovation initiative are capable of attracting additional funds from non-Federal sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa47a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate for the activities proposed in the application, analyze the likelihood that the participants in the regional innovation initiative will be able to sustain activities after grant funds received under this subsection have been expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa47b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedback","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide feedback to program applicants that are not awarded grants to help them improve future applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa47c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall give special consideration to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2aa47d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications proposing to include workforce or training related activities in their regional innovation initiative from eligible recipients who agree to collaborate with local workforce investment area boards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa47e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications from regions that contain communities negatively impacted by trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa47f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not provide more than 50 percent of the total cost of any activity funded under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa480-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach to rural communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct outreach to public and private sector entities in rural communities to encourage those entities to participate in regional innovation initiatives under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa481-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting a competitive process, the Secretary shall avoid undue geographic concentration among any one category of States based on their predominant rural or urban character as indicated by population density.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa482-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept funds from other Federal agencies to support grants and activities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa483-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional innovation research and information program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa484-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program established pursuant to subsection (b), the Secretary shall establish a regional innovation research and information program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa485-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to gather, analyze, and disseminate information on best practices for regional innovation initiatives, including information relating to how innovation, productivity, and economic development can be maximized through such strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa486-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance, including through the development of technical assistance guides, for the development and implementation of regional innovation initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa487-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the development of relevant metrics and measurement standards to evaluate regional innovation initiatives, including the extent to which such strategies stimulate innovation, productivity, and economic development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa488-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to collect and make available data on regional innovation initiatives in the United States, including data on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2aa489-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size, specialization, and competitiveness of regional innovation initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa48a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regional domestic product contribution, total jobs and earnings by key occupations, establishment size, nature of specialization, patents, Federal research and development spending, and other relevant information for regional innovation initiatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa48b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply chain product and service flows within and between regional innovation initiatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa48c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award research grants on a competitive basis to support and further the goals of the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa48d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Data and analysis compiled by the Secretary under the program established in this subsection shall be made available to other Federal agencies, State and local governments, and nonprofit and for-profit entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa48e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional innovation grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall incorporate data and analysis relating to any grant awarded under subsection (c) into the program established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa48f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa490-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall ensure that the activities carried out under this section are coordinated with, and do not duplicate the efforts of, other programs at the Department of Commerce or at other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa491-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa492-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall explore and pursue collaboration with other Federal agencies, including through multi-agency funding opportunities, on regional innovation strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa493-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small businesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that such collaboration with Federal agencies prioritizes the needs and challenges of small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa494-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa495-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after Congress first appropriates funds to carry out this section, the Secretary shall competitively award a contract with an independent entity to conduct an evaluation of programs established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa496-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evaluation conducted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa497-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether the program is achieving its goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa498-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program’s efficacy in providing awards to geographically diverse entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa499-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for how the program may be improved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa49a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recommendation as to whether the program should be continued or terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa49b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after the first grant is awarded under subsection (c), and every 5 years thereafter until 5 years after the last grant recipient completes the regional innovation initiative for which such grant was awarded, the Secretary shall submit a summary report to Congress that describes the outcome of each regional innovation initiative that was completed during the previous 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa49c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts appropriated by Congress to the Secretary, the Secretary may use up to $50,000,000 in each of the fiscal years 2020 through 2024 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2aa49d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s27"},"text":"Pub. L. 96–480, § 27","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tVI/s603"},"text":"Pub. L. 111–358, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4030"},"text":"124 Stat. 4030","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dB/tVII/s705"},"text":"Pub. L. 113–235, div. B, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2230"},"text":"128 Stat. 2230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1742"},"text":"Pub. L. 116–92, div. A, title XVII, § 1742","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1837"},"text":"133 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2aa49e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2aa49f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a2aa4a0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" amended section generally. Prior to amendment, section related to regional innovation program, consisting of subsecs. (a) to (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" amended section generally. Prior to amendment, text related to regional innovation program and consisted of subsecs. (a) to (i), including provisions relating to establishment of program, cluster grants, science and research park development grants, loan guarantees for science park infrastructure, regional innovation research and information program, interagency coordination, evaluation of program, definitions, and authorization of appropriations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
