{"tag":"section","attrib":{"id":"id7a9f8601-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050"},"text":null,"children":[{"tag":"num","attrib":{"value":"9050"},"text":"§ 9050.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary relief for community banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9f8602-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8603-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “appropriate Federal banking agency” has the meaning given the term in section 2 of the Economic Growth, Regulatory Relief, and Consumer Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"12 U.S.C. 5365","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8604-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “Community Bank Leverage Ratio” and “qualifying community bank” have the meanings given the terms in section 201(a) of the Economic Growth, Regulatory Relief, and Consumer Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5371"},"text":"12 U.S.C. 5371","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f8605-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8606-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law or regulation, the appropriate Federal banking agencies shall issue an interim final rule that provides that, for the purposes of section 201 of the Economic Growth, Regulatory Relief, and Consumer Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5371"},"text":"12 U.S.C. 5371","children":[],"tail":" note)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f8607-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Community Bank Leverage Ratio shall be 8 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f8608-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualifying community bank that falls below the Community Bank Leverage Ratio established under subparagraph (A) shall have a reasonable grace period to satisfy the Community Bank Leverage Ratio.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8609-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interim rule issued under paragraph (1) shall be effective during the period beginning on the date on which the appropriate Federal banking agencies issue the rule and ending on the sooner of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f860a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination date of the national emergency concerning the novel coronavirus disease (COVID–19) outbreak declared by the President on ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":" under the National Emergencies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f860b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f860c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9050/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grace period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During a grace period described in subsection (b)(1)(B), a qualifying community bank to which the grace period applies may continue to be treated as a qualifying community bank and shall be presumed to satisfy the capital and leverage requirements described in section 201(c) of the Economic Growth, Regulatory Relief, and Consumer Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5371"},"text":"12 U.S.C. 5371","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9f860d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4012"},"text":"Pub. L. 116–136, div. A, title IV, § 4012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/479"},"text":"134 Stat. 479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9f860e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9f860f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9f8610-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2 of the Economic Growth, Regulatory Relief, and Consumer Protection Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s2"},"text":"section 2 of Pub. L. 115–174","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1297"},"text":"132 Stat. 1297","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5365"},"text":"section 5365 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 201 of the Economic Growth, Regulatory Relief, and Consumer Protection Act, referred to in subsecs. (a)(2), (b)(1), and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s201"},"text":"section 201 of Pub. L. 115–174","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1306"},"text":"132 Stat. 1306","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5371"},"text":"section 5371 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Emergencies Act, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412"},"text":"Pub. L. 94–412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":", which is classified principally to chapter 34 (§ 1601 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"section 1601 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
