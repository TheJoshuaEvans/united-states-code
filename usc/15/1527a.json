{"tag":"section","attrib":{"id":"id7983dd0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1527a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1527a"},"text":"§ 1527a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economics and Statistics Administration Revolving Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established the Economics and Statistics Administration Revolving Fund which shall be available without fiscal year limitation. For initial capitalization, there is appropriated $1,677,000 to the Fund: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Secretary of Commerce is authorized to disseminate economic and statistical data products as authorized by sections 1525 to 1527 of this title and, notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4912"},"text":"section 4912 of this title","children":[],"tail":", charge fees necessary to recover the full costs incurred in their production. Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", receipts received from these data dissemination activities shall be credited to this account as offsetting collections, to be available for carrying out these purposes without further appropriation."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7983dd0d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317/tII"},"text":"Pub. L. 103–317, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1744"},"text":"108 Stat. 1744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7983dd0e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7983dd0f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7983dd10-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Dissemination of Economic and Statistical Data Products; Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/119/tII"},"text":"Pub. L. 105–119, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2474"},"text":"111 Stat. 2474","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/119/tII"},"text":"“The Secretary of Commerce is authorized to disseminate economic and statistical data products as authorized by sections 1, 2, and 4 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/412"},"text":"Public Law 91–412","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1525–152"},"text":"15 U.S.C. 1525–152","children":[],"tail":"7) and, notwithstanding section 5412 of the Omnibus Trade and Competitiveness Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4912"},"text":"15 U.S.C. 4912","children":[],"tail":"), charge fees necessary to recover the full costs incurred in their production. Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"31 U.S.C. 3302","children":[],"tail":", receipts received from these data dissemination activities shall be credited to this account, to be available for carrying out these purposes without further appropriation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–34."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title II], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–25; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
