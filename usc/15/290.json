{"tag":"section","attrib":{"id":"id789c89c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290"},"text":null,"children":[{"tag":"num","attrib":{"value":"290"},"text":"§ 290.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress hereby finds and declares that reliable standardized scientific and technical reference data are of vital importance to the progress of the Nation’s science and technology. It is therefore the policy of the Congress to make critically evaluated reference data readily available to scientists, engineers, and the general public. It is the purpose of this chapter to strengthen and enhance this policy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789c89c4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/396/s1"},"text":"Pub. L. 90–396, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-11"},"text":"July 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/339"},"text":"82 Stat. 339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789c89c5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id789c89c6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id789c89c7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/396/s8"},"text":"Pub. L. 90–396, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-11"},"text":"July 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/340"},"text":"82 Stat. 340","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/396/s8"},"text":"“This Act [enacting this chapter] may be cited as the ‘Standard Reference Data Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
