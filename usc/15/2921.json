{"tag":"section","attrib":{"id":"id7a108cd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921"},"text":null,"children":[{"tag":"num","attrib":{"value":"2921"},"text":"§ 2921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108cd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Committee” means the Committee on Earth and Environmental Sciences established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2932"},"text":"section 2932 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Council” means the Federal Coordinating Council on Science, Engineering, and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “global change” means changes in the global environment (including alterations in climate, land productivity, oceans or other water resources, atmospheric chemistry, and ecological systems) that may alter the capacity of the Earth to sustain life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “global change research” means study, monitoring, assessment, prediction, and information management activities to describe and understand—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a108cd6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interactive physical, chemical, and biological processes that regulate the total Earth system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a108cd7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unique environment that the Earth provides for life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a108cd8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes that are occurring in the Earth system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a108cd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which such system, environment, and changes are influenced by human actions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Plan” means the National Global Change Research Plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2934"},"text":"section 2934 of this title","children":[],"tail":", or any revision thereof; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108cdb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2921/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Program” means the United States Global Change Research Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2933"},"text":"section 2933 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108cdc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/s2"},"text":"Pub. L. 101–606, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3096"},"text":"104 Stat. 3096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a108cdd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a108cde-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a108cdf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/s1"},"text":"Pub. L. 101–606, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3096"},"text":"104 Stat. 3096","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/606/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Global Change Research Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/tII/s201"},"text":"Pub. L. 101–606, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3102"},"text":"104 Stat. 3102","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/606/tII/s201"},"text":"“This title [enacting subchapter II of this chapter] may be cited as the ‘International Cooperation in Global Change Research Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
