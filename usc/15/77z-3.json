{"tag":"section","attrib":{"id":"id77ebfed2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"77z–3"},"text":"§ 77z–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General exemptive authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission, by rule or regulation, may conditionally or unconditionally exempt any person, security, or transaction, or any class or classes of persons, securities, or transactions, from any provision or provisions of this subchapter or of any rule or regulation issued under this subchapter, to the extent that such exemption is necessary or appropriate in the public interest, and is consistent with the protection of investors.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ebfed3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 28, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/290/tI/s105/a"},"text":"Pub. L. 104–290, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3424"},"text":"110 Stat. 3424","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/353/tIII/s301/a/5"},"text":"Pub. L. 105–353, title III, § 301(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3235"},"text":"112 Stat. 3235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ebfed4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ebfed5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77ebfed6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353"},"text":"Pub. L. 105–353","children":[],"tail":" made technical correction relating to placement of section in subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
