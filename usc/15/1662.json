{"tag":"section","attrib":{"id":"id799df49b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1662"},"text":null,"children":[{"tag":"num","attrib":{"value":"1662"},"text":"§ 1662.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising of downpayments and installments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No advertisement to aid, promote, or assist directly or indirectly any extension of consumer credit may state","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799df49c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1662/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a specific periodic consumer credit amount or installment amount can be arranged, unless the creditor usually and customarily arranges credit payments or installments for that period and in that amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799df49d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1662/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a specified downpayment is required in connection with any extension of consumer credit, unless the creditor usually and customarily arranges downpayments in that amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799df49e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s142"},"text":"Pub. L. 90–321, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/158"},"text":"82 Stat. 158","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
