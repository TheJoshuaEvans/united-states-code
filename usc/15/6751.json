{"tag":"section","attrib":{"id":"id7a619378-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6751"},"text":null,"children":[{"tag":"num","attrib":{"value":"6751"},"text":"§ 6751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Association of Registered Agents and Brokers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a619379-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Association of Registered Agents and Brokers (referred to in this subchapter as the “Association”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a61937a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Association shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a61937b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a nonprofit corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a61937c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be an agent or instrumentality of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a61937d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6751/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an independent organization that may not be merged with or into any other private or public entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a61937e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6751/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided in this subchapter, be subject to, and have all the powers conferred upon, a nonprofit corporation by the District of Columbia Nonprofit Corporation Act (D.C. Code, sec. 29–301.01 et seq.) or any successor thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a61937f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s321"},"text":"Pub. L. 106–102, title III, § 321","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/13"},"text":"129 Stat. 13","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a619380-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a619381-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a619382-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","child