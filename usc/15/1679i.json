{"tag":"section","attrib":{"id":"id79a2d6d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679i"},"text":"§ 1679i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any action to enforce any liability under this subchapter may be brought before the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d6d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the 5-year period beginning on the date of the occurrence of the violation involved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in any case in which any credit repair organization has materially and willfully misrepresented any information which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a2d6da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit repair organization is required, by any provision of this subchapter, to disclose to any consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d6db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is material to the establishment of the credit repair organization’s liability to the consumer under this subchapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the end of the 5-year period beginning on the date of the discovery by the consumer of the misrepresentation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a2d6dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s411"},"text":"Pub. L. 90–321, title IV, § 411","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-461"},"text":"110 Stat. 3009–461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2d6dd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a2d6de-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a2d6df-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable after the end of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", except with respect to contracts entered into by a credit repair organization before the end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s413"},"text":"section 413 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
