{"tag":"section","attrib":{"id":"id799df4bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665a"},"text":"§ 1665a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of annual percentage rate in oral disclosures; exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":" In responding orally to any inquiry about the cost of credit, a creditor, regardless of the method used to compute finance charges, shall state rates only in terms of the annual percentage rate, except that in the case of an open end credit plan, the periodic rate also may be stated and, in the case of an other than open end credit plan where a major component of the finance charge consists of interest computed at a simple annual rate, the simple annual rate also may be stated. The Bureau may, by regulation, modify the requirements of this section or provide an exception from this section for a transaction or class of transactions for which the creditor cannot determine in advance the applicable annual percentage rate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799df4c0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s146"},"text":"Pub. L. 90–321, title I, § 146","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIV/s401/a"},"text":"Pub. L. 93–495, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1517"},"text":"88 Stat. 1517","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s623/a"},"text":"Pub. L. 96–221, title VI, § 623(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/185"},"text":"94 Stat. 185","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df4c1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799df4c2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799df4c3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" substituted provisions relating to use of annual percentage rate in oral disclosures by creditors, for provisions setting forth requirements for advertisements concerning consumer credit repayable in more than four installments."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df4c4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799df4c5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799df4c6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" effective on expiration of two years and six months after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", with all regulations, forms, and clauses required to be prescribed to be promulgated at least one year prior to such effective date, and allowing any creditor to comply with any amendments, in accordance with the regulations, forms, and clauses prescribed by the Board prior to such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s625"},"text":"section 625 of Pub. L. 96–221","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799df4c7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIV/s416"},"text":"Pub. L. 93–495, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1521"},"text":"88 Stat. 1521","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/495/tIV/s416"},"text":"“This title [enacting this section and sections 1614 and 1645 of this title, amending sections 1603, 1607, 1635, 1637, 1640, and 1644 of this title, and enacting provision set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1640"},"text":"section 1640 of this title","children":[],"tail":"] takes effect upon the date of its enactment ["},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":"], except that sections 409 [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1631"},"text":"section 1631 of this title","children":[],"tail":"] and 411 [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637"},"text":"section 1637 of this title","children":[],"tail":"] take effect upon the expiration of one year after the date of its enactment ["},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
