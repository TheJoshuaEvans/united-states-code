{"tag":"section","attrib":{"id":"id7ab298e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552"},"text":null,"children":[{"tag":"num","attrib":{"value":"9552"},"text":"§ 9552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab298e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may establish MBDA Rural Business Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab298e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab298e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an MBDA Rural Business Center established by the Under Secretary, the Under Secretary shall establish the MBDA Rural Business Center in partnership with an eligible entity in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MBDA agreement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab298eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each MBDA Rural Business Center established by the Under Secretary, the Under Secretary shall enter into a cooperative agreement with an eligible entity that provides that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab298ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity shall provide space, facilities, and staffing for the MBDA Rural Business Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary shall provide funding for, and oversight with respect to, the MBDA Rural Business Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (B), the eligible entity shall match 20 percent of the amount of the funding provided by the Under Secretary under clause (ii), which may be calculated to include the costs of providing the space, facilities, and staffing under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lower match requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Based on the available resources of an eligible entity, the Under Secretary may enter into a cooperative agreement with the eligible entity that provides that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab298f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity shall match less than 20 percent of the amount of the funding provided by the Under Secretary under subparagraph (A)(ii); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Under Secretary makes a determination, upon a demonstration by the eligible entity of substantial need, the eligible entity shall not be required to provide any match with respect to the funding provided by the Under Secretary under subparagraph (A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity may provide matching funds required under an MBDA Rural Business Center agreement with Federal funds received from other Federal programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial term of an MBDA Rural Business Center agreement shall be not less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary and an eligible entity may agree to extend the term of an MBDA Rural Business Center agreement with respect to an MBDA Rural Business Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab298f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An MBDA Rural Business Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab298f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" primarily serve clients that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab298f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural minority business enterprises; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority business enterprises that are located more than 50 miles from an MBDA Business Center (other than that MBDA Rural Business Center);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" focus on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab298fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" issues relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab298fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of broadband internet access service (as defined in section 8.1(b) of title 47, Code of Federal Regulations, or any successor regulation), digital literacy skills, and e-commerce by rural minority business enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of manufacturing in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways in which rural minority business enterprises can meet gaps in the supply chain of critical supplies and essential goods and services for the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the connectivity of rural minority business enterprises through transportation and logistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29900-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting trade and export opportunities by rural minority business enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29901-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing financial capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29902-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating entrepreneurship in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29903-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating jobs in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29904-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other issue relating to the unique challenges faced by rural minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29905-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide education, training, and legal, financial, and technical assistance to minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29906-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29907-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Under Secretary shall issue a Notice of Funding Opportunity requesting applications from eligible entities that desire to enter into MBDA Rural Business Center agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29908-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria and priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting an eligible entity with which to enter into an MBDA Rural Business Center agreement, the Under Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29909-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" select an eligible entity that demonstrates—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab2990a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to collaborate with governmental and private sector entities to leverage capabilities of minority business enterprises through public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab2990b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research and extension capacity to support minority business enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab2990c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge of the community that the eligible entity serves and the ability to conduct effective outreach to that community to advance the goals of an MBDA Rural Business Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab2990d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to provide innovative business solutions, including access to contracting opportunities, markets, and capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab2990e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to provide services that advance the development of science, technology, engineering, and math jobs within minority business enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab2990f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to leverage resources from within the eligible entity to advance an MBDA Rural Business Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29910-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the mission of the eligible entity aligns with the mission of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29911-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to leverage relationships with rural minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29912-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a referral relationship with not less than 1 community-based organization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29913-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority to an eligible entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab29914-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in a State or region that has a significant population of socially or economically disadvantaged individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29915-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a history of serving socially or economically disadvantaged individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab29916-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the determination of the Under Secretary, has not received an equitable allocation of land and financial resources under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7ab29917-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":" (commonly known as the “First Morrill Act”) ("},{"tag":"ref","attrib":{"href":"/us/stat/12/503"},"text":"12 Stat. 503","children":[],"tail":", chapter 130; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"7 U.S.C. 301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7ab29918-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" (commonly known as the “Second Morrill Act”) ("},{"tag":"ref","attrib":{"href":"/us/stat/26/417"},"text":"26 Stat. 417","children":[],"tail":", chapter 841; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"7 U.S.C. 321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29919-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9552/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to enter into an MBDA Rural Business Center agreement with an eligible entity under this section, the Under Secretary shall consider the needs of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab2991a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tIII/s100302"},"text":"Pub. L. 117–58, div. K, title III, § 100302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1459"},"text":"135 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab2991b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab2991c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab2991d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":", referred to in subsec. (d)(2)(B)(iii)(I), is "},{"tag":"ref","attrib":{"href":"/us/act/1862-07-02/ch130"},"text":"act July 2, 1862, ch. 130","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/503"},"text":"12 Stat. 503","children":[],"tail":", popularly known as the Morrill Act and also as the First Morrill Act, which is classified generally to subchapter I (§ 301 et seq.) of chapter 13 of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"section 301 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":", referred to in subsec. (d)(2)(B)(iii)(II), is "},{"tag":"ref","attrib":{"href":"/us/act/1890-08-30/ch841"},"text":"act Aug. 30, 1890, ch. 841","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/417"},"text":"26 Stat. 417","children":[],"tail":", popularly known as the Agricultural College Act of 1890 and also as the Second Morrill Act, which is classified generally to subchapter II (§ 321 et seq.) of chapter 13 of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"section 321 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
