{"tag":"section","attrib":{"id":"id79ef21ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2471"},"text":null,"children":[{"tag":"num","attrib":{"value":"2471"},"text":"§ 2471.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the purposes of this chapter, not to exceed $6,250,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", and the subsequent transition period ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":"; not to exceed $5,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":"; and not to exceed $5,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":". Funds appropriated for any fiscal year shall remain available for obligation until expended."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ef21ef-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/136/tVII/s701"},"text":"Pub. L. 94–136, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/743"},"text":"89 Stat. 743","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
