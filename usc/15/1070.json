{"tag":"section","attrib":{"id":"id795db68a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1070"},"text":null,"children":[{"tag":"num","attrib":{"value":"1070"},"text":"§ 1070.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals to Trademark Trial and Appeal Board from decisions of examiners","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An appeal may be taken to the Trademark Trial and Appeal Board from any final decision of the examiner in charge of the registration of marks or a final decision by an examiner in an ex parte expungement proceeding or ex parte reexamination proceeding upon the payment of the prescribed fee. The Director may reconsider, and modify or set aside, a decision of the Trademark Trial and Appeal Board under this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id795db68b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title I, § 20, "},{"tag":"ref","attrib":{"href":"/us/stat/60/435"},"text":"60 Stat. 435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/609/s1/b"},"text":"Pub. L. 85–609, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/540"},"text":"72 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tII"},"text":"Pub. L. 116–260, div. Q, title II","children":[],"tail":", §§ 225(d)(1), 228(a)(2), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2207"},"text":"134 Stat. 2207","children":[],"tail":", 2210.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795db68c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","ch