{"tag":"section","attrib":{"id":"id798ae1f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1608"},"text":null,"children":[{"tag":"num","attrib":{"value":"1608"},"text":"§ 1608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Views of other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the exercise of its functions under this subchapter, the Bureau may obtain upon requests the views of any other Federal agency which, in the judgment of the Bureau, exercises regulatory or supervisory functions with respect to any class of creditors subject to this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id798ae1fa-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s109"},"text":"Pub. L. 90–321, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/150"},"text":"82 Stat. 150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798ae1fb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798ae1fc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id798ae1fd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"