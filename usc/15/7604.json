{"tag":"section","attrib":{"id":"id7a7bd1c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7604"},"text":null,"children":[{"tag":"num","attrib":{"value":"7604"},"text":"§ 7604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of contact lens prescriptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7bd1c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contact lens prescription shall expire—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd1c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date specified by the law of the State in which the prescription was written, if that date is one year or more after the issue date of the prescription;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than one year after the issue date of the prescription if such State law specifies no date or a date that is less than one year after the issue date of the prescription; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding paragraphs (1) and (2), on the date specified by the prescriber, if that date is based on the medical judgment of the prescriber with respect to the ocular health of the patient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for prescriptions of less than 1 year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a prescription expires in less than 1 year, the reasons for the judgment referred to in subsection (a)(3) shall be documented in the patient’s medical record. In no circumstance shall the prescription expiration date be less than the period of time recommended by the prescriber for a reexamination of the patient that is medically necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “issue date” means the date on which the patient receives a copy of the prescription.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7bd1ca-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s5"},"text":"Pub. L. 108–164, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2025"},"text":"117 Stat. 2025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd1cb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a7bd1cc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a7bd1cd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/164/s12"},"text":"section 12 of Pub. L. 108–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7601"},"text":"section 7601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
