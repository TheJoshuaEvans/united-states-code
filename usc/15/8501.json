{"tag":"section","attrib":{"id":"id7a87b7bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8501"},"text":null,"children":[{"tag":"num","attrib":{"value":"8501"},"text":"§ 8501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b7be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seasonal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “seasonal” means the time range between 3 months and 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means a State, a territory, or possession of the United States, including a Commonwealth, or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subseasonal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “subseasonal” means the time range between 2 weeks and 3 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Under Secretary” means the Under Secretary of Commerce for Oceans and Atmosphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weather industry and weather enterprise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “weather industry” and “weather enterprise” are interchangeable in this chapter, and include individuals and organizations from public, private, and academic sectors that contribute to the research, development, and production of weather forecast products, and primary consumers of these weather forecast products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b7c3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s2"},"text":"Pub. L. 115–25, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/92"},"text":"131 Stat. 92","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a87b7c4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a87b7c5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a87b7c6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25"},"text":"Pub. L. 115–25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"April 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/91"},"text":"131 Stat. 91","children":[],"tail":", known as the Weather Research and Forecasting Innovation Act of 2017, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a87b7c7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a87b7c8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/229/dD/s1"},"text":"Pub. L. 117–229, div. D, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-16"},"text":"Dec. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2313"},"text":"136 Stat. 2313","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/229/dD/s1"},"text":"“This Act [enacting subchapter IV of this chapter] may be cited as the ‘Providing Research and Estimates of Changes In Precipitation Act’ or the ‘PRECIP Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a87b7c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s1"},"text":"Pub. L. 115–423, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5454"},"text":"132 Stat. 5454","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/423/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8550"},"text":"section 8550 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4010"},"text":"section 4010 of Title 33","children":[],"tail":", Navigation and Navigable Waters, amending sections 313d, 8512, 8518 to 8521, 8531, and 8532 of this title and sections 4001 to 4002 and 4009 of Title 33, enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4001"},"text":"section 4001 of Title 33","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s313d"},"text":"section 313d of this title","children":[],"tail":"] may be cited as the ‘National Integrated Drought Information System Reauthorization Act of 2018’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a87b7ca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s1/a"},"text":"Pub. L. 115–25, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/91"},"text":"131 Stat. 91","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/25/s1/a"},"text":"“This Act [enacting this chapter and sections 3206a and 3208 of Title 33, Navigation and Navigable Waters, amending sections 3201 to 3207 of Title 33, and enacting and repealing provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3201"},"text":"section 3201 of Title 33","children":[],"tail":"] may be cited as the ‘Weather Research and Forecasting Innovation Act of 2017’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
