{"tag":"section","attrib":{"id":"id7a912f57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952"},"text":null,"children":[{"tag":"num","attrib":{"value":"8952"},"text":"§ 8952.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and coordination plan for enhanced response on emerging contaminants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912f58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review Federal efforts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify, monitor, and assist in the development of treatment methods for emerging contaminants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist States in responding to the human health risks posed by contaminants of emerging concern; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in collaboration with owners and operators of public water systems, States, and other interested stakeholders, establish a strategic plan for improving the Federal efforts referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912f5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Working Group on emerging contaminants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Administrator and the Secretary of Health and Human Services shall jointly establish a Working Group to coordinate the activities of the Federal Government to identify and analyze the public health effects of drinking water contaminants of emerging concern."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Working Group shall include representatives of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Environmental Protection Agency, appointed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following agencies, appointed by the Secretary of Health and Human Services:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency for Toxic Substances and Disease Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Geological Survey, appointed by the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other Federal agency the assistance of which the Administrator determines to be necessary to carry out this subsection, appointed by the head of the respective agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing working group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may expand or modify the duties of an existing working group to perform the duties of the Working Group under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912f68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Emerging Contaminant Research Initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal research strategy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Director of the Office of Science and Technology Policy (referred to in this subsection as the “Director”) shall coordinate with the heads of the agencies described in subparagraph (C) to establish a research initiative, to be known as the “National Emerging Contaminant Research Initiative”, that shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the Federal research strategy to improve the identification, analysis, monitoring, and treatment methods of contaminants of emerging concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop any necessary program, policy, or budget to support the implementation of the Federal research strategy, including mechanisms for joint agency review of research proposals, for interagency cofunding of research activities, and for information sharing across agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on emerging contaminants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subparagraph (A), the Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration consensus conclusions from peer-reviewed, pertinent research on emerging contaminants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Administrator, identify priority emerging contaminants for research emphasis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agencies referred to in subparagraph (A) include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institutes of Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Geological Survey; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal agency that contributes to research in water quality, environmental exposures, and public health, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation from additional entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subparagraph (A), the Director shall consult with nongovernmental organizations, State and local governments, and science and research institutions determined by the Director to have scientific or material interest in the National Emerging Contaminant Research Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of research recommendations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the Director and heads of the agencies described in paragraph (1)(C) establish the National Emerging Contaminant Research Initiative under paragraph (1)(A), the head of each agency described in paragraph (1)(C) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a solicitation for research proposals consistent with the Federal research strategy and that agency’s mission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to applicants that submit research proposals consistent with the Federal research strategy and in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of research proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each agency described in paragraph (1)(C) shall select research proposals to receive grants under this paragraph on the basis of merit, using criteria identified by the head of each such agency, including the likelihood that the proposed research will result in significant progress toward achieving the objectives identified in the Federal research strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any entity or group of 2 or more entities may submit to the head of each agency described in paragraph (1)(C) a research proposal in response to the solicitation for research proposals described in subparagraph (A)(i), including, consistent with that agency’s grant policies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public institutions, including public institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private corporations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912f82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal technical assistance and support for States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Administrator shall conduct a study on actions the Administrator can take to increase technical assistance and support for States with respect to emerging contaminants in drinking water samples."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study described in subparagraph (A), the Administrator shall identify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods and effective treatment options to increase technical assistance and support with respect to emerging contaminants to States, including identifying opportunities for States to improve communication with various audiences about the risks associated with emerging contaminants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means to facilitate access to qualified contract testing laboratory facilities that conduct analyses for emerging contaminants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions to be carried out at existing Federal laboratory facilities, including the research facilities of the Administrator, to provide technical assistance and support for States that require testing facilities for emerging contaminants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of analytical resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study described in subparagraph (A), the Administrator shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the availability of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a912f8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and non-Federal laboratory capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912f8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validated methods to detect and analyze contaminants; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors determined to be appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Administrator shall submit to Congress a report describing the results of the study described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to provide Federal assistance to States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", based on the findings in the report described in paragraph (2), the Administrator shall develop a program to provide technical assistance and support to eligible States for the testing and analysis of emerging contaminants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for technical assistance and support under this paragraph, a State shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall evaluate an application for technical assistance and support under this paragraph on the basis of merit using criteria identified by the Administrator, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a912f94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laboratory facilities available to the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912f95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability and applicability of existing analytical methodologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912f96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potency and severity of the emerging contaminant, if known; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912f97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevalence and magnitude of the emerging contaminant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting States to receive technical assistance and support under this paragraph, the Administrator—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a912f99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give priority to States with affected areas primarily in financially distressed communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912f9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a912f9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive the application process in an emergency situation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912f9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an abbreviated application process for the continuation of work specified in a previously approved application that continues to meet the criteria described in clause (ii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912f9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall consider the relative expertise and availability of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a912f9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and non-Federal laboratory capacity available to the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912f9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytical resources available to the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912fa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/B/iii/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other types of technical assistance available to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912fa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database of available resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish and maintain a database of resources available through the program developed under subparagraph (A) to assist States with testing for emerging contaminants that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912fa2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a912fa3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" available to States and stakeholder groups determined by the Administrator to have scientific or material interest in emerging contaminants, including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a912fa4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drinking water and wastewater utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912fa5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912fa6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State emergency responders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912fa7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State primacy agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912fa8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/I/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a912fa9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/I/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water associations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912faa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" searchable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912fab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessible through the website of the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912fac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a912fad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified contract testing laboratory facilities that conduct analyses for emerging contaminants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a912fae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources available in Federal laboratory facilities to test for emerging contaminants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912faf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water contaminant information tool","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall integrate the database established under subparagraph (C) into the Water Contaminant Information Tool of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912fb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts available to the Administrator, the Administrator may use not more than $15,000,000 in a fiscal year to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912fb1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 2 years until 2029, the Administrator shall submit to Congress a report that describes the progress made in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912fb2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8952/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section modifies any obligation of a State, local government, or Indian Tribe with respect to treatment methods for, or testing or monitoring of, drinking water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912fb3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7342"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7342","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2284"},"text":"133 Stat. 2284","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
