{"tag":"section","attrib":{"id":"id7a4e8050-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5523"},"text":null,"children":[{"tag":"num","attrib":{"value":"5523"},"text":"§ 5523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As part of the Program described in subchapter I, the Secretary of Energy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4e8051-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5523/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support basic and applied research in networking and information technology to support fundamental research in science and engineering disciplines related to energy applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4e8052-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5523/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide computing and networking infrastructure support, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4e8053-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5523/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of high-end computing systems that are among the most advanced in the world in terms of performance in solving scientific and engineering problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4e8054-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5523/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for advanced software and applications development for science and engineering disciplines related to energy applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a50f055-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/194/tII/s203"},"text":"Pub. L. 102–194, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1600"},"text":"105 Stat. 1600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1052/j"},"text":"Pub. L. 104–66, title I, § 1052(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/719"},"text":"109 Stat. 719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s976/b"},"text":"Pub. L. 109–58, title IX, § 976(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/903"},"text":"119 Stat. 903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s105"},"text":"Pub. L. 114–329, title I, § 105","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2984"},"text":"130 Stat. 2984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a50f056-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a50f057-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a50f058-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105"},"text":"Pub. L. 114–329, § 105","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), (4), struck out subsec. (a) designation and heading “General responsibilities” and struck out subsec. (b) which authorized to be appropriated to the Secretary of Energy such sums as necessary to carry out this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105"},"text":"Pub. L. 114–329, § 105","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), substituted “networking and information technology” for “high-performance computing and networking”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105"},"text":"Pub. L. 114–329, § 105","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), substituted “high-end” for “high-performance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" reenacted section catchline without change and amended text generally, substituting provisions relating to general responsibilities and authorization of appropriations for provisions relating to general responsibilities, establishment of High-Performance Computing Research and Development Collaborative Consortia, transfer of technology to private sector and others, reports on activities, and authorization of appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “Within one year after "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"December 9, 1991","children":[],"tail":", and every year thereafter, the Secretary of Energy shall transmit to the Congress a report on activities taken to carry out this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
