{"tag":"section","attrib":{"id":"id792b8422-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l"},"text":null,"children":[{"tag":"num","attrib":{"value":"690l"},"text":"§ 690l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792b8423-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Renewable Fuel Capital Investment company that participates in the program established under this part shall be subject to examinations made at the direction of the Investment Division of the Administration in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b8424-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of private sector entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Examinations under this section may be conducted with the assistance of a private sector entity that has both the qualifications and the expertise necessary to conduct such examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b8425-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b8426-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792b8427-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may assess the cost of examinations under this section, including compensation of the examiners, against the company examined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b8428-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any company against which the Administrator assesses costs under this paragraph shall pay such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b8429-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds collected under this section shall be deposited in the account for salaries and expenses of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792b842a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s393"},"text":"Pub. L. 85–699, title III, § 393","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1782"},"text":"121 Stat. 1782","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
