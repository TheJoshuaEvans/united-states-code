{"tag":"section","attrib":{"id":"id7a533ae6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6101"},"text":null,"children":[{"tag":"num","attrib":{"value":"6101"},"text":"§ 6101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533ae7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Telemarketing differs from other sales activities in that it can be carried out by sellers across State lines without direct contact with the consumer. Telemarketers also can be very mobile, easily moving from State to State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ae8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interstate telemarketing fraud has become a problem of such magnitude that the resources of the Federal Trade Commission are not sufficient to ensure adequate consumer protection from such fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ae9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consumers and others are estimated to lose $40 billion a year in telemarketing fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533aea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consumers are victimized by other forms of telemarketing deception and abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533aeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consequently, Congress should enact legislation that will offer consumers necessary protection from telemarketing deception and abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a533aec-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/297/s2"},"text":"Pub. L. 103–297, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-16"},"text":"Aug. 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1545"},"text":"108 Stat. 1545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a533aed-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a533aee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a533aef-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1011/a"},"text":"Pub. L. 107–56, title X, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/396"},"text":"115 Stat. 396","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/56/tX/s1011/a"},"text":"“This section [amending sections 6102 and 6106 of this title and sections 917 and 2325 of Title 18, Crimes and Criminal Procedure] may be cited as the ‘Crimes Against Charitable Americans Act of 2001’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a533af0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/534/s1"},"text":"Pub. L. 106–534, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2555"},"text":"114 Stat. 2555","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/534/s1"},"text":"“This Act [enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3732"},"text":"section 3732 of Title 42","children":[],"tail":", The Public Health and Welfare] may be cited as the ‘Protecting Seniors From Fraud Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a533af1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/297/s1"},"text":"Pub. L. 103–297, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-16"},"text":"Aug. 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1545"},"text":"108 Stat. 1545","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/297/s1"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9b"},"text":"section 9b of Title 7","children":[],"tail":", Agriculture, and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s52"},"text":"section 52 of this title","children":[],"tail":"] may be cited as the ‘Telemarketing and Consumer Fraud and Abuse Prevention Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a533af2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/534/s2"},"text":"Pub. L. 106–534, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2555"},"text":"114 Stat. 2555","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/534/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Older Americans are among the most rapidly growing segments of our society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Our Nation’s elderly are too frequently the victims of violent crime, property crime, and consumer and telemarketing fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The elderly are often targeted and retargeted in a range of fraudulent schemes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The TRIAD program, originally sponsored by the National Sheriffs’ Association, International Association of Chiefs of Police, and the American Association of Retired Persons unites sheriffs, police chiefs, senior volunteers, elder care providers, families, and seniors to reduce the criminal victimization of the elderly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress should continue to support TRIAD and similar community partnerships that improve the safety and quality of life for millions of senior citizens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are few other community-based efforts that forge partnerships to coordinate criminal justice and social service resources to improve the safety and security of the elderly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to the National Consumers League, telemarketing fraud costs consumers nearly $40,000,000,000 each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior citizens are often the target of telemarketing fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fraudulent telemarketers compile the names of consumers who are potentially vulnerable to telemarketing fraud into the so-called ‘mooch lists’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is estimated that 56 percent of the names on such ‘mooch lists’ are individuals age 50 or older.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Bureau of Investigation and the Federal Trade Commission have provided resources to assist private-sector organizations to operate outreach programs to warn senior citizens whose names appear on confiscated ‘mooch lists’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administration on Aging was formed, in part, to provide senior citizens with the resources, information, and assistance their special circumstances require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"“(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administration on Aging has a system in place to inform senior citizens of the dangers of telemarketing fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"“(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior citizens need to be warned of the dangers of telemarketing fraud before they become victims of such fraud.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a533af3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senior Fraud Prevention Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/534/s3"},"text":"Pub. L. 106–534, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2556"},"text":"114 Stat. 2556","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/534/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Attorney General $1,000,000 for each of the fiscal years 2001 through 2005 for programs for the National Association of TRIAD.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General of the United States shall submit to Congress a report on the effectiveness of the TRIAD program 180 days prior to the expiration of the authorization under this Act [see Short Title of 2000 Amendment note above], including an analysis of TRIAD programs and activities; identification of impediments to the establishment of TRIADs across the Nation; and recommendations to improve the effectiveness of the TRIAD program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a533af4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Dissemination of Information","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/534/s4"},"text":"Pub. L. 106–534, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2556"},"text":"114 Stat. 2556","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/534/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Assistant Secretary of Health and Human Services for Aging, shall provide to the Attorney General of each State and publicly disseminate in each State, including dissemination to area agencies on aging, information designed to educate senior citizens and raise awareness about the dangers of fraud, including telemarketing and sweepstakes fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform senior citizens of the prevalence of telemarketing and sweepstakes fraud targeted against them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform senior citizens how telemarketing and sweepstakes fraud work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform senior citizens how to identify telemarketing and sweepstakes fraud;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform senior citizens how to protect themselves against telemarketing and sweepstakes fraud, including an explanation of the dangers of providing bank account, credit card, or other financial or personal information over the telephone to unsolicited callers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform senior citizens how to report suspected attempts at or acts of fraud;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform senior citizens of their consumer protection rights under Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such other information as the Secretary considers necessary to protect senior citizens against fraudulent telemarketing and sweepstakes promotions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Means of Dissemination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine the means to disseminate information under this section. In making such determination, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public service announcements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a printed manual or pamphlet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Internet website;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct mailings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telephone outreach to individuals whose names appear on so-called ‘mooch lists’ confiscated from fraudulent marketers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In disseminating information under this section, the Secretary shall give priority to areas with high incidents of fraud against senior citizens.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
