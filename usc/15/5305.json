{"tag":"section","attrib":{"id":"id7a49c5dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5305"},"text":null,"children":[{"tag":"num","attrib":{"value":"5305"},"text":"§ 5305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a49c5dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of research activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall regularly monitor and evaluate the research activities of the applicants selected. After considering the reports of the Board provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5306/b/2"},"text":"section 5306(b)(2) of this title","children":[],"tail":", the Secretary shall determine whether each applicant selected has complied with the management plan submitted in the original proposal and any modifications made since."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0ece-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each selected applicant in the program shall provide an annual report to the Secretary that explains the progress made, compliance with the management plan, whether changes are needed and are being made to the management plan, and what new research is planned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0ecf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuation of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event a selected applicant has substantially failed in the implementation of the management plan and research activities, the Secretary shall discontinue funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0ed0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of new proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion or discontinuance of any research activity authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5304"},"text":"section 5304 of this title","children":[],"tail":", the Secretary shall, using available funds appropriated pursuant to this chapter, solicit new research proposals as set forth under the terms of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4c0ed1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/425/s6"},"text":"Pub. L. 101–425, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/918"},"text":"104 Stat. 918","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
