{"tag":"section","attrib":{"id":"id79672d7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1176"},"text":null,"children":[{"tag":"num","attrib":{"value":"1176"},"text":"§ 1176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever violates any of the provisions of sections 1172, 1173, 1174, or 1175 of this title shall be fined not more than $5,000 or imprisoned not more than two years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79672d7f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-01-02/ch1194/s6"},"text":"Jan. 2, 1951, ch. 1194, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1135"},"text":"64 Stat. 1135","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
