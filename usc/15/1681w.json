{"tag":"section","attrib":{"id":"id79b3786f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681w"},"text":"§ 1681w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b37870-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b37871-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission, the Securities and Exchange Commission, the Commodity Futures Trading Commission, the Federal banking agencies, and the National Credit Union Administration, with respect to the entities that are subject to their respective enforcement authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681s"},"text":"section 1681s of this title","children":[],"tail":", and in coordination as described in paragraph (2), shall issue final regulations requiring any person that maintains or otherwise possesses consumer information, or any compilation of consumer information, derived from consumer reports for a business purpose to properly dispose of any such information or compilation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b37872-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agency required to prescribe regulations under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b37873-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult and coordinate with each other such agency so that, to the extent possible, the regulations prescribed by each such agency are consistent and comparable with the regulations by each such other agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b37874-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such regulations are consistent with the requirements and regulations issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Public Law 106–102","children":[],"tail":" and other provisions of Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b37875-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In issuing regulations under this section, the agencies identified in paragraph (1) may exempt any person or class of persons from application of those regulations, as such agency deems appropriate to carry out the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b37876-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b37877-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a person to maintain or destroy any record pertaining to a consumer that is not imposed under other law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b37878-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681w/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alter or affect any requirement imposed under any other provision of law to maintain or destroy such a record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b37879-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s628"},"text":"Pub. L. 90–321, title VI, § 628","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/159/tII/s216/a"},"text":"Pub. L. 108–159, title II, § 216(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1985"},"text":"117 Stat. 1985","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1088/a/12"},"text":"Pub. L. 111–203, title X, § 1088(a)(12)","children":[],"tail":", (13), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2091"},"text":"124 Stat. 2091","children":[],"tail":", 2092.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b3787a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b3787b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b3787c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Public Law 106–102","children":[],"tail":", referred to in subsec. (a)(2)(B), is "},{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1338"},"text":"113 Stat. 1338","children":[],"tail":", known as the Gramm-Leach-Bliley Act. For complete classification of this Act to the Code, see Short Title of 1999 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1811"},"text":"section 1811 of Title 12","children":[],"tail":", Banks and Banking, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79b3787d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1088/a/12"},"text":"Pub. L. 111–203, § 1088(a)(12)","children":[],"tail":", substituted “The Federal Trade Commission, the Securities and Exchange Commission, the Commodity Futures Trading Commission, the Federal banking agencies, and the National Credit Union Administration, with respect to the entities that are subject to their respective enforcement authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681s"},"text":"section 1681s of this title","children":[],"tail":",” for “Not later than 1 year after "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"December 4, 2003","children":[],"tail":", the Federal banking agencies, the National Credit Union Administration, and the Commission with respect to the entities that are subject to their respective enforcement authority under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681s"},"text":"section 1681s of this title","children":[],"tail":", and the Securities and Exchange Commission,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1088/a/13"},"text":"Pub. L. 111–203, § 1088(a)(13)","children":[],"tail":", substituted “the agencies identified in paragraph (1)” for “the Federal banking agencies, the National Credit Union Administration, the Commission, and the Securities and Exchange Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b3787e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79b3787f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79b37880-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section subject to joint regulations establishing effective dates as prescribed by Federal Reserve Board and Federal Trade Commission, except as otherwise provided, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/s3"},"text":"section 3 of Pub. L. 108–159","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
