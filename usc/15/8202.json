{"tag":"section","attrib":{"id":"id7a82fcf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8202"},"text":null,"children":[{"tag":"num","attrib":{"value":"8202"},"text":"§ 8202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of nonadmitted insurance by insured’s home State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a82fcf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home State authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, the placement of nonadmitted insurance shall be subject to the statutory and regulatory requirements solely of the insured’s home State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a82fcf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broker licensing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State other than an insured’s home State may require a surplus lines broker to be licensed in order to sell, solicit, or negotiate nonadmitted insurance with respect to such insured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a82fcf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8201"},"text":"section 8201 of this title","children":[],"tail":" and subsections (a) and (b) of this section, any law, regulation, provision, or action of any State that applies or purports to apply to nonadmitted insurance sold to, solicited by, or negotiated with an insured whose home State is another State shall be preempted with respect to such application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a82fcf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workers’ compensation exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be construed to preempt any State law, rule, or regulation that restricts the placement of workers’ compensation insurance or excess insurance for self-funded workers’ compensation plans with a nonadmitted insurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a82fcf9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tV/s522"},"text":"Pub. L. 111–203, title V, § 522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1590"},"text":"124 Stat. 1590","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
