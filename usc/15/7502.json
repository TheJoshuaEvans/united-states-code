{"tag":"section","attrib":{"id":"id7a796115-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502"},"text":null,"children":[{"tag":"num","attrib":{"value":"7502"},"text":"§ 7502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a796116-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall establish a National Nanotechnology Coordination Office, with a Director and full-time staff, which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a796117-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical and administrative support to the Council and the Advisory Panel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796118-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the point of contact on Federal nanotechnology activities for government organizations, academia, industry, professional societies, State nanotechnology programs, interested citizen groups, and others to exchange technical and programmatic information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796119-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct public outreach, including dissemination of findings and recommendations of the Advisory Panel, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a79611a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote access to and early application of the technologies, innovations, and expertise derived from Program activities to agency missions and systems across the Federal Government, and to United States industry, including startup companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a79611b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Nanotechnology Coordination Office shall be funded through interagency funding in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s631"},"text":"section 631 of Public Law 108–7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a79611c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 90 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-03"},"text":"December 3, 2003","children":[],"tail":", the Director of the Office of Science and Technology Policy shall report to the Senate Committee on Commerce, Science, and Transportation, and the House of Representatives Committee on Science on the funding of the National Nanotechnology Coordination Office. The report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a79611d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding required to adequately fund the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a79611e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of existing mechanisms to fund this Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a79611f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by the Director to ensure stable funding of this Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a796120-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/153/s3"},"text":"Pub. L. 108–153, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1926"},"text":"117 Stat. 1926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a796121-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a796122-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a796123-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/s631"},"text":"Section 631 of Public Law 108–7","children":[],"tail":", referred to in subsec. (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/s631"},"text":"section 631 of Pub. L. 108–7","children":[],"tail":", div. J, title VI, "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/471"},"text":"117 Stat. 471","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a796124-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a796125-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science of House of Representatives changed to Committee on Science and Technology of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, "},{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
