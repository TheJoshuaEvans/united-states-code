{"tag":"section","attrib":{"id":"id799baaef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1645"},"text":null,"children":[{"tag":"num","attrib":{"value":"1645"},"text":"§ 1645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business credit cards; limits on liability of employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The exemption provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1603/1"},"text":"section 1603(1) of this title","children":[],"tail":" does not apply to the provisions of sections 1642, 1643, and 1644 of this title, except that a card issuer and a business or other organization which provides credit cards issued by the same card issuer to ten or more of its employees may by contract agree as to liability of the business or other organization with respect to unauthorized use of such credit cards without regard to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1643"},"text":"section 1643 of this title","children":[],"tail":", but in no case may such business or other organization or card issuer impose liability upon any employee with respect to unauthorized use of such a credit card except in accordance with and subject to the limitations of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1643"},"text":"section 1643 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799baaf0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s135"},"text":"Pub. L. 90–321, title I, § 135","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIV/s410/a"},"text":"Pub. L. 93–495, title IV, § 410(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1519"},"text":"88 Stat. 1519","children":[],"t