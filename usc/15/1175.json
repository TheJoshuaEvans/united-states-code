{"tag":"section","attrib":{"id":"id79672d5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175"},"text":null,"children":[{"tag":"num","attrib":{"value":"1175"},"text":"§ 1175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific jurisdictions within which manufacturing, repairing, selling, possessing, etc., prohibited; exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79672d5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful to manufacture, recondition, repair, sell, transport, possess, or use any gambling device in the District of Columbia, in any possession of the United States, within Indian country as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":" or within the special maritime and territorial jurisdiction of the United States as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of title 18","children":[],"tail":", including on a vessel documented under chapter 121 of title 46 or documented under the laws of a foreign country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79672d61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except for a voyage or a segment of a voyage that begins and ends in the State of Hawaii, or as provided in paragraph (2), this section does not prohibit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79672d62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repair, transport, possession, or use of a gambling device on a vessel that is not within the boundaries of any State or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79672d63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the transport or possession, on a voyage, of a gambling device on a vessel that is within the boundaries of any State or possession of the United States, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79672d64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of the gambling device on a portion of that voyage is, by reason of subparagraph (A), not a violation of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79672d65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gambling device remains on board that vessel while the vessel is within the boundaries of that State or possession; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79672d66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repair, transport, possession, or use of a gambling device on a vessel on a voyage that begins in the State of Indiana and that does not leave the territorial jurisdiction of that State, including such a voyage on Lake Michigan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79672d67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to certain voyages","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79672d68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(A) does not apply to the repair or use of a gambling device on a vessel that is on a voyage or segment of a voyage described in subparagraph (B) of this paragraph if the State or possession of the United States in which the voyage or segment begins and ends has enacted a statute the terms of which prohibit that repair or use on that voyage or segment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79672d69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voyage and segment described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A voyage or segment of a voyage referred to in subparagraph (A) is a voyage or segment, respectively—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79672d6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that begins and ends in the same State or possession of the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79672d6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during which the vessel does not make an intervening stop within the boundaries of another State or possession of the United States or a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79672d6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain voyages and segments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except for a voyage or segment of a voyage that occurs within the boundaries of the State of Hawaii, a voyage or segment of a voyage is not described in subparagraph (B) if it includes or consists of a segment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79672d6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that begins and ends in the same State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79672d6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is part of a voyage to another State or to a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79672d6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the vessel reaches the other State or foreign country within 3 days after leaving the State in which it begins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for Alaska","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79672d71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a vessel operating in Alaska, this section does not prohibit, nor may the State of Alaska make it a violation of law for there to occur, the repair, transport, possession, or use of any gambling device on board a vessel which provides sleeping accommodations for all of its passengers and that is on a voyage or segment of a voyage described in paragraph (2), except that such State may, within its boundaries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79672d72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the use of a gambling device on a vessel while it is docked or anchored or while it is operating within 3 nautical miles of a port at which it is scheduled to call; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79672d73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the gambling devices to remain on board the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79672d74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A voyage referred to in paragraph (1) is a voyage that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79672d75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a stop in Canada or in a State other than the State of Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79672d76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes stops in at least 2 different ports situated in the State of Alaska; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79672d77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1175/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of at least 60 hours duration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79672d78-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-01-02/ch1194/s5"},"text":"Jan. 2, 1951, ch. 1194, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1135"},"text":"64 Stat. 1135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/251/tII/s202/b"},"text":"Pub. L. 102–251, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-09"},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/61"},"text":"106 Stat. 61","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tXII/s1222"},"text":"Pub. L. 104–264, title XII, § 1222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3286"},"text":"110 Stat. 3286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1106"},"text":"Pub. L. 104–324, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3967"},"text":"110 Stat. 3967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s147"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 147]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–251.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79672d79-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79672d7a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79672d7b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted “for a voyage or a segment of a voyage that begins and ends in the State of Hawaii, or” after “Except” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1106/b"},"text":"Pub. L. 104–324, § 1106(b)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/s1222"},"text":"Pub. L. 104–264, § 1222","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1106/a"},"text":"Pub. L. 104–324, § 1106(a)","children":[],"tail":", made substantially identical amendments, adding subpar. (C). The text of subpar. (C) is based on amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1106/c"},"text":"Pub. L. 104–324, § 1106(c)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251/s202/b/1"},"text":"Pub. L. 102–251, § 202(b)(1)","children":[],"tail":", (2), designated existing provisions as subsec. (a), inserted heading, and inserted before period at end “, including on a vessel documented under chapter 121 of title 46 or documented under the laws of a foreign country”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/251/s202/b/3"},"text":"Pub. L. 102–251, § 202(b)(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79672d7c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79672d7d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264"},"text":"Pub. L. 104–264","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and not to be construed as affecting funds made available for a fiscal year ending before "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/s3"},"text":"section 3 of Pub. L. 104–264","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
