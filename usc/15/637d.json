{"tag":"section","attrib":{"id":"id78f00177-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637d"},"text":null,"children":[{"tag":"num","attrib":{"value":"637d"},"text":"§ 637d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcontracting plan reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f00178-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", the Administrator of the Small Business Administration shall take such actions as are necessary to ensure that the electronic subcontracting reporting system established by the Administration to carry out the requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d/6/E"},"text":"section 637(d)(6)(E) of this title","children":[],"tail":" is modified to ensure that it can identify entities that fail to submit required reports."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f00179-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 31 of each year, the Administrator of the Small Business Administration shall provide the Committee on Small Business of the House of Representatives and the Committee on Small Business and Entrepreneurship of the Senate a report, based on data available through existing systems, that sets forth, by agency (and to the extent practicable, by type of goal or plan), the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78f0017a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of entities required to submit reports pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d/6"},"text":"section 637(d)(6) of this title","children":[],"tail":" that filed such reports and that failed to file such reports during the prior fiscal year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78f0017b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of entities filing such reports that met, exceeded, or failed to meet goals set forth in their subcontracting plans during the prior fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78f0017c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate value by which such entities exceeded, or failed to meet, their subcontracting goals during the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78f0017d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1653/b"},"text":"Pub. L. 112–239, div. A, title XVI, § 1653(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2082"},"text":"126 Stat. 2082","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78f0017e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78f0017f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78f00180-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2013, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
