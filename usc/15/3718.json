{"tag":"section","attrib":{"id":"id7a285a8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718"},"text":null,"children":[{"tag":"num","attrib":{"value":"3718"},"text":"§ 3718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" President’s Council on Innovation and Competitiveness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a285a8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a President’s Council on Innovation and Competitiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a285a8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Council shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a285a8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring implementation of public laws and initiatives for promoting innovation, including policies related to research funding, taxation, immigration, trade, and education that are proposed in this Act or in any other Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285a8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing advice to the President with respect to global trends in competitiveness and innovation and allocation of Federal resources in education, job training, and technology research and development considering such global trends in competitiveness and innovation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285a90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Director of the Office of Management and Budget, developing a process for using metrics to assess the impact of existing and proposed policies and rules that affect innovation capabilities in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285a91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying opportunities and making recommendations for the heads of executive agencies to improve innovation, monitoring, and reporting on the implementation of such recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285a92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing metrics for measuring the progress of the Federal Government with respect to improving conditions for innovation, including through talent development, investment, and infrastructure improvements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285a93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting to the President and Congress an annual report on such progress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a285a94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a285a95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the Secretary or head of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a285a96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285a9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285aa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285aa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285aa2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285aa3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285aa4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285aa5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a285aa6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/1/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other department or agency designated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285aa7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall serve as Chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285aa8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Council shall ensure appropriate coordination between the Council and the National Economic Council, the National Security Council, and the National Science and Technology Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa399-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet on a semi-annual basis at the call of the Chairperson and the initial meeting of the Council shall occur not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-09"},"text":"August 9, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa39a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of innovation agenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa39b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall develop a comprehensive agenda for strengthening the innovation and competitiveness capabilities of the Federal Government, State governments, academia, and the private sector in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa39c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive agenda required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa39d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of current strengths and weaknesses of the United States investment in research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa39e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for addressing weaknesses and maintaining the United States as a world leader in research and development and technological innovation, including strategies for increasing the participation of individuals identified in section 1885a or 1885b of title 42 in science, technology, engineering, and mathematics fields.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa39f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for strengthening the innovation and competitiveness capabilities of the Federal Government, State governments, academia, and the private sector in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa3a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa3a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2007-08-09"},"text":"August 9, 2007","children":[],"tail":", the National Academy of Sciences, in consultation with the National Academy of Engineering, the Institute of Medicine, and the National Research Council, shall develop and submit to the President a list of 50 individuals that are recommended to serve as advisors to the Council during the development of the comprehensive agenda required by paragraph (1). The list of advisors shall include appropriate representatives from the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a2aa3a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The private sector of the economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa3a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa3a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Various fields including information technology, energy, engineering, high-technology manufacturing, health care, and education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa3a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Scientific organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa3a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Academic organizations and other nongovernmental organizations working in the area of science or technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa3a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nongovernmental organizations, such as professional organizations, that represent individuals identified in section 1885a or 1885b of title 42 in the areas of science, engineering, technology, and mathematics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa3a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date that the National Academy of Sciences submits the list of recommended individuals to serve as advisors, the President shall designate 50 individuals to serve as advisors to the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa3a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to consult","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall develop the comprehensive agenda required by paragraph (1) in consultation with the advisors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa3aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial submission and updates","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa3ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-08-09"},"text":"August 9, 2007","children":[],"tail":", the Council shall submit to Congress and the President the comprehensive agenda required by paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa3ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least once every 2 years, the Council shall update the comprehensive agenda required by paragraph (1) and submit each such update to Congress and the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa3ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3718/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a) and paragraphs (1) and (2) of subsection (c), the President may designate an existing council to carry out the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2aa3ae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tI/s1006"},"text":"Pub. L. 110–69, title I, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/578"},"text":"121 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2aa3af-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2aa3b0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a2aa3b1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Act, also known as the America COMPETES Act, and not as part of the Stevenson-Wydler Technology Innovation Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a2aa3b2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a2aa3b3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Designation of the Committee on Technology of the National Science and Technology Council To Carry Out Certain Requirements of the America COMPETES Act","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of the President of the United States, ","children":[{"tag":"date","attrib":{"date":"2008-04-10"},"text":"Apr. 10, 2008","children":[],"tail":", 73 F.R. 20523, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Director of the Office of Science and Technology Policy","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President of the United States by the Constitution and the laws of the United States of America, including section 1006(e) of the America COMPETES Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Public Law 110–69","children":[],"tail":") (the “Act”), I hereby designate the Committee on Technology of the National Science and Technology Council to carry out the responsibilities assigned to the Council on Innovation and Competitiveness in section 1006 of the Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy is authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George W. Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
