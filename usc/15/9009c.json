{"tag":"section","attrib":{"id":"id7a9859ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c"},"text":null,"children":[{"tag":"num","attrib":{"value":"9009c"},"text":"§ 9009c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for restaurants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9859ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9859ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliated business” means a business in which an eligible entity has an equity or right to profit distributions of not less than 50 percent, or in which an eligible entity has the contractual authority to control the direction of the business, provided that such affiliation shall be determined as of any arrangements or agreements in existence as of ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered period” means the period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9859f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on ","children":[{"tag":"date","attrib":{"date":"2020-02-15"},"text":"February 15, 2020","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9859f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", or a date to be determined by the Administrator that is not later than 2 years after "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9859f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a restaurant, food stand, food truck, food cart, caterer, saloon, inn, tavern, bar, lounge, brewpub, tasting room, taproom, licensed facility or premise of a beverage alcohol producer where the public may taste, sample, or purchase products, or other similar place of business in which the public or patrons assemble for the primary purpose of being served food or drink;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9859f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an entity described in subparagraph (A) that is located in an airport terminal or that is a Tribally-owned concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9859f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a9859f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity described in subparagraph (A) that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a9859f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a State or local government-operated business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a9859fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":", owns or operates (together with any affiliated business) more than 20 locations, regardless of whether those locations do business under the same or multiple names; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a9859fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a pending application for or has received a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009a"},"text":"section 9009a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9859fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a publicly-traded company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange; issuer; security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “exchange”, “issuer”, and “security” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Restaurant Revitalization Fund established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9859ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pandemic-related revenue loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pandemic-related revenue loss” means, with respect to an eligible entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985a00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraphs (B), (C), and (D), the gross receipts, as established using such verification documentation as the Administrator may require, of the eligible entity during 2020 subtracted from the gross receipts of the eligible entity in 2019, if such sum is greater than zero;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the eligible entity was not in operation for the entirety of 2019—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a985a03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product obtained by multiplying the average monthly gross receipts of the eligible entity in 2019 by 12; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a985a04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product obtained by multiplying the average monthly gross receipts of the eligible entity in 2020 by 12; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount based on a formula determined by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the eligible entity opened during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":", and ending on the day before "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenses described in subsection (c)(5)(A) that were incurred by the eligible entity minus any gross receipts received; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount based on a formula determined by the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the eligible entity has not yet opened as of the date of application for a grant under subsection (c), but has incurred expenses described in subsection (c)(5)(A) as of ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of those expenses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/7/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount based on a formula determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this paragraph, the pandemic-related revenue losses for an eligible entity shall be reduced by any amounts received from a covered loan made under paragraph (36) or (37) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"section 636(a) of this title","children":[],"tail":" in 2020 or 2021."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payroll costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payroll costs” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a/36/A"},"text":"section 636(a)(36)(A) of this title","children":[],"tail":", except that such term shall not include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985a0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified wages (as defined in subsection (c)(3) of section 2301 of the CARES Act) taken into account in determining the credit allowed under such section 2301; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premiums taken into account in determining the credit allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6432"},"text":"section 6432 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly-traded company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “publicly-traded company” means an entity that is majority owned or controlled by an entity that is an issuer, the securities of which are listed on a national securities exchange under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78f"},"text":"section 78f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribally-owned concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribally-owned concern” has the meaning given the term in section 124.3 of title 13, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a985a11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restaurant Revitalization Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a985a12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the Restaurant Revitalization Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985a14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Restaurant Revitalization Fund for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $28,600,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available under subparagraph (A)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a985a17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000,000 shall be available to eligible entities with gross receipts during 2019 of not more than $500,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a985a18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $23,600,000,000 shall be available to the Administrator to award grants under subsection (c) in an equitable manner to eligible entities of different sizes based on annual gross receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make adjustments as necessary to the distribution of funds under clause (i)(II) based on demand and the relative local costs in the markets in which eligible entities operate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants after initial period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (B), on and after the date that is 60 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", or another period of time determined by the Administrator, the Administrator may make grants using amounts appropriated under subparagraph (A) to any eligible entity regardless of the annual gross receipts of the eligible entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall use amounts in the Fund to make grants described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a985a1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restaurant revitalization grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a985a1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b) and paragraph (3), the Administrator shall award grants to eligible entities in the order in which applications are received by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985a1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity applying for a grant under this subsection shall make a good faith certification that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the uncertainty of current economic conditions makes necessary the grant request to support the ongoing operations of the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity has not applied for or received a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009a"},"text":"section 9009a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business identifiers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accepting applications for grants under this subsection, the Administrator shall prioritize the ability of each applicant to use their existing business identifiers over requiring other forms of registration or identification that may not be common to their industry and imposing additional burdens on applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in awarding grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985a24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the initial 21-day period in which the Administrator awards grants under this subsection, the Administrator shall prioritize awarding grants to eligible entities that are small business concerns owned and controlled by women (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/n"},"text":"section 632(n) of this title","children":[],"tail":"), small business concerns owned and controlled by veterans (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/q"},"text":"section 632(q) of this title","children":[],"tail":"), or socially and economically disadvantaged small business concerns (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a/4/A"},"text":"section 637(a)(4)(A) of this title","children":[],"tail":"). The Administrator may take such steps as necessary to ensure that eligible entities described in this subparagraph have access to grant funding under this section after the end of such 21-day period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of establishing priority under subparagraph (A), an applicant shall submit a self-certification of eligibility for priority with the grant application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985a27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate maximum amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The aggregate amount of grants made to an eligible entity and any affiliated businesses of the eligible entity under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed $10,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be limited to $5,000,000 per physical location of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of grant amount","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this paragraph, the amount of a grant made to an eligible entity under this subsection shall be equal to the pandemic-related revenue loss of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return to Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount of a grant made under this subsection to an eligible entity based on estimated receipts that is greater than the actual gross receipts of the eligible entity in 2020 shall be returned to the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the covered period, an eligible entity that receives a grant under this subsection may use the grant funds for the following expenses incurred as a direct result of, or during, the COVID–19 pandemic:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985a2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payroll costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments of principal or interest on any mortgage obligation (which shall not include any prepayment of principal on a mortgage obligation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rent payments, including rent under a lease agreement (which shall not include any prepayment of rent).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Maintenance expenses, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a985a33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction to accommodate outdoor seating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a985a34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" walls, floors, deck surfaces, furniture, fixtures, and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplies, including protective equipment and cleaning materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Food and beverage expenses that are within the scope of the normal business practice of the eligible entity before the covered period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Covered supplier costs, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636m/a"},"text":"section 636m(a) of this title","children":[],"tail":" (as redesignated, transferred, and amended by section 304(b) of the Economic Aid to Hard-Hit Small Businesses, Nonprofits, and Venues Act ("},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paid sick leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985a3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/5/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other expenses that the Administrator determines to be essential to maintaining the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985a3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009c/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returning funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an eligible entity that receives a grant under this subsection fails to use all grant funds or permanently ceases operations on or before the last day of the covered period, the eligible entity shall return to the Treasury any funds that the eligible entity did not use for the allowable expenses under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a985a3c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tV/s5003"},"text":"Pub. L. 117–2, title V, § 5003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/85"},"text":"135 Stat. 85","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a985a3d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a985a3e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a985a3f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2301 of the CARES Act, referred to in subsec. (a)(8)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s2301"},"text":"section 2301 of Pub. L. 116–136","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3111"},"text":"section 3111 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636m/a"},"text":"Section 636m(a) of this title","children":[],"tail":" (as redesignated, transferred, and amended by section 304(b) of the Economic Aid to Hard-Hit Small Businesses, Nonprofits, and Venues Act ("},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":")), referred to in subsec. (c)(5)(H), probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636m/a"},"text":"section 636m(a) of this title","children":[],"tail":", as redesignated, transferred, and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIII/s304/b"},"text":"section 304(b) of title III of div. N of Pub. L. 116–260","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a985a40-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Rescue Plan Act of 2021, and not as part of the CARES Act which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a985a41-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a985a42-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tax Treatment of Restaurant Revitalization Grants","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9673"},"text":"Pub. L. 117–2, title IX, § 9673","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/184"},"text":"135 Stat. 184","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/2/tIX/s9673"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For purposes of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts received from the Administrator of the Small Business Administration in the form of a restaurant revitalization grant under section 5003 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9009c"},"text":"15 U.S.C. 9009c","children":[],"tail":"] shall not be included in the gross income of the person that receives such amounts,"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no deduction shall be denied, no tax attribute shall be reduced, and no basis increase shall be denied, by reason of the exclusion from gross income provided by paragraph (1), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a partnership or S corporation that receives such amounts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided by the Secretary of the Treasury (or the Secretary’s delegate), any amount excluded from income by reason of paragraph (1) shall be treated as tax exempt income for purposes of sections 705 and 1366 of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s705"},"text":"26 U.S.C. 705","children":[],"tail":", 1366], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury (or the Secretary’s delegate) shall prescribe rules for determining a partner’s distributive share of any amount described in subparagraph (A) for purposes of section 705 of the Internal Revenue Code of 1986.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
