{"tag":"section","attrib":{"id":"id7a9f85f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9049"},"text":null,"children":[{"tag":"num","attrib":{"value":"9049"},"text":"§ 9049.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary hiring flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9f85f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9049/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered period” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and ending on the sooner of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f85fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9049/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination date of the national emergency concerning the novel coronavirus disease (COVID–19) outbreak declared by the President on ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":" under the National Emergencies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f85fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9049/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f85fc-552d-11f1-9071