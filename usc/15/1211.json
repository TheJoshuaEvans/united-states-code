{"tag":"section","attrib":{"id":"id796be868-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1211"},"text":null,"children":[{"tag":"num","attrib":{"value":"1211"},"text":"§ 1211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against transportation of refrigerators without safety devices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person to introduce or deliver for introduction into interstate commerce any household refrigerator manufactured on or after the date this section takes effect unless it is equipped with a device, enabling the door thereof to be opened from the inside, which conforms with standards prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1213"},"text":"section 1213 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796be869-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-02/ch890/s1"},"text":"Aug. 2, 1956, ch. 890, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/953"},"text":"70 Stat. 953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be86a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796be86b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id796be86c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For date this section takes effect, referred to in text, see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796be86d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id796be86e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-02/ch890/s5"},"text":"Act Aug. 2, 1956, ch. 890, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/953"},"text":"70 Stat. 953","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-08-02/ch890/s5"},"text":"“This Act [this chapter] shall take effect on the date of its enactment [","children":[{"tag":"date","attrib":{"date":"1956-08-02"},"text":"Aug. 2, 1956","children":[],"tail":"], except that the first section of this Act [this section] shall take effect one year and 90 days after the date of publication of commercial standards first established under section 3 of this Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1213"},"text":"section 1213 of this title","children":[],"tail":"]. In the event of a change in said commercial standards first established, a like period shall be allowed for compliance with said change in commercial standards.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id796be86f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Secretary of Commerce and Federal Trade Commission under this chapter transferred to Consumer Product Safety Commission, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079"},"text":"section 2079 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
