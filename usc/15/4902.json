{"tag":"section","attrib":{"id":"id7a475471-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902"},"text":null,"children":[{"tag":"num","attrib":{"value":"4902"},"text":"§ 4902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Trade Data Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a475472-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Interagency Trade Data Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475473-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475474-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Trade Representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475475-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475476-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475477-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475478-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475479-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47547a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47547b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47547c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4902/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","childr