{"tag":"section","attrib":{"id":"id7a533ac9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004"},"text":null,"children":[{"tag":"num","attrib":{"value":"6004"},"text":"§ 6004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a533aca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Bicycle helmets manufactured 9 months or more after ","children":[{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", shall conform to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533acb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interim standard described under subsection (b), pending the establishment of a final standard pursuant to subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533acc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final standard, once it has been established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533acd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interim standards are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533ace-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The American National Standards Institute standard designated as “Z90.4–1984”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533acf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Snell Memorial Foundation standard designated as “B–90”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ad0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The American Society for Testing and Materials (ASTM) standard designated as “F 1447”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ad1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other standard that the Commission determines is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533ad2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", the Commission shall begin a proceeding under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533ad3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the requirements of the interim standards set forth in subsection (a) and establish a final standard based on such requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ad4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the final standard a provision to protect against the risk of helmets coming off the heads of bicycle riders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ad5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the final standard provisions that address the risk of injury to children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ad6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include additional provisions as appropriate.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Sections 7, 9, and 30(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002544"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002544"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Consumer Product Safety Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2056"},"text":"15 U.S.C. 2056","children":[],"tail":", 2058, 2079(d)) shall not apply to the proceeding under this subsection and section 11 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2060"},"text":"15 U.S.C. 2060","children":[],"tail":") shall not apply with respect to any standard issued under such proceeding. The final standard shall take effect 1 year from the date it is issued."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533ad7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533ad8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet interim standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until the final standard takes effect, a bicycle helmet that does not conform to an interim standard as required under subsection (a)(1) shall be considered in violation of a consumer product safety standard promulgated under the Consumer Product Safety Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"15 U.S.C. 2051","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533ad9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of final standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The final standard developed under subsection (c) shall be considered a consumer product safety standard promulgated under the Consumer Product Safety Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a533ada-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/267/tII/s205"},"text":"Pub. L. 103–267, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/727"},"text":"108 Stat. 727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a533adb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a533adc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a533add-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 30(d) of the Consumer Product Safety Act, referred to in subsec. (c), was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079/d"},"text":"section 2079(d) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s237"},"text":"Pub. L. 110–314, title II, § 237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3076"},"text":"122 Stat. 3076","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Consumer Product Safety Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573"},"text":"Pub. L. 92–573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1207"},"text":"86 Stat. 1207","children":[],"tail":", which is classified generally to chapter 47 (§ 2051 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
