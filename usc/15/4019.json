{"tag":"section","attrib":{"id":"id7a3440b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019"},"text":null,"children":[{"tag":"num","attrib":{"value":"4019"},"text":"§ 4019.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3440b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information submitted by any person in connection with the issuance, amendment, or revocation of a certificate of review shall be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3440b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of potentially harmful confidential information; exceptions: Congress; judicial or administrative proceedings; consent; necessity for determination; Federal law; regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3440ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), no officer or employee of the United States shall disclose commercial or financial information submitted in connection with the issuance, amendment, or revocation of a certificate of review if the information is privileged or confidential and if disclosure of the information would cause harm to the person who submitted the information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3440bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) shall not apply with respect to information disclosed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3440bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon a request made by the Congress or any committee of the Congress,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a judicial or administrative proceeding, subject to appropriate protective orders,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of the person who submitted the information,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of making a determination with respect to the issuance, amendment, or revocation of a certificate of review, if the Secretary deems disclosure of the information to be necessary in connection with making the determination,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with any requirement imposed by a statute of the United States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3440c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4019/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with any rule or regulation promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4020"},"text":"section 4020 of this title","children":[],"tail":" permitting the disclosure of the information to an agency of the United States or of a State on the condition that the agency will disclose the information only under the circumstances specified in subparagraphs (A) through (E)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3440c2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/290/tIII/s309"},"text":"Pub. L. 97–290, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1244"},"text":"96 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3440c3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a3440c4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a3440c5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/290/s312"},"text":"section 312 of Pub. L. 97–290","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4011"},"text":"section 4011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
