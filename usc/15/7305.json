{"tag":"section","attrib":{"id":"id7a723538-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305"},"text":null,"children":[{"tag":"num","attrib":{"value":"7305"},"text":"§ 7305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to support Teams in carrying out this chapter, the Director may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723539-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure the temporary or intermittent services of experts or consultants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72353a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the use, when appropriate, of available services, equipment, personnel, and facilities of a department, agency, or instrumentality of the United States Government on a reimbursable or other basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72353b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confer with employees and request the use of services, records, and facilities of State and local governmental authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72353c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept voluntary and uncompensated services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72353d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and use gifts of money and other property, to the extent provided in advance in appropriations Acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72353e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make contracts with nonprofit entities to carry out studies related to purpose, functions, and authorities of the Teams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a72353f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7305/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide nongovernmental members of the Team reasonable compensation for time spent carrying out activities under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a723540-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231/s6"},"text":"Pub. L. 107–231, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1474"},"text":"116 Stat. 1474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a723541-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a723542-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a723543-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231"},"text":"Pub. L. 107–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1471"},"text":"116 Stat. 1471","children":[],"tail":", known as the National Construction Safety Team Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7301"},"text":"section 7301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
