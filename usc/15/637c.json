{"tag":"section","attrib":{"id":"id78f0016d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637c"},"text":null,"children":[{"tag":"num","attrib":{"value":"637c"},"text":"§ 637c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f0016e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f0016f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal agency” has the meaning given the term “agency” by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of title 5","children":[],"tail":", but does not include the United States Postal Service or the Government Accountability Office; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f00170-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Government procurement contract” means any contract for the procurement of any goods or services by any Federal agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78f00171-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/507/tII/s224/a"},"text":"Pub. L. 95–507, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","a