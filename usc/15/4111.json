{"tag":"section","attrib":{"id":"id7a36b2be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4111"},"text":null,"children":[{"tag":"num","attrib":{"value":"4111"},"text":"§ 4111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Arctic” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “Arctic” means all United States and foreign territory north of the Arctic Circle and all United States territory north and west of the boundary formed by the Porcupine, Yukon, and Kuskokwim Rivers; all contiguous seas, including the Arctic Ocean and the Beaufort, Bering, and Chukchi Seas; and the Aleutian chain.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a36b2bf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373/tI/s112"},"text":"Pub. L. 98–373, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-31"},"text":"July 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1248"},"text":"98 Stat. 1248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
