{"tag":"section","attrib":{"id":"id793065ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d"},"text":null,"children":[{"tag":"num","attrib":{"value":"697d"},"text":"§ 697d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accredited Lenders Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id793065af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration is authorized to establish an Accredited Lenders Program for qualified State and local development companies that meet the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793065b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administration may designate a qualified State or local development company as an accredited lender if such company—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793065b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been an active participant in the Development Company Program authorized by sections 696, 697, and 697a of this title for not less than the preceding 12 months;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793065b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has well-trained, qualified personnel who are knowledgeable in the Administration’s lending policies and procedures for such Development Company Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793065b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the ability to process, close, and service financing for plant and equipment under such Development Company Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793065b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a loss rate on the company’s debentures that is reasonable and acceptable to the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793065b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a history of submitting to the Administration complete and accurate debenture guaranty application packages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793065b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated the ability to serve small business credit needs for financing plant and equipment through the Development Company Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793065b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited processing of loan applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration shall develop an expedited procedure for processing a loan application or servicing action submitted by a qualified State or local development company that has been designated as an accredited lender in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793065b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or revocation of designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793065b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The designation of a qualified State or local development company as an accredited lender may be suspended or revoked if the Administration determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id793065ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development company has not continued to meet the criteria for eligibility under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793065bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development company has failed to adhere to the Administration’s rules and regulations or is violating any other applicable provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793065bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A suspension or revocation under paragraph (1) shall not affect any outstanding debenture guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793065bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “qualified State or local development company” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697/e"},"text":"section 697(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id793065be-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tV/s507"},"text":"Pub. L. 85–699, title V, § 507","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tII/s212/a"},"text":"Pub. L. 103–403, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4183"},"text":"108 Stat. 4183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIII/s328/b"},"text":"Pub. L. 116–260, div. N, title III, § 328(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2040"},"text":"134 Stat. 2040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793065bf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id793065c0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793065c1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s328/b/2"},"text":"Pub. L. 116–260, § 328(b)(2)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which related to express loan authority of a local development company designated as an accredited lender, and subsec. (f) which defined terms “accredited lender certified company”, “covered loan”, and “qualified State or local development company” in this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s328/b/1"},"text":"Pub. L. 116–260, § 328(b)(1)","children":[],"tail":", added subsecs. (e) and (f) and struck out former subsec. (e) which defined “qualified State or local development company” for purposes of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793065c2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id793065c3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIII/s328/b/2"},"text":"Pub. L. 116–260, div. N, title III, § 328(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2040"},"text":"134 Stat. 2040","children":[],"tail":", provided in part that the amendment made by section 328(b)(2) is effective on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", and applicable to loans and grants made on or after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s348"},"text":"section 348 of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793065c4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/403/tII/s212/b"},"text":"Pub. L. 103–403, title II, § 212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4184"},"text":"108 Stat. 4184","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/403/tII/s212/b"},"text":"“Not later than 120 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":"], the Administration shall promulgate final regulations to carry out this section [enacting this section and provisions set out below].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793065c5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Implementation of Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/403/tII/s212/c"},"text":"Pub. L. 103–403, title II, § 212(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4184"},"text":"108 Stat. 4184","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/403/tII/s212/c"},"text":"“Not later than 1 year after the effective date of regulations promulgated under subsection (b) [set out above], and biennially thereafter, the Administration shall report to the Committees on Small Business of the Senate and the House of Representatives [Committee on Small Business of Senate now Committee on Small Business and Entrepreneurship of Senate] on the implementation of this section [enacting this section and provisions set out above]. Such report shall include data on the number of development companies designated as accredited lenders, their debenture guarantee volume, their loss rates, the average processing time on their guarantee applications, and such other information as the Administration deems appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
