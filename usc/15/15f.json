{"tag":"section","attrib":{"id":"id77b5374d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15f"},"text":null,"children":[{"tag":"num","attrib":{"value":"15f"},"text":"§ 15f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77b5374e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to State attorney general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Attorney General of the United States has brought an action under the antitrust laws, and he has reason to believe that any State attorney general would be entitled to bring an action under this Act based substantially on the same alleged violation of the antitrust laws, he shall promptly give written notification thereof to such State attorney general.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77b5374f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of files and other materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist a State attorney general in evaluating the notice or in bringing any action under this Act, the Attorney General of the United States shall, upon request by such State attorney general, make available to him, to the extent permitted by law, any investigative files or other materials which are or may be relevant or material to the actual or potential cause of action under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77b53750-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323/s4F"},"text":"Oct. 15, 1914, ch. 323, § 4F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/435/tIII/s301"},"text":"Pub. L. 94–435, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1395"},"text":"90 Stat. 1395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77b53751-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77b53752-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77b53753-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The antitrust laws, referred to in subsec. (a), are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323"},"text":"act Oct. 15, 1914, ch. 323","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/730"},"text":"38 Stat. 730","children":[],"tail":", known as the Clayton Act, which is classified generally to sections 12, 13, 14 to 19, 21, and 22 to 27 of this title, and sections 52 and 53 of Title 29, Labor. For further details and complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77b53754-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id77b53755-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Injuries sustained prior to ","children":[{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", not covered by this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/435/s304"},"text":"section 304 of Pub. L. 94–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s15c"},"text":"section 15c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
