{"tag":"section","attrib":{"id":"id78849583-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s175"},"text":null,"children":[{"tag":"num","attrib":{"value":"175"},"text":"§ 175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties of Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the province and duty of the Bureau of Foreign and Domestic Commerce, under the direction of the Secretary of Commerce, to foster, promote, and develop the various manufacturing industries of the United States, and markets for the same at home and abroad, domestic and foreign, by gathering, compiling, publishing, and supplying all available and useful information concerning such industries and such markets, and by such other methods and means as may be prescribed by the Secretary of Commerce or provided by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78849584-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s5"},"text":"Feb. 14, 1903, ch. 552, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/827"},"text":"32 Stat. 827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1906-04-05/ch1366/s3"},"text":"Apr. 5, 1906, ch. 1366, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/100"},"text":"34 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/407"},"text":"37 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-13/ch957"},"text":"Aug. 13, 1946, ch. 957","children":[],"tail":", title XI, § 1131(23), "},{"tag":"ref","attrib":{"href":"/us/stat/60/1037"},"text":"60 Stat. 1037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78849585-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78849586-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78849587-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1946—Act ","children":[{"tag":"date","attrib":{"date":"1946-08-13"},"text":"Aug. 13, 1946","children":[],"tail":", repealed last sentence relating to duties of consular officers with respect to the Bureau."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78849588-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78849589-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", substituted the “Secretary of Commerce” for “Secretary of Commerce and Labor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7884958a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1946 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1946-08-13"},"text":"Aug. 13, 1946","children":[],"tail":", effective three months from "},{"tag":"date","attrib":{"date":"1946-08-13"},"text":"Aug. 13, 1946","children":[],"tail":", see section 1141 of that act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7884958b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1912-08-23"},"text":"Aug. 23, 1912","children":[],"tail":", transferred certain duties of Department or Bureau of Labor to Bureau of Foreign and Domestic Commerce."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1906-04-05"},"text":"Apr. 5, 1906","children":[],"tail":", abolished the grade of commercial agent and commercial agent’s function of helping to gather foreign trade information, reference to which formerly appeared in the last sentence of this section. Such last sentence was subsequently repealed by Act "},{"tag":"date","attrib":{"date":"1946-08-13"},"text":"Aug. 13, 1946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7884958c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7884958d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Bureau of Foreign and Domestic Commerce, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s172"},"text":"section 172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
