{"tag":"section","attrib":{"id":"id7a55ac7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306"},"text":null,"children":[{"tag":"num","attrib":{"value":"6306"},"text":"§ 6306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a55ac7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each boxing commission shall establish each of the following procedures:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures to evaluate the professional records and physician’s certification of each boxer participating in a professional boxing match in the State, and to deny authorization for a boxer to fight where appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Procedures to ensure that, except as provided in subsection (b), no boxer is permitted to box while under suspension from any boxing commission due to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a55ac7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recent knockout or series of consecutive losses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an injury, requirement for a medical procedure, or physician denial of certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure of a drug test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of false aliases, or falsifying, or attempting to falsify, official identification cards or documents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsportsmanlike conduct or other inappropriate behavior inconsistent with generally accepted methods of competition in a professional boxing match.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures to review a suspension where appealed by a boxer, licensee, manager, matchmaker, promoter, or other boxing service provider, including an opportunity for a boxer to present contradictory evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Procedures to revoke a suspension where a boxer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a55ac86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was suspended under subparagraph (A) or (B) of paragraph (2) of this subsection, and has furnished further proof of a sufficiently improved medical or physical condition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes proof under subparagraph (C) or (D) of paragraph (2) that a suspension was not, or is no longer, merited by the facts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a55ac88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension in another State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A boxing commission may allow a boxer who is under suspension in any State to participate in a professional boxing match—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any reason other than those listed in subsection (a) if such commission notifies in writing and consults with the designated official of the suspending State’s boxing commission prior to the grant of approval for such individual to participate in that professional boxing match; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the boxer appeals to the Association of Boxing Commissions, and the Association of Boxing Commissions determines that the suspension of such boxer was without sufficient grounds, for an improper purpose, or not related to the health and safety of the boxer or the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a55ac8b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s7"},"text":"Pub. L. 104–272, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3311"},"text":"110 Stat. 3311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/b"},"text":"Pub. L. 106–210, § 7(b)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/328"},"text":"114 Stat. 328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a55ac8c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a55ac8d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a55ac8e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/b"},"text":"Pub. L. 106–210, § 7(b)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/d"},"text":"Pub. L. 106–210, § 7(d)","children":[],"tail":", substituted “boxer, licensee, manager, matchmaker, promoter, or other boxing service provider” for “boxer” the first place appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55ac8f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a55ac90-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23/2"},"text":"section 23(2) of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
