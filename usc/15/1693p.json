{"tag":"section","attrib":{"id":"id79bf5f75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1693p"},"text":"§ 1693p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79bf5f76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than twelve months after the effective date of this subchapter and at one-year intervals thereafter, the Bureau shall make reports to the Congress concerning the administration of its functions under this subchapter, including such recommendations as the Bureau deems necessary and appropriate. In addition, each report of the Bureau shall include its assessment of the extent to which compliance with this subchapter is being achieved, and a summary of the enforcement actions taken under section 1693","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002414"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002414"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title. In such report, the Bureau shall particularly address the effects of this subchapter on the costs and benefits to financial institutions and consumers, on competition, on the introduction of new technology, on the operations of financial institutions, and on the adequacy of consumer protection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bf5f77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the exercise of its functions under this subchapter, the Bureau may obtain upon request the views of any other Federal agency which, in the judgment of the Bureau, exercises regulatory or supervisory functions with respect to any class of persons subject to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79bf5f78-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIX/s921"},"text":"Pub. L. 90–321, title IX, § 921","children":[],"tail":", formerly § 918, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXX/s2001"},"text":"Pub. L. 95–630, title XX, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3740"},"text":"92 Stat. 3740","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s209/a"},"text":"Pub. L. 97–375, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1825"},"text":"96 Stat. 1825","children":[],"tail":"; renumbered § 919, "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tIV/s401/1"},"text":"Pub. L. 111–24, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1751"},"text":"123 Stat. 1751","children":[],"tail":"; renumbered § 920, renumbered § 921, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX"},"text":"Pub. L. 111–203, title X","children":[],"tail":", §§ 1073(a)(3), 1075(a)(1), 1084(1), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2060"},"text":"124 Stat. 2060","children":[],"tail":", 2068, 2081.)"}],"tail":"\n"},{"tag":"note