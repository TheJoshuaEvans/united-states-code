{"tag":"section","attrib":{"id":"id79dc0ec9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2086"},"text":null,"children":[{"tag":"num","attrib":{"value":"2086"},"text":"§ 2086.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on industry-sponsored travel","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1353"},"text":"section 1353 of title 31","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2076/b/6"},"text":"section 2076(b)(6) of this title","children":[],"tail":", no Commissioner or employee of the Commission shall accept travel, subsistence, or related expenses with respect to attendance by a Commissioner or employee at any meeting or similar function relating to official duties of a Commissioner or an employee, from a person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79dc0eca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2086/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeking official action from, doing business with, or conducting activities regulated by, the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79dc0ecb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2086/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose interests may be substantially affected by the performance or nonperformance of the Commissioner’s or employee’s official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dc0ecc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s39"},"text":"Pub. L. 92–573, § 39","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s206/a"},"text":"Pub. L. 110–314, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3044"},"text":"122 Stat. 3044","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
