{"tag":"section","attrib":{"id":"id7977cef7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1339"},"text":null,"children":[{"tag":"num","attrib":{"value":"1339"},"text":"§ 1339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States are invested with jurisdiction, for cause shown, to prevent and restrain violations of this chapter upon the application of the Attorney General of the United States acting through the several United States attorneys in their several districts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7977cef8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92/s11"},"text":"Pub. L. 89–92, § 11","children":[],"tail":", formerly § 10, "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/284"},"text":"79 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/222/s2"},"text":"Pub. L. 91–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-01"},"text":"Apr. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/89"},"text":"84 Stat. 89","children":[],"tail":"; renumbered § 11, "},{"tag":"ref","attrib":{"href":"/us/pl/98/474/s5/a"},"text":"Pub. L. 98–474, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2203"},"text":"98 Stat. 2203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7977cef9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7977cefa-552d-11f1-9071-ff305b7c3ff0