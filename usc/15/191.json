{"tag":"section","attrib":{"id":"id78849602-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s191"},"text":null,"children":[{"tag":"num","attrib":{"value":"191"},"text":"§ 191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of measure, weight, and money in commercial reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All terms of measure, weight, and money in the diplomatic, consular, and other commercial reports prepared, printed, published, and distributed by the Department of Commerce shall be reduced to and expressed in terms of measure, weight, and coin of the United States, as well as in the foreign terms.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78849603-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-02-09/ch530"},"text":"Feb. 9, 1903, ch. 530","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/813"},"text":"32 Stat. 813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s10"},"text":"Feb. 14, 1903, ch. 552, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/829"},"text":"32 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78849604-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78849605-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78849606-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", substituted “Department of Commerce” for “Department of Commerce and Labor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78849607-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":", transferred Bureau of Statistics from Treasury Department to Department of Commerce and Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
