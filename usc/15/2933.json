{"tag":"section","attrib":{"id":"id7a108d0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2933"},"text":null,"children":[{"tag":"num","attrib":{"value":"2933"},"text":"§ 2933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Global Change Research Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall establish an interagency United States Global Change Research Program to improve understanding of global change. The Program shall be implemented by the Plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2934"},"text":"section 2934 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a108d0b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/tI/s103"},"text":"Pub. L. 101–606, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3098"},"text":"104 Stat. 3098","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
