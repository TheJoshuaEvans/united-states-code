{"tag":"section","attrib":{"id":"id7a72346b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7242"},"text":null,"children":[{"tag":"num","attrib":{"value":"7242"},"text":"§ 7242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper influence on conduct of audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a72346c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules to prohibit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful, in contravention of such rules or regulations as the Commission shall prescribe as necessary and appropriate in the public interest or for the protection of investors, for any officer or director of an issuer, or any other person acting under the direction thereof, to take any action to fraudulently influence, coerce, manipulate, or mislead any independent public or certified accountant engaged in the performance of an audit of the financial statements of that issuer for the purpose of rendering such financial statements materially misleading.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a72346d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any civil proceeding, the Commission shall have exclusive authority to enforce this section and any rule or regulation issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a72346e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7242/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No preemption of other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsection (a) shall be in addition to, and shall not supersede or preempt, any other provision of law or any rule or regulation issued thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a72346f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7242/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723470-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7242/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose the rules or regulations required by this section, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723471-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7242/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue final rules or regulations required by this section, not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a723472-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIII/s303"},"text":"Pub. L. 107–204, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/778"},"text":"116 Stat. 778","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
