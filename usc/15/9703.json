{"tag":"section","attrib":{"id":"id7ab299e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9703"},"text":null,"children":[{"tag":"num","attrib":{"value":"9703"},"text":"§ 9703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observations and modeling for total water prediction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab299e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish partnerships with 1 or more institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") to evaluate observations that would improve total water prediction."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority observations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing partnerships under paragraph (1), the Administrator shall prioritize partnerships to evaluate observations from uncrewed aerial systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintained observations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator determines that incorporating additional observations improves total water prediction, the Administrator shall, to the extent practicable, continue incorporating those observations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modeling improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall advance geographic coverage, resolution, skill, and efficiency of coastal oceanographic modeling, including efforts that improve the coupling of and interoperability between hydrological models and coastal ocean models.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab299ec-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s4"},"text":"Pub. L. 117–316, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4408"},"text":"136 Stat. 4408","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
