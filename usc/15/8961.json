{"tag":"section","attrib":{"id":"id7a912fb5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961"},"text":null,"children":[{"tag":"num","attrib":{"value":"8961"},"text":"§ 8961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PFAS destruction and disposal guidance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912fb6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Administrator shall publish interim guidance on the destruction and disposal of perfluoroalkyl and polyfluoroalkyl substances and materials containing perfluoroalkyl and polyfluoroalkyl substances, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912fb7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aqueous film-forming foam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912fb8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil and biosolids;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912fb9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" textiles, other than consumer goods, treated with perfluoroalkyl and polyfluoroalkyl substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912fba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spent filters, membranes, resins, granular carbon, and other waste from water treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912fbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landfill leachate containing perfluoroalkyl and polyfluoroalkyl substances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912fbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solid, liquid, or gas waste streams containing perfluoroalkyl and polyfluoroalkyl substances from facilities manufacturing or using perfluoroalkyl and polyfluoroalkyl substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912fbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations; inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interim guidance under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912fbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939ebf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for releases of perfluoroalkyl and polyfluoroalkyl substances during destruction or disposal, including through volatilization, air dispersion, or leachate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939ec0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potentially vulnerable populations living near likely destruction or disposal sites; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ec1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance on testing and monitoring air, effluent, and soil near potential destruction or disposal sites for releases described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939ec2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8961/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall publish revisions to the interim guidance under subsection (a) as the Administrator determines to be appropriate, but not less frequently than once every 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a939ec3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7361"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7361","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2289"},"text":"133 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
