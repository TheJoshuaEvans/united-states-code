{"tag":"section","attrib":{"id":"id79c68b5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1831"},"text":null,"children":[{"tag":"num","attrib":{"value":"1831"},"text":"§ 1831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this chapter $125,000 for the period beginning ","children":[{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":"; and for the fiscal year beginning "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":", and for each fiscal year thereafter there are authorized to be appropriated such sums, not to exceed $500,000, as may be necessary to carry out this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c68b5e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/540/s12"},"text":"Pub. L. 91–540, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-09"},"text":"Dec. 9, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1407"},"text":"84 Stat. 1407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/360/s10"},"text":"Pub. L. 94–360, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-13"},"text":"July 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/921"},"text":"90 Stat. 921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c68b5f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c68b60-552d-11f1-9071-ff305b7c3ff0"},"text":null,"childr