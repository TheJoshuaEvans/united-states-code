{"tag":"section","attrib":{"id":"id7977ce82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332"},"text":null,"children":[{"tag":"num","attrib":{"value":"1332"},"text":"§ 1332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7977ce83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “cigarette” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7977ce84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any roll of tobacco wrapped in paper or in any substance not containing tobacco, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7977ce85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any roll of tobacco wrapped in any substance containing tobacco which, because of its appearance, the type of tobacco used in the filler, or its packaging and labeling, is likely to be offered to, or purchased by, consumers as a cigarette described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commerce” means (A) commerce between any State, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Virgin Islands, American Samoa, Wake Island, Midway Islands, Kingman Reef, or Johnston Island and any place outside thereof; (B) commerce between points in any state, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Virgin Islands, American Samoa, Wake Island, Midway Islands, Kingman Reef, or Johnston Island, but through any place outside thereof; or (C) commerce wholly within the District of Columbia, Guam, the Virgin Islands, American Samoa, Wake Island, Midway Islands, Kingman Reef, or Johnston Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States”, when used in a geographical sense, includes the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Virgin Islands, American Samoa, Wake Island, Midway Islands, Kingman Reef, and Johnston Island. The term “State” includes any political division of any State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “package” means a pack, box, carton, or container of any kind in which cigarettes are offered for sale, sold, or otherwise distributed to consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means an individual, partnership, corporation, or any other business or legal entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sale or distribution” includes sampling or any other distribution not for sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “little cigar” means any roll of tobacco wrapped in leaf tobacco or any substance containing tobacco (other than any roll of tobacco which is a cigarette within the meaning of subsection (1)) and as to which one thousand units weigh not more than three pounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “brand style” means a variety of cigarettes distinguished by the tobacco used, tar and nicotine content, flavoring used, size of the cigarette, filtration on the cigarette, or packaging.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1332/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7977ce8e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92/s3"},"text":"Pub. L. 89–92, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/282"},"text":"79 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/222/s2"},"text":"Pub. L. 91–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-01"},"text":"Apr. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/88"},"text":"84 Stat. 88","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/109/s2"},"text":"Pub. L. 93–109, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-21"},"text":"Sept. 21, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/352"},"text":"87 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/474/s6/b"},"text":"Pub. L. 98–474, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2204"},"text":"98 Stat. 2204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/92/s11/b"},"text":"Pub. L. 99–92, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/403"},"text":"99 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7977ce8f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7977ce90-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7977ce91-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Pars. (8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/92"},"text":"Pub. L. 99–92","children":[],"tail":" added par. (8) and redesignated former par. (8) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/474"},"text":"Pub. L. 98–474","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/109"},"text":"Pub. L. 93–109","children":[],"tail":" added subsec. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/222"},"text":"Pub. L. 91–222","children":[],"tail":" inserted provisions defining “State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7977ce92-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7977ce93-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/109/s4"},"text":"Pub. L. 93–109, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-21"},"text":"Sept. 21, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/352"},"text":"87 Stat. 352","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/109/s4"},"text":"“The amendment made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1335"},"text":"section 1335 of this title","children":[],"tail":"] shall become effective thirty days after the date of enactment ["},{"tag":"date","attrib":{"date":"1973-09-21"},"text":"Sept. 21, 1973","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7977ce94-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/222"},"text":"Pub. L. 91–222","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", except where otherwise specified, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/222/s3"},"text":"section 3 of Pub. L. 91–222","children":[],"tail":", set out in part as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1331"},"text":"section 1331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
