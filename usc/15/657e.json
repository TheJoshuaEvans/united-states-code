{"tag":"section","attrib":{"id":"id791ae182-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e"},"text":null,"children":[{"tag":"num","attrib":{"value":"657e"},"text":"§ 657e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentoring Networks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791ae183-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae184-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SBIR and STTR programs create jobs, increase capacity for technological innovation, and boost international competitiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae185-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the quantity of applications from all States to the SBIR and STTR programs would enhance competition for such awards and the quality of the completed projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae186-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring is a natural complement to the FAST program of reaching out to new companies regarding the SBIR and STTR programs as an effective and low-cost way to improve the likelihood that such companies will succeed in such programs in developing and commercializing their research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae187-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for Mentoring Networks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient of an award or participant in a cooperative agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657d"},"text":"section 657d of this title","children":[],"tail":" may use a reasonable amount of such assistance for the establishment of a Mentoring Network under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae188-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for Mentoring Networks","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Mentoring Network established using assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657d"},"text":"section 657d of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae189-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide business advice and counseling to high technology small business concerns located in the State or region served by the Mentoring Network and identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657d/c/1/E/ii"},"text":"section 657d(c)(1)(E)(ii) of this title","children":[],"tail":" as potential candidates for the SBIR or STTR programs;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae18a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify volunteer mentors who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae18b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are persons associated with a small business concern that has successfully completed one or more SBIR or STTR funding agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae18c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have agreed to guide small business concerns through all stages of the SBIR or STTR program process, including providing assistance relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791ae18d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposal writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae18e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae18f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Government accounting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae190-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Government audits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae191-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project facilities and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae192-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae193-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" third phase partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae194-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercialization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae195-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" venture capital networking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae196-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters relevant to the SBIR and STTR programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae197-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have experience working with small business concerns participating in the SBIR and STTR programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae198-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute information to the national database referred to in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae199-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to reimburse volunteer mentors for out-of-pocket expenses related to service as a mentor under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae19a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentoring database","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae19b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the database required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638/k/1"},"text":"section 638(k)(1) of this title","children":[],"tail":", in cooperation with the SBIR, STTR, and FAST programs, information on Mentoring Networks and mentors participating under this section, including a description of their areas of expertise;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae19c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work cooperatively with Mentoring Networks to maintain and update the database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae19d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such action as may be necessary to aggressively promote Mentoring Networks under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae19e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657e/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fulfill the requirements of this subsection either directly or by contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791ae19f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s35"},"text":"Pub. L. 85–536, § 2[35]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tI/s112"},"text":"Pub. L. 106–554, § 1(a)(9) [title I, § 112]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–680.)"}],"tail":"\n"}],"tail":null}
