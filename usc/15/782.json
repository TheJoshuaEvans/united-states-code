{"tag":"section","attrib":{"id":"id794cee51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782"},"text":null,"children":[{"tag":"num","attrib":{"value":"782"},"text":"§ 782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petrochemical report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794cee52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within ninety days after he has entered upon the office of Administrator or has been designated by the President to act in such office, the Administrator, or acting Administrator, as the case may be, with the assistance of the Department of Commerce, the Cost of Living Council, and the United States International Trade Commission shall, by written report, inform the Congress as to the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794cee53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effect of current petrochemical prices upon the current level of petrochemical exports, and export levels expected for 1975;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794cee54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effect of current and expected 1975 petrochemical export levels upon domestic petrochemical raw materials and products available to petrochemical producers, converters, and fabricators currently and in 1975;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794cee55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current contribution of petrochemical imports to domestic supplies and the expected contributions in 1975;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794cee56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anticipated economic effects of current and expected 1975 levels of domestic supplies of petrochemicals upon domestic producers, converters, and fabricators of petrochemical raw materials and products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794cee57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exact nature, extent, and sources of data and other information available to the Federal Government regarding the matters set forth in paragraphs (1) through (4) of this subsection, including the exact nature, extent, and sources of such data and information utilized in connection with the report required by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794cee58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s782/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Petrochemical” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “petrochemical” includes organic chemicals, cyclic intermediates, plastics and resins, synthetic fibers, elastomers, organic dyes, organic pigments, detergents, surface active agents, carbon black and ammonia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794cee59-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/275/s23"},"text":"Pub. L. 93–275, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-07"},"text":"May 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/113"},"text":"88 Stat. 113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/618/tI/s171/b"},"text":"Pub. L. 93–618, title I, § 171(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-03"},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2009"},"text":"88 Stat. 2009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794cee5a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id794cee5b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id794cee5c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/618"},"text":"Pub. L. 93–618","children":[],"tail":" substituted “United States International Trade Commission” for “United States Tariff Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794cee5d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id794cee5e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Energy Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id794cee5f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id794cee60-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Cost of Living Council","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cost of Living Council abolished ","children":[{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":", by Ex. Ord. No. 11788, § 1, "},{"tag":"date","attrib":{"date":"1974-06-18"},"text":"June 18, 1974","children":[],"tail":", 39 FR 22113."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
