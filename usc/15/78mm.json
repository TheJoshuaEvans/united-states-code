{"tag":"section","attrib":{"id":"id785288d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"78mm"},"text":"§ 78mm.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General exemptive authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id785288d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78mm/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id785288d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78mm/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), but notwithstanding any other provision of this chapter, the Commission, by rule, regulation, or order, may conditionally or unconditionally exempt any person, security, or transaction, or any class or classes of persons, securities, or transactions, from any provision or provisions of this chapter or of any rule or regulation thereunder, to the extent that such exemption is necessary or appropriate in the public interest, and is consistent with the protection of investors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id785288d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78mm/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, by rule or regulation, determine the procedures under which an exemptive order under this section shall be granted and may, in its sole discretion, decline to entertain any application for an order of exemption under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id785288d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78mm/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may not, under this section, exempt any person, security, or transaction, or any class or classes of persons, securities, or transactions from section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–5 of this title or the rules or regulations issued thereunder or (for purposes of section 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–5 of this title and the rules and regulations issued thereunder) from any definition in paragraph (42), (43), (44), or (45) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id785288d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78mm/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Derivatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless the Commission is expressly authorized by any provision described in this subsection to grant exemptions, the Commission shall not grant exemptions, with respect to amendments made by subtitle B of the Wall Street Transparency and Accountability Act of 2010, with respect to paragraphs (65), (66), (68), (69), (70), (71), (72), (73), (74), (75), (76), and (79) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":", and sections 78j–2(a), 78j–2(b), 78j–2(c), 78m–1, 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–10, 78q–1(g), 78q–1(h), 78q–1(i), 78q–1(j), 78q–1(k), and 78q–1("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title; provided that the Commission shall have exemptive authority under this chapter with respect to security-based swaps as to the same matters that the Commodity Futures Trading Commission has under the Wall Street Transparency and Accountability Act of 2010 with respect to swaps, including under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6/c"},"text":"section 6(c) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id785288da-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 36, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/290/tI/s105/b"},"text":"Pub. L. 104–290, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3424"},"text":"110 Stat. 3424","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s772/a"},"text":"Pub. L. 111–203, title VII, § 772(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1801"},"text":"124 Stat. 1801","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id785288db-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id785288dc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id785288dd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (c), was in the original “this title”. See References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Wall Street Transparency and Accountability Act of 2010, referred to in subsec. (c), is title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1641"},"text":"124 Stat. 1641","children":[],"tail":", which enacted chapter 109 (§ 8301 et seq.) of this title and enacted and amended numerous other sections and notes in the Code. Subtitle B of the Act enacted subchapter II (§ 8341 et seq.) of chapter 109 and sections 78c–3 to 78c–5, 78j–2, 78m–1, and 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–10 of this title, amended sections 77b, 77b–1, 77e, 77q, 78c, 78c–1, 78f, 78i, 78j, 78m, 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":", 78p, 78q–1, 78t, 78u–1, 78u–2, 78bb, 78dd, 78mm, 80a–2, and 80b–2 of this title, enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id785288de-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id785288df-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id785288e0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the later of 360 days after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle B (§§ 761–774) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle B, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s774"},"text":"section 774 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
