{"tag":"section","attrib":{"id":"id7a3b6d88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603"},"text":null,"children":[{"tag":"num","attrib":{"value":"4603"},"text":"§ 4603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Semiconductor Technology Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3b6d89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Semiconductor Technology Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6d8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes and functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3b6d8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of the Council are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3b6d8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To link assessment by the semiconductor industry of future market and national security needs to opportunities for technology development through cooperative public and private investment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To seek ways to respond to the technology challenges for semiconductors by fostering precompetitive cooperation among industry, the Federal Government, and institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To make available judgments, assessments, insights, and recommendations that relate to the opportunities for new research and development efforts and the potential to better rationalize and align industry and government contributions to semiconductor research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall carry out the following functions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3b6d90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise Sematech and the Secretary of Defense on appropriate technology goals and appropriate level of effort for the research and development activities of Sematech.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review the emerging markets, technology developments, and core technology challenges for semiconductor research and development and semiconductor manufacturing and explore opportunities for improved coordination among industry, the Federal Government, and institutions of higher education regarding such developments and challenges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assess the effect on the appropriate role of Sematech of public and private sector international agreements in semiconductor research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exchange views regarding the competitiveness of United States semiconductor technology and new or emerging semiconductor technologies that could affect national economic and security interests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exchange and update information and identify overlaps and gaps regarding the efforts of industry, the Federal Government, and institutions of higher education in semiconductor research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assess technology progress relative to industry requirements and Federal Government requirements, responding as appropriate to the challenges in the national semiconductor technology roadmap developed by representatives of industry, the Federal Government, and institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make recommendations regarding the semiconductor technology development efforts that should be supported by Federal agencies and industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appoint subgroups as appropriate in connection with the updating of the semiconductor technology roadmap.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publish and submit to Congress by March 31 of each year an annual report addressing the semiconductor technology challenges and developments for industry, government, and institutions of higher education and the relationship among the challenges and developments for each, including an evaluation of the role of Sematech.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6d99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of 16 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3b6d9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Acquisition, Technology, and Logistics who shall be Cochairman of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Energy responsible for science and technology matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Commerce for Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant to the President for Economic Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6da0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ten members appointed by the President as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3b6da1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four individuals who are eminent in the semiconductor device industry, one of whom shall be Cochairman of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6da2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two individuals who are eminent in the semiconductor equipment and materials industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6da3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three individuals who are eminent in the semiconductor user industry, including representatives from the telecommunications and computer industries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6da4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One individual who is eminent in an academic institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6da5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council appointed under subsection (c)(7) shall be appointed for a term of three years, except that of the members first appointed, two shall be appointed for a term of one year, five shall be appointed for a term of two years, and three shall be appointed for a term of three years, as designated by the President at the time of appointment. A member of the Council may serve after the expiration of the member’s term until a successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6da6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Council shall not affect its powers but, in the case of a member appointed under subsection (c)(7), shall be filled in the same manner as the original appointment was made. Any member appointed to fill a vacancy for an unexpired term shall be appointed for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6da7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Eleven members of the Council shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6da8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the call of a Cochairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6da9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3b6daa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Council shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6dab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While away from their homes or regular places of business in the performance of duties for the Council, members of the Council shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under sections 5702 and 5703 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6dac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6dad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4603/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall use Federal funds made available to Sematech as needed for general and administrative support in accomplishing the Council’s purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3b6dae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tII/s273"},"text":"Pub. L. 100–180, div. A, title II, § 273","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1070"},"text":"101 Stat. 1070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/245/tI/s103/e"},"text":"Pub. L. 102–245, title I, § 103(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-14"},"text":"Feb. 14, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/9"},"text":"106 Stat. 9","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tII/s263/b"},"text":"Pub. L. 103–160, div. A, title II, § 263(b)","children":[],"tail":", (c)(3)–(e), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1608"},"text":"107 Stat. 1608","children":[],"tail":", 1610; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tII/s251"},"text":"Pub. L. 103–337, div. A, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2702"},"text":"108 Stat. 2702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s911/a/1"},"text":"Pub. L. 106–65, div. A, title IX, § 911(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/717"},"text":"113 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/72"},"text":"Pub. L. 117–286, § 4(a)(72)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4313"},"text":"136 Stat. 4313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3b6daf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3b6db0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a3b6db1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition and Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" inserted “and submit to Congress by March 31 of each year” after “Publish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s263/b"},"text":"Pub. L. 103–160, § 263(b)","children":[],"tail":", substituted “Semiconductor Technology Council” for “Advisory Council” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s263/b"},"text":"Pub. L. 103–160, § 263(b)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “There is established the Advisory Council on Federal Participation in Sematech.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s263/b"},"text":"Pub. L. 103–160, § 263(b)",