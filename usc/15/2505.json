{"tag":"section","attrib":{"id":"id79ef2235-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2505"},"text":null,"children":[{"tag":"num","attrib":{"value":"2505"},"text":"§ 2505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy, acting through appropriate agencies and contractors, shall initiate and provide for the conduct of research and development in areas related to electric and hybrid vehicles, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ef2236-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy storage technology, including batteries and their potential for convenient recharging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef2237-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicle control systems and overall design for energy conservation, including the use of regenerative braking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef2238-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urban design and traffic management to promote maximum transportation-related energy conservation and minimum transportation-related degradation of the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef2239-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"t