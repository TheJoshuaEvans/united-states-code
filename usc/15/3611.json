{"tag":"section","attrib":{"id":"id7a1ebd0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3611"},"text":null,"children":[{"tag":"num","attrib":{"value":"3611"},"text":"§ 3611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1ebd0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits at law or equity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise limited as in section 3607 or 3608 of this title, any person aggrieved by a violation of this chapter may sue at law or in equity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ebd0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of actual damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action authorized by this section for a violation of section 3607 or 3609 of this title where actual damages have been suffered, such damages may be awarded or such other relief granted as deemed fair, just, and equitable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ebd0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person who becomes liable to make any payment under this section may recover contributions from any person who if sued separately, would have been liable to make the same payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1ebd10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts recoverable; defendant’s attorneys’ fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts recoverable under this section may include interest paid, reasonable attorneys’ fees, independent engineer and appraisers’ fees, and court costs. A defendant may recover reasonable attorneys’ fees if the court determines that the cause of action filed by the plaintiff is frivolous, malicious, or lacking in substantial merit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1ebd11-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s612"},"text":"Pub. L. 96–399, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1679"},"text":"94 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
