{"tag":"section","attrib":{"id":"id7a31d01e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3904"},"text":null,"children":[{"tag":"num","attrib":{"value":"3904"},"text":"§ 3904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a31d01f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership interest of members in risk retention groups","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ownership interests of members in a risk retention group shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31d020-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered to be exempted securities for purposes of section 5 of the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77e"},"text":"15 U.S.C. 77e","children":[],"tail":"] and for purposes of section 12 of the Securities Exchange Act of 1934 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78"},"text":"15 U.S.C. 78","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d021-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered to be securities for purposes of the provisions of section 17 of the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77q"},"text":"15 U.S.C. 77q","children":[],"tail":"] and the provisions of section 10 of the Securities Exchange Act of 1934 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j"},"text":"15 U.S.C. 78j","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d022-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A risk retention group shall not be considered to be an investment company for purposes of the Investment Company Act of 1940 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d023-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State blue sky laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ownership interests of members in a risk retention group shall not be considered securities for purposes of any State blue sky law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a31d024-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/45/s5"},"text":"Pub. L. 97–45, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-09-25"},"text":"Sept. 25, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/952"},"text":"95 Stat. 952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a31d025-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a31d026-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a31d027-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Investment Company Act of 1940, referred to in subsec. (b), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"act Aug. 22, 1940, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":", which is classified generally to subchapter I (§ 80a–1 et seq.) of chapter 2D of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
