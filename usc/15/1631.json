n":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/167"},"text":"82 Stat. 167","children":[],"tail":", provided in part that chapter 2 of title I, which enacted sections 1631 to 1641 of this title, is effective "},{"tag":"date","attrib":{"date":"1969-07-01"},"text":"July 1, 1969","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id798d5281-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Real Estate Settlement Procedures","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of Real Estate Settlement Procedures Act of 1974, as superseding provisions of subsec. (c) of this section insofar as applying to federally related mortgage loans, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2605"},"text":"section 2605 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
