{"tag":"section","attrib":{"id":"id7a1790e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3133"},"text":null,"children":[{"tag":"num","attrib":{"value":"3133"},"text":"§ 3133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of rulemaking powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1790e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002483"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002483"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" The Provisions of this subchapter and the amendments made by such provisions are enacted by the Congress—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1790e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3133/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an exercise of the rulemaking power of the House of Representatives and the Senate, respectively, and as such they shall be considered as part of the rules of each House, respectively, or of that House to which they specifically apply, and such rules shall supersede other rules only to the extent that they are inconsistent therewith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1790e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3133/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with full recognition of the constitutional right of either House to change such rules (so far as relating to such House), at any time, in the same manner and to the same extent as in the case of any other rule of such House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1790e6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/523/tIII/s305"},"text":"Pub. L. 95–523, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1907"},"text":"92 Stat. 1907","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1790e7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1790e8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1790e9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/523"},"text":"Pub. L. 95–523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1904"},"text":"92 Stat. 1904","children":[],"tail":", which enacted this subchapter and amended sections 632 and 636 of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
