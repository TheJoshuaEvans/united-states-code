{"tag":"section","attrib":{"id":"id78870634-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s201"},"text":null,"children":[{"tag":"num","attrib":{"value":"201"},"text":"§ 201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sets of standard weights and measures for agricultural colleges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce is directed to cause a complete set of all the weights and measures adopted as standards to be delivered to the governor of each State in the Union for the use of agricultural colleges in the States, respectively, which have received a grant of lands from the United States, and also one set of the same for the use of the Smithsonian Institution: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the cost of each set shall not exceed $200."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78870635-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"date","attrib":{"date":"1881-03-03"},"text":"Mar. 3, 1881","children":[],"tail":", No. 26, "},{"tag":"ref","attrib":{"href":"/us/stat/21/521"},"text":"21 Stat. 521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552"},"text":"Feb. 14, 1903, ch. 552","children":[],"tail":", §§ 4, 10, "},{"tag":"ref","attrib":{"href":"/us/stat/32/826"},"text":"32 Stat. 826","children":[],"tail":", 829; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78870636-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78870637-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78870638-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", created Department of Labor, and renamed Department of Commerce and Labor as Department of Commerce."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78870639-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":", transferred National Bureau of Standards from Treasury Department to Department of Commerce and Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7887063a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A sum sufficient to carry out the provisions of this section was appropriated out of any money in the Treasury not otherwise appropriated by act ","children":[{"tag":"date","attrib":{"date":"1881-03-03"},"text":"Mar. 3, 1881","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7887063b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Distribution to States","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Secretary of the Treasury was directed to cause a complete set of all the weights and measures adopted as standards to be delivered to the governor of each state for the use of the states by Res. ","children":[{"tag":"date","attrib":{"date":"1836-06-14"},"text":"June 14, 1836","children":[],"tail":", No. 7, "},{"tag":"ref","attrib":{"href":"/us/stat/5/133"},"text":"5 Stat. 133","children":[],"tail":", which provision was not incorporated into the Revised Statutes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
