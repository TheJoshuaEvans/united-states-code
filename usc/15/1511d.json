{"tag":"section","attrib":{"id":"id79816b37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1511d"},"text":"§ 1511d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chesapeake Bay Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79816b38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79816b39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce shall establish, within the National Oceanic and Atmospheric Administration, an office to be known as the Chesapeake Bay Office (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall be headed by a Director who shall be appointed by the Secretary of Commerce, in consultation with the Chesapeake Executive Council. Any individual appointed as Director shall have knowledge and experience in research or resource management efforts in the Chesapeake Bay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may appoint such additional personnel for the Office as the Director determines necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79816b3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office, in consultation with the Chesapeake Executive Council, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79816b3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical assistance to the Administrator, to other Federal departments and agencies, and to State and local government agencies in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79816b3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the processes that shape the Chesapeake Bay system and affect its living resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying technical and management alternatives for the restoration and protection of living resources and the habitats they depend upon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the implementation and effectiveness of management plans;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement a strategy for the National Oceanic and Atmospheric Administration that integrates the science, research, monitoring, data collection, regulatory, and management responsibilities of the Secretary of Commerce in such a manner as to assist the cooperative, intergovernmental Chesapeake Bay Program to meet the commitments of the Chesapeake Bay Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate the programs and activities of the various organizations within the National Oceanic and Atmospheric Administration, the Chesapeake Bay Regional Sea Grant Programs, and the Chesapeake Bay units of the National Estuarine Research Reserve System, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79816b43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs and activities in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79816b44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal and estuarine research, monitoring, and assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fisheries research and stock assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote sensing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coastal management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitat conservation and restoration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" atmospheric deposition; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs and activities of the Cooperative Oxford Laboratory of the National Ocean Service with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79816b4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonindigenous species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estuarine and marine species pathology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human pathogens in estuarine and marine environments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ecosystem health;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the National Oceanic and Atmospheric Administration with the activities of the Environmental Protection Agency and other Federal, State, and local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an effective mechanism which shall ensure that projects have undergone appropriate peer review and provide other appropriate means to determine that projects have acceptable scientific and technical merit for the purpose of achieving maximum utilization of available funds and resources to benefit the Chesapeake Bay area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain cognizant of ongoing research, monitoring, and management projects and assist in the dissemination of the results and findings of those projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit a biennial report to the Congress and the Secretary of Commerce with respect to the activities of the Office and on the progress made in protecting and restoring the living resources and habitat of the Chesapeake Bay, which report shall include an action plan consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79816b54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of recommended research, monitoring, and data collection activities necessary to continue implementation of the strategy described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" proposals for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79816b56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing any new National Oceanic and Atmospheric Administration activities in the Chesapeake Bay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of those activities with the activities of the partners in the Chesapeake Bay Program to meet the commitments of the Chesapeake 2000 agreement and subsequent agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79816b58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chesapeake Bay fishery and habitat restoration small watershed grants program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79816b59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Chesapeake Bay Office of the National Oceanic and Atmospheric Administration (in this section referred to as the “Director”), in cooperation with the Chesapeake Executive Council, shall carry out a community-based fishery and habitat restoration small grants and technical assistance program in the Chesapeake Bay watershed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79816b5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make grants under this subsection to pay the Federal share of the cost of projects that are carried out by entities eligible under paragraph (3) for the restoration of fisheries and habitats in the Chesapeake Bay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share under subparagraph (A) shall not exceed 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Projects for which grants may be made under this subsection include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79816b5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of fish passageways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of natural or artificial reefs or substrata for habitats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restoration of wetland or sea grass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of oysters for restoration projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention, identification, and control of nonindigenous species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following entities are eligible to receive grants under this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79816b64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The government of a political subdivision of a State in the Chesapeake Bay watershed, and the government of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An organization in the Chesapeake Bay watershed (such as an educational institution or a community organization)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79816b66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and is exempt from taxation under section 501(a) of that title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79816b67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that will administer such grants in coordination with a government referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may prescribe any additional requirements, including procedures, that the Director considers necessary to carry out the program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79816b69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chesapeake Executive Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, “Chesapeake Executive Council” means the representatives from the Commonwealth of Virginia, the State of Maryland, the Commonwealth of Pennsylvania, the Environmental Protection Agency, the District of Columbia, and the Chesapeake Bay Commission, who are signatories to the Chesapeake Bay Agreement, and any future signatories to that Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79816b6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Department of Commerce for the Chesapeake Bay Office $6,000,000 for each of fiscal years 2002 through 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79816b6b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tIII/s307"},"text":"Pub. L. 102–567, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4284"},"text":"106 Stat. 4284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/372/tIV/s401/a"},"text":"Pub. L. 107–372, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3096"},"text":"116 Stat. 3096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79816b6c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79816b6d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79816b6e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":" substituted “Chesapeake Bay Office” for “Chesapeake Bay Estuarine Resources Office” in section catchline and amended text generally, substituting provisions establishing Office, describing functions, establishing habitat restoration small watershed grants program, and authorizing appropriations, for provisions establishing Office, describing functions, and requiring identification of funding request in President’s annual budget."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79816b6f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79816b70-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Multiple Species Management Strategy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372/tIV/s401/c"},"text":"Pub. L. 107–372, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3099"},"text":"116 Stat. 3099","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/372/tIV/s401/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-12-19"},"text":"Dec. 19, 2002","children":[],"tail":"], the Director of the Chesapeake Bay Office of the National Oceanic and Atmospheric Administration shall begin a 5-year study, in cooperation with the scientific community of the Chesapeake Bay, appropriate State and interstate resource management entities, and appropriate Federal agencies—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine and expand the understanding of the role and response of living resources in the Chesapeake Bay ecosystem; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a multiple species management strategy for the Chesapeake Bay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required elements of study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to improve the understanding necessary for the development of the strategy under paragraph (1)(B), the study shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the current status and trends of fish and shellfish that live in the Chesapeake Bay and its tributaries and are selected for study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and assess interactions among the fish and shellfish referred to in subparagraph (A) and other living resources, with particular attention to the impact of changes within and among trophic levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend management actions to optimize the return of a healthy and balanced ecosystem for the Chesapeake Bay.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
