{"tag":"section","attrib":{"id":"id7a8c7323-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8701"},"text":null,"children":[{"tag":"num","attrib":{"value":"8701"},"text":"§ 8701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8c7324-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to authorize the establishment of an orderly program for developing, financing, and carrying out an effective, continuous, and coordinated program of research, education, and promotion, including funds for marketing and market research activities, that is designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c7325-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the position of the concrete masonry products industry in the domestic marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7326-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, develop, and expand markets and uses for concrete masonry products in the domestic marketplace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7327-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the use of concrete masonry products in construction and building.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c7328-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to provide for the control of production or otherwise limit the right of any person to manufacture concrete masonry products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8c7329-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1302"},"text":"Pub. L. 115–254, div. E, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3469"},"text":"132 Stat. 3469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a8c732a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a8c732b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a8c732c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1301"},"text":"Pub. L. 115–254, div. E, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3469"},"text":"132 Stat. 3469","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dE/s1301"},"text":"“This division [enacting this chapter] may be cited as the ‘Concrete Masonry Products Research, Education, and Promotion Act of 2018’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
