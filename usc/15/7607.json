{"tag":"section","attrib":{"id":"id7a7bd1d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7607"},"text":null,"children":[{"tag":"num","attrib":{"value":"7607"},"text":"§ 7607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking by Federal Trade Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission shall prescribe rules pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"section 57a of this title","children":[],"tail":" to carry out this chapter. Rules so prescribed shall be exempt from the requirements of the Magnuson-Moss Warranty—Federal Trade Commission Improvement Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2301"},"text":"15 U.S.C. 2301","children":[],"tail":" et seq.). Any such regulations shall be issued in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":". The first rules under this section shall take effect not later than 180 days after the effective date of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a7bd1d9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s8"},"text":"Pub. L. 108–164, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2026"},"text":"117 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd1da-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a7bd1db-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},