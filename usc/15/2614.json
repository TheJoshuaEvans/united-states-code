{"tag":"section","attrib":{"id":"id79fd7953-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2614"},"text":null,"children":[{"tag":"num","attrib":{"value":"2614"},"text":"§ 2614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79fd7954-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2614/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail or refuse to comply with any requirement of this subchapter or any rule promulgated, order issued, or consent agreement entered into under this subchapter, or any requirement of subchapter II or any rule promulgated or order issued under subchapter II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fd7955-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2614/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use for commercial purposes a chemical substance or mixture which such person knew or had reason to know was manufactured, processed, or distributed in commerce in violation of section 2604 or 2605 of this title, a rule or order under section 2604 or 2605 of this title, or an order issued in action brought under section 2604 or 2606 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fd7956-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2614/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail or refuse to (A) establish or maintain records, (B) submit reports, notices, or other information, or (C) permit access to or copying of records, as required by this chapter or a rule thereunder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79fd7957-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2614/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail or refuse to permit entry or inspection as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2610"},"text":"section 2610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79fd7958-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tI/s15"},"text":"Pub. L. 94–469, title I, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2036"},"text":"90 Stat. 2036","children":[],"tail":"; renumbered title I and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s3/b/1"},"text":"Pub. L. 99–519, § 3(b)(1)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2988"},"text":"100 Stat. 2988","children":[],"tail":", 2989; "},{"tag":"ref","attrib":{"href":"/us/pl/114/182/tI/s19"},"text":"Pub. L. 114–182, title I, § 19","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/508"},"text":"130 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79fd7959-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79fd795a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{}