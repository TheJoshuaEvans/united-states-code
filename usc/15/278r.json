{"tag":"section","attrib":{"id":"id7897a87c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r"},"text":null,"children":[{"tag":"num","attrib":{"value":"278r"},"text":"§ 278r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative manufacturing research pilot grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7897a87d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a87e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a pilot program of awards to partnerships among participants described in paragraph (2) for the purposes described in paragraph (3). Awards shall be made on a peer-reviewed, competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a87f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such partnerships shall include at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7897a880-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 manufacturing industry partner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a881-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 nonindustry partner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a882-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the program under this section is to foster cost-shared collaborations among firms, educational institutions, research institutions, State agencies, and nonprofit organizations to encourage the development of innovative, multidisciplinary manufacturing technologies. Partnerships receiving awards under this section shall conduct applied research to develop new manufacturing processes, techniques, or materials that would contribute to improved performance, productivity, and competitiveness of United States manufacturing, and build lasting alliances among collaborators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a883-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Awards under this section shall provide for not more than one-third of the costs of a partnership. Not more than an additional one-third of such costs may be obtained directly or indirectly from other Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a884-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Applications for awards under this section shall be submitted in such manner, at such time, and containing such information as the Director shall require. Such applications shall describe at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a885-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how each partner will participate in developing and carrying out the research agenda of the partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a886-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research that the grant would fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a887-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the research to be funded with the award would contribute to improved performance, productivity, and competitiveness of the United States manufacturing industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a888-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting applications for awards under this section, the Director shall consider at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a889-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which projects will have a broad impact on manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a88a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the novelty and scientific and technical merit of the proposed projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a88b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstrated capabilities of the applicants to successfully carry out the proposed research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a88c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting applications under this section the Director shall ensure, to the extent practicable, a distribution of overall awards among a variety of manufacturing industry sectors and a range of firm sizes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a88d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278r/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Director shall run a single pilot competition to solicit and make awards. Each award shall be for a 3-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7897a88e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s33"},"text":"Mar. 3, 1901, ch. 872, § 33","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII/s3007/2"},"text":"Pub. L. 110–69, title III, § 3007(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/591"},"text":"121 Stat. 591","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
