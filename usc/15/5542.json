{"tag":"section","attrib":{"id":"id7a50f087-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542"},"text":null,"children":[{"tag":"num","attrib":{"value":"5542"},"text":"§ 5542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy high-end computing research and development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a50f088-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f089-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out a coordinated program across the Department of research and development (including development of software and hardware) to advance high-end computing systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f08a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and deploy high-end computing systems for advanced scientific and engineering applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f08b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f08c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support both individual investigators and multidisciplinary teams of investigators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f08d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research in multiple architectures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f08e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research on software for high-end computing systems, including research on algorithms, programming environments, tools, languages, and operating systems for high-end computing systems, in collaboration with architecture development efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f08f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for sustained access by the research community in the United States to high-end computing systems and to Leadership Systems, including provision of technical support for users of such systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f090-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support technology transfer to the private sector and others in accordance with applicable law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f091-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the high-end computing activities of the Department of Energy are coordinated with relevant activities in industry and with other Federal agencies, including the National Science Foundation, the Defense Advanced Research Projects Agency, the National Nuclear Security Administration, the National Security Agency, the National Institutes of Health, the National Aeronautics and Space Administration, the National Oceanic and Atmospheric Administration, the National Institutes of Standards and Technology, and the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f092-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership Systems facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f093-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the program carried out under this subchapter, the Secretary shall establish and operate 1 or more Leadership Systems facilities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a50f094-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct advanced scientific and engineering research and development using Leadership Systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f095-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop potential advancements in high-end computing system hardware and software.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f096-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Secretary shall provide to Leadership Systems, on a competitive, merit-reviewed basis, access to researchers in United States industry, institutions of higher education, national laboratories, and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f097-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exascale Computing Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f098-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a research program (referred to in this subsection as the “Program”) for exascale computing, including the development of two or more exascale computing machine architectures, to promote the missions of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f099-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a50f09a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a50f09b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish two or more National Laboratory partnerships with industry partners and institutions of higher education for the research and development of two or more exascale computing architectures across all applicable organizations of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f09c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct mission-related codesign activities in developing the exascale computing architectures under clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f09d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop such advancements in hardware and software technology as are required to fully realize the potential of an exascale production system in addressing Department target applications and solving scientific problems involving predictive modeling and simulation and large scale data analytics and management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f09e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explore the use of exascale computing technologies to advance a broad range of science and engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f09f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, as appropriate, on a competitive, merit-reviewed basis, access for researchers in industries in the United States, institutions of higher education, National Laboratories, and other Federal agencies to the exascale computing systems developed pursuant to clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f0a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select the partnerships with the computing facilities of the Department under subparagraph (A) through a competitive, peer-review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f0a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Codesign and application development","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a50f0a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a50f0a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the Program through an integration of applications, computer science, applied mathematics, and computer hardware architecture using the partnerships established pursuant to paragraph (2) to ensure that, to the maximum extent practicable, two or more exascale computing machine architectures are capable of solving Department target applications and broader scientific problems, including predictive modeling and simulation and large scale data analytics and management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f0a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach programs to increase the readiness for the use of such platforms by domestic industries, including manufacturers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f0a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a50f0a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the integration under subparagraph (A) is furthering application science data and computational workloads across application interests, including national security, material science, physical science, cybersecurity, biological science, the Materials Genome and BRAIN Initiatives of the President, advanced manufacturing, and the national electric grid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f0a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles and responsibilities of National Laboratories and industry, including the definition of the roles and responsibilities within the Department to ensure an integrated program across the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f0a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a50f0a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exascale architectures developed pursuant to partnerships established pursuant to paragraph (2) shall be reviewed through a project review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f0aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-09-28"},"text":"September 28, 2018","children":[],"tail":", the Secretary shall submit to Congress a report on—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a50f0ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the review conducted under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f0ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination and management of the Program to ensure an integrated research program across the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f0ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5542/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time of the budget submission of the Department for each fiscal year, the Secretary, in consultation with the members of the partnerships established pursuant to paragraph (2), shall submit to Congress a report that describes funding for the Program as a whole by functional element of the Department and critical milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a50f0ae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423/s3"},"text":"Pub. L. 108–423, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2400"},"text":"118 Stat. 2400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/246/tIII/s304/b/3"},"text":"Pub. L. 115–246, title III, § 304(b)(3)","children":[],"tail":", formerly § 304(a)(3), "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3145"},"text":"132 Stat. 3145","children":[],"tail":", renumbered § 304(b)(3), "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10104/a/1"},"text":"Pub. L. 117–167, div. B, title I, § 10104(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1433"},"text":"136 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a50f0af-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a50f0b0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a50f0b1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (c)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/423"},"text":"Pub. L. 108–423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2400"},"text":"118 Stat. 2400","children":[],"tail":", which is classified principally to this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5501"},"text":"section 5501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a50f0b2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was enacted as part of the American Super Computing Leadership Act of 2017 which comprises this subchapter, and not as part of the High-Performance Computing Act of 1991 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a50f0b3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s304/b/3/A"},"text":"Pub. L. 115–246, § 304(b)(3)(A)","children":[],"tail":", formerly § 304(a)(3)(A), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", substituted “coordinated program across the Department” for “program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s304/b/3/B"},"text":"Pub. L. 115–246, § 304(b)(3)(B)","children":[],"tail":", formerly § 304(a)(3)(B), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", struck out “, which may include vector, reconfigurable logic, streaming, processor-in-memory, and multithreading architectures” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/246/s304/b/3/C"},"text":"Pub. L. 115–246, § 304(b)(3)(C)","children":[],"tail":", formerly § 304(a)(3)(C), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which related to the establishment of a High-End Software Development Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
