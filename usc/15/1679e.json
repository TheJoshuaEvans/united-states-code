{"tag":"section","attrib":{"id":"id79a2d691-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679e"},"text":"§ 1679e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to cancel contract","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a2d692-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any consumer may cancel any contract with any credit repair organization without penalty or obligation by notifying the credit repair organization of the consumer’s intention to do so at any time before midnight of the 3rd business day which begins after the date on which the contract or agreement between the consumer and the credit repair organization is executed or would, but for this subsection, become enforceable against the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d693-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation form and other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each contract shall be accompanied by a form, in duplicate, which has the heading “Notice of Cancellation” and contains in bold face type the following statement:","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“You may cancel this contract, without any penalty or obligation, at any time before midnight of the 3rd day which begins after the date the contract is signed by you.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“To cancel this contract, mail or deliver a signed, dated copy of this cancellation notice, or any other written notice to [ name of credit repair organization ] at [ address of credit repair organization ] before midnight on [ date ]","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“I hereby cancel this transaction,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"[ date ]","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"[ purchaser’s signature ].”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d694-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer copy of contract required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any consumer who enters into any contract with any credit repair organization shall be given, by the organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d695-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the completed contract and the disclosure statement required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679c"},"text":"section 1679c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d696-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of any other document the credit repair organization requires the consumer to sign,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"at the time the contract or the other document is signed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a2d697-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s407"},"text":"Pub. L. 90–321, title IV, § 407","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-459"},"text":"110 Stat. 3009–459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2d698-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a2d699-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79a2d69a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/s407"},"text":"section 407 of Pub. L. 90–321","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a2d69b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a2d69c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable after the end of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", except with respect to contracts entered into by a credit repair organization before the end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s413"},"text":"section 413 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
