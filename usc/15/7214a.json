{"tag":"section","attrib":{"id":"id7a6d7a57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7214a"},"text":"§ 7214a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6d7a58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6d7a59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “audit report” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7201/a"},"text":"section 7201(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Securities and Exchange Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered form”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6d7a5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6d7a5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form described in section 249.310 of title 17, Code of Federal Regulations, or any successor regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6d7a5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form described in section 249.220f of title 17, Code of Federal Regulations, or any successor regulation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6d7a5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a form that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6d7a60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the equivalent of, or substantially similar to, the form described in clause (i) or (ii) of subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6d7a61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign issuer files with the Commission under the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.) or rules issued under that Act;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “covered issuer” and “non-inspection year” have the meanings given the terms in subsection (i)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7214"},"text":"section 7214 of this title","children":[],"tail":", as added by section 2 of this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “foreign issuer” has the meaning given the term in section 240.3b–4 of title 17, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6d7a64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each covered issuer that is a foreign issuer and for which, during a non-inspection year with respect to the covered issuer, a registered public accounting firm described in subsection (i)(2)(A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7214"},"text":"section 7214 of this title","children":[],"tail":", as added by section 2 of this Act, has prepared an audit report shall disclose in each covered form filed by that issuer that covers such a non-inspection year—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6d7a65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, during the period covered by the covered form, such a registered public accounting firm has prepared an audit report for the issuer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the shares of the issuer owned by governmental entities in the foreign jurisdiction in which the issuer is incorporated or otherwise organized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether governmental entities in the applicable foreign jurisdiction with respect to that registered public accounting firm have a controlling financial interest with respect to the issuer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the name of each official of the Chinese Communist Party who is a member of the board of directors of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6d7a69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6d7a6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operating entity with respect to the issuer; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7a6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7214a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the articles of incorporation of the issuer (or equivalent organizing document) contains any charter of the Chinese Communist Party, including the text of any such charter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6d7a6c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/222/s3"},"text":"Pub. L. 116–222, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1064"},"text":"134 Stat. 1064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6d7a6d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6d7a6e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a6d7a6f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Securities Exchange Act of 1934, referred to in subsec. (a)(3)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2 of this Act, referred to in subsecs. (a)(4) and (b), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/222/s2"},"text":"section 2 of Pub. L. 116–222","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
