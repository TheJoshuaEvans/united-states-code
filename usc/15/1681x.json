{"tag":"section","attrib":{"id":"id79b37881-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681x"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681x"},"text":"§ 1681x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate and technological circumvention prohibited","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall prescribe regulations, to become effective not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-04"},"text":"December 4, 2003","children":[],"tail":", to prevent a consumer reporting agency from circumventing or evading treatment as a consumer reporting agency described in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/p"},"text":"section 1681a(p) of this title","children":[],"tail":" for purposes of this subchapter, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b37882-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681x/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by means of a corporate reorganization or restructuring, including a merger, acquisition, dissolution, divestiture, or asset sale of a consumer reporting agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b37883-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681x/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by maintaining or merging public record and credit account information in a manner that is substantially equivalent to that described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/p"},"text":"section 1681a(p) of this title","children":[],"tail":", in the manner described in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/p"},"text":"section 1681a(p) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b37884-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s629"},"text":"Pub. L. 90–321, title VI, § 629","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/159/tII/s211/b"},"text":"Pub. L. 108–159, title II, § 211(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1970"},"text":"117 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b37885-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b37886-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79b37887-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section subject to joint regulations establishing effective dates as prescribed by Federal Reserve Board and Federal Trade Commission, except as otherwise provided, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/s3"},"text":"section 3 of Pub. L. 108–159","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
