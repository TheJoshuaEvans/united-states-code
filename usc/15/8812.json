{"tag":"section","attrib":{"id":"id7a8ee477-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812"},"text":null,"children":[{"tag":"num","attrib":{"value":"8812"},"text":"§ 8812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Quantum Coordination Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8ee478-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee479-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a National Quantum Coordination Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee47a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordination Office shall have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8ee47b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Director appointed by the Director of the Office of Science and Technology Policy, in consultation with the Secretary of Commerce, the Director of the National Science Foundation, and the Secretary of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee47c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff comprised of employees detailed from the Federal departments and agencies described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8813/b"},"text":"section 8813(b) of this title","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee47d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordination Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee47e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical and administrative support to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8ee47f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Quantum Information Science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee480-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8ee481-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Economic and Security Implications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee482-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee interagency coordination of the Program, including by encouraging and supporting joint agency solicitation and selection of applications for funding of activities under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee483-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the point of contact on Federal civilian quantum information science and technology activities for Federal departments and agencies, industry, universities ","children":[{"tag":"ref","attrib":{"idref":"fn002608"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002608"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" professional societies, State governments, and such other persons as the Coordination Office considers appropriate to exchange technical and programmatic information;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee484-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure coordination among the collaborative ventures or consortia established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8831/a"},"text":"section 8831(a) of this title","children":[],"tail":", Multidisciplinary Centers for Quantum Research and Education established under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8842/a"},"text":"section 8842(a) of this title","children":[],"tail":", and the National Quantum Information Science Research Centers established under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8852/a"},"text":"section 8852(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee485-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct public outreach, including the dissemination of findings and recommendations of the Advisory Committee, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee486-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote access to and early application of the technologies, innovations, and expertise derived from Program activities to agency missions and systems across the Federal Government, and to industry, including startup companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee487-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote access, through appropriate Federal Government agencies, and an open and competitive merit-reviewed process, to existing quantum computing and communication systems developed by industry, universities, and Federal laboratories to the general user community in pursuit of discovery of the new applications of such systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee488-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds necessary to carry out the activities of the Coordination Office shall be made available each fiscal year by the Federal departments and agencies described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8813/b"},"text":"section 8813(b) of this title","children":[],"tail":", as determined by the Director of the Office of Science and Technology Policy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee489-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tI/s102"},"text":"Pub. L. 115–368, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5094"},"text":"132 Stat. 5094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXVI/s6606/c/2"},"text":"Pub. L. 117–81, div. F, title LXVI, § 6606(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2444"},"text":"135 Stat. 2444","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a8ee48a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id7a8ee48b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8815"},"text":"section 8815 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a8ee48c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a8ee48d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “on Quantum Information Science;” for “; and” in subpar. (A), inserted “and” after semicolon in subpar. (B), and added subpar. (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
