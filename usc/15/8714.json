{"tag":"section","attrib":{"id":"id7a8ee424-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8714"},"text":null,"children":[{"tag":"num","attrib":{"value":"8714"},"text":"§ 8714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on expenditures for administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated to carry out this chapter may not be used for the payment of the expenses or expenditures of the Board in administering the order.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a8ee425-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1315"},"text":"Pub. L. 115–254, div. E, § 1315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3483"},"text":"132 Stat. 3483","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
