{"tag":"section","attrib":{"id":"id7a108d49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951"},"text":null,"children":[{"tag":"num","attrib":{"value":"2951"},"text":"§ 2951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a108d4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pooling of international resources and scientific capabilities will be essential to a successful international global change program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While international scientific planning is already underway, there is currently no comprehensive intergovernmental mechanism for planning, coordinating, or implementing research to understand global change and to mitigate possible adverse effects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An international global change research program will be important in building future consensus on methods for reducing global environmental degradation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States, as a world leader in environmental and Earth sciences, should help provide leadership in developing and implementing an international global change research program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108d4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote international, intergovernmental cooperation on global change research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve scientists and policymakers from developing nations in such cooperative global change research programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2951/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote international efforts to provide technical and other assistance to developing nations which will facilitate improvements in their domestic standard of living while minimizing damage to the global or regional environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108d53-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/tII/s202"},"text":"Pub. L. 101–606, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3102"},"text":"104 Stat. 3102","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
