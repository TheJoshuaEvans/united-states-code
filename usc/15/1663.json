{"tag":"section","attrib":{"id":"id799df49f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1663"},"text":null,"children":[{"tag":"num","attrib":{"value":"1663"},"text":"§ 1663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising of open end credit plans","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No advertisement to aid, promote, or assist directly or indirectly the extension of consumer credit under an open end credit plan may set forth any of the specific terms of that plan unless it also clearly and conspicuously sets forth all of the following items:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799df4a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1663/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any minimum or fixed amount which could be imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799df4a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1663/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which periodic rates may be used to compute the finance charge, the periodic rates expressed as annual percentage rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799df4a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1663/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other term that the Bureau may by regulation require to be disclosed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799df4a3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s143"},"text":"Pub. L. 90–321, title I, § 143","children":[],"tail":",