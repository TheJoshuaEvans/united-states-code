{"tag":"section","attrib":{"id":"id79ea406b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233"},"text":null,"children":[{"tag":"num","attrib":{"value":"2233"},"text":"§ 2233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of civil liability barriers that discourage the donation of fire equipment to volunteer fire companies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ea406c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who donates qualified fire control or rescue equipment to a volunteer fire company shall not be liable for civil damages under any State or Federal law for personal injuries, property damage or loss, or death caused by the equipment after the donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea406d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to a person if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ea406e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person’s act or omission causing the injury, damage, loss, or death constitutes gross negligence or intentional misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea406f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is the manufacturer of the qualified fire control or rescue equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4070-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person or agency modified or altered the equipment after it had been recertified by an authorized technician as meeting the manufacturer’s specifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4071-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section preempts the laws of any State to the extent that such laws are inconsistent with this section, except that notwithstanding subsection (b) this section shall not preempt any State law that provides additional protection from liability for a person who donates fire control or fire rescue equipment to a volunteer fire company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4072-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ea4073-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” includes any governmental or other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4074-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fire control or rescue equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fire control or fire rescue equipment” includes any fire vehicle, fire fighting tool, communications equipment, protective gear, fire hose, or breathing apparatus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4075-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified fire control or rescue equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified fire control or rescue equipment” means fire control or fire rescue equipment that has been recertified by an authorized technician as meeting the manufacturer’s specifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4076-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, American Samoa, Guam, the Virgin Islands, any other territory or possession of the United States, and any political subdivision of any such State, territory, or possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4077-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer fire company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “volunteer fire company” means an association of individuals who provide fire protection and other emergency services, where at least 30 percent of the individuals receive little or no compensation compared with an entry level full-time paid individual in that association or in the nearest such association with an entry level full-time paid individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4078-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized technician","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “authorized technician” means a technician who has been certified by the manufacturer of fire control or fire rescue equipment to inspect such equipment. The technician need not be employed by the State or local agency administering the distribution of the fire control or fire rescue equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4079-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2233/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies only to liability for injury, damage, loss, or death caused by equipment that, for purposes of subsection (a), is donated on or after the date that is 30 days after ","children":[{"tag":"date","attrib":{"date":"2006-03-09"},"text":"March 9, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ea407a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tI/s125"},"text":"Pub. L. 109–177, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/226"},"text":"120 Stat. 226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ea407b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ea407c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79ea407d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the USA PATRIOT Improvement and Reauthorization Act of 2005, and not as part of the Federal Fire Prevention and Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
