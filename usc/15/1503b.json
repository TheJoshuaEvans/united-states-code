{"tag":"section","attrib":{"id":"id797efab8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1503b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1503b"},"text":"§ 1503b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Commerce for Oceans and Atmosphere; duties; appointment; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Commerce an Under Secretary of Commerce for Oceans and Atmosphere who shall serve as the Administrator of the National Oceanic and Atmospheric Administration established by Reorganization Plan No. 4 of 1970 [5 U.S.C. App.] and perform such duties as the Secretary of Commerce shall prescribe. The Under Secretary shall be appointed by the President by and with the advice and consent of the Senate and shall be compensated at the rate now or hereafter provided for Level III of the Executive Schedule Pay Rates (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"5 U.S.C. 5314","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797efab9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tIV/s407/a"},"text":"Pub. L. 99–659, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3739"},"text":"100 Stat. 3739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797efaba-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797efabb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id797efabc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan No. 4 of 1970, referred to in text, is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1511"},"text":"section 1511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id797efabd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id797efabe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Service by Incumbent Administrator and Deputy Administrator of the National Oceanic and Atmospheric Administration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tIV/s407/c"},"text":"Pub. L. 99–659, title IV, § 407(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3739"},"text":"100 Stat. 3739","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/659/tIV/s407/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The individual serving on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Administrator of the National Oceanic and Atmospheric Administration shall also serve as the Under Secretary of Commerce for Oceans and Atmosphere until such time as a successor is appointed under subsection (a) of this section [enacting this section]; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Deputy Administrator of the National Oceanic and Atmospheric Administration shall also serve as the Assistant Secretary of Commerce for Oceans and Atmosphere until such time as a successor is appointed under subsection (b) of this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1507/c"},"text":"section 1507(c) of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
