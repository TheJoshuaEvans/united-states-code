{"tag":"section","attrib":{"id":"id79293aa3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690"},"text":null,"children":[{"tag":"num","attrib":{"value":"690"},"text":"§ 690.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293aa4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operational assistance” means management, marketing, and other technical assistance that assists a small business concern with business development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293aa5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “participation agreement” means an agreement, between the Administrator and a company granted final approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s690c/e"},"text":"section 690c(e) of this title","children":[],"tail":", that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79293aa6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details the operating plan and investment criteria of the company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293aa7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the company to make investments in smaller enterprises primarily engaged in researching, manufacturing, developing, producing, or bringing to market goods, products, or services that generate or support the production of renewable energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293aa8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “renewable energy” means energy derived from resources that are regenerative or that cannot be depleted, including solar, wind, ethanol, and biodiesel fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293aa9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable Fuel Capital Investment company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Renewable Fuel Capital Investment company” means a company—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79293aaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79293aab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been granted final approval by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s690c/e"},"text":"section 690c(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79293aac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into a participation agreement with the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293aad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has received conditional approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s690c/c"},"text":"section 690c(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293aae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and any other commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293aaf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venture capital","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “venture capital” means capital in the form of equity capital investments, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s683/g/4"},"text":"section 683(g)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293ab0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s381"},"text":"Pub. L. 85–699, title III, § 381","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1774"},"text":"121 Stat. 1774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79293ab1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79293ab2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79293ab3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
