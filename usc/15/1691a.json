{"tag":"section","attrib":{"id":"id79b5e8b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1691a"},"text":"§ 1691a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; rules of construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b5e8b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The definitions and rules of construction set forth in this section are applicable for the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e8b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “applicant” means any person who applies to a creditor directly for an extension, renewal, or continuation of credit, or applies to a creditor indirectly by use of an existing credit plan for an amount exceeding a previously established credit limit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e8b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Bureau” means the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e8b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “credit” means the right granted by a creditor to a debtor to defer payment of debt or to incur debts and defer its payment or to purchase property or services and defer payment therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e8b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “creditor” means any person who regularly extends, renews, or continues credit; any person who regularly arranges for the extension, renewal, or continuation of credit; or any assignee of an original creditor who participates in the decision to extend, renew, or continue credit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e8b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means a natural person, a corporation, government or governmental subdivision or agency, trust, estate, partnership, cooperative, or association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e8ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reference to any requirement imposed under this subchapter or any provision thereof includes reference to the regulations of the Bureau under this subchapter or the provision thereof in question.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b5e8bb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVII/s702"},"text":"Pub. L. 90–321, title VII, § 702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tV/s503"},"text":"Pub. L. 93–495, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1522"},"text":"88 Stat. 1522","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1085/1"},"text":"Pub. L. 111–203, title X, § 1085(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2083"},"text":"124 Stat. 2083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b5e8bc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b5e8bd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79b5e8be-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1085/2"},"text":"Pub. L. 111–203, § 1085(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which read as follows: “The term ‘Board’ refers to the Board of Governors of the Federal Reserve System.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1085/1"},"text":"Pub. L. 111–203, § 1085(1)","children":[],"tail":", substituted “Bureau” for “Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b5e8bf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79b5e8c0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
