{"tag":"section","attrib":{"id":"id7a7234cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264"},"text":null,"children":[{"tag":"num","attrib":{"value":"7264"},"text":"§ 7264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Code of ethics for senior financial officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7234ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Code of ethics disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall issue rules to require each issuer, together with periodic reports required pursuant to section 78m(a) or 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title, to disclose whether or not, and if not, the reason therefor, such issuer has adopted a code of ethics for senior financial officers, applicable to its principal financial officer and comptroller or principal accounting officer, or persons performing similar functions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in codes of ethics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall revise its regulations concerning matters requiring prompt disclosure on Form 8–K (or any successor thereto) to require the immediate disclosure, by means of the filing of such form, dissemination by the Internet or by other electronic means, by any issuer of any change in or waiver of the code of ethics for senior financial officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “code of ethics” means such standards as are reasonably necessary to promote—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" honest and ethical conduct, including the ethical handling of actual or apparent conflicts of interest between personal and professional relationships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full, fair, accurate, timely, and understandable disclosure in the periodic reports required to be filed by the issuer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with applicable governmental rules and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose rules to implement this section, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7264/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue final rules to implement this section, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7234d7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIV/s406"},"text":"Pub. L. 107–204, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/789"},"text":"116 Stat. 789","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
