{"tag":"section","attrib":{"id":"id7a8c73de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706"},"text":null,"children":[{"tag":"num","attrib":{"value":"8706"},"text":"§ 8706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8c73df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial referendum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referendum required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 60-day period immediately preceding the proposed effective date of the order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8703"},"text":"section 8703 of this title","children":[],"tail":", the Secretary shall conduct a referendum among manufacturers eligible under subsection (b)(2) subject to assessments under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8705"},"text":"section 8705 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order needed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall become effective only if the Secretary determines that the order has been approved by a majority of manufacturers voting who also represent a majority of the machine cavities in operation of those manufacturers voting in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Votes permitted","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each manufacturer eligible to vote in a referendum conducted under this section shall be entitled to cast 1 vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), a manufacturer shall be considered to be eligible to vote if the manufacturer has manufactured concrete masonry products during a period of at least 180 days prior to the first day of the period during which voting in the referendum will occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of conducting referenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Referenda conducted pursuant to this section shall be conducted in a manner determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A manufacturer who chooses to vote in any referendum conducted under this section shall register with the Secretary prior to the voting period, after receiving notice from the Secretary concerning the referendum under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures for voting in any referendum conducted under this section. The ballots and other information or reports that reveal or tend to reveal the identity or vote of voters shall be strictly confidential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days before a referendum is conducted under this section with respect to an order, the Secretary shall notify all manufacturers, in such a manner as determined by the Secretary, of the period during which voting in the referendum will occur. The notice shall explain any registration and voting procedures established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent referenda","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an order is approved in a referendum conducted under subsection (a), the Secretary shall conduct a subsequent referendum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the Board, subject to the voting requirements of subsections (b) and (c), to ascertain whether eligible manufacturers favor suspension, termination, or continuance of the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective beginning on the date that is 5 years after the date of the approval of the order, and at 5-year intervals thereafter, at the request of 25 percent or more of the total number of persons eligible to vote under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as a result of a referendum conducted under subsection (d), the Secretary determines that suspension or termination of the order is favored by a majority of all votes cast in the referendum as provided in subsection (a)(2), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the referendum, suspend or terminate, as appropriate, collection of assessments under the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or terminate, as appropriate, programs and projects under the order as soon as practicable and in an orderly manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8706/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board established under an order with respect to which a referendum is conducted under this section shall reimburse the Secretary from assessments for any expenses incurred by the Secretary to conduct the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8c73f1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1307"},"text":"Pub. L. 115–254, div. E, § 1307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3479"},"text":"132 Stat. 3479","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
