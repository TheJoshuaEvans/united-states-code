{"tag":"section","attrib":{"id":"id794107ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717v"},"text":null,"children":[{"tag":"num","attrib":{"value":"717v"},"text":"§ 717v.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application of such provision to any person or circumstance, shall be held invalid, the remainder of the chapter, and the application of such provision to persons or circumstances other than those as to which it is held invalid, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id794107ed-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556/s25"},"text":"June 21, 1938, ch. 556, § 25","children":[],"tail":", formerly § 23, "},{"tag":"ref","attrib":{"href":"/us/stat/52/833"},"text":"52 Stat. 833","children":[],"tail":"; renumbered § 25, "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s314/b/1/A"},"text":"Pub. L. 109–58, title III, § 314(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/690"},"text":"119 Stat. 690","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
