{"tag":"section","attrib":{"id":"id797a404d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1358"},"text":null,"children":[{"tag":"num","attrib":{"value":"1358"},"text":"§ 1358.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent of Congress for interstate compacts; reservation of right to alter, amend, or repeal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id797a404e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1358/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consent of the Congress is given to any two or more States to enter into agreement or compacts, not in conflict with any law of the United States, for cooperative efforts and mutual assistance and in designating agencies, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1357"},"text":"section 1357 of this title","children":[],"tail":", for accomplishing the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797a404f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1358/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to alter, amend, or repeal this section, or consent granted by this section, is expressly reserved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id797a4050-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/182/s8"},"text":"Pub. L. 89–182, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-14"},"text":"Sept. 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/682"},"text":"79 Stat. 682","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
