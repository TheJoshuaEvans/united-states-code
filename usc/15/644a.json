{"tag":"section","attrib":{"id":"id790a3f54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a"},"text":null,"children":[{"tag":"num","attrib":{"value":"644a"},"text":"§ 644a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small Business Procurement Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id790a3f55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established an interagency council to be known as the “Small Business Procurement Advisory Council” (hereinafter in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790a3f56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Council are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id790a3f57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop positions on proposed procurement regulations affecting the small business community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit comments reflecting such positions to appropriate regulatory authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct reviews of each Office of Small and Disadvantaged Business Utilization established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s644/k"},"text":"section 644(k) of this title","children":[],"tail":" to determine the compliance of each Office with requirements under such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify best practices for maximizing small business utilization in Federal contracting that may be implemented by Federal agencies having procurement powers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to submit, annually, to the Committee on Small Business of the House of Representatives and the Committee on Small Business and Entrepreneurship of the Senate a report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id790a3f5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comments submitted under paragraph (2) during the 1-year period ending on the date on which the report is submitted, including any outcomes related to the comments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id790a3f5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of reviews conducted under paragraph (3) during such 1-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id790a3f5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices identified under paragraph (4) during such 1-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790a3f5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id790a3f60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Small Business Administration (or the designee of the Administrator).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Minority Business Development Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790a3f62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each Office of Small and Disadvantaged Business Utilization in each Federal agency having procurement powers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790a3f63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall be chaired by the Administrator of the Small Business Administration (or the designee of the Administrator).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790a3f64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the call of the chairman as necessary to consider proposed procurement regulations affecting the small business community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790a3f65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s644a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of Council comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Acquisition Regulatory Council and other appropriate regulatory authorities shall consider comments submitted in a timely manner pursuant to subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id790a3f66-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVII/s7104"},"text":"Pub. L. 103–355, title VII, § 7104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3369"},"text":"108 Stat. 3369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1692"},"text":"Pub. L. 112–239, div. A, title XVI, § 1692","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2089"},"text":"126 Stat. 2089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id790a3f67-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id790a3f68-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id790a3f69-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s644"},"text":"section 644 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Acquisition Streamlining Act of 1994, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id790a3f6a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1692/a"},"text":"Pub. L. 112–239, § 1692(a)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1692/b"},"text":"Pub. L. 112–239, § 1692(b)","children":[],"tail":", struck out “(established under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s644/k"},"text":"section 644(k) of this title","children":[],"tail":")” after “Utilization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1692/c"},"text":"Pub. L. 112–239, § 1692(c)","children":[],"tail":", inserted “(or the designee of the Administrator)” after “Small Business Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
