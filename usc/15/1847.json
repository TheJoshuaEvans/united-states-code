{"tag":"section","attrib":{"id":"id79c68b96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1847"},"text":null,"children":[{"tag":"num","attrib":{"value":"1847"},"text":"§ 1847.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The maximum obligation of the Board under all outstanding loans guaranteed by it shall not exceed at any time $250,000,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c68b97-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/70/s8"},"text":"Pub. L. 92–70, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-09"},"text":"Aug. 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/181"},"text":"85 Stat. 181","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
