{"tag":"section","attrib":{"id":"id7ab29a34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706"},"text":null,"children":[{"tag":"num","attrib":{"value":"9706"},"text":"§ 9706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freshwater monitoring along the coast","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab29a35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data availability assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall assess the availability of short- and long-term data on large-scale freshwater flooding into oceans, bays, and estuaries, including data on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29a36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flow rate, including discharge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conductivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oxygen concentration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutrient load;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water temperature; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sediment load.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29a3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data needs assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall assess the need for additional data to assess and predict the effect of the flooding and freshwater discharge described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab5093d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory of data needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the assessments required by subsections (a) and (b), the Administrator shall create an inventory of data needs with respect to the flooding and freshwater discharge described in subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab5093e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In planning for the collection of additional data necessary for ecosystem-based modeling of the effect of the flooding and freshwater discharge described in subsections (a) and (b), the Administrator shall use the inventory created under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab5093f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s7"},"text":"Pub. L. 117–316, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4412"},"text":"136 Stat. 4412","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
