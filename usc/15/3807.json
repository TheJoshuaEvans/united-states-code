{"tag":"section","attrib":{"id":"id7a2f8690-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3807"},"text":null,"children":[{"tag":"num","attrib":{"value":"3807"},"text":"§ 3807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of methane-fueled vehicles by Federal agencies and departments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall consult with the Postmaster General of the United States Postal Service, the Administrator of the General Services Administration, the Secretary of Defense, and the heads of other Federal agencies where appropriate to—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2f8691-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the practicability of using methane vehicles in the performance of certain or all of the functions of their agencies based in counties and standard metropolitan statistical areas in which demonstrations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3806"},"text":"section 3806 of this title","children":[],"tail":" are being conducted; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f8692-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for appropriate use of methane-fueled vehicles at the earliest practicable date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2f8693-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/512/s8"},"text":"Pub. L. 96–512, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2832"},"text":"94 Stat. 2832","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
