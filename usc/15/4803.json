{"tag":"section","attrib":{"id":"id7a4753d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803"},"text":null,"children":[{"tag":"num","attrib":{"value":"4803"},"text":"§ 4803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Council","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4753d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations for national strategies and on specific policies intended to enhance the productivity and international competitiveness of United States industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide comments, when appropriate, and through any existing comment procedure, on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4753d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector requests for governmental assistance or relief, specifically as to whether the applicant is likely, by receiving the assistance or relief, to become internationally competitive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what actions should be taken by the applicant as a condition of such assistance or relief to ensure that the applicant is likely to become internationally competitive;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze information concerning current and future United States economic competitiveness useful to decision making in government and industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a forum where national leaders with experience and background in business, labor, academia, public interest activities, and government shall identify and develop recommendations to address problems affecting the economic competitiveness of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate Federal policies, regulations, and unclassified international agreement on trade, science, and technology to which the United States is a party with respect to the impact on United States competitiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide policy recommendations to the Congress, the President, and the Federal departments and agencies regarding specific issues concerning competitiveness strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" monitor the changing nature of research, science, and technology in the United States and the changing nature of the United States economy and its capacity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4753de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide marketable, high quality goods and services in domestic and international markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to respond to international competition;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4753e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and private sector resources devoted to increased competitiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local government programs devised to enhance competitiveness, including joint ventures between universities and corporations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, when appropriate, subcouncils of public and private leaders to develop recommendations on long-term strategies for sectors of the economy and for specific competitiveness issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review policy recommendations developed by the subcouncils and transmit such recommendations to the Federal agencies responsible for the implementation of such recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare, publish, and distribute reports containing the recommendations of the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4803/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish their analysis and recommendations in the form of an annual report to the President and the Congress which also comments on the overall competitiveness of the American economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4753e7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5204"},"text":"Pub. L. 100–418, title V, § 5204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1456"},"text":"102 Stat. 1456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4753e8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a4753e9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a4753ea-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under par. (12) of this section is listed on page 158), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
