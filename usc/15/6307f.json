{"tag":"section","attrib":{"id":"id7a57f5cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307f"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307f"},"text":"§ 6307f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required disclosures for judges and referees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A judge or referee shall not be entitled to receive any compensation, directly or indirectly, in connection with a boxing match until it provides to the boxing commission responsible for regulating the match in a State a statement of all consideration, including reimbursement for expenses, that will be received from any source for participation in the match.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a57f5ce-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s14"},"text":"Pub. L. 104–272, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/2"},"text":"Pub. L. 106–210, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/325"},"text":"114 Stat. 325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f5cf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a57f5d0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a57f5d1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s14"},"text":"section 14 of Pub. L. 104–272","children":[],"tail":" was renumbered section 22 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6313"},"text":"section 6313 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
