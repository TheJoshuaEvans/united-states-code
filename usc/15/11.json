{"tag":"section","attrib":{"id":"id77b07ce3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"§ 11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of property in transit","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any property owned under any contract or by any combination, or pursuant to any conspiracy, and being the subject thereof, mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8"},"text":"section 8 of this title","children":[],"tail":", imported into and being within the United States or being in the course of transportation from one State to another, or to or from a Territory or the District of Columbia, shall be forfeited to the United States, and may be seized and condemned by like proceedings as those provided by law for the forfeiture, seizure, and condemnation of property imported into the United States contrary to law."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77b07ce4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-08-27/ch349/s76"},"text":"Aug. 27, 1894, ch. 349, § 76","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/570"},"text":"28 Stat. 570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-02-12/ch40"},"text":"Feb. 12, 1913, ch. 40","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/667"},"text":"37 Stat. 667","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77b07ce5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77b07ce6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77b07ce7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1913—Act ","children":[{"tag":"date","attrib":{"date":"1913-02-12"},"text":"Feb. 12, 1913","children":[],"tail":", substituted “imported into and being within the United States or” for “and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
