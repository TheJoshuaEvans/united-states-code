{"tag":"section","attrib":{"id":"id77ae0b7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7a"},"text":"§ 7a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 7a to 7a–3 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77ae0b7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust Division","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Antitrust Division” means the United States Department of Justice Antitrust Division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ae0b80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust leniency agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “antitrust leniency agreement,” or “agreement,” means a leniency letter agreement, whether conditional or final, between a person and the Antitrust Division pursuant to the Corporate Leniency Policy of the Antitrust Division in effect on the date of execution of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ae0b81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust leniency applicant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “antitrust leniency applicant,” or “applicant,” means, with respect to an antitrust leniency agreement, the person that has entered into the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ae0b82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claimant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “claimant” means a person or class, that has brought, or on whose behalf has been brought, a civil action alleging a violation of section 1 or 3 of this title or any similar State law, except that the term does not include a State or a subdivision of a State with respect to a civil action brought to recover damages sustained by the State or subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ae0b83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperating individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cooperating individual” means, with respect to an antitrust leniency agreement, a current or former director, officer, or employee of the antitrust leniency applicant who is covered by the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ae0b84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” has the meaning given it in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77ae0b85-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237/tII/s212"},"text":"Pub. L. 108–237, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-22"},"text":"June 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/666"},"text":"118 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/190/s2"},"text":"Pub. L. 111–190, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-06-09"},"text":"June 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1275"},"text":"124 Stat. 1275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/159/dD/tIII/s4303/b/2"},"text":"Pub. L. 116–159, div. D, title III, § 4303(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/742"},"text":"134 Stat. 742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ae0b86-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ae0b87-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77ae0b88-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 7a to 7a–3 of this title, referred to in text, was in the original “this subtitle”, meaning subtitle A (§§ 211–216) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237"},"text":"Pub. L. 108–237","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-22"},"text":"June 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/666"},"text":"118 Stat. 666","children":[],"tail":", which enacted this section and sections 7a–1 to 7a–3 of this title, amended sections 1, 2, and 3 of this title, and enacted provisions formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"section 1 of this title","children":[],"tail":". For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77ae0b89-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"section 1 of this title","children":[],"tail":", prior to transfer to this section upon repeal of sunset provision."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77ae0b8a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159"},"text":"Pub. L. 116–159","children":[],"tail":" redesignated par. (7) as (6) and struck out former par. (6). Prior to amendment, text of par. (6) read as follows: “The term ‘marker’ means an assurance given by the Antitrust Division to a candidate for corporate leniency that no other company will be considered for leniency, for some finite period of time, while the candidate is given an opportunity to perfect its leniency application.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/190"},"text":"Pub. L. 111–190","children":[],"tail":" added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77ae0b8b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77ae0b8c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings; Purpose of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/dD/tIII/s4302"},"text":"Pub. L. 116–159, div. D, title III, § 4302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/742"},"text":"134 Stat. 742","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/159/dD/tIII/s4302"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conspiracies among competitors to fix prices, rig bids, and allocate markets are categorically and irredeemably anticompetitive and contravene the competition policy of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperation incentives are important to the efforts of the Antitrust Division of the Department of Justice to prosecute and deter the offenses described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this Act [probably means title III of div. D (§ 4301 et seq.) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159"},"text":"Pub. L. 116–159","children":[],"tail":", see Tables for classification], and the amendments made by this Act, is to strengthen public and private antitrust enforcement by providing incentives for antitrust violators to cooperate fully with government prosecutors and private litigants through the repeal of the sunset provision of the Antitrust Criminal Penalty Enhancement and Reform Act of 2004 ["},{"tag":"ref","attrib":{"href":"/us/pl/108/237/s211"},"text":"section 211 of Pub. L. 108–237","children":[],"tail":"] ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"15 U.S.C. 1","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77ae0b8d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Technical and Conforming Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/dD/tIII/s4303/b/1"},"text":"Pub. L. 116–159, div. D, title III, § 4303(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/742"},"text":"134 Stat. 742","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/159/dD/tIII/s4303/b/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revival and restoration.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 212, 213, and 214 of the Antitrust Criminal Penalty Enhancement and Reform Act of 2004 [title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237"},"text":"Pub. L. 108–237","children":[],"tail":"] ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"15 U.S.C. 1","children":[],"tail":" note [now "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7a"},"text":"15 U.S.C. 7a","children":[],"tail":", 7a–1, 7a–2, respectively]) as in effect on "},{"tag":"date","attrib":{"date":"2020-06-21"},"text":"June 21, 2020","children":[],"tail":", and as amended by the laws described in subparagraph (B), are revived and restored."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The laws described in this subparagraph are:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Antitrust Criminal Penalty Enhancement and Reform Act of 2004 Extension Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/30"},"text":"Public Law 111–30","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/123/1775"},"text":"123 Stat. 1775","children":[],"tail":") [amending former "},{"tag":"ref","attrib":{"href":"/us/pl/108/237/s211"},"text":"section 211 of Pub. L. 108–237","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Act entitled ‘An Act to amend the Antitrust Criminal Penalty Enhancement and Reform Act of 2004 to extend the operation of such Act, and for other purposes’, approved ","children":[{"tag":"date","attrib":{"date":"2010-06-09"},"text":"June 9, 2010","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/111/90"},"text":"Public Law 111–90","children":[],"tail":" [sic, probably should be “111–190”]; "},{"tag":"ref","attrib":{"href":"/us/stat/124/1275"},"text":"124 Stat. 1275","children":[],"tail":") [amending this section, sections 7a–1 and 7a–2 of this title, and former "},{"tag":"ref","attrib":{"href":"/us/pl/108/237/s211"},"text":"section 211 of Pub. L. 108–237","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77b07c8e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/dD/tIII/s4303/c"},"text":"Pub. L. 116–159, div. D, title III, § 4303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/742"},"text":"134 Stat. 742","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/159/dD/tIII/s4303/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Markers and agreements before sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the repeal under subsection (a) [repealing ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237/s211"},"text":"section 211 of Pub. L. 108–237","children":[],"tail":"], section 211(b) of the Antitrust Criminal Penalty Enhancement and Reform Act of 2004 ["},{"tag":"ref","attrib":{"href":"/us/pl/108/237"},"text":"Pub. L. 108–237","children":[],"tail":"] ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"15 U.S.C. 1","children":[],"tail":" note), as in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":"], shall continue to apply to any person who received a marker or entered into an antitrust leniency agreement on or before "},{"tag":"date","attrib":{"date":"2020-06-22"},"text":"June 22, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Markers and agreements after sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The repeal under subsection (a) shall apply to any person who received a marker or entered into an antitrust leniency agreement on or after ","children":[{"tag":"date","attrib":{"date":"2020-06-23"},"text":"June 23, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
