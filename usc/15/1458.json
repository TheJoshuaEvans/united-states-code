{"tag":"section","attrib":{"id":"id797cb109-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1458"},"text":null,"children":[{"tag":"num","attrib":{"value":"1458"},"text":"§ 1458.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with State authorities; transmittal of regulations to States; noninterference with existing programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id797cb10a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1458/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of each regulation promulgated under this chapter shall be transmitted promptly to the Secretary of Commerce, who shall (1) transmit copies thereof to all appropriate State officers and agencies, and (2) furnish to such State officers and agencies information and assistance to promote to the greatest practicable extent uniformity in State and Federal regulation of the labeling of consumer commodities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb10b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1458/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in this section shall be construed to impair or otherwise interfere with any program carried into effect by the Secretary of Health and Human Services under other provisions of law in cooperation with State governments or agencies, instrumentalities, or political subdivisions thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id797cb10c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/755/s9"},"text":"Pub. L. 89–755, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1301"},"text":"80 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797cb10d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id797cb10e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id797cb10f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (b) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
