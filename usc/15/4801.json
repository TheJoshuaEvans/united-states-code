{"tag":"section","attrib":{"id":"id7a4753ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801"},"text":null,"children":[{"tag":"num","attrib":{"value":"4801"},"text":"§ 4801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4753ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4753af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" efforts to reverse the decline of United States industry has been hindered by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4753b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a serious erosion in the institutions and policies which foster United States competitiveness including a lack of high quality domestic and international economic and scientific data needed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4753b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reveal sectoral strengths and weaknesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify potential new markets and future technological and economic trends; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide necessary information regarding the competitive strategies of foreign competitors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lack of a coherent and consistent government competitiveness policy, including policies with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4753b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international trade, finance, and investment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, science, and technology,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education, labor retraining, and adjustment,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" macroeconomic and budgetary issues,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" antitrust and regulation, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government procurement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States economy benefits when business, labor, government, academia, and public interest groups work together cooperatively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decline of United States economic competitiveness endangers the ability of the United States to maintain the defense industrial base which is necessary to the national security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the world is moving rapidly toward the creation of an integrated and interdependent economy, a world economy in which the policies of one nation have a major impact on other nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated solutions to such issues as trade and investment research, science, and technology, education, and labor retraining and adjustments help the United States compete more effectively in the world economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government, business, labor, academia, and public interest groups shall cooperate to develop and coordinate long-range strategies to help assure the international competitiveness of the United States economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4753c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4753c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop recommendations for long-range strategies for promoting the international competitiveness of the United States industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to establish the Competitiveness Policy Council which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4753c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze information regarding the competitiveness of United States industries and business and trade policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" create an institutional forum where national leaders with experience and background in business, labor, government, academia, and public interest activities shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4753c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify economic problems inhibiting the competitiveness of United States agriculture, business, and industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop long-term strategies to address such problem; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations on issues crucial to the development of coordinated competitiveness strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4801/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish analysis in the form of periodic reports and recommendations concerning the United States business and trade policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4753c9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5202"},"text":"Pub. L. 100–418, title V, § 5202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1455"},"text":"102 Stat. 1455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4753ca-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a4753cb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a4753cc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5201"},"text":"Pub. L. 100–418, title V, § 5201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1454"},"text":"102 Stat. 1454","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/418/tV/s5201"},"text":"“This subtitle [subtitle C (§§ 5201–5210) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", enacting this chapter] may be cited as the ‘Competitiveness Policy Council Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
