{"tag":"section","attrib":{"id":"id79b833ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1692i"},"text":"§ 1692i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal actions by debt collectors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b833ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any debt collector who brings any legal action on a debt against any consumer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b833ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an action to enforce an interest in real property securing the consumer’s obligation, bring such action only in a judicial district or similar legal entity in which such real property is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b833f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an action not described in paragraph (1), bring such action only in the judicial district or similar legal entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b833f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which such consumer signed the contract sued upon; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b833f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which such consumer resides at the commencement of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b833f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize the bringing of legal actions by debt collectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b833f4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVIII/s811"},"text":"Pub. L. 90–321, title VIII, § 811","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/880"},"text":"91 Stat. 880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b833f5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b833f6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79b833f7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of six months after ","children":[{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s819"},"text":"section 819 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692"},"text":"section 1692 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
