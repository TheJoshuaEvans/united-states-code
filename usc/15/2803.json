{"tag":"section","attrib":{"id":"id7a0bab67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803"},"text":null,"children":[{"tag":"num","attrib":{"value":"2803"},"text":"§ 2803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial and interim franchises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0bab68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of statutory nonrenewal provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2802"},"text":"section 2802 of this title","children":[],"tail":" shall not apply to the nonrenewal of any franchise relationship—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0bab69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a trial franchise; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under an interim franchise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0bab6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0bab6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “trial franchise” means any franchise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0bab6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is entered into on or after ","children":[{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the franchisee of which has not previously been a party to a franchise with the franchisor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial term of which is for a period of not more than 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is in writing and states clearly and conspicuously—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0bab71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the franchise is a trial franchise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0bab72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of the initial term of the franchise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0bab73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the franchisor may fail to renew the franchise relationship at the conclusion of the initial term stated in the franchise by notifying the franchisee, in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2804"},"text":"section 2804 of this title","children":[],"tail":", of the franchisor’s intention not to renew the franchise relationship; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0bab74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2802"},"text":"section 2802 of this title","children":[],"tail":", limiting the right of a franchisor to fail to renew a franchise relationship, are not applicable to such trial franchise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “trial franchise” does not include any unexpired period of any term of any franchise (other than a trial franchise, as defined by paragraph (1)) which was transferred or assigned by a franchisee to the extent authorized by the provisions of the franchise or any applicable provision of State law which permits such transfer or assignment, without regard to any provision of the franchise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “interim franchise” means any franchise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0bab77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is entered into on or after ","children":[{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of which, when combined with the terms of all prior interim franchises between the franchisor and the franchisee, does not exceed 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effective date of which occurs immediately after the expiration of a prior franchise, applicable to the marketing premises, which was not renewed if such nonrenewal—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0bab7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was based upon a determination described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2802/b/2/E"},"text":"section 2802(b)(2)(E) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0bab7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2802/b/2/E"},"text":"section 2802(b)(2)(E) of this title","children":[],"tail":" were satisfied; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which is in writing and states clearly and conspicuously—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0bab7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the franchise is an interim franchise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0bab7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of the franchise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0bab7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/b/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the franchisor may fail to renew the franchise at the conclusion of the term stated in the franchise based upon a determination made by the franchisor in good faith and in the normal course of business to withdraw from the marketing of motor fuel through retail outlets in the relevant geographic market area in which the marketing premises are located if the requirements of section 2802(b)(2)(E)(ii) and (iii) of this title are satisfied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0bab80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonrenewal upon meeting statutory notification requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the notification requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2804"},"text":"section 2804 of this title","children":[],"tail":" are met, any franchisor may fail to renew any franchise relationship—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0bab81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under any trial franchise, at the conclusion of the initial term of such trial franchise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under any interim franchise, at the conclusion of the term of such interim franchise, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0bab83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such nonrenewal is based upon a determination described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2802/b/2/E"},"text":"section 2802(b)(2)(E) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0bab84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2803/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of section 2802(b)(2)(E)(ii) and (iii) of this title are satisfied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0bab85-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/297/tI/s103"},"text":"Pub. L. 95–297, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/328"},"text":"92 Stat. 328","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
