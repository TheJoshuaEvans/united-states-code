{"tag":"section","attrib":{"id":"id7854f9f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp"},"text":null,"children":[{"tag":"num","attrib":{"value":"78pp"},"text":"§ 78pp.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investor Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7854f9f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854f9fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Commission the Investor Advisory Committee (referred to in this section as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854f9fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854f9fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise and consult with the Commission on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7854f9fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulatory priorities of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854f9fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues relating to the regulation of securities products, trading strategies, and fee structures, and the effectiveness of disclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854f9ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives to protect investor interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives to promote investor confidence and the integrity of the securities marketplace; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Commission such findings and recommendations as the Committee determines are appropriate, including recommendations for proposed legislative changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Committee shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Investor Advocate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of State securities commissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the interests of senior citizens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not fewer than 10, and not more than 20, members appointed by the Commission, from among individuals who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7854fa08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the interests of individual equity and debt investors, including investors in mutual funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the interests of institutional investors, including the interests of pension funds and registered investment companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are knowledgeable about investment issues and decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7854fa0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have reputations of integrity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Committee appointed under paragraph (1)(B) shall serve for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members not Commission employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members appointed under paragraph (1)(B) shall not be deemed to be employees or agents of the Commission solely because of membership on the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; vice chairman; secretary; assistant secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Committee shall elect, from among the members of the Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a chairman, who may not be employed by an issuer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vice chairman, who may not be employed by an issuer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assistant secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member elected under paragraph (1) shall serve for a term of 3 years in the capacity for which the member was elected under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency of meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall meet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than twice annually, at the call of the chairman of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from time to time, at the call of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairman of the Committee shall give the members of the Committee written notice of each meeting, not later than 2 weeks before the date of the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Committee who is not a full-time employee of the United States shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be entitled to receive compensation at a rate not to exceed the daily equivalent of the annual rate of basic pay in effect for a position at level V of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":" for each day during which the member is engaged in the actual performance of the duties of the Committee; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while away from the home or regular place of business of the member in the performance of services for the Committee, be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in the Government service are allowed expenses under section 5703(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002114"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"Section 5703 of Title 5","children":[],"tail":" does not contain a subsec. (b)."}],"tail":" of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make available to the Committee such staff as the chairman of the Committee determines are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854fa1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the findings and recommendations of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854fa20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each time the Committee submits a finding or recommendation to the Commission, promptly issue a public statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7854fa21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the finding or recommendation of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7854fa22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosing the action, if any, the Commission intends to take with respect to the finding or recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall require the Commission to agree to or act upon any finding or recommendation of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply with respect to the Committee and its activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854fa25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78pp/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Commission such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7854fa26-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 39, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s911"},"text":"Pub. L. 111–203, title IX, § 911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1822"},"text":"124 Stat. 1822","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/64"},"text":"Pub. L. 117–286, § 4(a)(64)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4312"},"text":"136 Stat. 4312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7854fa27-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7854fa28-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7854fa29-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7854fa2a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7854fa2b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
