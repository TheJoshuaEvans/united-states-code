{"tag":"section","attrib":{"id":"id79862697-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546"},"text":null,"children":[{"tag":"num","attrib":{"value":"1546"},"text":"§ 1546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Travel and Tourism Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79862698-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the United States Travel and Tourism Advisory Board (referred to in this section as the “Board”), the members of which shall be appointed by the Secretary of Commerce for 2-year terms from companies and organizations in the travel and tourism industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79862699-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary of Commerce for Travel and Tourism shall serve as the Executive Director of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7986269a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Secretariat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Travel and Tourism Office of the International Trade Administration shall serve as the Executive Secretariat for the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7986269b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board’s Charter shall specify that the Board will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7986269c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the advisory body to the Secretary of Commerce on matters relating to the travel and tourism industry in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7986269d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Secretary of Commerce on government policies and programs that affect the United States travel and tourism industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7986269e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer counsel on current and emerging issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7986269f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a forum for discussing and proposing solutions to problems related to the travel and tourism industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798626a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice regarding the domestic travel and tourism industry as an economic engine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798626a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1546/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery strategies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall assist the Assistant Secretary of Commerce for Travel and Tourism in the development and implementation of the recovery strategies required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9803/e/1"},"text":"section 9803(e)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798626a2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-19/ch642/s3"},"text":"July 19, 1940, ch. 642, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/773"},"text":"54 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/31/s12/10"},"text":"Pub. L. 97–31, § 12(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-06"},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/154"},"text":"95 Stat. 154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/443/s9"},"text":"Pub. L. 98–443, § 9","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1708"},"text":"98 Stat. 1708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tVI/s607"},"text":"Pub. L. 117–328, div. BB, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5569"},"text":"136 Stat. 5569","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798626a3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798626a4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798626a5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s18b"},"text":"section 18b of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id798626a6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended section generally. Prior to amendment, section authorized creation of an advisory committee for promotion of tourist travel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Pub. L. 98–443","children":[],"tail":" struck out “the Civil Aeronautics Authority,” after “the Interstate Commerce Commission,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/31"},"text":"Pub. L. 97–31","children":[],"tail":" substituted “Department of Transportation” for “United States Maritime Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id798626a7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id798626a8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Pub. L. 98–443","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/443/s9/v"},"text":"section 9(v) of Pub. L. 98–443","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
