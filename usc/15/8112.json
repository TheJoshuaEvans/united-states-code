{"tag":"section","attrib":{"id":"id7a808c88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8112"},"text":null,"children":[{"tag":"num","attrib":{"value":"8112"},"text":"§ 8112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “intellectual property enforcement” means matters relating to the enforcement of laws protecting copyrights, patents, trademarks, other forms of intellectual property, and trade secrets, both in the United States and abroad, including in particular matters relating to combating counterfeit and infringing goods.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a808c89-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/tIII/s302"},"text":"Pub. L. 110–403, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4266"},"text":"122 Stat. 4266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a808c8a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a808c8b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a808c8c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403"},"text":"Pub. L. 110–403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4264"},"text":"122 Stat. 4264","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title III to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
