{"tag":"section","attrib":{"id":"id7a87b834-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514"},"text":null,"children":[{"tag":"num","attrib":{"value":"8514"},"text":"§ 8514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hurricane forecast improvement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b835-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary, in collaboration with the United States weather industry and such academic entities as the Administrator considers appropriate, shall maintain a project to improve hurricane forecasting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b836-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goal of the project maintained under subsection (a) shall be to develop and extend accurate hurricane forecasts and warnings in order to reduce loss of life, injury, and damage to the economy, with a focus on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b837-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the prediction of rapid intensification and track of hurricanes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b838-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the forecast and communication of storm surges from hurricanes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b839-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporating risk communication research to create more effective watch and warning products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b83a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating and incorporating, as appropriate, innovative observations, including acoustic or infrasonic measurements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b83b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2017-04-18"},"text":"April 18, 2017","children":[],"tail":", the Under Secretary, acting through the Assistant Administrator for Oceanic and Atmospheric Research and in consultation with the Director of the National Weather Service, shall develop a plan for the project maintained under subsection (a) that details the specific research, development, and technology transfer activities, as well as corresponding resources and timelines, necessary to achieve the goal set forth in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b83c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tI/s104"},"text":"Pub. L. 115–25, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/94"},"text":"131 Stat. 94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/316/s9"},"text":"Pub. L. 117–316, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4412"},"text":"136 Stat. 4412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a87b83d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a87b83e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a87b83f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316"},"text":"Pub. L. 117–316","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
