{"tag":"section","attrib":{"id":"id79889865-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603"},"text":null,"children":[{"tag":"num","attrib":{"value":"1603"},"text":"§ 1603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempted transactions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This subchapter does not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79889866-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credit transactions involving extensions of credit primarily for business, commercial, or agricultural purposes, or to government or governmental agencies or instrumentalities, or to organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79889867-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transactions in securities or commodities accounts by a broker-dealer registered with the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79889868-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credit transactions, other than those in which a security interest is or will be acquired in real property, or in personal property used or expected to be used as the principal dwelling of the consumer and other than private education loans (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1650/a"},"text":"section 1650(a) of this title","children":[],"tail":"), in which the total amount financed exceeds $50,000."},{"tag":"ref","attrib":{"idref":"fn002329"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002329"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Adjustments for Inflation note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79889869-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transactions under public utility tariffs, if the Bureau determines that a State regulatory body regulates the charges for the public utility services involved, the charges for delayed payment, and any discount allowed for early payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7988986a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transactions for which the Bureau, by rule, determines that coverage under this subchapter is not necessary to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7988986b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s603/c/3"},"text":"Pub. L. 96–221, title VI, § 603(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/169"},"text":"94 Stat. 169","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7988986c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1603/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loans made, insured, or guaranteed pursuant to a program authorized by title IV of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7988986d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s104"},"text":"Pub. L. 90–321, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/147"},"text":"82 Stat. 147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIV/s402"},"text":"Pub. L. 93–495, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1517"},"text":"88 Stat. 1517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s603/c"},"text":"Pub. L. 96–221, title VI, § 603(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/169"},"text":"94 Stat. 169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/320/tVII/s701/a"},"text":"Pub. L. 97–320, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1538"},"text":"96 Stat. 1538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2102/a"},"text":"Pub. L. 104–208, div. A, title II, § 2102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-398"},"text":"110 Stat. 3009–398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tX/s1022"},"text":"Pub. L. 110–315, title X, § 1022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3488"},"text":"122 Stat. 3488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX"},"text":"Pub. L. 111–203, title X","children":[],"tail":", §§ 1100A(2), 1100E(a)(1), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":", 2111.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7988986e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7988986f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79889870-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 1070 et seq.) of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79889871-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100E/a/1"},"text":"Pub. L. 111–203, § 1100E(a)(1)","children":[],"tail":", substituted “$50,000” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100A/2"},"text":"Pub. L. 111–203, § 1100A(2)","children":[],"tail":", substituted “Bureau” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315"},"text":"Pub. L. 110–315","children":[],"tail":" inserted “and other than private education loans (as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1650/a"},"text":"section 1650(a) of this title","children":[],"tail":")” after “consumer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Pars. (5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added par. (5) and redesignated former pars. (5) and (6) as (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320"},"text":"Pub. L. 97–320","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s603/c/1"},"text":"Pub. L. 96–221, § 603(c)(1)","children":[],"tail":", inserted provision relating to applicability to agricultural purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s603/c/2"},"text":"Pub. L. 96–221, § 603(c)(2)","children":[],"tail":", substituted provision excepting security interest in real property, or in personal property used as the consumer’s principal dwelling, for provisions excepting real property transactions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221/s603/c/3"},"text":"Pub. L. 96–221, § 603(c)(3)","children":[],"tail":", struck out par. (5) which related to credit transactions primarily for agricultural purposes where the amount financed exceeds $25,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495"},"text":"Pub. L. 93–495","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79889872-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79889873-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79889874-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/320/s701/c"},"text":"Section 701(c) of Pub. L. 97–320","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/457/s31"},"text":"Pub. L. 97–457, § 31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2511"},"text":"96 Stat. 2511","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/457/s31"},"text":"“The amendment made by subsection (a) [amending this section] and subsection (b) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1099"},"text":"section 1099 of Title 20","children":[],"tail":", Education] shall be effective with respect to loans made prior to, on, and after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79889875-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" effective on expiration of two years and six months after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", with all regulations, forms, and clauses required to be prescribed to be promulgated at least one year prior to such effective date, and allowing any creditor to comply with any amendments, in accordance with the regulations, forms, and clauses prescribed by the Board prior to such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s625"},"text":"section 625 of Pub. L. 96–221","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79889876-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495"},"text":"Pub. L. 93–495","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/s416"},"text":"section 416 of Pub. L. 93–495","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1665a"},"text":"section 1665a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79889877-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exceptions in Areas Where Major Disaster Exists","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Board of Governors of Federal Reserve System authorized to make exceptions to requirements of this subchapter for transactions within an area in which the President has determined that a major disaster exists, if Board determines that exception can reasonably be expected to alleviate hardships to the public that outweigh possible adverse effects, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/18/s50002"},"text":"section 50002 of Pub. L. 105–18","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s4008"},"text":"section 4008 of Title 12","children":[],"tail":", Banks and Banking, and similar provisions listed thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79889878-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adjustments for Inflation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100E/b"},"text":"Pub. L. 111–203, title X, § 1100E(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2111"},"text":"124 Stat. 2111","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tX/s1100E/b"},"text":"“On and after ","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", the Bureau [of Consumer Financial Protection] shall adjust annually the dollar amounts described in sections 104(3) and 181(1) of the Truth in Lending Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1603/3"},"text":"15 U.S.C. 1603(3)","children":[],"tail":", 1667(1)] (as amended by this section), by the annual percentage increase in the Consumer Price Index for Urban Wage Earners and Clerical Workers, as published by the Bureau of Labor Statistics, rounded to the nearest multiple of $100, or $1,000, as applicable.”"}],"tail":"\n Threshold amounts in effect during particular periods of time can be found in Code of Federal Regulations, Title 12, Supplement I to Part 1013, under Section 1013.2—Definitions, under 2(e)—Consumer Lease, paragraph 11."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
