{"tag":"section","attrib":{"id":"id7939db71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s714o"},"text":null,"children":[{"tag":"num","attrib":{"value":"714o"},"text":"§ 714o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution of Delaware corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture, representing the United States as the sole owner of the capital stock of Commodity Credit Corporation, a Delaware corporation, is authorized and directed to institute or cause to be instituted such proceedings as are required for the dissolution of said Corporation under the laws of the State of Delaware. The costs of such dissolution of said Corporation shall be borne by the Corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7939db72-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704/s17"},"text":"June 29, 1948, ch. 704, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1075"},"text":"62 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7939db73-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7939db74-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7939db75-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exceptions From Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For exception of functions of corporations of Department of Agriculture from transfer of functions to Secretary of Agriculture by Reorg. Plan No. 2 of 1953, see Exceptions From Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s712a"},"text":"section 712a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
