{"tag":"section","attrib":{"id":"id7932af1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f"},"text":null,"children":[{"tag":"num","attrib":{"value":"697f"},"text":"§ 697f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment of development company debentures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7932af20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the requirements set forth in subsection (b), an issuer of a debenture purchased by the Federal Financing Bank and guaranteed by the Administration under this chapter may, at the election of the borrower (in the case of a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":") or the issuer (in the case of a small business investment company) and with the approval of the Administration, prepay such debenture in accordance with the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a prepayment under paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower (in the case of a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":") or the issuer (in the case of a small business investment company) shall pay to the Federal Financing Bank an amount that is equal to the sum of the unpaid principal balance due on the debenture as of the date of the prepayment (plus accrued interest at the coupon rate on the debenture) and the amount of the repurchase premium described in subparagraph (B); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administration shall pay to the Federal Financing Bank the difference between the repurchase premium paid by the borrower under this subsection and the repurchase premium that the Federal Financing Bank would otherwise have received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repurchase premium","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)(i), the repurchase premium is the amount equal to the product of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7932af28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unpaid principal balance due on the debenture on the date of prepayment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable percentage rate, as determined in accordance with clauses (ii) and (iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable percentage rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of clause (i)(II), the applicable percentage rate means—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7932af2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a 10-year term loan, 8.5 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a 15-year term loan, 9.5 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a 20-year term loan, 10.5 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a 25-year term loan, 11.5 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments to applicable percentage rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The percentage rates described in clause (ii) shall be increased or decreased by the Administration by a factor not to exceed one-third, if the same factor is applied in each case and if the Administration determines that an adjustment is necessary, based on the number of borrowers having given notice of their intent to participate, in order to make the program (including the amounts appropriated for this purpose under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317"},"text":"Public Law 103–317","children":[],"tail":") result in no substantial net gain or loss of revenue to the Federal Financing Bank or to the Administration. Amounts collected in excess of the amount necessary to ensure revenue neutrality shall be refunded to the borrowers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the requirements of this subsection are that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debenture is outstanding and neither the loan that secures the debenture, if any, nor the debenture is in default on the date on which the prepayment is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, or personal funds, or the proceeds of a refinancing in accordance with subsection (d) under the programs authorized by this subchapter, are used to prepay or roll over the debenture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a debenture issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":", the issuer certifies that the benefits, net of fees and expenses authorized herein, associated with prepayment of the debenture are entirely passed through to the borrower."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prepayment fees or penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No fees or penalties other than those specified in this section may be imposed on the issuer, the borrower, the Administration, or any fund or account administered by the Administration as the result of a prepayment under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refinancing limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The refinancing of a debenture under sections 697a and 697b of this title, in accordance with subsection (b)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed the amount necessary to prepay existing debentures, including all costs associated with the refinancing and any applicable prepayment penalty or repurchase premium; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraphs (2) and (3), shall be subject to the provisions of sections 697a and 697b of this title and the rules and regulations promulgated thereunder, including rules and regulations governing payment of authorized expenses, commissions, fees, and discounts to brokers and dealers in trust certificates issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697b"},"text":"section 697b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Job creation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant for refinancing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697a"},"text":"section 697a of this title","children":[],"tail":" of a loan made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":" shall not be required to demonstrate that a requisite number of jobs will be created with the proceeds of a refinancing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan processing fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To cover the cost of loan packaging, processing, and other administrative functions, a development company that provides refinancing under subsection (b)(2) may impose a one-time loan processing fee, not to exceed 0.5 percent of the principal amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New debentures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Issuers of debentures under subchapter III may issue new debentures in accordance with such subchapter in order to prepay existing debentures as authorized in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration shall use certified mail and other reasonable means to notify each eligible borrower of the prepayment program provided in this subchapter. Each preliminary notice shall specify the range and dollar amount of repurchase premiums which could be required of that borrower in order to participate in the program. In carrying out this program, the Administration shall provide a period of not less than 45 days following the receipt of such notice by the borrower during which the borrower must notify the Administration of the borrower’s intent to participate in the program. The Administration shall require that a borrower who gives notice of its intent to participate to make an earnest money deposit of $1,000 which shall not be refundable but which shall be credited toward the final repurchase premium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Borrower” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “borrower”, in the case of a small business investment company or a specialized small business investment company, means “issuer”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based upon the response to the preliminary notice under paragraph (5), the Administration shall make a final computation of the necessary prepayment premiums and shall notify each qualified respondent of the results of such computation. Each qualified respondent shall be afforded not less than 4 months to complete the prepayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “issuer” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualified State or local development company that issued a debenture pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":", which has been purchased by the Federal Financing Bank; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business investment company licensed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s681"},"text":"section 681 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “borrower” means a small business concern whose loan secures a debenture issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"1994-10-22"},"text":"October 22, 1994","children":[],"tail":", the Administration shall promulgate such regulations as may be necessary to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $30,000,000 to carry out the provisions of The Small Business Prepayment Penalty Relief Act of 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7932af47-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tV/s509"},"text":"Pub. L. 85–699, title V, § 509","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tV/s503"},"text":"Pub. L. 103–403, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4199"},"text":"108 Stat. 4199","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dD/tII/s208/h/1/H"},"text":"Pub. L. 104–208, div. D, title II, § 208(h)(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-747"},"text":"110 Stat. 3009–747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7932af48-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7932af49-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7932af4a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (a)(1), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317"},"text":"Public Law 103–317","children":[],"tail":", referred to in subsec. (a)(2)(B)(iii), is "},{"tag":"ref","attrib":{"href":"/us/pl/103/317"},"text":"Pub. L. 103–317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1724"},"text":"108 Stat. 1724","children":[],"tail":", known as the Departments of Commerce, Justice, and State, The Judiciary, and Related Agencies Appropriations Act, 1995. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Small Business Prepayment Penalty Relief Act of 1994, referred to in subsec. (g), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/403"},"text":"Pub. L. 103–403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4198"},"text":"108 Stat. 4198","children":[],"tail":", which enacted this section and provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7932af4b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s208/h/1/H/i"},"text":"Pub. L. 104–208, § 208(h)(1)(H)(i)","children":[],"tail":", struck out at end “A small business investment company operating under the authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s681/d"},"text":"section 681(d) of this title","children":[],"tail":" that has issued a debenture that was purchased by and is held by the Administration, may, under the same terms and conditions, prepay such debenture, and the penalty as provided in this section, and shall thereafter be immediately eligible to apply for additional assistance from the Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s208/h/1/H/ii"},"text":"Pub. L. 104–208, § 208(h)(1)(H)(ii)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s681"},"text":"section 681 of this title","children":[],"tail":"” for “subsection (c) or (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s681"},"text":"section 681 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7932af4c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7932af4d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Intention of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/403/tV/s502"},"text":"Pub. L. 103–403, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4198"},"text":"108 Stat. 4198","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/403/tV/s502"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Small Business Administration shall fully utilize the $30,000,000 appropriated in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317"},"text":"Public Law 103–317","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/stat/108/1724"},"text":"108 Stat. 1724","children":[],"tail":"] to reduce, in accordance with this title [enacting this section and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"] and the amendments made by this title, prepayment penalties imposed in connection with debentures issued under—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 303 or 503 of the Small Business Investment Act of 1958 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s683"},"text":"15 U.S.C. 683","children":[],"tail":", 697], which have been purchased by the Federal Financing Bank; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title III [probably means title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699"},"text":"Pub. L. 85–699","children":[],"tail":", which is classified to section 681 et seq. of this title] to companies operating under section 301(d) of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s681/d"},"text":"15 U.S.C. 681(d)","children":[],"tail":"], which have been purchased by the Small Business Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Equal Opportunity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to provide an equal opportunity to participate in the program authorized under this title, the Small Business Administration shall afford each borrower or issuer of a debenture subject to this title, not less than 45 days to elect to participate and to provide an earnest money deposit. The Administration shall subsequently allow a period of not less than 4 months, during which those borrowers or issuers that elect to participate shall be allowed to complete the prepayment process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions on Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In no event shall the Small Business Administration—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow any borrower or issuer to participate in the program if the borrower or issuer fails to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a timely election and provide the deposit on a timely basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the prepayment process within the required time; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow any borrower or issuer to participate in the program at a percentage rate other than the rate finally determined to be applicable to all other borrowers or issuers with similar terms of years.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
