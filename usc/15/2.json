{"tag":"section","attrib":{"id":"id77ae0b5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monopolizing trade a felony; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every person who shall monopolize, or attempt to monopolize, or combine or conspire with any other person or persons, to monopolize any part of the trade or commerce among the several States, or with foreign nations, shall be deemed guilty of a felony, and, on conviction thereof, shall be punished by fine not exceeding $100,000,000 if a corporation, or, if any other person, $1,000,000, or by imprisonment not exceeding 10 years, or by both said punishments, in the discretion of the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ae0b5b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-02/ch647/s2"},"text":"July 2, 1890, ch. 647, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/209"},"text":"26 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-07-07/ch281"},"text":"July 7, 1955, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/282"},"text":"69 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/528/s3"},"text":"Pub. L. 93–528, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-21"},"text":"Dec. 21, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1708"},"text":"88 Stat. 1708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/588/s4/b"},"text":"Pub. L. 101–588, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2880"},"text":"104 Stat. 2880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/237/tII/s215/b"},"text":"Pub. L. 108–237, title II, § 215(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-06-22"},"text":"June 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/668"},"text":"118 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ae0b5c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ae0b5d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77ae0b5e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/237"},"text":"Pub. L. 108–237","children":[],"tail":" substituted “$100,000,000” for “$10,000,000”, “$1,000,000” for “$350,000”, and “10” for “three”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/588"},"text":"Pub. L. 101–588","children":[],"tail":" substituted “$10,000,000” for “one million dollars” and “$350,000” for “one hundred thousand dollars”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/528"},"text":"Pub. L. 93–528","children":[],"tail":" substituted “a felony, and, on conviction thereof, shall be punished by fine not exceeding one million dollars if a corporation, or, if any other person, one hundred thousand dollars, or by imprisonment not exceeding three years” for “a misdemeanor, and, on conviction thereof, shall be punished by fine not exceeding fifty thousand dollars, or by imprisonment not exceeding one year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-07-07"},"text":"July 7, 1955","children":[],"tail":", substituted “fifty thousand dollars” for “five thousand dollars”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
