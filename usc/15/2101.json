{"tag":"section","attrib":{"id":"id79de5939-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2101"},"text":null,"children":[{"tag":"num","attrib":{"value":"2101"},"text":"§ 2101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marking requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79de593a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacture in the United States, or the importation into the United States, for introduction into or distribution in commerce of any imitation political item which is not plainly and permanently marked with the calendar year in which such item was manufactured, is unlawful and is an unfair or deceptive act or practice in commerce under the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de593b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coins and other numismatic items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The manufacture in the United States, or the importation into the United States, for introduction into or distribution in commerce, or the sale in commerce of any imitation numismatic item which is not plainly and permanently marked “copy”, is unlawful and is an unfair or deceptive act or practice in commerce under the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de593c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission shall prescribe rules for determining the manner and form in which items described in subsection (a) or (b) shall be permanently marked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de593d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance or support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be a violation of subsection (a) or (b) for a person to provide substantial assistance or support to any manufacturer, importer, or seller if that person knows or should have known that the manufacturer, importer, or seller is engaged in any act or practice that violates subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de593e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) ","children":[{"tag":"ref","attrib":{"idref":"fn002441"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002441"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" (b), and (d), and regulations under subsection (c), shall not apply to any common carrier or contract carrier or freight forwarder with respect to an imitation political item or imitation numismatic item received, shipped, delivered, or handled by it for shipment in the ordinary course of its business."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79de593f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/167/s2"},"text":"Pub. L. 93–167, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-29"},"text":"Nov. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/686"},"text":"87 Stat. 686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/288/s2/1"},"text":"Pub. L. 113–288, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3281"},"text":"128 Stat. 3281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79de5940-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79de5941-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79de5942-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79de5943-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/288/s2/1/A"},"text":"Pub. L. 113–288, § 2(1)(A)","children":[],"tail":", inserted “, or the sale in commerce” after “distribution in commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/288/s2/1/B"},"text":"Pub. L. 113–288, § 2(1)(B)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/288/s2/1/B"},"text":"Pub. L. 113–288, § 2(1)(B)","children":[],"tail":", (C), redesignated subsec. (d) as (e) and substituted “(b), and (d)” for “and (b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79de5944-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79de5945-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/167/s8"},"text":"Pub. L. 93–167, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-29"},"text":"Nov. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/687"},"text":"87 Stat. 687","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/167/s8"},"text":"“This Act [enacting this chapter] shall apply only to imitation political items and imitation numismatic items manufactured after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1973-11-29"},"text":"Nov. 29, 1973","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79de5946-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/288/s1"},"text":"Pub. L. 113–288, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3281"},"text":"128 Stat. 3281","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/288/s1"},"text":"“This Act [amending this section and sections 2102 and 2106 of this title] may be cited as the ‘Collectible Coin Protection Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79de5947-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/167/s1"},"text":"Pub. L. 93–167, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-29"},"text":"Nov. 29, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/686"},"text":"87 Stat. 686","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/167/s1"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Hobby Protection Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
