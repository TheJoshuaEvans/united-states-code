{"tag":"section","attrib":{"id":"id7a06ef73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663"},"text":null,"children":[{"tag":"num","attrib":{"value":"2663"},"text":"§ 2663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EPA citizen’s guide","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a06ef74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to make continuous progress toward the long-term goal established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2661"},"text":"section 2661 of this title","children":[],"tail":", the Administrator of the Environmental Protection Agency shall, not later than "},{"tag":"date","attrib":{"date":"1989-06-01"},"text":"June 1, 1989","children":[],"tail":", publish and make available to the public an updated version of its document titled “A Citizen’s Guide to Radon”. The Administrator shall revise and republish the guide as necessary thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a06ef75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information included","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a06ef76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action levels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The updated citizen’s guide published as provided in subsection (a) shall include a description of a series of action levels indicating the health risk associated with different levels of radon exposure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a06ef77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The updated citizen’s guide shall also include information with respect to each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a06ef78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The increased health risk associated with the exposure of potentially sensitive populations to different levels of radon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06ef79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The increased health risk associated with the exposure to radon of persons engaged in potentially risk-increasing behavior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06ef7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost and technological feasibility of reducing radon concentrations within existing and new buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06ef7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The relationship between short-term and long-term testing techniques and the relationship between (i) measurements based on both such techniques, and (ii) the actions ","children":[{"tag":"ref","attrib":{"idref":"fn002470"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002470"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “action”."}],"tail":" levels set forth as provided in paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a06ef7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2663/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Outdoor radon levels around the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a06ef7d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tIII/s303"},"text":"Pub. L. 94–469, title III, § 303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/551/s1/a"},"text":"Pub. L. 100–551, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2755"},"text":"102 Stat. 2755","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
