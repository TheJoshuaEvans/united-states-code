{"tag":"section","attrib":{"id":"id7ab299c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702"},"text":null,"children":[{"tag":"num","attrib":{"value":"9702"},"text":"§ 9702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Integrated Flood Information System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab299c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a system, to be known as the “National Integrated Flood Information System”, to better inform and provide for more timely decision making to reduce flood-related effects and costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, through the National Integrated Flood Information System, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide an effective flood early warning system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab299cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collects and integrates information on the key indicators of floods and flood impacts, including streamflow, reservoir release and diversion, precipitation, soil moisture, snow water equivalent, land cover, and evaporative demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes usable, reliable, and timely forecasts of floods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the severity of flood conditions and effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides information described in subparagraph (A), forecasts described in subparagraph (B), and assessments described in subparagraph (C) at the national, regional, and local levels, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" communicates flood forecasts, flood conditions, and flood impacts to appropriate entities engaged in flood planning, preparedness, and response and post-event flood extent, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab299d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decision makers at the Federal, State, local, and Tribal levels of government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab299d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide timely data, information, and products that reflect differences in flood conditions among localities, regions, watersheds, and States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and integrate, through interagency agreements as practicable, Federal research and monitoring in support of the flood early warning information system provided under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use existing forecasting and assessment programs and partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make improvements in seasonal precipitation and temperature, subseasonal precipitation and temperature, and flood water prediction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" continue ongoing research and monitoring activities relating to floods, including research activities relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab299d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prediction, length, severity, and impacts of floods and improvement of the accuracy, timing, and specificity of flash flood warnings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of extreme weather events and climate variability in floods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how water travels over and through surfaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, through the National Integrated Flood Information System, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with the private sector to improve flood monitoring, forecasts, land and topography data, and communication, if the Administrator determines that such engagement is appropriate, cost effective, and beneficial to the public and decision makers described in subsection (b)(1)(E)(i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the development of 1 or more academic cooperative partnerships to assist in carrying out the functions of the National Integrated Flood Information System described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use and support monitoring by citizen scientists, including by developing best practices to facilitate maximum data integration, as the Administrator considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with, and leverage the resources of, entities within the National Oceanic and Atmospheric Administration in existence as of ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", such as the National Weather Service with respect to forecast and warning functions, the National Integrated Drought Information System, the Regional Climate Center, and the National Mesonet Program, to improve coordination of water monitoring, forecasting, and management; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engage with and support water monitoring by the United States Geological Survey—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab299e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the availability and continuity of streamflow data at critical locations through the deployment of rapid deployment gages and the flood-hardening of at-risk streamflow gauges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase storm surge monitoring data through the deployment of additional storm surge sensors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and maintaining the National Integrated Flood Information System, the Administrator shall consult with relevant Federal, State, local, and Tribal government agencies, research institutions, and the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation from other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency shall cooperate as appropriate with the Administrator in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab299e5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s3"},"text":"Pub. L. 117–316, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4406"},"text":"136 Stat. 4406","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
