{"tag":"section","attrib":{"id":"id7a4299b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4723a"},"text":"§ 4723a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Commercial Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4299b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, in his or her role as chairperson of the Trade Promotion Coordinating Committee, is authorized and encouraged to establish United States Commercial Centers (hereinafter in this section referred to as “Centers”) in Asia, in Latin America, and in Africa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Centers shall be to provide additional resources for the promotion of exports of United States goods and services to the host countries, by familiarizing United States exporters with the industries, markets, and customs of the host countries, thus facilitating commercial ties and trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and publish economic and market data with respect to the host country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, on a user-fee basis, preliminary technical and clerical assistance, language translation, and administrative assistance, and information regarding the legal systems, laws, regulations, and procedures of the host country, to United States exporters seeking to do business in the host country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in other ways promote exports of United States goods and services to the host country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific services to be provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out its objectives, each Center shall make available the following (on a user-fee basis):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Business facilities, including exhibition space, conference rooms, office space (including telephones and other basic office equipment), and, where warranted by impeding deficiencies in the public system, high quality international telecommunications facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Business support services, including language translation services, clerical services, and a commercial library containing a comprehensive collection of reference materials covering United States and host country industries and markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial law information services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Commercial law information services, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4299c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a clearinghouse for information regarding the relevant commercial laws, practices, and regulations of the host country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4299c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publications to assist United States businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4299c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal referral services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4299c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists of local agents and distributors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other trade promotion activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Center shall also promote United States export trade by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating contacts between buyers, sellers, bankers, traders, distributors, agents, and necessary government officials from the United States and the host country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating trade missions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting with applications, contracts, and clearances for imports into the host country and exports from the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staffing of Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Center shall be staffed by members of the United States and Foreign Commercial Service, participants in the Market Development Cooperator Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4723"},"text":"section 4723 of this title","children":[],"tail":", other employees of the Department of Commerce, and employees of appropriate executive branch departments and agencies which are members of the Trade Promotion Coordinating Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center facilities and their relationship to United States Department of Commerce operations in host countries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physical accommodations for the Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall locate each Center in the primary commercial city of the host country. The Secretary shall acquire office space, exhibition space, and other facilities and equipment that are necessary for each Center to perform its functions. To the extent feasible, each Center shall be located in the central commercial district of the host city.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of Department of Commerce operations in host countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of obtaining maximum effectiveness and efficiency and to the extent consistent with the purposes of the Centers, the Secretary of Commerce is encouraged to place all personnel of the Department of Commerce who are assigned to the city in which a Center is located in the same facilities as those in which the Center conducts its activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Market Development Cooperator Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall, to the greatest extent feasible, use the Market Development Cooperator Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4723"},"text":"section 4723 of this title","children":[],"tail":" to assist in carrying out the purposes of the Centers established under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Commerce to carry out this section $8,000,000 for fiscal year 1993, and $5,500,000 for fiscal year 1994. Funds made available under this subsection may be used for the acquisition of real property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1021/b"},"text":"Pub. L. 104–66, title I, § 1021(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/712"},"text":"109 Stat. 712","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “United States exporter” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4299d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4299d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, partnership, or other association created under the laws of the United States or of any State, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4299d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/k/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign corporation, partnership, or other association, more than 95 percent of which is owned by persons described in subparagraphs (A) and (B),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that exports, or seeks to export, goods or services produced in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any of the several States, the District of Columbia, or any commonwealth, territory, or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4723a/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States” means the several States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4299d9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549/tIV/s401"},"text":"Pub. L. 102–549, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3661"},"text":"106 Stat. 3661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1021/b"},"text":"Pub. L. 104–66, title I, § 1021(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/712"},"text":"109 Stat. 712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4299da-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4299db-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a4299dc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Jobs Through Exports Act of 1992, and not as part of the Export Enhancement Act of 1988 which enacted this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a4299dd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out heading and text of subsec. (j). Text read as follows: “The Secretary of Commerce shall submit to the Committee on Foreign Affairs of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate, not later than 1 year after "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", and not later than the end of each 1-year period occurring thereafter, a report on the status, activities, and effectiveness of the Centers. Each such report shall include any recommendations with respect to the program established under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
