{"tag":"section","attrib":{"id":"id7a912e68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853"},"text":null,"children":[{"tag":"num","attrib":{"value":"8853"},"text":"§ 8853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy quantum network infrastructure research and development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912e69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy (referred to in this section as the “Secretary”) shall carry out a research, development, and demonstration program to accelerate innovation in quantum network infrastructure in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the advancement of distributed quantum computing systems through the internet and intranet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the precision of measurements of scientific phenomena and physical imaging technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop secure national quantum communications technologies and strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate quantum networking utilizing the Department of Energy’s Energy Sciences Network User Facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the relevant domestic supply chains, manufacturing capabilities, and associated simulations or modeling capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chair of the Subcommittee on Quantum Information Science of the National Science and Technology Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8813/a"},"text":"section 8813(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chair of the Subcommittee on the Economic and Security Implications of Quantum Science;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct cooperative research with industry, National Laboratories, institutions of higher education, and other research institutions to facilitate new quantum infrastructure methods and technologies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum-limited detectors, ultra-low loss optical channels, space-to-ground connections, and classical networking and cybersecurity protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entanglement and hyper-entangled state sources and transmission, control, and measurement of quantum states;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum interconnects that allow short range local connections between quantum processors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transducers for quantum sources and signals between optical wavelength regimes, including telecommunications regimes and quantum computer-relevant domains, including microwaves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of quantum memory buffers and small-scale quantum computers that are compatible with photon-based quantum bits in the optical or telecommunications wavelengths;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-range entanglement distribution, including allowing entanglement-based protocols between small- and large ","children":[{"tag":"ref","attrib":{"idref":"fn002611"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002611"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a hyphen."}],"tail":" scale quantum processors, at the terrestrial and space-based level using quantum repeaters and optical or laser communications;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum routers, multiplexers, repeaters, and related technologies necessary to create secure long-distance quantum communication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of systems across the quantum technology stack into traditional computing networks, including the development of remote controlled, high-performance, and reliable implementations of key quantum network components by leveraging the expertise, infrastructure and supplemental investments at the National Laboratories in the Energy Sciences Network User Facility;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with the Quantum Economic Development Consortium and other organizations, as applicable, to transition component technologies to help facilitate as appropriate the development of a quantum supply chain for quantum network technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance basic research in advanced scientific computing, particle and nuclear physics, and material science to enhance the understanding, prediction, and manipulation of materials, processes, and physical phenomena relevant to quantum network infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop experimental tools and testbeds in collaboration with the Energy Sciences Network User Facility necessary to support cross-cutting fundamental research and development activities with diverse stakeholders from industry, National Laboratories, and institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider quantum network infrastructure applications that span the Department of Energy’s missions in energy, environment, and national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall leverage resources, infrastructure, and expertise across the Department of Energy and from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Quantum Information Science Research Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate a 4-year research plan that identifies and prioritizes basic research needs relating to quantum network infrastructure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review activities carried out under this section to determine the achievement of technical milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8853/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds authorized to be appropriated for the Department of Energy’s Office of Science, there is authorized to be appropriated to the Secretary to carry out the activities under this section $100,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912e8e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tIV/s403"},"text":"Pub. L. 115–368, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10104/b/2/A"},"text":"Pub. L. 117–167, div. B, title I, § 10104(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1438"},"text":"136 Stat. 1438","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
