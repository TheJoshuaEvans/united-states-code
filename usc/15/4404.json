{"tag":"section","attrib":{"id":"id7a38fcbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404"},"text":null,"children":[{"tag":"num","attrib":{"value":"4404"},"text":"§ 4404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement, regulations, and construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38fcc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fcc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4402"},"text":"section 4402 of this title","children":[],"tail":" or the regulations promulgated pursuant to this chapter shall be considered a violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fcc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who is found to violate any provision of section 4402 or 4403(a) of this title shall be guilty of a misdemeanor and shall on conviction thereof be subject to a fine of not more than $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4402"},"text":"section 4402 of this title","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fcc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations issued by the Federal Trade Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4402"},"text":"section 4402 of this title","children":[],"tail":" shall be issued in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fcc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1986-02-27"},"text":"February 27, 1986","children":[],"tail":", the Federal Trade Commission shall promulgate such regulations as it may require to implement "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4402"},"text":"section 4402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter (other than the requirements of sections 4402 and 4403 of this title) shall be construed to limit, restrict, or expand the authority of the Federal Trade Commission with respect to unfair or deceptive acts or practices in the advertising of smokeless tobacco products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38fcc7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/252/s5"},"text":"Pub. L. 99–252, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/33"},"text":"100 Stat. 33","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a38fcc8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a38fcc9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a38fcca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsecs. (a) and (c) effective one year after ","children":[{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/252/s11/a"},"text":"section 11(a) of Pub. L. 99–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4401"},"text":"section 4401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
