{"tag":"section","attrib":{"id":"id7a57f5d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307h"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307h"},"text":"§ 6307h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judges and referees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person may arrange, promote, organize, produce, or fight in a professional boxing match unless all referees and judges participating in the match have been certified and approved by the boxing commission responsible for regulating the match in the State where the match is held.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a57f5da-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s16"},"text":"Pub. L. 104–272, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/2"},"text":"Pub. L. 106–210, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/325"},"text":"114 Stat. 325","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
