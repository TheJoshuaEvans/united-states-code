{"tag":"section","attrib":{"id":"id79b83358-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1691f"},"text":"§ 1691f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress; contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each year, the Bureau and the Attorney General shall, respectively, make reports to the Congress concerning the administration of their functions under this subchapter, including such recommendations as the Bureau and the Attorney General, respectively, deem necessary or appropriate. In addition, each report of the Bureau shall include its assessment of the extent to which compliance with the requirements of this subchapter is being achieved, and a summary of the enforcement actions taken by each of the agencies assigned administrative enforcement responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1691c"},"text":"section 1691c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79b83359-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVII/s707"},"text":"Pub. L. 90–321, title VII, § 707","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/239/s7"},"text":"Pub. L. 94–239, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-23"},"text":"Mar. 23, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/255"},"text":"90 Stat. 255","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s610/c"},"text":"Pub. L. 96–221, title VI, § 610(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/174"},"text":"94 Stat. 174","children":[],"tail":";