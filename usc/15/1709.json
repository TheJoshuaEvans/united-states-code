{"tag":"section","attrib":{"id":"id79c1d057-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1709"},"text":null,"children":[{"tag":"num","attrib":{"value":"1709"},"text":"§ 1709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c1d058-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; relief recoverable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A purchaser or lessee may bring an action at law or in equity against a developer or agent if the sale or lease was made in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1703/a"},"text":"section 1703(a) of this title","children":[],"tail":". In a suit authorized by this subsection, the court may order damages, specific performance, or such other relief as the court deems fair, just, and equitable. In determining such relief the court may take into account, but not be limited to, the following factors: the contract price of the lot or leasehold; the amount the purchaser or lessee actually paid; the cost of any improvements to the lot; the fair market value of the lot or leasehold at the time relief is determined; and the fair market value of the lot or leasehold at the time such lot was purchased or leased."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c1d059-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of rights by purchaser or lessee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A purchaser or lessee may bring an action at law or in equity against the seller or lessor (or successor thereof) to enforce any right under subsection (b), (c), (d), or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1703"},"text":"section 1703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c1d05a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts recoverable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount recoverable in a suit authorized by this section may include, in addition to matters specified in subsections (a) and (b), interest, court costs, and reasonable amounts for attorneys’ fees, independent appraisers’ fees, and travel to and from the lot.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c1d05b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every person who becomes liable to make any payment under this section may recover contribution as in cases of contract from any person who, if sued separately, would have been liable to make the same payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c1d05c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIV/s1410"},"text":"Pub. L. 90–448, title XIV, § 1410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/595"},"text":"82 Stat. 595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/153/tIV/s405"},"text":"Pub. L. 96–153, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1130"},"text":"93 Stat. 1130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c1d05d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c1d05e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c1d05f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" substituted provisions relating to violations of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1703/a"},"text":"section 1703(a) of this title","children":[],"tail":" and scope of relief authorized in suits brought against such violations, for provisions relating to suits for untrue statements or omissions to state material fact in statement of record."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" substituted provisions relating to enforcement of rights by the purchaser or lessee against the seller or lessor, for provisions relating to suits by the purchaser against the developer or agent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" substituted provisions authorizing interest, court costs, etc., to be recoverable in suits under this section, for provisions relating to enumeration of damages recoverable in suits under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" reenacted provisions without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" struck out subsec. (e) which set forth limitation on amount recoverable under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c1d060-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79c1d061-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" effective on effective date of regulations implementing such amendment, but in no case later than six months following "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/153/s410"},"text":"section 410 of Pub. L. 96–153","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79c1d062-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of two hundred and seventy days after ","children":[{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/448/s1423"},"text":"section 1423 of Pub. L. 90–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1701"},"text":"section 1701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
