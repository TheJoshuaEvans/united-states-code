{"tag":"section","attrib":{"id":"id7a1ebcb5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3602"},"text":null,"children":[{"tag":"num","attrib":{"value":"3602"},"text":"§ 3602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion lending","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that lending by federally insured lending institutions for the conversion of rental housing to condominiums and cooperative housing should be discouraged where there are adverse impacts on housing opportunities of the low- and moderate-income and elderly and handicapped tenants involved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a1ebcb6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s603"},"text":"Pub. L. 96–399, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1673"},"text":"94 Stat. 1673","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
