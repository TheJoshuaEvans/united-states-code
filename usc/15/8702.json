{"tag":"section","attrib":{"id":"id7a8c732d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702"},"text":null,"children":[{"tag":"num","attrib":{"value":"8702"},"text":"§ 8702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c732e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Block machine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “block machine” means a piece of equipment that utilizes vibration and compaction to form concrete masonry products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c732f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Concrete Masonry Products Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8704"},"text":"section 8704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7330-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cavity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cavity” means the open space in the mold of a block machine capable of forming a single concrete masonry unit having nominal plan dimensions of 8 inches by 16 inches.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7331-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concrete masonry products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “concrete masonry products” refers to a broader class of products, including concrete masonry units as well as hardscape products such as concrete pavers and segmental retaining wall units, manufactured on a block machine using dry-cast concrete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7332-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concrete masonry unit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “concrete masonry unit”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8c7333-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a concrete masonry product that is a manmade masonry unit having an actual width of 3 inches or greater and manufactured from dry-cast concrete using a block machine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c7334-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes concrete block and related concrete units used in masonry applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7335-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conflict of interest” means, with respect to a member or employee of the Board, a situation in which such member or employee has a direct or indirect financial or other interest in a person that performs a service for, or enters into a contract with, for anything of economic value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7336-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7337-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dry-cast concrete","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dry-cast concrete” means a composite material that is composed essentially of aggregates embedded in a binding medium composed of a mixture of cementitious materials (including hydraulic cement, pozzolans, or other cementitious materials) and water of such a consistency to maintain its shape after forming in a block machine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7338-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “education” means programs that will educate or communicate the benefits of concrete masonry products in safe and environmentally sustainable development, advancements in concrete masonry product technology and development, and other information and programs designed to generate increased demand for commercial, residential, multifamily, and institutional projects using concrete masonry products and to generally enhance the image of concrete masonry products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7339-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Machine cavities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “machine cavities” means the cavities with which a block machine could be equipped.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c733a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Machine cavities in operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “machine cavities in operation” means those machine cavities associated with a block machine that have produced concrete masonry units within the last 6 months of the date set for determining eligibility and is fully operable and capable of producing concrete masonry units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c733b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “manufacturer” means any person engaged in the manufacturing of commercial concrete masonry products in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c733c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Masonry unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “masonry unit” means a noncombustible building product intended to be laid by hand or joined using mortar, grout, surface bonding, post-tensioning or some combination of these methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c733d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8703"},"text":"section 8703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c733e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c733f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action, including paid advertising, to advance the image and desirability of concrete masonry products with the express intent of improving the competitive position and stimulating sales of concrete masonry products in the marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7340-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means studies testing the effectiveness of market development and promotion efforts, studies relating to the improvement of concrete masonry products and new product development, and studies documenting the performance of concrete masonry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7341-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7342-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8702/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the several States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8c7343-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1303"},"text":"Pub. L. 115–254, div. E, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3469"},"text":"132 Stat. 3469","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
