{"tag":"section","attrib":{"id":"id797584ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1292"},"text":null,"children":[{"tag":"num","attrib":{"value":"1292"},"text":"§ 1292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area telecasting restriction limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1291"},"text":"Section 1291 of this title","children":[],"tail":" shall not apply to any joint agreement described in the first sentence in such section which prohibits any person to whom such rights are sold or transferred from televising any games within any area, except within the home territory of a member club of the league on a day when such club is playing a game at home."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797584ed-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/331/s2"},"text":"Pub. L. 87–331, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-30"},"text":"Sept. 30, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/732"},"text":"75 Stat. 732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/800/s6/b/2"},"text":"Pub. L. 89–800, § 6(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-08"},"text":"Nov. 8, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1515"},"text":"80 Stat. 1515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797584ee-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797584ef-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],