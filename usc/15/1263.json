{"tag":"section","attrib":{"id":"id7970c985-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263"},"text":null,"children":[{"tag":"num","attrib":{"value":"1263"},"text":"§ 1263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following acts and the causing thereof are prohibited:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7970c986-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The introduction or delivery for introduction into interstate commerce of any misbranded hazardous substance or banned hazardous substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c987-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The alteration, mutilation, destruction, obliteration, or removal of the whole or any part of the label of, or the doing of any other act with respect to, a hazardous substance, if such act is done while the substance is in interstate commerce, or while the substance is held for sale (whether or not the first sale) after shipment in interstate commerce, and results in the hazardous substance being a misbranded hazardous substance or banned hazardous substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c988-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The receipt in interstate commerce of any misbranded hazardous substance or banned hazardous substance and the delivery or proffered delivery thereof for pay or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c989-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The giving of a guarantee or undertaking referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1264/b/2"},"text":"section 1264(b)(2) of this title","children":[],"tail":" which guarantee or undertaking is false, except by a person who relied upon a guarantee or undertaking to the same effect signed by, and containing the name and address of, the person residing in the United States from whom he received in good faith the hazardous substance."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c98a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure to permit entry or inspection as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1270/b"},"text":"section 1270(b) of this title","children":[],"tail":" or to permit access to and copying of any record as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1271"},"text":"section 1271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c98b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The introduction or delivery for introduction into interstate commerce, or the receipt in interstate commerce and subsequent delivery or proffered delivery for pay or otherwise, of a hazardous substance in a reused food, drug, or cosmetic container or in a container which, though not a reused container, is identifiable as a food, drug, or cosmetic container by its labeling or by other identification. The reuse of a food, drug, or cosmetic container as a container for a hazardous substance shall be deemed to be an act which results in the hazardous substance being a misbranded hazardous substance. As used in this paragraph, the terms “food”, “drug”, and “cosmetic” shall have the same meanings as in the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c98c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manufacture of a misbranded hazardous substance or banned hazardous substance within the District of Columbia or within any territory not organized with a legislative body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c98d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use by any person to his own advantage, or revealing other than to the Commission or officers or employees of the Commission, or to the courts when relevant in any judicial proceeding under this chapter, of any information acquired under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1270"},"text":"section 1270 of this title","children":[],"tail":" concerning any method of process which as a trade secret is entitled to protection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c98e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure to notify the Commission with respect to exports, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1273/d"},"text":"section 1273(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c98f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure to comply with an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1274"},"text":"section 1274 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c990-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1263/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The introduction or delivery for introduction into interstate commerce of any lead solder which has a lead content in excess of 0.2 percent which does not prominently display a warning label stating the lead content of the solder and warning that the use of such solder in the making of joints or fittings in any private or public potable water supply system is prohibited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7970c991-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s4"},"text":"Pub. L. 86–613, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/375"},"text":"74 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/756"},"text":"Pub. L. 89–756","children":[],"tail":", §§ 2(f), 3(b), "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1304"},"text":"80 Stat. 1304","children":[],"tail":", 1305; "},{"tag":"ref","attrib":{"href":"/us/pl/95/631/s7/a"},"text":"Pub. L. 95–631, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3745"},"text":"92 Stat. 3745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXII/s1211/f/2"},"text":"Pub. L. 97–35, title XII, § 1211(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/723"},"text":"95 Stat. 723","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/339/tI/s109/d/2"},"text":"Pub. L. 99–339, title I, § 109(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/653"},"text":"100 Stat. 653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s204/b/4/B"},"text":"Pub. L. 110–314, title II, § 204(b)(4)(B)","children":[],"tail":", (C), (H), "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3041"},"text":"122 Stat. 3041","children":[],"tail":", 3042.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7970c992-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7970c993-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7970c994-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7970c995-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s204/b/4/B"},"text":"Pub. L. 110–314, § 204(b)(4)(B)","children":[],"tail":", (C), substituted “Commission or officers or employees of the Commission” for “Secretary or officers or employees of the Department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s204/b/4/H"},"text":"Pub. L. 110–314, § 204(b)(4)(H)","children":[],"tail":", substituted “Commission” for “Consumer Product Safety Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/339"},"text":"Pub. L. 99–339","children":[],"tail":" added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/631"},"text":"Pub. L. 95–631","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/756"},"text":"Pub. L. 89–756","children":[],"tail":", §§ 2(f)(1), 3(b), substituted “misbranded hazardous substance or banned hazardous substance” for “misbranded package of a hazardous substance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/756"},"text":"Pub. L. 89–756","children":[],"tail":", §§ 2(f)(2), 3(b), substituted “being a misbranded hazardous substance or banned hazardous substance” for “being in a misbranded package”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/756"},"text":"Pub. L. 89–756","children":[],"tail":", §§ 2(f)(1), 3(b), substituted “misbranded hazardous substance or banned hazardous substance” for “misbranded package of a hazardous substance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/756/s2/f/2"},"text":"Pub. L. 89–756, § 2(f)(2)","children":[],"tail":", substituted “being a misbranded hazardous substance” for “being in a misbranded package”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/756"},"text":"Pub. L. 89–756","children":[],"tail":", §§ 2(f)(1), 3(b), substituted “misbranded hazardous substance or banned hazardous substance” for “misbranded package of a hazardous substance”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7970c996-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7970c997-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/339"},"text":"Pub. L. 99–339","children":[],"tail":" effective 24 months after "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/339/s109/d/3"},"text":"section 109(d)(3) of Pub. L. 99–339","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261"},"text":"section 1261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7970c998-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1215"},"text":"section 1215 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052"},"text":"section 2052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
