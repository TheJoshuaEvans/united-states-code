{"tag":"section","attrib":{"id":"id77e4d32b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p"},"text":null,"children":[{"tag":"num","attrib":{"value":"77p"},"text":"§ 77p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional remedies; limitation on remedies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e4d32c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies additional","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the rights and remedies provided by this subchapter shall be in addition to any and all other rights and remedies that may exist at law or in equity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d32d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class action limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No covered class action based upon the statutory or common law of any State or subdivision thereof may be maintained in any State or Federal court by any private party alleging—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d32e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an untrue statement or omission of a material fact in connection with the purchase or sale of a covered security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d32f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the defendant used or employed any manipulative or deceptive device or contrivance in connection with the purchase or sale of a covered security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d330-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of covered class actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any covered class action brought in any State court involving a covered security, as set forth in subsection (b), shall be removable to the Federal district court for the district in which the action is pending, and shall be subject to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d331-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of certain actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d332-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions under State law of State of incorporation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d333-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions preserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (b) or (c), a covered class action described in subparagraph (B) of this paragraph that is based upon the statutory or common law of the State in which the issuer is incorporated (in the case of a corporation) or organized (in the case of any other entity) may be maintained in a State or Federal court by a private party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d334-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered class action is described in this subparagraph if it involves—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e4d335-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or sale of securities by the issuer or an affiliate of the issuer exclusively from or to holders of equity securities of the issuer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e4d336-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any recommendation, position, or other communication with respect to the sale of securities of the issuer that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77e4d337-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made by or on behalf of the issuer or an affiliate of the issuer to holders of equity securities of the issuer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77e4d338-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerns decisions of those equity holders with respect to voting their securities, acting in response to a tender or exchange offer, or exercising dissenters’ or appraisal rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d339-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State actions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d33a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, nothing in this section may be construed to preclude a State or political subdivision thereof or a State pension plan from bringing an action involving a covered security on its own behalf, or as a member of a class comprised solely of other States, political subdivisions, or State pension plans that are named plaintiffs, and that have authorized participation, in such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d33b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State pension plan” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “State pension plan” means a pension plan established and maintained for its employees by the government of the State or political subdivision thereof, or by any agency or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d33c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions under contractual agreements between issuers and indenture trustees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (b) or (c), a covered class action that seeks to enforce a contractual agreement between an issuer and an indenture trustee may be maintained in a State or Federal court by a party to the agreement or a successor to such party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d33d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remand of removed actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an action that has been removed from a State court pursuant to subsection (c), if the Federal court determines that the action may be maintained in State court pursuant to this subsection, the Federal court shall remand such action to such State court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d33e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of State jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The securities commission (or any agency or office performing like functions) of any State shall retain jurisdiction under the laws of such State to investigate and bring enforcement actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d33f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d340-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate of the issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliate of the issuer” means a person that directly or indirectly, through one or more intermediaries, controls or is controlled by or is under common control with, the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d341-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered class action","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d342-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered class action” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e4d343-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any single lawsuit in which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77e4d344-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damages are sought on behalf of more than 50 persons or prospective class members, and questions of law or fact common to those persons or members of the prospective class, without reference to issues of individualized reliance on an alleged misstatement or omission, predominate over any questions affecting only individual persons or members; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77e4d345-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more named parties seek to recover damages on a representative basis on behalf of themselves and other unnamed parties similarly situated, and questions of law or fact common to those persons or members of the prospective class predominate over any questions affecting only individual persons or members; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e4d346-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any group of lawsuits filed in or pending in the same court and involving common questions of law or fact, in which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77e4d347-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damages are sought on behalf of more than 50 persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77e4d348-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lawsuits are joined, consolidated, or otherwise proceed as a single action for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d349-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for derivative actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the term “covered class action” does not include an exclusively derivative action brought by one or more shareholders on behalf of a corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d34a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counting of certain class members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, a corporation, investment company, pension plan, partnership, or other entity, shall be treated as one person or prospective class member, but only if the entity is not established for the purpose of participating in the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d34b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall be construed to affect the discretion of a State court in determining whether actions filed in such court should be joined, consolidated, or otherwise allowed to proceed as a single action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d34c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77p/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered security” means a security that satisfies the standards for a covered security specified in paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77r/b"},"text":"section 77r(b) of this title","children":[],"tail":" at the time during which it is alleged that the misrepresentation, omission, or manipulative or deceptive conduct occurred, except that such term shall not include any debt security that is exempt from registration under this subchapter pursuant to rules issued by the Commission under section 77d(2) "},{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e4d34d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 16, "},{"tag":"ref","attrib":{"href":"/us/stat/48/84"},"text":"48 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/353/tI/s101/a/1"},"text":"Pub. L. 105–353, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3227"},"text":"112 Stat. 3227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e4d34e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e4d34f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77e4d350-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77d/2"},"text":"Section 77d(2) of this title","children":[],"tail":", referred to in subsec. (f)(3), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77d/a/2"},"text":"section 77d(a)(2) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/112/106/tII/s201/b/1"},"text":"Pub. L. 112–106, title II, § 201(b)(1)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2012-04-05"},"text":"Apr. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/314"},"text":"126 Stat. 314","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e4d351-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353"},"text":"Pub. L. 105–353","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “The rights and remedies provided by this subchapter shall be in addition to any and all other rights and remedies that may exist at law or in equity.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e4d352-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e4d353-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353/tI/s101/c"},"text":"Pub. L. 105–353, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3233"},"text":"112 Stat. 3233","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/353/tI/s101/c"},"text":"“The amendments made by this section [amending this section and sections 77v, 77z–1, 78u–4, and 78bb of this title] shall not affect or apply to any action commenced before and pending on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
