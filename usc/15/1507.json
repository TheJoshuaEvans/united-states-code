{"tag":"section","attrib":{"id":"id797efad0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1507"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507"},"text":"§ 1507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Assistant Secretary; appointment; compensation; duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Commerce, in addition to the Assistant Secretaries now provided by law, one additional Assistant Secretary of Commerce who shall be appointed by the President by and with the advice and consent of the Senate, shall receive compensation at the rate prescribed by law for Assistant Secretaries of Commerce, and shall perform such duties as the Secretary of Commerce shall prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797efad1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/405"},"text":"Pub. L. 87–405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-02-16"},"text":"Feb. 16, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/9"},"text":"76 Stat. 9","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797efad2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797efad3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id797efad4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib"