{"tag":"section","attrib":{"id":"id79a0661c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673"},"text":null,"children":[{"tag":"num","attrib":{"value":"1673"},"text":"§ 1673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on garnishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a0661d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum allowable garnishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b) and in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1675"},"text":"section 1675 of this title","children":[],"tail":", the maximum part of the aggregate disposable earnings of an individual for any workweek which is subjected to garnishment may not exceed"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a0661e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 per centum of his disposable earnings for that week, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a0661f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which his disposable earnings for that week exceed thirty times the Federal minimum hourly wage prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"section 206(a)(1) of title 29","children":[],"tail":" in effect at the time the earnings are payable,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever is less. In the case of earnings for any pay period other than a week, the Secretary of Labor shall by regulation prescribe a multiple of the Federal minimum hourly wage equivalent in effect to that set forth in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06620-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a06621-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The restrictions of subsection (a) do not apply in the case of","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06622-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any order for the support of any person issued by a court of competent jurisdiction or in accordance with an administrative procedure, which is established by State law, which affords substantial due process, and which is subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06623-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any order of any court of the United States having jurisdiction over cases under chapter 13 of title 11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06624-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any debt due for any State or Federal tax.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06625-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The maximum part of the aggregate disposable earnings of an individual for any workweek which is subject to garnishment to enforce any order for the support of any person shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06626-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where such individual is supporting his spouse or dependent child (other than a spouse or child with respect to whose support such order is used), 50 per centum of such individual’s disposable earnings for that week; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06627-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where such individual is not supporting such a spouse or dependent child described in clause (A), 60 per centum of such individual’s disposable earnings for that week;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that, with respect to the disposable earnings of any individual for any workweek, the 50 per centum specified in clause (A) shall be deemed to be 55 per centum and the 60 per centum specified in clause (B) shall be deemed to be 65 per centum, if and to the extent that such earnings are subject to garnishment to enforce a support order with respect to a period which is prior to the twelve-week period which ends with the beginning of such workweek.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06628-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1673/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution or enforcement of garnishment order or process prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No court of the United States or any State, and no State (or officer or agency thereof), may make, execute, or enforce any order or process in violation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a06629-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIII/s303"},"text":"Pub. L. 90–321, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/163"},"text":"82 Stat. 163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tV/s501/e/1"},"text":"Pub. L. 95–30, title V, § 501(e)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/161"},"text":"91 Stat. 161","children":[],"tail":", 162; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIII/s312/a"},"text":"Pub. L. 95–598, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2676"},"text":"92 Stat. 2676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a0662a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a0662b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a0662c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" substituted “court of the United States having jurisdiction over cases under chapter 13 of title 11” for “court of bankruptcy under chapter XIII of the Bankruptcy Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/s501/e/1"},"text":"Pub. L. 95–30, § 501(e)(1)","children":[],"tail":", (2), designated existing provisions as par. (1) and existing pars. (1), (2), and (3) as subpars. (A), (B), and (C) thereof, substituted “for the support of any person issued by a court of competent jurisdiction or in accordance with an administrative procedure, which is established by State law, which affords substantial due process, and which is subject to judicial review” for “of any court for the support of any person” in subpar. (A) as so redesignated, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/s501/e/3"},"text":"Pub. L. 95–30, § 501(e)(3)","children":[],"tail":", inserted “, and no State (or officer or agency thereof),” after “or any State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a0662d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a0662e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/a"},"text":"section 402(a) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a0662f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30/tV/s501/e/5"},"text":"Pub. L. 95–30, title V, § 501(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/162"},"text":"91 Stat. 162","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/30/tV/s501/e/5"},"text":"“The amendments made by this subsection [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1675"},"text":"section 1675 of this title","children":[],"tail":"] shall take effect on the first day of the first calendar month which begins after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
