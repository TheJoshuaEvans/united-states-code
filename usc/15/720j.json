{"tag":"section","attrib":{"id":"id794833f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720j"},"text":null,"children":[{"tag":"num","attrib":{"value":"720j"},"text":"§ 720j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress concerning participation by small business concerns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794833f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of small business concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “small business concern” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a"},"text":"section 632(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794833f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794833f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Alaska natural gas transportation project would provide significant economic benefits to the United States and Canada; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":