{"tag":"section","attrib":{"id":"id7a096097-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2689"},"text":null,"children":[{"tag":"num","attrib":{"value":"2689"},"text":"§ 2689.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person to fail or refuse to comply with a provision of this subchapter or with any rule or order issued under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a096098-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tIV/s409"},"text":"Pub. L. 94–469, title IV, § 409","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1021/a"},"text":"Pub. L. 102–550, title X, § 1021(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3921"},"text":"106 Stat. 3921","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
