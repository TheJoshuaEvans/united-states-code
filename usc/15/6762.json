{"tag":"section","attrib":{"id":"id7a640473-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6762"},"text":null,"children":[{"tag":"num","attrib":{"value":"6762"},"text":"§ 6762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a640474-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person aggrieved by a decision or action of the Association may, after reasonably exhausting available avenues for resolution within the Association, commence a civil action in an appropriate United States district court, and obtain all appropriate relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640475-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Association interpretations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action under subsection (a), the court shall give appropriate weight to the interpretation of the Association of its bylaws and standards and this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a640476-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s332"},"text":"Pub. L. 106–102, title III, § 332","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/26"},"text":"129 Stat. 26","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a640477-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a640478-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a640479-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6765"},"text":"section 6765 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6762, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s332"},"text":"Pub. L. 106–102, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1431"},"text":"113 Stat. 1431","children":[],"tail":", related to elimination of NAIC oversight, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":". See sections 6757 and 6759 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
