{"tag":"section","attrib":{"id":"id799df554-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1666f"},"text":"§ 1666f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inducements to cardholders by sellers of cash discounts for payments by cash, check or similar means; finance charge for sales transactions involving cash discounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799df555-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash discounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to credit ","children":[{"tag":"ref","attrib":{"idref":"fn002362"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002362"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “a”."}],"tail":" card which may be used for extensions of credit in sales transactions in which the seller is a person other than the card issuer, the card issuer may not, by contract or otherwise, prohibit any such seller from offering a discount to a cardholder to induce the cardholder to pay by cash, check, or similar means rather than use a credit card."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799df556-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finance charge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any sales transaction, any discount from the regular price offered by the seller for the purpose of inducing payment by cash, checks, or other means not involving the use of an open-end credit plan or a credit card shall not constitute a finance charge as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1605"},"text":"section 1605 of this title","children":[],"tail":" if such discount is offered to all prospective buyers and its availability is disclosed clearly and conspicuously."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799df557-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s167"},"text":"Pub. L. 90–321, title I, § 167","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIII/s306"},"text":"Pub. L. 93–495, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1515"},"text":"88 Stat. 1515","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/222/s3/c/1"},"text":"Pub. L. 94–222, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-27"},"text":"Feb. 27, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/197"},"text":"90 Stat. 197","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/25/tI/s101"},"text":"Pub. L. 97–25, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-27"},"text":"July 27, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/144"},"text":"95 Stat. 144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df558-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799df559-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799df55a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/25"},"text":"Pub. L. 97–25","children":[],"tail":" substituted “With respect to any sales transaction, any discount from the regular price offered by the seller for the purpose of inducing payment by cash, checks, or other means not involving the use of an open-end credit plan or a credit card shall not constitute a finance charge as determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1605"},"text":"section 1605 of this title","children":[],"tail":" if such discount is offered to all prospective buyers and its availability is disclosed clearly and conspicuously” for “With respect to any sales transaction, any discount not in excess of 5 per centum offered by the seller for the purpose of inducing payment by cash, check, or other means not involving the use of a credit card shall not constitute a finance charge as determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1605"},"text":"section 1605 of this title","children":[],"tail":", if such discount is offered to all prospective buyers and its availability is disclosed to all prospective buyers clearly and conspicuously in accordance with regulations of the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/222"},"text":"Pub. L. 94–222","children":[],"tail":" temporarily designated existing provisions as par. (1) and added par. (2). See Termination Date of 1976 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df55b-552d-11f1-9071-ff305b7c3ff0"},"text":