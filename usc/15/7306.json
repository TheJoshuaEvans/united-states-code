{"tag":"section","attrib":{"id":"id7a723544-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7306"},"text":null,"children":[{"tag":"num","attrib":{"value":"7306"},"text":"§ 7306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a723545-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, a copy of a record, information, or investigation submitted or received by a Team shall be made available to the public on request and at reasonable cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a723546-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not require the release of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723547-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information described by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":" or protected from disclosure by any other law of the United States; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723548-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information described in subsection (a) by the National Institute of Standards and Technology or by a Team until the report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7307"},"text":"section 7307 of this title","children":[],"tail":" is issued."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a723549-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of voluntary submission of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a Team, the National Institute of Standards and Technology, and any agency receiving information from a Team or the National Institute of Standards and Technology, shall not disclose voluntarily provided safety-related information if that information is not directly related to the building failure being investigated and the Director finds that the disclosure of the information would inhibit the voluntary provision of that type of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a72354a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public safety information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Team and the National Institute of Standards and Technology shall not publicly release any information it receives in the course of an investigation under this chapter if the Director finds that the disclosure of that information might jeopardize public safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a72354b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231/s7"},"text":"Pub. L. 107–231, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1475"},"text":"116 Stat. 1475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a72354c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a72354d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a72354e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231"},"text":"Pub. L. 107–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1471"},"text":"116 Stat. 1471","children":[],"tail":", known as the National Construction Safety Team Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7301"},"text":"section 7301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
