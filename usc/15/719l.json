{"tag":"section","attrib":{"id":"id7945c229-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719l"},"text":null,"children":[{"tag":"num","attrib":{"value":"719l"},"text":"§ 719l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter, and no action taken hereunder, shall imply or effect an amendment to, or exemption from, any provision of the antitrust laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7945c22a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/586/s14"},"text":"Pub. L. 94–586, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2915"},"text":"90 Stat. 2915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
