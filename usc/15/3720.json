{"tag":"section","attrib":{"id":"id7a2aa401-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720"},"text":null,"children":[{"tag":"num","attrib":{"value":"3720"},"text":"§ 3720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Innovation and Entrepreneurship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2aa402-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an Office of Innovation and Entrepreneurship to foster innovation and the commercialization of new technologies, products, processes, and services with the goal of promoting productivity and economic growth in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa403-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Innovation and Entrepreneurship shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa404-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing policies to accelerate innovation and advance the commercialization of research and development, including federally funded research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa405-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying existing barriers to innovation and commercialization, including access to capital and other resources, and ways to overcome those barriers, particularly in States participating in the Experimental Program to Stimulate Competitive Research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa406-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing access to relevant data, research, and technical assistance on innovation and commercialization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa407-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening collaboration on and coordination of policies relating to innovation and commercialization, including those focused on the needs of small businesses and rural communities, within the Department of Commerce, between the Department of Commerce and other Federal agencies, and between the Department of Commerce and appropriate State government agencies and institutions, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa408-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other duties as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa409-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3720/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an Advisory Council on Innovation and Entrepreneurship to provide advice to the Secretary on carrying out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2aa40a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s25"},"text":"Pub. L. 96–480, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tVI/s601"},"text":"Pub. L. 111–358, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4026"},"text":"124 Stat. 4026","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
