{"tag":"section","attrib":{"id":"id7a8ee418-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8710"},"text":null,"children":[{"tag":"num","attrib":{"value":"8710"},"text":"§ 8710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8ee419-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory suspension or termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall suspend or terminate an order or a provision of an order if the Secretary finds that an order or provision of an order obstructs or does not tend to effectuate the purpose of this chapter, or if the Secretary determines that the order or a provision of an order is not favored by a majority of all votes cast in the referendum as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8706/a/2"},"text":"section 8706(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee41a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of suspension or termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as a result of a referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8706"},"text":"section 8706 of this title","children":[],"tail":", the Secretary determines that the order is not approved, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee41b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after making the determination, suspend or terminate, as the case may be, collection of assessments under the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee41c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable, suspend or terminate, as the case may be, activities under the order in an orderly manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee41d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1311"},"text":"Pub. L. 115–254, div. E, § 1311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3482"},"text":"132 Stat. 3482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
