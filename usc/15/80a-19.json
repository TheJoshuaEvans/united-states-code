{"tag":"section","attrib":{"id":"id786a7dff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–19"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–19"},"text":"§ 80a–19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments or distributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id786a7e00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–19/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends; restriction; exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any registered investment company to pay any dividend, or to make any distribution in the nature of a dividend payment, wholly or partly from any source other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id786a7e01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–19/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such company’s accumulated undistributed net income, determined in accordance with good accounting practice and not including profits or losses realized upon the sale of securities or other properties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id786a7e02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–19/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such company’s net income so determined for the current or preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless such payment is accompanied by a written statement which adequately discloses the source or sources of such payment. The Commission may prescribe the form of such statement by rules and regulations in the public interest and for the protection of investors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786a7e03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–19/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term capital gains; limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful in contravention of such rules, regulations, or orders as the Commission may prescribe as necessary or appropriate in the public interest or for the protection of investors for any registered investment company to distribute long-term capital gains, as defined in title 26, more often than once every twelve months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id786a7e04-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 19, "},{"tag":"ref","attrib":{"href":"/us/stat/54/821"},"text":"54 Stat. 821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/547/s11"},"text":"Pub. L. 91–547, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1422"},"text":"84 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786a7e05-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786a7e06-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id786a7e07-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/547"},"text":"Pub. L. 91–547","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id786a7e08-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id786a7e09-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/547"},"text":"Pub. L. 91–547","children":[],"tail":" effective on expiration of one year after "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/547/s30/1"},"text":"section 30(1) of Pub. L. 91–547","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–52"},"text":"section 80a–52 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id786a7e0a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id786a7e0b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Securities and Exchange Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 10 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
