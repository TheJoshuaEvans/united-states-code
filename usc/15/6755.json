{"tag":"section","attrib":{"id":"id7a640425-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755"},"text":null,"children":[{"tag":"num","attrib":{"value":"6755"},"text":"§ 6755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws, standards, and disciplinary actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a640426-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption and amendment of bylaws and standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a640427-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Association shall adopt procedures for the adoption of bylaws and standards that are similar to procedures under subchapter II of chapter 5 of title 5 (commonly known as the “Administrative Procedure Act”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640428-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copy required to be filed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall submit to the President, through the Department of the Treasury, and the States (including State insurance regulators), and shall publish on the website of the Association, all proposed bylaws and standards of the Association, or any proposed amendment to the bylaws or standards of the Association, accompanied by a concise general statement of the basis and purpose of such proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640429-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any proposed bylaw or standard of the Association, and any proposed amendment to the bylaws or standards of the Association, shall take effect, after notice under paragraph (2) and opportunity for public comment, on such date as the Association may designate, unless suspended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6759/c"},"text":"section 6759(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64042a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to subject the Board or the Association to the requirements of subchapter II of chapter 5 of title 5 (commonly known as the “Administrative Procedure Act”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a64042b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disciplinary action by the Association","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a64042c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specification of charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding to determine whether membership shall be denied, suspended, revoked, or not renewed, or to determine whether a member of the Association should be placed on probation (referred to in this section as a “disciplinary action”) or whether to assess fines or monetary penalties, the Association shall bring specific charges, notify the member of the charges, give the member an opportunity to defend against the charges, and keep a record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64042d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A determination to take disciplinary action shall be supported by a statement setting forth—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a64042e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any act or practice in which the member has been found to have been engaged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a64042f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific provision of this subchapter or standard of the Association that any such act or practice is deemed to violate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a640430-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sanction imposed and the reason for the sanction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640431-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility of private sector representatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Board members appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6754/c/3"},"text":"section 6754(c)(3) of this title","children":[],"tail":" may not—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a640432-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in any disciplinary action or be counted toward establishing a quorum during a disciplinary action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a640433-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6755/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to confidential information concerning any disciplinary action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a640434-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s325"},"text":"Pub. L. 106–102, title III, § 325","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/23"},"text":"129 Stat. 23","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a640435-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a640436-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a640437-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6758"},"text":"section 6758 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6755, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s325"},"text":"Pub. L. 106–102, title III, § 325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1424"},"text":"113 Stat. 1424","children":[],"tail":", related to membership in the Association, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6753"},"text":"section 6753 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
