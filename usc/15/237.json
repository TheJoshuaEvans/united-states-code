{"tag":"section","attrib":{"id":"id7889772f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s237"},"text":null,"children":[{"tag":"num","attrib":{"value":"237"},"text":"§ 237.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard barrels for lime","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established a large and a small barrel of lime, the large barrel to consist of two hundred and eighty pounds and the small barrel to consist of one hundred and eighty pounds, net weight.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78897730-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-23/ch396/s1"},"text":"Aug. 23, 1916, ch. 396, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/530"},"text":"39 Stat. 530","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
