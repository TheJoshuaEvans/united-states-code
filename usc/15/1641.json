{"tag":"section","attrib":{"id":"id799baa9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641"},"text":null,"children":[{"tag":"num","attrib":{"value":"1641"},"text":"§ 1641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of assignees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799baaa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prerequisites","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided in this subchapter, any civil action for a violation of this subchapter or proceeding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1607"},"text":"section 1607 of this title","children":[],"tail":" which may be brought against a creditor may be maintained against any assignee of such creditor only if the violation for which such action or proceeding is brought is apparent on the face of the disclosure statement, except where the assignment was involuntary. For the purpose of this section, a violation apparent on the face of the disclosure statement includes, but is not limited to (1) a disclosure which can be determined to be incomplete or inaccurate from the face of the disclosure statement or other documents assigned, or (2) a disclosure which does not use the terms required to be used by this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799baaa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of compliance with statutory provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1635/c"},"text":"section 1635(c) of this title","children":[],"tail":", in any action or proceeding by or against any subsequent assignee of the original creditor without knowledge to the contrary by the assignee when he acquires the obligation, written acknowledgement of receipt by a person to whom a statement is required to be given pursuant to this subchapter shall be conclusive proof of the delivery thereof and, except as provided in subsection (a), of compliance with this part. This section does not affect the rights of the obligor in any action against the original creditor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799baaa2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of rescission by consumer unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any consumer who has the right to rescind a transaction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1635"},"text":"section 1635 of this title","children":[],"tail":" may rescind the transaction as against any assignee of the obligation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799baaa3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights upon assignment of certain mortgages","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799baaa4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who purchases or is otherwise assigned a mortgage referred to in section 1602(aa) ","children":[{"tag":"ref","attrib":{"idref":"fn002357"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002357"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall be subject to all claims and defenses with respect to that mortgage that the consumer could assert against the creditor of the mortgage, unless the purchaser or assignee demonstrates, by a preponderance of the evidence, that a reasonable person exercising ordinary due diligence, could not determine, based on the documentation required by this subchapter, the itemization of the amount financed, and other disclosure of disbursements that the mortgage was a mortgage referred to in section 1602(aa) "},{"tag":"ref","attrib":{"idref":"fn002357"},"text":"1","children":[],"tail":" of this title. The preceding sentence does not affect rights of a consumer under subsection (a), (b), or (c) of this section or any other provision of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baaa5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, relief provided as a result of any action made permissible by paragraph (1) may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799baaa6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to actions based upon a violation of this subchapter, the amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1640"},"text":"section 1640 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baaa7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to all other causes of action, the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id799baaa8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of all remaining indebtedness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799baaa9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount paid by the consumer in connection with the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baaaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of damages that may be awarded under paragraph (2)(B) shall be reduced by the amount of any damages awarded under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baaab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who sells or otherwise assigns a mortgage referred to in section 1602(aa) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title shall include a prominent notice of the potential liability under this subsection as determined by the Bureau."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799baaac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of assignee for consumer credit transactions secured by real property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799baaad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided in this subchapter, any civil action against a creditor for a violation of this subchapter, and any proceeding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1607"},"text":"section 1607 of this title","children":[],"tail":" against a creditor, with respect to a consumer credit transaction secured by real property may be maintained against any assignee of such creditor only if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799baaae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation for which such action or proceeding is brought is apparent on the face of the disclosure statement provided in connection with such transaction pursuant to this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baaaf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assignment to the assignee was voluntary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baab0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation apparent on the face of the disclosure described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section, a violation is apparent on the face of the disclosure statement if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799baab1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure can be determined to be incomplete or inaccurate by a comparison among the disclosure statement, any itemization of the amount financed, the note, or any other disclosure of disbursement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baab2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure statement does not use the terms or format required to be used by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799baab3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of servicer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799baab4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A servicer of a consumer obligation arising from a consumer credit transaction shall not be treated as an assignee of such obligation for purposes of this section unless the servicer is or was the owner of the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baab5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Servicer not treated as owner on basis of assignment for administrative convenience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A servicer of a consumer obligation arising from a consumer credit transaction shall not be treated as the owner of the obligation for purposes of this section on the basis of an assignment of the obligation from the creditor or another assignee to the servicer solely for the administrative convenience of the servicer in servicing the obligation. Upon written request by the obligor, the servicer shall provide the obligor, to the best knowledge of the servicer, with the name, address, and telephone number of the owner of the obligation or the master servicer of the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baab6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Servicer” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “servicer” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2605/i/2"},"text":"section 2605(i)(2) of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baab7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall apply to all consumer credit transactions in existence or consummated on or after ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799baab8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of new creditor","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799baab9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other disclosures required by this subchapter, not later than 30 days after the date on which a mortgage loan is sold or otherwise transferred or assigned to a third party, the creditor that is the new owner or assignee of the debt shall notify the borrower in writing of such transfer, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799baaba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity, address, telephone number of the new creditor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baabb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baabc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to reach an agent or party having authority to act on behalf of the new creditor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baabd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the place where transfer of ownership of the debt is recorded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baabe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information regarding the new creditor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baabf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1641/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this subsection, the term “mortgage loan” means any consumer credit transaction that is secured by the principal dwelling of a consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799baac0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s131"},"text":"Pub. L. 90–321, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/157"},"text":"82 Stat. 157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s616/a"},"text":"Pub. L. 96–221, title VI, § 616(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/182"},"text":"94 Stat. 182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s153/c"},"text":"Pub. L. 103–325, title I, § 153(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2195"},"text":"108 Stat. 2195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/29/s7"},"text":"Pub. L. 104–29, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"da