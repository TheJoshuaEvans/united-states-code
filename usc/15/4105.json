{"tag":"section","attrib":{"id":"id7a36b260-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b261-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4105/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the civil service laws and subchapter III of chapter 53 of title 5, appoint and fix the compensation of an Executive Director and necessary additional staff personnel, but not to exceed a total of seven compensated personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b262-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4105/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure temporary and intermittent services as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b263-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4105/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts and procure supplies, services, and personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b264-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4105/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements with the General Services Administration for the procurement of necessary financial and administrative services, for which payment shall be made by reimbursement from funds of the Commission in amounts to be agreed upon by the Commission and the Administrator of the General Services Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b265-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4105/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint, and accept without compensation the services of, scientists and engineering specialists to be advisors to the Commission. Each advisor may be allowed travel expenses, including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":". Except for the purposes of chapter 81 of title 5 (relating to compensation for work injuries) and chapter 171 of title 28 (relating to tort claims), an advisor appointed under this paragraph shall not be considered an employee of the United States for any purpose."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a36b266-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373/tI/s106"},"text":"Pub. L. 98–373, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-31"},"text":"July 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1245"},"text":"98 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/609/s5"},"text":"Pub. L. 101–609, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3125"},"text":"104 Stat. 3125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a36b267-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a36b268-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a36b269-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/609"},"text":"Pub. L. 101–609","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
