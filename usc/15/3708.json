{"tag":"section","attrib":{"id":"id7a239f36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3708"},"text":null,"children":[{"tag":"num","attrib":{"value":"3708"},"text":"§ 3708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a239f37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":" (a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the National Science Foundation shall, on a continuing basis, obtain the advice and cooperation of departments and agencies whose missions contribute to or are affected by the programs established under this chapter, including the development of an agenda for research and policy experimentation. These departments and agencies shall include but not be limited to the Departments of Defense, Energy, Education, Health and Human Services, Housing and Urban Development, the Environmental Protection Agency, National Aeronautics and Space Administration, Small Business Administration, Council of Economic Advisers, Council on Environmental Quality, and Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a239f38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that departments and agencies, including the Federal laboratories, whose missions are affected by, or could contribute to, the programs established under this chapter, should, within the limits of budgetary authorizations and appropriations, support or participate in activities or projects authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a239f39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a239f3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Departments and agencies described in subsection (b) are authorized to participate in, contribute to, and serve as resources for the Centers and for any other activities authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a239f3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary and the National Science Foundation are authorized to receive moneys and to receive other forms of assistance from other departments or agencies to support activities of the Centers and any other activities authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a239f3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the National Science Foundation shall, on a continuing basis, provide each other the opportunity to comment on any proposed program of activity under section 3705, 3707, 3710, 3710d, 3711a, or 3712 of this title before funds are committed to such program in order to mount complementary efforts and avoid duplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a239f3d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s10"},"text":"Pub. L. 96–480, § 10","children":[],"tail":", formerly § 9, "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2316"},"text":"94 Stat. 2316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/e/2/C"},"text":"Pub. L. 99–502, § 9(e)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-20"},"text":"Oct. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1797"},"text":"100 Stat. 1797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/107/s3/b"},"text":"Pub. L. 100–107, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-20"},"text":"Aug. 20, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/727"},"text":"101 Stat. 727","children":[],"tail":"; renumbered § 10 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5122/a/1"},"text":"Pub. L. 100–418, title V, § 5122(a)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1438"},"text":"102 Stat. 1438","children":[],"tail":", 1439; "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tVI/s6019"},"text":"Pub. L. 102–240, title VI, § 6019","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2183"},"text":"105 Stat. 2183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a239f3e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a239f3f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a239f40-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s10"},"text":"section 10 of Pub. L. 96–480","children":[],"tail":" was renumbered section 11 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710"},"text":"section 3710 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s10"},"text":"section 10 of Pub. L. 96–480","children":[],"tail":" related to National Industrial Technology Board and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3709"},"text":"section 3709 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/a"},"text":"section 9(a) of Pub. L. 99–502","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a239f41-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3712"},"text":"section 3712 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s5122/c"},"text":"Pub. L. 100–418, § 5122(c)","children":[],"tail":", made technical amendment to references to sections 3705, 3707, 3710, 3710d, 3711a, and 3712 of this title to reflect renumbering of corresponding sections of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/107"},"text":"Pub. L. 100–107","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3711a"},"text":"section 3711a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502"},"text":"Pub. L. 99–502","children":[],"tail":" inserted references to sections 3710 and 3710d of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
