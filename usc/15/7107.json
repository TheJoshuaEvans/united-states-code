{"tag":"section","attrib":{"id":"id7a6b0924-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107"},"text":null,"children":[{"tag":"num","attrib":{"value":"7107"},"text":"§ 7107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of the Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6b0925-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint an individual to serve as chairperson of the Council, in consultation with the Administrator. The chairperson of the Council shall be a prominent business woman who is qualified to head the Council by virtue of her education, training, and experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0926-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall, after receiving the recommendations of the Chairman and the Ranking Member of the Committees on Small Business of the House of Representatives and the Senate, appoint, in consultation with the chairperson of the Council appointed under subsection (a), 14 members of the Council, of whom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b0927-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b0928-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners of small businesses, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0929-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the same political party as the President;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b092a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b092b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be owners of small businesses, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b092c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be members of the same political party as the President; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b092d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 shall be representatives of women’s business organizations, including representatives of women’s business center sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b092e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In appointing members of the Council, the Administrator shall, to the extent possible, ensure that the members appointed reflect geographic (including both urban and rural areas), racial, economic, and sectoral diversity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b092f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council shall be appointed for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0930-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any member of the Council subsequently becomes an officer or employee of the Federal Government or of the Congress, such individual may continue as a member of the Council for not longer than the 30-day period beginning on the date on which such individual becomes such an officer or employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0931-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b0932-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Council shall be filled not later than 30 days after the date on which the vacancy occurs, in the manner in which the original appointment was made, and shall be subject to any conditions that applied to the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0933-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unexpired term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual chosen to fill a vacancy shall be appointed for the unexpired term of the member replaced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0934-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council shall serve without pay for such membership, except that members shall be entitled to reimbursement for travel, subsistence, and other necessary expenses incurred by them in carrying out the functions of the Council, in the same manner as persons serving on advisory boards pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/b"},"text":"section 637(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0935-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in consultation with the chairperson of the Council, shall appoint an executive director of the Council. Upon the recommendation by the executive director, the chairperson of the Council may appoint and fix the pay of 4 additional employees of the Council, at a rate of pay not to exceed the maximum rate of pay payable for a position at GS–15 of the General Schedule. All such appointments shall be subject to the appropriation of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0936-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7107/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates of pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The executive director and staff of the Council may be appointed without regard to the provisions of title 5 governing appointments in the competitive service, and except as provided in subsection (e), may be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and General Schedule pay rates, except that the executive director may not receive pay in excess of the annual rate of basic pay payable for a position at ES–3 of the Senior Executive Pay Schedule under section 5832 ","children":[{"tag":"ref","attrib":{"idref":"fn002569"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002569"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “5382”."}],"tail":" of title 5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b0937-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/tIV/s407"},"text":"Pub. L. 100–533, title IV, § 407","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tIV/s413"},"text":"Pub. L. 103–403, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4196"},"text":"108 Stat. 4196","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/tIII/s304"},"text":"Pub. L. 105–135, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2609"},"text":"111 Stat. 2609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tVII/s702"},"text":"Pub. L. 106–554, § 1(a)(9) [title VII, § 702]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–701.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6b0938-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6b0939-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a6b093a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsecs. (h) and (i), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a6b093b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/s407"},"text":"section 407 of Pub. L. 100–533","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2696"},"text":"102 Stat. 2696","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/81/s11"},"text":"Pub. L. 103–81, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-13"},"text":"Aug. 13, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/783"},"text":"107 Stat. 783","children":[],"tail":", related to authorization of appropriations to carry out this chapter, prior to the general amendment of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/100/533"},"text":"Pub. L. 100–533","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/403"},"text":"Pub. L. 103–403","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7110"},"text":"section 7110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a6b093c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tVII/s702/1"},"text":"Pub. L. 106–554, § 1(a)(9) [title VII, § 702(1)]","children":[],"tail":", substituted “The President” for “Not later than 45 days after "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"December 2, 1997","children":[],"tail":", the President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tVII/s702/2"},"text":"Pub. L. 106–554, § 1(a)(9) [title VII, § 702(2)]","children":[],"tail":", in introductory provisions, substituted “The Administrator” for “Not later than 60 days after "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"December 2, 1997","children":[],"tail":", the Administrator” and struck out “the Assistant Administrator of the Office of Women’s Business Ownership and” after “in consultation with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tVII/s702/3"},"text":"Pub. L. 106–554, § 1(a)(9) [title VII, § 702(3)]","children":[],"tail":", struck out before period at end “, except that, of the initial members appointed to the Council—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 2 members appointed under subsection (b)(1) of this section shall be appointed for a term of 1 year;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 2 members appointed under subsection (b)(2) of this section shall be appointed for a term of 1 year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) each member appointed under subsection (b)(3) of this section shall be appointed for a term of 2 years”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tVII/s702/4"},"text":"Pub. L. 106–554, § 1(a)(9) [title VII, § 702(4)]","children":[],"tail":", substituted “The Administrator” for “Not later than 60 days after "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"October 22, 1994","children":[],"tail":", the Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s304/1"},"text":"Pub. L. 105–135, § 304(1)","children":[],"tail":", made substitution in original which was executed by substituting “"},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"December 2, 1997","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"October 22, 1994","children":[],"tail":"” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s304/2/A"},"text":"Pub. L. 105–135, § 304(2)(A)","children":[],"tail":"–(C), in introductory provisions made substitution in original which was executed by substituting “"},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"December 2, 1997","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"October 22, 1994","children":[],"tail":"” to reflect the probable intent of Congress, inserted “, after receiving the recommendations of the Chairman and the Ranking Member of the Committees on Small Business of the House of Representatives and the Senate,” after “the Administrator shall”, and substituted “14” for “9”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s304/2/D"},"text":"Pub. L. 105–135, § 304(2)(D)","children":[],"tail":", (E), substituted “4” for “2” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s304/2/F"},"text":"Pub. L. 105–135, § 304(2)(F)","children":[],"tail":", substituted “6” for “5”, struck out “national” after “representatives of”, and inserted before period at end “, including representatives of women’s business center sites”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s304/3"},"text":"Pub. L. 105–135, § 304(3)","children":[],"tail":", inserted “(including both urban and rural areas)” after “geographic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s304/4"},"text":"Pub. L. 105–135, § 304(4)","children":[],"tail":", added subsec. (d) and struck out heading and text of former subsec. (d). Text read as follows: “The term of service of the members of the Council shall be 3 years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s304/5"},"text":"Pub. L. 105–135, § 304(5)","children":[],"tail":", added subsec. (f) and struck out heading and text of former subsec. (f). Text read as follows: “A vacancy on the Council shall, not later than 30 days after the date on which the vacancy occurs, be filled in the same manner in which the original appointment was made.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a6b093d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a6b093e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Small Business of Senate changed to Committee on Small Business and Entrepreneurship of Senate. See Senate Resolution No. 123, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-06-29"},"text":"June 29, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a6b093f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135"},"text":"Pub. L. 105–135","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/s3"},"text":"section 3 of Pub. L. 105–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
