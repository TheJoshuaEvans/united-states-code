{"tag":"section","attrib":{"id":"id7a2f8699-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3810"},"text":null,"children":[{"tag":"num","attrib":{"value":"3810"},"text":"§ 3810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2f869a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification or waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as authorizing the Secretary or any other official with respect to any activity pursuant to this chapter to modify or waive the application of any Federal, State or local laws dealing with the production, transportation, storage, safety, use or pricing of methane.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f869b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed as granting the Secretary or any other Federal official any authority to promulgate rules of general application to regulate the production, transportation, storage, safety, use or pricing of methane as a transportation fuel or vehicles which use methane as a transportation fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2f869c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/512/s11"},"text":"Pub. L. 96–512, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2833"},"text":"94 Stat. 2833","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
