{"tag":"section","attrib":{"id":"id79c44112-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1822"},"text":null,"children":[{"tag":"num","attrib":{"value":"1822"},"text":"§ 1822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c44113-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1822/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the soring of horses is cruel and inhumane;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c44114-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1822/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" horses shown or exhibited which are sore, where such soreness improves the performance of such horse, compete unfairly with horses which are not sore;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c44115-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1822/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement, showing, exhibition, or sale of sore horses in intrastate commerce adversely affects and burdens interstate and foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c44116-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1822/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all horses which are subject to regulation under this chapter are either in interstate or foreign commerce or substantially affect such commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c44117-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1822/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulation under this chapter by the Secretary is appropriate to prevent and eliminate burdens upon commerce and to effectively regulate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c44118-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/540/s3"},"text":"Pub. L. 91–540, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-09"},"text":"Dec. 9, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1405"},"text":"84 Stat. 1405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/360/s4"},"text":"Pub. L. 94–360, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-13"},"text":"July 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/915"},"text":"90 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c44119-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c4411a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c4411b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/360"},"text":"Pub. L. 94–360","children":[],"tail":", among other changes, inserted findings stating that all horses subject to regulation under this chapter are either in interstate or foreign commerce or substantially affect interstate or foreign commerce, and that regulation by the Secretary is appropriate to eliminate burdens upon commerce."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
