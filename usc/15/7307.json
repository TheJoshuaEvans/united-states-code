{"tag":"section","attrib":{"id":"id7a72354f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7307"},"text":null,"children":[{"tag":"num","attrib":{"value":"7307"},"text":"§ 7307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Construction Safety Team report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after completing an investigation, a Team shall issue a public report which includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723550-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7307/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the likely technical cause or causes of the building failure investigated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723551-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7307/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any technical recommendations for changes to or the establishment of evacuation and emergency response procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723552-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7307/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommended specific improvements to building standards, codes, and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723553-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7307/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for research and other appropriate actions needed to help prevent future building failures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a723554-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231/s8"},"text":"Pub. L. 107–231, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1475"},"text":"116 Stat. 1475","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
