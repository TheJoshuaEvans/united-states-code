{"tag":"section","attrib":{"id":"id7a2aa40b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721"},"text":null,"children":[{"tag":"num","attrib":{"value":"3721"},"text":"§ 3721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal loan guarantees for innovative technologies in manufacturing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2aa40c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to provide loan guarantees for obligations to small- or medium-sized manufacturers for the use or production of innovative technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa40d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan guarantee may be made under the program only for a project that re-equips, expands, or establishes a manufacturing facility in the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa40e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use an innovative technology or an innovative process in manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa40f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to manufacture an innovative technology product or an integral component of such a product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa410-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to commercialize an innovative product, process, or idea that was developed by research funded in whole or in part by a grant from the Federal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa411-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible borrower","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan guarantee may be made under the program only for a borrower who is a small- or medium-sized manufacturer, as determined by the Secretary under the criteria established pursuant to subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa412-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan guarantee shall not exceed an amount equal to 80 percent of the obligation, as estimated at the time at which the loan guarantee is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa413-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on loan guarantee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No loan guarantee shall be made unless the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa414-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reasonable prospect of repayment of the principal and interest on the obligation by the borrower;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa415-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the obligation (when combined with amounts available to the borrower from other sources) is sufficient to carry out the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa416-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligation is not subordinate to other financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa417-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligation bears interest at a rate that does not exceed a level that the Secretary determines appropriate, taking into account the prevailing rate of interest in the private sector for similar loans and risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa418-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term of an obligation requires full repayment over a period not to exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa419-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa41a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of the projected useful life, as determined by the Secretary, of the physical asset to be financed by the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa41b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defaults","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa41c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment by Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa41d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a borrower defaults (as defined in regulations promulgated by the Secretary and specified in the loan guarantee) on the obligation, the holder of the loan guarantee shall have the right to demand payment of the unpaid amount from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa41e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within such period as may be specified in the loan guarantee or related agreements, the Secretary shall pay to the holder of the loan guarantee the unpaid interest on and unpaid principal of the obligation as to which the borrower has defaulted, unless the Secretary finds that there was no default by the borrower in the payment of interest or principal or that the default has been remedied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa41f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forbearance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection precludes any forbearance by the holder of the obligation for the benefit of the borrower which may be agreed upon by the parties to the obligation and approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa420-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa421-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary makes a payment under paragraph (1), the Secretary shall be subrogated to the rights, as specified in the loan guarantee, of the recipient of the payment or related agreements including, if appropriate, the authority (notwithstanding any other provision of law)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2aa422-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complete, maintain, operate, lease, or otherwise dispose of any property acquired pursuant to such loan guarantee or related agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2aa423-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the borrower, pursuant to an agreement with the Secretary, to continue to pursue the purposes of the project if the Secretary determines that such an agreement is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa424-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superiority of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rights of the Secretary, with respect to any property acquired pursuant to a loan guarantee or related agreements, shall be superior to the rights of any other person with respect to the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa425-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the borrower defaults on an obligation, the Secretary shall notify the Attorney General of the default.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa426-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan guarantee under this section shall include such detailed terms and conditions as the Secretary determines appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa427-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the interests of the United States in the case of default; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa428-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have available all the patents and technology necessary for any person selected, including the Secretary, to complete and operate the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa429-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the terms and conditions of a loan guarantee under this section, the Secretary shall consult with the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa42a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa42b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall charge and collect fees for loan guarantees in amounts the Secretary determines are sufficient to cover applicable administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa42c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fees collected under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa42d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be deposited by the Secretary into the Treasury of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa42e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended, subject to such other conditions as are contained in annual appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa42f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In charging and collecting fees under paragraph (1), the Secretary shall take into consideration the amount of the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa430-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa431-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a loan guarantee under this section, the borrower, the lender, and any other appropriate party shall keep such records and other pertinent documents as the Secretary shall prescribe by regulation, including such records as the Secretary may require to facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa432-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Comptroller General of the United States, or their duly authorized representatives, shall have access to records and other pertinent documents for the purpose of conducting an audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa433-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to the payment of all loan guarantees issued under this section with respect to principal and interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa434-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue final regulations before making any loan guarantees under the program. The regulations shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa435-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" criteria that the Secretary shall use to determine eligibility for loan guarantees under this section, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2aa436-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether a borrower is a small- or medium-sized manufacturer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2aa437-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether a borrower demonstrates that a market exists for the innovative technology product, or the integral component of such a product, to be manufactured, as evidenced by written statements of interest from potential purchasers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa438-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria that the Secretary shall use to determine the amount of any fees charged under subsection (i), including criteria related to the amount of the obligation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa439-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and procedures for selecting and monitoring lenders and loan performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa43a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other policies, procedures, or information necessary to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa43b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa43c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual independent audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into an arrangement with an independent auditor for annual evaluations of the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa43d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of the independent audit under paragraph (1) shall be provided directly to the Committee on Science and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa43e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Concurrent with the submission to Congress of the President’s annual budget request in each year after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Secretary shall transmit to the Committee on Science and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report containing a summary of all activities carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa43f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination and nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall ensure that the activities carried out under this section are coordinated with, and do not duplicate the efforts of, other loan guarantee programs within the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa440-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/p"},"text":null,"children":[{"tag":"num","attrib":{"value":"p"},"text":"(p)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MEP centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use centers established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":" to provide information about the program established under this section and to conduct outreach to potential borrowers, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa441-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/q"},"text":null,"children":[{"tag":"num","attrib":{"value":"q"},"text":"(q)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimizing risk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations and policies to carry out this section in accordance with Office of Management and Budget Circular No. A–129, entitled “Policies for Federal Credit Programs and Non-Tax Receivables”, as in effect on ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa442-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/r"},"text":null,"children":[{"tag":"num","attrib":{"value":"r"},"text":"(r)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that no loan guarantee shall be made under this section unless the borrower agrees to use a federally-approved electronic employment eligibility verification system to verify the employment eligibility of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa443-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/r/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all persons hired during the contract term by the borrower to perform employment duties within the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa444-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/r/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all persons assigned by the borrower to perform work within the United States on the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa445-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/s"},"text":null,"children":[{"tag":"num","attrib":{"value":"s"},"text":"(s)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2aa446-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/s/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cost” has the meaning given such term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa447-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/s/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “innovative process” means a process that is significantly improved as compared to the process in general use in the commercial marketplace in the United States at the time the loan guarantee is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa448-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/s/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “innovative technology” means a technology that is significantly improved as compared to the technology in general use in the commercial marketplace in the United States at the time the loan guarantee is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa449-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/s/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan guarantee” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":". The term includes a loan guarantee commitment (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa44a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/s/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “obligation” means the loan or other debt obligation that is guaranteed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2aa44b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/s/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the loan guarantee program established in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2aa44c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3721/t"},"text":null,"children":[{"tag":"num","attrib":{"value":"t"},"text":"(t)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $20,000,000 for each of fiscal years 2011 through 2013 to provide the cost of loan guarantees under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2aa44d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s26"},"text":"Pub. L. 96–480, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tVI/s602"},"text":"Pub. L. 111–358, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4026"},"text":"124 Stat. 4026","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10246/b/2"},"text":"Pub. L. 117–167, div. B, title II, § 10246(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1492"},"text":"136 Stat. 1492","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2aa44e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2aa44f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a2aa450-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (m)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" redesignated par. (3) as (2), struck out “and the Comptroller General’s review under paragraph (2)” before “shall be provided”, and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “The Comptroller General of the United States shall conduct a biennial review of the Secretary’s execution of the program under this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a2aa451-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a2aa452-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
