{"tag":"section","attrib":{"id":"id797cb0fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1456"},"text":null,"children":[{"tag":"num","attrib":{"value":"1456"},"text":"§ 1456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id797cb0fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1456/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misbranded consumer commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any consumer commodity which is a food, drug, device, or cosmetic, as each such term is defined by section 201 of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"21 U.S.C. 321","children":[],"tail":"), and which is introduced or delivered for introduction into commerce in violation of any of the provisions of this chapter, or the regulations issued pursuant to this chapter, shall be deemed to be misbranded within the meaning of chapter III of the Federal Food, Drug, and Cosmetic Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s331"},"text":"21 U.S.C. 331","children":[],"tail":" et seq.], but the provisions of section 303 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s333"},"text":"21 U.S.C. 333","children":[],"tail":") shall have no application to any violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1452"},"text":"section 1452 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb0ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1456/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfair or deceptive acts or practices in commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any violation of any of the provisions of this chapter, or the regulations issued pursuant to this chapter, with respect to any consumer commodity which is not a food, drug, device, or cosmetic, shall constitute an unfair or deceptive act or practice in commerce in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/a"},"text":"section 45(a) of this title","children":[],"tail":" and shall be subject to enforcement under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/b"},"text":"section 45(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb100-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1456/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any imports into the United States of any consumer commodity covered by this chapter, the provisions of sections 1453 and 1454 of this title shall be enforced by the Secretary of the Treasury pursuant to section 801(a) and (b) of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s381"},"text":"21 U.S.C. 381","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id797cb101-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/755/s7"},"text":"Pub. L. 89–755, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1300"},"text":"80 Stat. 1300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797cb102-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797cb103-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id797cb104-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsecs. (a) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":". Chapter III of the Act is classified generally to subchapter III (§ 331 et seq.) of chapter 9 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
