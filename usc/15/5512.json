{"tag":"section","attrib":{"id":"id7a4e8033-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512"},"text":null,"children":[{"tag":"num","attrib":{"value":"5512"},"text":"§ 5512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grand Challenges in areas of national importance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4e8034-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Program shall encourage the participating agencies to support foundational, large-scale, long-term, interdisciplinary, and interagency information technology research and development activities in networking and information technology directed toward agency mission areas that have the potential for significant contributions to national economic competitiveness and for other significant societal benefits. Such activities, ranging from basic research to the demonstration of technical solutions, shall be designed to advance the development of fundamental discoveries. The advisory committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5511/b"},"text":"section 5511(b) of this title","children":[],"tail":" shall make recommendations to the Program for candidate research and development areas for support under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4e8035-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Characteristics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4e8036-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research and development activities under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4e8037-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include projects selected on the basis of applications for support through a competitive, merit-based process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4e8038-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, involve collaborations among researchers in institutions of higher education and industry, and may involve nonprofit research institutions and Federal laboratories, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4e8039-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, leverage Federal investments through collaboration with related State and private sector initiatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4e803a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a plan for fostering the transfer of research discoveries and the results of technology demonstration activities, including from institutions of higher education and Federal laboratories, to industry for commercial development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4e803b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5512/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting applications for support, the agencies may give special consideration to projects that include cost sharing from non-Federal sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4e803c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/194/tI/s102"},"text":"Pub. L. 102–194, title I, § 102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s105/i"},"text":"Pub. L. 114–329, title I, § 105(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2982"},"text":"130 Stat. 2982","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4e803d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4e803e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a4e803f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5512, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/194/tI/s102"},"text":"Pub. L. 102–194, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1598"},"text":"105 Stat. 1598","children":[],"tail":", related to the National Research and Education Network, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s105/g"},"text":"Pub. L. 114–329, title I, § 105(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2982"},"text":"130 Stat. 2982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
