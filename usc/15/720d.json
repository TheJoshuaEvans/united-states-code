{"tag":"section","attrib":{"id":"id7948338e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d"},"text":null,"children":[{"tag":"num","attrib":{"value":"720d"},"text":"§ 720d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Coordinator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7948338f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, as an independent office in the executive branch, the Office of the Federal Coordinator for Alaska Natural Gas Transportation Projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79483390-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Coordinator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79483391-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by a Federal Coordinator for Alaska Natural Gas Transportation Projects, who shall be appointed by the President, by and with the advice and consent of the Senate, to serve a term to last until 1 year following the completion of the project referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s720a"},"text":"section 720a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483392-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Coordinator shall be compensated at the rate prescribed for level III of the Executive Schedule (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"5 U.S.C. 5314","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79483393-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Coordinator shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79483394-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the expeditious discharge of all activities by Federal agencies with respect to an Alaska natural gas transportation project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483395-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the compliance of Federal agencies with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79483396-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews and actions of other Federal agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79483397-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited reviews and actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All reviews conducted and actions taken by any Federal agency relating to an Alaska natural gas transportation project authorized under this section shall be expedited, in a manner consistent with completion of the necessary reviews and approvals by the deadlines under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483398-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of certain terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal agency may include in any certificate, right-of-way, permit, lease, or other authorization issued to an Alaska natural gas transportation project any term or condition that may be permitted, but is not required, by any applicable law if the Federal Coordinator determines that the term or condition would prevent or impair in any significant respect the expeditious construction and operation, or an expansion, of the Alaska natural gas transportation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483399-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of certain actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless required by law, no Federal agency shall add to, amend, or abrogate any certificate, right-of-way, permit, lease, or other authorization issued to an Alaska natural gas transportation project if the Federal Coordinator determines that the action would prevent or impair in any significant respect the expeditious construction and operation, or an expansion, of the Alaska natural gas transportation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7948339a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Coordinator shall not have authority to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7948339b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" override—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7948339c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation or enforcement of regulations issued by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s720a"},"text":"section 720a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7948339d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an order by the Commission to expand the project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s720c"},"text":"section 720c of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7948339e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose any terms, conditions, or requirements in addition to those imposed by the Commission or any agency with respect to construction and operation, or an expansion of, the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7948339f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794833a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Coordinator and the State shall enter into a joint surveillance and monitoring agreement similar to the agreement in effect during construction of the Trans-Alaska Pipeline, to be approved by the President and the Governor of the State, for the purpose of monitoring the construction of the Alaska natural gas transportation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary responsibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an Alaska natural gas transportation project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id794833a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government shall have primary surveillance and monitoring responsibility in areas where the Alaska natural gas transportation project crosses Federal land or private land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State government shall have primary surveillance and monitoring responsibility in areas where the Alaska natural gas transportation project crosses State land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794833a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of Federal Inspector functions and authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On appointment of the Federal Coordinator by the President, all of the functions and authority of the Office of Federal Inspector of Construction for the Alaska Natural Gas Transportation System vested in the Secretary under section 3012(b) of the Energy Policy Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719e"},"text":"15 U.S.C. 719e","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Public Law 102–486","children":[],"tail":"), including all functions and authority described and enumerated in the Reorganization Plan No. 1 of 1979 (44 Fed. Reg. 33663), Executive Order No. 12142 of "},{"tag":"date","attrib":{"date":"1979-06-21"},"text":"June 21, 1979","children":[],"tail":" (44 Fed. Reg. 36927), and section 5 of the President’s decision, shall be transferred to the Federal Coordinator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794833a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The functions, authorities, duties, and responsibilities of the Federal Coordinator shall be vested in the Secretary until the earlier of the appointment of the Federal Coordinator by the President, or 18 months after ","children":[{"tag":"date","attrib":{"date":"2004-10-13"},"text":"October 13, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794833a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794833a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel appointments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id794833a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Coordinator may appoint and terminate such personnel as the Federal Coordinator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Federal Coordinator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Personnel appointed by the Federal Coordinator under subparagraph (A) shall be appointed without regard to the provisions of title 5 governing appointments in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id794833ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), personnel appointed by the Federal Coordinator under paragraph (1)(A) shall be paid without regard to the provisions of chapter 51 and subchapter III of chapter 53 of title 5 (relating to classification and General Schedule pay rates).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum level of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate of pay for personnel appointed by the Federal Coordinator under paragraph (1)(A) shall not exceed the maximum level of rate payable for level III of the Executive Schedule (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"5 U.S.C. 5314","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5941"},"text":"Section 5941 of title 5","children":[],"tail":" shall apply to personnel appointed by the Federal Coordinator under paragraph (1)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id794833af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Coordinator may procure temporary and intermittent services in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum level of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The level of compensation of an individual employed on a temporary or intermittent basis under subparagraph (A) shall not exceed the maximum level of rate payable for level III of the Executive Schedule (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"5 U.S.C. 5314","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees, charges, and commissions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id794833b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the duties of the Federal Coordinator, as described in this chapter, the Federal Coordinator shall have similar authority to establish, change, and abolish reasonable filing and service fees, charges, and commissions, require deposits of payments, and provide refunds as provided to the Secretary of the Interior in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1734"},"text":"section 1734 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of the Interior","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not affect the authority of the Secretary of the Interior to establish, change, and abolish reasonable filing and service fees, charges, and commissions, require deposits of payments, and provide refunds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1734"},"text":"section 1734 of title 43","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720d/h/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Coordinator is authorized to use, without further appropriation, amounts collected under subparagraph (A) to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794833b5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/dC/s106"},"text":"Pub. L. 108–324, div. C, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-13"},"text":"Oct. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1259"},"text":"118 Stat. 1259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/148/dA/tVIII/s8128"},"text":"Pub. L. 109–148, div. A, title VIII, § 8128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2731"},"text":"119 Stat. 2731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVIII/s802"},"text":"Pub. L. 110–140, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1717"},"text":"121 Stat. 1717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794833b6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id794833b7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id794833b8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c)(2) and (d)(1), was in the original “this division”, meaning division C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324"},"text":"Pub. L. 108–324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-13"},"text":"Oct. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1255"},"text":"118 Stat. 1255","children":[],"tail":", which is classified principally to this chapter. This chapter, referred to in subsec. (h)(4)(A), was in the original “this Act”, also meaning division C of "},{"tag":"ref","attrib":{"href":"/us/pl/108/324"},"text":"Pub. L. 108–324","children":[],"tail":" as provided in "},{"tag":"ref","attrib":{"href":"/us/pl/108/324/s2"},"text":"section 2 of Pub. L. 108–324","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1220"},"text":"118 Stat. 1220","children":[],"tail":". For complete classification of division C to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s720"},"text":"section 720 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reorganization Plan No. 1 of 1979, referred to in subsec. (f), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719e"},"text":"section 719e of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order No. 12142, referred to in subsec. (f), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719e"},"text":"section 719e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id794833b9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/148"},"text":"Pub. L. 109–148","children":[],"tail":" substituted “earlier” for “later”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794833ba-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id794833bb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
