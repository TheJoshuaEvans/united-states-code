{"tag":"section","attrib":{"id":"id7a57f672-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6406"},"text":null,"children":[{"tag":"num","attrib":{"value":"6406"},"text":"§ 6406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Council may bring suit in Federal court to compel compliance with an assessment levied by the Council under this chapter. A successful action for compliance under this section may also require payment by the defendant of the costs incurred by the Council in bringing such action.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a57f673-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/284/s7"},"text":"Pub. L. 104–284, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3374"},"text":"110 Stat. 3374","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
