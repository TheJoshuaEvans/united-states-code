{"tag":"section","attrib":{"id":"id7a15478f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112"},"text":null,"children":[{"tag":"num","attrib":{"value":"3112"},"text":"§ 3112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countercyclical employment policies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a154790-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programmatic entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any countercyclical efforts undertaken to aid in achieving the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3111"},"text":"section 3111 of this title","children":[],"tail":" shall consider for inclusion the following programmatic entities:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a154791-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerated public works, including the development of standby public works projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154792-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public service employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154793-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local grant programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154794-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the levels and duration of unemployment insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154795-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" skill training in both the private and public sectors, both as a general remedy and as a supplement to unemployment insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154796-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" youth employment programs as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3115"},"text":"section 3115 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154797-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community development programs to provide employment in activities of value to the States, local communities (including rural areas), and the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154798-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal procurement programs which are targeted on labor surplus areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154799-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" augmentation of other employment and training programs which would help to reduce high levels of unemployment arising from cyclical causes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a15479a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Triggering mechanism","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any countercyclical efforts undertaken, the President shall consider a triggering mechanism which will implement the program during a period of rising unemployment and phase out the program when unemployment is appropriately reduced, and incorporate effective means to facilitate individuals assisted under programs developed pursuant to this section to return promptly to regular private and public employment as the economy recovers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a15479b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/523/tII/s202"},"text":"Pub. L. 95–523, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1900"},"text":"92 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
