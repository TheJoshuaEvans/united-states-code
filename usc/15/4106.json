{"tag":"section","attrib":{"id":"id7a36b26a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106"},"text":null,"children":[{"tag":"num","attrib":{"value":"4106"},"text":"§ 4106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of Arctic research policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a36b26b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Science Foundation and Director; functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Science Foundation is designated as the lead agency responsible for implementing Arctic research policy, and the Director of the National Science Foundation shall insure that the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4107"},"text":"section 4107 of this title","children":[],"tail":" are fulfilled."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a36b26c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Arctic Research Policy Committee; establishment; represented agencies; Chairperson","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b26d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall establish an Interagency Arctic Research Policy Committee (hereinafter referred to as the “Interagency Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b26e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Interagency Committee shall be composed of representatives of the following Federal agencies or offices:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a36b26f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b270-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b271-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b272-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b273-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b274-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b275-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b276-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b277-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b278-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b279-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b27a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other agency or office deemed appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b27b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The representative of the National Science Foundation shall serve as the Chairperson of the Interagency Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a36b27c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373/tI/s107"},"text":"Pub. L. 98–373, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-31"},"text":"July 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1246"},"text":"98 Stat. 1246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s902/g"},"text":"Pub. L. 109–241, title IX, § 902(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/567"},"text":"120 Stat. 567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a36b27d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a36b27e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a36b27f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2)(I) to (L). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" added subpar. (I) and redesignated former subpars. (I) to (K) as (J) to (L), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a36b280-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a36b281-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Designation of the National Science and Technology Council to Coordinate Certain Activities Under the Arctic Research and Policy Act of 1984","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2010-07-22"},"text":"July 22, 2010","children":[],"tail":", 75 F.R. 44063, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Director of the Office of Science and Technology Policy","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States, including the Arctic Research and Policy Act of 1984 (Title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373"},"text":"Public Law 98–373","children":[],"tail":") (the “Act”), I hereby assign to the National Science and Technology Council (NSTC) responsibility to coordinate activities assigned in sections 107 and 108 of the Act to the Interagency Arctic Research Policy Committee, including through committees of the NSTC."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy is authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
