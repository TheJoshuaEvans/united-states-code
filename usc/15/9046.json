{"tag":"section","attrib":{"id":"id7a9f85e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046"},"text":null,"children":[{"tag":"num","attrib":{"value":"9046"},"text":"§ 9046.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of certain aviation excise taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9f85e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation by air","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any amount paid for transportation by air (including any amount treated as paid for transportation by air by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4261/e/3"},"text":"section 4261(e)(3) of title 26","children":[],"tail":") during the excise tax holiday period, no tax shall be imposed under section 4261 or 4271 of title 26. The preceding sentence shall not apply to amounts paid on or before "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f85e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Kerosene in commercial aviation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of kerosene used in commercial aviation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4083"},"text":"section 4083 of title 26","children":[],"tail":") during the excise tax holiday period—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f85e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" no tax shall be imposed on such kerosene under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f85e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4041/c"},"text":"section 4041(c) of title 26","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f85e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4081"},"text":"section 4081 of title 26","children":[],"tail":" (other than at the rate provided in subsection (a)(2)(B) thereof), and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f85e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" section 6427(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 26 shall be applied—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f85e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by treating such use as a nontaxable use, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f85ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to paragraph (4)(A)(ii) thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f85eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9046/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excise tax holiday period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “excise tax holiday period” means the period beginning after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and ending before "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9f85ec-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4007"},"text":"Pub. L. 116–136, div. A, title IV, § 4007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/477"},"text":"134 Stat. 477","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
