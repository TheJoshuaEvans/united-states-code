{"tag":"section","attrib":{"id":"id79672d8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191"},"text":null,"children":[{"tag":"num","attrib":{"value":"1191"},"text":"§ 1191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79672d90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means an individual, partnership, corporation, association, or any other form of business enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commerce” means commerce among the several States or with foreign nations or in any territory of the United States or in the District of Columbia or between any such territory and another, or between any such territory and any State or foreign nation, or between the District of Columbia or the Commonwealth of Puerto Rico and any State or territory or foreign nation, or between the Commonwealth of Puerto Rico and any State or territory or foreign nation or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “territory” includes the insular possessions of the United States and also any territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “article of wearing apparel” means any costume or article of clothing worn or intended to be worn by individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “interior furnishing” means any type of furnishing made in whole or in part of fabric or related material and intended for use or which may reasonably be expected to be used, in homes, offices, or other places of assembly or accommodation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fabric” means any material (except fiber, filament, or yarn for other than retail sale) woven, knitted, felted, or otherwise produced from or in combination with any natural or synthetic fiber, film, or substitute therefor which is intended for use or which may reasonably be expected to be used, in any product as defined in subsection (h).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “related material” means paper, plastic, rubber, synthetic film, or synthetic foam which is intended for use or which may reasonably be expected to be used in any product as defined in subsection (h).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “product” means any article of wearing apparel or interior furnishing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Consumer Product Safety Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79672d99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1191/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal Trade Commission Act” means the Act of Congress entitled “An Act to create a Federal Trade Commission, to define its powers and duties, and for other purposes”, approved ","children":[{"tag":"date","attrib":{"date":"1914-09-26"},"text":"September 26, 1914","children":[],"tail":", as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79672d9a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-06-30/ch164/s2"},"text":"June 30, 1953, ch. 164, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/111"},"text":"67 Stat. 111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/189/s1"},"text":"Pub. L. 90–189, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-14"},"text":"Dec. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/568"},"text":"81 Stat. 568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s204/c/2/A"},"text":"Pub. L. 110–314, title II, § 204(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3042"},"text":"122 Stat. 3042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79672d9b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79672d9c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79672d9d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in par. (j), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79672d9e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":" added par. (i) and struck out former par. (i) which read as follows: “The term ‘Commission’ means the Federal Trade Commission.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Par. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/189/s1/1"},"text":"Pub. L. 90–189, § 1(1)","children":[],"tail":", reduced from capital to lower-case the first letter of “territory” wherever appearing and redefined “commerce” to include commerce between the Commonwealth of Puerto Rico and any State or territory or foreign nation or the District of Columbia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/189/s1/2"},"text":"Pub. L. 90–189, § 1(2)","children":[],"tail":", reduced from capital to lower-case the first letter of “territory” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/189/s1/3"},"text":"Pub. L. 90–189, § 1(3)","children":[],"tail":", struck out provisions which excepted hats, gloves, and footwear from definition of “article of wearing apparel” provided that: such hats did not constitute or form part of a covering for the neck, face, or shoulders when worn by individuals; such gloves were not more than fourteen inches in length and were not affixed to or did not form an integral part of another garment; and such footwear did not consist of hosiery in whole or in part and was not affixed to or did not form an integral part of another garment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/189/s1/5"},"text":"Pub. L. 90–189, § 1(5)","children":[],"tail":", (6), added par. (e) and redesignated former par. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/189/s1/4"},"text":"Pub. L. 90–189, § 1(4)","children":[],"tail":", (5), (7), redesignated par. (e) as (f), substituted “(except fiber, filament, or yarn for other than retail sale)” for “(other than fiber, filament, or yarn)” and “for use or which may reasonably be expected to be used, in any product as defined in subsection (h)” for “or sold for use in wearing apparel except that interlining fabrics when intended or sold for use in wearing apparel shall not be subject to this chapter”, and struck out former par. (f) which defined “interlining”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (g) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/189/s1/5"},"text":"Pub. L. 90–189, § 1(5)","children":[],"tail":", (8), added pars. (g) and (h) and redesignated former pars. (g) and (h) as (i) and (j), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79672d9f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79672da0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-06-30/ch164/s12"},"text":"Act June 30, 1953, ch. 164, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/115"},"text":"67 Stat. 115","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1953-06-30/ch164/s12"},"text":"“This Act [enacting this chapter] shall take effect one year after the date of its passage [","children":[{"tag":"date","attrib":{"date":"1953-06-30"},"text":"June 30, 1953","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79672da1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-06-30/ch164/s1"},"text":"Act June 30, 1953, ch. 164, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/111"},"text":"67 Stat. 111","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1953-06-30/ch164/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Flammable Fabrics Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id79672da2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/189/s11"},"text":"Pub. L. 90–189, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-14"},"text":"Dec. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/574"},"text":"81 Stat. 574","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/189/s11"},"text":"“Notwithstanding the provisions of this Act [amending this section and sections 1192 to 1195, 1197, 1198, and 1200 of this title and enacting sections 1201 to 1204 of this title], the standards of flammability in effect under the provisions of the Flammable Fabrics Act, as amended [this chapter], on the day preceding the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1967-12-14"},"text":"Dec. 14, 1967","children":[],"tail":"], shall continue in effect for the fabrics and articles of wearing apparel to which they are applicable until superseded or modified by the Secretary of Commerce pursuant to the authority conferred by the amendments made by this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79672da3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-06-30/ch164/s13"},"text":"Act June 30, 1953, ch. 164, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/115"},"text":"67 Stat. 115","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/90/189/s9"},"text":"Pub. L. 90–189, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-14"},"text":"Dec. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/573"},"text":"81 Stat. 573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/542"},"text":"Pub. L. 92–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1108"},"text":"86 Stat. 1108","children":[],"tail":", appropriated $1,500,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1968-06-30"},"text":"June 30, 1968","children":[],"tail":", $2,250,000 each for the fiscal year ending "},{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", and the fiscal year ending "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":", and $4,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1973-06-30"},"text":"June 30, 1973","children":[],"tail":", to carry out the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79672da4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"COVID–19 Regulatory Relief and Work From Home Safety Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXXI/s2101"},"text":"Pub. L. 116–260, div. FF, title XXI, § 2101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3303"},"text":"134 Stat. 3303","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dFF/tXXI/s2101"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This title may be cited as the ‘COVID–19 Regulatory Relief and Work From Home Safety Act’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this Act [probably means “this title”]—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘bedding product’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an item that is used for sleeping or sleep-related purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any component or accessory with respect to an item described in subparagraph (A), without regard to whether the component or accessory, as applicable, is used—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alone; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" along with, or contained within, that item;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘California standard’ means the standard set forth by the Bureau of Electronic and Appliance Repair, Home Furnishings and Thermal Insulation of the Department of Consumer Affairs of the State of California in Technical Bulletin 117–2013, entitled ‘Requirements, Test Procedure and Apparatus for Testing the Smolder Resistance of Materials Used in Upholstered Furniture’, originally published June 2013, as in effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms ‘foundation’ and ‘mattress’ have the meanings given those terms in section 1633.2 of title 16, Code of Federal Regulations, as in effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘upholstered furniture’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an article of seating furniture that—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended for indoor use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is movable or stationary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is constructed with an upholstered seat, back, or arm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made or sold with a cushion or pillow, without regard to whether that cushion or pillow, as applicable, is attached or detached with respect to the article of furniture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stuffed or filled, or able to be stuffed or filled, in whole or in part, with any material, including a substance or material that is hidden or concealed by fabric or another covering, including a cushion or pillow belonging to, or forming a part of, the article of furniture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"“(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" together with the structural units of the article of furniture, any filling material, and the container and covering with respect to those structural units and that filling material, can be used as a support for the body of an individual, or the limbs and feet of an individual, when the individual sits in an upright or reclining position;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an article of furniture that is intended for use by a child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mattress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bedding product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furniture that is used exclusively for the purpose of physical fitness and exercise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adoption of Standard.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date that is 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"], and except as provided in paragraph (2), the California standard shall be considered to be a flammability standard promulgated by the Consumer Product Safety Commission under section 4 of the Flammable Fabrics Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1193"},"text":"15 U.S.C. 1193","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing and certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fabric, related material, or product to which the California standard applies as a result of paragraph (1) shall not be subject to section 14(a) of the Consumer Product Safety Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063/a"},"text":"15 U.S.C. 2063(a)","children":[],"tail":") with respect to that standard."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification label","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each manufacturer of a product that is subject to the California standard as a result of paragraph (1) shall include the statement ‘Complies with U.S. CPSC requirements for upholstered furniture flammability’ on a permanent label located on the product, which shall be considered to be a certification that the product complies with that standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 16 of the Flammable Fabrics Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1203"},"text":"15 U.S.C. 1203","children":[],"tail":") and section 231 of the Consumer Product Safety Improvement Act of 2008 ["},{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"15 U.S.C. 2051","children":[],"tail":" note), and except as provided in subparagraphs (B) and (C) of paragraph (2), no State or any political subdivision of a State may establish or continue in effect any provision of a flammability law, regulation, code, standard, or requirement that is designed to protect against the risk of occurrence of fire, or to slow or prevent the spread of fire, with respect to upholstered furniture."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of certain state law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act [probably means “this title”] or the Flammable Fabrics Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1191"},"text":"15 U.S.C. 1191","children":[],"tail":" et seq.) may be construed to preempt or otherwise affect—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any State or local law, regulation, code, standard, or requirement that—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concerns health risks associated with upholstered furniture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not designed to protect against the risk of occurrence of fire, or to slow or prevent the spread of fire, with respect to upholstered furniture;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1374 through 1374.3 of title 4, California Code of Regulations (except for subsections (b) and (c) of section 1374 of that title), as in effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the California standard.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79699da5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hazardous Substances","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Federal Hazardous Substances Act as not modifying this chapter or regulations promulgated thereunder, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s18"},"text":"Pub. L. 86–613, § 18","children":[],"tail":", (formerly § 17), "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/380"},"text":"74 Stat. 380","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/756/s4/a"},"text":"Pub. L. 89–756, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1305"},"text":"80 Stat. 1305","children":[],"tail":"; renumbered and amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/113/s4/a"},"text":"Pub. L. 91–113, § 4(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1969-11-06"},"text":"Nov. 6, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/190"},"text":"83 Stat. 190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261"},"text":"section 1261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
