{"tag":"section","attrib":{"id":"id796be875-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1213"},"text":null,"children":[{"tag":"num","attrib":{"value":"1213"},"text":"§ 1213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of safety standards in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Consumer Product Safety Commission shall prescribe and publish in the Federal Register commercial standards for devices which, when used in or on household refrigerators, will enable the doors thereof to be opened easily from the inside; and the standards first established under this section shall be so prescribed and published not later than one year after ","children":[{"tag":"date","attrib":{"date":"1956-08-02"},"text":"August 2, 1956","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796be876-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-02/ch890/s3"},"text":"Aug. 2, 1956, ch. 890, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/953"},"text":"70 Stat. 953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/573/s30/c"},"text":"Pub. L. 92–573, § 30(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1231"},"text":"86 Stat. 1231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be877-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796be878-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id796be879-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Consumer Product Safety Commission” substituted for “Secretary of Commerce” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s30/c"},"text":"section 30(c) of Pub. L. 92–573","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079/c"},"text":"section 2079(c) of this title","children":[],"tail":" and which transferred functions of Secretary of Commerce and Federal Trade Commission under this chapter to Consumer Product Safety Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
