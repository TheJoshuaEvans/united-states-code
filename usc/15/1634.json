{"tag":"section","attrib":{"id":"id798d52a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1634"},"text":null,"children":[{"tag":"num","attrib":{"value":"1634"},"text":"§ 1634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subsequent occurrence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If information disclosed in accordance with this part is subsequently rendered inaccurate as the result of any act, occurrence, or agreement subsequent to the delivery of the required disclosures, the inaccuracy resulting therefrom does not constitute a violation of this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id798d52aa-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s124"},"text":"Pub. L. 90–321, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/152"},"text":"82 Stat. 152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
