{"tag":"section","attrib":{"id":"id7a664dbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803"},"text":null,"children":[{"tag":"num","attrib":{"value":"6803"},"text":"§ 6803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of institution privacy policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a664dbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the time of establishing a customer relationship with a consumer and not less than annually during the continuation of such relationship, a financial institution shall provide a clear and conspicuous disclosure to such consumer, in writing or in electronic form or other form permitted by the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6804"},"text":"section 6804 of this title","children":[],"tail":", of such financial institution’s policies and practices with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a664dbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosing nonpublic personal information to affiliates and nonaffiliated third parties, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6802"},"text":"section 6802 of this title","children":[],"tail":", including the categories of information that may be disclosed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosing nonpublic personal information of persons who have ceased to be customers of the financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting the nonpublic personal information of consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a664dc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Disclosures required by subsection (a) shall be made in accordance with the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6804"},"text":"section 6804 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a664dc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The disclosure required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a664dc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the policies and practices of the institution with respect to disclosing nonpublic personal information to nonaffiliated third parties, other than agents of the institution, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6802"},"text":"section 6802 of this title","children":[],"tail":", and including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a664dc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the categories of persons to whom the information is or may be disclosed, other than the persons to whom the information may be provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6802/e"},"text":"section 6802(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664dc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies and practices of the institution with respect to disclosing of nonpublic personal information of persons who have ceased to be customers of the financial institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the categories of nonpublic personal information that are collected by the financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies that the institution maintains to protect the confidentiality and security of nonpublic personal information in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6801"},"text":"section 6801 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dc7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosures required, if any, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/d/2/A/iii"},"text":"section 1681a(d)(2)(A)(iii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a664dc8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for certified public accountants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a664dc9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The disclosure requirements of subsection (a) do not apply to any person, to the extent that the person is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a664dca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified public accountant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664dcb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified or licensed for such purpose by a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664dcc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to any provision of law, rule, or regulation issued by a legislative or regulatory body of the State, including rules of professional conduct or ethics, that prohibits disclosure of nonpublic personal information without the knowing and expressed consent of the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dcd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to exempt or otherwise exclude any financial institution that is affiliated or becomes affiliated with a certified public accountant described in paragraph (1) from any provision of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “State” means any State or territory of the United States, the District of Columbia, Puerto Rico, Guam, American Samoa, the Trust Territory of the Pacific Islands, the Virgin Islands, or the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a664dcf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model forms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a664dd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agencies referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6804/a/1"},"text":"section 6804(a)(1) of this title","children":[],"tail":" shall jointly develop a model form which may be used, at the option of the financial institution, for the provision of disclosures under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Format","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A model form developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a664dd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be comprehensible to consumers, with a clear format and design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664dd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for clear and conspicuous disclosures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664dd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable consumers easily to identify the sharing practices of a financial institution and to compare privacy practices among financial institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664dd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be succinct, and use an easily readable type font.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dd6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A model form required to be developed by this subsection shall be issued in proposed form for public comment not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dd7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any financial institution that elects to provide the model form developed by the agencies under this subsection shall be deemed to be in compliance with the disclosures required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a664dd8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to annual notice requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A financial institution that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a664dd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides nonpublic personal information only in accordance with the provisions of subsection (b)(2) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6802"},"text":"section 6802 of this title","children":[],"tail":" or regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6804/b"},"text":"section 6804(b) of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664dda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6803/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not changed its policies and practices with regard to disclosing nonpublic personal information from the policies and practices that were disclosed in the most recent disclosure sent to consumers in accordance with this section,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be required to provide an annual disclosure under this section until such time as the financial institution fails to comply with any criteria described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a664ddb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tV/s503"},"text":"Pub. L. 106–102, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1439"},"text":"113 Stat. 1439","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tVI/s609"},"text":"Pub. L. 109–351, title VI, § 609","children":[],"tail":", title VII, § 728, "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1983"},"text":"120 Stat. 1983","children":[],"tail":", 2003; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXV/s75001"},"text":"Pub. L. 114–94, div. G, title LXXV, § 75001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1787"},"text":"129 Stat. 1787","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a664ddc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a664ddd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a664dde-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" designated concluding provisions of subsec. (a) as (b), inserted heading, substituted “Disclosures required by subsection (a)” for “Such disclosures”, redesignated former subsec. (b) as (c), and added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a664ddf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a664de0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
