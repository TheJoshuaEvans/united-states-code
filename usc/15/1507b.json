{"tag":"section","attrib":{"id":"id797efad8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1507b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507b"},"text":"§ 1507b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary of Commerce; appointment; compensation; duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Commerce, in addition to the Assistant Secretaries provided by law as of ","children":[{"tag":"date","attrib":{"date":"1977-11-12"},"text":"November 12, 1977","children":[],"tail":", one additional Assistant Secretary of Commerce who shall be appointed by the President, by and with the advice and consent of the Senate. Such Assistant Secretary shall perform such duties as the Secretary of Commerce shall prescribe."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797efad9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/173/s9/a"},"text":"Pub. L. 95–173, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-12"},"text":"Nov. 12, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1360"},"text":"91 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/195/s1/c/4"},"text":"Pub. L. 97–195, § 1(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-06-16"},"text":"June 16, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/115"},"text":"96 Stat. 115","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797efada-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797efadb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id797efadc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/195"},"text":"Pub. L. 97–195","children":[],"tail":" substituted “Such Assistant Secretary shall perform such duties” for “Such Assistant Secretary shall receive compensation at the rate prescribed by law for Assistant Secretaries of Commerce, and shall perform such duties”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
