{"tag":"section","attrib":{"id":"id799df55e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1666g"},"text":"§ 1666g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tie-in services prohibited for issuance of credit card","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any agreement to the contrary, a card issuer may not require a seller, as a condition to participating in a credit card plan, to open an account with or procure any other service from the card issuer or its subsidiary or agent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799df55f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s168"},"text":"Pub. L. 90–321, title I, § 168","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIII/s306"},"text":"Pub. L. 93–495, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1515"},"text":"88 Stat. 1515","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
