{"tag":"section","attrib":{"id":"id7a9d3c6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041"},"text":null,"children":[{"tag":"num","attrib":{"value":"9041"},"text":"§ 9041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air carrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “air carrier” has the meaning such term has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coronavirus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coronavirus” means SARS–CoV–2 or another coronavirus with pandemic potential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered loss” includes losses incurred directly or indirectly as a result of coronavirus, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible business” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States business that has not otherwise received adequate economic relief in the form of loans or loan guarantees provided under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except where the context otherwise requires, the term “employee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s152"},"text":"section 152 of title 29","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any individual employed by an employer subject to the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity security; exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “equity security” and “exchange” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Municipality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “municipality” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an instrumentality of a municipality, a State, or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National securities exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national securities exchange” means an exchange registered as a national securities exchange under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78f"},"text":"section 78f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury, or the designee of the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the several States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the territories and possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bi-State or multi-State entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9041/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aerospace-related businesses critical to maintaining national security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “businesses critical to maintaining national security” means those businesses that manufacture or produce aerospace-related products, civil or defense, including those that design, integrate, assemble, supply, maintain, and repair such products, and other businesses involved in aerospace-related manufacturing or production as further defined by the Secretary, in consultation with the Secretary of Defense and the Secretary of Transportation. For purposes of the preceding sentence, aerospace-related products include, but are not limited to, components, parts, or systems of aircraft, aircraft engines, or appliances for inclusion in an aircraft, aircraft engine, or appliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9d3c82-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4002"},"text":"Pub. L. 116–136, div. A, title IV, § 4002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/469"},"text":"134 Stat. 469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIV/s412/c"},"text":"Pub. L. 116–260, div. N, title IV, § 412(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2061"},"text":"134 Stat. 2061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9d3c83-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9d3c84-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9d3c85-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this subtitle”, meaning subtitle A (§§ 4001–4029) of title IV of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", known as the Coronavirus Economic Stabilization Act of 2020, which is classified principally to this part. For complete classification of subtitle A to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4001"},"text":"section 4001 of Pub. L. 116–136","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":", and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (4)(B), probably means subtitle A (§§ 4001–4029) of title IV of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", known as the Coronavirus Economic Stabilization Act of 2020, which is classified principally to this part. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4001"},"text":"section 4001 of Pub. L. 116–136","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":", and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Railway Labor Act, referred to in par. (5)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347"},"text":"act May 20, 1926, ch. 347","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":", which is classified principally to chapter 8 (§ 151 et seq.) of Title 45, Railroads. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"section 151 of Title 45","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a9d3c86-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added par. (11)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
