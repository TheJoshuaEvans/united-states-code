{"tag":"section","attrib":{"id":"id7a1c72d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374"},"text":null,"children":[{"tag":"num","attrib":{"value":"3374"},"text":"§ 3374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clauses prohibiting certain sales, transportation, and commingling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1c72d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any provision of any contract for the first sale of natural gas is hereby declared against public policy and unenforceable with respect to any natural gas covered by this chapter if such provision—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c72d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits the commingling of natural gas subject to such contract with natural gas subject to the jurisdiction of the Commission under the provisions of the Natural Gas Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s717"},"text":"15 U.S.C. 717","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c72d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits the sale of any natural gas subject to such contract to, or transportation of any such natural gas by, any person subject to the jurisdiction of the Commission under the Natural Gas Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s717"},"text":"15 U.S.C. 717","children":[],"tail":" et seq.], or otherwise prohibits the sale or transportation in interstate commerce (within the meaning of the Natural Gas Act) of natural gas subject to such contract; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c72da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminates, or grants any party the option to terminate, any obligation under any such contract as a result of such commingling, sale, or transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c72db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural gas covered by this chapter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “natural gas covered by this chapter” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c72dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural gas which is not committed or dedicated to interstate commerce as of ","children":[{"tag":"date","attrib":{"date":"1978-11-08"},"text":"November 8, 1978","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c72dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" natural gas, the sale in interstate commerce of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1c72de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized under section 3362(a) or 3371(b) of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c72df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is pursuant to an assignment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3372/a"},"text":"section 3372(a) of this title","children":[],"tail":"; and,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c72e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" natural gas, the transportation in interstate commerce of which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1c72e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to any order under section 3362(c) or section 3363(b), (c), (d), or (h) of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c72e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3374/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3371/a"},"text":"section 3371(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c72e3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tIII/s314"},"text":"Pub. L. 95–621, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3392"},"text":"92 Stat. 3392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1c72e4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1c72e5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1c72e6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Natural Gas Act, referred to in subsec. (a)(1), (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556"},"text":"act June 21, 1938, ch. 556","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/821"},"text":"52 Stat. 821","children":[],"tail":", which is classified generally to chapter 15B (§ 717 et seq.) of this title. For complete classification of this act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717w"},"text":"section 717w of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
