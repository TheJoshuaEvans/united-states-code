{"tag":"section","attrib":{"id":"id7aa44157-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071"},"text":null,"children":[{"tag":"num","attrib":{"value":"9071"},"text":"§ 9071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Unless otherwise specified, the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":" shall apply to this part, except that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44158-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “airline catering employee” means an employee who performs airline catering services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44159-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “airline catering services” means preparation, assembly, or both, of food, beverages, provisions and related supplies for delivery, and the delivery of such items, directly to aircraft or to a location on or near airport property for subsequent delivery to aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4415a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “contractor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa4415b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person that performs, under contract with a passenger air carrier conducting operations under part 121 of title 14, Code of Federal Regulations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa4415c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" catering functions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa4415d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" functions on the property of an airport that are directly related to the air transportation of persons, property, or mail, including but not limited to the loading and unloading of property on aircraft; assistance to passengers under part 382 of title 14, Code of Federal Regulations; security; airport ticketing and check-in functions; ground-handling of aircraft; or aircraft cleaning and sanitization functions and waste removal; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa4415e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subcontractor that performs such functions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4415f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” means an individual, other than a corporate officer, who is employed by an air carrier or a contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44160-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “recall” means the dispatch of a notice by a contractor, via mail, courier, or electronic mail, to an involuntarily furloughed employee notifying the employee that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa44161-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the employee must, within a specified period of time that is not less than 14 days, elect either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa44162-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to return to employment or bypass return to employment in accordance with an applicable collective bargaining agreement or, in the absence of a collective bargaining agreement, company policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa44163-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permanently separate from employment with the contractor; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa44164-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to respond within such time period specified will be deemed to be an election under subparagraph (A)(ii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44165-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9071/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa44166-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4111"},"text":"Pub. L. 116–136, div. A, title IV, § 4111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/497"},"text":"134 Stat. 497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIV/s412/b"},"text":"Pub. L. 116–260, div. N, title IV, § 412(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2061"},"text":"134 Stat. 2061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa44167-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa44168-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7aa44169-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Pars. (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
