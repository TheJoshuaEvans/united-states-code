{"tag":"section","attrib":{"id":"id7a87b82a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8513"},"text":null,"children":[{"tag":"num","attrib":{"value":"8513"},"text":"§ 8513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tornado warning improvement and extension program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b82b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary, in collaboration with the United States weather industry and academic partners, shall establish a tornado warning improvement and extension program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b82c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The goal of such program shall be to reduce the loss of life and economic losses from tornadoes through the development and extension of accurate, effective, and timely tornado forecasts, predictions, and warnings, including the prediction of tornadoes beyond 1 hour in advance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b82d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative observations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall ensure that the program periodically examines the value of incorporating innovative observations, such as acoustic or infrasonic measurements, observations from phased array radars, and observations from mesonets, with respect to the improvement of tornado forecasts, predictions, and warnings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b82e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-04-18"},"text":"April 18, 2017","children":[],"tail":", the Assistant Administrator for Oceanic and Atmospheric Research, in coordination with the Director of the National Weather Service, shall develop a program plan that details the specific research, development, and technology transfer activities, as well as corresponding resources and timelines, necessary to achieve the program goal."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b82f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual budget for plan submittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following completion of the plan, the Under Secretary, acting through the Assistant Administrator for Oceanic and Atmospheric Research and in coordination with the Director of the National Weather Service, shall, not less frequently than once each year, submit to Congress a proposed budget corresponding with the activities identified in the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b830-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tI/s103"},"text":"Pub. L. 115–25, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/94"},"text":"131 Stat. 94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/316/s8"},"text":"Pub. L. 117–316, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4412"},"text":"136 Stat. 4412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a87b831-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a87b832-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a87b833-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316"},"text":"Pub. L. 117–316","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
