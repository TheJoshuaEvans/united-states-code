{"tag":"section","attrib":{"id":"id791d5399-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u"},"text":null,"children":[{"tag":"num","attrib":{"value":"657u"},"text":"§ 657u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lender Oversight Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791d539a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Administration the Lender Oversight Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d539b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall consist of at least 8 members selected by the Administrator, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d539c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members shall be voting members, 2 of whom shall be career appointees in the Senior Executive Service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132"},"text":"section 3132 of title 5","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d539d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining members shall be nonvoting members who shall serve in an advisory capacity on the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d539e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d539f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review reports on lender oversight activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d53a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review formal enforcement action recommendations of the Director of the Office of Credit Risk Management with respect to any lender making loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"section 636(a) of this title","children":[],"tail":" and any Lending Partner or Intermediary participant of the Administration in a lending program of the Office of Capital Access of the Administration;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791f9c91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out paragraph (2) with respect to formal enforcement actions taken under subsection (d) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s650"},"text":"section 650 of this title","children":[],"tail":", vote to recommend or not recommend action to the Administrator or a designee of the Administrator;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791f9c92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out paragraph (2) with respect to any formal enforcement action not specified under subsection (d) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s650"},"text":"section 650 of this title","children":[],"tail":", vote to approve, disapprove, or modify the action;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791f9c93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, in an advisory capacity, any lender oversight, portfolio risk management, or program integrity matters brought by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791f9c94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other actions and perform such other functions as may be delegated to the Committee by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791f9c95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791f9c96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet as necessary, but not less frequently than on a quarterly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791f9c97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657u/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall submit to the Administrator a report detailing each meeting of the Committee, including if the Committee does or does not vote to approve a formal enforcement action of the Director of the Office of Credit Risk Management with respect to a lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791f9c98-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s48"},"text":"Pub. L. 85–536, § 2[48]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/a/2"},"text":"Pub. L. 115–189, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1494"},"text":"132 Stat. 1494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791f9c99-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id791f9c9a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id791f9c9b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/d/2"},"text":"Pub. L. 115–189, § 3(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1496"},"text":"132 Stat. 1496","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/189/s3/d/2"},"text":"“Any reference in a law, regulation, guidance, document, paper, or other record of the United States to the Lender Oversight Committee of the Small Business Administration shall be deemed a reference to the Lender Oversight Committee, established under section 48 of the Small Business Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657u"},"text":"15 U.S.C. 657u","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id791f9c9c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/c/2"},"text":"Pub. L. 115–189, § 3(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1496"},"text":"132 Stat. 1496","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/189/s3/c/2"},"text":"“All functions of the Lender Oversight Committee of the Small Business Administration, including the personnel, assets, and obligations of the Lender Oversight Committee, as in existence on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":"], shall be transferred to the Lender Oversight Committee established under section 48 of the Small Business Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s657u"},"text":"15 U.S.C. 657u","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
