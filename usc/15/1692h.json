{"tag":"section","attrib":{"id":"id79b833e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1692h"},"text":"§ 1692h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple debts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any consumer owes multiple debts and makes any single payment to any debt collector with respect to such debts, such debt collector may not apply such payment to any debt which is disputed by the consumer and, where applicable, shall apply such payment in accordance with the consumer’s directions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79b833e9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVIII/s810"},"text":"Pub. L. 90–321, title VIII, § 810","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/880"},"text":"91 Stat. 880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b833ea-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b833eb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79b833ec-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of six months after ","children":[{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s819"},"text":"section 819 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692"},"text":"section 1692 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
