{"tag":"section","attrib":{"id":"id788e3264-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s276"},"text":null,"children":[{"tag":"num","attrib":{"value":"276"},"text":"§ 276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership of facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the absence of specific agreement to the contrary, additional facilities, including equipment, purchased pursuant to the performance of services authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s273"},"text":"section 273 of this title","children":[],"tail":" shall become the property of the Department of Commerce."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788e3265-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s8"},"text":"Mar. 3, 1901, ch. 872, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1450"},"text":"31 Stat. 1450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/ch314"},"text":"June 30, 1932, ch. 314","children":[],"tail":", pt. II, title III, § 312, "},{"tag":"ref","attrib":{"href":"/us/stat/47/410"},"text":"47 Stat. 410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch906/s1"},"text":"Aug. 3, 1956, ch. 906, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/959"},"text":"70 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788e3266-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788e3267-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic