{"tag":"section","attrib":{"id":"id79293a68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689j"},"text":null,"children":[{"tag":"num","attrib":{"value":"689j"},"text":"§ 689j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each New Markets Venture Capital company that participates in the program established under this part shall provide to the Administrator such information as the Administrator may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information related to the measurement criteria that the company proposed in its program application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each case in which the company under this part makes an investment in, or a loan or grant to, a business that is not located in a low-income geographic area, a report on the number and percentage of employees of the business who reside in such areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293a6b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s361"},"text":"Pub. L. 85–699, title III, § 361","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–661.)"}],"tail":"\n"}],"tail":null}
