{"tag":"section","attrib":{"id":"id79ef222c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2504"},"text":null,"children":[{"tag":"num","attrib":{"value":"2504"},"text":"§ 2504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination between Secretary of Energy and other agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ef222d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Secretary of Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the project established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2503"},"text":"section 2503 of this title","children":[],"tail":", the Secretary of Energy shall, to the maximum extent practicable, consult and coordinate with the Secretary of Transportation, with respect to any functions of the Secretary of Energy under this chapter which relate to regulatory activities or other responsibilities of the Secretary of Transportation, including safety and damageability programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ef222e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each department, agency, and instrumentality of the executive branch of the Federal Government shall carefully consider any written request from the Secretary of Energy, or the head of any agency to which the Secretary of Energy has delegated responsibility for specified parts or aspects of the project, to furnish such assistance, on a reimbursable basis, as the Secretary of Energy or such head deems necessary to carry out the project and to achieve the purposes of this chapter. Such assistance may include transfer of personnel with their consent and without prejudice to their position and rating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ef222f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/413/s5"},"text":"Pub. L. 94–413, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-17"},"text":"Sept. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1262"},"text":"90 Stat. 1262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIII/s301/a"},"text":"Pub. L. 95–91, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/577"},"text":"91 Stat. 577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ef2230-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ef2231-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79ef2232-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “Secretary of Transportation” substituted for “Secretary” for clarity, see Codification note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2502"},"text":"section 2502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ef2233-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79ef2234-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Energy” substituted in text for “Administrator” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/s301/a"},"text":"section 301(a) of Pub. L. 95–91","children":[],"tail":", see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2502"},"text":"section 2502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
