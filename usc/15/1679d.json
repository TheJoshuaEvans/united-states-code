{"tag":"section","attrib":{"id":"id79a2d67e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679d"},"text":"§ 1679d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit repair organizations contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a2d67f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written contracts required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No services may be provided by any credit repair organization for any consumer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d680-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless a written and dated contract (for the purchase of such services) which meets the requirements of subsection (b) has been signed by the consumer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d681-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the end of the 3-business-day period beginning on the date the contract is signed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d682-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No contract referred to in subsection (a) meets the requirements of this subsection unless such contract includes (in writing)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d683-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions of payment, including the total amount of all payments to be made by the consumer to the credit repair organization or to any other person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d684-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a full and detailed description of the services to be performed by the credit repair organization for the consumer, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a2d685-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all guarantees of performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d686-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an estimate of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a2d687-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date by which the performance of the services (to be performed by the credit repair organization or any other person) will be complete; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a2d688-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of the period necessary to perform such services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d689-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credit repair organization’s name and principal business address; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d68a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conspicuous statement in bold face type, in immediate proximity to the space reserved for the consumer’s signature on the contract, which reads as follows: “You may cancel this contract without penalty or obligation at any time before midnight of the 3rd business day after the date on which you signed the contract. See the attached notice of cancellation form for an explanation of this right.”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a2d68b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s406"},"text":"Pub. L. 90–321, title IV, § 406","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-458"},"text":"110 Stat. 3009–458","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2d68c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a2d68d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79a2d68e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/s406"},"text":"section 406 of Pub. L. 90–321","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a2d68f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a2d690-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable after the end of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", except with respect to contracts entered into by a credit repair organization before the end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s413"},"text":"section 413 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
