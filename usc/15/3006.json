{"tag":"section","attrib":{"id":"id7a12d69f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3006"},"text":null,"children":[{"tag":"num","attrib":{"value":"3006"},"text":"§ 3006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a12d6a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parties; remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The host State, the host racing association, or the horsemen’s group may commence a civil action against any person alleged to be in violation of this chapter, for injunctive relief to restrain violations and for damages in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3005"},"text":"section 3005 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any civil action under this section, the host State, the host racing association and horsemen’s group, if not a party, shall be permitted to intervene as a matter of right.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action may not be commenced pursuant to this section more than 3 years after the discovery of the alleged violation upon which such civil action is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3006/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State as defendant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to permit a State to be sued under this section other than in accordance with its applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a12d6a4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/515/s7"},"text":"Pub. L. 95–515, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1814"},"text":"92 Stat. 1814","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
