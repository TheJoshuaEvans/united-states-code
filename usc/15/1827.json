{"tag":"section","attrib":{"id":"id79c68b4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1827"},"text":null,"children":[{"tag":"num","attrib":{"value":"1827"},"text":"§ 1827.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of personnel of Department of Agriculture and officers and employees of consenting States; technical and other nonfinancial assistance to State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c68b4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1827/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from Department of Agriculture and States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in carrying out the provisions of this chapter, shall utilize, to the maximum extent practicable, the existing personnel and facilities of the Department of Agriculture. The Secretary is further authorized to utilize the officers and employees of any State, with its consent, and with or without reimbursement, to assist him in carrying out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c68b50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1827/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, upon request, provide technical and other nonfinancial assistance (including the lending of equipment on such terms and conditions as the Secretary determines is appropriate) to any State to assist it in administering and enforcing any law of such State designed to prohibit conduct described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1824"},"text":"section 1824 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c68b51-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/540/s8"},"text":"Pub. L. 91–540, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-09"},"text":"Dec. 9, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1406"},"text":"84 Stat. 1406","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/360/s8"},"text":"Pub. L. 94–360, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-13"},"text":"July 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/920"},"text":"90 Stat. 920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c68b52-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c68b53-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c68b54-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/360"},"text":"Pub. L. 94–360","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
