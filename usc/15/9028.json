{"tag":"section","attrib":{"id":"id7a9d3c06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028"},"text":null,"children":[{"tag":"num","attrib":{"value":"9028"},"text":"§ 9028.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for short-time compensation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9d3c07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For implementation or improved administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to States that enact short-time compensation programs (as defined in subsection (i)(2)) for the purpose of implementation or improved administration of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" For promotion and enrollment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to States that are eligible and submit plans for a grant under paragraph (1) for such States to promote and enroll employers in short-time compensation programs (as so defined).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine eligibility criteria for the grants under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State administering a short-time compensation program that does not meet the definition of a short-time compensation program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":", and a State with an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9027"},"text":"section 9027 of this title","children":[],"tail":", shall not be eligible to receive a grant under this section until such time as the State law of the State provides for payments under a short-time compensation program that meets such definition and such law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum amount available for making grants to a State under paragraphs (1) and (2) shall be equal to the amount obtained by multiplying $100,000,000 (less the amount used by the Secretary under subsection (e)) by the same ratio as would apply under subsection (a)(2)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1103"},"text":"section 1103 of title 42","children":[],"tail":" for purposes of determining such State’s share of any excess amount (as described in subsection (a)(1) of such section) that would have been subject to transfer to State accounts, as of "},{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":", under the provisions of subsection (a) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount available for different grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the maximum incentive payment determined under paragraph (1) with respect to a State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-third shall be available for a grant under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two-thirds shall be available for a grant under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant application and disbursal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State seeking a grant under paragraph (1) or (2) of subsection (a) shall submit an application to the Secretary at such time, in such manner, and complete with such information as the Secretary may require. In no case may the Secretary award a grant under this section with respect to an application that is submitted after ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, within 30 days after receiving a complete application, notify the State agency of the State of the Secretary’s findings with respect to the requirements for a grant under paragraph (1) or (2) (or both) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that the State law provisions meet the requirements for a grant under subsection (a), the Secretary shall thereupon make a certification to that effect to the Secretary of the Treasury, together with a certification as to the amount of the grant payment to be transferred to the State account in the Unemployment Trust Fund (as established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1104/a"},"text":"section 1104(a) of title 42","children":[],"tail":") pursuant to that finding. The Secretary of the Treasury shall make the appropriate transfer to the State account within 7 days after receiving such certification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No certification of compliance with the requirements for a grant under paragraph (1) or (2) of subsection (a) may be made with respect to any State whose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State law is not otherwise eligible for certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s503"},"text":"section 503 of title 42","children":[],"tail":" or approvable under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of title 26","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short-time compensation program is subject to discontinuation or is not scheduled to take effect within 12 months of the certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of any grant awarded under this section shall be used for the implementation of short-time compensation programs and the overall administration of such programs and the promotion and enrollment efforts associated with such programs, such as through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation or support of rapid response teams to advise employers about alternatives to layoffs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of education or assistance to employers to enable them to assess the feasibility of participating in short-time compensation programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development or enhancement of systems to automate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3c1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission and approval of plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3c1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the filing and approval of new and ongoing short-time compensation claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to use 0.25 percent of the funds available under subsection (g) to provide for outreach and to share best practices with respect to this section and short-time compensation programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recoupment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a process under which the Secretary shall recoup the amount of any grant awarded under paragraph (1) or (2) of subsection (a) if the Secretary determines that, during the 5-year period beginning on the first date that any such grant is awarded to the State, the State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminated the State’s short-time compensation program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to meet appropriate requirements with respect to such program (as established by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are appropriated, out of moneys in the Treasury not otherwise appropriated, to the Secretary, $100,000,000 to carry out this section, to remain available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish reporting requirements for States receiving a grant under this section in order to provide oversight of grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3c26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-time compensation program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “short-time compensation program” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3c28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9028/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State; State agency; State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “State”, “State agency”, and “State law” have the meanings given those terms in section 205 of the Federal-State Extended Unemployment Compensation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"26 U.S.C. 3304","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9d3c29-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2110"},"text":"Pub. L. 116–136, div. A, title II, § 2110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/331"},"text":"134 Stat. 331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9d3c2a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9d3c2b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9d3c2c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205 of the Federal-State Extended Unemployment Compensation Act of 1970, referred to in subsec. (i)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s205"},"text":"section 205 of Pub. L. 91–373","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
