{"tag":"section","attrib":{"id":"id787fda24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a"},"text":null,"children":[{"tag":"num","attrib":{"value":"80b–10a"},"text":"§ 80b–10a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787fda25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination results and other information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787fda26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The appropriate Federal banking agency shall provide the Commission upon request the results of any examination, reports, records, or other information to which such agency may have access—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787fda27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the investment advisory activities of any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id787fda28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bank holding company or savings and loan holding company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id787fda29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id787fda2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separately identifiable department or division of a bank,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that is registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787fda2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a bank holding company or savings and loan holding company or bank that has a subsidiary or a separately identifiable department or division registered under that section, with respect to the investment advisory activities of such bank or bank holding company or savings and loan holding company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787fda2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall provide to the appropriate Federal banking agency upon request the results of any examination, reports, records, or other information with respect to the investment advisory activities of any bank holding company or savings and loan holding company, bank, or separately identifiable department or division of a bank, which is registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787fda2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Commission and the appropriate Federal banking agencies shall not be compelled to disclose any information provided under paragraph (1) or (2). Nothing in this paragraph shall authorize the Commission or such agencies to withhold information from Congress, or prevent the Commission or such agencies from complying with a request for information from any other Federal department or agency or any self-regulatory organization requesting the information for purposes within the scope of its jurisdiction, or complying with an order of a court of the United States in an action brought by the United States, the Commission, or such agencies. For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", this paragraph shall be considered a statute described in subsection (b)(3)(B) of such section 552."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787fda2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall limit in any respect the authority of the appropriate Federal banking agency with respect to such bank holding company or savings and loan holding company (or affiliates or subsidiaries thereof), bank, or subsidiary, department, or division or a bank under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787fda2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–10a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “appropriate Federal banking agency” shall have the same meaning as given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787fda30-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title II, § 210A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tII/s220"},"text":"Pub. L. 106–102, title II, § 220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1400"},"text":"113 Stat. 1400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tIV/s401/b/2"},"text":"Pub. L. 109–351, title IV, § 401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1973"},"text":"120 Stat. 1973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787fda31-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787fda32-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787fda33-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" substituted “bank holding company or savings and loan holding company” for “bank holding company” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787fda34-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id787fda35-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 18 months after ","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/s225"},"text":"section 225 of Pub. L. 106–102","children":[],"tail":", set out as an Effective Date of 1999 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c"},"text":"section 77c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
