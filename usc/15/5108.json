{"tag":"section","attrib":{"id":"id7a49c544-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5108"},"text":null,"children":[{"tag":"num","attrib":{"value":"5108"},"text":"§ 5108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this chapter $12,000,000 for each of the fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a49c545-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/680/s9"},"text":"Pub. L. 100–680, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4076"},"text":"102 Stat. 4076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2106/a/3"},"text":"Pub. L. 102–486, title XXI, § 2106(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3070"},"text":"106 Stat. 3070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/229/tVI/s602/a"},"text":"Pub. L. 110–229, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-08"},"text":"May 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/853"},"text":"122 Stat. 853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a49c546-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a49c547-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"