{"tag":"section","attrib":{"id":"id7897a86b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278o"},"text":null,"children":[{"tag":"num","attrib":{"value":"278o"},"text":"§ 278o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Institute shall not implement a policy of charging fees with respect to the use of Institute research facilities by research associates in the absence of express statutory authority to charge such fees.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7897a86c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s30"},"text":"Mar. 3, 1901, ch. 872, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5161"},"text":"Pub. L. 100–418, title V, § 5161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1450"},"text":"102 Stat. 1450","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
