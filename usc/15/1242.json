{"tag":"section","attrib":{"id":"id796be8eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1242"},"text":null,"children":[{"tag":"num","attrib":{"value":"1242"},"text":"§ 1242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Introduction, manufacture for introduction, transportation or distribution in interstate commerce; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly introduces, or manufactures for introduction, into interstate commerce, or transports or distributes in interstate commerce, any switchblade knife, shall be fined not more than $2,000 or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796be8ec-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623/s2"},"text":"Pub. L. 85–623, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/562"},"text":"72 Stat. 562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be8ed-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796be8ee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id796be8ef-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":", see "