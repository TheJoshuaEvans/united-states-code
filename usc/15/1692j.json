{"tag":"section","attrib":{"id":"id79b833f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1692j"},"text":"§ 1692j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furnishing certain deceptive forms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b833f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is unlawful to design, compile, and furnish any form knowing that such form would be used to create the false belief in a consumer that a person other than the creditor of such consumer is participating in the collection of or in an attempt to collect a debt such consumer allegedly owes such creditor, when in fact such person is not so participating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b833fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who violates this section shall be liable to the same extent and in the same manner as a debt collector is liable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692k"},"text":"section 1692k of this title","children":[],"tail":" for failure to comply with a provision of this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b833fb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVIII/s812"},"text":"Pub. L. 90–321, title VIII, § 812","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/880"},"text":"91 Stat. 880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b833fc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b833fd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79b833fe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of six months after ","children":[{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s819"},"text":"section 819 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692"},"text":"section 1692 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
