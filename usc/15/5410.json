{"tag":"section","attrib":{"id":"id7a4c0f72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5410"},"text":null,"children":[{"tag":"num","attrib":{"value":"5410"},"text":"§ 5410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to preempt any rights or causes of action that any buyer may have with respect to any seller of fasteners under the law of any State, except to the extent that the provisions of this chapter are in conflict with such State law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a4c0f73-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s8"},"text":"Pub. L. 101–592, § 8","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2952"},"text":"104 Stat. 2952","children":[],"tail":"; renumbered § 8, "},{"tag":"ref","attrib":{"href":"/us/pl/106/34/s8"},"text":"Pub. L. 106–34, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/123"},"text":"113 Stat. 123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4c0f74-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4c0f75-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a4c0f76-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"head