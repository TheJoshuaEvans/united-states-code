{"tag":"section","attrib":{"id":"id791d52f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r"},"text":null,"children":[{"tag":"num","attrib":{"value":"657r"},"text":"§ 657r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentor-protege programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791d52f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d52f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is authorized to establish a mentor-protege program for all small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model for program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The mentor-protege program established under paragraph (1) shall be identical to the mentor-protege program of the Administration for small business concerns that participate in the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"section 637(a) of this title","children":[],"tail":" (as in effect on "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":"), except that the Administrator may modify the program to the extent necessary given the types of small business concerns included as proteges."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Puerto Rico businesses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"August 13, 2018","children":[],"tail":", and ending on the date on which the Oversight Board established under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s2121"},"text":"section 2121 of title 48","children":[],"tail":" terminates, the Administrator shall identify potential incentives to a covered mentor that awards a subcontract to its covered protege, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d52f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positive consideration in any past performance evaluation of the covered mentor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of costs incurred for providing training to such covered protege to the subcontracting plan (as required under paragraph (4) or (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"section 637(d) of this title","children":[],"tail":") of the covered mentor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered territory businesses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", and ending on the date that is 4 years after such date, the Administrator shall identify potential incentives to a covered territory mentor that awards a subcontract to its covered territory protege, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d52f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positive consideration in any past performance evaluation of the covered territory mentor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of costs incurred for providing training to such covered territory protege to the subcontracting plan (as required under paragraph (4) or (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"section 637(d) of this title","children":[],"tail":") of the covered territory mentor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d52fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs of other agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d52fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (4), a Federal department or agency may not carry out a mentor-protege program for small business concerns unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d52fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the department or agency submits a plan to the Administrator for the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator approves such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall approve or disapprove a plan submitted under paragraph (1) based on whether the program proposed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5300-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will assist proteges to compete for Federal prime contracts and subcontracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5301-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with the regulations issued under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5302-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", the Administrator shall issue, subject to notice and comment, regulations with respect to mentor-protege programs, which shall ensure that such programs improve the ability of proteges to compete for Federal prime contracts and subcontracts and which shall address, at a minimum, the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5303-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Eligibility criteria for program participants, including any restrictions on the number of mentor-protege relationships permitted for each participant, except that such restrictions shall not apply to up to 2 mentor-protege relationships if such relationships—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791d5304-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are between a covered protege and a covered mentor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d5305-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are between a covered territory protege and a covered territory mentor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5306-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of developmental assistance to be provided by mentors, including how the assistance provided shall improve the competitive viability of the proteges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5307-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether any developmental assistance provided by a mentor may affect the status of a program participant as a small business concern due to affiliation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5308-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The length of mentor-protege relationships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5309-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effect of mentor-protege relationships on contracting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d530a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefits that may accrue to a mentor as a result of program participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d530b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reporting requirements during program participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d530c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Postparticipation reporting requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d530d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The need for a mentor-protege pair, if accepted to participate as a pair in a mentor-protege program of any Federal department or agency, to be accepted to participate as a pair in all Federal mentor-protege programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d530e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Actions to be taken to ensure benefits for proteges and to protect a protege against actions by a mentor that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791d530f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adversely affect the protege’s status as a small business concern; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d5310-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide disproportionate economic benefits to the mentor relative to those provided the protege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5311-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The types of assistance provided by a mentor to assist with compliance with the requirements of contracting with the Federal Government after award of a contract or subcontract under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5312-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not apply to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5313-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any mentor-protege program of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5314-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any mentoring assistance provided under a Small Business Innovation Research Program or a Small Business Technology Transfer Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5315-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until the date that is 1 year after the date on which the Administrator issues regulations under paragraph (3), any Federal department or agency operating a mentor-protege program in effect on ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5316-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5317-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", and annually thereafter, the Administrator shall submit to the Committee on Small Business of the House of Representatives and the Committee on Small Business and Entrepreneurship of the Senate a report that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5318-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each Federal mentor-protege program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5319-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specifies the number of participants in each such program, including the number of participants that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791d531a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d531b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns owned and controlled by service-disabled veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d531c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified HUBZone small business concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d531d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns owned and controlled by socially and economically disadvantaged individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d531e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns owned and controlled by women;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d531f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the type of assistance provided to proteges under each such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5320-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the benefits provided to mentors under each such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5321-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the progress of proteges under each such program with respect to competing for Federal prime contracts and subcontracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5322-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Federal department or agency carrying out a mentor-protege program shall provide to the Administrator, on an annual basis, the information necessary for the Administrator to submit a report required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5323-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5324-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “mentor” means a for-profit business concern, of any size, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5325-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the ability to assist and commits to assisting a protege to compete for Federal prime contracts and subcontracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5326-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies any other requirements imposed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5327-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentor-protege program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mentor-protege program” means a program that pairs a mentor with a protege for the purpose of assisting the protege to compete for Federal prime contracts and subcontracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5328-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protege","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “protege” means a small business concern that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5329-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to enter into Federal prime contracts and subcontracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d532a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies any other requirements imposed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d532b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered mentor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered mentor” means a mentor that enters into an agreement under this chapter, or under any mentor-protege program approved under subsection (b)(1), with a covered protege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d532c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered protege","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered protege” means a protege of a covered mentor that is a Puerto Rico business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d532d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered territory mentor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered territory mentor” means a mentor that enters into an agreement under this chapter, or under any mentor-protege program approved under subsection (b)(1), with a covered territory protege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d532e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered territory protege","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered territory protege” means a protege of a covered territory mentor that is a covered territory business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d532f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current mentor protege agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Mentors and proteges with approved agreement in a program operating pursuant to subsection (b)(4)(C) shall be permitted to continue their relationship according to the terms specified in their agreement until the expiration date specified in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5330-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657r/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of agency plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agencies operating mentor protege programs pursuant to subsection (b)(4)(C) shall submit the plans specified in subsection (b)(1)(A) to the Administrator within 6 months of the promulgation of rules required by subsection (b)(3). The Administrator shall provide initial comments on each plan within 60 days of receipt, and final approval or denial of each plan within 180 days after receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d5331-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s45"},"text":"Pub. L. 85–536, § 2[45]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1641/2"},"text":"Pub. L. 112–239, div. A, title XVI, § 1641(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2077"},"text":"126 Stat. 2077","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXVIII/s1813/e"},"text":"Pub. L. 114–328, div. A, title XVIII, § 1813(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2653"},"text":"130 Stat. 2653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s861/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 861(d)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1896"},"text":"132 Stat. 1896","children":[],"tail":", 1897; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s866/c"},"text":"Pub. L. 116–283, div. A, title VIII, § 866(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3786"},"text":"134 Stat. 3786","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791d5332-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id791d5333-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id791d5334-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2[45] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536"},"text":"Pub. L. 85–536","children":[],"tail":" was renumbered section 2[49] and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id791d5335-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s866/c/1"},"text":"Pub. L. 116–283, § 866(c)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s866/c/2"},"text":"Pub. L. 116–283, § 866(c)(2)","children":[],"tail":", substituted “relationships—” and cls. (i) and (ii) for “relationships are between a covered protege and covered mentor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s866/c/3"},"text":"Pub. L. 116–283, § 866(c)(3)","children":[],"tail":", added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s861/d/1"},"text":"Pub. L. 115–232, § 861(d)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s861/e"},"text":"Pub. L. 115–232, § 861(e)","children":[],"tail":", inserted “, except that such restrictions shall not apply to up to 2 mentor-protege relationships if such relationships are between a covered protege and covered mentor” after “each participant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s861/d/2"},"text":"Pub. L. 115–232, § 861(d)(2)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added subpar. (K)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
