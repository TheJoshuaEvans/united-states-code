{"tag":"section","attrib":{"id":"id78955e19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"278h–1"},"text":"§ 278h–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for artificial intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78955e1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institute shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78955e1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance collaborative frameworks, standards, guidelines, and associated methods and techniques for artificial intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of a risk-mitigation framework for deploying artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of technical standards and guidelines that promote trustworthy artificial intelligence systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of technical standards and guidelines by which to test for bias in artificial intelligence training data and applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78955e1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institute of Standards and Technology may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78955e20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support measurement research and development of best practices and voluntary standards for trustworthy artificial intelligence systems, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78955e21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privacy and security, including for datasets used to train or test artificial intelligence systems and software and hardware used in artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced computer chips and hardware designed for artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data management and techniques to increase the usability of data, including strategies to systematically clean, label, and standardize data into forms useful for training artificial intelligence systems and the use of common, open licenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety and robustness of artificial intelligence systems, including assurance, verification, validation, security, control, and the ability for artificial intelligence systems to withstand unexpected inputs and adversarial attacks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" auditing mechanisms and benchmarks for accuracy, transparency, verifiability, and safety assurance for artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications of machine learning and artificial intelligence systems to improve other scientific fields and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model documentation, including performance metrics and constraints, measures of fairness, training and testing processes, and results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" system documentation, including connections and dependences within and between systems, and complications that may arise from such connections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other areas deemed by the Director to be critical to the development and deployment of trustworthy artificial intelligence;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce curated, standardized, representative, high-value, secure, aggregate, and privacy protected data sets for artificial intelligence research, development, and use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support one or more institutes as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9431/b"},"text":"section 9431(b) of this title","children":[],"tail":" for the purpose of advancing measurement science, voluntary consensus standards, and guidelines for trustworthy artificial intelligence systems;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support and strategically engage in the development of voluntary consensus standards, including international standards, through open, transparent, and consensus-based processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into and perform such contracts, including cooperative research and development arrangements and grants and cooperative agreements or other transactions, as may be necessary in the conduct of the work of the National Institute of Standards and Technology and on such terms as the Director considers appropriate, in furtherance of the purposes of this division.","children":[{"tag":"ref","attrib":{"idref":"fn002154"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002154"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78955e2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk management framework","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Director shall work to develop, and periodically update, in collaboration with other public and private sector organizations, including the National Science Foundation and the Department of Energy, a voluntary risk management framework for trustworthy artificial intelligence systems. The framework shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78955e2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and provide standards, guidelines, best practices, methodologies, procedures and processes for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78955e30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing trustworthy artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the trustworthiness of artificial intelligence systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating risks from artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish common definitions and characterizations for aspects of trustworthiness, including explainability, transparency, safety, privacy, security, robustness, fairness, bias, ethics, validation, verification, interpretability, and other properties related to artificial intelligence systems that are common across all sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide case studies of framework implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" align with international standards, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate voluntary consensus standards and industry best practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not prescribe or otherwise require the use of specific information or communications technology products or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78955e38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in standard setting organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78955e39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall participate in the development of standards and specifications for artificial intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of this participation shall be to ensure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78955e3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that standards promote artificial intelligence systems that are trustworthy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that standards relating to artificial intelligence reflect the state of technology and are fit-for-purpose and developed in transparent and consensus-based processes that are open to all stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78955e3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data sharing best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Director shall, in collaboration with other public and private sector organizations, develop guidance to facilitate the creation of voluntary data sharing arrangements between industry, federally funded research centers, and Federal agencies for the purpose of advancing artificial intelligence research and technologies, including options for partnership models between government entities, industry, universities, and nonprofits that incentivize each party to share the data they collected."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78955e3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices for documentation of data sets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Director shall, in collaboration with other public and private sector organizations, develop best practices for datasets used to train artificial intelligence systems, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78955e3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" standards for metadata that describe the properties of datasets, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78955e40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origins of the data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intent behind the creation of the data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized uses of the data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descriptive characteristics of the data, including what populations are included and excluded from the datasets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78955e44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other properties as determined by the Director; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for privacy and security of datasets with human characteristics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78955e46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testbeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In coordination with other Federal agencies as appropriate, the private sector, and institutions of higher education (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"), the Director may establish testbeds, including in virtual environments, to support the development of robust and trustworthy artificial intelligence and machine learning systems, including testbeds that examine the vulnerabilities and conditions that may lead to failure in, malfunction of, or attacks on such systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78955e47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the National Institute of Standards and Technology to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78955e48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $64,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,400,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $77,440,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $85,180,000 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78955e4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278h–1/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $93,700,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78955e4d-552d-11f1-9071-ff305b7c3ff0"},"text"