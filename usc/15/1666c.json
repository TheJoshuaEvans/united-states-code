{"tag":"section","attrib":{"id":"id799df53a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1666c"},"text":"§ 1666c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt and fair crediting of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799df53b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments received from an obligor under an open end consumer credit plan by the creditor shall be posted promptly to the obligor’s account as specified in regulations of the Bureau. Such regulations shall prevent a finance charge from being imposed on any obligor if the creditor has received the obligor’s payment in readily identifiable form, by 5:00 p.m. on the date on which such payment is due, in the amount, manner, and location indicated by the creditor to avoid the imposition thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799df53c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799df53d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of a payment from a cardholder, the card issuer shall apply amounts in excess of the minimum payment amount first to the card balance bearing the highest rate of interest, and then to each successive balance bearing the next highest rate of interest, until the payment is exhausted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799df53e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification relating to certain deferred interest arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A creditor shall allocate the entire amount paid by the consumer in excess of the minimum payment amount to a balance on which interest is deferred during the last 2 billing cycles immediately preceding the expiration of the period during which interest is deferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799df53f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes by card issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a card issuer makes a material change in the mailing address, office, or procedures for handling cardholder payments, and such change causes a material delay in the crediting of a cardholder payment made during the 60-day period following the date on which such change took effect, the card issuer may not impose any late fee or finance charge for a late payment on the credit card account to which such payment was credited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799df540-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s164"},"text":"Pub. L. 90–321, title I, § 164","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIII/s306"},"text":"Pub. L. 93–495, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1514"},"text":"88 Stat. 1514","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tI/s104"},"text":"Pub. L. 111–24, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1741"},"text":"123 Stat. 1741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX"},"text":"Pub. L. 111–203, title X","children":[],"tail":", §§ 1087, 1100A(2), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2086"},"text":"124 Stat. 2086","children":[],"tail":", 2107.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df541-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799df542-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id799df543-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pub L. 111–203, § 1100A(2), which directed the substitution of “Bureau” for “Board” wherever appearing in title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", was executed to this section, which is "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s164"},"text":"section 164 of title I of Pub. L. 90–321","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1087"},"text":"Section 1087 of Pub. L. 111–203","children":[],"tail":", which directed the making of an identical amendment in title III of "},{"tag":"ref","attrib":{"href":"/us/pl/93/495"},"text":"Pub. L. 93–495","children":[],"tail":", which added this section to title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", has not been executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799df544-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100A/2"},"text":"Pub. L. 111–203, § 1100A(2)","children":[],"tail":", substituted “Bureau” for “Board”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/s104/1"},"text":"Pub. L. 111–24, § 104(1)","children":[],"tail":", substituted “Prompt and fair crediting of payments” for “Prompt crediting of payments” in section catchline, designated existing provisions as subsec. (a), and inserted subsec. (a) heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/s104/2"},"text":"Pub. L. 111–24, § 104(2)","children":[],"tail":", (3), inserted “, by 5:00 p.m. on the date on which such payment is due,” after “in readily identifiable form” and substituted “manner, and location” for “manner, location, and time”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/s104/4"},"text":"Pub. L. 111–24, § 104(4)","children":[],"tail":", added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df545-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799df546-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799df547-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24"},"text":"Pub. L. 111–24","children":[],"tail":" effective 9 months after "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/s3"},"text":"section 3 of Pub. L. 111–24","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"