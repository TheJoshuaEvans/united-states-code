{"tag":"section","attrib":{"id":"id79ecb0f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2305"},"text":null,"children":[{"tag":"num","attrib":{"value":"2305"},"text":"§ 2305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full and limited warranting of a consumer product","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall prohibit the selling of a consumer product which has both full and limited warranties if such warranties are clearly and conspicuously differentiated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ecb0fa-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/637/tI/s105"},"text":"Pub. L. 93–637, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2188"},"text":"88 Stat. 2188","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
