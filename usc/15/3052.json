{"tag":"section","attrib":{"id":"id7a12d6cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052"},"text":null,"children":[{"tag":"num","attrib":{"value":"3052"},"text":"§ 3052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of the Horseracing Integrity and Safety Authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a12d6cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The private, independent, self-regulatory, nonprofit corporation, to be known as the “Horseracing Integrity and Safety Authority”, is recognized for purposes of developing and implementing a horseracing anti-doping and medication control program and a racetrack safety program for covered horses, covered persons, and covered horseraces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d6ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Authority shall be governed by a board of directors (in this section referred to as the “Board”) comprised of nine members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Five members of the Board shall be independent members selected from outside the equine industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry members","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d6d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Four members of the Board shall be industry members selected from among the various equine constituencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d6d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of equine constituencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The industry members shall be representative of the various equine constituencies, and shall include not more than one industry member from any one equine constituency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chair of the Board shall be an independent member described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of the Authority shall be governed by bylaws for the operation of the Authority with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administrative structure and employees of the Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of standing committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures for filling vacancies on the Board and the standing committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" term limits for members and termination of membership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter the Board considers necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standing committees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d6db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-doping and medication control standing committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall establish an anti-doping and medication control standing committee, which shall provide advice and guidance to the Board on the development and maintenance of the horseracing anti-doping and medication control program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The anti-doping and medication control standing committee shall be comprised of seven members as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d6de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members shall be independent members selected from outside the equine industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d6df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A minority of the members shall be industry members selected to represent the various equine constituencies, and shall include not more than one industry member from any one equine constituency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d6e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of individuals selected to serve on the anti-doping and medication control standing committee shall have significant, recent experience in anti-doping and medication control rules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chair of the anti-doping and medication control standing committee shall be an independent member of the Board described in subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Racetrack safety standing committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall establish a racetrack safety standing committee, which shall provide advice and guidance to the Board on the development and maintenance of the racetrack safety program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The racetrack safety standing committee shall be comprised of seven members as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d6e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members shall be independent members selected from outside the equine industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d6e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A minority of the members shall be industry members selected to represent the various equine constituencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chair of the racetrack safety standing committee shall be an industry member of the Board described in subsection (b)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominating committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d6e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The nominating committee of the Authority shall be comprised of seven independent members selected from business, sports, and academia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial nominating committee members shall be set forth in the governing corporate documents of the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the initial committee members are appointed in accordance with subparagraph (B), vacancies shall be filled by the Board pursuant to rules established by the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chair of the nominating committee shall be selected by the nominating committee from among the members of the nominating committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of members of the Board and standing committees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The nominating committee shall select the initial members of the Board and the standing committees described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" The nominating committee shall recommend individuals to fill any vacancy on the Board or on such standing committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To avoid conflicts of interest, the following individuals may not be selected as a member of the Board or as an independent member of a nominating or standing committee under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d6f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who has a financial interest in, or provides goods or services to, covered horses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An official or officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of an equine industry representative; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who serves in a governance or policymaking capacity for an equine industry representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of, or an individual who has a business or commercial relationship with, an individual described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An immediate family member of an individual described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d6f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Initial funding to establish the Authority and underwrite its operations before the program effective date shall be provided by loans obtained by the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrowing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may borrow funds toward the funding of its operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual calculation of amounts required","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d6fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that is 90 days before the program effective date, and not later than November 1 each year thereafter, the Authority shall determine and provide to each State racing commission the estimated amount required from the State—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a12d6fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund the State’s proportionate share of the horseracing anti-doping and medication control program and the racetrack safety program for the next calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a12d6ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to liquidate the State’s proportionate share of any loan or funding shortfall in the current calendar year and any previous calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d700-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis of calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts calculated under clause (i) shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a12d701-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be based on—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a12d702-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual budget of the Authority for the following calendar year, as approved by the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a12d703-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected amount of covered racing starts for the year in each State; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a12d704-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account other sources of Authority revenue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d705-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements regarding budgets of Authority","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a12d706-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial budget of the Authority shall require the approval of ⅔ of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a12d707-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent budgets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any subsequent budget that exceeds the budget of the preceding calendar year by more than 5 percent shall require the approval of ⅔ of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d708-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate increases","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a12d709-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A proposed increase in the amount required under this subparagraph shall be reported to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a12d70a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall publish in the Federal Register such a proposed increase and provide an opportunity for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d70b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and collection of fees by States","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d70c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State racing commission that elects to remit fees pursuant to this subsection shall notify the Authority of such election not later than 60 days before the program effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d70d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to remit fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a State racing commission makes a notification under subparagraph (A), the election shall remain in effect and the State racing commission shall be required to remit fees pursuant to this subsection according to a schedule established in rule developed by the Authority and approved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d70e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State racing commission may cease remitting fees under this subsection not earlier than one year after notifying the Authority of the intent of the State racing commission to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d70f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State racing commission shall determine, subject to the applicable laws, regulations, and contracts of the State, the method by which the requisite amount of fees, such as foal registration fees, sales contributions, starter fees, and track fees, and other fees on covered persons, shall be allocated, assessed, and collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d710-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and collection of fees by the Authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d711-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State racing commission does not elect to remit fees pursuant to paragraph (2) or withdraws its election under such paragraph, the Authority shall, not less frequently than monthly, calculate the applicable fee per racing start multiplied by the number of racing starts in the State during the preceding month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d712-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall allocate equitably the amount calculated under subparagraph (A) collected among covered persons involved with covered horseraces pursuant to such rules as the Authority may promulgate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d713-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and collection","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d714-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall assess a fee equal to the allocation made under subparagraph (B) and shall collect such fee according to such rules as the Authority may promulgate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d715-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remittance of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Covered persons described in subparagraph (B) shall be required to remit such fees to the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d716-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State racing commission that does not elect to remit fees pursuant to paragraph (2) or that withdraws its election under such paragraph shall not impose or collect from any person a fee or tax relating to anti-doping and medication control or racetrack safety matters for covered horseraces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d717-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and fines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees and fines imposed by the Authority shall be allocated toward funding of the Authority and its activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d718-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to require—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d719-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriation of any amount to the Authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d71a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government to guarantee the debts of the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d71b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3052/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For all items where Board approval is required, the Authority shall have present a majority of independent members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a12d71c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1203"},"text":"Pub. L. 116–260, div. FF, title XII, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3253"},"text":"134 Stat. 3253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a12d71d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a12d71e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a12d71f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (f)(5), was in the original “this Act” and was translated as reading “this title”, meaning title XII of div. FF of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
