{"tag":"section","attrib":{"id":"id79a2d69d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679f"},"text":"§ 1679f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance with this subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a2d69e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer waivers invalid","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any waiver by any consumer of any protection provided by or any right of the consumer under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d69f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as void; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be enforced by any Federal or State court or any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d6a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attempt to obtain waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any attempt by any person to obtain a waiver from any consumer of any protection provided by or any right of the consumer under this subchapter shall be treated as a violation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d6a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts not in compliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract for services which does not comply with the applicable provisions of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d6a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as void; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be enforced by any Federal or State court or any other person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a2d6a5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s408"},"text":"Pub. L. 90–321, title IV, § 408","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-459"},"text":"110 Stat. 3009–459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2d6a6-552d-11f1-9071-ff305b7c3ff0"},"tex