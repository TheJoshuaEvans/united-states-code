{"tag":"section","attrib":{"id":"id78849565-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s160"},"text":null,"children":[{"tag":"num","attrib":{"value":"160"},"text":"§ 160.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of agent for service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every China Trade Act corporation shall maintain in the District of Columbia a person as its accredited agent, upon whom legal process may be served, in any suit to be brought in the United States District Court for the District of Columbia, and who is authorized to enter an appearance in its behalf. In the event of the death or inability to serve, or the resignation or removal, of such person, such corporation shall, within such time as the Secretary by regulation prescribes, appoint a successor. Such corporation shall file with the Secretary a certified copy of each power of attorney appointing a person under this section, and a certified copy of the written consent of each person so appointed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78849566-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-19/ch346/s20/b"},"text":"Sept. 19, 1922, ch. 346, § 20(b)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-26/ch345/s10"},"text":"Feb. 26, 1925, ch. 345, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/996"},"text":"43 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch804"},"text":"June 25, 1936, ch. 804","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1921"},"text":"49 Stat. 1921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s32/a"},"text":"June 25, 1948, ch. 646, § 32(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s127"},"text":"May 24, 1949, ch. 139, § 127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78849567-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78849568-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78849569-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section comprises subsec. (b) of section 20 of act ","children":[{"tag":"date","attrib":{"date":"1922-09-19"},"text":"Sept. 19, 1922","children":[],"tail":", as added by act "},{"tag":"date","attrib":{"date":"1925-02-26"},"text":"Feb. 26, 1925","children":[],"tail":". Subsec. (a) of section 20 is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s146a"},"text":"section 146a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7884956a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7884956b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “United States District Court for the District of Columbia” for “district court of the United States for the District of Columbia.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1936-06-25"},"text":"June 25, 1936","children":[],"tail":", changed name of “Supreme Court of the District of Columbia” to “district court of the United States for the District of Columbia”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
