{"tag":"section","attrib":{"id":"id79376ad4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s714a"},"text":null,"children":[{"tag":"num","attrib":{"value":"714a"},"text":"§ 714a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Corporation may establish offices in such place or places as it may deem necessary or desirable in the conduct of its business.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79376ad5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704/s3"},"text":"June 29, 1948, ch. 704, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1070"},"text":"62 Stat. 1070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79376ad6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79376ad7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79376ad8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exceptions From Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For exception of functions of corporations of Department of Agriculture from transfer of functions to Secretary of Agriculture by Reorg. Plan No. 2 of 1953, see Exceptions From Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s712a"},"text":"section 712a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
