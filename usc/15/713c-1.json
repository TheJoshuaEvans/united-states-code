{"tag":"section","attrib":{"id":"id79352123-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s713c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"713c–1"},"text":"§ 713c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress by Federal Surplus Commodities Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Surplus Commodities Corporation shall submit to Congress on the first day of each regular session an annual report setting forth a statement of the activities, receipts, and expenditures of the Corporation during the previous year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79352124-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/52/38"},"text":"52 Stat. 38","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79352125-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79352126-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79352127-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was previously classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1293"},"text":"section 1293 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79352128-552d-11f1-9