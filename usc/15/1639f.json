{"tag":"section","attrib":{"id":"id79993943-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1639f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639f"},"text":"§ 1639f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for prompt crediting of home loan payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79993944-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1639f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with a consumer credit transaction secured by a consumer’s principal dwelling, no servicer shall fail to credit a payment to the consumer’s loan account as of the date of receipt, except when a delay in crediting does not result in any charge to the consumer or in the reporting of negative information to a consumer reporting agency, except as required in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79993945-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1639f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a servicer specifies in writing requirements for the consumer to follow in making payments, but accepts a payment that does not conform to the requirements, the servicer shall credit the payment as of 5 days after receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79993946-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s129F"},"text":"Pub. L. 90–321, title I, § 129F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1464/a"},"text":"Pub. L. 111–203, title XIV, § 1464(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2184"},"text":"124 Stat. 2184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79993947-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79993948-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79993949-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date on which final regulations implementing such section take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
