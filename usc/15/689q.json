{"tag":"section","attrib":{"id":"id79293a9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689q"},"text":null,"children":[{"tag":"num","attrib":{"value":"689q"},"text":"§ 689q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79293a9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for fiscal years 2001 through 2006, to remain available until expended, the following sums:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such subsidy budget authority as may be necessary to guarantee $150,000,000 of debentures under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 to make grants under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293aa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds collected for examinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds deposited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s689k/c/2"},"text":"section 689k(c)(2) of this title","children":[],"tail":" are authorized to be appropriated only for the costs of examinations under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s689k"},"text":"section 689k of this title","children":[],"tail":" and for the costs of other oversight activities with respect to the program established under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293aa1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s368"},"text":"Pub. L. 85–699, title III, § 368","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–664.)"}],"tail":"\n"}],"tail":null}
