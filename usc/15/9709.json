{"tag":"section","attrib":{"id":"id7ab50976-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709"},"text":null,"children":[{"tag":"num","attrib":{"value":"9709"},"text":"§ 9709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Weather Service hydrologic research fellowship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab50977-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab50978-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Assistant Administrator” means the Assistant Administrator for Weather Services of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50979-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “decision support services” means information, including data and refined products, that supports water resources-related decision-making processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5097a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5097b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NOAA line offices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “NOAA line offices” means the following offices of the National Oceanic and Atmospheric Administration:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab5097c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Ocean Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5097d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Environmental Satellite, Data, and Information Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5097e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Marine Fisheries Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5097f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Oceanic and Atmospheric Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50980-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Marine and Aviation Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50981-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrologic research fellowship program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab50982-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a hydrologic research fellowship program (in this section referred to as the “program”) for qualified individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50983-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a qualified individual is an individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab50984-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50985-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enrolled in a research-based graduate program, at an institution of higher education, in a field that advances the research priorities developed by the Assistant Administrator under paragraph (7), such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab50986-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab50987-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" earth sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab50988-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" atmospheric sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab50989-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab5098a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab5098b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab5098c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geosciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab5098d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urban planning; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab5098e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related social sciences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5098f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fellowships under the program shall be awarded pursuant to guidelines established by the Assistant Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50990-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting qualified individuals for participation in the program, the Assistant Administrator shall give preference to applicants from historically Black colleges and universities and minority-serving institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50991-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall support the placement of qualified individuals in positions within the executive branch of the Federal Government where such individuals can address and advance the research priorities developed by the Assistant Administrator under paragraph (7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50992-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fellowship under the program shall be for a period of up to 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50993-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship research priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Administrator, in consultation with representatives from the NOAA line offices, the United States Geological Survey, the Federal Emergency Management Agency, and the Army Corps of Engineers, as appropriate, shall develop and publish priorities for the conduct of research by fellows, which may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab50994-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advance the collaborative development of a flexible community-based water resources modeling system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50995-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Apply artificial intelligence and machine learning capabilities to advance existing hydrologic modeling capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50996-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support the evolution and integration of hydrologic modeling within an Earth Systems Modeling Framework.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50997-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improve visualizations of hydrologic model outputs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50998-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advance the state of coupled freshwater and salt water modeling and forecasting capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50999-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advance understanding and process representation of water quality parameters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5099a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advance the assimilation of in-situ and remotely sensed observations and data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5099b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support the integration of social science to advance decision support services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5099c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/b/7/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop methods to study groundwater sustainability and estimate the efficiency of recharge management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab5099d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct hiring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab5099e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During fiscal year 2022 and any fiscal year thereafter, the head of any Federal agency may appoint, without regard to the provisions of subchapter I of chapter 33 of title 5, other than sections 3303 and 3328 of that title, to a position with the Federal agency a recipient of a fellowship under the program who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab5099f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" earned a degree from a program described in subsection (b)(2)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully fulfilled the requirements of the fellowship within the executive branch of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets qualification standards established by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exercise of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The direct hire authority provided by this subsection shall be exercised with respect to an individual described in paragraph (1) not later than 2 years after the date on which the individual completed the fellowship under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab509a3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s14"},"text":"Pub. L. 117–316, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4415"},"text":"136 Stat. 4415","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
