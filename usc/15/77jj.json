{"tag":"section","attrib":{"id":"id77ebff2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77jj"},"text":null,"children":[{"tag":"num","attrib":{"value":"77jj"},"text":"§ 77jj.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans to Corporation from Reconstruction Finance Corporation authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Reconstruction Finance Corporation is authorized to loan out of its funds not to exceed $75,000 for the use of the Corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ebff2f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title II, § 209, "},{"tag":"ref","attrib":{"href":"/us/stat/48/95"},"text":"48 Stat. 95","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ebff30-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77ebff31-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77ebff32-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Reconstruction Finance Corporation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6(a) of Reorg. Plan No. 1 of 1957, eff. ","children":[{"tag":"date","attrib":{"date":"1957-06-30"},"text":"June 30, 1957","children":[],"tail":", 22 F.R. 4633, "},{"tag":"ref","attrib":{"href":"/us/stat/71/647"},"text":"71 Stat. 647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s601"},"text":"section 601 of this title","children":[],"tail":", abolished the Reconstruction Finance Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
