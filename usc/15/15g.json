{"tag":"section","attrib":{"id":"id77b53756-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15g"},"text":null,"children":[{"tag":"num","attrib":{"value":"15g"},"text":"§ 15g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of sections 15c, 15d, 15e, and 15f of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77b53757-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “State attorney general” means the chief legal officer of a State, or any other person authorized by State law to bring actions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s15c"},"text":"section 15c of this title","children":[],"tail":", and includes the Corporation Counsel of the District of Columbia, except that such term does not include any person employed or retained on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77b53758-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contingency fee based on a percentage of the monetary relief awarded under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77b53759-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other contingency fee basis, unless the amount of the award of a reasonable attorney’s fee to a prevailing plaintiff is determined by the court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s15c/d/1"},"text":"section 15c(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77b5375a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77b5375b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “natural persons” does not include proprietorships or partnerships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77b5375c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323/s4G"},"text":"Oct. 15, 1914, ch. 323, § 4G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/435/tIII/s301"},"text":"Pub. L. 94–435, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1396"},"text":"90 Stat. 1396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77b5375d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77b5375e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id77b5375f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Injuries sustained prior to ","children":[{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", not covered by this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/435/s304"},"text":"section 304 of Pub. L. 94–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s15c"},"text":"section 15c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
