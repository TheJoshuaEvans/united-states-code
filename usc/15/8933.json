{"tag":"section","attrib":{"id":"id7a912f22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933"},"text":null,"children":[{"tag":"num","attrib":{"value":"8933"},"text":"§ 8933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide sampling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912f23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out a nationwide sampling to determine the concentration of highly fluorinated compounds in estuaries, lakes, streams, springs, wells, wetlands, rivers, aquifers, and soil using the performance standard developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8932/a"},"text":"section 8932(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912f24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the sampling under subsection (a), the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first carry out the sampling at sources of drinking water near locations with known or suspected releases of highly fluorinated compounds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when carrying out sampling of sources of drinking water under paragraph (1), carry out the sampling prior to and, at the request of the Administrator, after any treatment of the water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survey for ecological exposure to highly fluorinated compounds, with a priority in determining direct human exposure through drinking water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States to determine areas that are a priority for sampling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Administrator—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance coverage of the sampling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to avoid unnecessary duplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912f2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the completion of the sampling under subsection (a), the Director shall prepare a report describing the results of the sampling and submit the report to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works and the Committee on Energy and Natural Resources of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce and the Committee on Natural Resources of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senators of each State in which the Director carried out the sampling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8933/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each Member of the House of Representatives who represents a district in which the Director carried out the sampling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912f32-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7333"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2282"},"text":"133 Stat. 2282","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
