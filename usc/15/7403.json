{"tag":"section","attrib":{"id":"id7a74a59a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403"},"text":null,"children":[{"tag":"num","attrib":{"value":"7403"},"text":"§ 7403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Science Foundation research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a74a59b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computer and network security research grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a74a59c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall award grants for basic research on innovative approaches to the structure of computer and network hardware and software that are aimed at enhancing computer security. Research areas may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a59d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authentication, cryptography, and other secure data communications technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a59e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer forensics and intrusion detection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a59f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reliability of computer and network applications, middleware, operating systems, control systems, and communications infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privacy and confidentiality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" network security architecture, including tools for security administration and analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emerging threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vulnerability assessments and techniques for quantifying risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote access and wireless security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of law enforcement ability to detect, investigate, and prosecute cyber-crimes, including those that involve piracy of intellectual property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure fundamental protocols that are integral to inter-network communications and data exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" secure software engineering and software assurance, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a74a5a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programming languages and systems that include fundamental security features;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" portable or reusable code that remains secure when deployed in various environments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/K/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verification and validation technologies to ensure that requirements and specifications have been implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/K/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" models for comparison and metrics to assure that required standards have been met;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" holistic system security that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a74a5ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/L/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses the building of secure systems from trusted and untrusted components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/L/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proactively reduces vulnerabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/L/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses insider threats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/L/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports privacy in conjunction with improved security;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and detection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigation and rapid recovery methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security of wireless networks and mobile devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security of cloud infrastructure and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security of election-dedicated voting system software and hardware; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/1/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" role of the human factor in cybersecurity and the interplay of computers and humans and the physical world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review; competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be awarded under this section on a merit-reviewed competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the National Science Foundation to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a5b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $35,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $40,000,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $46,000,000 for fiscal year 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $52,000,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a74a5be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computer and network security research centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a74a5bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall award multiyear grants, subject to the availability of appropriations, to institutions of higher education, nonprofit research institutions, or consortia thereof to establish multidisciplinary Centers for Computer and Network Security Research. Institutions of higher education, nonprofit research institutions, or consortia thereof receiving such grants may partner with 1 or more government laboratories or for-profit institutions, or other institutions of higher education or nonprofit research institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review; competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be awarded under this subsection on a merit-reviewed competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Centers shall be to generate innovative approaches to computer and network security by conducting cutting-edge, multidisciplinary research in computer and network security, including improving the security and resiliency of information technology, reducing cyber vulnerabilities, and anticipating and mitigating consequences of cyber attacks on critical infrastructure, by conducting research in the areas described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education, nonprofit research institution, or consortia thereof seeking funding under this subsection shall submit an application to the Director at such time, in such manner, and containing such information as the Director may require. The application shall include, at a minimum, a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a5c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research projects that will be undertaken by the Center and the contributions of each of the participating entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will promote active collaboration among scientists and engineers from different disciplines, such as computer scientists, engineers, mathematicians, and social science researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will contribute to increasing the number and quality of computer and network security researchers and other professionals, including individuals from groups historically underrepresented in these fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will disseminate research results quickly and widely to improve cyber security in information technology networks, products, and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating the applications submitted under paragraph (4), the Director shall consider, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a5c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the applicant to generate innovative approaches to computer and network security and effectively carry out the research program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experience of the applicant in conducting research on computer and network security and the capacity of the applicant to foster new multidisciplinary collaborations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the applicant to attract and provide adequate support for a diverse group of undergraduate and graduate students and postdoctoral fellows to pursue computer and network security research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant will partner with government laboratories, for-profit entities, other institutions of higher education, or nonprofit research institutions, and the role the partners will play in the research undertaken by the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstrated capability of the applicant to conduct high performance computation integral to complex computer and network security research, through on-site or off-site computing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s affiliation with private sector entities involved with industrial research described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of the applicant to conduct research in a secure environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s affiliation with existing research programs of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s experience managing public-private partnerships to transition new technologies into a commercial setting or the government user community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of the applicant to conduct interdisciplinary cybersecurity research, basic and applied, such as in law, economics, or behavioral sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/5/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of the applicant to conduct research in areas such as systems security, wireless security, networking and protocols, formal methods and networking and information technology, nanotechnology, or industrial control systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall convene an annual meeting of the Centers in order to foster collaboration and communication between Center participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for the National Science Foundation to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a5d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $24,000,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $36,000,000 for fiscal year 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $36,000,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7403/b/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $36,000,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a74a5da-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/305/s4"},"text":"Pub. L. 107–305, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2368"},"text":"116 Stat. 2368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/274/tII"},"text":"Pub. L. 113–274, title II","children":[],"tail":", §§ 201(e), 202, "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2978"},"text":"128 Stat. 2978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI"},"text":"Pub. L. 114–329, title I","children":[],"tail":", §§ 104(a), 105(r), "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2975"},"text":"130 Stat. 2975","children":[],"tail":", 2984.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a74a5db-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a74a5dc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a74a5dd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1)(Q), (R). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s104/a"},"text":"Pub. L. 114–329, § 104(a)","children":[],"tail":", added subpars. (Q) and (R)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/r"},"text":"Pub. L. 114–329, § 105(r)","children":[],"tail":", substituted “networking and information technology” for “high-performance computing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1)(J) to (P). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/274/s201/e"},"text":"Pub. L. 113–274, § 201(e)","children":[],"tail":", added subpars. (J) to (P)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/274/s202/1"},"text":"Pub. L. 113–274, § 202(1)","children":[],"tail":", substituted “improving the security and resiliency of information technology, reducing cyber vulnerabilities, and anticipating and mitigating consequences of cyber attacks on critical infrastructure, by conducting research in the areas” for “the research areas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/274/s202/2"},"text":"Pub. L. 11