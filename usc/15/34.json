{"tag":"section","attrib":{"id":"id77bc639b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s34"},"text":null,"children":[{"tag":"num","attrib":{"value":"34"},"text":"§ 34.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions applicable to sections 34 to 36","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 34 to 36 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77bc639c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s34/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “local government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77bc639d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s34/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a city, county, parish, town, township, village, or any other general function governmental unit established by State law, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77bc639e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s34/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a school district, sanitary district, or any other special function governmental unit established by State law in one or more States,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77bc639f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s34/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” has the meaning given it in subsection (a) of the first section of the Clayton Act [","children":[{"tag":"ref","attrib":{"href":"/u