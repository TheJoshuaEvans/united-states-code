{"tag":"section","attrib":{"id":"id78824c12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s144a"},"text":null,"children":[{"tag":"num","attrib":{"value":"144a"},"text":"§ 144a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation fee for perpetual existence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any China Trade Act corporation existing on ","children":[{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":", may make its existence perpetual only upon application to the Secretary of Commerce to amend its charter in that respect and upon payment of a fee equivalent to the incorporation fee. Upon receipt of such application and the payment of such prescribed fee, the Secretary shall approve such application and the charter of the corporation shall be amended accordingly."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78824c13-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch696/s2"},"text":"June 25, 1938, ch. 696, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1196"},"text":"52 Stat. 1196","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78824c14-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78824c15-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78824c16-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the China Trade Act, 1922, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
