{"tag":"section","attrib":{"id":"id792b844d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s693"},"text":null,"children":[{"tag":"num","attrib":{"value":"693"},"text":"§ 693.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Administration respecting loans; liquidation of obligations through creation of new leases, execution of subleases, and assignments of leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Without limiting the authority conferred upon the Administrator and the Administration by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s671"},"text":"section 671 of this title","children":[],"tail":", the Administrator and the Administration shall have, in the performance of and with respect to the functions, powers, and duties conferred by this part, all the authority and be subject to the same conditions prescribed in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s634/b"},"text":"section 634(b) of this title","children":[],"tail":" with respect to loans, including the authority to execute subleases, assignments of lease and new leases with any person, firm, organization, or other entity, in order to aid in the liquidation of obligations of the Administration hereunder."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id792b844e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIV/s402"},"text":"Pub. L. 85–699, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/117/tIII/s316/a"},"text":"Pub. L. 89–117, title III, § 316(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-10"},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/483"},"text":"79 Stat. 483","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/609/tIX/s911/a/2"},"text":"Pub. L. 91–609, title IX, § 911(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1812"},"text":"84 Stat. 1812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792b844f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792b8450-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792b8451-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/609"},"text":"Pub. L. 91–609","children":[],"tail":" substituted “part” for “title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
