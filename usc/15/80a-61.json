{"tag":"section","attrib":{"id":"id7878ae7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–61"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–61"},"text":"§ 80a–61.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the exemption set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–6/f"},"text":"section 80a–6(f) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–21"},"text":"section 80a–21 of this title","children":[],"tail":" shall apply to a business development company to the same extent as if it were a registered closed-end investment company, except that nothing in that section shall be deemed to prohibit—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7878ae7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–61/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan to a director, officer, or employee of, or general partner in, a business development company for the purpose of purchasing securities of such company as part of an executive compensation plan, if such loan meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–56/j"},"text":"section 80a–56(j) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7878ae7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–61/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan to a company controlled by a business development company, which companies could be deemed to be under common control solely because a third person controls such business development company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit"