{"tag":"section","attrib":{"id":"id79862688-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1544"},"text":null,"children":[{"tag":"num","attrib":{"value":"1544"},"text":"§ 1544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of tourist travel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall encourage, promote, and develop travel within the United States, including any Commonwealth, territory, and possession thereof, through activities which are in the public interest and which do not compete with activities of any State, city, or private agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79862689-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-07-19/ch642/s1"},"text":"July 19, 1940, ch. 642, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/773"},"text":"54 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/193/s2"},"text":"Pub. L. 93–193, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-19"},"text":"Dec. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/765"},"text":"87 Stat. 765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/55/s2/b"},"text":"Pub. L. 94–55, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-09"},"text":"July 9, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/262"},"text":"89 Stat. 262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7986268a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7986268b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7986268c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s18"},"text":"section 18 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7986268d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/55"},"text":"Pub. L. 94–55","children":[],"tail":" substituted “shall encourage, promote, and develop travel within the United States, including any Commonwealth, territory, and possession thereof, through activities which are in the public interest and which do not compete with activities of any State, city, or private agency” for “is authorized and directed to encourage, promote, and develop travel within the United States, its Territories and possessions, providing such activities do not compete with the activities of private agencies; and to administer all existing travel promotion functions of the Department of Commerce”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7986268e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7986268f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/193/s2"},"text":"Pub. L. 93–193, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-19"},"text":"Dec. 19, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/765"},"text":"87 Stat. 765","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/193/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby transferred to and vested in the Secretary of Commerce all functions, powers, and duties of the Secretary of the Interior and other offices and officers of the Department of the Interior under the Act of ","children":[{"tag":"date","attrib":{"date":"1940-07-19"},"text":"July 19, 1940","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/54/773"},"text":"54 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s18–18d"},"text":"16 U.S.C. 18–18d","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1544–154"},"text":"15 U.S.C. 1544–154","children":[],"tail":"8]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assets, liabilities, contracts, property, records, authorizations, and allocations, employed, held, used, rising from, available or to be made available in connection with the functions, powers, and duties transferred by subsection (a) of this section are hereby transferred to the Secretary of Commerce.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
