{"tag":"section","attrib":{"id":"id7977ceff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1340"},"text":null,"children":[{"tag":"num","attrib":{"value":"1340"},"text":"§ 1340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cigarettes for export","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Packages of cigarettes manufactured, imported, or packaged (1) for export from the United States or (2) for delivery to a vessel or aircraft, as supplies, for consumption beyond the jurisdiction of the internal revenue laws of the United States shall be exempt from the requirements of this chapter, but such exemptions shall not apply to cigarettes manufactured, imported, or packaged for sale or distribution to members or units of the Armed Forces of the United States located outside of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7977cf00-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92/s12"},"text":"Pub. L. 89–92, § 12","children":[],"tail":", formerly § 11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/222/s2"},"text":"Pub. L. 91–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-01"},"text":"Apr. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/89"},"text":"84 Stat. 89","children":[],"tail":"; renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/98/474/s5/a"},"text":"Pub. L. 98–474, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2203"},"text":"98 Stat. 2203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7977cf01-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7977c