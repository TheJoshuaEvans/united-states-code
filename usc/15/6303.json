{"tag":"section","attrib":{"id":"id7a55ac55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6303"},"text":null,"children":[{"tag":"num","attrib":{"value":"6303"},"text":"§ 6303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boxing matches in States without boxing commissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a55ac56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may arrange, promote, organize, produce, or fight in a professional boxing match held in a State that does not have a boxing commission unless the match is supervised by a boxing commission from another State and subject to the most recent version of the recommended regulatory guidelines certified and published by the Association of Boxing Commissions as well as any additional relevant professional boxing regulations and requirements of such other State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a55ac57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this chapter, if no State commission is available to supervise a boxing match according to subsection (a), then—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the match may not be held unless it is supervised by an association of boxing commissions to which at least a majority of the States belong; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reporting or other requirement relating to a supervising commission allowed under this section shall be deemed to refer to the entity described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a55ac5a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s4"},"text":"Pub. L. 104–272, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3310"},"text":"110 Stat. 3310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/e"},"text":"Pub. L. 106–210, § 7(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/328"},"text":"114 Stat. 328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a55ac5b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a55ac5c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a55ac5d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210"},"text":"Pub. L. 106–210","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55ac5e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a55ac5f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"Jan. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23"},"text":"section 23 of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
