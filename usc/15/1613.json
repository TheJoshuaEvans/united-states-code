{"tag":"section","attrib":{"id":"id798d522c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1613"},"text":null,"children":[{"tag":"num","attrib":{"value":"1613"},"text":"§ 1613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress by Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each year the Bureau shall make a report to the Congress concerning the administration of its functions under this subchapter, including such recommendations as the Bureau deems necessary or appropriate. In addition, each report of the Bureau shall include its assessment of the extent to which compliance with the requirements imposed under this subchapter is being achieved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id798d522d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s114"},"text":"Pub. L. 90–321, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/151"},"text":"82 Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s610/a"},"text":"Pub. L. 96–221, title VI, § 610(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/174"},"text":"94 Stat. 174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s209/b"},"text":"Pub. L. 97–375, title II, § 209(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1825"},"text":"96 Stat. 1825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[