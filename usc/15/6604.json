{"tag":"section","attrib":{"id":"id7a5a67ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604"},"text":null,"children":[{"tag":"num","attrib":{"value":"6604"},"text":"§ 6604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punitive damages limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5a67ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any Y2K action in which punitive damages are permitted by applicable law, the defendant shall not be liable for punitive damages unless the plaintiff proves by clear and convincing evidence that the applicable standard for awarding damages has been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a67ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Caps on punitive damages","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a67af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the evidentiary standard established by subsection (a), punitive damages permitted under applicable law against a defendant described in paragraph (2) in a Y2K action may not exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three times the amount awarded for compensatory damages; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defendant described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defendant described in this paragraph is a defendant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a67b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is sued in his or her capacity as an individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a67b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose net worth does not exceed $500,000; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is an unincorporated business, a partnership, corporation, association, or organization, with fewer than 50 full-time employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No cap if injury specifically intended","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) does not apply if the plaintiff establishes by clear and convincing evidence that the defendant acted with specific intent to injure the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a67b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Punitive damages in a Y2K action may not be awarded against a government entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a67b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institutions of higher education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a67ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), punitive damages in a Y2K action may not be awarded against an instituion ","children":[{"tag":"ref","attrib":{"idref":"fn002555"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002555"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “institution”."}],"tail":" of higher education as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to an institution of higher education if the Y2K failure in the Y2K action occurred in a computer-based student financial aid system of that institution of higher education, and the institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has passed Y2K data exchange testing with the Department of Education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6604/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not or was not in the process of performing data exchange testing with the Department of Education at the time the Department terminates such testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5a67be-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s5"},"text":"Pub. L. 106–37, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/192"},"text":"113 Stat. 192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/4/tIII/s311"},"text":"Pub. L. 106–113, div. B, § 1000(a)(4) [title III, § 311]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–265.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a5a67bf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a5a67c0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a5a67c1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
