{"tag":"section","attrib":{"id":"id7a6b094e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7109"},"text":null,"children":[{"tag":"num","attrib":{"value":"7109"},"text":"§ 7109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and other research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6b094f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may conduct such studies and other research relating to the award of Federal prime contracts and subcontracts to women-owned businesses, to access to credit and investment capital by women entrepreneurs, or to other issues relating to women-owned businesses, as the Council determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0950-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting any study or other research under this section, the Council may contract with one or more public or private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b0951-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/tIV/s409"},"text":"Pub. L. 100–533, title IV, § 409","children":[],"tail":", formerly § 410, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/tIII/s307"},"text":"Pub. L. 105–135, title III, § 307","children":[],"tail":", "