{"tag":"section","attrib":{"id":"id7a49c597-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301"},"text":null,"children":[{"tag":"num","attrib":{"value":"5301"},"text":"§ 5301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c598-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" metal casting is an important process for manufacturing many items imported into or exported from the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c599-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the encouragement and maintenance of a technically advanced United States metal casting industry is essential to the competitiveness of many American industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c59a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a viable metal casting industry is vital to the national security and economic well being of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c59b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of technology competitiveness and energy efficiency in the United States metal casting industry by the Federal Government is necessary to maintain a viable metal casting industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c59c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many metal casting companies lack the resources to conduct metal casting research alone, placing them at a serious competitive disadvantage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c59d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the support of university-based research in metal casting is important in promoting technology development and providing industry with qualified engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c59e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by combining the resources of the Federal Government, universities, industry, and private organizations, to conduct research and development activities, substantial technological benefits will result to the metal casting industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c59f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/425/s2"},"text":"Pub. L. 101–425, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/915"},"text":"104 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a49c5a0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a49c5a1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a49c5a2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/425/s1"},"text":"Pub. L. 101–425, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/915"},"text":"104 Stat. 915","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/425/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Department of Energy Metal Casting Competitiveness Research Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
