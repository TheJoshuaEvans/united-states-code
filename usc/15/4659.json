{"tag":"section","attrib":{"id":"id7a4028f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659"},"text":null,"children":[{"tag":"num","attrib":{"value":"4659"},"text":"§ 4659.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4028f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibilities of the Department of Commerce under this chapter, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4028f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements, including contracts, grants and cooperative agreements, and other transactions as may be necessary and on such terms as the Secretary considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4028f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make advance payments under agreements and other transactions authorized under paragraph (1) without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3324"},"text":"section 3324 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4028f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a person or other entity to make payments to the Department of Commerce upon application and as a condition for receiving support through an award of assistance or other transaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4028f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure temporary and intermittent services of experts and consultants in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4028f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3104"},"text":"section 3104 of title 5","children":[],"tail":" or the provisions of any other law relating to the appointment, number, classification, or compensation of employees, make appointments of scientific, engineering, and professional personnel, and fix the basic pay of such personnel at a rate to be determined by the Secretary at rates not in excess of the highest total annual compensation payable at the rate determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":", except that the Secretary shall appoint not more than 25 personnel under this paragraph;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4028fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of another Federal agency, enter into an agreement with that Federal agency to use, with or without reimbursement, any service, equipment, personnel, or facility of that Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4028fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such rules, regulations, and procedures as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4028fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds received from a payment made by a person or entity pursuant to subsection (a)(3) shall be credited to and merged with the account from which support to the person or entity was made ","children":[{"tag":"ref","attrib":{"idref":"fn002530"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002530"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4028fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead Federal agency and cooperating agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4028fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “lead agency” has the meaning given the term in section 111 of NEPA (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336e"},"text":"42 U.S.C. 4336e","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4028ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to serve as lead agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a covered activity that is a major Federal action under NEPA, and with respect to which the Department of Commerce is authorized or required by law to issue an authorization or take action for or relating to that covered activity, the Department of Commerce shall have the first right to serve as the lead agency with respect to that covered activity under NEPA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a429900-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categorical exclusions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a429901-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of categorical exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each of the following categorical exclusions is established for the National Institute of Standards and Technology with respect to a covered activity and, beginning on ","children":[{"tag":"date","attrib":{"date":"2024-10-02"},"text":"October 2, 2024","children":[],"tail":", is available for use by the Secretary with respect to a covered activity:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a429902-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Categorical exclusion 17.04.d (relating to the acquisition of machinery and equipment) in the document entitled “EDA Program to Implement the National Environmental Policy Act of 1969 and Other Federal Environmental Mandates As Required” (Directive No. 17.02–2; effective date ","children":[{"tag":"date","attrib":{"date":"1992-10-14"},"text":"October 14, 1992","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429903-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Categorical exclusion A9 in Appendix A to subpart D of part 1021 of title 10, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429904-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Categorical exclusions B1.24, B1.31, B2.5, and B5.1 in Appendix B to subpart D of part 1021 of title 10, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429905-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The categorical exclusions described in paragraphs (4) and (13) of section 50.19(b) of title 24, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429906-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Categorical exclusion (c)(1) in Appendix B to part 651 of title 32, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429907-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Categorical exclusions A2.3.8 and A2.3.14 in Appendix B to part 989 of title 32, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429908-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional categorical exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, each of the following shall be treated as a category of action categorically excluded from the requirements relating to environmental assessments and environmental impact statements under section 1501.4 of title 40, Code of Federal Regulations, or any successor regulation:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a429909-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provision by the Secretary of any Federal financial assistance for a project described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4652"},"text":"section 4652 of this title","children":[],"tail":", if the facility that is the subject of the project is on or adjacent to a site—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a42990a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is owned or leased by the covered entity to which Federal financial assistance is provided for that project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a42990b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which, as of the date on which the Secretary provides that Federal financial assistance, substantially similar construction, expansion, or modernization is being or has been carried out, such that the facility would not more than double existing developed acreage or on-site supporting infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42990c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provision by the Secretary of Defense of any Federal financial assistance relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a42990d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation, expansion, or modernization of one or more facilities described in the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4653/a/1"},"text":"section 4653(a)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a42990e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4653/b"},"text":"section 4653(b) of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2024-10-02"},"text":"October 2, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42990f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any activity undertaken by the Secretary relating to carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4656"},"text":"section 4656 of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2024-10-02"},"text":"October 2, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a429910-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of prior planning decisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a429911-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “prior studies and decisions” means baseline data, planning documents, studies, analyses, decisions, and documentation that a Federal agency has completed for a project (or that have been completed under the laws and procedures of a State or Indian Tribe), including for determining the reasonable range of alternatives for that project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429912-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reliance on prior studies and decisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In completing an environmental review under NEPA for a covered activity, the Secretary may consider and, as appropriate, rely on or adopt prior studies and decisions, if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a429913-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those prior studies and decisions meet the standards for an adequate statement, assessment, or determination under applicable procedures of the Department of Commerce implementing the requirements of NEPA;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429914-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of prior studies and decisions completed under the laws and procedures of a State or Indian Tribe, those laws and procedures are of equal or greater rigor than those of each applicable Federal law, including NEPA, implementing procedures of the Department of Commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429915-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the prior studies and decisions are informed by other analysis or documentation that would have been prepared if the prior studies and decisions were prepared by the Secretary under NEPA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a429916-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a429917-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered activity” means any activity relating to the construction, expansion, or modernization of a facility, the investment in which is eligible for Federal financial assistance under section 4652 or 4656 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429918-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4659/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NEPA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NEPA” means the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a429919-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCIX/s9909"},"text":"Pub. L. 116–283, div. H, title XCIX, § 9909","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dA/s103/d"},"text":"Pub. L. 117–167, div. A, § 103(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1389"},"text":"136 Stat. 1389","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/105/s2/2"},"text":"Pub. L. 118–105, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-02"},"text":"Oct. 2, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1588"},"text":"138 Stat. 1588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a42991a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a42991b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a42991c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this division” and was translated as reading “this title”, meaning title XCIX of div. H of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (f)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a42991d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/105"},"text":"Pub. L. 118–105","children":[],"tail":" added subsecs. (c) to (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
