{"tag":"section","attrib":{"id":"id79ef21d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2435"},"text":null,"children":[{"tag":"num","attrib":{"value":"2435"},"text":"§ 2435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other statutory obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter affects any specific statutory obligation of any Federal agency (1) to coordinate or consult with any other Federal or State agency or (2) to act, or to refrain from acting, contingent upon the recommendations or certification of any other Federal or State agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ef21d3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/136/tIII/s305"},"text":"Pub. L. 94–136, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/741"},"text":"89 Stat. 741","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
