{"tag":"section","attrib":{"id":"id78a5ffdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378"},"text":null,"children":[{"tag":"num","attrib":{"value":"378"},"text":"§ 378.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a5ffdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States district courts shall have jurisdiction to prevent and restrain violations of this chapter and to provide other appropriate injunctive or equitable relief, including money damages, for the violations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5ffde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General of the United States shall administer and enforce this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5ffdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, local, and tribal enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5ffe0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a5ffe1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, through its attorney general, or a local government or Indian tribe that levies a tax subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a/a/3"},"text":"section 376a(a)(3) of this title","children":[],"tail":", through its chief law enforcement officer, may bring an action in a United States district court to prevent and restrain violations of this chapter by any person or to obtain any other appropriate relief from any person for violations of this chapter, including civil penalties, money damages, and injunctive or other equitable relief."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffe2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sovereign immunity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be deemed to abrogate or constitute a waiver of any sovereign immunity of a State or local government or Indian tribe against any unconsented lawsuit under this chapter, or otherwise to restrict, expand, or modify any sovereign immunity of a State or local government or Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5ffe3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, through its attorney general, or a local government or Indian tribe that levies a tax subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s376a/a/3"},"text":"section 376a(a)(3) of this title","children":[],"tail":", through its chief law enforcement officer, may provide evidence of a violation of this chapter by any person not subject to State, local, or tribal government enforcement actions for violations of this chapter to the Attorney General of the United States or a United States attorney, who shall take appropriate actions to enforce this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5ffe4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of penalties collected","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a5ffe5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a separate account in the Treasury known as the “PACT Anti-Trafficking Fund”. Notwithstanding any other provision of law and subject to subparagraph (B), an amount equal to 50 percent of any criminal and civil penalties collected by the Federal Government in enforcing this chapter shall be transferred into the PACT Anti-Trafficking Fund and shall be available to the Attorney General of the United States for purposes of enforcing this chapter and other laws relating to contraband tobacco products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffe6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount available to the Attorney General of the United States under subparagraph (A), not less than 50 percent shall be made available only to the agencies and offices within the Department of Justice that were responsible for the enforcement actions in which the penalties concerned were imposed or for any underlying investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5ffe7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonexclusivity of remedy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a5ffe8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies available under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s377"},"text":"section 377 of this title","children":[],"tail":" are in addition to any other remedies available under Federal, State, local, tribal, or other law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffe9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State court proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to expand, restrict, or otherwise modify any right of an authorized State official to proceed in State court, or take other enforcement actions, on the basis of an alleged violation of State or other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal court proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to expand, restrict, or otherwise modify any right of an authorized Indian tribal government official to proceed in tribal court, or take other enforcement actions, on the basis of an alleged violation of tribal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a5ffeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to expand, restrict, or otherwise modify any right of an authorized local government official to proceed in State court, or take other enforcement actions, on the basis of an alleged violation of local or other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5ffec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons dealing in tobacco products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who holds a permit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5712"},"text":"section 5712 of title 26","children":[],"tail":" (regarding permitting of manufacturers and importers of tobacco products and export warehouse proprietors) may bring an action in an appropriate United States district court to prevent and restrain violations of this chapter by any person other than a State, local, or tribal government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5ffed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5ffee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons dealing in tobacco products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who commences a civil action under subsection (d) shall inform the Attorney General of the United States of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5ffef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, local, and tribal actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the attorney general of any State, or chief law enforcement officer of any locality or tribe, that commences a civil action under this section should inform the Attorney General of the United States of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a5fff0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a5fff1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General of the United States shall make available to the public, by posting information on the Internet and by other appropriate means, information regarding all enforcement actions brought by the United States, or reported to the Attorney General of the United States, under this section, including information regarding the resolution of the enforcement actions and how the Attorney General of the United States has responded to referrals of evidence of violations pursuant to subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a5fff2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s378/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-03-31"},"text":"March 31, 2010","children":[],"tail":", and every year thereafter until the date that is 5 years after "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"March 31, 2010","children":[],"tail":", the Attorney General of the United States shall submit to Congress a report containing the information described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a5fff3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-19/ch699/s4"},"text":"Oct. 19, 1949, ch. 699, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/154/s2/e"},"text":"Pub. L. 111–154, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1101"},"text":"124 Stat. 1101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a5fff4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a5fff5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78a5fff6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 378, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-19/ch699/s4"},"text":"act Oct. 19, 1949, ch. 699, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch695/s1"},"text":"Aug. 9, 1955, ch. 695, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/628"},"text":"69 Stat. 628","children":[],"tail":", which provided U.S. district courts with jurisdiction to prevent and restrain violations of this chapter, was repealed, effective on the date that is 90 days after "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"March 31, 2010","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/111/154"},"text":"Pub. L. 111–154","children":[],"tail":", §§ 2(e), 6, "},{"tag":"date","attrib":{"date":"2010-03-31"},"text":"Mar. 31, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1101"},"text":"124 Stat. 1101","children":[],"tail":", 1110."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a5fff7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78a5fff8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-03-31"},"text":"March 31, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/154/s6"},"text":"section 6 of Pub. L. 111–154","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s375"},"text":"section 375 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
