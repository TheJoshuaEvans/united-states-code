{"tag":"section","attrib":{"id":"id789c89db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290d"},"text":null,"children":[{"tag":"num","attrib":{"value":"290d"},"text":"§ 290d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of standard reference data; cost recovery; proceeds subject to National Institute of Standards and Technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Standard reference data conforming to standards established by the Secretary may be made available and sold by the Secretary or by a person or agency designated by him. To the extent practicable and appropriate, the prices established for such data may reflect the cost of collection, compilation, evaluation, publication, and dissemination of the data, including administrative expenses; and the amounts received shall be subject to the Act of ","children":[{"tag":"date","attrib":{"date":"1901-03-03"},"text":"March 3, 1901","children":[],"tail":", as amended ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s271"},"text":"15 U.S.C. 271","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789c89dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/396/s5"},"text":"Pub. L. 90–396, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-11"},"text":"July 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/340"},"text":"82 Stat. 340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789c89dd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789c89de-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id789c89df-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1901-03-03"},"text":"March 3, 1901","children":[],"tail":", as amended, referred to in text, means "},{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872"},"text":"act Mar. 3, 1901, ch. 872","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1449"},"text":"31 Stat. 1449","children":[],"tail":", which is classified generally to chapter 7 (§ 271 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
