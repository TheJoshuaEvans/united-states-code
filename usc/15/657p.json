{"tag":"section","attrib":{"id":"id791d52ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p"},"text":null,"children":[{"tag":"num","attrib":{"value":"657p"},"text":"§ 657p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach regarding health insurance options available to children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791d52ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d52ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “Administration” and “Administrator” means the Small Business Administration and the Administrator thereof, respectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “certified development company” means a development company participating in the program under title V of the Small Business Investment Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s695"},"text":"15 U.S.C. 695","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Medicaid program” means the program established under title XIX of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396"},"text":"42 U.S.C. 1396","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Service Corps of Retired Executives” means the Service Corps of Retired Executives authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/b/1"},"text":"section 637(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business concern” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business development center” means a small business development center described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648"},"text":"section 648 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” has the meaning given that term for purposes of title XXI of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397aa"},"text":"42 U.S.C. 1397aa","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State Children’s Health Insurance Program” means the State Children’s Health Insurance Program established under title XXI of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397aa"},"text":"42 U.S.C. 1397aa","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “task force” means the task force established under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “women’s business center” means a women’s business center described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s656"},"text":"section 656 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d52b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of task force","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d52b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a task force to conduct a nationwide campaign of education and outreach for small business concerns regarding the availability of coverage for children through private insurance options, the Medicaid program, and the State Children’s Health Insurance Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The task force shall consist of the Administrator, the Secretary of Health and Human Services, the Secretary of Labor, and the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The campaign conducted under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d52bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to educate the owners of small business concerns about the value of health coverage for children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding options available to the owners and employees of small business concerns to make insurance more affordable, including Federal and State tax deductions and credits for health care-related expenses and health insurance expenses and Federal tax exclusion for health insurance options available under employer-sponsored cafeteria plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s125"},"text":"section 125 of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to educate the owners of small business concerns about assistance available through public programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to educate the owners and employees of small business concerns regarding the availability of the hotline operated as part of the Insure Kids Now program of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the task force may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d52c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use any business partner of the Administration, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791d52c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business development center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d52c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified development company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d52c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a women’s business center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d52c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Service Corps of Retired Executives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791d52c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a memorandum of understanding with a chamber of commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d52c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership with any appropriate small business concern or health advocacy group; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate outreach programs at regional offices of the Department of Health and Human Services to work with district offices of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Website","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that links to information on the eligibility and enrollment requirements for the Medicaid program and State Children’s Health Insurance Program of each State are prominently displayed on the website of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d52ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d52cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2009-02-04"},"text":"February 4, 2009","children":[],"tail":", and every 2 years thereafter, the Administrator shall submit to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives a report on the status of the nationwide campaign conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d52cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657p/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report submitted under subparagraph (A) shall include a status update on all efforts made to educate owners and employees of small business concerns on options for providing health insurance for children through public and private alternatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d52cd-552d-11f1-9071-ff305b7c3ff0"},"tex