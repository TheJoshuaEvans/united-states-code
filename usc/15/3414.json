{"tag":"section","attrib":{"id":"id7a1c7338-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414"},"text":null,"children":[{"tag":"num","attrib":{"value":"3414"},"text":"§ 3414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1c7339-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person to violate any provision of this chapter or any rule or order under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c733a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c733b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), whenever it appears to the Commission that any person is engaged or about to engage in any act or practice which constitutes or will constitute a violation of any provision of this chapter, or of any rule or order thereunder, the Commission may bring an action in the District Court of the United States for the District of Columbia or any other appropriate district court of the United States to enjoin such act or practice and to enforce compliance with this chapter, or any rule or order thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c733c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of emergency orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever it appears to the President that any person has engaged, is engaged, or is about to engage in acts or practices constituting a violation of any order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3362"},"text":"section 3362 of this title","children":[],"tail":" or any order or supplemental order issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3363"},"text":"section 3363 of this title","children":[],"tail":", the President may bring a civil action in any appropriate district court of the United States to enjoin such acts or practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c733d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/a/4/B"},"text":"Pub. L. 101–60, § 3(a)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-07-26"},"text":"July 26, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/158"},"text":"103 Stat. 158","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c733e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action under paragraph (1) or (2), the court shall, upon a proper showing, issue a temporary restraining order or preliminary or permanent injunction without bond. In any such action, the court may also issue a mandatory injunction commanding any person to comply with any applicable provision of law, rule, or order, or ordering such other legal or equitable relief as the court determines appropriate, including refund or restitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c733f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal referral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may transmit such evidence as may be available concerning any acts or practices constituting any possible violations of the Federal antitrust laws to the Attorney General who may institute appropriate criminal proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7340-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1c7341-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who knowingly violates any provision of this chapter, or any provision of any rule or order under this chapter, shall be subject to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1c7342-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in clause (ii) a civil penalty, which the Commission may assess, of not more than $1,000,000 for any one violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1c7343-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty, which the President may assess, of not more than $1,000,000, in the case of any violation of an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3362"},"text":"section 3362 of this title","children":[],"tail":" or an order or supplemental order under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3363"},"text":"section 3363 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c7344-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Knowing” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A) the term “knowing” means the having of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1c7345-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual knowledge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1c7346-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the constructive knowledge deemed to be possessed by a reasonable individual who acts under similar circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c7347-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Each day separate violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, in the case of a continuing violation, each day of violation shall constitute a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c7348-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be subject to any civil penalty under this paragraph with respect to any violation occurring more than 3 years before the date on which such person is provided notice of the proposed penalty under subparagraph (E). The preceding sentence shall not apply in any case in which an untrue statement of material fact was made to the Commission or a State or Federal agency by, or acquiesced to by, the violator with respect to the acts or omissions constituting such violation, or if there was omitted a material fact necessary in order to make any statement made by, or acquiesced to by, the violator with respect to such acts or omissions not misleading in light of circumstances under such statement was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c7349-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessed by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before assessing any civil penalty under this paragraph, the Commission shall provide to such person notice of the proposed penalty. Following receipt of notice of the proposed penalty by such person, the Commission shall, by order, asssess ","children":[{"tag":"ref","attrib":{"idref":"fn002493"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002493"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “assess”."}],"tail":" such penalty."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c734a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/b/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the civil penalty has not been paid within 60 calendar days after the assessment order has been made under subparagraph (E), the Commission shall institute an action in the appropriate district court of the United States for an order affirming the assessment of the civil penalty. The court shall have authority to review de novo the law and the facts involved, and shall have jurisdiction to enter a judgment enforcing, modifying, and enforcing as so modified, or setting aside in whole or in part, such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c734b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c734c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of chapter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in the case of violations covered under paragraph (3), any person who knowingly and willfully violates any provision of this chapter shall be subject to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1c734d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fine of not more than $1,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c734e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imprisonment for not more than 5 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c734f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both such fine and such imprisonment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7350-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of rules or orders generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in the case of violations covered under paragraph (3), any person who knowingly and willfully violates any rule or order under this chapter (other than an order of the Commission assessing a civil penalty under subsection (b)(4)(E)), shall be subject to a fine of not more than $50,000 for each day on which the offense occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7351-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of emergency orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly and willfully violates an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3362"},"text":"section 3362 of this title","children":[],"tail":" or an order or supplemental order under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3363"},"text":"section 3363 of this title","children":[],"tail":" shall be fined not more than $50,000 for each violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7352-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Each day separate violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, each day of violation shall constitute a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7353-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Knowingly” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “knowingly”, when used with respect to any act or omission by any person, means such person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1c7354-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had actual knowledge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1c7355-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3414/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had constructive knowledge deemed to be possessed by a reasonable individual who acts under similar circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c7356-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tV/s504"},"text":"Pub. L. 95–621, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3401"},"text":"92 Stat. 3401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/a/4"},"text":"Pub. L. 101–60, § 3(a)(4)","children":[],"tail":", (b)(6), "},{"tag":"date","attrib":{"date":"1989-07-26"},"text":"July 26, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/158"},"text":"103 Stat. 158","children":[],"tail":", 159; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s314/a/2"},"text":"Pub. L. 109–58, title III, § 314(a)(2)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/690"},"text":"119 Stat. 690","children":[],"tail":", 691.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1c7357-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1c7358-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1c7359-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s314/b/2"},"text":"Pub. L. 109–58, § 314(b)(2)","children":[],"tail":", substituted “$1,000,000” for “$5,000” in cl. (i) and “$1,000,000” for “$25,000” in cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s314/a/2/A"},"text":"Pub. L. 109–58, § 314(a)(2)(A)","children":[],"tail":", substituted “$1,000,000” for “$5,000” in subpar. (A) and “5 years” for “two years” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s314/a/2/B"},"text":"Pub. L. 109–58, § 314(a)(2)(B)","children":[],"tail":", substituted “$50,000 for each day on which the offense occurs” for “$500 for each violation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b/6"},"text":"Pub. L. 101–60, § 3(b)(6)","children":[],"tail":", struck out par. (2) designation and par. (1) making it unlawful to sell natural gas at a first sale price in excess of any applicable maximum lawful price under this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/a/4"},"text":"Pub. L. 101–60, § 3(a)(4)","children":[],"tail":", substituted “paragraph (2)” for “paragraphs (2) and (3)” in par. (1), struck out par. (3) which related to enforcement of incremental pricing, and substituted “paragraph (1) or (2)” for “paragraph (1), (2), or (3)” in par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1c735a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a1c735b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b/6"},"text":"section 3(b)(6) of Pub. L. 101–60","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b"},"text":"section 3(b) of Pub. L. 101–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3372"},"text":"section 3372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
