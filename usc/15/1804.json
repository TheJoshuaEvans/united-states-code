{"tag":"section","attrib":{"id":"id79c440fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1804"},"text":null,"children":[{"tag":"num","attrib":{"value":"1804"},"text":"§ 1804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement of joint operating arrangements previously adjudged unlawful under antitrust laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c440fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any final judgment rendered in any action brought by the United States under which a joint operating arrangement has been held to be unlawful under any antitrust law, any party to such final judgment may reinstitute said joint newspaper operating arrangement to the extent permissible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1803/a"},"text":"section 1803(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c440fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1803"},"text":"section 1803 of this title","children":[],"tail":" shall apply to the determination of any civil or criminal action pending in any district court of the United State "},{"tag":"ref","attrib":{"idref":"fn002417"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002417"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “States”."}],"tail":" on "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", in which it is alleged that any such joint operating agreement is unlawful under any antitrust law."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c440fd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/353/s5"},"text":"Pub. L. 91–353, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/467"},"text":"84 Stat. 467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
