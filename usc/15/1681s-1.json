{"tag":"section","attrib":{"id":"id79aebd48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681s–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681s–1"},"text":"§ 1681s–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on overdue child support obligations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter, a consumer reporting agency shall include in any consumer report furnished by the agency in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of this title","children":[],"tail":", any information on the failure of the consumer to pay overdue support which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79aebd49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681s–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aebd4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681s–1/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the consumer reporting agency by a State or local child support enforcement agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aebd4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681s–1/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the consumer reporting agency and verified by any local, State, or Federal Government agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aebd4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681s–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" antedates the report by 7 years or less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79aebd4d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s622"},"text":"Pub. L. 90–321, title VI, § 622","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/537/s2/a"},"text":"Pub. L. 102–537, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3531"},"text":"106 Stat. 3531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79aebd4e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79aebd4f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79aebd50-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/s622"},"text":"section 622 of Pub. L. 90–321","children":[],"tail":" was renumbered section 625 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681t"},"text":"section 1681t of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79aebd51-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","childre