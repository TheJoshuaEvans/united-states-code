{"tag":"section","attrib":{"id":"id792b842d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690n"},"text":null,"children":[{"tag":"num","attrib":{"value":"690n"},"text":"§ 690n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal or suspension of directors or officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Using the procedures for removing or suspending a director or an officer of a licensee set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s687e"},"text":"section 687e of this title","children":[],"tail":" (to the extent such procedures are not inconsistent with the requirements of this part), the Administrator may remove or suspend any director or officer of any Renewable Fuel Capital Investment company."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id792b842e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s395"},"text":"Pub. L. 85–699, title III, § 395","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1783"},"text":"121 Stat. 1783","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
