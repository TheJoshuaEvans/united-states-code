{"tag":"section","attrib":{"id":"id79c44100-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821"},"text":null,"children":[{"tag":"num","attrib":{"value":"1821"},"text":"§ 1821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter unless the context otherwise requires:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c44101-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “management” means any person who organizes, exercises control over, or administers or who is responsible for organizing, directing, or administering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c44102-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c44103-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “sore” when used to describe a horse means that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79c44104-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an irritating or blistering agent has been applied, internally or externally, by a person to any limb of a horse,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c44105-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any burn, cut, or laceration has been inflicted by a person on any limb of a horse,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c44106-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any tack, nail, screw, or chemical agent has been injected by a person into or used by a person on any limb of a horse, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79c44107-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other substance or device has been used by a person on any limb of a horse or a person has engaged in a practice involving a horse,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and, as a result of such application, infliction, injection, use, or practice, such horse suffers, or can reasonably be expected to suffer, physical pain or distress, inflammation, or lameness when walking, trotting, or otherwise moving, except that such term does not include such an application, infliction, injection, use, or practice in connection with the therapeutic treatment of a horse by or under the supervision of a person licensed to practice veterinary medicine in the State in which such treatment was given.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c44108-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1821/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c44109-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/540/s2"},"text":"Pub. L. 91–540, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-09"},"text":"Dec. 9, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1404"},"text":"84 Stat. 1404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/360/s3"},"text":"Pub. L. 94–360, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-13"},"text":"July 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/915"},"text":"90 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c4410a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79c4410b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79c4410c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/360"},"text":"Pub. L. 94–360","children":[],"tail":" added pars. (1) and (2), redesignated subsec. (a), defining “sore” as meaning that certain substances or devices had been applied to any limb of a horse prior to "},{"tag":"date","attrib":{"date":"1970-12-09"},"text":"Dec. 9, 1970","children":[],"tail":", resulting in, or reasonably likely to result in, such horse suffering physical pain or distress when walking or trotting, as par. (3) and, as so redesignated, struck out requirement that such substance or device had to have been applied prior to "},{"tag":"date","attrib":{"date":"1970-12-09"},"text":"Dec. 9, 1970","children":[],"tail":" in order for a horse to be considered “sored” for purposes of this chapter, and substituted par. (4) defining “State” for subsec. (b) defining “commerce” as between a point in any State or possession of the United States and any point outside thereof, or between points within the same State or possession of the United States but through any place outside thereof, or within the District of Columbia, or from any foreign country to any point within the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c4410d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c4410e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/360/s1/a"},"text":"Pub. L. 94–360, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-13"},"text":"July 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/915"},"text":"90 Stat. 915","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/360/s1/a"},"text":"“This Act [amending this section and sections 1822 to 1825, 1827, 1830, and 1831 of this title and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1831"},"text":"section 1831 of this title","children":[],"tail":"] may be cited as the ‘Horse Protection Act Amendments of 1976’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79c4410f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/540/s1"},"text":"Pub. L. 91–540, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-09"},"text":"Dec. 9, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1404"},"text":"84 Stat. 1404","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/94/360/s2"},"text":"Pub. L. 94–360, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-13"},"text":"July 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/915"},"text":"90 Stat. 915","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/360/s2"},"text":"“That this Act [enacting this chapter] may be cited as the ‘Horse Protection Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79c44110-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79c44111-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
