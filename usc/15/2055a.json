{"tag":"section","attrib":{"id":"id79cb45f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2055a"},"text":"§ 2055a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly available consumer product safety information database","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79cb45f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cb45f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Commission shall, in accordance with the requirements of this section, establish and maintain a database on the safety of consumer products, and other products or substances regulated by the Commission, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cb45f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cb45f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" searchable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cb45f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessible through the Internet website of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cb45f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of detailed implementation plan to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Commission shall transmit to the appropriate Congressional committees a detailed plan for establishing and maintaining the database required by paragraph (1), including plans for the operation, content, maintenance, and functionality of the database. The plan shall detail the integration of the database into the Commission’s overall information technology improvement objectives and plans. The plan submitted under this subsection shall include a detailed implementation schedule for the database, and plans for a public awareness campaign to be conducted by the Commission to increase consumer awareness of the database."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cb45f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of initial availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the date on which the Commission submits the plan required by paragraph (2), the Commission shall establish the database required by paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cb45f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content and organization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cb45f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c)(4), the database shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cb45fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Reports of harm relating to the use of consumer products, and other products or substances regulated by the Commission, that are received by the Commission from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cdb6fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb6fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local, State, or Federal government agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb6fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb6fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child service providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb6ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb700-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information derived by the Commission from notice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2064/c"},"text":"section 2064(c) of this title","children":[],"tail":" or any notice to the public relating to a voluntary corrective action taken by a manufacturer, in consultation with the Commission, of which action the Commission has notified the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb701-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The comments received by the Commission under subsection (c)(2)(A) to the extent requested under subsection (c)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb702-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing the database, the Commission shall establish the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb703-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic, telephonic, and paper-based means of submitting, for inclusion in the database, reports described in paragraph (1)(A) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb704-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A requirement that any report described in paragraph (1)(A) submitted for inclusion in such database include, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cdb705-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the consumer product (or other product or substance regulated by the Commission) concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb706-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the manufacturer or private labeler of the consumer product (or other product or substance regulated by the Commission);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb707-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the harm relating to the use of the consumer product (or other product or substance regulated by the Commission);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb708-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contact information for the person submitting the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb709-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a verification by the person submitting the information that the information submitted is true and accurate to the best of the person’s knowledge and that the person consents that such information be included in the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb70a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the reports received under paragraph (1), the Commission shall include in the database, consistent with the requirements of section 2055(a) and (b) of this title, any additional information it determines to be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb70b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization of database","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall categorize the information available on the database in a manner consistent with the public interest and in such manner as it determines to facilitate easy use by consumers and shall ensure, to the extent practicable, that the database is sortable and accessible by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb70c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which information is submitted for inclusion in the database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb70d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the consumer product (or other product or substance regulated by the Commission);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb70e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the model name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb70f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer’s or private labeler’s name; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb710-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other elements as the Commission considers in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb711-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall provide clear and conspicuous notice to users of the database that the Commission does not guarantee the accuracy, completeness, or adequacy of the contents of the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb712-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of contact information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may not disclose, under this section, the name, address, or other contact information of any individual or entity that submits to the Commission a report described in paragraph (1)(A), except that the Commission may provide such information to the manufacturer or private labeler of the product with the express written consent of the person submitting the information. Consumer information provided to a manufacturer or private labeler under this section may not be used or disseminated to any other party for any purpose other than verifying a report submitted under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb713-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedural requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb714-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of reports to manufacturers and private labelers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 business days after the Commission receives a report described in subsection (b)(1)(A) which includes the information required by subsection (b)(2)(B), the Commission shall to the extent practicable transmit the report, subject to subsection (b)(6), to the manufacturer or private labeler identified in the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb715-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to comment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb716-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission transmits a report under paragraph (1) to a manufacturer or private labeler, the Commission shall provide such manufacturer or private labeler an opportunity to submit comments to the Commission on the information contained in such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb717-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for inclusion in database","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A manufacturer or private labeler may request the Commission to include its comments in the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb718-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential matter","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cdb719-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission transmits a report received under paragraph (1) to a manufacturer or private labeler, the manufacturer or private labeler may review the report for confidential information and request that portions of the report identified as confidential be so designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb71a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission determines that the designated information contains, or relates to, a trade secret or other matter referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", or that is subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", the Commission shall redact the designated information in the report before it is placed in the database."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb71b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission determines that the designated information is not confidential under clause (ii), the Commission shall notify the manufacturer or private labeler and include the information in the database. The manufacturer or private labeler may bring an action in the district court of the United States in the district in which the complainant resides, or has its principal place of business, or in the United States District Court for the District of Columbia, to seek removal of the information from the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb71c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of reports and comments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb71d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4)(A) or paragraph (5), if the Commission receives a report described in subsection (b)(1)(A), the Commission shall make the report available in the database not later than the 10th business day after the date on which the Commission transmits the report under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb71e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4)(A), if the Commission receives a comment under paragraph (2)(A) with respect to a report described in subsection (b)(1)(A) and a request with respect to such comment under paragraph (2)(B) of this subsection, the Commission shall make such comment available in the database at the same time as such report or as soon as practicable thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb71f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inaccurate information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb720-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inaccurate information in reports and comments received","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, prior to making a report described in subsection (b)(1)(A) or a comment described in paragraph (2) of this subsection available in the database, the Commission receives notice that the information in such report or comment is materially inaccurate, the Commission shall stay the publication of the report on the database as required under paragraph (3) for a period of no more than 5 additional days. If the Commission determines that the information in such report or comment is materially inaccurate, the Commission shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cdb721-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decline to add the materially inaccurate information to the database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb722-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct the materially inaccurate information in the report or comment and add the report or comment to the database; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb723-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add information to correct inaccurate information in the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb724-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inaccurate information in database","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commission determines, after investigation, that information previously made available in the database is materially inaccurate or duplicative of information in the database, the Commission shall, not later than 7 business days after such determination—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cdb725-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove such information from the database;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb726-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct such information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb727-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add information to correct inaccurate information in the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb728-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obtaining certain product identification information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb729-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Commission receives a report described in subsection (b)(1)(A) that does not include the model or serial number of the consumer product concerned, the Commission shall seek from the individual or entity submitting the report such model or serial number or, if such model or serial number is not available, a photograph of the product. If the Commission obtains information relating to the serial or model number of the product or a photograph of the product, it shall immediately forward such information to the manufacturer of the product. The Commission shall make the report available in the database on the 15th business day after the date on which the Commission transmits the report under paragraph (1) and shall include in the database any additional information about the product obtained under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb72a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph shall be construed to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79cdb72b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the Commission to delay transmission of the report under paragraph (1) until the Commission has obtained the model or serial number or a photograph of the consumer product concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79cdb72c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make inclusion in the database of a report described in subsection (b)(1)(A) contingent on the availability of the model or serial number or a photograph of the consumer product concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb72d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall submit to the appropriate Congressional committees an annual report on the database, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb72e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation, content, maintenance, functionality, and cost of the database for the reporting year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb72f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of reports and comments for the year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb730-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received by the Commission under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb731-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" posted on the database; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb732-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corrected on or removed from the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb733-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 2 years after the date on which the Commission establishes the database under this section, the Comptroller General shall submit a report to the appropriate Congressional committees containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb734-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of the general utility of the database, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb735-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the extent of use of the database by consumers, including whether the database is accessed by a broad range of the public and whether consumers find the database to be useful; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb736-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts by the Commission to inform the public about the database; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb737-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for measures to increase use of the database by consumers and to ensure use by a broad range of the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb738-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain notice and disclosure requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb739-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of section 2055(a) and (b) of this title shall not apply to the disclosure under this section of a report described in subsection (b)(1)(A) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb73a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not be construed to exempt from the requirements of section 2055(a) and (b) of this title information received by the Commission under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79cdb73b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2064/b"},"text":"section 2064(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79cdb73c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other mandatory or voluntary reporting program established between a retailer, manufacturer, or private labeler and the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cdb73d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harm defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “harm” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cdb73e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injury, illness, or death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cdb73f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2055a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk of injury, illness, or death, as determined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79cdb740-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s6A"},"text":"Pub. L. 92–573, § 6A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s212/a"},"text":"Pub. L. 110–314, title II, § 212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3048"},"text":"122 Stat. 3048","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/28/s7"},"text":"Pub. L. 112–28, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-12"},"text":"Aug. 12, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/281"},"text":"125 Stat. 281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79cdb741-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79cdb742-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79cdb743-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/28/s7/1"},"text":"Pub. L. 112–28, § 7(1)","children":[],"tail":", inserted “or paragraph (5)” after “paragraph (4)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/28/s7/2"},"text":"Pub. L. 112–28, § 7(2)","children":[],"tail":", substituted “receives notice that the information in such report or comment is materially inaccurate, the Commission shall stay the publication of the report on the database as required under paragraph (3) for a period of no more than 5 additional days. If the Commission determines that the information in such report or comment is materially inaccurate, the Commission shall—” for “determines that the information in such report or comment is materially inaccurate, the Commission shall—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/28/s7/3"},"text":"Pub. L. 112–28, § 7(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
