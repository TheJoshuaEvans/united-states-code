{"tag":"section","attrib":{"id":"id7a25e8d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3710b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3710b"},"text":"§ 3710b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rewards for scientific, engineering, and technical personnel of Federal agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each Federal agency that is making expenditures at a rate of more than $50,000,000 per fiscal year for research and development in its Government-operated laboratories shall use the appropriate statutory authority to develop and implement a cash awards program to reward its scientific, engineering, and technical personnel for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2859da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3710b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inventions, innovations, computer software, or other outstanding scientific or technological contributions of value to the United States due to commercial application or due to contributions to missions of the Federal agency or the Federal government,","children":[{"tag":"ref","attrib":{"idref":"fn002502"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002502"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2859db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3710b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exemplary activities that promote the domestic transfer of science and technology development within the Federal Government and result in utilization of such science and technology by American industry or business, universities, State or local governments, or other non-Federal parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2859dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s13"},"text":"Pub. L. 96–480, § 13","children":[],"tail":", as added and renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/99/502"},"text":"Pub. L. 99–502","children":[],"tail":", §§ 6, 9(e)(1), "},{"tag":"date","attrib":{"date":"1986-10-20"},"text":"Oct. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1792"},"text":"100 Stat. 1792","children":[],"tail":", 1797; renumbered § 13, "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5122/a/1"},"text":"Pub. L. 100–418, title V, § 5122(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1438"},"text":"102 Stat. 1438","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/519/tIII/s302"},"text":"Pub. L. 100–519, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2597"},"text":"102 Stat. 2597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2859dd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2859de-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a2859df-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/519"},"text":"Pub. L. 100–519","children":[],"tail":" inserted “computer software,” after “inventions, innovations,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
