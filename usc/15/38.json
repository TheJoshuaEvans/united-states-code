{"tag":"section","attrib":{"id":"id77beacdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s38"},"text":null,"children":[{"tag":"num","attrib":{"value":"38"},"text":"§ 38.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Association of marine insurance companies; application of antitrust laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77beace0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s38/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77beace1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s38/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “association” means any association, exchange, pool, combination, or other arrangement for concerted action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77beace2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s38/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “marine insurance companies” means any persons, companies, or associations, authorized to write marine insurance or reinsurance under the laws of the United States or of a State, Territory, District, or possession thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77beace3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s38/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in the “antitrust laws” as designated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":", shall be construed as declaring illegal an association entered into by marine insurance companies for the following purposes: To transact a marine insurance and reinsurance business in the United States and in foreign countries and to reinsure or otherwise apportion among its membership the risks undertaken by such association or any of the component members."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77beace4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch250/s29"},"text":"June 5, 1920, ch. 250, § 29","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1000"},"text":"41 Stat. 1000","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77beace5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77beace6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77beace7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was classified to section 885 of the former Appendix to Title 46, prior to the completion of the enactment of Title 46, Shipping, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1485"},"text":"120 Stat. 1485","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
