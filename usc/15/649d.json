{"tag":"section","attrib":{"id":"id79114488-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s649d"},"text":null,"children":[{"tag":"num","attrib":{"value":"649d"},"text":"§ 649d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central information clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary through the International Trade Administration, shall, only to such extent and in such amounts as are provided in appropriation Acts on and after ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", maintain a central clearinghouse to provide for the collection, dissemination, and exchange of information between programs established pursuant to sections 649a and 649b of this title, the Office of International Trade of the Small Business Administration, and other interested concerns."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79114489-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/481/tIII/s304"},"text":"Pub. L. 96–481, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2333"},"text":"94 Stat. 2333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7911448a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7911448b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7911448c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
