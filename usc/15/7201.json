{"tag":"section","attrib":{"id":"id7a6b0964-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201"},"text":null,"children":[{"tag":"num","attrib":{"value":"7201"},"text":"§ 7201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided in this Act, in this Act, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b0965-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate State regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate State regulatory authority” means the State agency or other authority responsible for the licensure or other regulation of the practice of accounting in the State or States having jurisdiction over a registered public accounting firm or associated person thereof, with respect to the matter in question.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0966-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “audit” means an examination of the financial statements of any issuer by an independent public accounting firm in accordance with the rules of the Board or the Commission (or, for the period preceding the adoption of applicable rules of the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7213"},"text":"section 7213 of this title","children":[],"tail":", in accordance with then-applicable generally accepted auditing and related standards for such purposes), for the purpose of expressing an opinion on such statements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0967-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “audit committee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b0968-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a committee (or equivalent body) established by and amongst the board of directors of an issuer for the purpose of overseeing the accounting and financial reporting processes of the issuer and audits of the financial statements of the issuer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0969-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no such committee exists with respect to an issuer, the entire board of directors of the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b096a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “audit report” means a document or other record—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b096b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared following an audit performed for purposes of compliance by an issuer with the requirements of the securities laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b096c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in which a public accounting firm either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6b096d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the opinion of that firm regarding a financial statement, report, or other document; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6b096e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asserts that no such opinion can be expressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b096f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Public Company Accounting Oversight Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7211"},"text":"section 7211 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0970-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0971-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “issuer” means an issuer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of this title","children":[],"tail":"), the securities of which are registered under section 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, or that is required to file reports under section 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title, or that files or has filed a registration statement that has not yet become effective under the Securities Act of 1933 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.), and that it has not withdrawn."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0972-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-audit services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-audit services” means any professional services provided to an issuer by a registered public accounting firm, other than those provided to an issuer in connection with an audit or a review of the financial statements of an issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0973-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person associated with a public accounting firm","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b0974-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “person associated with a public accounting firm” (or with a “registered public accounting firm”) and “associated person of a public accounting firm” (or of a “registered public accounting firm”) mean any individual proprietor, partner, shareholder, principal, accountant, or other professional employee of a public accounting firm, or any other independent contractor or entity that, in connection with the preparation or issuance of any audit report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6b0975-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shares in the profits of, or receives compensation in any other form from, that firm; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6b0976-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates as agent or otherwise on behalf of such accounting firm in any activity of that firm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0977-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may, by rule, exempt persons engaged only in ministerial tasks from the definition in subparagraph (A), to the extent that the Board determines that any such exemption is consistent with the purposes of this Act, the public interest, or the protection of investors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0978-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigative and enforcement authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of sections 7202(c), 7211(c), 7215, and 7217(c) of this title and the rules of the Board and Commission issued thereunder, except to the extent specifically excepted by such rules, the terms defined in subparagraph (A) shall include any person associated, seeking to become associated, or formerly associated with a public accounting firm, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6b0979-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority to conduct an investigation of such person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7215/b"},"text":"section 7215(b) of this title","children":[],"tail":" shall apply only with respect to any act or practice, or omission to act, by the person while such person was associated or seeking to become associated with a registered public accounting firm; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6b097a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the authority to commence a disciplinary proceeding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7215/c/1"},"text":"section 7215(c)(1) of this title","children":[],"tail":", or impose sanctions under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7215/c/4"},"text":"section 7215(c)(4) of this title","children":[],"tail":", against such person shall apply only with respect to—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id7a6b097b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct occurring while such person was associated or seeking to become associated with a registered public accounting firm; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a6b097c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/9/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-cooperation, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7215/b/3"},"text":"section 7215(b)(3) of this title","children":[],"tail":", with respect to a demand in a Board investigation for testimony, documents, or other information relating to a period when such person was associated or seeking to become associated with a registered public accounting firm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b097d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “professional standards” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b097e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accounting principles that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6b097f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/10/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established by the standard setting body described in section 19(b) of the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s/b"},"text":"15 U.S.C. 77s(b)","children":[],"tail":"], or prescribed by the Commission under section 19(a) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s/a"},"text":"15 U.S.C. 77s(a)","children":[],"tail":"] or "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m/b"},"text":"section 78m(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6b0980-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/10/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant to audit reports for particular issuers, or dealt with in the quality control system of a particular registered public accounting firm; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0981-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" auditing standards, standards for attestation engagements, quality control policies and procedures, ethical and competency standards, and independence standards (including rules implementing title II) that the Board or the Commission determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6b0982-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relate to the preparation or issuance of audit reports for issuers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6b0983-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are established or adopted by the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7213/a"},"text":"section 7213(a) of this title","children":[],"tail":", or are promulgated as rules of the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0984-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public accounting firm","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public accounting firm” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b0985-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proprietorship, partnership, incorporated association, corporation, limited liability company, limited liability partnership, or other legal entity that is engaged in the practice of public accounting or preparing or issuing audit reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0986-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent so designated by the rules of the Board, any associated person of any entity described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0987-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registered public accounting firm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “registered public accounting firm” means a public accounting firm registered with the Board in accordance with this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7988-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rules of the Board” means the bylaws and rules of the Board (as submitted to, and approved, modified, or amended by the Commission, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7217"},"text":"section 7217 of this title","children":[],"tail":"), and those stated policies, practices, and interpretations of the Board that the Commission, by rule, may deem to be rules of the Board, as necessary or appropriate in the public interest or for the protection of investors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d7989-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “security” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d798a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “securities laws” means the provisions of law referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/47"},"text":"section 78c(a)(47) of this title","children":[],"tail":" and includes the rules, regulations, and orders issued by the Commission thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d798b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, Puerto Rico, the Virgin Islands, or any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d798c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7201/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign auditor oversight authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign auditor oversight authority” means any governmental body or other entity empowered by a foreign government to conduct inspections of public accounting firms or otherwise to administer or enforce laws related to the regulation of public accounting firms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6d798d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s2/a"},"text":"Pub. L. 107–204, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/746"},"text":"116 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX"},"text":"Pub. L. 111–203, title IX","children":[],"tail":", §§ 929F(g)(1), 981(a), 982(a)(2), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1854"},"text":"124 Stat. 1854","children":[],"tail":", 1926, 1928.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6d798e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6d798f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a6d7990-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/745"},"text":"116 Stat. 745","children":[],"tail":", known as the Sarbanes-Oxley Act of 2002. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Act of 1933, referred to in par. (7), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"act May 27, 1933, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title II, referred to in par. (10)(B), means title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/771"},"text":"116 Stat. 771","children":[],"tail":", which enacted subchapter II of this chapter and amended sections 78c, 78j–1, 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" and 78q of this title. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a6d7991-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s982/a/2"},"text":"Pub. L. 111–203, § 982(a)(2)","children":[],"tail":", substituted “Except as otherwise specifically provided in this Act, in this” for “In this” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s929F/g/1"},"text":"Pub. L. 111–203, § 929F(g)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s981/a"},"text":"Pub. L. 111–203, § 981(a)","children":[],"tail":", added par. (17)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a6d7992-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a6d7993-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a6d7994-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/222/s1"},"text":"Pub. L. 116–222, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-18"},"text":"Dec. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1063"},"text":"134 Stat. 1063","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/222/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7214a"},"text":"section 7214a of this title","children":[],"tail":" and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7214"},"text":"section 7214 of this title","children":[],"tail":"] may be cited as the ‘Holding Foreign Companies Accountable Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a6d7995-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s1/a"},"text":"Pub. L. 107–204, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/745"},"text":"116 Stat. 745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/204/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Sarbanes-Oxley Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a6d7996-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"GAO Study and Report Regarding Consolidation of Public Accounting Firms","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tVII/s701"},"text":"Pub. L. 107–204, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/797"},"text":"116 Stat. 797","children":[],"tail":", directed the Comptroller General, in consultation with the Commission, regulatory agencies in other countries of the Group of Seven Industrialized Nations, the Justice Department, and others, to study the factors resulting in the consolidation of public accounting firms and their impact, and to report the study findings to Congress not later than 1 year after "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
