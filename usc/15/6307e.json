{"tag":"section","attrib":{"id":"id7a57f5bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307e"},"text":"§ 6307e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required disclosures for promoters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a57f5bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures to the boxing commissions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A promoter shall not be entitled to receive any compensation directly or indirectly in connection with a boxing match until it provides to the boxing commission responsible for regulating the match in a State a statement of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of any agreement in writing to which the promoter is a party with any boxer participating in the match;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement made under penalty of perjury that there are no other agreements, written or oral, between the promoter and the boxer with respect to that match; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all fees, charges, and expenses that will be assessed by or through the promoter on the boxer pertaining to the event, including any portion of the boxer’s purse that the promoter will receive, and training expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all payments, gifts, or benefits the promoter is providing to any sanctioning organization affiliated with the event; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reduction in a boxer’s purse contrary to a previous agreement between the promoter and the boxer or a purse bid held for the event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures to the boxer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A promoter shall not be entitled to receive any compensation directly or indirectly in connection with a boxing match until it provides to the boxer it promotes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts of any compensation or consideration that a promoter has contracted to receive from such match;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all fees, charges, and expenses that will be assessed by or through the promoter on the boxer pertaining to the event, including any portion of the boxer’s purse that the promoter will receive, and training expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reduction in a boxer’s purse contrary to a previous agreement between the promoter and the boxer or a purse bid held for the event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be available to State Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A promoter shall make information required to be disclosed under this section available to the chief law enforcement officer of the State in which the match is to be held upon request of such officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f5c9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s13"},"text":"Pub. L. 104–272, § 13","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/2"},"text":"Pub. L. 106–210, § 4(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/324"},"text":"114 Stat. 324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f5ca-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a57f5cb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a57f5cc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s13"},"text":"section 13 of Pub. L. 104–272","children":[],"tail":" was renumbered section 21 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6312"},"text":"section 6312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
