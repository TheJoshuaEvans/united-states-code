{"tag":"section","attrib":{"id":"id7a3b6dfc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4629"},"text":null,"children":[{"tag":"num","attrib":{"value":"4629"},"text":"§ 4629.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoidance of duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out the Initiative, the Secretary of Energy shall ensure that unnecessary duplicative research is not performed at the research facilities (including the national laboratories of the Department of Energy) that are participating in the Initiative.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a3b6dfd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dC/tI/s3149"},"text":"Pub. L. 100–180, div. C, title I, § 3149","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1244"},"text":"101 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
