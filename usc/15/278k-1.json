{"tag":"section","attrib":{"id":"id7897a7f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"278k–1"},"text":"§ 278k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive awards program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7897a7f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish within the Hollings Manufacturing Extension Partnership under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":" and section 278"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title a program of competitive awards among participants described in subsection (b) of this section for the purposes described in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a7fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participants receiving awards under this section shall be Centers, or a consortium of Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a7fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose, themes, and reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a7fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the program established under subsection (a) is to add capabilities to the Hollings Manufacturing Extension Partnership, including the development of projects to solve new or emerging manufacturing problems as determined by the Director, in consultation with the Director of the Hollings Manufacturing Extension Partnership, the MEP Advisory Board, other Federal agencies, and small and medium-sized manufacturers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a7fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Themes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may identify 1 or more themes for a competition carried out under this section, which may vary from year to year, as the Director considers appropriate after assessing the needs of United States manufacturers and the success of previous competitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a7fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Centers may be reimbursed for costs incurred by the Centers under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a7ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications for awards under this section shall be submitted in such manner, at such time, and containing such information as the Director shall require in consultation with the MEP Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a800-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a801-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review and competitively awarded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that awards under this section are peer reviewed and competitively awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a802-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall endeavor to have broad geographic diversity among selected proposals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a803-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall select applications to receive awards that the Director determines will achieve 1 or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7897a804-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improve the competitiveness of industries in the region in which the Center or Centers are located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a805-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Create jobs or train newly hired employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a806-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promote the transfer and commercialization of research and technology from institutions of higher education, national laboratories or other federally funded research programs, and nonprofit research institutes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a807-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruit a diverse manufacturing workforce, including through outreach to underrepresented populations, including individuals identified in section 1885a or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1885b"},"text":"section 1885b of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a808-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other result as the Director determines will advance the objective set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k/c"},"text":"section 278k(c) of this title","children":[],"tail":" or in section 278"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a809-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program Contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of awards under this section shall not be required to provide a matching contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a80a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global marketplace projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making an award under this section, the Director, in consultation with the MEP Advisory Board and the Secretary, may take into consideration whether an application has significant potential for enhancing the competitiveness of small and medium-sized United States manufacturers in the global marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a80b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duration of an award under this section shall be for not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a80c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms used in this section have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7897a80d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s25A"},"text":"Mar. 3, 1901, ch. 872, § 25A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tV/s501/c"},"text":"Pub. L. 114–329, title V, § 501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3031"},"text":"130 Stat. 3031","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10252/c"},"text":"Pub. L. 117–167, div. B, title II, § 10252(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1499"},"text":"136 Stat. 1499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7897a80e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7897a80f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7897a810-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k/f"},"text":"section 278k(f) of this title","children":[],"tail":", prior to the general amendment of section 278k by "},{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7897a811-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" inserted “United States” before “manufacturers”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
