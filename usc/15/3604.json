{"tag":"section","attrib":{"id":"id7a1ebcd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3604"},"text":null,"children":[{"tag":"num","attrib":{"value":"3604"},"text":"§ 3604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provisions of this chapter shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1ebcd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3604/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cooperative or condominium unit sold or offered for sale by the Federal Government, by any State or local government, by any corporate instrumentality of the United States, or by any agency thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ebcd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3604/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cooperative or condominium project in which all units are restricted to nonresidential purposes or uses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1ebcd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3604/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any lease or portion thereof—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1ebcd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3604/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which establishes any leasehold or other estate or interest in, over or under land on or in which one or more residential condominium or cooperative units are located, the termination of which will terminate the condominium or cooperative project, or reduce the number of units in such project, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1ebcd6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3604/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which establishes a leasehold interest in, or other rights to use, possess, or gain access to, a condominium or cooperative unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1ebcd7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s605"},"text":"Pub. L. 96–399, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1675"},"text":"94 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
