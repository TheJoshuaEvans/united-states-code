{"tag":"section","attrib":{"id":"id7a796182-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508"},"text":null,"children":[{"tag":"num","attrib":{"value":"7508"},"text":"§ 7508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a796183-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Nanotechnology Preparedness Center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program shall provide for the establishment, on a merit-reviewed and competitive basis, of an American Nanotechnology Preparedness Center which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a796184-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct, coordinate, collect, and disseminate studies on the societal, ethical, environmental, educational, legal, and workforce implications of nanotechnology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796185-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify anticipated issues related to the responsible research, development, and application of nanotechnology, as well as provide recommendations for preventing or addressing such issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a796186-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for nanomaterials manufacturing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program shall provide for the establishment, on a merit reviewed and competitive basis, of a center to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a796187-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, conduct, coordinate, commission, collect, and disseminate research on new manufacturing technologies for materials, devices, and systems with new combinations of characteristics, such as, but not limited to, strength, toughness, density, conductivity, flame resistance, and membrane separation characteristics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a796188-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop mechanisms to transfer such manufacturing technologies to United States industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a796189-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council, through the Director of the National Nanotechnology Coordination Office, shall submit to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Science—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a79618a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 6 months after ","children":[{"tag":"date","attrib":{"date":"2003-12-03"},"text":"December 3, 2003","children":[],"tail":", a report identifying which agency shall be the lead agency and which other agencies, if any, will be responsible for establishing the Centers described in this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a79618b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7508/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 18 months after ","children":[{"tag":"date","attrib":{"date":"2003-12-03"},"text":"December 3, 2003","children":[],"tail":", a report describing how the Centers described in this section have been established."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a79618c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/153/s9"},"text":"Pub. L. 108–153, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1930"},"text":"117 Stat. 1930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a79618d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a79618e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a79618f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science of House of Representatives changed to Committee on Science and Technology of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, "},{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
