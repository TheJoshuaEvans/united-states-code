{"tag":"section","attrib":{"id":"id7aa441b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9080"},"text":null,"children":[{"tag":"num","attrib":{"value":"9080"},"text":"§ 9080.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, there is appropriated, out of amounts in the Treasury not otherwise appropriated, $32,000,000,000 to carry out this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7aa441b2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4120"},"text":"Pub. L. 116–136, div. A, title IV, § 4120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/501"},"text":"134 Stat. 501","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
