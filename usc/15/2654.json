{"tag":"section","attrib":{"id":"id7a047f40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2654"},"text":null,"children":[{"tag":"num","attrib":{"value":"2654"},"text":"§ 2654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any regulation of the Environmental Protection Agency under subchapter I which is inconsistent with this subchapter shall not be in effect after ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":". Any advanced notice of proposed rulemaking, any proposed rule, and any regulation of the Environmental Protection Agency in effect before "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", which is consistent with the regulations required under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643"},"text":"section 2643 of this title","children":[],"tail":" shall remain in effect and may be used to meet the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643"},"text":"section 2643 of this title","children":[],"tail":", except that any such regulation shall be enforced under this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a047f41-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tII/s214"},"text":"Pub. L. 94–469, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s2"},"text":"Pub. L. 99–519, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2988"},"text":"100 Stat. 2988","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
