{"tag":"section","attrib":{"id":"id794aa469-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s762"},"text":null,"children":[{"tag":"num","attrib":{"value":"762"},"text":"§ 762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established an independent agency in the executive branch to be known as the Federal Energy Administration (hereinafter in this chapter referred to as the “Administration”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id794aa46a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/275/s3"},"text":"Pub. L. 93–275, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-07"},"text":"May 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/97"},"text":"88 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794aa46b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794aa46c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id794aa46d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Energy Administration terminated and functions vested by law in Administration or in its Administrator, officers, and components transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
