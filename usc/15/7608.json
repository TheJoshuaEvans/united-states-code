{"tag":"section","attrib":{"id":"id7a7bd1df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7608"},"text":null,"children":[{"tag":"num","attrib":{"value":"7608"},"text":"§ 7608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7bd1e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any violation of this chapter or the rules required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7607"},"text":"section 7607 of this title","children":[],"tail":" shall be treated as a violation of a rule under section 18 of the Federal Trade Commission Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"15 U.S.C. 57a","children":[],"tail":") regarding unfair or deceptive acts or practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by the Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission shall enforce this chapter in the same manner, by the same means, and with the same jurisdiction, powers, and duties as though all applicable terms and provisions of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.) were incorporated into and made a part of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":