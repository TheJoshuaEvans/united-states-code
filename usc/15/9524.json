{"tag":"section","attrib":{"id":"id7ab04f51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524"},"text":null,"children":[{"tag":"num","attrib":{"value":"9524"},"text":"§ 9524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab04f52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An MBDA Business Center (referred to in this part as a “Center”), with respect to the Federal financial assistance award made to operate the Center under the MBDA Business Center Program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to minority business enterprises programs and services determined to be appropriate by the Under Secretary, which may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral services to meet the needs of minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs and services to accomplish the goals described in section ___101(1); ","children":[{"tag":"ref","attrib":{"idref":"fn002665"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002665"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, cultivate, and maintain a network of strategic partnerships with organizations that foster access by minority business enterprises to economic markets, capital, or contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to upgrade and modify the services provided by the Center, as necessary, in order to meet the changing and evolving needs of the business community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or continue a referral relationship with not less than 1 community-based organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with other Centers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in providing programs and services under the applicable MBDA Business Center agreement, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate on a fee-for-service basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" generate income through the collection of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" client fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" membership fees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate fees proposed by the Center in the application submitted by the Center under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (g)(3), the term of an MBDA Business Center agreement shall be not less than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of financial assistance provided by the Under Secretary under an MBDA Business Center agreement shall be not less than $250,000 for the term of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Center shall match not less than ⅓ of the amount of the financial assistance awarded to the Center under the terms of the applicable MBDA Business Center agreement, unless the Under Secretary determines that a waiver of that requirement is necessary after a demonstration by the Center of a substantial need for that waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Center may meet the matching requirement under subparagraph (A) by using—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash or in-kind contributions, without regard to whether the contribution is made by a third party; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal funds received from other Federal programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of financial assistance and program income","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Center shall use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all financial assistance awarded to the Center under the applicable MBDA Business Center agreement to carry out subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all income that the Center generates in carrying out subsection (a)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the matching requirement under paragraph (2) of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Center meets the matching requirement under paragraph (2) of this subsection, to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish criteria that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary shall use in determining whether to enter into an MBDA Business Center agreement with an eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include criteria relating to whether an eligible entity is located in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area, the population of which is composed of not less than 51 percent socially or economically disadvantaged individuals, as determined in accordance with data collected by the Bureau of the Census;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally recognized area of economic distress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State that is underserved with respect to the MBDA Business Center Program, as defined by the Under Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make the criteria and standards established under paragraph (1) publicly available, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the website of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each Notice of Funding Opportunity soliciting MBDA Business Center agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity desiring to enter into an MBDA Business Center agreement shall submit to the Under Secretary an application that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the eligible entity will carry out subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any experience or plans of the eligible entity with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assisting minority business enterprises to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7ab04f7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtain—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7ab04f7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" large-scale contracts, grants, or procurements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7ab04f7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7ab04f80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal assistance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7ab04f81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access established supply chains; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7ab04f82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engage in—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7ab04f83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint ventures, teaming arrangements, and mergers and acquisitions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7ab04f84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/i/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" large-scale transactions in global markets;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting minority business enterprises in increasing the size of the workforces of those enterprises, including, with respect to a minority business enterprise that does not have employees, aiding the minority business enterprise in becoming an enterprise that has employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocating for minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget and corresponding budget narrative that the eligible entity will use in carrying out subsection (a) during the term of the applicable MBDA Business Center agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Under Secretary grants an application of an eligible entity submitted under subsection (e), the Under Secretary shall notify the eligible entity that the application has been granted not later than 150 days after the last day on which an application may be submitted under that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program examination; accreditation; extensions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", and biennially thereafter, the Under Secretary shall conduct a programmatic financial examination of each Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary may provide financial support, by contract or otherwise, to an association, not less than 51 percent of the members of which are Centers, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue matters of common concern with respect to Centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an accreditation program with respect to Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary may extend the term under subsection (b) of an MBDA Business Center agreement to which a Center is a party, if the Center consents to the extension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Under Secretary extends the term of an MBDA Business Center agreement under paragraph (1), the Under Secretary shall, in the same manner and amount in which financial assistance was provided during the initial term of the agreement, provide financial assistance under the agreement during the extended term of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MBDA involvement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary may take actions to ensure that the Agency is substantially involved in the activities of Centers in carrying out subsection (a), including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing to each Center training relating to the MBDA Business Center Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requiring that the operator and staff of each Center—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" attend—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conference with the Agency to establish the services and programs that the Center will provide in carrying out the requirements before the date on which the Center begins providing those services and programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training provided under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive necessary guidance relating to carrying out the requirements under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in coordination and collaboration with the Under Secretary to carry out the MBDA Business Center Program and other programs of the Agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitating connections between Centers and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies other than the Agency, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other institutions or entities that use Federal resources, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business development centers, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/t"},"text":"section 632(t) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" women’s business centers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s656"},"text":"section 656 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible entities, as that term is defined in section 2411 ","children":[{"tag":"ref","attrib":{"idref":"fn002666"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002666"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 10, that provide services under the program carried out under chapter 142 "},{"tag":"ref","attrib":{"idref":"fn002666"},"text":"2","children":[],"tail":" of that title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities participating in the Hollings Manufacturing Extension Partnership Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring projects carried out by each Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and enforcing administrative and reporting requirements for each Center to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04fa2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9524/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall issue and publish regulations that establish minimum standards regarding verification of minority business enterprise status for clients of entities operating under the MBDA Business Center Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04fa3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tI/s100114"},"text":"Pub. L. 117–58, div. K, title I, § 100114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1452"},"text":"135 Stat. 1452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab04fa4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab04fa5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab04fa6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section ___101(1), referred to in subsec. (a)(1)(A)(ii), probably means par. (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s100101"},"text":"section 100101 of Pub. L. 117–58","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9511"},"text":"sect