{"tag":"section","attrib":{"id":"id797efac2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1505"},"text":null,"children":[{"tag":"num","attrib":{"value":"1505"},"text":"§ 1505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Assistant Secretary; duties, rank of Assistant Secretaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Commerce one additional Assistant Secretary of Commerce, who shall be appointed by the President, by and with the advice and consent of the Senate. The Secretary of Commerce may assign to his Assistant Secretaries such duties, including the direction of the Bureau of Foreign and Domestic Commerce, as he shall prescribe, or may be required by law. The Assistant Secretaries of Commerce shall be without numerical distinction of rank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797efac3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-15/ch251"},"text":"July 15, 1947, ch. 251","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/326"},"text":"61 Stat. 326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797efac4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797efac5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id797efac6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of last sentence that fixed the compensation of the Assistant Secretaries