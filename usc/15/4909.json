{"tag":"section","attrib":{"id":"id7a49c4d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4909"},"text":null,"children":[{"tag":"num","attrib":{"value":"4909"},"text":"§ 4909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Data Bank shall not include any information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c4da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4909/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure of which to the public is prohibited under any other provision of law or otherwise authorized to be withheld under other provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4909/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is specifically authorized under criteria established by statute or an Executive order not to be disclosed in the interest of national defense or foreign policy and are in fact properly classified pursuant to such Executive order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c4dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5409"},"text":"Pub. L. 100–418, title V, § 5409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1467"},"text":"102 Stat. 1467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
