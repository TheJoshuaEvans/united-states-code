{"tag":"section","attrib":{"id":"id799bab54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650"},"text":null,"children":[{"tag":"num","attrib":{"value":"1650"},"text":"§ 1650.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing unfair and deceptive private educational lending practices and eliminating conflicts of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799bab55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799bab56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “cosigner”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any individual who is liable for the obligation of another without compensation, regardless of how designated in the contract or instrument with respect to that obligation, other than an obligation under a private education loan extended to consolidate a consumer’s pre-existing private education loans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any person the signature of which is requested as condition to grant credit or to forbear on collection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a spouse of an individual described in subparagraph (A), the signature of whom is needed to perfect the security interest in a loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered educational institution”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any educational institution that offers a postsecondary educational degree, certificate, or program of study (including any institution of higher education); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an agent, officer, or employee of the educational institution;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “gift”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id799bab5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any gratuity, favor, discount, entertainment, hospitality, loan, or other item having more than a de minimis monetary value, including services, transportation, lodging, or meals, whether provided in kind, by purchase of a ticket, payment in advance, or reimbursement after the expense has been incurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799bab60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes an item described in clause (i) provided to a family member of an officer, employee, or agent of a covered educational institution, or to any other individual based on that individual’s relationship with the officer, employee, or agent, if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id799bab61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the item is provided with the knowledge and acquiescence of the officer, employee, or agent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id799bab62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer, employee, or agent has reason to believe the item was provided because of the official position of the officer, employee, or agent; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id799bab64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standard informational material related to a loan, default aversion, default prevention, or financial literacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799bab65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food, refreshments, training, or informational material furnished to an officer, employee, or agent of a covered educational institution, as an integral part of a training session or through participation in an advisory council that is designed to improve the service of the private educational lender to the covered educational institution, if such training or participation contributes to the professional development of the officer, employee, or agent of the covered educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799bab66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" favorable terms, conditions, and borrower benefits on a private education loan provided to a student employed by the covered educational institution, if such terms, conditions, or benefits are not provided because of the student’s employment with the covered educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799bab67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the provision of financial literacy counseling or services, including counseling or services provided in coordination with a covered educational institution, to the extent that such counseling or services are not undertaken to secure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id799bab68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for private education loans or private education loan volume;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id799bab69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications or loan volume for any loan made, insured, or guaranteed under title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id799bab6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of a product or service of a specific private educational lender;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799bab6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" philanthropic contributions to a covered educational institution from a private educational lender that are unrelated to private education loans and are not made in exchange for any advantage related to private education loans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799bab6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State education grants, scholarships, or financial aid funds administered by or on behalf of a State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “institution of higher education” has the same meaning as in section 102 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"20 U.S.C. 1002","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “postsecondary educational expenses” means any of the expenses that are included as part of the cost of attendance of a student, as defined under section 472 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “preferred lender arrangement” has the same meaning as in section 151 of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1019"},"text":"20 U.S.C. 1019","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “private educational lender” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial institution, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":" that solicits, makes, or extends private education loans;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal credit union, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of title 12","children":[],"tail":" that solicits, makes, or extends private education loans; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person engaged in the business of soliciting, making, or extending private education loans;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “private education loan”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a loan provided by a private educational lender that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id799bab76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not made, insured, or guaranteed under of ","children":[{"tag":"ref","attrib":{"idref":"fn002359"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002359"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “of” probably should not appear."}],"tail":" title IV of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799bab77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is issued expressly for postsecondary educational expenses to a borrower, regardless of whether the loan is provided through the educational institution that the subject student attends or directly to the borrower from the private educational lender; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an extension of credit under an open end consumer credit plan, a reverse mortgage transaction, a residential mortgage transaction, or any other loan that is secured by real property or a dwelling; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “revenue sharing” means an arrangement between a covered educational institution and a private educational lender under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private educational lender provides or issues private education loans with respect to students attending the covered educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered educational institution recommends to students or others the private educational lender or the private education loans of the private educational lender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private educational lender pays a fee or provides other material benefits, including profit sharing, to the covered educational institution in connection with the private education loans provided to students attending the covered educational institution or a borrower acting on behalf of a student.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain gifts and arrangements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A private educational lender may not, directly or indirectly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799bab7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer or provide any gift to a covered educational institution in exchange for any advantage or consideration provided to such private educational lender related to its private education loan activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in revenue sharing with a covered educational institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on co-branding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A private educational lender may not use the name, emblem, mascot, or logo of the covered educational institution, or other words, pictures, or symbols readily identified with the covered educational institution, in the marketing of private education loans in any way that implies that the covered educational institution endorses the private education loans offered by the private educational lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is employed in the financial aid office of a covered educational institution, or who otherwise has responsibilities with respect to private education loans or other financial aid of the institution, and who serves on an advisory board, commission, or group established by a private educational lender or group of such lenders shall be prohibited from receiving anything of value from the private educational lender or group of lenders. Nothing in this subsection prohibits the reimbursement of reasonable expenses incurred by an employee of a covered educational institution as part of their service on an advisory board, commission, or group described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on prepayment or repayment fees or penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any private educational lender to impose a fee or penalty on a borrower for early repayment or prepayment of any private education loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit card protections for college students","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799bab84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education shall publicly disclose any contract or other agreement made with a card issuer or creditor for the purpose of marketing a credit card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inducements prohibited","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No card issuer or creditor may offer to a student at an institution of higher education any tangible item to induce such student to apply for or participate in an open end consumer credit plan offered by such card issuer or creditor, if such offer is made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the campus of an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" near the campus of an institution of higher education, as determined by rule of the Bureau; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at an event sponsored by or related to an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of the Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress that each institution of higher education should consider adopting the following policies relating to credit cards:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That any card issuer that markets a credit card on the campus of such institution notify the institution of the location at which such marketing will take place.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the number of locations on the campus of such institution at which the marketing of credit cards takes place be limited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That credit card and debt education and counseling sessions be offered as a regular part of any orientation program for new students of such institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional protections relating to borrower or cosigner of a private education loan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799bab8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on automatic default in case of death or bankruptcy of non-student obligor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a private education loan involving a student obligor and 1 or more cosigners, the creditor shall not declare a default or accelerate the debt against the student obligor on the sole basis of a bankruptcy or death of a cosigner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cosigner release in case of death of borrower","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of cosigner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The holder of a private education loan, when notified of the death of a student obligor, shall release within a reasonable timeframe any cosigner from the obligations of the cosigner under the private education loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of release","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A holder or servicer of a private education loan, as applicable, shall within a reasonable time-frame notify any cosigners for the private education loan if a cosigner is released from the obligations of the cosigner for the private education loan under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1650/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of individual to act on behalf of the borrower","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any lender that extends a private education loan shall provide the student obligor an option to designate an individual to have the legal authority to act on behalf of the student obligor with respect to the private education loan in the event of the death of the student obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799bab93-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s140"},"text":"Pub. L. 90–321, title I, § 140","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tX/s1011/a"},"text":"Pub. L. 110–315, title X, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3479"},"text":"122 Stat. 3479","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tIII/s304"},"text":"Pub. L. 111–24, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1749"},"text":"123 Stat. 1749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tVI/s601/a"},"text":"Pub. L. 115–174, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1365"},"text":"132 Stat. 1365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799bab94-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799bab95-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id799bab96-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (a)(3)(B)(iv)(II), (8)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 1070 et seq.) of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799bab97-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s601/a/1"},"text":"Pub. L. 115–174, § 601(a)(1)","children":[],"tail":", added par. (1) and redesignated former pars. (1) to (8) as (2) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s601/a/2"},"text":"Pub. L. 115–174, § 601(a)(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24"},"text":"Pub. L. 111–24","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df488-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799df489-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/tVI/s601/b"},"text":"Pub. L. 115–174, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":