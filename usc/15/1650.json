of Pub. L. 111–24","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799df48c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective on the earlier of the date on which regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/315/s1002"},"text":"section 1002 of Pub. L. 110–315","children":[],"tail":" (set out as a Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1638"},"text":"section 1638 of this title","children":[],"tail":") become effective or 18 months after "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/s1003/b"},"text":"section 1003(b) of Pub. L. 110–315","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1638"},"text":"section 1638 of this title","children":[],"tail":". Such regulations were issued effective "},{"tag":"date","attrib":{"date":"2009-09-14"},"text":"Sept. 14, 2009","children":[],"tail":", with compliance optional until "},{"tag":"date","attrib":{"date":"2010-02-14"},"text":"Feb. 14, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
