{"tag":"section","attrib":{"id":"id7ab29978-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592"},"text":null,"children":[{"tag":"num","attrib":{"value":"9592"},"text":"§ 9592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab29979-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab2997a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of Federal assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out sections ___101, ___102, and ___103(a),","children":[{"tag":"ref","attrib":{"idref":"fn002668"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002668"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See References in Text note below."}],"tail":" the Under Secretary may provide Federal assistance to public sector entities and private sector entities in the form of grants or cooperative agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2997b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the date on which amounts are appropriated to carry out this section, the Under Secretary shall, in accordance with subsection (b), broadly publish a statement regarding Federal assistance that will, or may, be provided under paragraph (1) during the fiscal year for which those amounts are appropriated, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab2997c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual, or anticipated, amount of Federal assistance that will, or may, be made available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab2997d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of Federal assistance that will, or may, be made available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab2997e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which Federal assistance will be allocated among public sector entities and private sector entities, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab2997f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology used by the Under Secretary to make allocations under subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29980-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall consult with public sector entities and private sector entities, as applicable, in deciding the amounts and types of Federal assistance to make available under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29981-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9592/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Under Secretary shall broadly publicize all opportunities for Federal assistance available under this section, including through the means required under section ___116. ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab29982-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tVII/s100702"},"text":"Pub. L. 117–58, div. K, title VII, § 100702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1465"},"text":"135 Stat. 1465","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab29983-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab29984-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab29985-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections ___101, ___102, and ___103(a), referred to in subsec. (a)(1), probably mean sections 100101, 100102, and 100103(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which are classified to sections 9511, 9512, and 9513(a) of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section ___116, referred to in subsec. (b), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s100116"},"text":"section 100116 of Pub. L. 117–58","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9526"},"text":"section 9526 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
