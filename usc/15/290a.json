{"tag":"section","attrib":{"id":"id789c89c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a"},"text":null,"children":[{"tag":"num","attrib":{"value":"290a"},"text":"§ 290a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789c89c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard reference data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “standard reference data” means data that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789c89ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id789c89cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantitative information related to a measurable physical, or chemical, or biological property of a substance or system of substances of known composition and structure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id789c89cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurable characteristics of a physical artifact or artifacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id789c89cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering properties or performance characteristics of a system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id789c89ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 or more digital data objects that serve—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id789c89cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to calibrate or characterize the performance of a detection or measurement system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id789c89d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interpolate or extrapolate, or both, data described in subparagraph (A) through (C); ","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789c89d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is critically evaluated as to its reliability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s290b"},"text":"section 290b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789c89d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789c89d3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/396/s2"},"text":"Pub. L. 90–396, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-11"},"text":"July 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/340"},"text":"82 Stat. 340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s108"},"text":"Pub. L. 114–329, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2987"},"text":"130 Stat. 2987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789c89d4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789c89d5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id789c89d6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “For the purposes of this chapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The term ‘standard reference data’ means quantitative information, related to a measurable physical or chemical property of a substance or system of substances of known composition and structure, which is critically evaluated as to its reliability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s290b"},"text":"section 290b of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The term ‘Secretary’ means the Secretary of Commerce.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
