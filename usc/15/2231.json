{"tag":"section","attrib":{"id":"id79ea4051-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2231"},"text":null,"children":[{"tag":"num","attrib":{"value":"2231"},"text":"§ 2231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements with Federal facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall make publicly available, including through the Internet, information on procedures for establishing cooperative agreements between State and local fire and emergency services and Federal facilities in their region relating to the provision of fire and emergency services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ea4052-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498/s36"},"text":"Pub. L. 93–498, § 36","children":[],"tail":", formerly § 34, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/503/tI/s106"},"text":"Pub. L. 106–503, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2301"},"text":"114 Stat. 2301","children":[],"tail":"; renumbered § 36, "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1057"},"text":"Pub. L. 108–136, div. A, title X, § 1057","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1616"},"text":"117 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
