{"tag":"section","attrib":{"id":"id7a723555-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7308"},"text":null,"children":[{"tag":"num","attrib":{"value":"7308"},"text":"§ 7308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Institute of Standards and Technology actions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"After the issuance of a public report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7307"},"text":"section 7307 of this title","children":[],"tail":", the National Institute of Standards and Technology shall comprehensively review the report and, working with the United States Fire Administration and other appropriate Federal and non-Federal agencies and organizations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a723556-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7308/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct, or enable or encourage the conducting of, appropriate research recommended by the Team; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a723557-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7308/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote (consistent with existing procedures for the establishment of building standards, codes, and practices) the appropriate adoption by the Federal Government, and encourage the appropriate adoption by other agencies and organizations, of the recommendations of the Team with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a723558-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7308/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical aspects of evacuation and emergency response procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a723559-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7308/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific improvements to building standards, codes, and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a72355a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7308/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other actions needed to help prevent future building failures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a72355b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231/s9"},"text":"Pub. L. 107–231, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1475"},"text":"116 Stat. 1475","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
