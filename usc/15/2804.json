{"tag":"section","attrib":{"id":"id7a0bab86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804"},"text":null,"children":[{"tag":"num","attrib":{"value":"2804"},"text":"§ 2804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of termination or nonrenewal of franchise relationship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0bab87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements applicable to franchisor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to termination of any franchise or nonrenewal of any franchise relationship, the franchisor shall furnish notification of such termination or such nonrenewal to the franchisee who is a party to such franchise or such franchise relationship—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0bab88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the manner described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0bab89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (b), not less than 90 days prior to the date on which such termination or nonrenewal takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0bab8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements applicable to franchisor","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0bab8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In circumstances in which it would not be reasonable for the franchisor to furnish notification, not less than 90 days prior to the date on which termination or nonrenewal takes effect, as required by subsection (a)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0bab8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such franchisor shall furnish notification to the franchisee affected thereby on the earliest date on which furnishing of such notification is reasonably practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1b8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of leased marketing premises, such franchisor—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0e1b8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not establish a new franchise relationship with respect to such premises before the expiration of the 30-day period which begins—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a0e1b8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date notification was posted or personally delivered, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a0e1b90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if later, on the date on which such termination or nonrenewal takes effect; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0e1b91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, if permitted to do so by the franchise agreement, repossess such premises and, in circumstances under which it would be reasonable to do so, operate such premises through employees or agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0e1b92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of any termination of any franchise or any nonrenewal of any franchise relationship pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2802/b/2/E"},"text":"section 2802(b)(2)(E) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2803/c/2"},"text":"section 2803(c)(2) of this title","children":[],"tail":", the franchisor shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0e1b93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish notification to the franchisee not less than 180 days prior to the date on which such termination or nonrenewal takes effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1b94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly provide a copy of such notification, together with a plan describing the schedule and conditions under which the franchisor will withdraw from the marketing of motor fuel through retail outlets in the relevant geographic area, to the Governor of each State which contains a portion of such area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0e1b95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner and form of notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notification under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0e1b96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0e1b97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be posted by certified mail or personally delivered to the franchisee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0e1b98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0e1b99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of intention to terminate the franchise or not to renew the franchise relationship, together with the reasons therefor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1b9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which such termination or nonrenewal takes effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1b9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the summary statement prepared under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0e1b9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation, publication, etc., of statutory summaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0e1b9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":", the Secretary of Energy shall prepare and publish in the Federal Register a simple and concise summary of the provisions of this subchapter, including a statement of the respective responsibilities of, and the remedies and relief available to, any franchisor and franchisee under this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0e1b9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2804/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of summaries required to be furnished under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2802/b/2/D"},"text":"section 2802(b)(2)(D) of this title","children":[],"tail":" or subsection (c)(3)(C) of this section before the date of publication of such summary in the Federal Register, such summary may be furnished not later than 5 days after it is so published rather than at the time required under such provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0e1b9f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/297/tI/s104"},"text":"Pub. L. 95–297, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-06-19"},"text":"June 19, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/329"},"text":"92 Stat. 329","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
