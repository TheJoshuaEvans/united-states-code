{"tag":"section","attrib":{"id":"id7a108d75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3001"},"text":null,"children":[{"tag":"num","attrib":{"value":"3001"},"text":"§ 3001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a108d76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States should have the primary responsibility for determining what forms of gambling may legally take place within their borders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government should prevent interference by one State with the gambling policies of another, and should act to protect identifiable national interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3001/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the limited area of interstate off-track wagering on horseraces, there is a need for Federal action to ensure States will continue to cooperate with one another in the acceptance of legal interstate wagers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108d7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the policy of the Congress in this chapter to regulate interstate commerce with respect to wagering on horseracing, in order to further the horseracing and legal off-track betting industries in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108d7b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/515/s2"},"text":"Pub. L. 95–515, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1811"},"text":"92 Stat. 1811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a108d7c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a108d7d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a108d7e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/515/s9"},"text":"Pub. L. 95–515, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1815"},"text":"92 Stat. 1815","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/515/s9"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this Act [this chapter] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":"], and, except as provided in subsection (b) of this section, shall apply to any interstate off-track wager accepted on or after such date of enactment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this Act [this chapter] shall not apply to any interstate off-track wager which is accepted pursuant to a contract existing on ","children":[{"tag":"date","attrib":{"date":"1978-05-01"},"text":"May 1, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this Act shall not apply to any form of legal non-parimutuel off-track betting existing in a State on ","children":[{"tag":"date","attrib":{"date":"1978-05-01"},"text":"May 1, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subsection (b) of section 5 of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3004/b"},"text":"section 3004(b) of this title","children":[],"tail":"] shall not apply to any parimutuel off-track betting system existing on "},{"tag":"date","attrib":{"date":"1978-05-01"},"text":"May 1, 1978","children":[],"tail":", in a State which does not conduct parimutuel horseracing on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a108d7f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/515/s1"},"text":"Pub. L. 95–515, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1811"},"text":"92 Stat. 1811","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/515/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Interstate Horseracing Act of 1978’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
