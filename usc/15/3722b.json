{"tag":"section","attrib":{"id":"id7a2d1567-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3722b"},"text":"§ 3722b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distressed area Recompete Pilot Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2d1568-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the program authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a"},"text":"section 3722a of this title","children":[],"tail":", the Secretary is authorized to establish a pilot program, to be known as the “Recompete Pilot Program”, to provide grants to eligible recipients representing eligible areas or Tribal lands to alleviate persistent economic distress and support long-term comprehensive economic development and job creation in eligible areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d1569-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy development grants and cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to available appropriations, the Secretary is authorized, on the application of an eligible recipient, to award up to one half of the number of grants under subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a"},"text":"section 3722a of this title","children":[],"tail":" to eligible recipients to develop a recompete plan and carry out related predevelopment activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d156a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy implementation grants and cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to available appropriations and subsection (f), the Secretary shall award, on the application of an eligible recipient, at least ten strategy implementation grants, in accordance with a recompete plan review and approved by the Secretary, to carry out coordinated and comprehensive economic development programs and activities in an eligible area, consistent with a recompete plan approved by the Secretary. Such activities may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2d156b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" workforce development activities of the kind described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a/f"},"text":"section 3722a(f) of this title","children":[],"tail":" or other job training and workforce outreach programs oriented to local employer needs, such as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d156c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" customized job training programs carried out by local community colleges and other training or educational organizations in partnership with local businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d156d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce outreach programs located in, and targeted to, lower-income and underemployed neighborhoods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d156e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to embed job placement and training services in neighborhood institutions such as churches, housing projects, and community advocacy programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d156f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job retention programs and activities, such as the provision of career coaches;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d1570-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" business and entrepreneur development activities of the kind described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a/f"},"text":"section 3722a(f) of this title","children":[],"tail":", technology development and maturation activities of the kind described in such section, or the provision of business advice and assistance to small and medium-sized local businesses and entrepreneurs. Such advice and assistance may include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d1571-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing extension services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d1572-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business development centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d1573-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" centers to help businesses bid for Federal procurement contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d1574-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entrepreneurial assistance programs that link entrepreneurs with available public and private resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d1575-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal advice and resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d1576-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in accessing capital;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d1577-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure related activities of the kind described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a/f"},"text":"section 3722a(f) of this title","children":[],"tail":" or other land and site development programs, such as brownfield redevelopment, research and technology parks, business incubators, business corridor development, and other infrastructure activities related to supporting job creation and employment for residents, subject to the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3722a/f/6"},"text":"section 3722a(f)(6) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d1578-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional planning, predevelopment, technical assistance, and other administrative activities as may be necessary for the ongoing implementation, administration, and operation of the programs and activities carried out with a grant or cooperative agreement under this section, including but not limited to economic development planning and evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d1579-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2d157a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial performance period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of an initial grant or cooperative agreement awarded under subsection (c) shall be for a period that the Secretary deems appropriate for the proposed activities but not less than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d157b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent performance period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may renew a grant or cooperative agreement awarded under subsection (c) for such period, such amount, and such terms as the Secretary considers appropriate, if the Secretary determines that the recipient of an award under subsection (c) has made satisfactory progress towards metrics or benchmarking requirements established by the Secretary at time of award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d157c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In renewing a grant or cooperative agreement under subsection (c), the Secretary may approve new or additional uses of funds, consistent with the uses described in subsection (c), to meet changes in the needs of the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d157d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2d157e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on eligible areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible area may not benefit from more than 1 grant or cooperative agreement described in subsection (b) and 1 grant or cooperative agreement described in subsection (c), provided that a renewal described in subsection (d)(2) shall not constitute an additional grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d157f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the program under this section, an eligible recipient may not receive multiple grants described in subsection (c) on behalf of more than 1 eligible area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d1580-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2d1581-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a grant that an eligible recipient may be awarded under subsection (c), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d1582-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the proposed activities and projected expenditures outlined in an approved recompete plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d1583-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" award not more than the product obtained by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2d1584-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prime-age employment gap of the eligible area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d1585-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prime-age population of the eligible area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d1586-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a2d1587-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,585 for local labor markets; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2d1588-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $53,600 for local communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d1589-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make an award that is less than $20,000,000 to an eligible recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d158a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be considered for a grant or cooperative agreement under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2d158b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b) of this section, an eligible recipient shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d158c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) of this section, an eligible recipient shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary determines to be appropriate, including a recompete plan approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d158d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to certain grant awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not require an eligible recipient to receive a grant or cooperative agreement under subsection (b) in order to receive a grant or cooperative agreement under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d158e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary $1,000,000,000 to award grants and cooperative agreements under subsection (c) of this section, for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2d158f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2d1590-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible area” means either of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d1591-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A local labor market that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2d1592-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a prime-age employment gap equal to not less than 2.5 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d1593-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets additional criteria as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d1594-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A local community that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2d1595-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a prime-age employment gap equal to not less than 5 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d1596-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not located within an eligible local labor market that meets the criteria described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d1597-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a median annual household income of not more than $75,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d1598-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets additional criteria as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d1599-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible recipient” means a specified entity that has been authorized in a manner as determined by the Secretary to represent and act on behalf of an eligible area for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d159a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local labor market","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local labor market” means any of the following areas that contains 1 or more specified entities described in subparagraphs (A) through (D) of paragraph (6) ","children":[{"tag":"ref","attrib":{"idref":"fn002507"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002507"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be paragraph “(7)”."}],"tail":":"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d159b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A metropolitan statistical area or micropolitan statistical area, excluding any area described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d159c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commuting zone, excluding any areas described in subparagraphs (A) and (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d159d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Tribal land with a Tribal prime-age population represented by a Tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d159e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local community” means the area served by a general-purpose unit of local government that is located within, but does not cover the entire area of, a local labor market that does not meet the criteria described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d159f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prime-age employment gap","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d15a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “prime-age employment gap” means the difference (expressed as a percentage) between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2d15a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national 5-year average prime-age employment rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d15a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 5-year average prime-age employment rate of the eligible area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of subparagraph (A), an individual is prime-age if such individual between the ages of 25 years and 54 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d15a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recompete plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “recompete plan” means a comprehensive multiyear economic development plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d15a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2d15a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed programs and activities to be carried out with a grant awarded under subsection (c) to address the economic challenges of the eligible area in a comprehensive manner that promotes long-term, sustained economic growth, lasting job creation, per capita wage increases, and reduction in the prime-age employment gap of the eligible area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d15a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected costs and annual expenditures and proposed disbursement schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d15a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the roles and responsibilities of specified entities that may receive grant funds awarded under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d15a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information as the Secretary determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is submitted to the Secretary for approval for an eligible recipient to be considered for a grant described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be modified over the term of the grant by the eligible recipient, subject to the approval of the Secretary or at the direction of the Secretary, if the Secretary determines benchmarking requirements are repeatedly not met or if other circumstances necessitate a modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d15ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specified entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d15ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" political subdivision of a State or other entity, including a special-purpose entity engaged in economic development activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public entity or nonprofit organization, acting in cooperation with the officials of a political subdivision of a State or other entity described in subparagraph (E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic development district (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3122"},"text":"section 3122 of title 42","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of any of the specified entities described in this paragraph which serve or are contained within the same eligible area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d15b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal land","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Tribal land” means any land—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d15b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located within the boundaries of an Indian reservation, pueblo, or rancheria; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not located within the boundaries of an Indian reservation, pueblo, or rancheria, the title to which is held—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2d15b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in trust by the United States for the benefit of an Indian Tribe or an individual Indian;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d15b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an Indian Tribe or an individual Indian, subject to restriction against alienation under laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d15ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a dependent Indian community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2d15bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal prime-age population","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2d15bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Tribal prime-age population” shall be equal to the sum obtained by adding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a2d15bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product obtained by multiplying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a2d15be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals ages 25 through 54 residing on the Tribal land of the Tribal government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2d15bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.65; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a2d15c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product obtained by multiplying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a2d15c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals ages 25 through 54 included on the membership roll of the Tribal government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a2d15c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.35 ","children":[{"tag":"ref","attrib":{"idref":"fn002508"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002508"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2d15c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3722b/j/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A calculation under subparagraph (A) shall be determined based on data provided by the applicable Tribal government to the Department of the Treasury under the Coronavirus State and Local Fiscal Recovery Fund programs under title VI of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s801"},"text":"42 U.S.C. 801","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2f85c4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s29"},"text":"Pub. L. 96–480, § 29","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10621/a/2"},"text":"Pub. L. 117–167, div. B, title VI, § 10621(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1655"},"text":"136 Stat. 1655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2f85c5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a2f85c6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a2f85c7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (j)(9)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title VI of the Act is classified generally to subchapter VI (§ 801 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a2f85c8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a2f85c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Distressed Area Designation and Award","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10621/c"},"text":"Pub. L. 117–167, div. B, title VI, § 10621(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1660"},"text":"136 Stat. 1660","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/167/dB/tVI/s10621/c"},"text":"“Not later than 18 months after the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":"], subject to the availability of appropriations, if the Secretary [of Commerce] has received applications under section 29 of the Stevenson-Wydler Technology Innovation Act of 1980 ["},{"tag"