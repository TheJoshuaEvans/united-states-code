{"tag":"section","attrib":{"id":"id7a047f56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2656"},"text":null,"children":[{"tag":"num","attrib":{"value":"2656"},"text":"§ 2656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a047f57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2656/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is authorized to award grants under this section to nonprofit organizations that demonstrate experience in implementing and operating health and safety asbestos training and education programs for workers who are or will be engaged in asbestos-related activities (including State and local governments, colleges and universities, joint labor-management trust funds, and nonprofit government employee organizations) to establish and, or, operate asbestos training programs on a not-for-profit basis. Applications for grants under this subsection shall be submitted in such form and manner, and contain such information, as the Administrator prescribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047f58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2656/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of such sums as are authorized to be appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4021/a"},"text":"section 4021(a) of title 20","children":[],"tail":" for the fiscal years 1991, 1992, 1993, 1994, and 1995, not more than $5,000,000 are authorized to be appropriated to carry out this section in each such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a047f59-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tII/s216"},"text":"Pub. L. 94–469, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/637/s16/a/1"},"text":"Pub. L. 101–637, § 16(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4597"},"text":"104 Stat. 4597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a047f5a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a047f5b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a047f5c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/637/s16/b"},"text":"Pub. L. 101–637, § 16(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4598"},"text":"104 Stat. 4598","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/637/s16/b"},"text":"“Section 216 of the Toxic Substances Control Act [this section], as added by subsection (a), shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
