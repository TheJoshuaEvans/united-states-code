{"tag":"section","attrib":{"id":"id792457a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s685"},"text":null,"children":[{"tag":"num","attrib":{"value":"685"},"text":"§ 685.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term loans to small-business concerns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792457a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s685/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each company is authorized to make loans, in the manner and subject to the conditions described in this section, to incorporated and unincorporated small-business concerns in order to provide such concerns with funds needed for sound financing, growth, modernization, and expansion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792457a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s685/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct loans; loans on participation basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans made under this section may be made directly or in cooperation with other lenders, incorporated or unincorporated, through agreements to participate on an immediate or deferred basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792457a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s685/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum rate of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum rate of interest for the company’s share of any loan made under this section shall be determined by the Administration: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Administration also shall permit those companies which have issued debentures pursuant to this chapter to charge a maximum rate of interest based upon the coupon rate of interest on the outstanding debentures, determined on an annual basis, plus such other expenses of the company as may be approved by the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792457aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s685/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maturity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any loan made under this section shall have a maturity not exceeding twenty years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792457ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s685/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soundness of loan; security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any loan made under this section shall be of such sound value, or so secured, as reasonably to assure repayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792457ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s685/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension or renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any company which has made a loan to a small-business concern under this section is authorized to extend the maturity of or renew such loan for additional periods, not exceeding ten years, if the company finds that such extension or renewal will aid in the orderly liquidation of such loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792457ad-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s305"},"text":"Pub. L. 85–699, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-21"},"text":"Aug. 21, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/693"},"text":"72 Stat. 693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/341/s6"},"text":"Pub. L. 87–341, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-03"},"text":"Oct. 3, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/753"},"text":"75 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/305/tI/s105"},"text":"Pub. L. 94–305, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/666"},"text":"90 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/366/tIV/s411"},"text":"Pub. L. 102–366, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-04"},"text":"Sept. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1018"},"text":"106 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792457ae-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792457af-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id792457b0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (c), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792457b1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/366"},"text":"Pub. L. 102–366","children":[],"tail":" inserted before period at end “: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Administration also shall permit those companies which have issued debentures pursuant to this chapter to charge a maximum rate of interest based upon the coupon rate of interest on the outstanding debentures, determined on an annual basis, plus such other expenses of the company as may be approved by the Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305"},"text":"Pub. L. 94–305","children":[],"tail":" struck out provision that in agreements to participate in loans on a deferred basis, the participation by the company shall not be in excess of 90 percentum of the balance of the loan outstanding at the time of disbursement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/341"},"text":"Pub. L. 87–341","children":[],"tail":" substituted “other lenders, incorporated or unincorporated” for “other lending institutions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792457b2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id792457b3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of Small Business Equity Enhancement Act of 1992 on Securities Laws","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/366"},"text":"Pub. L. 102–366","children":[],"tail":" to be construed to affect applicability of securities laws or to otherwise supersede or limit jurisdiction of Securities and Exchange Commission, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/366/s418"},"text":"section 418 of Pub. L. 102–366","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
