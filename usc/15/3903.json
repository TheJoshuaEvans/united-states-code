{"tag":"section","attrib":{"id":"id7a31cff3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903"},"text":null,"children":[{"tag":"num","attrib":{"value":"3903"},"text":"§ 3903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchasing groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a31cff4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions from State laws, rules, regulations, or orders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3905"},"text":"section 3905 of this title","children":[],"tail":", a purchasing group is exempt from any State law, rule, regulation, or order to the extent that such law, rule, regulation, or order would—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31cff5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the establishment of a purchasing group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31cff6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make it unlawful for an insurer to provide or offer to provide insurance on a basis providing, to a purchasing group or its members, advantages, based on their loss and expense experience, not afforded to other persons with respect to rates, policy forms, coverages, or other matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31cff7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit a purchasing group or its members from purchasing insurance on the group basis described in paragraph (2) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31cff8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit a purchasing group from obtaining insurance on a group basis because the group has not been in existence for a minimum period of time or because any member has not belonged to the group for a minimum period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31cff9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a purchasing group must have a minimum number of members, common ownership or affiliation, or a certain legal form;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31cffa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a certain percentage of a purchasing group must obtain insurance on a group basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31cffb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that any insurance policy issued to a purchasing group or any members of the group be countersigned by an insurance agent or broker residing in that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31cffc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise discriminate against a purchasing group or any of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31cffd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of exemptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exemptions specified in subsection (a) apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31cffe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" liability insurance provided to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31cfff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a purchasing group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d000-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who is a member of a purchasing group; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d001-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the provision of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31d002-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liability coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d003-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance related services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d004-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management services;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to a purchasing group or member of the group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d005-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing of agents or brokers for purchasing groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may require that a person acting, or offering to act, as an agent or broker for a purchasing group obtain a license from that State, except that a State may not impose any qualification or requirement which discriminates against a nonresident agent or broker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d006-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to State insurance commissioners of intent to do business","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31d007-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A purchasing group which intends to do business in any State shall furnish notice of such intention to the insurance commissioner of such State. Such notice—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31d008-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall identify the State in which such group is domiciled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d009-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall specify the lines and classifications of liability insurance which the purchasing group intends to purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d00a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall identify the insurance company from which the group intends to purchase insurance and the domicile of such company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d00b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall identify the principal place of business of the group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d00c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such purchasing group shall notify the commissioner of any such State as to any subsequent changes in any of the items provided in such notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d00d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of agent for service of documents and process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A purchasing group shall register with and designate the State insurance commissioner of each State in which it does business as its agent solely for the purpose of receiving service of legal documents or process, except that such requirement shall not apply in the case of a purchasing group—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31d00e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31d00f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was domiciled before ","children":[{"tag":"date","attrib":{"date":"1986-04-01"},"text":"April 1, 1986","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d010-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is domiciled on and after ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002512"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002512"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":null}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in any State of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d011-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31d012-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before ","children":[{"tag":"date","attrib":{"date":"1981-09-25"},"text":"September 25, 1981","children":[],"tail":", purchased insurance from an insurance carrier licensed in any State; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d013-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" since ","children":[{"tag":"date","attrib":{"date":"1981-09-25"},"text":"September 25, 1981","children":[],"tail":", purchases its insurance from an insurance carrier licensed in any State;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d014-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was a purchasing group under the requirements of this chapter before ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d015-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as long as such group does not purchase insurance that was not authorized for purposes of an exemption under this chapter as in effect before ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d016-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases of insurance through licensed agents or brokers acting pursuant to surplus lines laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A purchasing group may not purchase insurance from a risk retention group that is not chartered in a State or from an insurer not admitted in the State in which the purchasing group is located, unless the purchase is effected through a licensed agent or broker acting pursuant to the surplus lines laws and regulations of such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d017-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State powers to enforce State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect the authority of any State to make use of any of its powers to enforce the laws of such State with respect to which a purchasing group is not exempt under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d018-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3903/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States’ authority to sue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall affect the authority of any State to bring an action in any Federal or State court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a31d019-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/45/s4"},"text":"Pub. L. 97–45, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-09-25"},"text":"Sept. 25, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/951"},"text":"95 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/563"},"text":"Pub. L. 99–563","children":[],"tail":", §§ 6, 8(b), 12(d), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3174"},"text":"100 Stat. 3174","children":[],"tail":", 3175, 3178.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a31d01a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a31d01b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a31d01c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":", referred to in subsec. (e)(1)(B), was in the original “the date of the enactment of this Act” which was translated as meaning the date of the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/99/563"},"text":"Pub. L. 99–563","children":[],"tail":", which enacted subsec. (e), to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a31d01d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/563/s8/b/1"},"text":"Pub. L. 99–563, § 8(b)(1)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3905"},"text":"section 3905 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/563/s12/d/1"},"text":"Pub. L. 99–563, § 12(d)(1)","children":[],"tail":", substituted “liability insurance” for “product liability or completed operations liability insurance, and comprehensive general liability insurance which includes either of these coverages,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/563/s12/d/2"},"text":"Pub. L. 99–563, § 12(d)(2)","children":[],"tail":", struck out “product liability or completed operations insurance, and comprehensive general” before “liability coverage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/563"},"text":"Pub. L. 99–563","children":[],"tail":", §§ 6, 8(b)(2), added subsecs. (d) to (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
