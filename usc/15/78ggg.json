{"tag":"section","attrib":{"id":"id7859b49f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78ggg"},"text":null,"children":[{"tag":"num","attrib":{"value":"78ggg"},"text":"§ 78ggg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SEC functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7859b4a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78ggg/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Determinations of the Commission, for purposes of making rules pursuant to section 78ccc(e)(3) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78iii/f"},"text":"section 78iii(f) of this title","children":[],"tail":" shall be after appropriate notice and opportunity for a hearing, and for submission of views of interested persons in accordance with the rulemaking procedures specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", but the holding of a hearing shall not prevent adoption of any such rule or regulation upon expiration of the notice period specified in subsection (d) of such section and shall not be required to be on a record within the meaning of subchapter II of chapter 5 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7859b4a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78ggg/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of the refusal of SIPC to commit its funds or otherwise to act for the protection of customers of any member of SIPC, the Commission may apply to the district court of the United States in which the principal office of SIPC is located for an order requiring SIPC to discharge its obligations under this chapter and for such other relief as the court may deem appropriate to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7859b4a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78ggg/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations and reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7859b4a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78ggg/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of SIPC, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may make such examinations and inspections of SIPC and require SIPC to furnish it with such reports and rec­ords or copies thereof as the Commission may consider necessary or appropriate in the public interest or to effectuate the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7859b4a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78ggg/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports from SIPC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the close of each fiscal year, SIPC shall submit to the Commission a written report relative to the conduct of its business, and the exercise of the other rights and powers granted by this chapter, during such fiscal year. Such report shall include financial statements setting forth the financial position of SIPC at the end of such fiscal year and the results of its operations (including the source and application of its funds) for such fiscal year. The financial statements so included shall be examined by an independent public accountant or firm of independent public accountants, selected by SIPC and satisfactory to the Commission, and shall be accompanied by the report thereon of such accountant or firm. The Commission shall transmit such report to the President and the Congress with such comment thereon as the Commission may deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7859b4a5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/598/s11"},"text":"Pub. L. 91–598, § 11","children":[],"tail":", formerly § 7, "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1652"},"text":"84 Stat. 1652","children":[],"tail":", 1653; renumbered § 11 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/283"},"text":"Pub. L. 95–283","children":[],"tail":", §§ 9, 10, "},{"tag":"date","attrib":{"date":"1978-05-21"},"text":"May 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/260"},"text":"92 Stat. 260","children":[],"tail":", 268.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7859b4a6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7859b4a7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7859b4a8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b) and (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/598"},"text":"Pub. L. 91–598","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1636"},"text":"84 Stat. 1636","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7859b4a9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/598/s11"},"text":"section 11 of Pub. L. 91–598","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/91/598/s11"},"text":"section 11 of Pub. L. 91–598","children":[],"tail":" amended section 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7859b4aa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/598/s11"},"text":"section 11 of Pub. L. 91–598","children":[],"tail":" was renumbered section 15 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78kkk"},"text":"section 78kkk of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7859b4ab-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/283"},"text":"Pub. L. 95–283","children":[],"tail":" substituted “pursuant to section 78ccc(e)(3) and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78iii/f"},"text":"section 78iii(f) of this title","children":[],"tail":"” for “or regulations pursuant to section 78ccc(e) and 78iii(f) of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7859b4ac-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7859b4ad-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (c)(2) of this section relating to submittal of annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 191 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
