{"tag":"section","attrib":{"id":"id797cb148-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472"},"text":null,"children":[{"tag":"num","attrib":{"value":"1472"},"text":"§ 1472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special packaging standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id797cb149-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission,","children":[{"tag":"ref","attrib":{"idref":"fn002325"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002325"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Comma retained in amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/97/414"},"text":"Pub. L. 97–414","children":[],"tail":"."}],"tail":" may establish in accordance with the provisions of this Act, by regulation, standards for the special packaging of any household substance if it finds that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id797cb14a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree or nature of the hazard to children in the availability of such substance, by reason of its packaging, is such that special packaging is required to protect children from serious personal injury or serious illness resulting from handling, using, or ingesting such substance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb14b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the special packaging to be required by such standard is technically feasible, practicable, and appropriate for such substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb14c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing a standard under this section, the Commission shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id797cb14d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonableness of such standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb14e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available scientific, medical, and engineering data concerning special packaging and concerning childhood accidental ingestions, illness, and injury caused by household substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb14f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturing practices of industries affected by this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb150-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and use of the household substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb151-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of findings, reasons, and citation of statutory authorizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this Act, the Commission shall publish its findings, its reasons therefor, and citation of the sections of statutes which authorize its action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb152-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall authorize the Commission to prescribe specific packaging designs, product content, package quantity, or, with the exception of authority granted in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1473/a/2"},"text":"section 1473(a)(2) of this title","children":[],"tail":", labeling. In this case of a household substance for which special packaging is required pursuant to a regulation under this section, the Commission may in such regulation prohibit the packaging of such substance in packages which it determines are unnecessarily attractive to children."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb153-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1472/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-benefit analysis not required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall be construed to require the Consumer Product Safety Commission, in establishing a standard under this section, to prepare a comparison of the costs that would be incurred in complying with such standard with the benefits of such standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id797cb154-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/601/s3"},"text":"Pub. L. 91–601, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1670"},"text":"84 Stat. 1670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/573/s30/a"},"text":"Pub. L. 92–573, § 30(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1231"},"text":"86 Stat. 1231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/414/s9/k"},"text":"Pub. L. 97–414, § 9(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2065"},"text":"96 Stat. 2065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s233"},"text":"Pub. L. 110–314, title II, § 233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3073"},"text":"122 Stat. 3073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797cb155-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797cb156-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id797cb157-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For classification to the Code of “this Act”, referred to in text, see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1471"},"text":"section 1471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id797cb158-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414"},"text":"Pub. L. 97–414","children":[],"tail":" struck out “, after consultation with the technical advisory committee provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1475"},"text":"section 1475 of this title","children":[],"tail":"” after “The Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id797cb159-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id797cb15a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Commission” substituted for “Secretary”, “it” substituted for “he”, and “its” substituted for “his” wherever appearing in subsecs. (a) to (d) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s30/a"},"text":"section 30(a) of Pub. L. 92–573","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079/a"},"text":"section 2079(a) of this title","children":[],"tail":" and which transferred functions of Secretary of Health, Education, and Welfare under this chapter to Consumer Product Safety Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
