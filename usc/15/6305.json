{"tag":"section","attrib":{"id":"id7a55ac69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305"},"text":null,"children":[{"tag":"num","attrib":{"value":"6305"},"text":"§ 6305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a55ac6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each boxer shall register with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the boxing commission of the State in which such boxer resides; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a boxer who is a resident of a foreign country, or a State in which there is no boxing commission, the boxing commission of any State that has such a commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a55ac6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification card","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A boxing commission shall issue to each professional boxer who registers in accordance with subsection (a), an identification card that contains each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a55ac6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recent photograph of the boxer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The social security number of the boxer (or, in the case of a foreign boxer, any similar citizen identification number or professional boxer number from the country of residence of the boxer).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A personal identification number assigned to the boxer by a boxing registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each professional boxer shall renew his or her identification card at least once every 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each professional boxer shall present his or her identification card to the appropriate boxing commission not later than the time of the weigh-in for a professional boxing match.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a55ac74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health and safety disclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that a boxing commission should, upon issuing an identification card to a boxer under subsection (b)(1), make a health and safety disclosure to that boxer as that commission considers appropriate. The health and safety disclosure should include the health and safety risks associated with boxing, and, in particular, the risk and frequency of brain injury and the advisability that a boxer periodically undergo medical procedures designed to detect brain injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a55ac75-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s6"},"text":"Pub. L. 104–272, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3310"},"text":"110 Stat. 3310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/c"},"text":"Pub. L. 106–210, § 7(c)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/328"},"text":"114 Stat. 328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a55ac76-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a55ac77-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a55ac78-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/c"},"text":"Pub. L. 106–210, § 7(c)","children":[],"tail":", substituted “4 years” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/f"},"text":"Pub. L. 106–210, § 7(f)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55ac79-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a55ac7a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23/2"},"text":"section 23(2) of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
