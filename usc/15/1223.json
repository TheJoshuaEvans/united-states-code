{"tag":"section","attrib":{"id":"id796be88a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1223"},"text":null,"children":[{"tag":"num","attrib":{"value":"1223"},"text":"§ 1223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any action brought pursuant to this chapter shall be forever barred unless commenced within three years after the cause of action shall have accrued.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796be88b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-08/ch1038/s3"},"text":"Aug. 8, 1956, ch. 1038, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1125"},"text":"70 Stat. 1125","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
