{"tag":"section","attrib":{"id":"id79d027da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2056d"},"text":"§ 2056d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance standards to protect against portable fuel container explosions near open flames or other ignition sources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d027db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Portable Fuel Container Safety Act of 2020”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d027dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d027dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule on safety performance standards required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Consumer Product Safety Commission (referred to in this section as the “Commission”) shall promulgate a final rule to require flame mitigation devices in portable fuel containers that impede the propagation of flame into the container, except as provided in paragraph (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking; consumer product safety standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A rule under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d027df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be promulgated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d027e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as a consumer product safety rule promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2058"},"text":"section 2058 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d027e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply for a class of portable fuel containers in the scope of this section if the Commission determines at any time that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79d027e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a voluntary standard for flame mitigation devices for those containers that impedes the propagation of flame into the container;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d027e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the voluntary standard described in clause (i) is or will be in effect not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79d027e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the voluntary standard described in clause (i) is developed by ASTM International or such other standard development organization that the Commission determines to have met the intent of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d027e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination required to be published in the Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any determination made by the Commission under this subsection shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of voluntary standard for purpose of enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commission determines that a voluntary standard meets the conditions described in paragraph (3)(A), the requirements of such voluntary standard shall be treated as a consumer product safety rule promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2058"},"text":"section 2058 of this title","children":[],"tail":" beginning on the date which is the later of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d027e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after publication of the Commission’s determination under paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d027e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date contained in the voluntary standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of voluntary standard","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d027eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the requirements of a voluntary standard that meet the conditions of paragraph (3) are subsequently revised, the organization that revised the standard shall notify the Commission after the final approval of the revision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d027ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the Commission is notified of a revised voluntary standard described in subparagraph (A) (or such later date as the Commission determines appropriate), such revised voluntary standard shall become enforceable as a consumer product safety rule promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2058"},"text":"section 2058 of this title","children":[],"tail":", in place of the prior version, unless within 90 days after receiving the notice the Commission determines that the revised voluntary standard does not meet the requirements described in paragraph (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission, at any time after publication of the consumer product safety rule required by paragraph (1), a voluntary standard is treated as a consumer product safety rule under paragraph (4), or a revision is enforceable as a consumer product safety rule under paragraph (5) ","children":[{"tag":"ref","attrib":{"idref":"fn002421"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002421"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" may initiate a rulemaking in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" to modify the requirements or to include any additional provision that the Commission determines is reasonably necessary to protect the public against flame jetting from a portable fuel container. Any rule promulgated under this subsection shall be treated as a consumer product safety rule promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2058"},"text":"section 2058 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action required","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d027ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education campaign","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Commission shall undertake a campaign to educate consumers about the dangers associated with using or storing portable fuel containers for flammable liquids near an open flame or any other source of ignition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d027f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Summary of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Commission shall submit to Congress a summary of actions taken by the Commission in such campaign."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portable fuel container defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “portable fuel container” means any container or vessel (including any spout, cap, and other closure mechanism or component of such container or vessel or any retrofit or aftermarket spout or component intended or reasonably anticipated to be for use with such container)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d027f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intended for flammable liquid fuels with a flash point less than 140 degrees Fahrenheit, including gasoline, kerosene, diesel, ethanol, methanol, denatured alcohol, or biofuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d027f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is a consumer product with a capacity of 5 gallons or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d027f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the manufacturer knows or reasonably should know is used by consumers for transporting, storing, and dispensing flammable liquid fuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be interpreted to conflict with the Children’s Gasoline Burn Prevention Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/278"},"text":"Public Law 110–278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/2602"},"text":"122 Stat. 2602","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d027f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children’s Gasoline Burn Prevention Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d027f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d027f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2056d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amendment made by paragraph (1) shall take effect 6 months after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d027f9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tIX/s901"},"text":"Pub. L. 116–260, div. FF, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3204"},"text":"134 Stat. 3204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d027fa-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d027fb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79d027fc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (b)(1), (3)(A), (8), and (9), was in the original “this Act”, which was translated as reading “this section”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s901"},"text":"section 901 of Pub. L. 116–260","children":[],"tail":", div. FF, title IX, "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3204"},"text":"134 Stat. 3204","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Children’s Gasoline Burn Prevention Act, referred to in subsecs. (b)(9) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/278"},"text":"Pub. L. 110–278","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-17"},"text":"July 17, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2602"},"text":"122 Stat. 2602","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2056"},"text":"section 2056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d027fd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as the Portable Fuel Container Safety Act of 2020, and not as part of the Consumer Product Safety Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/s901"},"text":"section 901 of div. FF of Pub. L. 116–260","children":[],"tail":". Subsec. (c)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/s901"},"text":"section 901 of div. FF of Pub. L. 116–260","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/278/s2"},"text":"section 2 of Pub. L. 110–278","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2056"},"text":"section 2056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
