{"tag":"section","attrib":{"id":"id78a60013-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s384"},"text":null,"children":[{"tag":"num","attrib":{"value":"384"},"text":"§ 384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application of such provision to any person or circumstance is held invalid, the remainder of this chapter or the application of such provision to persons or circumstances other than those to which it is held invalid, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a60014-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/272/tI/s104"},"text":"Pub. L. 86–272, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/556"},"text":"73 Stat. 556","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
