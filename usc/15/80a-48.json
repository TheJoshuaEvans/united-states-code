{"tag":"section","attrib":{"id":"id7873f3cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–48"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–48"},"text":"§ 80a–48.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates any provision of this subchapter or of any rule, regulation, or order hereunder, or any person who willfully in any registration statement, application, report, account, record, or other document filed or transmitted pursuant to this subchapter or the keeping of which is required pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–30/a"},"text":"section 80a–30(a) of this title","children":[],"tail":" makes any untrue statement of a material fact or omits to state any material fact necessary in order to prevent the statements made therein from being materially misleading in the light of the circumstances under which they were made, shall upon conviction be fined not more than $10,000 or imprisoned not more than five years, or both; but no person shall be convicted under this section for the violation of any rule, regulation, or order if he proves that he had no actual knowledge of such rule, regulation, or order."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7873f3ce-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 49, "},{"tag":"ref","attrib":{"href":"/us/stat/54/846"},"text":"54 Stat. 846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s27/e"},"text":"Pub. L. 94–29, § 27(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/163"},"text":"89 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7873f3cf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7873f3d0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7873f3d1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/29"},"text":"Pub. L. 94–29","children":[],"tail":" substituted “or imprisoned not more than five years” for “or imprisoned not more than two years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7873f3d2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7873f3d3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/29"},"text":"Pub. L. 94–29","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s31/a"},"text":"section 31(a) of Pub. L. 94–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78b"},"text":"section 78b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
