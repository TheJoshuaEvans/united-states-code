{"tag":"section","attrib":{"id":"id78063dbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"78d–9"},"text":"§ 78d–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on oversight of national securities associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78063dbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", and every 3 years thereafter, the Comptroller General of the United States shall submit to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives a report that includes an evaluation of the oversight by the Commission of national securities associations registered under section 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–3 of this title with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063dbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governance of such national securities associations, including the identification and management of conflicts of interest by such national securities associations, together with an analysis of the impact of any conflicts of interest on the regulatory enforcement or rulemaking by such national securities associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the examinations carried out by the national securities associations, including the expertise of the examiners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the executive compensation practices of such national securities associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arbitration services provided by the national securities associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review performed by national securities associations of advertising by the members of the national securities associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cooperation with and assistance to State securities administrators by the national securities associations to promote investor protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" how the funding of national securities associations is used to support the mission of the national securities associations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063dc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063dc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sufficiency of funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063dc7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how funds are invested by the national securities association pending use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063dc8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the methods, sufficiency, and investment of funds on regulatory enforcement by the national securities associations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dc9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies regarding the employment of former employees of national securities associations by regulated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ongoing effectiveness of the rules of the national securities associations in achieving the goals of the rules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dcb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transparency of governance and activities of the national securities associations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dcc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other issue that has an impact, as determined by the Comptroller General, on the effectiveness of such national securities associations in performing their mission and in dealing fairly with investors and members; ","children":[{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063dcd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements for cost of reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063dce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall reimburse the Government Accountability Office for the full cost of making the reports under subsection (a), as billed therefor by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063dcf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting and use of reimbursements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such reimbursements shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063dd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the appropriation account “Salaries and Expenses, Government Accountability Office” current when the payment is received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063dd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–9/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78063dd2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s964"},"text":"Pub. L. 111–203, title IX, § 964","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1910"},"text":"124 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78063dd3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78063dd4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78063dd5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Investor Protection and Securities Reform Act of 2010 and also as part of the Dodd-Frank Wall Street Reform and Consumer Protection Act, and not as part of the Securities Exchange Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78063dd6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78063dd7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id78063dd8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
