{"tag":"section","attrib":{"id":"id78df3857-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s636f"},"text":null,"children":[{"tag":"num","attrib":{"value":"636f"},"text":"§ 636f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of efforts between the Administrator and the Internal Revenue Service to expedite loan processing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator and the Commissioner of Internal Revenue shall, to the maximum extent practicable, ensure that all relevant and allowable tax records for loan approval are shared with loan processors in an expedited manner, upon request by the Administrator.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78df3858-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12066/b"},"text":"Pub. L. 110–234, title XII, § 12066(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1410"},"text":"122 Stat. 1410","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12066(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2172.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78df3859-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78df385a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":