{"tag":"section","attrib":{"id":"id7892ed86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c"},"text":null,"children":[{"tag":"num","attrib":{"value":"278g–3c"},"text":"§ 278g–3c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines on the disclosure process for security vulnerabilities relating to information systems, including Internet of Things devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7892ed87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-04"},"text":"December 4, 2020","children":[],"tail":", the Director of the Institute, in consultation with such cybersecurity researchers and private sector industry experts as the Director considers appropriate, and in consultation with the Secretary, shall develop and publish under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"section 278g–3 of this title","children":[],"tail":" guidelines—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892ed88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the reporting, coordinating, publishing, and receiving of information about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7892ed89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a security vulnerability relating to information systems owned or controlled by an agency (including Internet of Things devices owned or controlled by an agency); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7892ed8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resolution of such security vulnerability; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a contractor providing to an agency an information system (including an Internet of Things device) and any subcontractor thereof at any tier providing such information system to such contractor, on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7892ed8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving information about a potential security vulnerability relating to the information system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7892ed8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating information about the resolution of a security vulnerability relating to the information system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892ed8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines published under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892ed8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, be aligned with industry best practices and Standards 29147 and 30111 of the International Standards Organization (or any successor standard) or any other appropriate, relevant, and widely-used standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" incorporate guidelines on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7892ed91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving information about a potential security vulnerability relating to an information system owned or controlled by an agency (including an Internet of Things device); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7892ed92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating information about the resolution of a security vulnerability relating to an information system owned or controlled by an agency (including an Internet of Things device); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with the policies and procedures produced under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s659/m"},"text":"section 659(m) of title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892ed94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information items","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines published under subsection (a) shall include example content, on the information items that should be reported, coordinated, published, or received pursuant to this section by a contractor, or any subcontractor thereof at any tier, providing an information system (including Internet of Things device) to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892ed95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of OMB shall oversee the implementation of the guidelines published under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892ed96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Director of OMB, shall administer the implementation of the guidelines published under subsection (a) and provide operational and technical assistance in implementing such guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7892ed97-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/207/s5"},"text":"Pub. L. 116–207, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-04"},"text":"Dec. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1004"},"text":"134 Stat. 1004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7892ed98-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7892ed99-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7892ed9a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Internet of Things Cybersecurity Improvement Act of 2020, also known as the IoT Cybersecurity Improvement Act of 2020, and not as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7892ed9b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7892ed9c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3a"},"text":"section 278g–3a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
