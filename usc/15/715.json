{"tag":"section","attrib":{"id":"id793c4c80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s715"},"text":null,"children":[{"tag":"num","attrib":{"value":"715"},"text":"§ 715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is declared to be the policy of Congress to protect interstate and foreign commerce from the diversion and obstruction of, and the burden and harmful effect upon, such commerce caused by contraband oil as herein defined, and to encourage the conservation of deposits of crude oil situated within the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id793c4c81-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-02-22/ch18/s1"},"text":"Feb. 22, 1935, ch. 18, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/30"},"text":"49 Stat. 30","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793c4c82-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793c4c83-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id793c4c84-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1935-02-22"},"text":"Feb. 22, 1935","children":[],"tail":", which is classified to this chapter, is popularly known as the “Hot Oil Act” and also as the “Connally Hot Oil Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
