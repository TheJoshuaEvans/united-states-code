{"tag":"section","attrib":{"id":"id791ae1e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h"},"text":null,"children":[{"tag":"num","attrib":{"value":"657h"},"text":"§ 657h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business energy efficiency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791ae1e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae1e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “Administration” and “Administrator” mean the Small Business Administration and the Administrator thereof, respectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “association” means the association of small business development centers established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a/3/A"},"text":"section 648(a)(3)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “disability” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12102"},"text":"section 12102 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Efficiency Program” means the Small Business Energy Efficiency Program established under subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electric utility” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602"},"text":"section 2602 of title 16","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “high performance green building” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17061"},"text":"section 17061 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “on-bill financing” means a low interest or no interest financing agreement between a small business concern and an electric utility for the purchase or installation of equipment, under which the regularly scheduled payment of that small business concern to that electric utility is not reduced by the amount of the reduction in cost attributable to the new equipment and that amount is credited to the electric utility, until the cost of the purchase or installation is repaid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business concern” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business development center” means a small business development center described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648"},"text":"section 648 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “telecommuting” means the use of telecommunications to perform work functions under circumstances which reduce or eliminate the need to commute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Telecommuting Pilot Program” means the pilot program established under subsection (d)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “veteran” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae1f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of small business energy efficiency program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae1f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Administrator shall promulgate final rules establishing the Government-wide program authorized under subsection (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6307"},"text":"section 6307 of title 42","children":[],"tail":" that ensure compliance with that subsection by not later than 6 months after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop and coordinate a Government-wide program, building on the Energy Star for Small Business program, to assist small business concerns in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae1f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becoming more energy efficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae1f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding the cost savings from improved energy efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae1f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying financing options for energy efficiency upgrades.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program required by paragraph (2) shall be developed and coordinated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae1fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Secretary of Energy and the Administrator of the Environmental Protection Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae1fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with any entities the Administrator considers appropriate, such as industry trade associations, industry members, and energy efficiency organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall make available the information and materials developed under the program required by paragraph (2) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae1fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns, including smaller design, engineering, and construction firms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae1fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal programs for energy efficiency, such as the Energy Star for Small Business program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae1ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy and report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae200-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop a strategy to educate, encourage, and assist small business concerns in adopting energy efficient building fixtures and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae201-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":", the Administrator shall submit to Congress a report containing a plan to implement the strategy developed under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae202-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business sustainability initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae203-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a Small Business Energy Efficiency Program to provide energy efficiency assistance to small business concerns through small business development centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae204-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business development centers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae205-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Efficiency Program, the Administrator shall enter into agreements with small business development centers under which such centers shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791ae206-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide access to information and resources on energy efficiency practices, including on-bill financing options;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae207-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct training and educational activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae208-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer confidential, free, one-on-one, in-depth energy audits to the owners and operators of small business concerns regarding energy efficiency practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae209-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give referrals to certified professionals and other providers of energy efficiency assistance who meet such standards for educational, technical, and professional competency as the Administrator shall establish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae20a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent not inconsistent with controlling State public utility regulations, act as a facilitator between small business concerns, electric utilities, lenders, and the Administration to facilitate on-bill financing arrangements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae20b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide necessary support to small business concerns to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id791ae20c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate energy efficiency opportunities and opportunities to design or construct high performance green buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae20d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate renewable energy sources, such as the use of solar and small wind to supplement power consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae20e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure financing to achieve energy efficiency or to design or construct high performance green buildings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae20f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vi/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement energy efficiency projects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae210-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist owners of small business concerns with the development and commercialization of clean technology products, goods, services, and processes that use renewable energy sources, dramatically reduce the use of natural resources, and cut or eliminate greenhouse gas emissions through—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id791ae211-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae212-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intellectual property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae213-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Small Business Innovation Research submissions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"section 638 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae214-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategic alliances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae215-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business model development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae216-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/vii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation for investors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae217-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help small business concerns improve environmental performance by shifting to less hazardous materials and reducing waste and emissions, including by providing assistance for small business concerns to adapt the materials they use, the processes they operate, and the products and services they produce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae218-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each small business development center participating in the Efficiency Program shall submit to the Administrator and the Administrator of the Environmental Protection Agency an annual report that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791ae219-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the energy efficiency assistance provided by that center under the Efficiency Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae21a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of small business concerns assisted by that center under the Efficiency Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae21b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistics on the total amount of energy saved as a result of assistance provided by that center under the Efficiency Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae21c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional information determined necessary by the Administrator, in consultation with the association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae21d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which all reports under subparagraph (B) relating to a year are submitted, the Administrator shall submit to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives a report summarizing the information regarding the Efficiency Program submitted by small business development centers participating in that program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae21e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A small business development center shall be eligible to participate in the Efficiency Program only if that center is certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/k/2"},"text":"section 648(k)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae21f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of participating State programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From among small business development centers submitting applications to participate in the Efficiency Program, the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae220-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the maximum extent practicable, select small business development centers in such a manner so as to promote a nationwide distribution of centers participating in the Efficiency Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae221-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not select more than 1 small business development center in a State to participate in the Efficiency Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae222-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraphs (A) and (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a/4"},"text":"section 648(a)(4) of this title","children":[],"tail":" shall apply to assistance made available under the Efficiency Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae223-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each small business development center selected to participate in the Efficiency Program under paragraph (4) shall be eligible to receive a grant in an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae224-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $100,000 in each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae225-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $300,000 in each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae226-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae227-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 months after the date of disbursement of the first grant under the Efficiency Program, initiate an evaluation of that program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae228-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 6 months after the date of the initiation of the evaluation under subparagraph (A), submit to the Administrator, the Committee on Small Business and Entrepreneurship of the Senate, and the Committee on Small Business of the House of Representatives, a report containing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791ae229-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae22a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations regarding whether the Efficiency Program, with or without modification, should be extended to include the participation of all small business development centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae22b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent not inconsistent with State law, the Administrator may guarantee the timely payment of a loan made to a small business concern through an on-bill financing agreement on such terms and conditions as the Administrator shall establish through a formal rulemaking, after providing notice and an opportunity for comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae22c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to amounts approved in advance in appropriations Acts and separate from amounts approved to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a/1"},"text":"section 648(a)(1) of this title","children":[],"tail":", the Administrator may make grants or enter into cooperative agreements to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae22d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to make grants and enter into cooperative agreements to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae22e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority under this subsection shall terminate 4 years after the date of disbursement of the first grant under the Efficiency Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae22f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business telecommuting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae230-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae231-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall conduct, in not more than 5 of the regions of the Administration, a pilot program to provide information regarding telecommuting to employers that are small business concerns and to encourage such employers to offer telecommuting options to employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae232-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special outreach to individuals with disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Telecommuting Pilot Program, the Administrator shall make a concerted effort to provide information to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791ae233-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns owned by or employing individuals with disabilities, particularly veterans who are individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae234-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and local agencies having knowledge and expertise in assisting individuals with disabilities, including veterans who are individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae235-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any group or organization, the primary purpose of which is to aid individuals with disabilities or veterans who are individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae236-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Telecommuting Pilot Program, the Administrator may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791ae237-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce educational materials and conduct presentations designed to raise awareness in the small business community of the benefits and the ease of telecommuting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae238-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct outreach—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id791ae239-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to small business concerns that are considering offering telecommuting options; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791ae23a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791ae23b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire telecommuting technologies and equipment to be used for demonstration purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae23c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of regions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining which regions will participate in the Telecommuting Pilot Program, the Administrator shall give priority consideration to regions in which Federal agencies and private-sector employers have demonstrated a strong regional commitment to telecommuting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae23d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which funds are first appropriated to carry out this subsection, the Administrator shall transmit to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives a report containing the results of an evaluation of the Telecommuting Pilot Program and any recommendations regarding whether the pilot program, with or without modification, should be extended to include the participation of all regions of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae23e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Telecommuting Pilot Program shall terminate 4 years after the date on which funds are first appropriated to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae23f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657h/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administration $5,000,000 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791ae240-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1203"},"text":"Pub. L. 110–140, title XII, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1766"},"text":"121 Stat. 1766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791ae241-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id791ae242-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id791ae243-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1203"},"text":"section 1203 of Pub. L. 110–140","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1203"},"text":"section 1203 of Pub. L. 110–140","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"section 638 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Independence and Security Act of 2007, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id791ae244-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id791ae245-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
