{"tag":"section","attrib":{"id":"id7a6b08b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031"},"text":null,"children":[{"tag":"num","attrib":{"value":"7031"},"text":"§ 7031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles governing the use of electronic signatures in international transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6b08b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of electronic signatures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b08b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall promote the acceptance and use, on an international basis, of electronic signatures in accordance with the principles specified in paragraph (2) and in a manner consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":". The Secretary of Commerce shall take all actions necessary in a manner consistent with such principles to eliminate or reduce, to the maximum extent possible, the impediments to commerce in electronic signatures, for the purpose of facilitating the development of interstate and foreign commerce."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b08b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The principles specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b08b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Remove paper-based obstacles to electronic transactions by adopting relevant principles from the Model Law on Electronic Commerce adopted in 1996 by the United Nations Commission on International Trade Law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Permit parties to a transaction to determine the appropriate authentication technologies and implementation models for their transactions, with assurance that those technologies and implementation models will be recognized and enforced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Permit parties to a transaction to have the opportunity to prove in court or other proceedings that their authentication approaches and their transactions are valid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Take a nondiscriminatory approach to electronic signatures and authentication methods from other jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the activities required by this section, the Secretary shall consult with users and providers of electronic signature products and services and other interested persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7031/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the terms “electronic record” and “electronic signature” have the same meanings provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7006"},"text":"section 7006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b08bd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/229/tIII/s301"},"text":"Pub. L. 106–229, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/475"},"text":"114 Stat. 475","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
