{"tag":"section","attrib":{"id":"id7a808bd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002"},"text":null,"children":[{"tag":"num","attrib":{"value":"8002"},"text":"§ 8002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808bd6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ASME/ANSI","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ASME/ANSI” as applied to a safety standard means such a standard that is accredited by the American National Standards Institute and published by the American Society of Mechanical Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808bd7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barrier","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “barrier” includes a natural or constructed topographical feature that prevents unpermitted access by children to a swimming pool, and, with respect to a hot tub, a lockable cover.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808bd8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Consumer Product Safety Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808bd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808bda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808bdb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808bdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribe” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808bdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Main drain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “main drain” means a submerged suction outlet typically located at the bottom of a pool or spa to conduct water to a recirculating pump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808bde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety vacuum release system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “safety vacuum release system” means a vacuum release system capable of providing vacuum release at a suction outlet caused by a high vacuum occurrence due to a suction outlet flow blockage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808bdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swimming pool; spa","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “swimming pool” or “spa” means any outdoor or indoor structure intended for swimming or recreational bathing, including in-ground and above-ground structures, and includes hot tubs, spas, portable spas, and non-portable wading pools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808be0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unblockable drain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unblockable drain” means a drain of any size and shape that a human body cannot sufficiently block to create a suction entrapment hazard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808be1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8002/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052/a"},"text":"section 2052(a) of this title","children":[],"tail":", and includes the Northern Mariana Islands. For purposes of eligibility for the grants authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8004"},"text":"section 8004 of this title","children":[],"tail":", such term shall also include any political subdivision of a State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a808be2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXIV/s1403"},"text":"Pub. L. 110–140, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1795"},"text":"121 Stat. 1795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s238/1"},"text":"Pub. L. 110–314, title II, § 238(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3076"},"text":"122 Stat. 3076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tV/s1576/a"},"text":"Pub. L. 112–10, div. B, title V, § 1576(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/139"},"text":"125 Stat. 139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tIV/s401"},"text":"Pub. L. 117–328, div. BB, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5562"},"text":"136 Stat. 5562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a808be3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a808be4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a808be5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Pars. (4) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s401/a"},"text":"Pub. L. 117–328, § 401(a)","children":[],"tail":", added par. (4) and redesignated former pars. (4) to (8) as (6) to (9), respectively. Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s401/a/1"},"text":"Pub. L. 117–328, § 401(a)(1)","children":[],"tail":", (b), redesignated par. (9) as (10) and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052/a"},"text":"section 2052(a) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052/10"},"text":"section 2052(10) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10"},"text":"Pub. L. 112–10","children":[],"tail":" inserted at end “For purposes of eligibility for the grants authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8004"},"text":"section 8004 of this title","children":[],"tail":", such term shall also include any political subdivision of a State.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":" added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a808be6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a808be7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
