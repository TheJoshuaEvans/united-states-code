{"tag":"section","attrib":{"id":"id77d1c084-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"57c–2"},"text":"§ 57c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission may accept payment or reimbursement, in cash or in kind, from a domestic or foreign law enforcement agency, or payment or reimbursement made on behalf of such agency, for expenses incurred by the Commission, its members, or employees in carrying out any activity pursuant to a statute administered by the Commission without regard to any other provision of law. Any such payments or reimbursements shall be considered a reimbursement to the appropriated funds of the Commission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d1c085-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s26"},"text":"Sept. 26, 1914, ch. 311, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s11/2"},"text":"Pub. L. 109–455, § 11(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3381"},"text":"120 Stat. 3381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d1c086-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id77d1c087-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"section 13 of Pub. L. 109–455","children":[],"tail":",