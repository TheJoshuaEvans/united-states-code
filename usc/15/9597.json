{"tag":"section","attrib":{"id":"id7ab299af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9597"},"text":null,"children":[{"tag":"num","attrib":{"value":"9597"},"text":"§ 9597.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Order 11625","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The powers and duties of the Agency shall be determined—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9597/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with this chapter and the requirements of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9597/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to Executive Order 11625 (36 Fed. Reg. 19967; relating to prescribing additional arrangements for developing and coordinating a national program for minority business enterprise).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab299b2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tVII/s100707"},"text":"Pub. L. 117–58, div. K, title VII, § 100707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1467"},"text":"135 Stat. 1467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab299b3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab299b4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab299b5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 11625, referred to in section catchline and par. (2), is Ex. Ord. No. 11625, ","children":[{"tag":"date","attrib":{"date":"1971-10-13"},"text":"Oct. 13, 1971","children":[],"tail":", 36 F.R. 19967, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (1), was in the original “this division”, meaning div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1445"},"text":"135 Stat. 1445","children":[],"tail":", which is classified principally to this chapter. For complete classification of division K to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
