{"tag":"section","attrib":{"id":"id794f5f14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790h"},"text":null,"children":[{"tag":"num","attrib":{"value":"790h"},"text":"§ 790h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional access to energy information; disclosure by Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall promptly provide upon request any energy information in the possession of the Office to any duly established committee of the Congress. Such information shall be deemed the property of such committee and may not be disclosed except in accordance with the rules of such committee and the Rules of the House of Representatives or the Senate and as permitted by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id794f5f15-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/275/s59"},"text":"Pub. L. 93–275, § 59","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/tI/s142"},"text":"Pub. L. 94–385, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1140"},"text":"90 Stat. 1140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794f5f16-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794f5f17-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id794f5f18-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 150 days after ","children":[{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/s143"},"text":"section 143 of Pub. L. 94–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s790"},"text":"section 790 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id794f5f19-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions assigned to Director of Office of Energy Information and Analysis under this subchapter vested in Administrator of Energy Information Administration within Department of Energy by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7135/c"},"text":"section 7135(c) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
