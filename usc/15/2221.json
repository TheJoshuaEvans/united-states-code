{"tag":"section","attrib":{"id":"id79e5855b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221"},"text":null,"children":[{"tag":"num","attrib":{"value":"2221"},"text":"§ 2221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arson prevention grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79e5855c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e5855d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “arson” includes all incendiary and suspicious fires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5855e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the Office of Fire Prevention and Arson Control of the United States Fire Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e5855f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, acting through the Office, shall carry out a demonstration program under which not more than 10 grant awards shall be made to States, or consortia of States, for programs relating to arson research, prevention, and control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58560-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Administrator shall award 2-year grants on a competitive, merit basis to States, or consortia of States, for projects that promote one or more of the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e58561-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve the training by States leading to professional certification of arson investigators, in accordance with nationally recognized certification standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58562-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide resources for the formation of arson task forces or interagency organizational arrangements involving police and fire departments and other relevant local agencies, such as a State arson bureau and the office of a fire marshal of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58563-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To combat fraud as a cause of arson and to advance research at the State and local levels on the significance and prevention of fraud as a motive for setting fires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58564-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To provide for the management of arson squads, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e58565-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training courses for fire departments in arson case management, including standardization of investigative techniques and reporting methodology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e58566-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of arson unit management guides; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e58567-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and dissemination of new public education materials relating to the arson problem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58568-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To combat civil unrest as a cause of arson and to advance research at the State and local levels on the prevention and control of arson linked to urban disorders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58569-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To combat juvenile arson, such as juvenile fire-setter counseling programs and similar intervention programs, and to advance research at the State and local levels on the prevention of juvenile arson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5856a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To combat drug-related arson and to advance research at the State and local levels on the causes and prevention of drug-related arson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5856b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To combat domestic violence as a cause of arson and to advance research at the State and local levels on the prevention of arson arising from domestic violence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5856c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To combat arson in rural areas and to improve the capability of firefighters to identify and prevent arson initiated fires in rural areas and public forests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5856d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To improve the capability of firefighters to identify and combat arson through expanded training programs, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79e5856e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training courses at the State fire academies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79e5856f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/c/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative courses developed with the Academy and made available to volunteer firefighters through regional delivery methods, including teleconferencing and satellite delivered television programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58570-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structuring of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall assist grant applicants in structuring their applications so as to ensure that at least one grant is awarded for each goal described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58571-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State qualification criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to qualify for a grant under this section, a State, or consortium of States, shall provide assurances adequate to the Administrator that the State or consortium—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e58572-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will obtain at least 25 percent of the cost of programs funded by the grant, in cash or in kind, from non-Federal sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58573-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not as a result of receiving the grant decrease the prior level of spending of funds of the State or consortium from non-Federal sources for arson research, prevention, and control programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58574-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will use no more than 10 percent of funds provided under the grant for administrative costs of the programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58575-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is making efforts to ensure that all local jurisdictions will provide arson data to the National Fire Incident Reporting System or the Uniform Crime Reporting program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58576-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section may be extended for one or more additional periods, at the discretion of the Administrator, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58577-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide technical assistance to States in carrying out programs funded by grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58578-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Administrator shall consult and cooperate with other Federal agencies to enhance program effectiveness and avoid duplication of effort, including the conduct of regular meetings initiated by the Administrator with representatives of other Federal agencies concerned with arson and concerned with efforts to develop a more comprehensive profile of the magnitude of the national arson problem.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58579-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1994-05-19"},"text":"May 19, 1994","children":[],"tail":", the Administrator shall submit a report to Congress that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e5857a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies grants made under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5857b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the identity of grantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5857c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the goals of each grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e5857d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a preliminary assessment of the effectiveness of the grant program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e5857e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-05-19"},"text":"May 19, 1994","children":[],"tail":", the Administrator shall issue regulations to implement this section, including procedures for grant applications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e5857f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall directly administer the grant program required by this section, and shall not enter into any contract under which the grant program or any portion of the program will be administered by another party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79e58580-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of American made equipment and products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79e58581-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that any recipient of a grant under this section should purchase, when available and cost-effective, American made equipment and products when expending grant monies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79e58582-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2221/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to recipients of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In allocating grants under this section, the Administrator shall provide to each recipient a notice describing the statement made in paragraph (1) by the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79e58583-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498/s25"},"text":"Pub. L. 93–498, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/254/s3"},"text":"Pub. L. 103–254, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-19"},"text":"May 19, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/679"},"text":"108 Stat. 679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e58584-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e58585-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79e58586-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2221, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498/s25"},"text":"Pub. L. 93–498, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/422/s4"},"text":"Pub. L. 95–422, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-05"},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/933"},"text":"92 Stat. 933","children":[],"tail":", authorized sale by United States Fire Administrator of former Marjorie Webster Junior College facility, located in Washington, D.C., which had previously been purchased as site for National Academy for Fire Prevention and Control, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/80/tII/s202/b"},"text":"Pub. L. 97–80, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-20"},"text":"Nov. 20, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1083"},"text":"95 Stat. 1083","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
