{"tag":"section","attrib":{"id":"id7a15472d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058"},"text":"§ 3058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of final decisions of the Authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a15472e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of civil sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" If the Authority imposes a final civil sanction for a violation committed by a covered person pursuant to the rules or standards of the Authority, the Authority shall promptly submit to the Commission notice of the civil sanction in such form as the Commission may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a15472f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by administrative law judge","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a154730-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a final civil sanction imposed by the Authority, on application by the Commission or a person aggrieved by the civil sanction filed not later than 30 days after the date on which notice under subsection (a) is submitted, the civil sanction shall be subject to de novo review by an administrative law judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154731-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a154732-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In matters reviewed under this subsection, the administrative law judge shall determine whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a154733-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person has engaged in such acts or practices, or has omitted such acts or practices, as the Authority has found the person to have engaged in or omitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a154734-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such acts, practices, or omissions are in violation of this chapter or the anti-doping and medication control or racetrack safety rules approved by the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a154735-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final civil sanction of the Authority was arbitrary, capricious, an abuse of discretion, or otherwise not in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154736-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An administrative law judge shall conduct a hearing under this subsection in such a manner as the Commission may specify by rule, which shall conform to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s556"},"text":"section 556 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154737-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision by administrative law judge","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a154738-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a matter reviewed under this subsection, an administrative law judge—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a154739-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall render a decision not later than 60 days after the conclusion of the hearing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a15473a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may affirm, reverse, modify, set aside, or remand for further proceedings, in whole or in part, the final civil sanction of the Authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a15473b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make any finding or conclusion that, in the judgment of the administrative law judge, is proper and based on the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15473c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision under this paragraph shall constitute the decision of the Commission without further proceedings unless a notice or an application for review is timely filed under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a15473d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a15473e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of review by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, on its own motion, review any decision of an administrative law judge issued under subsection (b)(3) by providing written notice to the Authority and any interested party not later than 30 days after the date on which the administrative law judge issues the decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a15473f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a154740-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority or a person aggrieved by a decision issued under subsection (b)(3) may petition the Commission for review of such decision by filing an application for review not later than 30 days after the date on which the administrative law judge issues the decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154741-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of denial of application for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an application for review under subparagraph (A) is denied, the decision of the administrative law judge shall constitute the decision of the Commission without further proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154742-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion of Commission","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a154743-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision with respect to whether to grant an application for review under subparagraph (A) is subject to the discretion of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a154744-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether to grant such an application for review, the Commission shall consider whether the application makes a reasonable showing that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a154745-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prejudicial error was committed in the conduct of the proceeding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a154746-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the decision involved—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a154747-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/C/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an erroneous application of the anti-doping and medication control or racetrack safety rules approved by the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a154748-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/2/C/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an exercise of discretion or a decision of law or policy that warrants review by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154749-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a15474a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In matters reviewed under this subsection, the Commission may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a15474b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affirm, reverse, modify, set aside, or remand for further proceedings, in whole or in part, the decision of the administrative law judge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a15474c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any finding or conclusion that, in the judgement of the Commission, is proper and based on the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15474d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" De novo review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall review de novo the factual findings and conclusions of law made by the administrative law judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15474e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of additional evidence","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a15474f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, on its own motion, allow the consideration of additional evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a154750-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motion by a party","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a154751-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A party may file a motion to consider additional evidence at any time before the issuance of a decision by the Commission, which shall show, with particularity, that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a154752-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional evidence is material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a154753-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there were reasonable grounds for failure to submit the evidence previously.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a154754-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a154755-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept or hear additional evidence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a154756-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/c/3/C/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remand the proceeding to the administrative law judge for the consideration of additional evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a154757-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3058/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Review by an administrative law judge or the Commission under this section shall not operate as a stay of a final civil sanction of the Authority unless the administrative law judge or Commission orders such a stay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a154758-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1209"},"text":"Pub. L. 116–260, div. FF, title XII, § 1209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3272"},"text":"134 Stat. 3272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a154759-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a15475a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a15475b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2)(A)(ii), was in the original “this Act” and was translated as reading “this title”, meaning title XII of div. FF of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
