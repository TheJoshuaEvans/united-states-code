{"tag":"section","attrib":{"id":"id7a939f58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9003"},"text":null,"children":[{"tag":"num","attrib":{"value":"9003"},"text":"§ 9003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Trade Expansion Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a939f59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (3)(C)(iii) of section 649(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title, for grants under the State Trade Expansion Program under such section 649("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title using amounts made available for fiscal year 2018 or fiscal year 2019, the period of the grant shall continue through the end of fiscal year 2021."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939f5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall reimburse any recipient of assistance under section 649(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title for financial losses relating to a foreign trade mission or a trade show exhibition that was cancelled solely due to a public health emergency declared due to COVID–19 if the reimbursement does not exceed a recipient’s grant funding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a939f5b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tI/s1104"},"text":"Pub. L. 116–136, div. A, title I, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/297"},"text":"134 Stat. 297","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
