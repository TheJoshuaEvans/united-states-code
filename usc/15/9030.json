{"tag":"section","attrib":{"id":"id7a9d3c3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9030"},"text":null,"children":[{"tag":"num","attrib":{"value":"9030"},"text":"§ 9030.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of the 7-day waiting period for benefits under the Railroad Unemployment Insurance Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9d3c3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9030/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No waiting week","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any registration period beginning after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and ending on or before "},{"tag":"date","attrib":{"date":"2021-09-06"},"text":"September 6, 2021","children":[],"tail":", subparagraphs (A)(ii) and (B)(ii) of section 2(a)(1) of the Railroad Unemployment Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s352/a/1"},"text":"45 U.S.C. 352(a)(1)","children":[],"tail":") shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9030/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating instructions and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Railroad Retirement Board may prescribe any operating instructions or regulations necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9030/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any funds in the Treasury not otherwise appropriated, there are appropriated $50,000,000 to cover the costs of additional benefits payable due to the application of subsection (a). Upon the exhaustion of the funds appropriated under this subsection, subsection (a) shall no longer apply with respect to any registration period beginning after the date of exhaustion of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3c3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9030/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of registration period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “registration period” has the meaning given such term under section 1 of the Railroad Unemployment Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s351"},"text":"45 U.S.C. 351","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9d3c40-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2112"},"text":"Pub. L. 116–136, div. A, title II, § 2112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/333"},"text":"134 Stat. 333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tII/s234/a"},"text":"Pub. L. 116–260, div. N, title II, § 234(a)","children":[],"tail":", "},{"tag":"date","attrib"