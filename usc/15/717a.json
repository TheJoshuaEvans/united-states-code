{"tag":"section","attrib":{"id":"id793c4cdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a"},"text":null,"children":[{"tag":"num","attrib":{"value":"717a"},"text":"§ 717a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter, unless the context otherwise requires—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id793c4cdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” includes an individual or a corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4cde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Corporation” includes any corporation, joint-stock company, partnership, association, business trust, organized group of persons, whether incorporated or not, receiver or receivers, trustee or trustees of any of the foregoing, but shall not include municipalities as hereinafter defined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4cdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Municipality” means a city, county, or other political subdivision or agency of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State admitted to the Union, the District of Columbia, and any organized Territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Natural gas” means either natural gas unmixed, or any mixture of natural and artificial gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Natural-gas company” means a person engaged in the transportation of natural gas in interstate commerce, or the sale in interstate commerce of such gas for resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Interstate commerce” means commerce between any point in a State and any point outside thereof, or between points within the same State but through any place outside thereof, but only insofar as such commerce takes place within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State commission” means the regulatory body of the State or municipality having jurisdiction to regulate rates and charges for the sale of natural gas to consumers within the State or municipality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” and “Commissioner” means the Federal Power Commission, and a member thereof, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Vehicular natural gas” means natural gas that is ultimately used as a fuel in a self-propelled vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id793c4ce7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “LNG terminal” includes all natural gas facilities located onshore or in State waters that are used to receive, unload, load, store, transport, gasify, liquefy, or process natural gas that is imported to the United States from a foreign country, exported to a foreign country from the United States, or transported in interstate commerce by waterborne vessel, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id793c4ce8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waterborne vessels used to deliver natural gas to or from any such facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id793c4ce9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pipeline or storage facility subject to the jurisdiction of the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s717f"},"text":"section 717f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id793c4cea-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556/s2"},"text":"June 21, 1938, ch. 556, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/821"},"text":"52 Stat. 821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIV/s404/a/2"},"text":"Pub. L. 102–486, title IV, § 404(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2879"},"text":"106 Stat. 2879","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s311/b"},"text":"Pub. L. 109–58, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/685"},"text":"119 Stat. 685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793c4ceb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id793c4cec-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793c4ced-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":" added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" added par. (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793c4cee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793c4cef-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Federal Power Commission; Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Power Commission was terminated, and its functions, personnel, property, funds, etc., were transferred to the Secretary of Energy (except for certain functions which were transferred to the Federal Energy Regulatory Commission) by sections 7151(b), 7171(a), 7172(a)(1), 7291, and 7293 of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
