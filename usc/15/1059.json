{"tag":"section","attrib":{"id":"id7958d588-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1059"},"text":null,"children":[{"tag":"num","attrib":{"value":"1059"},"text":"§ 1059.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal of registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7958d589-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1059/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of renewal; time for renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1058"},"text":"section 1058 of this title","children":[],"tail":", each registration may be renewed for periods of 10 years at the end of each successive 10-year period following the date of registration upon payment of the prescribed fee and the filing of a written application, in such form as may be prescribed by the Director. Such application may be made at any time within 1 year before the end of each successive 10-year period for which the registration was issued or renewed, or it may be made within a grace period of 6 months after the end of each successive 10-year period, upon payment of a fee and surcharge prescribed therefor. If any application filed under this section is deficient, the deficiency may be corrected within the time prescribed after notification of the deficiency, upon payment of a surcharge prescribed therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7958d58a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1059/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of refusal of renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director refuses to renew the registration, the Director shall notify the registrant of the Commissioner’s ","children":[{"tag":"ref","attrib":{"idref":"fn002298"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002298"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Director’s”."}],"tail":" refusal and the reasons therefor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7958d58b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1059/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of resident for service of process and notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the registrant is not domiciled in the United States the registrant may designate, by a document filed in the United States Patent and Trademark Office, the name and address of a person resident in the United States on whom may be served notices or process in proceedings affecting the mark. Such notices or process may be served upon the person so designated by leaving with that person or mailing to that person a copy thereof at the address specified in the last designation so filed. If the person so designated cannot be found at the address given in the last designation, or if the registrant does not designate by a document filed in the United States Patent and Trademark Office the name and address of a person resident in the United States on whom may be served notices or process in proceedings affecting the mark, such notices or process may be served on the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7958d58c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title I, § 9, "},{"tag":"ref","attrib":{"href":"/us/stat/60/431"},"text":"60 Stat. 431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/772/s5"},"text":"Pub. L. 87–772, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/770"},"text":"76 Stat. 770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/tI/s111"},"text":"Pub. L. 100–667, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3939"},"text":"102 Stat. 3939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/tI/s106"},"text":"Pub. L. 105–330, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3067"},"text":"112 Stat. 3067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(1)(B), (C)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–583; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13207/b/4"},"text":"Pub. L. 107–273, div. C, title III, § 13207(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1907"},"text":"116 Stat. 1907","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7958d58d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7958d58e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7958d58f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-20/ch592/s12"},"text":"Act Feb. 20, 1905, ch. 592, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/727"},"text":"33 Stat. 727","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7958d590-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, text read as follows: “If the registrant is not domiciled in the United States, the registrant shall designate by a written document filed in the Patent and Trademark Office the name and address of some person resident in the United States on whom may be served notices or process in proceedings affecting the mark. Such notices or process may be served upon the person so designated by leaving with that person or mailing to that person a copy thereof at the address specified in the last designation so filed. If the person so designated cannot be found at the address given in the last designation, such notice or process may be served upon the Director.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(b)(1)(B), (C)]","children":[],"tail":", amended subsec. (b) identically, substituting “Director” for “Commissioner” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text consisted of subsecs. (a) to (c) relating to period of renewal and time for renewal, notification of refusal of renewal, and applicants for renewal not domiciled in the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667/s111/1"},"text":"Pub. L. 100–667, § 111(1)","children":[],"tail":", substituted “ten” for “twenty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667/s111/2"},"text":"Pub. L. 100–667, § 111(2)","children":[],"tail":", substituted “1051(e)” for “1051(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/772"},"text":"Pub. L. 87–772","children":[],"tail":" designated existing provisions as subsecs. (a) and (c), added subsec. (b), and among other changes, amended subsec. (a) by substituting provisions requiring a verified application specifying the goods or services recited in the registration on or in connection with which the mark is still in use in commerce and having attached a specimen showing current use of the mark, or showing that any nonuse is due to special circumstances which excuse the nonuse and that it’s not due to an intention to abandon the mark, for provisions requiring an affidavit by the registrant stating that the mark is still in use in commerce."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7958d591-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d592-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" effective 4 months after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", see section 1000(a)(9) [title IV, § 4731] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d593-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" effective on the date that is 1 year after "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/s110"},"text":"section 110 of Pub. L. 105–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions relating to applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" to applications for registration of trademarks, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/s109/b"},"text":"section 109(b) of Pub. L. 105–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330/tI/s109/d"},"text":"Pub. L. 105–330, title I, § 109(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3069"},"text":"112 Stat. 3069","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/330/tI/s109/d"},"text":"“The amendment made by section 106 [amending this section] shall apply to the filing of an application for renewal of a registration if the expiration date of the registration for which the renewal application is filed is on or after the effective date of this Act [probably should be “this title”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330/s110"},"text":"section 110 of Pub. L. 105–330","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d594-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667"},"text":"Pub. L. 100–667","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/s136"},"text":"section 136 of Pub. L. 100–667","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7958d595-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal and Effect on Existing Rights","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Repeal of inconsistent provisions, effect of this chapter on pending proceedings and existing registrations and rights under prior acts, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7958d596-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Renewal Under Prior Acts","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Renewal of registrations under prior acts, see section 46(b) of act ","children":[{"tag":"date","attrib":{"date":"1946-07-05"},"text":"July 5, 1946","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7958d597-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Time for Renewal by Foreign Registrant","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-17/ch587"},"text":"Act July 17, 1946, ch. 587","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/568"},"text":"60 Stat. 568","children":[],"tail":", provided for extension of time for renewal by a foreign registrant and expired by its own terms "},{"tag":"date","attrib":{"date":"1949-07-17"},"text":"July 17, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
