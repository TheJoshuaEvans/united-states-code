{"tag":"section","attrib":{"id":"id7a7bd1ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603"},"text":null,"children":[{"tag":"num","attrib":{"value":"7603"},"text":"§ 7603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescriber verification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7bd1ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescription requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A seller may sell contact lenses only in accordance with a contact lens prescription for the patient that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd1ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presented to the seller by the patient or prescriber directly or by facsimile; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verified by direct communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A seller shall maintain a record of all direct communications referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When seeking verification of a contact lens prescription, a seller shall provide the prescriber with the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd1b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patient’s full name and address.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contact lens power, manufacturer, base curve or appropriate designation, and diameter when appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quantity of lenses ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Date of patient request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Date and time of verification request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Name of contact person at seller’s company, including facsimile and telephone number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification events","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A prescription is verified under this chapter only if one of the following occurs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7bd1b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prescriber confirms the prescription is accurate by direct communication with the seller.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prescriber informs the seller that the prescription is inaccurate and provides the accurate prescription.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7bd1bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prescriber fails to communicate with the seller within 8 business hours, or a similar time as defined by the Federal Trade Commission, after receiving from the seller the information described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invalid prescription","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a prescriber informs a seller before the deadline under subsection (d)(3) that the contact lens prescription is inaccurate, expired, or otherwise invalid, the seller shall not fill the prescription. The prescriber shall specify the basis for the inaccuracy or invalidity of the prescription. If the prescription communicated by the seller to the prescriber is inaccurate, the prescriber shall correct it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No alteration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A seller may not alter a contact lens prescription. Notwithstanding the preceding sentence, if the same contact lens is manufactured by the same company and sold under multiple labels to individual providers, the seller may fill the prescription with a contact lens manufactured by that company under another label.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7bd1be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7603/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “direct communication” includes communication by telephone, facsimile, or electronic mail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7bd1bf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s4"},"text":"Pub. L. 108–164, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2024"},"text":"117 Stat. 2024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd1c0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a7bd1c1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a7bd1c2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/164/s12"},"text":"section 12 of Pub. L. 108–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7601"},"text":"section 7601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
