{"tag":"section","attrib":{"id":"id7a12d720-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053"},"text":null,"children":[{"tag":"num","attrib":{"value":"3053"},"text":"§ 3053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Trade Commission oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a12d721-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Authority shall submit to the Commission, in accordance with such rules as the Commission may prescribe under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", any proposed rule, or proposed modification to a rule, of the Authority relating to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d722-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bylaws of the Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d723-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of permitted and prohibited medications, substances, and methods, including allowable limits of permitted medications, substances, and methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d724-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laboratory standards for accreditation and protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d725-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for racing surface quality maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d726-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" racetrack safety standards and protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d727-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program for injury and fatality data analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d728-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program of research and education on safety, performance, and anti-doping and medication control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d729-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of safety, performance, and anti-doping and medication control rule violations applicable to covered horses and covered persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d72a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a schedule of civil sanctions for violations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d72b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process or procedures for disciplinary hearings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d72c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a formula or methodology for determining assessments described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3052/f"},"text":"section 3052(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d72d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication and comment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d72e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d72f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in the Federal Register each proposed rule or modification submitted under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d730-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d731-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A proposed rule, or a proposed modification to a rule, of the Authority shall not take effect unless the proposed rule or modification has been approved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d732-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decision on proposed rule or modification to a rule","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d733-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which a proposed rule or modification is published in the Federal Register, the Commission shall approve or disapprove the proposed rule or modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d734-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall approve a proposed rule or modification if the Commission finds that the proposed rule or modification is consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d735-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d736-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable rules approved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d737-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of proposed rule or modification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d738-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of disapproval of a proposed rule or modification under this subsection, not later than 30 days after the issuance of the disapproval, the Commission shall make recommendations to the Authority to modify the proposed rule or modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d739-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resubmission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may resubmit for approval by the Commission a proposed rule or modification that incorporates the modifications recommended under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d73a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed standards and procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d73b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall submit to the Commission any proposed rule, standard, or procedure developed by the Authority to carry out the horseracing anti-doping and medication control program or the racetrack safety program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d73c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall publish in the Federal Register any such proposed rule, standard, or procedure and provide an opportunity for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d73d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3053/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment by Commission of rules of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission, by rule in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", may abrogate, add to, and modify the rules of the Authority promulgated in accordance with this chapter as the Commission finds necessary or appropriate to ensure the fair administration of the Authority, to conform the rules of the Authority to requirements of this chapter and applicable rules approved by the Commission, or otherwise in furtherance of the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a12d73e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1204"},"text":"Pub. L. 116–260, div. FF, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3257"},"text":"134 Stat. 3257","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tVII/s701"},"text":"Pub. L. 117–328, div. O, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5231"},"text":"136 Stat. 5231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a12d73f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a12d740-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a12d741-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (c)(2)(A) and (e), was in the original “this Act” and was translated as reading “this title”, meaning title XII of div. FF of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a12d742-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, text read as follows: “The Commission may adopt an interim final rule, to take effect immediately, under conditions specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553/b/B"},"text":"section 553(b)(B) of title 5","children":[],"tail":", if the Commission finds that such a rule is necessary to protect—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the health and safety of covered horses; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the integrity of covered horseraces and wagering on those horseraces.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
