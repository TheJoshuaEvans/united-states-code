{"tag":"section","attrib":{"id":"id77cf7628-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b"},"text":null,"children":[{"tag":"num","attrib":{"value":"57b–2b"},"text":"§ 57b–2b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection for voluntary provision of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77cf7629-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cf762a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No liability for providing certain material","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity described in paragraphs (2) or (3) of subsection (d) that voluntarily provides material to the Commission that such entity reasonably believes is relevant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77cf762b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a possible unfair or deceptive act or practice, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/a"},"text":"section 45(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cf762c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assets subject to recovery by the Commission, including assets located in foreign jurisdictions;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be liable to any person under any law or regulation of the United States, or under the constitution, or any law or regulation, of any State, political subdivision of a State, territory of the United States, or the District of Columbia, for such provision of material or for any failure to provide notice of such provision of material or of intention to so provide material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cf762d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed to exempt any such entity from liability—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77cf762e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the underlying conduct reported; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cf762f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any Federal agency for providing such material or for any failure to comply with any obligation the entity may have to notify a Federal agency prior to providing such material to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cf7630-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain financial institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity described in paragraph (1) of subsection (d) shall, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318/g/3"},"text":"section 5318(g)(3) of title 31","children":[],"tail":", be exempt from liability for making a voluntary disclosure to the Commission of any possible violation of law or regulation, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cf7631-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a disclosure regarding assets, including assets located in foreign jurisdictions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77cf7632-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to possibly fraudulent or deceptive commercial practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cf7633-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related to persons involved in such practices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cf7634-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise subject to recovery by the Commission; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cf7635-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disclosure regarding suspicious chargeback rates related to possibly fraudulent or deceptive commercial practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cf7636-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer complaints","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any entity described in subsection (d) that voluntarily provides consumer complaints sent to it, or information contained therein, to the Commission shall not be liable to any person under any law or regulation of the United States, or under the constitution, or any law or regulation, of any State, political subdivision of a State, territory of the United States, or the District of Columbia, for such provision of material or for any failure to provide notice of such provision of material or of intention to so provide material. This subsection shall not provide any exemption from liability for the underlying conduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cf7637-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to the following entities, whether foreign or domestic:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cf7638-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A financial institution as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312"},"text":"section 5312 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cf7639-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent not included in paragraph (1), a bank or thrift institution, a commercial bank or trust company, an investment company, a credit card issuer, an operator of a credit card system, and an issuer, redeemer, or cashier of travelers’ checks, money orders, or similar instruments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cf763a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A courier service, a commercial mail receiving agency, an industry membership organization, a payment system provider, a consumer reporting agency, a domain name registrar or registry acting as such, and a provider of alternative dispute resolution services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cf763b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–2b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Internet service provider or provider of telephone services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77cf763c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s21B"},"text":"Sept. 26, 1914, ch. 311, § 21B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s8"},"text":"Pub. L. 109–455, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3380"},"text":"120 Stat. 3380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cf763d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id77cf763e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"section 13 of Pub. L. 109–455","children":[],"tail":", see Effective Date of Repeal note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77cf763f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id77cf7640-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed effective ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"Sept. 30, 2027","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"section 13 of Pub. L. 109–455","children":[],"tail":", as amended, set out as a Termination Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s44"},"text":"section 44 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
