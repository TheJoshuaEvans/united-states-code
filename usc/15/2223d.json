{"tag":"section","attrib":{"id":"id79e585a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2223d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2223d"},"text":"§ 2223d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual revision of recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After the submission of the report cited in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2223c"},"text":"section 2223c of this title","children":[],"tail":", the working group established under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2223b"},"text":"section 2223b of this title","children":[],"tail":" shall meet as needed, but at least once every 12 months, to review and recommend changes and additions to the report cited in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2223c"},"text":"section 2223c of this title","children":[],"tail":", that are necessary and appropriate for operational personnel at the local level."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79e585a8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/446/s5"},"text":"Pub. L. 101–446, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-22"},"text":"Oct. 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1046"},"text":"104 Stat. 1046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79e585a9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79e585aa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79e585ab-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Firefighters’ Safety Study Act, and not as part of the Federal Fire Prevention and Control Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
