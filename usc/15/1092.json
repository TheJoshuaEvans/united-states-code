{"tag":"section","attrib":{"id":"id795db6d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1092"},"text":null,"children":[{"tag":"num","attrib":{"value":"1092"},"text":"§ 1092.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication; not subject to opposition; cancellation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Marks for the supplemental register shall not be published for or be subject to opposition, but shall be published on registration in the Official Gazette of the Patent and Trademark Office. Whenever any person believes that such person is or will be damaged by the registration of a mark on the supplemental register—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id795db6d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1092/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the effective filing date is after the date on which such person’s mark became famous and which would be likely to cause dilution by blurring or dilution by tarnishment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1125/c"},"text":"section 1125(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id795db6d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1092/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on grounds other than dilution by blurring or dilution by tarnishment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such person may at any time, upon payment of the prescribed fee and the filing of a petition stating the ground therefor, apply to the Director to cancel such registration. The Director shall refer such application to the Trademark Trial and Appeal Board which shall give notice thereof to the registrant. If it is found after a hearing before the Board that the registrant is not entitled to registration, or that the mark has been abandoned, the registration shall be canceled by the Director, unless the Director reconsiders the decision of the Board, and modifies or sets aside, such decision. However, no final judgment shall be entered in favor of an applicant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051/b"},"text":"section 1051(b) of this title","children":[],"tail":" before the mark is registered, if such applicant cannot prevail without establishing constructive use pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1057/c"},"text":"section 1057(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795db6d3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title II, § 24, "},{"tag":"ref","attrib":{"href":"/us/stat/60/436"},"text":"60 Stat. 436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/609/s1/d"},"text":"Pub. L. 85–609, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/540"},"text":"72 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/772/s14"},"text":"Pub. L. 87–772, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/773"},"text":"76 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/tI/s122"},"text":"Pub. L. 100–667, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3943"},"text":"102 Stat. 3943","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/43/s2/d"},"text":"Pub. L. 106–43, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-05"},"text":"Aug. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/218"},"text":"113 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–583; "},{"tag":"ref","attrib":{"href":"/us/pl/109/312/s3/d"},"text":"Pub. L. 109–312, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1732"},"text":"120 Stat. 1732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dQ/tII/s228/a/3"},"text":"Pub. L. 116–260, div. Q, title II, § 228(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2210"},"text":"134 Stat. 2210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795db6d4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795db6d5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id795db6d6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1920-03-19/ch104/s2"},"text":"Act Mar. 19, 1920, ch. 104, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/534"},"text":"41 Stat. 534","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795db6d7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" inserted “, unless the Director reconsiders the decision of the Board, and modifies or sets aside, such decision” after “shall be canceled by the Director” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/312"},"text":"Pub. L. 109–312","children":[],"tail":" amended second sentence generally. Prior to amendment, second sentence read as follows: “Whenever any person believes that he is or will be damaged by the registration of a mark on this register, including as a result of dilution under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1125/c"},"text":"section 1125(c) of this title","children":[],"tail":", he may at any time, upon payment of the prescribed fee and the filing of a petition stating the ground therefor, apply to the Director to cancel such registration.” The words following “tarnishment,” in second sentence are shown as a flush provision notwithstanding directory language showing them as part of cl. (2), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “Director” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/43"},"text":"Pub. L. 106–43","children":[],"tail":" inserted “, including as a result of dilution under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1125/c"},"text":"section 1125(c) of this title","children":[],"tail":",” after “register” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667"},"text":"Pub. L. 100–667","children":[],"tail":" struck out “verified” after “filing of a”, substituted “is not entitled to registration,” for “was not entitled to register the mark at the time of his application for registration thereof,” struck out “is not used by the registrant or” after “that the mark”, and inserted provision that no final judgment be entered before mark is registered if applicant cannot prevail without establishing constructive use."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/772"},"text":"Pub. L. 87–772","children":[],"tail":" provided for payment of the prescribed fee and the filing of a verified petition."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/609"},"text":"Pub. L. 85–609","children":[],"tail":" substituted provisions requiring the Commissioner to refer applications to the Trademark Trial and Appeal Board for provisions which required referral to the examiner in charge of interferences."}],"tail":"\n"}],"