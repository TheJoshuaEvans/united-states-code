{"tag":"section","attrib":{"id":"id7a1ebd05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3609"},"text":null,"children":[{"tag":"num","attrib":{"value":"3609"},"text":"§ 3609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Void lease or contract provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any provision in any lease or contract requiring unit owners or the owners’ association, in any conversion project involving a contract meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3607"},"text":"section 3607 of this title","children":[],"tail":" of in any project involving a lease meeting the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3608"},"text":"section 3608 of this title","children":[],"tail":", to reimburse, regardless of outcome, the developer, his successor, or affiliate of the developer for attorneys’ fees or money judgments, in a suit between unit owners or the owners’ association and the developer arising under the lease or agreement, is against public policy and void."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a1ebd06-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s610"},"text":"Pub. L. 96–399, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1678"},"text":"94 Stat. 1678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1ebd07-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1ebd08-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a1ebd09-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", except that prohibition included in this section as it relates to a lease with respect to which a cause of action may be established under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3608"},"text":"section 3608 of this title","children":[],"tail":", shall be effective one year after "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/s618"},"text":"section 618 of Pub. L. 96–399","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
