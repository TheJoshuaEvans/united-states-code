{"tag":"section","attrib":{"id":"id79c68b77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1844"},"text":null,"children":[{"tag":"num","attrib":{"value":"1844"},"text":"§ 1844.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security for loan guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In negotiating a loan guarantee under this chapter, the Board shall make every effort to arrange that the payment of the principal of and interest on any plan guaranteed shall be secured by sufficient property of the enterprise to collateralize fully the amount of the loan guarantee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c68b78-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/70/s5"},"text":"Pub. L. 92–70, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-09"},"text":"Aug. 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/179"},"text":"85 Stat. 179","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
