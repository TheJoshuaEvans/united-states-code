{"tag":"section","attrib":{"id":"id7a55abff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6209"},"text":null,"children":[{"tag":"num","attrib":{"value":"6209"},"text":"§ 6209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of existing authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a55ac00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by this chapter is in addition to, and not in lieu of, any other authority vested in the Attorney General, the Commission, or any other officer of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a55ac01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General and Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall not be construed to modify or affect the allocation of responsibility between the Attorney General and the Commission for the enforcement of the Federal antitrust laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a55ac02-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/438/s10"},"text":"Pub. L. 103–438, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4602"},"text":"108 Stat. 4602","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
