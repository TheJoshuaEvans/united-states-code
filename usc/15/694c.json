{"tag":"section","attrib":{"id":"id792df4bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s694c"},"text":null,"children":[{"tag":"num","attrib":{"value":"694c"},"text":"§ 694c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving fund for surety bond guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792df4be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s694c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is created within the Treasury a separate fund for guarantees which shall be available to the Administrator without fiscal year limitation as a revolving fund for the purposes of this part. All amounts received by the Administrator, including any moneys, property, or assets derived by him from his operations in connection with this part, shall be deposited in the fund. All expenses and payments, excluding administrative expenses, pursuant to operations of the Administrator under this part shall be paid from the fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792df4bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s694c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such sums as may be appropriated to the Fund to carry out the programs authorized by this part shall be without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792df4c0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIV/s412"},"text":"Pub. L. 85–699, title IV, § 412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/386/s6/a/4"},"text":"Pub. L. 93–386, § 6(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-23"},"text":"Aug. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/747"},"text":"88 Stat. 747","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/305/tI/s113"},"text":"Pub. L. 94–305, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/667"},"text":"90 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/14/s4"},"text":"Pub. L. 95–14, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-03-24"},"text":"Mar. 24, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/25"},"text":"91 Stat. 25","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/89/tI/s105"},"text":"Pub. L. 95–89, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/556"},"text":"91 Stat. 556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/302/tI/s111"},"text":"Pub. L. 96–302, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-02"},"text":"July 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/837"},"text":"94 Stat. 837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/590/tII/s208"},"text":"Pub. L. 100–590, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3009"},"text":"102 Stat. 3009","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792df4c1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792df4c2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children"