4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793520d6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" substituted “$30,000,000,000” for “$25,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/279"},"text":"Pub. L. 95–279","children":[],"tail":" substituted “$25,000,000,000” for “$14,500,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", substituted “$14,500,000,000” for “$12,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-11"},"text":"Aug. 11, 1955","children":[],"tail":", substituted “$12,000,000,000 for “$10,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-31"},"text":"Aug. 31, 1954","children":[],"tail":", substituted “$10,000,000,000” for “$8,500,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1954-03-20"},"text":"Mar. 20, 1954","children":[],"tail":", substituted “$8,500,000,000” for “$6,750,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-06-28"},"text":"June 28, 1950","children":[],"tail":", substituted “$6,750,000,000” for “$4,750,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-10-31"},"text":"Oct. 31, 1949","children":[],"tail":", inserted proviso in next to last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1945—Act ","children":[{"tag":"date","attrib":{"date":"1945-04-12"},"text":"Apr. 12, 1945","children":[],"tail":", substituted “$4,750,000,000” for “$3,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1943—Act ","children":[{"tag":"date","attrib":{"date":"1943-07-16"},"text":"July 16, 1943","children":[],"tail":", substituted “$3,000,000,000” for “$2,650,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Act ","children":[{"tag":"date","attrib":{"date":"1941-07-01"},"text":"July 1, 1941","children":[],"tail":", substituted “$2,650,000,000” for “$1,400,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1940—Act ","children":[{"tag":"date","attrib":{"date":"1940-08-09"},"text":"Aug. 9, 1940","children":[],"tail":", substituted “$1,400,000,000 for “$900,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1939—Act ","children":[{"tag":"date","attrib":{"date":"1939-03-04"},"text":"Mar. 4, 1939","children":[],"tail":", substituted $900,000,000” for “$500,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793520d7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id793520d8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/279/tIII/s301/d"},"text":"Pub. L. 95–279, title III, § 301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-05-15"},"text":"May 15, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/242"},"text":"92 Stat. 242","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/279/tIII/s301/d"},"text":"“The provisions of this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b"},"text":"section 714b of this title","children":[],"tail":" and enacting provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b"},"text":"section 714b of this title","children":[],"tail":"] shall become effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793520d9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Discharge of Indebtedness","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1947-05-26/ch82/tI/s101"},"text":"Act May 26, 1947, ch. 82, title I, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/109"},"text":"61 Stat. 109","children":[],"tail":", provided in part that on the date of enactment of that Act ["},{"tag":"date","attrib":{"date":"1947-05-26"},"text":"May 26, 1947","children":[],"tail":"] the Secretary of the Treasury was authorized and directed to discharge $641,832,080.64 of the indebtedness of the Commodity Credit Corporation to the Secretary of the Treasury by canceling notes in such amount issued by the Corporation to the Secretary of the Treasury pursuant to "},{"tag":"ref","attrib":{"href":"/us/act/1938-03-08/s4"},"text":"section 4 of the Act of March 8, 1938","children":[],"tail":", as amended [this section]."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id793520da-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id793520db-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exceptions From Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For exception of functions of corporations of Department of Agriculture from transfer of functions to Secretary of Agriculture by Reorg. Plan No. 2 of 1953, see Exceptions From Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s712a"},"text":"section 712a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
