{"tag":"section","attrib":{"id":"id794833f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720i"},"text":null,"children":[{"tag":"num","attrib":{"value":"720i"},"text":"§ 720i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress concerning use of steel manufactured in North America and negotiation of a project labor agreement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794833f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Alaska natural gas transportation project would provide significant economic benefits to the United States and Canada; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to maximize those benefits, the sponsors of the Alaska natural gas transportation project should make every effort to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id794833f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use steel that is manufactured in North America; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794833f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiate a project labor agreement to expedite construction of the pipeline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794833f5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/dC/s111"},"text":"Pub. L. 108–324, div. C, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-13"},"text":"Oct. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1263"},"text":"118 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
