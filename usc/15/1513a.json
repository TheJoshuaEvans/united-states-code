{"tag":"section","attrib":{"id":"id79816b8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1513a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1513a"},"text":"§ 1513a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost estimates for National Oceanic and Atmospheric Administration programs included in Department budget justification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 2007 and for each fiscal year thereafter, the Secretary of Commerce shall include in the budget justification materials that the Secretary submits to Congress in support of the Department of Commerce budget (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":") an estimate for each National Oceanic and Atmospheric Administration procurement, acquisition and construction program having a total multiyear program cost of more than $5,000,000 and an estimate of the budgetary requirements for each such program for each of the five subsequent fiscal years."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79816b8e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/108/tII"},"text":"Pub. L. 109–108, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-22"},"text":"Nov. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2312"},"text":"119 Stat. 2312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79816b8f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79816b90-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79816b91-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Department of Commerce and Related Agencies Appropriations Act, 2006, which is title II of the Science, State, Justice, Commerce, and Related Agencies Appropriations Act, 2006.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79816b92-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id79816b93-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/74/dA/tI"},"text":"Pub. L. 119–74, div. A, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-01-23"},"text":"Jan. 23, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/12"},"text":"140 Stat. 12","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/42/dC/tI"},"text":"Pub. L. 118–42, div. C, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"Mar. 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/128"},"text":"138 Stat. 128","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","a