{"tag":"section","attrib":{"id":"id79731451-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278"},"text":null,"children":[{"tag":"num","attrib":{"value":"1278"},"text":"§ 1278.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for labeling certain toys and games","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79731452-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Toys or games for children who are at least 3","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79731453-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The packaging of any toy or game intended for use by children who are at least 3 years old but not older than 6 years (or such other upper age limit as the Commission may determine, which may not be less than 5 years old), any descriptive material which accompanies such toy or game, and, in the case of bulk sales of such toy or game when unpackaged, any bin, container for retail display, or vending machine from which the unpackaged toy or game is dispensed shall bear or contain the cautionary statement described in paragraph (2) if the toy or game—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79731454-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is manufactured for sale, offered for sale, or distributed in commerce in the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79731455-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a small part, as defined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79731456-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Label","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cautionary statement required by paragraph (1) for a toy or game shall be as follows:","children":[],"tail":"\n"},{"tag":"img","attrib":{"src":"file:///t151278a.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79731457-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balloons, small balls, and marbles","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79731458-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any latex balloon, any ball with a diameter of 1.75 inches or less intended for children 3 years of age or older, any marble intended for children 3 years of age or older, or any toy or game which contains such a balloon, ball, or marble, which is manufactured for sale, offered for sale, or distributed in commerce in the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79731459-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the packaging of such balloon, ball, marble, toy, or game,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7973145a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any descriptive material which accompanies such balloon, ball, marble, toy, or game, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7973145b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of bulk sales of any such product when unpackaged, any bin, container for retail display, or vending machine from which such unpackaged balloon, ball, marble, toy, or game is dispensed,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall bear or contain the cautionary statement described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7973145c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Label","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cautionary statement required under paragraph (1) for a balloon, ball, marble, toy, or game shall be as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7973145d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balloons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of balloons, or toys or games that contain latex balloons, the following cautionary statement applies:","children":[],"tail":"\n"},{"tag":"img","attrib":{"src":"file:///t151278b.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7973145e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of balls, the following cautionary statement applies:","children":[],"tail":"\n"},{"tag":"img","attrib":{"src":"file:///t151278c.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7973145f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marbles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of marbles, the following cautionary statement applies:","children":[],"tail":"\n"},{"tag":"img","attrib":{"src":"file:///t151278d.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79731460-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Toys and games","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of toys or games containing balls, the following cautionary statement applies:","children":[],"tail":"\n"},{"tag":"img","attrib":{"src":"file:///t151278e.eps"},"text":null,"children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the case of toys or games containing marbles, the following cautionary statement applies:","children":[],"tail":"\n"},{"tag":"img","attrib":{"src":"file:///t151278f.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79731461-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79731462-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79731463-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cautionary statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any advertisement by a retailer, manufacturer, importer, distributor, or private labeler (including advertisements on Internet websites or in catalogues or other printed materials) that provides a direct means for the purchase or order of a product for which a cautionary statement is required under subsection (a) or (b) shall include the appropriate cautionary statement displayed on or immediately adjacent to that advertisement, as modified by regulations issued under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79731464-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to retailers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79731465-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to inform","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A manufacturer, importer, distributor, or private labeler that provides such a product to a retailer shall inform the retailer of any cautionary statement requirement applicable to the product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79731466-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retailer’s requirement to inquire","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A retailer is not in violation of subparagraph (A) if the retailer requested information from the manufacturer, importer, distributor, or private labeler as to whether the cautionary statement required by subparagraph (A) applies to the product that is the subject of the advertisement and the manufacturer, importer, distributor, or private labeler provided false information or did not provide such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79731467-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Display","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cautionary statement required by subparagraph (A) shall be prominently displayed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79731468-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the primary language used in the advertisement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79731469-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conspicuous and legible type in contrast by typography, layout, or color with other material printed or displayed in such advertisement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7973146a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner consistent with part 1500 of title 16, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7973146b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7973146c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “manufacturer”, “distributor”, and “private labeler” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052"},"text":"section 2052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7973146d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “retailer” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052"},"text":"section 2052 of this title","children":[],"tail":", but does not include an individual whose selling activity is intermittent and does not constitute a trade or business."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7973146e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement in paragraph (1) shall take effect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7973146f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to advertisements on Internet websites, 120 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79731470-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to catalogues and other printed materials, 180 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79731471-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any provision of chapter 6 of title 5 or the Paperwork Reduction Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" et seq.), the Commission shall, not later than 90 days after "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", promulgate regulations to effectuate this section with respect to catalogues and other printed material. The Commission may, under such regulations, provide a grace period of no more than 180 days for catalogues and other printed material printed prior to the effective date of paragraph (1) during which time distribution of such catalogues and other printed material shall not be considered a violation of such paragraph. The Commission may promulgate regulations concerning the size and placement of the cautionary statement required by paragraph (1) of this subsection as appropriate relative to the size and placement of the advertisements in such catalogues and other printed material. The Commission shall promulgate regulations that clarify the applicability of these requirements to catalogues and other printed material distributed solely between businesses and not to individual consumers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79731472-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements in paragraph (1) shall be treated as a consumer product safety standard promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2058"},"text":"section 2058 of this title","children":[],"tail":". The publication or distribution of any advertisement that is not in compliance with paragraph (1) shall be treated as a prohibited act under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2068/a/1"},"text":"section 2068(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79731473-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General labeling requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79731474-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraphs (2) and (3), any cautionary statement required under subsection (a) or (b) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79731475-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" displayed in its entirety on the principal display panel of the product’s package, and on any descriptive material which accompanies the product, and, in the case of bulk sales of such product when unpackaged, on the bin, container for retail display of the product, and any vending machine from which the unpackaged product is dispensed, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79731476-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" displayed in the English language in conspicuous and legible type in contrast by typography, layout, or color with other printed matter on such package, descriptive materials, bin, container, and vending machine, and in a manner consistent with part 1500 of title 16, Code of Federal Regulations (or successor regulations thereto).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79731477-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for products manufactured outside United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a product manufactured outside the United States and directly shipped from the manufacturer to the consumer by United States mail or other delivery service, the accompanying material inside the package of the product may fail to bear the required statement if other accompanying material shipped with the product bears such statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79731478-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for certain packages","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79731479-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A cautionary statement required by subsection (a) or (b) may, in lieu of display on the principal display panel of the product’s package, be displayed on another panel of the package if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7973147a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the package has a principal display panel of 15 square inches or less and the required statement is displayed in three or more languages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7973147b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statement specified in subparagraph (B) is displayed on the principal display panel and is accompanied by an arrow or other indicator pointing toward the place on the package where the statement required by subsection (a) or (b) appears.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7973147c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7973147d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a product to which subsection (a), subsection (b)(2)(B), subsection (b)(2)(C), or subsection (b)(2)(D) applies, the statement specified by this subparagraph is as follows:","children":[{"tag":"img","attrib":{"src":"file:///t151278g.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7973147e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a product to which subsection (b)(2)(A) applies, the statement specified by this subparagraph is as follows:","children":[{"tag":"img","attrib":{"src":"file:///t151278h.eps"},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7973147f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1278/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as misbranded hazardous substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A balloon, ball, marble, toy, or game, that is not in compliance with the requirements of this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002317"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002317"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “this section”."}],"tail":" shall be considered a misbranded hazardous substance under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261/p"},"text":"section 1261(p) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79731480-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s24"},"text":"Pub. L. 86–613, § 24","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/267/tI/s101/a"},"text":"Pub. L. 103–267, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/722"},"text":"108 Stat. 722","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tI/s105"},"text":"Pub. L. 110–314, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3031"},"text":"122 Stat. 3031","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79731481-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79731482-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79731483-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Paperwork Reduction Act of 1980, referred to in subsec. (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511"},"text":"Pub. L. 96–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2812"},"text":"94 Stat. 2812","children":[],"tail":", which was classified principally to chapter 35 (§ 3501 et seq.) of Title 44, Public Printing and Documents, prior to the general amendment of that chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/163"},"text":"109 Stat. 163","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1980 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s101"},"text":"section 101 of Title 44","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79731484-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79731485-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79731486-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/267/tI/s101/d"},"text":"Pub. L. 103–267, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/725"},"text":"108 Stat. 725","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/267/tI/s101/d"},"text":"“Subsections (a) and (b) [enacting this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261"},"text":"section 1261 of this title","children":[],"tail":"] shall take effect "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", and section 24 of the Federal Hazardous Substances Act [this section] shall apply only to products entered into commerce on or after "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79731487-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/267/tI/s101/c"},"text":"Pub. L. 103–267, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/725"},"text":"108 Stat. 725","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/267/tI/s101/c"},"text":"“The Consumer Product Safety Commission (hereinafter referred to as the ‘Commission’) shall promulgate regulations, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code, for the implementation of this section [enacting this section and provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261"},"text":"section 1261 of this title","children":[],"tail":"] and section 24 of the Federal Hazardous Substances Act [this section] by "},{"tag":"date","attrib":{"date":"1994-07-01"},"text":"July 1, 1994","children":[],"tail":", or the date that is 6 months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":"], whichever occurs first. Subsections (f) through (i) of section 3 of the Federal Hazardous Substances Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1262"},"text":"15 U.S.C. 1262","children":[],"tail":") shall not apply with respect to the issuance of regulations under this subsection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79731488-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preemption","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/267/tI/s101/e"},"text":"Pub. L. 103–267, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/725"},"text":"108 Stat. 725","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/267/tI/s101/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), a State or political subdivision of a State may not establish or enforce a requirement relating to cautionary labeling of small parts hazards or choking hazards in any toy, game, marble, small ball, or balloon intended or suitable for use by children unless such requirement is identical to a requirement established by amendments made by this section to the Federal Hazardous Substances Act [enacting this section] or by regulations promulgated by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State or political subdivision of a State may, until ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", enforce a requirement described in paragraph (1) if such requirement was in effect on "},{"tag":"date","attrib":{"date":"1993-10-02"},"text":"October 2, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
