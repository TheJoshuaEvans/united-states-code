{"tag":"section","attrib":{"id":"id7a664e85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827"},"text":null,"children":[{"tag":"num","attrib":{"value":"6827"},"text":"§ 6827.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a664e86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “customer” means, with respect to a financial institution, any person (or authorized representative of a person) to whom the financial institution provides a product or service, including that of acting as a fiduciary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664e87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer information of a financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “customer information of a financial institution” means any information maintained by or for a financial institution which is derived from the relationship between the financial institution and a customer of the financial institution and is identified with the customer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664e88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “document” means any information in any form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a664e89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a664e8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” means any institution engaged in the business of providing financial services to customers who maintain a credit, deposit, trust, or other financial account or relationship with the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664e8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain financial institutions specifically included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” includes any depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/A"},"text":"section 461(b)(1)(A) of title 12","children":[],"tail":"), any broker or dealer, any investment adviser or investment company, any insurance company, any loan or finance company, any credit card issuer or operator of a credit card system, and any consumer reporting agency that compiles and maintains files on consumers on a nationwide basis (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/p"},"text":"section 1681a(p) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664e8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a664e8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “broker” and “dealer” have the same meanings as given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a664e8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “investment adviser” has the same meaning as given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–2/a/11"},"text":"section 80b–2(a)(11) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a664e8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “investment company” has the same meaning as given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–3"},"text":"section 80a–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664e90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain persons and entities specifically excluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” does not include any person or entity with respect to any financial activity that is subject to the jurisdiction of the Commodity Futures Trading Commission under the Commodity Exchange Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.] and does not include the Federal Agricultural Mortgage Corporation or any entity chartered and operating under the Farm Credit Act of 1971 ["},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"12 U.S.C. 2001","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a664e91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6827/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further definition by regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission, after consultation with Federal banking agencies and the Securities and Exchange Commission, may prescribe regulations clarifying or describing the types of institutions which shall be treated as financial institutions for purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a664e92-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tV/s527"},"text":"Pub. L. 106–102, title V, § 527","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1449"},"text":"113 Stat. 1449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a664e93-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a664e94-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a664e95-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Commodity Exchange Act, referred to in par. (4)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/998"},"text":"42 Stat. 998","children":[],"tail":", which is classified generally to chapter 1 (§ 1 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Farm Credit Act of 1971, referred to in par. (4)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/181"},"text":"Pub. L. 92–181","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/583"},"text":"85 Stat. 583","children":[],"tail":", which is classified generally to chapter 23 (§ 2001 et seq.) of Title 12, Banks and Banking. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2001"},"text":"section 2001 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
