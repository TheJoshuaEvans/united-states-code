{"tag":"section","attrib":{"id":"id77d6a1b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69i"},"text":null,"children":[{"tag":"num","attrib":{"value":"69i"},"text":"§ 69i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d6a1b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully violates section 69a, 69d, or 69h(b) of this title shall be guilty of a misdemeanor and upon conviction shall be fined not more than $5,000, or be imprisoned not more than one year, or both, in the discretion of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d6a1b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Commission has reason to believe any person is guilty of a misdemeanor under this section, it shall certify all pertinent facts to the Attorney General, whose duty it shall be to cause appropriate proceedings to be brought for the enforcement of the provisions of this section against such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d6a1b4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-08-08/ch298/s11"},"text":"Aug. 8, 1951, ch. 298, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/181"},"text":"65 Stat. 181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d6a1b5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77d6a1b6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77d6a1b7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Federal Trade Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 8 of 1950, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1264"},"text":"64 Stat. 1264","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
