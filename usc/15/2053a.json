{"tag":"section","attrib":{"id":"id79cb4594-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2053a"},"text":"§ 2053a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee training exchanges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79cb4595-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cb4596-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain or employ officers or employees of foreign government agencies on a temporary basis pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2053"},"text":"section 2053 of this title","children":[],"tail":" or section 3101 or 3109 of title 5; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cb4597-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail officers or employees of the Commission to work on a temporary basis for appropriate foreign government agencies for the purpose of providing or receiving training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cb4598-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reciprocity and reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may execute the authority contained in subsection (a) with or without reimbursement in money or in kind, and with or without reciprocal arrangements by or on behalf of the foreign government agency involved. Any amounts received as reimbursement for expenses incurred by the Commission under this section shall be credited to the appropriations account from which such expenses were paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79cb4599-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of conduct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual retained or employed under subsection (a)(1) shall be considered to be a Federal employee while so retained or employed, only for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79cb459a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" injury compensation as provided in chapter 81 of title 5 and tort claims liability under chapter 171 of title 28;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cb459b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 131 of title 5 and the provisions of chapter 11 of title 18; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79cb459c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2053a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other statute or regulation governing the conduct of Federal employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79cb459d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s208"},"text":"Pub. L. 110–314, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3046"},"text":"122 Stat. 3046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/25"},"text":"Pub. L. 117–286, § 4(c)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4357"},"text":"136 Stat. 4357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79cb459e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79cb459f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79cb45a0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consumer Product Safety Improvement Act of 2008, and not as part of the Consumer Product Safety Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79cb45a1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of title 5” for “the Ethics in Government Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79cb45a2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id79cb45a3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Commission” used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s2/a"},"text":"section 2(a) of Pub. L. 110–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
