{"tag":"section","attrib":{"id":"id795db71a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1113"},"text":null,"children":[{"tag":"num","attrib":{"value":"1113"},"text":"§ 1113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id795db71b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications; services; materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish fees for the filing and processing of an application for the registration of a trademark or other mark and for all other services performed by and materials furnished by the Patent and Trademark Office related to trademarks and other marks. Fees established under this subsection may be adjusted by the Director once each year to reflect, in the aggregate, any fluctuations during the preceding 12 months in the Consumer Price Index, as determined by the Secretary of Labor. Changes of less than 1 percent may be ignored. No fee established under this section shall take effect until at least 30 days after notice of the fee has been published in the Federal Register and in the Official Gazette of the Patent and Trademark Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id795db71c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver; Indian products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may waive the payment of any fee for any service or material related to trademarks or other marks in connection with an occasional request made by a department or agency of the Government, or any officer thereof. The Indian Arts and Crafts Board will not be charged any fee to register Government trademarks of genuineness and quality for Indian products or for products of particular Indian tribes and groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id795db71d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title V, § 31, "},{"tag":"ref","attrib":{"href":"/us/stat/60/437"},"text":"60 Stat. 437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/609/s1/e"},"text":"Pub. L. 85–609, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/540"},"text":"72 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/83/s3"},"text":"Pub. L. 89–83, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-24"},"text":"July 24, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/260"},"text":"79 Stat. 260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/517/s5"},"text":"Pub. L. 96–517, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3018"},"text":"94 Stat. 3018","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s3/f"},"text":"Pub. L. 97–247, § 3(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/319"},"text":"96 Stat. 319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/256/tI/s103"},"text":"Pub. L. 97–256, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/816"},"text":"96 Stat. 816","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/204/s5/f/1"},"text":"Pub. L. 102–204, § 5(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-10"},"text":"Dec. 10, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1640"},"text":"105 Stat. 1640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/tII/s201/a/7"},"text":"Pub. L. 105–330, title II, § 201(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3070"},"text":"112 Stat. 3070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–583.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id795db71e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id795db71f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id795db720-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-20/ch592"},"text":"Feb. 20, 1905, ch. 592","children":[],"tail":", §§ 14, 15, "},{"tag":"ref","attrib":{"href":"/us/stat/33/728"},"text":"33 Stat. 728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1920-03-19/ch104/s8"},"text":"Mar. 19, 1920, ch. 104, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/535"},"text":"41 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-04-11/ch132/s4"},"text":"Apr. 11, 1930, ch. 132, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/155"},"text":"46 Stat. 155","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id795db721-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “Director” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" made technical amendment relating to section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/204"},"text":"Pub. L. 102–204","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Commissioner will establish fees for the filing and processing of an application for the registration of a trademark or other mark and for all other services performed by and materials furnished by the Patent and Trademark Office related to trademarks and other marks. However, no fee for the filing or processing of an application for the registration of a trademark or other mark or for the renewal or assignment of a trademark or other mark will be adjusted more than once every three years. No fee established under this section will take effect prior to sixty days following notice in the Federal Register.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/256"},"text":"Pub. L. 97–256","children":[],"tail":" struck out “of Patents” after “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" struck out provisions directing that fees be set and adjusted by the Commissioner to recover in aggregate 50 per centum of the estimated average cost to the Office of processing and that fees for all other services or materials related to trademarks and other marks recover the estimated average cost to the Office of performing the service or furnishing the material."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517"},"text":"Pub. L. 96–517","children":[],"tail":" in revising fee provisions required the Commissioner to establish fees based on recovery of estimated average cost of processing applications, performing services and providing material; authorized triennial adjustments; and prescribed an effective date for fees; deleted prior provisions containing statutory schedule covering fees for filing: applications for registration and renewals, affidavits, revival petitions for abandoned applications, opposition or application for cancellation, disclaimers, and notice of benefits for a mark to be published; and fees covering: appeals from examiners in charge of registration, certificates of amendment, certifying, printed copies of registered marks, and recordation of documents and papers relating to property in a registration or application."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517"},"text":"Pub. L. 96–517","children":[],"tail":" added subsec. (b) and struck out former subsec. (b) authorizing Commissioner to establish charges for copies of records, publications, or services of Patent and Trademark Office. See subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517"},"text":"Pub. L. 96–517","children":[],"tail":" in revising fee provisions struck out subsec. (c) authorizing Commissioner to refund any mistaken or excessive payments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/83"},"text":"Pub. L. 89–83","children":[],"tail":" increased fees for filing an application for registration of a mark from $25 to $35; for issuance of a new certificate of registration following a change of ownership of a mark or correction of a registrant’s mistake from $10 to $15; for a certificate of correction of registrant’s mistake from $10 to $15; for filing a disclaimer from $10 to $15; and for recording an assignment, agreement, or other paper relating to the property in a registration or application from $3 for documents not exceeding six pages plus $1 for each additional two pages or less and 50 cents additional for each additional registration or application included in one writing, to a $20 fee for every document plus an additional fee of $3 for each additional item where the document relates to more than one application or registration; eliminated provisions which established fees for the surrender or cancellation of a registration, for an abstract of title, for a title report required for office use, for certificates that marks have not been registered, and for copies of various specified records and documents; added the fees for filing and affidavit under section 1058(a) or (b) of this title and for filing a petition for the revival of an abandoned application; empowered the Commissioner to establish charges for copies of records, publications or services furnished by the Patent Office; and made the provisions relating to refunds of sums paid by mistake permissive."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/609"},"text":"Pub. L. 85–609","children":[],"tail":" struck out “to the Commissioner” after “on appeal from an examiner in charge of the registration of marks”, and provisions which required payment of a $25 fee on appeals from an examiner in charge of interferences to the Commissioner."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79600112-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79600113-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" effective 4 months after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", see section 1000(a)(9) [title IV, § 4731] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79600114-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", and applicable only to any civil action filed or proceeding before the United States Patent and Trademark Office commenced on or after such date relating to the registration of a mark, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/s201/b"},"text":"section 201(b) of Pub. L. 105–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79600115-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s17/a"},"text":"section 17(a) of Pub. L. 97–247","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41"},"text":"section 41 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79600116-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/517"},"text":"Pub. L. 96–517","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", with provision for continuation of fees in effect as of such date until corresponding fees are established under this section, see section 8(a), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/96/517"},"text":"Pub. L. 96–517","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s41"},"text":"section 41 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79600117-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s4"},"text":"section 4 of Pub. L. 93–596","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1111"},"text":"section 1111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79600118-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading",