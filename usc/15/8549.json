{"tag":"section","attrib":{"id":"id7a8a29ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8549"},"text":null,"children":[{"tag":"num","attrib":{"value":"8549"},"text":"§ 8549.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hurricane hunter aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8a29cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8549/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Backup capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall acquire backup for the capabilities of the WP–3D Orion and G–IV hurricane aircraft of the National Oceanic and Atmospheric Administration that is sufficient to prevent a single point of failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a29cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8549/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out subsection (a), the Under Secretary shall negotiate and enter into 1 or more agreements or contracts, to the extent practicable and necessary, with governmental and non-governmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a29cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8549/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall continue the development of Airborne Phased Array Radar under the United States Weather Research Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a29ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8549/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2017 through 2020, support for implementing subsections (a) and (b) is authorized out of funds appropriated to the Office of Marine and Aviation Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8a29cf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tIV/s413"},"text":"Pub. L. 115–25, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/114"},"text":"131 Stat. 114","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
