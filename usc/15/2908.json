{"tag":"section","attrib":{"id":"id7a108cca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2908"},"text":null,"children":[{"tag":"num","attrib":{"value":"2908"},"text":"§ 2908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to any other funds otherwise authorized to be appropriated for the purpose of conducting climate-related programs, there are authorized to be appropriated to the Secretary, for the purpose of carrying out the provisions of this chapter, not to exceed $50,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", not to exceed $65,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", and not to exceed $25,500,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", of which amount not less than $2,653,000 shall be made directly available to the National Climate Program Office in the form of a budget item separate from the activities of the National Oceanic and Atmospheric Administration."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a108ccb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/367/s9"},"text":"Pub. L. 95–367, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-17"},"text":"Sept. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/605"},"text":"92 Stat. 605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/547/s1"},"text":"Pub. L. 96–547, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-18"},"text":"Dec. 18, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3217"},"text":"94 Stat. 3217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a108ccc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a108ccd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a108cce-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/547"},"text":"Pub. L. 96–547","children":[],"tail":" revised former subsec. (a) into entire section with additional provisions relating to fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":", and struck out subsec. (b) setting forth authorization of appropriations for grants."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
