{"tag":"section","attrib":{"id":"id79352109-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s713a–11a"},"text":null,"children":[{"tag":"num","attrib":{"value":"713a–11a"},"text":"§ 713a–11a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest prohibited when reimbursing Corporation for net realized losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1964-09-30"},"text":"September 30, 1964","children":[],"tail":", the portion of borrowings from Treasury equal to the unreimbursed realized losses recorded on the books of the Commodity Credit Corporation after September 30 of the fiscal year in which such losses are realized, shall not bear interest and interest shall not be accrued or paid thereon."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7935210a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/316/tIII/s301"},"text":"Pub. L. 89–316, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-02"},"text":"Nov. 2, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1178"},"text":"79 Stat. 1178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s2/6"},"text":"Pub. L. 94–273, § 2(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/375"},"text":"90 Stat. 375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7935210b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7935210c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail"