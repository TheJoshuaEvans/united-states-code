{"tag":"section","attrib":{"id":"id7a985a43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9010"},"text":null,"children":[{"tag":"num","attrib":{"value":"9010"},"text":"§ 9010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources and services in languages other than English","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a985a44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide the resources and services made available by the Administration to small business concerns in the 10 most commonly spoken languages, other than English, in the United States, which shall include Mandarin, Cantonese, Japanese, and Korean.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a985a45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator $25,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a985a46-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tI/s1111"},"text":"Pub. L. 116–136, div. A, title I, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/309"},"text":"134 Stat. 309","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
