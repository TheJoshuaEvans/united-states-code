{"tag":"section","attrib":{"id":"id7a64047f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764"},"text":null,"children":[{"tag":"num","attrib":{"value":"6764"},"text":"§ 6764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a640480-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “business entity” means a corporation, association, partnership, limited liability company, limited liability partnership, or other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640481-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depository institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “depository institution” has the meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640482-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “home State” means the State in which the insurance producer maintains its principal place of residence or business and is licensed to act as an insurance producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640483-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insurance” means any product, other than title insurance or bail bonds, defined or regulated as insurance by the appropriate State insurance regulatory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640484-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insurance producer” means any insurance agent or broker, excess or surplus lines broker or agent, insurance consultant, limited insurance representative, and any other individual or entity that sells, solicits, or negotiates policies of insurance or offers advice, counsel, opinions or services related to insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640485-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “insurer” has the meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s313/e/2/B"},"text":"section 313(e)(2)(B) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640486-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal place of business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “principal place of business” means the State in which an insurance producer maintains the headquarters of the insurance producer and, in the case of a business entity, where high-level officers of the entity direct, control, and coordinate the business activities of the business entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640487-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal place of residence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “principal place of residence” means the State in which an insurance producer resides for the greatest number of days during a calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640488-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes any State, the District of Columbia, any territory of the United States, and Puerto Rico, Guam, American Samoa, the Trust Territory of the Pacific Islands, the Virgin Islands, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640489-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a64048a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State law” includes all laws, decisions, rules, regulations, or other State action having the effect of law, of any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a64048b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6764/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laws applicable in the District of Columbia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A law of the United States applicable only to or within the District of Columbia shall be treated as a State law rather than a law of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a64048c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s334"},"text":"Pub. L. 106–102, title III, § 334","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/27"},"text":"129 Stat. 27","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a64048d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a64048e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a64048f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6766"},"text":"section 6766 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6764, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s334"},"text":"Pub. L. 106–102, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1433"},"text":"113 Stat. 1433","children":[],"tail":", related to coordination with other regulators, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6761"},"text":"section 6761 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6765, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s335"},"text":"Pub. L. 106–102, title III, § 335","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1433"},"text":"113 Stat. 1433","children":[],"tail":", which related to judicial review, was omitted in the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6762"},"text":"section 6762 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6766, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s336"},"text":"Pub. L. 106–102, title III, § 336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1433"},"text":"113 Stat. 1433","children":[],"tail":", which related to definitions, was omitted in the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
