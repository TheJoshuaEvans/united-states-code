{"tag":"section","attrib":{"id":"id79ef21e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2461"},"text":null,"children":[{"tag":"num","attrib":{"value":"2461"},"text":"§ 2461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit, review, and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ef21e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2461/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit, etc., by Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall audit, review, and evaluate the implementation of the provisions of this chapter by the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ef21e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2461/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than thirty months nor more than thirty-six months after ","children":[{"tag":"date","attrib":{"date":"1975-11-28"},"text":"November 28, 1975","children":[],"tail":", the Comptroller General shall prepare and submit to the Congress a report on his audit conducted pursuant to subsection (a), which shall contain, but not be limited to, the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ef21e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2461/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of the Center’s activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef21ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2461/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effect of the activities of the Center on the efficiency, and effectiveness, of affected Federal agencies in carrying out their assigned functions and duties under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef21eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2461/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations concerning any legislation he deems necessary, and the reasons therefor, for improving the implementation of the objectives of this chapter as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2402"},"text":"section 2402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ef21ec-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/136/tV/s501"},"text":"Pub. L. 94–136, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/742"},"text":"89 Stat. 742","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
