{"tag":"section","attrib":{"id":"id7a5cd85a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614"},"text":null,"children":[{"tag":"num","attrib":{"value":"6614"},"text":"§ 6614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Y2K actions as class actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5cd85b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Material defect requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Y2K action involving a claim that a product or service is defective may be maintained as a class action in Federal or State court as to that claim only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd85c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it satisfies all other prerequisites established by applicable Federal or State law, including applicable rules of civil procedure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd85d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court finds that the defect in a product or service as alleged would be a material defect for the majority of the members of the class.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd85e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any Y2K action that is maintained as a class action, the court, in addition to any other notice required by applicable Federal or State law, shall direct notice of the action to each member of the class, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd85f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a concise and clear description of the nature of the action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd860-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction where the case is pending; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd861-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fee arrangements with class counsel, including the hourly fee being charged, or, if it is a contingency fee, the percentage of the final award which will be paid, including an estimate of the total amount that would be paid if the requested damages were to be granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd862-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forum for Y2K class actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd863-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the district courts of the United States shall have original jurisdiction of any Y2K action that is brought as a class action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd864-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district courts of the United States shall not have original jurisdiction over a Y2K action brought as a class action if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5cd865-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5cd866-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantial majority of the members of the proposed plaintiff class are citizens of a single State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5cd867-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary defendants are citizens of that State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5cd868-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claims asserted will be governed primarily by the laws of that State;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd869-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary defendants are States, State officials, or other governmental entities against whom the district courts of the United States may be foreclosed from ordering relief;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd86a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plaintiff class does not seek an award of punitive damages, and the amount in controversy is less than the sum of $10,000,000 (exclusive of interest and costs), computed on the basis of all claims to be determined in the action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd86b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are less than 100 members of the proposed plaintiff class.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A party urging that any exception described in subparagraph (A), (B), (C), or (D) applies to an action shall bear the full burden of demonstrating the applicability of the exception.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd86c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure if requirements not met","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5cd86d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal or remand","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A United States district court shall dismiss, or, if after removal, strike the class allegations and remand, any Y2K action brought or removed under this subsection as a class action if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5cd86e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action is subject to the jurisdiction of the court solely under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5cd86f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court determines the action may not proceed as a class action based on a failure to satisfy the conditions of Rule 23 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd870-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment; removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (A) shall prohibit plaintiffs from filing an amended class action in Federal or State court. A defendant shall have the right to remove such an amended class action to a United States district court under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd871-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitations tolled","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon dismissal or remand, the period of limitations for any claim that was asserted in an action on behalf of any named or unnamed member of any proposed class shall be deemed tolled to the full extent provided under Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd872-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dismissal without prejudice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The dismissal of a Y2K action under subparagraph (A) shall be without prejudice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd873-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6614/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on rules of civil procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, nothing in this section supersedes any rule of Federal or State civil procedure applicable to class actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5cd874-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s15"},"text":"Pub. L. 106–37, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/201"},"text":"113 Stat. 201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a5cd875-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a5cd876-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a5cd877-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Rules of Federal civil procedure, referred to in subsecs. (a)(1), (c)(3)(A)(ii), and (d), are contained in the Federal Rules of Civil Procedure which are set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
