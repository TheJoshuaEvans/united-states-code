{"tag":"section","attrib":{"id":"id796be8f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1243"},"text":null,"children":[{"tag":"num","attrib":{"value":"1243"},"text":"§ 1243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacture, sale, or possession within specific jurisdictions; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever, within any Territory or possession of the United States, within Indian country (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"), or within the special maritime and territorial jurisdiction of the United States (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of title 18","children":[],"tail":"), manufactures, sells, or possesses any switchblade knife, shall be fined not more than $2,000 or imprisoned not more than five years, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796be8f1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623/s3"},"text":"Pub. L. 85–623, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/562"},"text":"72 Stat. 562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be8f2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796be8f3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id796be8f4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"chi