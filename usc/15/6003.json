{"tag":"section","attrib":{"id":"id7a533ac7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6003"},"text":null,"children":[{"tag":"num","attrib":{"value":"6003"},"text":"§ 6003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-05-01"},"text":"May 1, 1997","children":[],"tail":", the Administrator of the National Highway Traffic Safety Administration shall report to Congress on the effectiveness of the grant program established by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6001"},"text":"section 6001 of this title","children":[],"tail":". The report shall include a list of grant recipients, a summary of the types of programs implemented by the grantees, and any recommendation by the Administrator regarding how the program should be changed in the future."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a533ac8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/267/tII/s204"},"text":"Pub. L. 103–267, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-16"},"text":"June 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/727"},"text":"108 Stat. 727","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
