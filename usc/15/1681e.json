{"tag":"section","attrib":{"id":"id79aa0291-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681e"},"text":"§ 1681e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79aa0292-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identity and purposes of credit users","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every consumer reporting agency shall maintain reasonable procedures designed to avoid violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681c"},"text":"section 1681c of this title","children":[],"tail":" and to limit the furnishing of consumer reports to the purposes listed under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of this title","children":[],"tail":". These procedures shall require that prospective users of the information identify themselves, certify the purposes for which the information is sought, and certify that the information will be used for no other purpose. Every consumer reporting agency shall make a reasonable effort to verify the identity of a new prospective user and the uses certified by such prospective user prior to furnishing such user a consumer report. No consumer reporting agency may furnish a consumer report to any person if it has reasonable grounds for believing that the consumer report will not be used for a purpose listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa0293-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accuracy of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a consumer reporting agency prepares a consumer report it shall follow reasonable procedures to assure maximum possible accuracy of the information concerning the individual about whom the report relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa0294-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of consumer reports by users allowed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A consumer reporting agency may not prohibit a user of a consumer report furnished by the agency on a consumer from disclosing the contents of the report to the consumer, if adverse action against the consumer has been taken by the user based in whole or in part on the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa0295-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to users and furnishers of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79aa0296-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A consumer reporting agency shall provide to any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aa0297-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who regularly and in the ordinary course of business furnishes information to the agency with respect to any consumer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa0298-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom a consumer report is provided by the agency;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a notice of such person’s responsibilities under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aa0299-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall prescribe the content of notices under paragraph (1), and a consumer reporting agency shall be in compliance with this subsection if it provides a notice under paragraph (1) that is substantially similar to the Bureau prescription under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aa029a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of consumer report for resale","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79aa029b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not procure a consumer report for purposes of reselling the report (or any information in the report) unless the person discloses to the consumer reporting agency that originally furnishes the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aa029c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of the end-user of the report (or information); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa029d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each permissible purpose under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of this title","children":[],"tail":" for which the report is furnished to the end-user of the report (or information)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aa029e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of procurers for resale","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who procures a consumer report for purposes of reselling the report (or any information in the report) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aa029f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and comply with reasonable procedures designed to ensure that the report (or information) is resold by the person only for a purpose for which the report may be furnished under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of this title","children":[],"tail":", including by requiring that each person to which the report (or information) is resold and that resells or provides the report (or information) to any other person—"}],"tail":null},{"tag":"clause","attrib":{"id":"id79aa02a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each end user of the resold report (or information);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79aa02a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies each purpose for which the report (or information) will be used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79aa02a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies that the report (or information) will be used for no other purpose; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa02a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before reselling the report, make reasonable efforts to verify the identifications and certifications made under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aa02a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resale of consumer report to a Federal agency or department","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1) or (2), a person who procures a consumer report for purposes of reselling the report (or any information in the report) shall not disclose the identity of the end-user of the report under paragraph (1) or (2) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aa02a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end user is an agency or department of the United States Government which procures the report from the person for purposes of determining the eligibility of the consumer concerned to receive access or continued access to classified information (as defined in section 1681b(b)(4)(E)(i) ","children":[{"tag":"ref","attrib":{"idref":"fn002375"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002375"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aa02a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681e/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency or department certifies in writing to the person reselling the report that nondisclosure is necessary to protect classified information or the safety of persons employed by or contracting with, or undergoing investigation for work or contracting with the agency or department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79aa02a7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s607"},"text":"Pub. L. 90–321, title VI, § 607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tVI/s601"},"text":"Pub. L. 91–508, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1130"},"text":"84 Stat. 1130","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2407"},"text":"Pub. L. 104–208, div. A, title II, § 2407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-435"},"text":"110 Stat. 3009–435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/107/tIII/s311/b"},"text":"Pub. L. 105–107, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2256"},"text":"111 Stat. 2256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1088/a/2/A"},"text":"Pub. L. 111–203, title X, § 1088(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2087"},"text":"124 Stat. 2087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79aa02a8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79aa02a9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79aa02aa-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b/b/4"},"text":"Section 1681b(b)(4) of this title","children":[],"tail":", referred to in subsec. (e)(3)(A), was subsequently amended, and section 1681b(b)(4)(E) no longer defines the term “classified information”. However, such term is defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79aa02ab-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Federal Trade Commission” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/107"},"text":"Pub. L. 105–107","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79aa02ac-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79aa02ad-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79aa02ae-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/107"},"text":"Pub. L. 105–107","children":[],"tail":" effective as if included in chapter 1 of subtitle D of the Economic Growth and Regulatory Paperwork Reduction Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", as of "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/107/s311/c"},"text":"section 311(c) of Pub. L. 105–107","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79aa02af-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective 365 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", with special rule for early compliance, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2420"},"text":"section 2420 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a"},"text":"section 1681a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79aa02b0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of one hundred and eighty days following ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s504/d"},"text":"section 504(d) of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/508"},"text":"Pub. L. 91–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
