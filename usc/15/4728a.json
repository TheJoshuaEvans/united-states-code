{"tag":"section","attrib":{"id":"id7a475383-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4728a"},"text":"§ 4728a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and Federal Export Promotion Coordination Working Group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a475384-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States to promote exports as an opportunity for small businesses. In exercising their powers and functions in order to advance that policy, all Federal agencies shall work constructively with State and local agencies engaged in export promotion and export financing activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475385-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a State and Federal Export Promotion Coordination Working Group (in this section referred to as the “Working Group”) as a subcommittee of the Trade Promotion Coordination Committee (in this section referred to as the “TPCC”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475386-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Working Group are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475387-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify issues related to the coordination of Federal resources relating to export promotion and export financing with such resources provided by State and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475388-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify ways to improve coordination with respect to export promotion and export financing activities through the strategic plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4727/c"},"text":"section 4727(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475389-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a strategy for improving coordination of Federal and State resources relating to export promotion and export financing, including methods to eliminate duplication of effort and overlapping functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47538a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a strategic plan for considering and implementing the suggestions of the Working Group as part of the strategic plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4727/c"},"text":"section 4727(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47538b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce shall select the members of the Working Group, who shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a47538c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from State trade agencies representing regionally diverse areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47538d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4728a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the departments and agencies that are represented on the TPCC, who are designated by the heads of their respective departments or agencies to advise the head on ways of promoting the exportation of United States goods and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a47538e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII/s2313A"},"text":"Pub. L. 100–418, title II, § 2313A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tV/s504/a"},"text":"Pub. L. 114–125, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/177"},"text":"130 Stat. 177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a47538f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a475390-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id7a475391-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (b) of this section assigned to Secretary of Commerce, see Ex. Ord. No. 13733, § 1(a), ","children":[{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", 81 F.R. 49515, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s4421"},"text":"section 4421 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
