{"tag":"section","attrib":{"id":"id79816b2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1511c"},"text":"§ 1511c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estuarine Programs Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79816b2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the National Oceanic and Atmospheric Administration (hereinafter in this section referred to as the “Administrator”) shall establish within the Administration an Estuarine Programs Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79816b2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Estuarine Programs Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79816b2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement a national estuarine strategy for the Administration that integrates the research, regulatory, and trusteeship responsibilities of the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the estuarine activities of the various organizations within the Administration, including activities in estuarine research and assessment, fisheries research, coastal management, and habitat conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the estuarine activities of the Administration with the activities of other Federal and State agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79816b30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical assistance to the Administrator, to other Federal agencies, and to State and local government agencies in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79816b31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the condition of estuaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying estuaries of critical national or regional importance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying technical and management alternatives for the restoration and protection of estuarine resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79816b34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the implementation and effectiveness of estuarine management plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79816b35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1511c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Administration not to exceed $500,000 for fiscal year 1987, $530,000 for fiscal year 1988, $560,000 for fiscal year 1989, and $600,000 for fiscal year 1990 to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79816b36-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659/tIV/s406"},"text":"Pub. L. 99–659, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3738"},"text":"100 Stat. 3738","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
