{"tag":"section","attrib":{"id":"id7ab298d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551"},"text":null,"children":[{"tag":"num","attrib":{"value":"9551"},"text":"§ 9551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab298da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab298db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Financial Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab298de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minority-serving institution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of institutions of higher education that is led by a minority-serving institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MBDA Rural Business Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “MBDA Rural Business Center” means an MBDA Business Center that provides technical business assistance to minority business enterprises located in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MBDA Rural Business Center agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “MBDA Rural Business Center agreement” means an MBDA Business Center agreement that establishes the terms by which the recipient of the Federal assistance award that is the subject of the agreement shall operate an MBDA Rural Business Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority-serving institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minority-serving institution” means an institution described in any of paragraphs (1) through (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural area” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1991/a"},"text":"section 1991(a) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9551/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural minority business enterprise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural minority business enterprise” means a minority business enterprise located in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab298e5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tIII/s100301"},"text":"Pub. L. 117–58, div. K, title III, § 100301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1458"},"text":"135 Stat. 1458","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
