{"tag":"section","attrib":{"id":"id79a06617-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1672"},"text":null,"children":[{"tag":"num","attrib":{"value":"1672"},"text":"§ 1672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a06618-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “earnings” means compensation paid or payable for personal services, whether denominated as wages, salary, commission, bonus, or otherwise, and includes periodic payments pursuant to a pension or retirement program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06619-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “disposable earnings” means that part of the earnings of any individual remaining after the deduction from those earnings of any amounts required by law to be withheld.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a0661a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “garnishment” means any legal or equitable procedure through which the earnings of any individual are required to be withheld for payment of any debt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a0661b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIII/s302"},"text":"Pub. L. 90–321, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/163"},"text":"82 Stat. 163","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
