{"tag":"section","attrib":{"id":"id79dc0ec0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2085"},"text":null,"children":[{"tag":"num","attrib":{"value":"2085"},"text":"§ 2085.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-speed electric bicycles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79dc0ec1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2085/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, low-speed electric bicycles are consumer products within the meaning of section 2052(a)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002438"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002438"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title and shall be subject to the Commission regulations published at section 1500.18(a)(12) and part 1512 of title 16, Code of Federal Regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dc0ec2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2085/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, the term “low-speed electric bicycle” means a two- or three-wheeled vehicle with fully operable pedals and an electric motor of less than 750 watts (1 h.p.), whose maximum speed on a paved level surface, when powered solely by such a motor while ridden by an operator who weighs 170 pounds, is less than 20 mph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dc0ec3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2085/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To further protect the safety of consumers who ride low-speed electric bicycles, the Commission may promulgate new or amended requirements applicable to such vehicles as necessary and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79dc0ec4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2085/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall supersede any State law or requirement with respect to low-speed electric bicycles to the extent that such State law or requirement is more stringent than the Federal law or requirements referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79dc0ec5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s38"},"text":"Pub. L. 92–573, § 38","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/319/s1"},"text":"Pub. L. 107–319, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2776"},"text":"116 Stat. 2776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79dc0ec6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79dc0ec7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79dc0ec8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052/a/1"},"text":"Section 2052(a)(1) of this title","children":[],"tail":", referred to in subsec. (a), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052/a/5"},"text":"section 2052(a)(5) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s235/b/4"},"text":"Pub. L. 110–314, title II, § 235(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3074"},"text":"122 Stat. 3074","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
