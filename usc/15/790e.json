{"tag":"section","attrib":{"id":"id794f5ee9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e"},"text":null,"children":[{"tag":"num","attrib":{"value":"790e"},"text":"§ 790e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination by Director of energy information gathering activities of Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794f5eea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the purposes of this chapter the Director shall, as he deems appropriate, review the energy information gathering activities of Federal agencies with a view toward avoiding duplication of effort and minimizing the compliance burden on business enterprises and other persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794f5eeb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In exercising his responsibilities under subsection (a) of this section, the Director shall recommend policies which, to the greatest extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794f5eec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide adequately for the energy information needs of the various departments and agencies of the Federal Government, the Congress, and the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5eed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the burden of reporting energy information on businesses, other persons, and especially small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5eee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the cost to Government of obtaining information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5eef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize files of information and existing facilities of established Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794f5ef0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Administrator by other Federal agencies involved in collection of energy information; cooperation of other Federal agencies; report by Administrator to President, Congress, and Energy Resources Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794f5ef1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At the earliest practicable date after ","children":[{"tag":"date","attrib":{"date":"1976-08-14"},"text":"August 14, 1976","children":[],"tail":", each Federal agency which is engaged in the gathering of energy information as a part of an established program, function, or other activity shall promptly provide the Administrator with a report on energy information which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id794f5ef2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the statutory authority upon which the energy information collection activities of such agency is based;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794f5ef3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists and describes the energy information needs and requirements of such agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id794f5ef4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790e/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists and describes the categories, definitions, levels of detail, and frequency of collection of the energy information collected by such agency.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such agencies shall cooperate with the Administrator and provide such other descriptive information with respect to energy information activities as the Administrator may request. The Administrator shall prepare a report on his activities under this subsection, which report shall include recommendations with respect to the coordination of energy information activities of the Federal Government. Such report shall be available to the Congress and shall be transmitted to the President and to the Energy Resources Council for use in preparation of the plan required under subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5818"},"text":"section 5818 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794f5ef5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/275/s56"},"text":"Pub. L. 93–275, § 56","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/tI/s142"},"text":"Pub. L. 94–385, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1138"},"text":"90 Stat. 1138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794f5ef6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id794f5ef7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id794f5ef8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5818"},"text":"Section 5818 of title 42","children":[],"tail":", referred to in subsec. (c), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVII/s709/b"},"text":"Pub. L. 95–91, title VII, § 709(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/608"},"text":"91 Stat. 608","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794f5ef9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id794f5efa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 150 days after ","children":[{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", except that subsec. (c) of this section effective "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/s143"},"text":"section 143 of Pub. L. 94–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s790"},"text":"section 790 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id794f5efb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions assigned to Director of Office of Energy Information and Analysis under this subchapter vested in Administrator of Energy Information Administration within Department of Energy by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7135/c"},"text":"section 7135(c) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Energy Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of Title 42.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
