{"tag":"section","attrib":{"id":"id7a9f867b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055"},"text":null,"children":[{"tag":"num","attrib":{"value":"9055"},"text":"§ 9055.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Oversight Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9f867c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Congressional Oversight Commission (hereafter in this section referred to as the “Oversight Commission”) as an establishment in the legislative branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f867d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f867e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Oversight Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f867f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct oversight of the implementation of this part by the Department of the Treasury and the Board of Governors of the Federal Reserve System, including efforts of the Department and the Board to provide economic stability as a result of the coronavirus disease 2019 (COVID–19) pandemic of 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f8680-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress reports under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f8681-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the implementation of this part by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8682-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f8683-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Reports of the Oversight Commission shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a9f8684-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use by the Secretary and the Board of Governors of the Federal Reserve System of authority under this part, including with respect to the use of contracting authority and administration of the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9f8685-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The impact of loans, loan guarantees, and investments made under this part on the financial well-being of the people of the United States and the United States economy, financial markets, and financial institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9f8686-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the information made available on transactions under this part has contributed to market transparency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a9f8687-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effectiveness of loans, loan guarantees, and investments made under this part of minimizing long-term costs to the taxpayers and maximizing the benefits for taxpayers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f8688-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports required under this paragraph shall be submitted not later than 30 days after the first exercise by the Secretary and the Board of Governors of the Federal Reserve System of the authority under this part and every 30 days thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f8689-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f868a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Oversight Commission shall consist of 5 members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f868b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the Speaker of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f868c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f868d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the majority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f868e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f868f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed as Chairperson by the Speaker of the House of Representatives and the majority leader of the Senate, after consultation with the minority leader of the Senate and the minority leader of the House of Representatives ","children":[{"tag":"ref","attrib":{"idref":"fn002636"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002636"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8690-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Oversight Commission shall be paid at a rate equal to the daily equivalent of the annual rate of basic pay for level I of the Executive Schedule for each day (including travel time) during which such member is engaged in the actual performance of duties vested in the Oversight Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8691-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of compensation of Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Oversight Commission who are full-time officers or employees of the United States may not receive additional pay, allowances, or benefits by reason of their service on the Oversight Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8692-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8693-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Four members of the Oversight Commission shall constitute a quorum but a lesser number may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8694-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Oversight Commission shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8695-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission shall meet at the call of the Chairperson or a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f8696-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8697-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission may appoint and fix the pay of any personnel as the Oversight Commission considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8698-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Experts and consultants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission may procure temporary and intermittent services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8699-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff of agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the Oversight Commission, the head of any Federal department or agency may detail, on a reimbursable basis, any of the personnel of that department or agency to the Oversight Commission to assist it in carrying out its duties under the this ","children":[{"tag":"ref","attrib":{"idref":"fn002637"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002637"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f869a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f869b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission, or any subcommittee or member thereof, may, for the purpose of carrying out this section hold hearings, sit and act at times and places, take testimony, and receive evidence as the Oversight Commission considers appropriate and may administer oaths or affirmations to witnesses appearing before it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f869c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission may, to such extent and in such amounts as are provided in appropriation Acts, enter into contracts to enable the Oversight Commission to discharge its duties under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f869d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of members and agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member or agent of the Oversight Commission may, if authorized by the Oversight Commission, take any action which the Oversight Commission is authorized to take by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f869e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obtaining official data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission may secure directly from any department or agency of the United States information necessary to enable it to carry out this section. Upon request of the Chairperson of the Oversight Commission, the head of that department or agency shall furnish that information to the Oversight Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f869f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission shall receive and consider all reports required to be submitted to the Oversight Commission under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f86a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Oversight Commission shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-06-30"},"text":"June 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f86a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f86a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Oversight Commission such sums as may be necessary for any fiscal year, half of which shall be derived from the applicable account of the House of Representatives, and half of which shall be derived from the contingent fund of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f86a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9055/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An amount equal to the expenses of the Oversight Commission shall be promptly transferred by the Secretary and the Board of Governors of the Federal Reserve System, from time to time upon the presentment of a statement of such expenses by the Chairperson of the Oversight Commission, from funds made available to the Secretary under this part to the applicable fund of the House of Representatives and the contingent fund of the Senate, as appropriate, as reimbursement for amounts expended from such account and fund under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9f86a4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4020"},"text":"Pub. L. 116–136, div. A, title IV, § 4020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/486"},"text":"134 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dAA/tVIII/s801"},"text":"Pub. L. 117–328, div. AA, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5551"},"text":"136 Stat. 5551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9f86a5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9f86a6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9f86a7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsecs. (b), (d)(3), (e)(5), and (g)(2), was in the original “this subtitle”, meaning subtitle A (§§ 4001–4029) of title IV of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", known as the Coronavirus Economic Stabilization Act of 2020, which is classified principally to this part. For complete classification of subtitle A to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4001"},"text":"section 4001 of Pub. L. 116–136","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":", and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level I of the Executive Schedule, referred to in subsec. (c)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a9f86a8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2023-06-30"},"text":"June 30, 2023","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
