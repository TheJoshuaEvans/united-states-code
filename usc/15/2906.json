{"tag":"section","attrib":{"id":"id7a108cba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2906"},"text":null,"children":[{"tag":"num","attrib":{"value":"2906"},"text":"§ 2906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prepare and submit to the President and the authorizing committees of the Congress, not later than March 31 of each year, a report on the activities conducted pursuant to this chapter during the preceding fiscal year, including—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a108cbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the achievements of the Program during the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108cbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the progress made toward achieving the goals and objectives of the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108cbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the 5-year plan and any changes made in such plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108cbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the multiagency budget request for the Program of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2904/g"},"text":"section 2904(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108cbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2906/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for additional legislation which may be required to assist in achieving the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108cc0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/367/s7"},"text":"Pub. L. 95–367, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-17"},"text":"Sept. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/604"},"text":"92 Stat. 604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tII/s202/b"},"text":"Pub. L. 97–375, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1822"},"text":"96 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a108cc1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a108cc2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a108cc3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"