{"tag":"section","attrib":{"id":"id77d6a207-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70d"},"text":null,"children":[{"tag":"num","attrib":{"value":"70d"},"text":"§ 70d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d6a208-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and preservation by manufacturer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Every manufacturer of textile fiber products subject to this subchapter shall maintain proper records showing the fiber content as required by this subchapter of all such products made by him, and shall preserve such records for at least three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d6a209-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and preservation by person substituting stamp, tag, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person substituting a stamp, tag, label, or other identification pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s70c/b"},"text":"section 70c(b) of this title","children":[],"tail":" shall keep such records as will show the information set forth on the stamp, tag, label, or other identification that he removed and the name or names of the person or persons from whom such textile fiber product was received, and shall preserve such records for at least three years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d6a20a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neglect or refusal to maintain or preserve records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The neglect or refusal to maintain or preserve the records required by this section is unlawful, and any person neglecting or refusing to maintain such records shall be guilty of an unfair method of competition, and an unfair or deceptive act or practice, in commerce, under the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d6a20b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/897/s6"},"text":"Pub. L. 85–897, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1721"},"text":"72 Stat. 1721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d6a20c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d6a20d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77d6a20e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
