{"tag":"section","attrib":{"id":"id797a4079-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1368"},"text":null,"children":[{"tag":"num","attrib":{"value":"1368"},"text":"§ 1368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id797a407a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1368/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant under this chapter shall keep such records as the Secretary shall prescribe, including records which fully disclose the amount and the disposition of such grant, the total cost of the related approved program, the amount and nature of the cost of the program supplied by other sources, and such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797a407b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1368/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to records of recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Comptroller General of the United States, or any of their duly authorized representatives, shall have access to any books, documents, papers, and records of the recipient that are pertinent to amounts received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id797a407c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/182/s18"},"text":"Pub. L. 89–182, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-14"},"text":"Sept. 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/684"},"text":"79 Stat. 684","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
