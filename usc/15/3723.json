{"tag":"section","attrib":{"id":"id7a2f85ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723"},"text":null,"children":[{"tag":"num","attrib":{"value":"3723"},"text":"§ 3723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM apprenticeship programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2f85cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may carry out a grant program to identify the need for skilled science, technology, engineering, and mathematics (referred to in this section as “STEM”) workers and to expand STEM apprenticeship programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f85cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible recipient” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f85cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a city or other political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a2f85d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a nonprofit organization, an institution of higher education, a public-private partnership, a science or research park, a Federal laboratory, or an economic development organization or similar entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a2f85d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an application that is supported by a State, a political subdivision of a State, or a native organization; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of any of the entities described in paragraphs (1) through (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f85d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Needs assessment grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce may provide a grant to an eligible recipient to conduct a needs assessment to identify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f85d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unmet need of a region’s employer base for skilled STEM workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential of STEM apprenticeships to address the unmet need described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f85d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any barriers to addressing the unmet need described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2f85d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprenticeship expansion grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce may provide a grant to an eligible recipient that has conducted a needs assessment as described in subsection (c)(1) to develop infrastructure to expand STEM apprenticeship programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2f85d9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s30"},"text":"Pub. L. 96–480, § 30","children":[],"tail":", formerly § 28, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s312/e"},"text":"Pub. L. 114–329, title III, § 312(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3014"},"text":"130 Stat. 3014","children":[],"tail":"; renumbered § 30, "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10621/a/1"},"text":"Pub. L. 117–167, div. B, title VI, § 10621(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1642"},"text":"136 Stat. 1642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a2f85da-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a2f85db-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a2f85dc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Developing STEM Apprenticeships","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s312/a"},"text":"Pub. L. 114–329, title III, § 312(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3013"},"text":"130 Stat. 3013","children":[],"tail":", 3014, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/329/tIII/s312/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The lack of data on the return on investment for United States employers using registered apprenticeships makes it difficult—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to communicate the value of these programs to businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand registered apprenticeships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lack of data on the value and impact of employer-provided worker training, which is likely substantial, hinders the ability of the Federal Government to formulate policy related to workforce training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Commerce has initiated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first study on the return on investment for United States employers using registered apprenticeships through case studies of firms in various sectors, occupations, and geographic locations to provide the business community with data on employer benefits and costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" discussions with officials at relevant Federal agencies about the need to collect comprehensive data on—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employer-provided worker training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing tools that could be used to collect such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Apprenticeship Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce shall continue to research the value to businesses of utilizing apprenticeship programs, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of return on investment of apprenticeships, including estimates for the average time it takes a business to recover the costs associated with training apprentices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data from the United States Census Bureau and other statistical surveys on employer-provided training, including apprenticeships and other on-the-job training and industry-recognized certification programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissemination of Apprenticeship Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce shall disseminate findings from research on apprenticeships to businesses and other relevant stakeholders, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local chambers of commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce training organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New Apprenticeship Program Study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce may collaborate with the Secretary of Labor to study approaches for reducing the cost of creating new apprenticeship programs and hosting apprentices for businesses, particularly small businesses, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training sharing agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" group training models; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pooling resources and best practices.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “STEM” and “institution of higher education” as used in section 312(a)–(d) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/s2"},"text":"section 2 of Pub. L. 114–329","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862s"},"text":"section 1862s of Title 42","children":[],"tail":", The Public Health and Welfare.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
