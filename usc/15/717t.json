{"tag":"section","attrib":{"id":"id794107be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717t"},"text":null,"children":[{"tag":"num","attrib":{"value":"717t"},"text":"§ 717t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794107bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully and knowingly does or causes or suffers to be done any act, matter, or thing in this chapter prohibited or declared to be unlawful, or who willfully and knowingly omits or fails to do any act, matter, or thing in this chapter required to be done, or willfully and knowingly causes or suffers such omission or failure, shall, upon conviction thereof, be punished by a fine of not more than $1,000,000 or by imprisonment for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794107c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who willfully and knowingly violates any rule, regulation, restriction, condition, or order made or imposed by the Commission under authority of this chapter, shall, in addition to any other penalties provided by law, be punished upon conviction thereof by a fine of not exceeding $50,000 for each and every day during which such offense occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794107c1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556/s21"},"text":"June 21, 1938, ch. 556, § 21","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/833"},"text":"52 Stat. 833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s314/a/1"},"text":"Pub. L. 109–58, title III, § 314(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/690"},"text":"119 Stat. 690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794107c2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id794107c3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id794107c4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s314/a/1/A"},"text":"Pub. L. 109–58, § 314(a)(1)(A)","children":[],"tail":", substituted “$1,000,000” for “$5,000” and “5 years” for “two years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s314/a/1/B"},"text":"Pub. L. 109–58, § 314(a)(1)(B)","children":[],"tail":", substituted “$50,000” for “$500”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
