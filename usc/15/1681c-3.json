{"tag":"section","attrib":{"id":"id79a7916a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681c–3"},"text":"§ 1681c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse information in cases of trafficking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a7916b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a7916c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking documentation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “trafficking documentation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a7916d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" documentation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a7916e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination that a consumer is a victim of trafficking made by a Federal, State, or Tribal governmental entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a7916f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a court of competent jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a79170-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation that identifies items of adverse information that should not be furnished by a consumer reporting agency because the items resulted from a severe form of trafficking in persons or sex trafficking of which the consumer is a victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79171-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking Victims Protection Act of 2000 definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “severe forms of trafficking in persons” and “sex trafficking” have the meanings given, respectively, in section 103 of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"22 U.S.C. 7102","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79172-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim of trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “victim of trafficking” means a person who is a victim of a severe form of trafficking in persons or sex trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a79173-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A consumer reporting agency may not furnish a consumer report containing any adverse item of information about a consumer that resulted from a severe form of trafficking in persons or sex trafficking if the consumer has provided trafficking documentation to the consumer reporting agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a79174-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a79175-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Director shall issue rules to implement subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79176-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules issued pursuant to paragraph (1) shall establish a method by which consumers shall submit trafficking documentation to consumer reporting agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a79177-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s605C"},"text":"Pub. L. 90–321, title VI, § 605C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXI/s6102/a"},"text":"Pub. L. 117–81, div. F, title LXI, § 6102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2383"},"text":"135 Stat. 2383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a79178-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a79179-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a7917a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXI/s6102/c"},"text":"Pub. L. 117–81, div. F, title LXI, § 6102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2384"},"text":"135 Stat. 2384","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dF/tLXI/s6102/c"},"text":"“The amendments made by this section [enacting this section] shall apply on the date that is 30 days after the date on which the Director of the Bureau of Consumer Financial Protection issues a rule pursuant to section 605C(c) of the Fair Credit Reporting Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681c–3/c"},"text":"15 U.S.C. 1681c–3(c)","children":[],"tail":"], as added by subsection (a) of this section. Any rule issued by the Director to implement such section 605C ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681c–3"},"text":"15 U.S.C. 1681c–3","children":[],"tail":"] shall be limited to preventing a consumer reporting agency from furnishing a consumer report containing any adverse item of information about a consumer (as such terms are defined, respectively, in section 603 the Fair Credit Reporting Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a"},"text":"15 U.S.C. 1681a","children":[],"tail":")) that resulted from trafficking.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
