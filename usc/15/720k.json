{"tag":"section","attrib":{"id":"id794833ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k"},"text":null,"children":[{"tag":"num","attrib":{"value":"720k"},"text":"§ 720k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alaska pipeline construction training program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79483400-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79483401-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor (in this section referred to as the “Secretary”) shall make grants to the Alaska Workforce Investment Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79483402-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recruit and train adult and dislocated workers in Alaska, including Alaska Natives, in the skills required to construct and operate an Alaska gas pipeline system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79483403-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the design and construction of a training facility to be located in Fairbanks, Alaska, to support an Alaska gas pipeline training program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483404-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with existing programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The training program established with the grants authorized under paragraph (1) shall be consistent with the vision and goals set forth in the State of Alaska unified plan or combined plan, as appropriate, as developed pursuant to section 3112 or 3113, as appropriate, of title 29.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79483405-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make a grant under subsection (a) only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79483406-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor of the State of Alaska requests the grant funds and certifies in writing to the Secretary that there is a reasonable expectation that the construction of the Alaska natural gas pipeline system will commence by the date that is 2 years after the date of the certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483407-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Energy concurs in writing to the Secretary with the certification made under paragraph (1) after considering—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79483408-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of necessary Federal and State permits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79483409-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of financing for the Alaska natural gas pipeline project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7948340a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7948340b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $20,000,000. Not more than 15 percent of the funds may be used for the facility described in subsection (a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7948340c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/dC/s113"},"text":"Pub. L. 108–324, div. C, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-13"},"text":"Oct. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1264"},"text":"118 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/c"},"text":"Pub. L. 113–128, title V, § 512(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1706"},"text":"128 Stat. 1706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7948340d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7948340e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7948340f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “consistent with the vision and goals set forth in the State of Alaska unified plan or combined plan, as appropriate, as developed pursuant to section 3112 or 3113, as appropriate, of title 29” for “consistent with the vision and goals set forth in the State of Alaska Unified Plan, as developed pursuant to the Workforce Investment Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2801"},"text":"29 U.S.C. 2801","children":[],"tail":" et seq.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79483410-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79483411-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" effective on the first day of the first full program year after "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
