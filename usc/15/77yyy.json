{"tag":"section","attrib":{"id":"id77f59bbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77yyy"},"text":null,"children":[{"tag":"num","attrib":{"value":"77yyy"},"text":"§ 77yyy.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates any provision of this subchapter or any rule, regulation, or order thereunder, or any person who willfully, in any application, report, or document filed or required to be filed under the provisions of this subchapter or any rule, regulation, or order thereunder, makes any untrue statement of a material fact or omits to state any material fact required to be stated therein or necessary to make the statements therein not misleading, shall upon conviction be fined not more than $10,000 or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77f59bbe-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title III, § 325, as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-03/ch411"},"text":"Aug. 3, 1939, ch. 411","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1177"},"text":"53 Stat. 1177","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s27/d"},"text":"Pub. L. 94–29, § 27(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/163"},"text":"89 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f59bbf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f59bc0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77f59bc1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/29"},"text":"Pub. L. 94–29","children":[],"tail":" substituted “$10,000” for “$5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77f59bc2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77f59bc3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/29"},"text":"Pub. L. 94–29","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s31/a"},"text":"section 31(a) of Pub. L. 94–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78b"},"text":"section 78b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
