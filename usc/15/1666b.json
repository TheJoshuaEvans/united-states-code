{"tag":"section","attrib":{"id":"id799df531-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1666b"},"text":"§ 1666b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799df532-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time to make payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A creditor may not treat a payment on a credit card account under an open end consumer credit plan as late for any purpose, unless the creditor has adopted reasonable procedures designed to ensure that each periodic statement including the information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637/b"},"text":"section 1637(b) of this title","children":[],"tail":" is mailed or delivered to the consumer not later than 21 days before the payment due date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799df533-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grace period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an open end consumer credit plan provides a time period within which an obligor may repay any portion of the credit extended without incurring an additional finance charge, such additional finance charge may not be imposed with respect to such portion of the credit extended for the billing cycle of which such period is a part, unless a statement which includes the amount upon which the finance charge for the period is based was mailed or delivered to the consumer not later than 21 days before the date specified in the statement by which payment must be made in order to avoid imposition of that finance charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799df534-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s163"},"text":"Pub. L. 90–321, title I, § 163","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIII/s306"},"text":"Pub. L. 93–495, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1514"},"text":"88 Stat. 1514","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tI/s106/b/1"},"text":"Pub. L. 111–24, title I, § 106(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1742"},"text":"123 Stat. 1742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/93/s2"},"text":"Pub. L. 111–93, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2998"},"text":"123 Stat. 2998","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df535-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799df536-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799df537-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24"},"text":"Pub. L. 111–24","children":[],"tail":" amended section generally, adding provisions relating to late payments and delivery of periodic statements, substituting provisions requiring a 21-day statement delivery period for provisions requiring a 14-day period before the imposition of additional finance charges, and striking provisions relating to excusable cause for creditor’s failure to make timely mailing or delivery of periodic statements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/93"},"text":"Pub. L. 111–93","children":[],"tail":" inserted “a credit card account under” after “payment on”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df538-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799df539-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/tI/s106/b/2"},"text":"Pub. L. 111–24, title I, § 106(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1742"},"text":"123 Stat. 1742","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/24/tI/s106/b/2"},"text":"“Notwithstanding section 3 [see Effective Date of 2009 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"], section 163 of the Truth in Lending Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1666b"},"text":"15 U.S.C. 1666b","children":[],"tail":"], as amended by this subsection, shall become effective 90 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
