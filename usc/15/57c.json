{"tag":"section","attrib":{"id":"id77d1c06e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c"},"text":null,"children":[{"tag":"num","attrib":{"value":"57c"},"text":"§ 57c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out the functions, powers, and duties of the Commission not to exceed $92,700,000 for fiscal year 1994; not to exceed $99,000,000 for fiscal year 1995; not to exceed $102,000,000 for fiscal year 1996; not to exceed $107,000,000 for fiscal year 1997; and not to exceed $111,000,000 for fiscal year 1998.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d1c06f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s25"},"text":"Sept. 26, 1914, ch. 311, § 25","children":[],"tail":", formerly § 20, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/367/tII/s207"},"text":"Pub. L. 93–367, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/299/s1"},"text":"Pub. L. 94–299, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-29"},"text":"May 29, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/588"},"text":"90 Stat. 588","children":[],"tail":"; renumbered § 24 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/252"},"text":"Pub. L. 96–252","children":[],"tail":", §§ 13, 17, "},{"tag":"date","attrib":{"date":"1980-05-28"},"text":"May 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/380"},"text":"94 Stat. 380","children":[],"tail":", 391; renumbered § 25 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/312"},"text":"Pub. L. 103–312","children":[],"tail":", §§ 2, 14, "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1691"},"text":"108 Stat. 1691","children":[],"tail":", 1697; "},{"tag":"ref","attrib":{"href":"/us/pl/104/216/s2"},"text":"Pub. L. 104–216, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3019"},"text":"110 Stat. 3019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d1c070-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d1c071-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id77d1c072-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 25 of act ","children":[{"tag":"date","attrib":{"date":"1914-09-26"},"text":"Sept. 26, 1914","children":[],"tail":", was renumbered section 28 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77d1c073-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/216"},"text":"Pub. L. 104–216","children":[],"tail":" struck out “and” before “not to exceed $102,000,000” and inserted before period at end “; not to exceed $107,000,000 for fiscal year 1997; and not to exceed $111,000,000 for fiscal year 1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/312/s14"},"text":"Pub. L. 103–312, § 14","children":[],"tail":", amended section generally. Prior to amendment, section read as follows: “There are authorized to be appropriated to carry out the functions, powers, and duties of the Federal Trade Commission not to exceed $42,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":"; not to exceed $47,091,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":"; not to exceed $50,000,000 for the fiscal year ending in 1977; not to exceed $70,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":"; not to exceed $75,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":"; and not to exceed $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/252/s17"},"text":"Pub. L. 96–252, § 17","children":[],"tail":", substituted “1977; not to exceed $70,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":"; not to exceed $75,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":"; and not to exceed $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"” for “1977. For fiscal years ending after 1977, there may be appropriated to carry out such functions, powers, and duties, only such sums as the Congress may hereafter authorize by law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/299"},"text":"Pub. L. 94–299","children":[],"tail":" substituted “$47,091,000” for “$46,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77d1c074-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77d1c075-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/252"},"text":"Pub. L. 96–252","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-05-28"},"text":"May 28, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/252/s23"},"text":"section 23 of Pub. L. 96–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77d1c076-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Intervention by Commission in Certain Proceedings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/312/s11"},"text":"Pub. L. 103–312, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1696"},"text":"108 Stat. 1696","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/312/s11"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Use of Authorized Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Trade Commission shall not have any authority to use any funds which are authorized to be appropriated to carry out the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.) for fiscal years 1994, 1995, and 1996 for the purpose of submitting statements to, appearing before, or intervening in the proceedings of, any Federal or State agency or State legislative body concerning proposed rules or legislation that the agency or legislative body is considering unless the Commission advises the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Energy and Commerce of the House of Representatives regarding such action as soon as possible."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Notice to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notice required in subsection (a) shall include the name of the agency or legislator involved, the date of such action, and a concise statement regarding the nature and purpose of such action.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77d1c077-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restriction on Use of Funds To Cancel Registration of Trademarks","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/252/s18"},"text":"Pub. L. 96–252, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-28"},"text":"May 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/391"},"text":"94 Stat. 391","children":[],"tail":", prohibited the Federal Trade Commission from using any funds authorized to be appropriated to carry out this subchapter for fiscal year 1980, 1981, or 1982 (or 1983 as extended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI"},"text":"Pub. L. 97–377, title I","children":[],"tail":" § 101(d), "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1870"},"text":"96 Stat. 1870","children":[],"tail":"), under this section, for the purpose of taking any action under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1064"},"text":"15 U.S.C. 1064","children":[],"tail":" with respect to the cancellation of the registration of any mark on the ground that such mark has become the common descriptive name of an article or substance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77d1c078-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restriction on Use of Funds Respecting Study, Investigation, or Prosecution of any Agricultural Cooperative or Study or Investigation of any Agricultural Marketing Orders","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/252/s20"},"text":"Pub. L. 96–252, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-05-28"},"text":"May 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/393"},"text":"94 Stat. 393","children":[],"tail":", prohibited the Federal Trade Commission from using any funds authorized to be appropriated to carry out this subchapter for fiscal year 1980, 1981, or 1982 (or 1983 as extended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI"},"text":"Pub. L. 97–377, title I","children":[],"tail":" § 101(d), "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1870"},"text":"96 Stat. 1870","children":[],"tail":"), under this section, for the purpose of conducting any study, investigation, or prosecution of any agricultural cooperative for any conduct which, because of the provisions of the Capper-Volstead Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s291"},"text":"7 U.S.C. 291","children":[],"tail":" et seq.), was not a violation of any Federal antitrust Act or this subchapter or for the purpose of conducting any study or investigation of any agricultural marketing orders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
