{"tag":"section","attrib":{"id":"id79d028a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2057e"},"text":"§ 2057e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banning of crib bumpers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d028a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-05-16"},"text":"May 16, 2022","children":[],"tail":", crib bumpers, regardless of the date of manufacture, shall be considered a banned hazardous product under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2057"},"text":"section 2057 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d028a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crib bumper defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “crib bumper”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d028a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any material that is intended to cover the sides of a crib to prevent injury to any crib occupant from impacts against the side of a crib or to prevent partial or complete access to any openings in the sides of a crib to prevent a crib occupant from getting any part of the body entrapped in any opening;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d028a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a padded crib bumper, a supported and unsupported vinyl bumper guard, and vertical crib slat covers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d028a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2057e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a non-padded mesh crib liner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d028a8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/126/s3"},"text":"Pub. L. 117–126, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-05-16"},"text":"May 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1208"},"text":"136 Stat. 1208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d028a9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d028aa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d028ab-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Safe Sleep for Babies Act of 2021, and not as part of the Consumer Product Safety Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
