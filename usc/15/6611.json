{"tag":"section","attrib":{"id":"id7a5cd839-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611"},"text":null,"children":[{"tag":"num","attrib":{"value":"6611"},"text":"§ 6611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages in tort claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5cd83a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A party to a Y2K action making a tort claim, other than a claim of intentional tort arising independent of a contract, may not recover damages for economic loss unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd83b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recovery of such losses is provided for in a contract to which the party seeking to recover such losses is a party; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd83c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such losses result directly from damage to tangible personal or real property caused by the Y2K failure involved in the action (other than damage to property that is the subject of the contract between the parties to the Y2K action or, in the event there is no contract between the parties, other than damage caused only to the property that experienced the Y2K failure),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and such damages are permitted under applicable Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd83d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic loss","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section only, and except as otherwise specifically provided in a valid and enforceable written contract between the plaintiff and the defendant in a Y2K action, the term “economic loss” means amounts awarded to compensate an injured party for any loss, and includes amounts awarded for damages such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd83e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lost profits or sales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd83f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business interruption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd840-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" losses indirectly suffered as a result of the defendant’s wrongful act or omission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd841-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" losses that arise because of the claims of third parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd842-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" losses that must be pled as special damages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd843-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consequential damages (as defined in the Uniform Commercial Code or analogous State commercial law).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd844-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain other actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person liable for damages, whether by settlement or judgment, in a civil action to which this chapter does not apply because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6603/c"},"text":"section 6603(c) of this title","children":[],"tail":" whose liability, in whole or in part, is the result of a Y2K failure may, notwithstanding any other provision of this chapter, pursue any remedy otherwise available under Federal or State law against the person responsible for that Y2K failure to the extent of recovering the amount of those damages."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5cd845-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s12"},"text":"Pub. L. 106–37, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/199"},"text":"113 Stat. 199","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
