{"tag":"section","attrib":{"id":"id7a047f2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2651"},"text":null,"children":[{"tag":"num","attrib":{"value":"2651"},"text":"§ 2651.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a047f2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2651/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State or local educational agency may discriminate against a person in any way, including firing a person who is an employee, because the person provided information relating to a potential violation of this subchapter to any other person, including a State or the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047f30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2651/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor Department review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any public or private employee or representative of employees who believes he or she has been fired or otherwise discriminated against in violation of subsection (a) may within 90 days after the alleged violation occurs apply to the Secretary of Labor for a review of the firing or alleged discrimination. The review shall be conducted in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s660/c"},"text":"section 660(c) of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a047f31-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tII/s211"},"text":"Pub. L. 94–469, title II, § 211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s2"},"text":"Pub. L. 99–519, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2987"},"text":"100 Stat. 2987","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
