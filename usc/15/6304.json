{"tag":"section","attrib":{"id":"id7a55ac60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6304"},"text":null,"children":[{"tag":"num","attrib":{"value":"6304"},"text":"§ 6304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No person may arrange, promote, organize, produce, or fight in a professional boxing match without meeting each of the following requirements or an alternative requirement in effect under regulations of a boxing commission that provides equivalent protection of the health and safety of boxers:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A physical examination of each boxer by a physician certifying whether or not the boxer is physically fit to safely compete, copies of which must be provided to the boxing commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise expressly provided under regulation of a boxing commission promulgated subsequent to ","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":", an ambulance or medical personnel with appropriate resuscitation equipment continuously present on site."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6304/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A physician continuously present at ringside.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6304/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health insurance for each boxer to provide medical coverage for any injuries sustained in the match.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a55ac65-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s5"},"text":"Pub. L. 104–272, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3310"},"text":"110 Stat. 3310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a55ac66-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55ac67-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a55ac68-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23/2"},"text":"section 23(2) of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
