{"tag":"section","attrib":{"id":"id77bc63ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s36"},"text":null,"children":[{"tag":"num","attrib":{"value":"36"},"text":"§ 36.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of damages, etc., for antitrust violations on claim against person based on official action directed by local government, or official or employee thereof acting in an official capacity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77bc63af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s36/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition in general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No damages, interest on damages, costs or attorney’s fees may be recovered under section 4, 4A, or 4C of the Clayton Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s15"},"text":"15 U.S.C. 15","children":[],"tail":", 15a, or 15c) in any claim against a person based on any official action directed by a local government, or official or employee thereof acting in an official capacity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77bc63b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s36/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of prohibition for cases commenced before effective date of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply with respect to cases commenced before the effective date of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77bc63b1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[