{"tag":"section","attrib":{"id":"id79a79146-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681c–2"},"text":"§ 1681c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Block of information resulting from identity theft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a79147-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Block","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, a consumer reporting agency shall block the reporting of any information in the file of a consumer that the consumer identifies as information that resulted from an alleged identity theft, not later than 4 business days after the date of receipt by such agency of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a79148-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate proof of the identity of the consumer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79149-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of an identity theft report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a7914a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of such information by the consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a7914b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement by the consumer that the information is not information relating to any transaction by the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a7914c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A consumer reporting agency shall promptly notify the furnisher of information identified by the consumer under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a7914d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the information may be a result of identity theft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a7914e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that an identity theft report has been filed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a7914f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a block has been requested under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79150-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the effective dates of the block.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a79151-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to decline or rescind","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a79152-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A consumer reporting agency may decline to block, or may rescind any block, of information relating to a consumer under this section, if the consumer reporting agency reasonably determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a79153-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information was blocked in error or a block was requested by the consumer in error;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a79154-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information was blocked, or a block was requested by the consumer, on the basis of a material misrepresentation of fact by the consumer relevant to the request to block; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a79155-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer obtained possession of goods, services, or money as a result of the blocked transaction or transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79156-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to consumer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a block of information is declined or rescinded under this subsection, the affected consumer shall be notified promptly, in the same manner as consumers are notified of the reinsertion of information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681i/a/5/B"},"text":"section 1681i(a)(5)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79157-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significance of block","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, if a consumer reporting agency rescinds a block, the presence of information in the file of a consumer prior to the blocking of such information is not evidence of whether the consumer knew or should have known that the consumer obtained possession of any goods, services, or money as a result of the block.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a79158-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for resellers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a79159-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No reseller file","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to a consumer reporting agency, if the consumer reporting agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a7915a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a reseller;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a7915b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not, at the time of the request of the consumer under subsection (a), otherwise furnishing or reselling a consumer report concerning the information identified by the consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a7915c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs the consumer, by any means, that the consumer may report the identity theft to the Bureau to obtain consumer information regarding identity theft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a7915d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reseller with file","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sole obligation of the consumer reporting agency under this section, with regard to any request of a consumer under this section, shall be to block the consumer report maintained by the consumer reporting agency from any subsequent use, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a7915e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer, in accordance with the provisions of subsection (a), identifies, to a consumer reporting agency, information in the file of the consumer that resulted from identity theft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a7915f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer reporting agency is a reseller of the identified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a79160-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out its obligation under paragraph (2), the reseller shall promptly provide a notice to the consumer of the decision to block the file. Such notice shall contain the name, address, and telephone number of each consumer reporting agency from which the consumer information was obtained for resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a79161-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for verification companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section do not apply to a check services company, acting as such, which issues authorizations for the purpose of approving or processing negotiable instruments, electronic fund transfers, or similar methods of payments, except that, beginning 4 business days after receipt of information described in paragraphs (1) through (3) of subsection (a), a check services company shall not report to a national consumer reporting agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/p"},"text":"section 1681a(p) of this title","children":[],"tail":", any information identified in the subject identity theft report as resulting from identity theft."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a79162-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681c–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to blocked information by law enforcement agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed as requiring a consumer reporting agency to prevent a Federal, State, or local law enforcement agency from accessing blocked information in a consumer file to which the agency could otherwise obtain access under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a79163-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s605B"},"text":"Pub. L. 90–321, title VI, § 605B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/159/tI/s152/a"},"text":"Pub. L. 108–159, title I, § 152(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1964"},"text":"117 Stat. 1964","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1088/a/2/C"},"text":"Pub. L. 111–203, title X, § 1088(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2087"},"text":"124 Stat. 2087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a79164-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a79165-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a79166-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “the Bureau” for “the Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a79167-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a79168-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a79169-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section subject to joint regulations establishing effective dates as prescribed by Federal Reserve Board and Federal Trade Commission, except as otherwise provided, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/s3"},"text":"section 3 of Pub. L. 108–159","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
