{"tag":"section","attrib":{"id":"id7986265e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1540"},"text":null,"children":[{"tag":"num","attrib":{"value":"1540"},"text":"§ 1540.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce, acting through the Under Secretary of Commerce for Oceans and Atmosphere, may enter into cooperative agreements and other financial agreements with any nonprofit organization to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7986265f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1540/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aid and promote scientific and educational activities to foster public understanding of the National Oceanic and Atmospheric Administration or its programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79862660-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1540/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit private donations for the support of such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79862661-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/567/tIV/s406"},"text":"Pub. L. 102–567, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4293"},"text":"106 Stat. 4293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79862662-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79862663-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79862664-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cooperative Agreements for Research, Education, Training, and Outreach","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dB/tII"},"text":"Pub. L. 108–199, div. B, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/71"},"text":"118 Stat. 71","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dB/tII"},"text":"“That, hereafter, the Secretary of Commerce may enter into cooperative agreements with the Joint and Cooperative Institutes as designated by the Secretary to use the personnel, services, or facilities of such organizations for research, education, training, and outreach”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dB/tII"},"text":"Pub. L. 108–7, div. B, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/74"},"text":"117 Stat. 74","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
