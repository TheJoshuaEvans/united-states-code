{"tag":"section","attrib":{"id":"id7a533af5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102"},"text":"§ 6102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telemarketing rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a533af6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533af7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall prescribe rules prohibiting deceptive telemarketing acts or practices and other abusive telemarketing acts or practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533af8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall include in such rules respecting deceptive telemarketing acts or practices a definition of deceptive telemarketing acts or practices which shall include fraudulent charitable solicitations, and which may include acts or practices of entities or individuals that assist or facilitate deceptive telemarketing, including credit card laundering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533af9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall include in such rules respecting other abusive telemarketing acts or practices—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533afa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that telemarketers may not undertake a pattern of unsolicited telephone calls which the reasonable consumer would consider coercive or abusive of such consumer’s right to privacy,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533afb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrictions on the hours of the day and night when unsolicited telephone calls can be made to consumers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533afc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that any person engaged in telemarketing for the sale of goods or services shall promptly and clearly disclose to the person receiving the call that the purpose of the call is to sell goods or services and make such other disclosures as the Commission deems appropriate, including the nature and price of the goods and services; ","children":[{"tag":"ref","attrib":{"idref":"fn002545"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002545"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a comma."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533afd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that any person engaged in telemarketing for the solicitation of charitable contributions, donations, or gifts of money or any other thing of value, shall promptly and clearly disclose to the person receiving the call that the purpose of the call is to solicit charitable contributions, donations, or gifts, and make such other disclosures as the Commission considers appropriate, including the name and mailing address of the charitable organization on behalf of which the solicitation is made.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In prescribing the rules described in this paragraph, the Commission shall also consider recordkeeping requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533afe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall have authority to prescribe rules under subsection (a), in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":". In prescribing a rule under this section that relates to the provision of a consumer financial product or service that is subject to the Consumer Financial Protection Act of 2010, including any enumerated consumer law thereunder, the Commission shall consult with the Bureau of Consumer Financial Protection regarding the consistency of a proposed rule with standards, purposes, or objectives administered by the Bureau of Consumer Financial Protection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533aff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any violation of any rule prescribed under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be treated as a violation of a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"section 57a of this title","children":[],"tail":" regarding unfair or deceptive acts or practices; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is committed by a person subject to the Consumer Financial Protection Act of 2010 shall be treated as a violation of a rule under section 1031 of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5531"},"text":"12 U.S.C. 5531","children":[],"tail":"] regarding unfair, deceptive, or abusive acts or practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities and Exchange Commission rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), not later than 6 months after the effective date of rules promulgated by the Federal Trade Commission under subsection (a), the Securities and Exchange Commission shall promulgate, or require any national securities exchange or registered securities association to promulgate, rules substantially similar to such rules to prohibit deceptive and other abusive telemarketing acts or practices by persons described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Securities and Exchange Commission is not required to promulgate a rule under subparagraph (A) if it determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a533b06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal securities laws or rules adopted by the Securities and Exchange Commission thereunder provide protection from deceptive and other abusive telemarketing by persons described in paragraph (2) substantially similar to that provided by rules promulgated by the Federal Trade Commission under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a533b07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a rule promulgated by the Securities and Exchange Commission is not necessary or appropriate in the public interest, or for the protection of investors, or would be inconsistent with the maintenance of fair and orderly markets.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the Securities and Exchange Commission determines that an exception described in clause (i) or (ii) applies, the Securities and Exchange Commission shall publish in the Federal Register its determination with the reasons for it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules promulgated by the Securities and Exchange Commission under paragraph (1)(A) shall apply to a broker, dealer, transfer agent, municipal securities dealer, municipal securities broker, government securities broker, government securities dealer, investment adviser or investment company, or any individual associated with a broker, dealer, transfer agent, municipal securities dealer, municipal securities broker, government securities broker, government securities dealer, investment adviser or investment company. The rules promulgated by the Federal Trade Commission under subsection (a) shall not apply to persons described in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a533b0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “broker”, “dealer”, “transfer agent”, “municipal securities dealer”, “municipal securities broker”, “government securities broker”, and “government securities dealer” have the meanings given such terms by paragraphs (4), (5), (25), (30), (31), (43), and (44) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a533b0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “investment adviser” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–2/a/11"},"text":"section 80b–2(a)(11) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a533b0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “investment company” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–3/a"},"text":"section 80a–3(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Futures Trading Commission rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules promulgated by the Federal Trade Commission under subsection (a) shall not apply to persons described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9b/1"},"text":"section 9b(1) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6102/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a533b11-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/297/s3"},"text":"Pub. L. 103–297, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-16"},"text":"Aug. 16, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1545"},"text":"108 Stat. 1545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1011/b/1"},"text":"Pub. L. 107–56, title X, § 1011(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/396"},"text":"115 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100C/a"},"text":"Pub. L. 111–203, title X, § 1100C(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2110"},"text":"124 Stat. 2110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a533b12-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a533b13-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a533b14-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Consumer Financial Protection Act of 2010, referred to in subsecs. (b) and (c)(2), is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1955"},"text":"124 Stat. 1955","children":[],"tail":", which enacted subchapter V (§ 5481 et seq.) of chapter 53 of Title 12, Banks and Banking, and enacted and amended numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a533b15-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/297/s3"},"text":"section 3 of Pub. L. 103–297","children":[],"tail":". Subsec. (e)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/297/s3"},"text":"section 3 of Pub. L. 103–297","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9b"},"text":"section 9b of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a533b16-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" added subsecs. (b) and (c) and struck out former subsecs. (b) and (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking","children":[],"tail":".—The Commission shall prescribe the rules under subsection (a) of this section within 365 days after "},{"tag":"date","attrib":{"date":"1994-08-16"},"text":"August 16, 1994","children":[],"tail":". Such rules shall be prescribed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—Any violation of any rule prescribed under subsection (a) of this section shall be treated as a violation of a rule under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a"},"text":"section 57a of this title","children":[],"tail":" regarding unfair or deceptive acts or practices.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s1011/b/1"},"text":"Pub. L. 107–56, § 1011(b)(1)","children":[],"tail":", inserted “which shall include fraudulent charitable solicitations, and” before “which may include”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s1011/b/2"},"text":"Pub. L. 107–56, § 1011(b)(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a533b17-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a533b18-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
