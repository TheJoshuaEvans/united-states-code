{"tag":"section","attrib":{"id":"id7a49c538-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5105"},"text":null,"children":[{"tag":"num","attrib":{"value":"5105"},"text":"§ 5105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the research and development conducted under this chapter with other research and development being conducted by the Department of Energy and other Federal agencies in order to increase efficiency and avoid duplication of effort.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a49c539-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/680/s6"},"text":"Pub. L. 100–680, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-17"},"text":"Nov. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4076"},"text":"102 Stat. 4076","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
