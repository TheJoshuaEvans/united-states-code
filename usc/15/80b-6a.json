{"tag":"section","attrib":{"id":"id787fd9df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–6a"},"text":null,"children":[{"tag":"num","attrib":{"value":"80b–6a"},"text":"§ 80b–6a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission, by rules and regulations, upon its own motion, or by order upon application, may conditionally or unconditionally exempt any person or transaction, or any class or classes of persons, or transactions, from any provision or provisions of this subchapter or of any rule or regulation thereunder, if and to the extent that such exemption is necessary or appropriate in the public interest and consistent with the protection of investors and the purposes fairly intended by the policy and provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787fd9e0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title II, § 206A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/547/s26"},"text":"Pub. L. 91–547, § 26","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1433"},"text":"84 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787fd9e1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787fd9e2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id787fd9e3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/547/s30"},"text":"section 30 of Pub. L. 91–547","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–2"},"text":"section 80a–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
