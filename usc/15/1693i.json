{"tag":"section","attrib":{"id":"id79bd152b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1693i"},"text":"§ 1693i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of cards or other means of access","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79bd152c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition; proper issuance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may issue to a consumer any card, code, or other means of access to such consumer’s account for the purpose of initiating an electronic fund transfer other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd152d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in response to a request or application therefor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd152e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a renewal of, or in substitution for, an accepted card, code, or other means of access, whether issued by the initial issuer or a successor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd152f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of subsection (a), a person may distribute to a consumer on an unsolicited basis a card, code, or other means of access for use in initiating an electronic fund transfer from such consumer’s account, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd1530-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such card, code, or other means of access is not validated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1531-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such distribution is accompanied by a complete disclosure, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693c"},"text":"section 1693c of this title","children":[],"tail":", of the consumer’s rights and liabilities which will apply if such card, code, or other means of access is validated;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1532-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such distribution is accompanied by a clear explanation, in accordance with regulations of the Bureau, that such card, code, or other means of access is not validated and how the consumer may dispose of such code, card, or other means of access if validation is not desired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1533-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such card, code, or other means of access is validated only in response to a request or application from the consumer, upon verification of the consumer’s identity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd1534-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of subsection (b), a card, code, or other means of access is validated when it may be used to initiate an electronic fund transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79bd1535-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIX/s911"},"text":"Pub. L. 90–321, title IX, § 911","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXX/s2001"},"text":"Pub. L. 95–630, title XX, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3736"},"text":"92 Stat. 3736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1084/1"},"text":"Pub. L. 111–203, title X, § 1084(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2081"},"text":"124 Stat. 2081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79bd1536-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79bd1537-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79bd1538-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79bd1539-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79bd153a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
