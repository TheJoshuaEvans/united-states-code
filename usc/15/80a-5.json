{"tag":"section","attrib":{"id":"id78635156-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–5"},"text":"§ 80a–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subclassification of management companies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78635157-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open-end and closed-end companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, management companies are divided into open-end and closed-end companies, defined as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78635158-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Open-end company” means a management company which is offering for sale or has outstanding any redeemable security of which it is the issuer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78635159-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Closed-end company” means any management company other than an open-end company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7863515a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversified and non-diversified companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Management companies are further divided into diversified companies and non-diversified companies, defined as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7863515b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Diversified company” means a management company which meets the following requirements: At least 75 per centum of the value of its total assets is represented by cash and cash items (including receivables), Government securities, securities of other investment companies, and other securities for the purposes of this calculation limited in respect of any one issuer to an amount not greater in value than 5 per centum of the value of the total assets of such management company and to not more than 10 per centum of the outstanding voting securities of such issuer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7863515c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Non-diversified company” means any management company other than a diversified company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7863515d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of status as diversified company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A registered diversified company which at the time of its qualification as such meets the requirements of paragraph (1) of subsection (b) shall not lose its status as a diversified company because of any subsequent discrepancy between the value of its various investments and the requirements of said paragraph, so long as any such discrepancy existing immediately after its acquisition of any security or other property is neither wholly nor partly the result of such acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7863515e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/54/800"},"text":"54 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/181/tVI/s607"},"text":"Pub. L. 100–181, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1261"},"text":"101 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7863515f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78635160-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78635161-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/181"},"text":"Pub. L. 100–181","children":[],"tail":" substituted “Closed-end” for “Close-end”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78635162-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78635163-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Securities and Exchange Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 10 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
