{"tag":"section","attrib":{"id":"id7a5cd835-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6610"},"text":null,"children":[{"tag":"num","attrib":{"value":"6610"},"text":"§ 6610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damages limitation by contract","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any Y2K action for breach or repudiation of contract, no party may claim, or be awarded, any category of damages unless such damages are allowed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd836-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6610/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the express terms of the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd837-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6610/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the contract is silent on such damages, by operation of State law at the time the contract was effective or by operation of Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5cd838-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s11"},"text":"Pub. L. 106–37, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/199"},"text":"113 Stat. 199","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
