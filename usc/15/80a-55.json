{"tag":"section","attrib":{"id":"id78766414-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–55"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–55"},"text":"§ 80a–55.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78766415-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–55/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-interested persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of a business development company’s directors or general partners shall be persons who are not interested persons of such company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78766416-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–55/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies; suspension of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, by reason of the death, disqualification, or bona fide resignation of any director or general partner, a business development company does not meet the requirements of subsection (a) of this section, or the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–15/f/1"},"text":"section 80a–15(f)(1) of this title","children":[],"tail":" with respect to directors, the operation of such provisions shall be suspended for a period of 90 days or for such longer period as the Commission may prescribe, upon its own motion or by order upon application, as not inconsistent with the protection of investors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78766417-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 56, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/477/tI"},"text":"Pub. L. 96–477, title I","children":[],"tail":" § 105, "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2280"},"text":"94 Stat. 2280","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
