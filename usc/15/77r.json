{"tag":"section","attrib":{"id":"id77e4d364-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r"},"text":null,"children":[{"tag":"num","attrib":{"value":"77r"},"text":"§ 77r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from State regulation of securities offerings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e4d365-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of exemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, no law, rule, regulation, or order, or other administrative action of any State or any political subdivision thereof—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d366-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requiring, or with respect to, registration or qualification of securities, or registration or qualification of securities transactions, shall directly or indirectly apply to a security that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d367-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a covered security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d368-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be a covered security upon completion of the transaction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d369-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall directly or indirectly prohibit, limit, or impose any conditions upon the use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d36a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a covered security described in subsection (b), any offering document that is prepared by or on behalf of the issuer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d36b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proxy statement, report to shareholders, or other disclosure document relating to a covered security or the issuer thereof that is required to be and is filed with the Commission or any national securities organization registered under section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–3 of this title, except that this subparagraph does not apply to the laws, rules, regulations, or orders, or other administrative actions of the State of incorporation of the issuer; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d36c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall directly or indirectly prohibit, limit, or impose conditions, based on the merits of such offering or issuer, upon the offer or sale of any security described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d36d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered securities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following are covered securities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d36e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive Federal registration of nationally traded securities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A security is a covered security if such security is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d36f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a security designated as qualified for trading in the national market system pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78k–1/a/2"},"text":"section 78k–1(a)(2) of this title","children":[],"tail":" that is listed, or authorized for listing, on a national securities exchange (or tier or segment thereof); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d370-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a security of the same issuer that is equal in seniority or that is a senior security to a security described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d371-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive Federal registration of investment companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A security is a covered security if such security is a security issued by an investment company that is registered, or that has filed a registration statement, under the Investment Company Act of 1940 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d372-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales to qualified purchasers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A security is a covered security with respect to the offer or sale of the security to qualified purchasers, as defined by the Commission by rule. In prescribing such rule, the Commission may define the term “qualified purchaser” differently with respect to different categories of securities, consistent with the public interest and the protection of investors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d373-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption in connection with certain exempt offerings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A security is a covered security with respect to a transaction that is exempt from registration under this subchapter pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d374-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) or (3) of section 77d ","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and the issuer of such security files reports with the Commission pursuant to section 78m or 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d375-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 77d(4) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d376-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 77d(6) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d377-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rule or regulation adopted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c/b/2"},"text":"section 77c(b)(2) of this title","children":[],"tail":" and such security is—"}],"tail":null},{"tag":"clause","attrib":{"id":"id77e4d378-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered or sold on a national securities exchange; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e4d379-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered or sold to a qualified purchaser, as defined by the Commission pursuant to paragraph (3) with respect to that purchase or sale;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d37a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c/a"},"text":"section 77c(a) of this title","children":[],"tail":", other than the offer or sale of a security that is exempt from such registration pursuant to paragraph (4), (10), or (11) of such section, except that a municipal security that is exempt from such registration pursuant to paragraph (2) of such section is not a covered security with respect to the offer or sale of such security in the State in which the issuer of such security is located;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d37b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commission rules or regulations issued under section 77d(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, except that this subparagraph does not prohibit a State from imposing notice filing requirements that are substantially similar to those required by rule or regulation under section 77d(2) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title that are in effect on "},{"tag":"date","attrib":{"date":"1996-09-01"},"text":"September 1, 1996","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d37c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77d/a/7"},"text":"section 77d(a)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d37d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d37e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with this section, the securities commission (or any agency or office performing like functions) of any State shall retain jurisdiction under the laws of such State to investigate and bring enforcement actions, in connection with securities or securities transactions ","children":[{"tag":"ref","attrib":{"idref":"fn002022"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma after “enforcement actions” probably should be a hyphen and the words “in connection with securities or securities transactions” probably should be part of subpar. (A)."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d37f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e4d380-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraud or deceit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e4d381-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unlawful conduct by a broker, dealer, or funding portal; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d382-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in connection to ","children":[{"tag":"ref","attrib":{"idref":"fn002023"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002023"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “with”."}],"tail":" a transaction described under section 77d(6) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, with respect to—"}],"tail":null},{"tag":"clause","attrib":{"id":"id77e4d383-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraud or deceit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e4d384-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unlawful conduct by a broker, dealer, funding portal, or issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d385-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of filing requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d386-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice filings permitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits the securities commission (or any agency or office performing like functions) of any State from requiring the filing of any document filed with the Commission pursuant to this subchapter, together with annual or periodic reports of the value of securities sold or offered to be sold to persons located in the State (if such sales data is not included in documents filed with the Commission), solely for notice purposes and the assessment of any fee, together with a consent to service of process and any required fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d387-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of fees","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e4d388-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until otherwise provided by law, rule, regulation, or order, or other administrative action of any State or any political subdivision thereof, adopted after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", filing or registration fees with respect to securities or securities transactions shall continue to be collected in amounts determined pursuant to State law as in effect on the day before "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e4d389-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fees required by this subparagraph shall be paid, and all necessary supporting data on sales or offers for sales required under subparagraph (A), shall be reported on the same schedule as would have been applicable had the issuer not relied on the exemption provided in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d38a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of preemption contingent on payment of fees","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e4d38b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", and ending 3 years after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", the securities commission (or any agency or office performing like functions) of any State may require the registration of securities issued by any issuer who refuses to pay the fees required by subparagraph (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e4d38c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delays","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subparagraph, delays in payment of fees or underpayments of fees that are promptly remedied shall not constitute a refusal to pay fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d38d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees not permitted on listed securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraphs (A), (B), and (C), no filing or fee may be required with respect to any security that is a covered security pursuant to subsection (b)(1), or will be such a covered security upon completion of the transaction, or is a security of the same issuer that is equal in seniority or that is a senior security to a security that is a covered security pursuant to subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d38e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002024"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002024"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. No subpar. (E) has been enacted."}],"tail":" Fees not permitted on crowdfunded securities"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraphs (A), (B), and (C), no filing or fee may be required with respect to any security that is a covered security pursuant to subsection (b)(4)(B), or will be such a covered security upon completion of the transaction, except for the securities commission (or any agency or office performing like functions) of the State of the principal place of business of the issuer, or any State in which purchasers of 50 percent or greater of the aggregate amount of the issue are residents, provided that for purposes of this subparagraph, the term “State” includes the District of Columbia and the territories of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d38f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prohibit the securities commission (or any agency or office performing like functions) of any State from suspending the offer or sale of securities within such State as a result of the failure to submit any filing or fee required under law and permitted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d390-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d391-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offering document","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “offering document”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e4d392-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term “prospectus” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b/a/10"},"text":"section 77b(a)(10) of this title","children":[],"tail":", but without regard to the provisions of subparagraphs (a) and (b) of that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e4d393-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a communication that is not deemed to offer a security pursuant to a rule of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d394-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepared by or on behalf of the issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", the Commission shall, by rule, define the term “prepared by or on behalf of the issuer” for purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d395-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d396-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77r/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “senior security” means any bond, debenture, note, or similar obligation or instrument constituting a security and evidencing indebtedness, and any stock of a class having priority over any other class as to distribution of assets or payment of dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e74397-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 18, "},{"tag":"ref","attrib":{"href":"/us/stat/48/85"},"text":"48 Stat. 85","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/290/tI/s102/a"},"text":"Pub. L. 104–290, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3417"},"text":"110 Stat. 3417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/353/tIII"},"text":"Pub. L. 105–353, title III","children":[],"tail":", §§ 301(a)(4), 302, "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3235"},"text":"112 Stat. 3235","children":[],"tail":", 3237; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s985/a/2"},"text":"Pub. L. 111–203, title IX, § 985(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1933"},"text":"124 Stat. 1933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/106/tIII/s305/a"},"text":"Pub. L. 112–106, title III, § 305(a)","children":[],"tail":", (b)(2), (c), (d)(2), title IV, § 401(b), "},{"tag":"date","attrib":{"date":"2012-04-05"},"text":"Apr. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/322"},"text":"126 Stat. 322","children":[],"tail":", 323, 325; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXVI/s76001/b"},"text":"Pub. L. 114–94, div. G, title LXXVI, § 76001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1789"},"text":"129 Stat. 1789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/174/tV/s501"},"text":"Pub. L. 115–174, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1361"},"text":"132 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e74398-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e74399-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77e7439a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Investment Company Act of 1940, referred to in subsec. (b)(2), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"act Aug. 22, 1940, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":", which is classified generally to subchapter I (§ 80a–1 et seq.) of chapter 2D of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 77d(1), (2), (3), (4), and (6) of this title, referred to in subsecs. (b)(4)(A) to (C), (E) and (c)(1)(B), were redesignated section 77d(a)(1), (2), (3), (4), and (6), respectively, of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/tII/s201/b/1"},"text":"Pub. L. 112–106, title II, § 201(b)(1)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2012-04-05"},"text":"Apr. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/314"},"text":"126 Stat. 314","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e7439b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s501/1"},"text":"Pub. L. 115–174, § 501(1)","children":[],"tail":", (4), redesignated subpar. (B) as (A) and struck out former subpar. (A) which read as follows: “listed, or authorized for listing, on the New York Stock Exchange or the American Stock Exchange, or listed, or authorized for listing, on the National Market System of the Nasdaq Stock Market (or any successor to such entities);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s501/4"},"text":"Pub. L. 115–174, § 501(4)","children":[],"tail":", redesignated subpar. (C) as (B). Former subpar. (B) redesignated (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s501/2"},"text":"Pub. L. 115–174, § 501(2)","children":[],"tail":", inserted “a security designated as qualified for trading in the national market system pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78k–1/a/2"},"text":"section 78k–1(a)(2) of this title","children":[],"tail":" that is” before “listed” and struck out “that has listing standards that the Commission determines by rule (on its own initiative or on the basis of a petition) are substantially similar to the listing standards applicable to securities described in subparagraph (A)” after “(or tier or segment thereof)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s501/4"},"text":"Pub. L. 115–174, § 501(4)","children":[],"tail":", redesignated subpar. (C) as (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/174/s501/3"},"text":"Pub. L. 115–174, § 501(3)","children":[],"tail":", struck out “or (B)” after “described in subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s76001/b/1"},"text":"Pub. L. 114–94, § 76001(b)(1)","children":[],"tail":", which directed amendment of subsec. (b)(4) by redesignating “the second subparagraph (D)” as (E), was executed by making the redesignation for the subpar. (D) relating to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c/a"},"text":"section 77c(a) of this title","children":[],"tail":" to reflect the probable intent of Congress. Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s76001/b/1"},"text":"Pub. L. 114–94, § 76001(b)(1)","children":[],"tail":", redesignated subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s76001/b/2"},"text":"Pub. L. 114–94, § 76001(b)(2)","children":[],"tail":"–(4), added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/s305/a/2"},"text":"Pub. L. 112–106, § 305(a)(2)","children":[],"tail":", added subpar. (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/s401/b"},"text":"Pub. L. 112–106, § 401(b)","children":[],"tail":", added subpar. (D) relating to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c/b/2"},"text":"section 77c(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/s305/a/1"},"text":"Pub. L. 112–106, § 305(a)(1)","children":[],"tail":", redesignated subpar. (C), relating to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c/a"},"text":"section 77c(a) of this title","children":[],"tail":", as (D). Former subpar (D) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/s305/a/1"},"text":"Pub. L. 112–106, § 305(a)(1)","children":[],"tail":", redesignated subpar. (D) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/s305/b/2"},"text":"Pub. L. 112–106, § 305(b)(2)","children":[],"tail":", substituted “, in connection with securities or securities transactions” for “with respect to fraud or deceit, or unlawful conduct by a broker or dealer, in connection with securities or securities transactions.” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/s305/d/2"},"text":"Pub. L. 112–106, § 305(d)(2)","children":[],"tail":", which directed amendment of subsec. (c)(1) by substituting “, dealer, or funding portal” for “or dealer”, was executed by making the substitution in subpar. (A)(ii) as added by "},{"tag":"ref","attrib":{"href":"/us/pl/112/106/s305/b/2"},"text":"Pub. L. 112–106, § 305(b)(2)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/s305/c"},"text":"Pub. L. 112–106, § 305(c)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s985/a/2/A"},"text":"Pub. L. 111–203, § 985(a)(2)(A)","children":[],"tail":", substituted “(C) a security” for “(C) is a security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s985/a/2/B"},"text":"Pub. L. 111–203, § 985(a)(2)(B)","children":[],"tail":", substituted “State or” for “State, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353/s301/a/4/A"},"text":"Pub. L. 105–353, § 301(a)(4)(A)","children":[],"tail":", inserted “, or authorized for listing,” after “Exchange, or listed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353/s302"},"text":"Pub. L. 105–353, § 302","children":[],"tail":", substituted “paragraph (4), (10), or (11)” for “paragraph (4) or (11)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(i), (C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353/s301/a/4/B"},"text":"Pub. L. 105–353, § 301(a)(4)(B)","children":[],"tail":", (C), made technical amendments to references in original act which appear in text as references to "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353/s301/a/4/D"},"text":"Pub. L. 105–353, § 301(a)(4)(D)","children":[],"tail":", substituted “section 77b(a)(10)” for “section 77b(10)” and “subparagraphs (a) and (b)” for “subparagraphs (A) and (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353/s301/a/4/E"},"text":"Pub. L. 105–353, § 301(a)(4)(E)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353/s301/a/4/F"},"text":"Pub. L. 105–353, § 301(a)(4)(F)","children":[],"tail":", substituted “The term” for “For purposes of this paragraph, the term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/290"},"text":"Pub. L. 104–290","children":[],"tail":" substituted “Exemption from State regulation of securities offerings” for “State control of securities” as section catchline and amended text generally. Prior to amendment, text read as follows: “Nothing in this subchapter shall affect the jurisdiction of the securities commission (or any agency or office performing like functions) of any State or Territory of the United States, or the District of Columbia, over any security or any person.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e7439c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e7439d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77e7439e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Clarification of the Preservation of State Enforcement Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106/tIII/s305/b/1"},"text":"Pub. L. 112–106, title III, § 305(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-04-05"},"text":"Apr. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/322"},"text":"126 Stat. 322","children":[],"tail":", provided that: The amendments made by subsection (a) [amending this section] relate solely to State registration, documentation, and offering requirements, as described under section 18(a) of [the] Securities Act of 1933 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77r/a"},"text":"15 U.S.C. 77r(a)","children":[],"tail":"), and shall have no impact or limitation on other State authority to take enforcement action with regard to an issuer, funding portal, or any other person or entity using the exemption from registration provided by section 4(6) [probably means “section 4(a)(6)”] of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77d/a/6"},"text":"15 U.S.C. 77d(a)(6)","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77e7439f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study and Report on Uniformity of State Regulatory Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/290/tI/s102/b"},"text":"Pub. L. 104–290, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3420"},"text":"110 Stat. 3420","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/290/tI/s102/b"},"text":"“The Commission shall conduct a study, after consultation with States, issuers, brokers, and dealers, on the extent to which uniformity of State regulatory requirements for securities or securities transactions has been achieved for securities that are not covered securities (within the meaning of section 18 of the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77r"},"text":"15 U.S.C. 77r","children":[],"tail":"], as amended by paragraph (1) of this subsection). Not later than 1 year after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"], the Commission shall submit a report to the Congress on the results of such study.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77e743a0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77e743a1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Securities and Exchange Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 10 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
