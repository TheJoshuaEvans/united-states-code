{"tag":"section","attrib":{"id":"id7a985aa6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013"},"text":null,"children":[{"tag":"num","attrib":{"value":"9013"},"text":"§ 9013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Navigator pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a985aa7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a985aa8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administration” means the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985aa9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985aaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community navigator services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community navigator services” means the outreach, education, and technical assistance provided by community navigators that target eligible businesses to increase awareness of, and participation in, programs of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985aab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community navigator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community navigator” means a community organization, community financial institution as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a/36/A"},"text":"section 636(a)(36)(A) of this title","children":[],"tail":", or other private nonprofit organization engaged in the delivery of community navigator services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985aac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible business” means any small business concern, with priority for small business concerns owned and controlled by women (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/n"},"text":"section 632(n) of this title","children":[],"tail":"), small business concerns owned and controlled by veterans (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/q"},"text":"section 632(q) of this title","children":[],"tail":"), and socially and economically disadvantaged small business concerns (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a/4/A"},"text":"section 637(a)(4)(A) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985aad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private nonprofit organization” means an entity that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985aae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “resource partner” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985aaf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business development center (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985ab0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a women’s business center (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s656"},"text":"section 656 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985ab1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a chapter of the Service Corps of Retired Executives (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/b/1/B"},"text":"section 637(b)(1)(B) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985ab2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small business concern” has the meaning given under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985ab3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, the Commonwealth of the Northern Mariana Islands, and Guam, or an agency, instrumentality, or fiscal agent thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985ab4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit of general local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit of general local government” means a county, city, town, village, or other general purpose political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a985ab5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Navigator pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a985ab6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Small Business Administration shall establish a Community Navigator pilot program to make grants to, or enter into contracts or cooperative agreements with, private nonprofit organizations, resource partners, States, Tribes, and units of local government to ensure the delivery of free community navigator services to current or prospective owners of eligible businesses in order to improve access to assistance programs and resources made available because of the COVID–19 pandemic by Federal, State, Tribal, and local entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985ab7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $100,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", for carrying out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a985ab8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a985ab9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop and implement a program to promote community navigator services to current or prospective owners of eligible businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985aba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Call center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a telephone hotline to offer information about Federal programs to assist eligible businesses and offer referral services to resource partners, community navigators, potential lenders, and other persons that the Administrator determines appropriate for current or prospective owners of eligible businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985abb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a985abc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach and education, in the 10 most commonly spoken languages in the United States, to current or prospective owners of eligible businesses on community navigator services and other Federal programs to assist eligible businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985abd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the website of the Administration to describe such community navigator services and other Federal programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a985abe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement an education campaign by advertising in media targeted to current or prospective owners of eligible businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a985abf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Administrator for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $75,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":", for carrying out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a985ac0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9013/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Administrator to make grants under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a985ac1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tV/s5004"},"text":"Pub. L. 117–2, title V, § 5004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/90"},"text":"135 Stat. 90","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a985ac2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a985ac3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a985ac4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Rescue Plan Act of 2021, and not as part of the CARES Act which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
