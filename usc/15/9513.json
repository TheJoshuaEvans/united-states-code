{"tag":"section","attrib":{"id":"id7ab04f28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513"},"text":null,"children":[{"tag":"num","attrib":{"value":"9513"},"text":"§ 9513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab04f29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to achieve the purposes of this chapter, the Under Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and analyze data, including data relating to the causes of the success or failure of minority business enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct research, studies, and surveys of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic conditions generally in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the conditions described in clause (i) particularly affect the development of minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide outreach, educational services, and technical assistance in, at a minimum, the 5 most commonly spoken languages in the United States to ensure that limited English proficient individuals receive culturally and linguistically appropriate access to the services and information provided by the Agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may perform an evaluation of programs carried out by the Under Secretary that are designed to assist the development of minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04f31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information clearinghouse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain an information clearinghouse for the collection and dissemination to relevant parties (including business owners and researchers) of demographic, economic, financial, managerial, and technical data relating to minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take such steps as the Under Secretary may determine to be necessary and desirable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" search for, collect, classify, coordinate, integrate, record, and catalog the data described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9513/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that is consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", protect the privacy of the minority business enterprises to which the data described in paragraph (1) relates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04f36-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tI/s100103"},"text":"Pub. L. 117–58, div. K, title I, § 100103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1450"},"text":"135 Stat. 1450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab04f37-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab04f38-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab04f39-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this division”, meaning div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1445"},"text":"135 Stat. 1445","children":[],"tail":", which is classified prinicpally to this chapter. For complete classification of division K to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
