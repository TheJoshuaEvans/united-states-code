{"tag":"section","attrib":{"id":"id7970c9d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1268"},"text":null,"children":[{"tag":"num","attrib":{"value":"1268"},"text":"§ 1268.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings in name of United States; subpenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All criminal proceedings and all libel or injunction proceedings for the enforcement, or to restrain violations, of this chapter shall be by and in the name of the United States. Subpenas for witnesses who are required to attend a court of the United States in any district may run into any other district in any such proceeding.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7970c9d2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s9"},"text":"Pub. L. 86–613, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/378"},"text":"74 Stat. 378","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7970c9d3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7970c9d4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7970c9d5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Secretary of Health, Education, and Welfare under this chapter transferred to Consumer Product Safety Commission, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079"},"text":"section 2079 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
