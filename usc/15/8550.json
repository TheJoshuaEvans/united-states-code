{"tag":"section","attrib":{"id":"id7a8a29d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550"},"text":null,"children":[{"tag":"num","attrib":{"value":"8550"},"text":"§ 8550.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements to Cooperative Observer Program of National Weather Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8a29d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary of Commerce for Oceans and Atmosphere, acting through the National Weather Service, shall improve the Cooperative Observer Program by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8a29d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing support to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8a29d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State-coordinated programs relating to the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a29d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States and regions where observations provided through the Program are scarce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a29d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with State weather service headquarters to increase participation in the Program and to add stations in States and regions described in paragraph (1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a29d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where feasible, ensuring that data streams from stations that have been contributing data to the Program for more than 50 years are maintained and continually staffed by volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a29d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizing the recruitment of new volunteers for the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a29d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that opportunities exist for automated reporting to lessen the burden on volunteers to collect and report data by hand; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a29d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that integrated reporting is available for qualitative observations that cannot be automated, such as drought conditions, snow observations, and hazardous weather events, to ensure that volunteers in the Program can report and upload observations quickly and easily.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a29da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with States and regions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than every 180 days, the National Weather Service shall coordinate with State and regional offices with respect to the status of Cooperative Observer Program stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a29db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8550/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Weather Service shall coordinate with other Federal agencies, including the Forest Service, the Department of Agriculture, and the United States Geological Survey, to leverage opportunities to grow the Cooperative Observer Program network and to more effectively use existing infrastructure, weather stations, and staff of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8a29dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s8"},"text":"Pub. L. 115–423, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5461"},"text":"132 Stat. 5461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a8a29dd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a8a29de-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a8a29df-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was enacted as part of the National Integrated Drought Information System Reauthorization Act of 2018, and not as part of the Weather Research and Forecasting Innovation Act of 2017 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
