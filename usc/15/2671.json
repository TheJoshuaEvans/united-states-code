{"tag":"section","attrib":{"id":"id7a06f00d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2671"},"text":null,"children":[{"tag":"num","attrib":{"value":"2671"},"text":"§ 2671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated in this subchapter for purposes of carrying out the provisions of this subchapter are in addition to amounts authorized to be appropriated under other provisions of law for radon-related activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a06f00e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tIII/s311"},"text":"Pub. L. 94–469, title III, § 311","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/551/s1/a"},"text":"Pub. L. 100–551, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2764"},"text":"102 Stat. 2764","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
