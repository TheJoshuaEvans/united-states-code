{"tag":"section","attrib":{"id":"id7ab04fc9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543"},"text":null,"children":[{"tag":"num","attrib":{"value":"9543"},"text":"§ 9543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational development relating to management and entrepreneurship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab04fca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall, whenever the Under Secretary determines such action is necessary or appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04fcb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the education and training of socially or economically disadvantaged individuals in subjects directly relating to business administration and management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fcc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage institutions of higher education, leaders in business and industry, and other public sector entities and private sector entities, particularly minority business enterprises, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04fcd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop programs to offer scholarships and fellowships, apprenticeships, and internships relating to business to socially or economically disadvantaged individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04fce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor seminars, conferences, and similar activities relating to business for the benefit of socially or economically disadvantaged individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fcf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate and accelerate curriculum design and improvement in support of development of minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and assist private institutions and organizations and public sector entities to undertake activities similar to the activities described in paragraphs (1), (2), and (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab04fd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parren J. Mitchell Entrepreneurship Education Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04fd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “eligible institution” means an institution of higher education described in any of paragraphs (1) through (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall award grants to eligible institutions to develop and implement entrepreneurship curricula.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution to which a grant is awarded under this subsection shall use the grant funds to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04fd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a curriculum that includes training in various skill sets needed by contemporary successful entrepreneurs, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab298c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business management and marketing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial management and accounting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competitive analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategic and succession planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology and technology adoption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab298d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human resources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the curriculum developed under subparagraph (A) at the eligible institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation timeline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall establish and publish a timeline under which an eligible institution to which a grant is awarded under this section shall carry out the requirements under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab298d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, the Under Secretary shall submit to all applicable committees of Congress, and as part of the annual budget submission of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", a report evaluating the awarding and use of grants under this subsection during the fiscal year immediately preceding the fiscal year in which the report is submitted, which shall include, with respect to the fiscal year covered by the report—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab298d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each curriculum developed and implemented under each grant awarded under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which each grant awarded under this section was awarded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab298d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9543/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of eligible entities that were recipients of grants awarded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab298d7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tII/s100203"},"text":"Pub. L. 117–58, div. K, title II, § 100203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1457"},"text":"135 Stat. 1457","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
