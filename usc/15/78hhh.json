{"tag":"section","attrib":{"id":"id7859b4ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78hhh"},"text":null,"children":[{"tag":"num","attrib":{"value":"78hhh"},"text":"§ 78hhh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examining authority functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each member of SIPC shall file with such member’s examining authority, or collection agent if a collection agent has been designated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78iii/a"},"text":"section 78iii(a) of this title","children":[],"tail":", such information (including reports of, and information with respect to, the gross revenues from the securities business of such member, including the composition thereof, transactions in securities effected by such member, and other information with respect to such member’s activities, whether in the securities business or otherwise, including customer accounts maintained, net capital employed, and activities conducted) as SIPC may determine to be necessary or appropriate for the purpose of making assessments under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78ddd"},"text":"section 78ddd of this title","children":[],"tail":". The examining authority or collection agent shall file with SIPC all or such part of such information (and such compilations and analyses thereof) as SIPC, by bylaw or rule, shall prescribe. No application, report, or document filed pursuant to this section shall be deemed to be filed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78r"},"text":"section 78r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7859b4af-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/598/s12"},"text":"Pub. L. 91–598, § 12","children":[],"tail":", formerly § 8, "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1653"},"text":"84 Stat. 1653","children":[],"tail":"; renumbered § 12 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/283"},"text":"Pub. L. 95–283","children":[],"tail":", §§ 9, 11, "},{"tag":"date","attrib":{"date":"1978-05-21"},"text":"May 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/260"},"text":"92 Stat. 260","children":[],"tail":", 268.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7859b4b0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7859b4b1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7859b4b2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/598/s12"},"text":"section 12 of Pub. L. 91–598","children":[],"tail":" was renumbered section 16 and is classified to section 78"},{"tag":"i","attrib":{},"text":"lll","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7859b4b3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/283"},"text":"Pub. L. 95–283","children":[],"tail":" inserted provisions relating to applicability to a collection agent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
