{"tag":"section","attrib":{"id":"id79ea407e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2234"},"text":null,"children":[{"tag":"num","attrib":{"value":"2234"},"text":"§ 2234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging adoption of standards for firefighter health and safety","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall promote adoption by fire services of national voluntary consensus standards for firefighter health and safety, including such standards for firefighter operations, training, staffing, and fitness, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ea407f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2234/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating fire services about such standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4080-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2234/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the adoption at all levels of government of such standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4081-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2234/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations on other ways in which the Federal Government can promote the adoption of such standards by fire services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ea4082-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498/s37"},"text":"Pub. L. 93–498, § 37","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/376/s7"},"text":"Pub. L. 110–376, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4060"},"text":"122 Stat. 4060","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
