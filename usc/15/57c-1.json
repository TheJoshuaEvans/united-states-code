{"tag":"section","attrib":{"id":"id77d1c079-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"57c–1"},"text":"§ 57c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff exchanges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d1c07a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77d1c07b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain or employ officers or employees of foreign government agencies on a temporary basis as employees of the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s42"},"text":"section 42 of this title","children":[],"tail":" or section 3101 or "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d1c07c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail officers or employees of the Commission to work on a temporary basis for appropriate foreign government agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d1c07d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reciprocity and reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The staff arrangements described in subsection (a) need not be reciprocal. The Commission may accept payment or reimbursement, in cash or in kind, from a foreign government agency to which this section is applicable, or payment or reimbursement made on behalf of such agency, for expenses incurred by the Commission, its members, and employees in carrying out such arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d1c07e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person appointed under subsection (a)(1) shall be subject to the provisions of law relating to ethics, conflicts of interest, corruption, and any other criminal or civil statute or regulation governing the standards of conduct for Federal employees that are applicable to the type of appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d1c07f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s25A"},"text":"Sept. 26, 1914, ch. 311, § 25A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s9"},"text":"Pub. L. 109–455, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3381"},"text":"120 Stat. 3381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d1c080-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id77d1c081-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"section 13 of Pub. L. 109–455","children":[],"tail":", see Effective Date of Repeal note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77d1c082-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id77d1c083-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed effective ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"Sept. 30, 2027","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"section 13 of Pub. L. 109–455","children":[],"tail":", as amended, set out as a Termination Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s44"},"text":"section 44 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
