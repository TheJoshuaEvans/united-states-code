{"tag":"section","attrib":{"id":"id789c89e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290e"},"text":null,"children":[{"tag":"num","attrib":{"value":"290e"},"text":"§ 290e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States copyright and renewal rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id789c89e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the limitations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s105"},"text":"section 105 of title 17","children":[],"tail":", the Secretary may secure copyright and renewal thereof on behalf of the United States as author or proprietor in all or any part of any standard reference data which he prepares or makes available under this chapter, and may authorize the reproduction and publication thereof by others."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789c89e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The publication or republication by the Government under this chapter, either separately or in a public document, of any material in which copyright is subsisting shall not be taken to cause any abridgment or annulment of the copyright or to authorize any use or appropriation of such material without the consent of the copyright proprietor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789c89e3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/396/s6"},"text":"Pub. L. 90–396, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-11"},"text":"July 11, 1968","children":[],"tail":", "},{"tag":"ref",