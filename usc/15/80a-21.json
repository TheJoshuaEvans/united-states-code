{"tag":"section","attrib":{"id":"id786cc709-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–21"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–21"},"text":"§ 80a–21.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans by management companies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any registered management company to lend money or property to any person, directly or indirectly, if—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id786cc70a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–21/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investment policies of such registered company, as recited in its registration statement and reports filed under this subchapter, do not permit such a loan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id786cc70b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–21/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person controls or is under common control with such registered company; except that the provisions of this paragraph shall not apply to any loan from a registered company to a company which owns all of the outstanding securities of such registered company, except directors’ qualifying shares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id786cc70c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 21, "},{"tag":"ref","attrib":{"href":"/us/stat/54/822"},"text":"54 Stat. 822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/181/tVI/s615"},"text":"Pub. L. 100–181, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1262"},"text":"101 Stat. 1262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id786cc70d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id786cc70e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id786cc70f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/181"},"text":"Pub. L. 100–181","children":[],"tail":" struck out “to the extension or renewal of any such loan made prior to "},{"tag":"date","attrib":{"date":"1940-03-15"},"text":"March 15, 1940","children":[],"tail":", or” after “shall not apply”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
