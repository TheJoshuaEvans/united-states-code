{"tag":"section","attrib":{"id":"id7a179103-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201"},"text":null,"children":[{"tag":"num","attrib":{"value":"3201"},"text":"§ 3201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes; coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a179104-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to encourage—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a179105-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conservation of energy supplied by gas utilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a179106-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the optimization of the efficiency of use of facilities and resources by gas utility systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a179107-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitable rates to gas consumers of natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a179108-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volume of total retail sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter applies to each gas utility in any calendar year, and to each proceeding relating to each gas utility in such year, if the total sales of natural gas by such utility for purposes other than resale exceeded 10 billion cubic feet during any calendar year beginning after ","children":[{"tag":"date","attrib":{"date":"1975-12-31"},"text":"December 31, 1975","children":[],"tail":", and before the immediately preceding calendar year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a179109-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of wholesale sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this chapter do not apply to the operations of a gas utility, or to proceedings respecting such operations, to the extent that such operations or proceedings relate to sales of natural gas for purposes of resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a17910a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of covered utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the beginning of each calendar year, the Secretary shall publish a list identifying each gas utility to which this chapter applies during such calendar year. Promptly after publication of such list, each State regulatory authority shall notify the Secretary of each gas utility on the list for which such State regulatory authority has ratemaking authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a17910b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIII/s301"},"text":"Pub. L. 95–617, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3149"},"text":"92 Stat. 3149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a17910c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a17910d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a17910e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of Secretary in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602"},"text":"section 2602 of Title 16","children":[],"tail":", Conservation, applies to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
