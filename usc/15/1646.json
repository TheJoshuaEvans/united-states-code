{"tag":"section","attrib":{"id":"id799baaf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646"},"text":null,"children":[{"tag":"num","attrib":{"value":"1646"},"text":"§ 1646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of annual percentage rates; implementation, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799baaf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual percentage rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall collect, publish, and disseminate to the public, on a demonstration basis in a number of standard metropolitan statistical areas to be determined by the Bureau, the annual percentage rates charged for representative types of nonsale credit by creditors in such areas. For the purpose of this section, the Bureau is authorized to require creditors in such areas to furnish information necessary for the Bureau to collect, publish, and disseminate such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799baaf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit card price and availability information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799baaf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall collect, on a semiannual basis, credit card price and availability information, including the information required to be disclosed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637/c"},"text":"section 1637(c) of this title","children":[],"tail":", from a broad sample of financial institutions which offer credit card services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baaf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sample requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The broad sample of financial institutions required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799baaf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 25 largest issuers of credit cards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799baafa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not less than 125 additional financial institutions selected by the Bureau in a manner that ensures—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id799baafb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an equitable geographical distribution within the sample; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id799baafc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the representation of a wide spectrum of institutions within the sample.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baafd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of information from sample","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each financial institution in the broad sample established pursuant to paragraph (2) shall report the information to the Bureau in accordance with such regulations or orders as the Bureau may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799baafe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of collected information; report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799baaff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the information collected pursuant to this subsection available to the public upon request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report such information semiannually to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1646/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau is authorized to enter into contracts or other arrangements with appropriate persons, organizations, or State agencies to carry out its functions under subsections (a) and (b) and to furnish financial assistance in support thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799bab02-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s136"},"text":"Pub. L. 90–321, title I, § 136","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s618/a"},"text":"Pub. L. 96–221, title VI, § 618(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/183"},"text":"94 Stat. 183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/583/s5"},"text":"Pub. L. 100–583, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2967"},"text":"102 Stat. 2967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799bab03-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799bab04-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799bab05-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/583"},"text":"Pub. L. 100–583","children":[],"tail":" added subsec. (b), redesignated former subsec. (b) as (c), and substituted “subsections (a) and (b)” for “subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799bab06-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799bab07-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799bab08-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on expiration of two years and six months after ","children":[{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", with all regulations, forms, and clauses required to be prescribed to be promulgated at least one year prior to such effective date, and allowing any creditor to comply with any amendments, in accordance with the regulations, forms, and clauses prescribed by the Board prior to such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s625"},"text":"section 625 of Pub. L. 96–221","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
