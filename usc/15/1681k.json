{"tag":"section","attrib":{"id":"id79ac4c51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681k"},"text":"§ 1681k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public record information for employment purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ac4c52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A consumer reporting agency which furnishes a consumer report for employment purposes and which for that purpose compiles and reports items of information on consumers which are matters of public record and are likely to have an adverse effect upon a consumer’s ability to obtain employment shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ac4c53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time such public record information is reported to the user of such consumer report, notify the consumer of the fact that public record information is being reported by the consumer reporting agency, together with the name and address of the person to whom such information is being reported; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ac4c54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain strict procedures designed to insure that whenever public record information which is likely to have an adverse effect on a consumer’s ability to obtain employment is reported it is complete and up to date. For purposes of this paragraph, items of public record relating to arrests, indictments, convictions, suits, tax liens, and outstanding judgments shall be considered up to date if the current public record status of the item at the time of the report is reported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ac4c55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for national security investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) does not apply in the case of an agency or department of the United States Government that seeks to obtain and use a consumer report for employment purposes, if the head of the agency or department makes a written finding as prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b/b/4/A"},"text":"section 1681b(b)(4)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ac4c56-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s613"},"text":"Pub. L. 90–321, title VI, § 613","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tVI/s601"},"text":"Pub. L. 91–508, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1133"},"text":"84 Stat. 1133","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/347/s4/b"},"text":"Pub. L. 105–347, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-02"},"text":"Nov. 2, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3210"},"text":"112 Stat. 3210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ac4c57-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79ac4c58-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79ac4c59-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/347"},"text":"Pub. L. 105–347","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ac4c5a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79ac4c5b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/347"},"text":"Pub. L. 105–347","children":[],"tail":" deemed to have same effective date as amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2403"},"text":"section 2403 of Pub. L. 104–208","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/347/s7"},"text":"section 7 of Pub. L. 105–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a"},"text":"section 1681a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79ac4c5c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of one hundred and eighty days following ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s504/d"},"text":"section 504(d) of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/508"},"text":"Pub. L. 91–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
