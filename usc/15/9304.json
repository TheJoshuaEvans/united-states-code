{"tag":"section","attrib":{"id":"id7aa923ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304"},"text":null,"children":[{"tag":"num","attrib":{"value":"9304"},"text":"§ 9304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships in sustainable chemistry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa923ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agencies participating in the Entity may facilitate and support, through financial, technical, or other assistance, the creation of partnerships between institutions of higher education, nongovernmental organizations, consortia, or companies across the value chain in the chemical industry, including small- and medium-sized enterprises, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa923ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create collaborative sustainable chemistry research, development, demonstration, technology transfer, and commercialization programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa923f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" train students and retrain professional scientists, engineers, and others involved in materials specification on the use of sustainable chemistry concepts and strategies by methods, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa923f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing or recognizing curricular materials and courses for undergraduate and graduate levels and for the professional development of scientists, engineers, and others involved in materials specification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa923f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicizing the availability of professional development courses in sustainable chemistry and recruiting professionals to pursue such courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa923f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sector participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for support under this section, a partnership in sustainable chemistry shall include at least one private sector organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa923f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting partnerships for support under this section, the agencies participating in the Entity shall also consider the extent to which the applicants are willing and able to demonstrate evidence of support for, and commitment to, the goals outlined in the strategic plan and report described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9302"},"text":"section 9302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa923f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial support provided under this section may not be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa923f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support or expand a regulatory chemical management program at an implementing agency under a State law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa923f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct or renovate a building or structure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa923f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9304/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the sale of a specific product, process, or technology, or to disparage a specific product, process, or technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa923f9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tII/s264"},"text":"Pub. L. 116–283, div. A, title II, § 264","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3501"},"text":"134 Stat. 3501","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
