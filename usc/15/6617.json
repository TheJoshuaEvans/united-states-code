{"tag":"section","attrib":{"id":"id7a5cd87f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617"},"text":null,"children":[{"tag":"num","attrib":{"value":"6617"},"text":"§ 6617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of penalties for certain year 2000 failures by small business concerns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5cd880-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd881-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency” means any executive agency, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", that has the authority to impose civil penalties on small business concerns;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd882-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “first-time violation” means a violation by a small business concern of a federally enforceable rule or regulation (other than a Federal rule or regulation that relates to the safety and soundness of the banking or monetary system or for the integrity of the National Securities markets, including protection of depositors and investors) caused by a Y2K failure if that Federal rule or regulation had not been violated by that small business concern within the preceding 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd883-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business concern” has the same meaning as a defendant described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6604/b/2/B"},"text":"section 6604(b)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd884-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of liaisons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", each agency shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd885-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a point of contact within the agency to act as a liaison between the agency and small business concerns with respect to problems arising out of Y2K failures and compliance with Federal rules or regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd886-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the name and phone number of the point of contact for the agency in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd887-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (d) and (e), no agency shall impose any civil money penalty on a small business concern for a first-time violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd888-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency shall provide a waiver of civil money penalties for a first-time violation, provided that a small business concern demonstrates, and the agency determines, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd889-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small business concern previously made a reasonable good faith effort to anticipate, prevent, and effectively remediate a potential Y2K failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd88a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a first-time violation occurred as a result of the Y2K failure of the small business concern or other entity, which significantly affected the small business concern’s ability to comply with a Federal rule or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd88b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first-time violation was unavoidable in the face of a Y2K failure or occurred as a result of efforts to prevent the disruption of critical functions or services that could result in harm to life or property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd88c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon identification of a first-time violation, the small business concern initiated reasonable and prompt measures to correct the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd88d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small business concern submitted notice to the appropriate agency of the first-time violation within a reasonable time not to exceed 5 business days from the time that the small business concern became aware that the first-time violation had occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd88e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency may impose civil money penalties authorized under Federal law on a small business concern for a first-time violation if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd88f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small business concern’s failure to comply with Federal rules or regulations resulted in actual harm, or constitutes or creates an imminent threat to public health, safety, or the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd890-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small business concern fails to correct the violation not later than 1 month after initial notification to the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd891-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6617/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to first-time violations caused by a Y2K failure occurring after ","children":[{"tag":"date","attrib":{"date":"2000-12-31"},"text":"December 31, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5cd892-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s18"},"text":"Pub. L. 106–37, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/202"},"text":"113 Stat. 202","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
