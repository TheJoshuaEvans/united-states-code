{"tag":"section","attrib":{"id":"id7a771700-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441"},"text":null,"children":[{"tag":"num","attrib":{"value":"7441"},"text":"§ 7441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity competitions and challenges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a771701-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Commerce, Director of the National Science Foundation, and Secretary of Homeland Security, in consultation with the Director of the Office of Personnel Management, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a771702-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support competitions and challenges under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of this title","children":[],"tail":" (as amended by section 105 of the America COMPETES Reauthorization Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/stat/124/3989"},"text":"124 Stat. 3989","children":[],"tail":")) or any other provision of law, as appropriate—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a771703-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify, develop, and recruit talented individuals to perform duties relating to the security of information technology in Federal, State, local, and tribal government agencies, and the private sector; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a771704-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate innovation in basic and applied cybersecurity research, technology development, and prototype demonstration that has the potential for application to the information technology activities of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771705-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the effective operation of the competitions and challenges under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a771706-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Participants in the competitions and challenges under subsection (a)(1) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a771707-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students enrolled in grades 9 through 12;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771708-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students enrolled in a postsecondary program of study leading to a baccalaureate degree at an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771709-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students enrolled in a postbaccalaureate program of study at an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a77170a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education and research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a77170b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a77170c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other groups or individuals that the Secretary of Commerce, Director of the National Science Foundation, and Secretary of Homeland Security determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a77170d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliation and cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Competitions and challenges under this section may be carried out through affiliation and cooperative agreements with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a77170e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a77170f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional, State, or school programs supporting the development of cyber professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771710-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal governments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771711-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other private sector organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a771712-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas of skill","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Competitions and challenges under subsection (a)(1)(A) shall be designed to identify, develop, and recruit exceptional talent relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a771713-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ethical hacking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771714-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" penetration testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771715-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vulnerability assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771716-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuity of system operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771717-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security in design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771718-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cyber forensics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a771719-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offensive and defensive cyber operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a77171a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas the Secretary of Commerce, Director of the National Science Foundation, and Secretary of Homeland Security consider necessary to fulfill the cybersecurity mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a77171b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Topics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting topics for competitions and challenges under subsection (a)(1), the Secretary of Commerce, Director of the National Science Foundation, and Secretary of Homeland Security—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a77171c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult widely both within and outside the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a77171d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may empanel advisory committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a77171e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7441/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Personnel Management may support, as appropriate, internships or other work experience in the Federal Government to the winners of the competitions and challenges under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a77171f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/274/tIII/s301"},"text":"Pub. L. 113–274, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2981"},"text":"128 Stat. 2981","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a771720-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a771721-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a771722-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"Section 3719 of this title","children":[],"tail":" (as amended by section 105 of the America COMPETES Reauthorization Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/stat/124/3989"},"text":"124 Stat. 3989","children":[],"tail":")), referred to in subsec. (a)(1), probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of this title","children":[],"tail":" as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/s105/a"},"text":"section 105(a) of Pub. L. 111–358","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
