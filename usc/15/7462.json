{"tag":"section","attrib":{"id":"id7a7960b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7462"},"text":null,"children":[{"tag":"num","attrib":{"value":"7462"},"text":"§ 7462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cybersecurity technical standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7960b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, in coordination with appropriate Federal authorities, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7960b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7462/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, ensure coordination of Federal agencies engaged in the development of international technical standards related to information system security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7960b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7462/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", develop and transmit to Congress a plan for ensuring such Federal agency coordination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7960b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with the private sector","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities specified in subsection (a)(1), the Director shall ensure consultation with appropriate private sector stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7960b7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/274/tV/s502"},"text":"Pub. L. 113–274, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2986"},"text":"128 Stat. 2986","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
