{"tag":"section","attrib":{"id":"id7a31d095-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4015"},"text":null,"children":[{"tag":"num","attrib":{"value":"4015"},"text":"§ 4015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review; admissibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a31d096-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District court review of grants or denials; erroneous determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary grants or denies, in whole or in part, an application for a certificate of review or for an amendment to a certificate, or revokes or modifies a certificate pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4014/b"},"text":"section 4014(b) of this title","children":[],"tail":", any person aggrieved by such determination may, within 30 days of the determination, bring an action in any appropriate district court of the United States to set aside the determination on the ground that such determination is erroneous."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d097-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive provision for review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (a), no action by the Secretary or the Attorney General pursuant to this subchapter shall be subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d098-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4015/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inadmissibility in antitrust proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary denies, in whole or in part, an application for a certificate of review or for an amendment to a certificate, or revokes or amends a certificate, neither the negative determination nor the statement of reasons therefor shall be admissible in evidence, in any administrative or judicial proceeding, in support of any claim under the antitrust laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a31d099-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/290/tIII/s305"},"text":"Pub. L. 97–290, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1243"},"text":"96 Stat. 1243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a31d09a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a31d09b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a31d09c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/290/s312"},"text":"section 312 of Pub. L. 97–290","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4011"},"text":"section 4011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
