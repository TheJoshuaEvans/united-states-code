{"tag":"section","attrib":{"id":"id7a57f5f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309"},"text":null,"children":[{"tag":"num","attrib":{"value":"6309"},"text":"§ 6309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a57f5f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Attorney General of the United States has reasonable cause to believe that a person is engaged in a violation of this chapter, the Attorney General may bring a civil action in the appropriate district court of the United States requesting such relief, including a permanent or temporary injunction, restraining order, or other order, against the person, as the Attorney General determines to be necessary to restrain the person from continuing to engage in, sanction, promote, or otherwise participate in a professional boxing match in violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managers, promoters, matchmakers, and licensees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any manager, promoter, matchmaker, and licensee who knowingly violates, or coerces or causes any other person to violate, any provision of this chapter, other than section 6307a(b),","children":[{"tag":"ref","attrib":{"idref":"fn002549"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002549"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Section 6307a does not contain a subsec. (b)."}],"tail":" 6307b, 6307c, 6307d, 6307e, 6307f, or 6307h of this title, shall, upon conviction, be imprisoned for not more than 1 year or fined not more than $20,000, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of antiexploitation, sanctioning organization, or disclosure provisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who knowingly violates any provision of section 6307a(b),","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" 6307b, 6307c, 6307d, 6307e, 6307f, or 6307h of this title shall, upon conviction, be imprisoned for not more than 1 year or fined not more than—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a violation occurs in connection with a professional boxing match the gross revenues for which exceed $2,000,000, an additional amount which bears the same ratio to $100,000 as the amount of such revenues compared to $2,000,000, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member or employee of a boxing commission, any person who administers or enforces State boxing laws, and any member of the Association of Boxing Commissions who knowingly violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6308/a"},"text":"section 6308(a) of this title","children":[],"tail":" shall, upon conviction, be imprisoned for not more than 1 year or fined not more than $20,000, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boxers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any boxer who knowingly violates any provision of this chapter shall, upon conviction, be fined not more than $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the chief law enforcement officer of any State has reason to believe that a person or organization is engaging in practices which violate any requirement of this chapter, the State, as parens patriae, may bring a civil action on behalf of its residents in an appropriate district court of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enjoin the holding of any professional boxing match which the practice involves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce compliance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain the fines provided under subsection (b) or appropriate restitution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain such other relief as the court may deem appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any boxer who suffers economic injury as a result of a violation of any provision of this chapter may bring an action in the appropriate Federal or State court and recover the damages suffered, court costs, and reasonable attorneys fees and expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f600-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement against Federal Trade Commission, State Attorneys General, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter authorizes the enforcement of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f601-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of this chapter against the Federal Trade Commission, the United States Attorney General, or the chief legal officer of any State for acting or failing to act in an official capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f602-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (d) of this section against a State or political subdivision of a State, or any agency or instrumentality thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f603-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6309/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6307b"},"text":"section 6307b of this title","children":[],"tail":" against a boxer acting in his capacity as a boxer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f604-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s18"},"text":"Pub. L. 104–272, § 18","children":[],"tail":", formerly § 10, "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3312"},"text":"110 Stat. 3312","children":[],"tail":"; renumbered § 18 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/210"},"text":"Pub. L. 106–210","children":[],"tail":", §§ 4(1), 6, "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/322"},"text":"114 Stat. 322","children":[],"tail":", 326.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f605-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a57f606-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a57f607-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s6/1"},"text":"Pub. L. 106–210, § 6(1)","children":[],"tail":", inserted “, other than section 6307a(b), 6307b, 6307c, 6307d, 6307e, 6307f, or 6307h of this title,” after “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s6/3"},"text":"Pub. L. 106–210, § 6(3)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s6/2"},"text":"Pub. L. 106–210, § 6(2)","children":[],"tail":", (4), redesignated pars. (2) and (3) as (3) and (4), respectively, and in par. (3) substituted “section 6308(a)” for “section 6308”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s6/5"},"text":"Pub. L. 106–210, § 6(5)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a57f608-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a57f609-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"Jan. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23"},"text":"section 23 of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
