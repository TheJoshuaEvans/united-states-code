{"tag":"section","attrib":{"id":"id77d8ec1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j"},"text":null,"children":[{"tag":"num","attrib":{"value":"70j"},"text":"§ 70j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d8ec20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" None of the provisions of this subchapter shall be construed to apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77d8ec21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upholstery stuffing, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s70b/h"},"text":"section 70b(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outer coverings of furniture, mattresses, and box springs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" linings or interlinings incorporated primarily for structural purposes and not for warmth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filling or padding incorporated primarily for structural purposes and not for warmth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stiffenings, trimmings, facings, or interfacings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" backings of, and paddings or cushions to be used under, floor coverings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sewing and handicraft threads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bandages, surgical dressings, and other textile fiber products, the labeling of which is subject to the requirements of the Federal Food, Drug and Cosmetic Act of 1938, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waste materials not intended for use in a textile fiber product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" textile fiber products incorporated in shoes or overshoes or similar outer footwear;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d8ec2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" textile fiber products incorporated in headwear, handbags, luggage, brushes, lampshades, or toys, catamenial devices, adhesive tapes and adhesive sheets, cleaning cloths impregnated with chemicals, or diapers.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The exemption provided for any article by paragraph (3) or (4) of this subsection shall not be applicable if any representation as to fiber content of such article is made in any advertisement, label, or other means of identification covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s70b"},"text":"section 70b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d8ec2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may exclude from the provisions of this subchapter other textile fiber products (1) which have an insignificant or inconsequential textile fiber content, or (2) with respect to which the disclosure of textile fiber content is not necessary for the protection of the ultimate consumer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d8ec2d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/897/s12"},"text":"Pub. L. 85–897, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1723"},"text":"72 Stat. 1723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d8ec2e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d8ec2f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77d8ec30-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug and Cosmetic Act of 1938, referred to in subsec. (a)(8), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
