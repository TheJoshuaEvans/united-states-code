{"tag":"section","attrib":{"id":"id79a0656d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1666i–1"},"text":"§ 1666i–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits on interest rate, fee, and finance charge increases applicable to outstanding balances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a0656e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any credit card account under an open end consumer credit plan, no creditor may increase any annual percentage rate, fee, or finance charge applicable to any outstanding balance, except as permitted under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a0656f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition under subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a06570-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an increase in an annual percentage rate upon the expiration of a specified period of time, provided that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06571-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to commencement of that period, the creditor disclosed to the consumer, in a clear and conspicuous manner, the length of the period and the annual percentage rate that would apply after expiration of the period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06572-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased annual percentage rate does not exceed the rate disclosed pursuant to subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06573-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased annual percentage rate is not applied to transactions that occurred prior to commencement of the period;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06574-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in a variable annual percentage rate in accordance with a credit card agreement that provides for changes in the rate according to operation of an index that is not under the control of the creditor and is available to the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06575-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an increase due to the completion of a workout or temporary hardship arrangement by the obligor or the failure of the obligor to comply with the terms of a workout or temporary hardship arrangement, provided that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06576-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual percentage rate, fee, or finance charge applicable to a category of transactions following any such increase does not exceed the rate, fee, or finance charge that applied to that category of transactions prior to commencement of the arrangement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06577-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creditor has provided the obligor, prior to the commencement of such arrangement, with clear and conspicuous disclosure of the terms of the arrangement (including any increases due to such completion or failure); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06578-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an increase due solely to the fact that a minimum payment by the obligor has not been received by the creditor within 60 days after the due date for such payment, provided that the creditor shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06579-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, together with the notice of such increase required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637/i"},"text":"section 1637(i) of this title","children":[],"tail":", a clear and conspicuous written statement of the reason for the increase and that the increase will terminate not later than 6 months after the date on which it is imposed, if the creditor receives the required minimum payments on time from the obligor during that period; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a0657a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate such increase not later than 6 months after the date on which it is imposed, if the creditor receives the required minimum payments on time during that period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a0657b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of outstanding balance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a0657c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The creditor shall not change the terms governing the repayment of any outstanding balance, except that the creditor may provide the obligor with one of the methods described in paragraph (2) of repaying any outstanding balance, or a method that is no less beneficial to the obligor than one of those methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a0657d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The methods described in this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a0657e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amortization period of not less than 5 years, beginning on the effective date of the increase set forth in the notice required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637/i"},"text":"section 1637(i) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a0657f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a required minimum periodic payment that includes a percentage of the outstanding balance that is equal to not more than twice the percentage required before the effective date of the increase set forth in the notice required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637/i"},"text":"section 1637(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06580-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outstanding balance defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “outstanding balance” means the amount owed on a credit card account under an open end consumer credit plan as of the end of the 14th day after the date on which the creditor provides notice of an increase in the annual percentage rate, fee, or finance charge in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1637/i"},"text":"section 1637(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a06581-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s171"},"text":"Pub. L. 90–321, title I, § 171","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tI/s101/b/2"},"text":"Pub. L. 111–24, title I, § 101(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1736"},"text":"123 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a06582-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a06583-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79a06584-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/s171"},"text":"section 171 of Pub. L. 90–321","children":[],"tail":" was renumbered section 173 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1666j"},"text":"section 1666j of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a06585-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a06586-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/s3"},"text":"section 3 of Pub. L. 111–24","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
