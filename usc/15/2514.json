{"tag":"section","attrib":{"id":"id79f16baf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2514"},"text":null,"children":[{"tag":"num","attrib":{"value":"2514"},"text":"§ 2514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f16bb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Secretary of Energy, for purposes of carrying out this chapter, (1) not to exceed $30,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":", except that at least $10,000,000 of such authorization shall be allocated for battery research and development; (2) not to exceed $40,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":"; (3) not to exceed $25,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":"; (4) not to exceed $20,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":"; and (5) not to exceed $45,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":". Any amount appropriated pursuant to this section shall remain available until expended, and any amount authorized for any fiscal year prior to the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", but not appropriated, may be appropriated for any succeeding fiscal year through the fiscal year ending "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f16bb1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any moneys received by the Secretary of Energy from vehicle sales or leases or other activities under this chapter may be retained and used for purposes of carrying out this chapter, notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":", and may remain available until expended; but the amount authorized to be appropriated for any fiscal year under subsection (a) shall be reduced by the amount of the moneys so received in that year."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f16bb2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/413/s16"},"text":"Pub. L. 94–413, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-17"},"text":"Sept. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1270"},"text":"90 Stat. 1270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIII/s301/a"},"text":"Pub. L. 95–91, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/577"},"text":"91 Stat. 577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f16bb3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f16bb4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79f16bb5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":"” substituted for “section 3617 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s484"},"text":"31 U.S.C. 484","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f16bb6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79f16bb7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Energy” substituted in text for “Administrator” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/s301/a"},"text":"section 301(a) of Pub. L. 95–91","children":[],"tail":", see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2502"},"text":"section 2502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
