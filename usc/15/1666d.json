{"tag":"section","attrib":{"id":"id799df548-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1666d"},"text":"§ 1666d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of credit balances","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever a credit balance in excess of $1 is created in connection with a consumer credit transaction through (1) transmittal of funds to a creditor in excess of the total balance due on an account, (2) rebates of unearned finance charges or insurance premiums, or (3) amounts otherwise owed to or held for the benefit of an obligor, the creditor shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799df549-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666d/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit the amount of the credit balance to the consumer’s account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799df54a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666d/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refund any part of the amount of the remaining credit balance, upon request of the consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799df54b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666d/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a good faith effort to refund to the consumer by cash, check, or money order any part of the amount of the credit balance remaining in the account for more than six months, except that no further action is required in any case in which the consumer’s current location is not known by the creditor and cannot be traced through the consumer’s last known address or telephone number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799df54c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s165"},"text":"Pub. L. 90–321, title I, § 165","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/495/tIII/s306"},"text":"Pub. L. 93–495, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1514"},"text":"88 Stat. 1514","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s621/a"},"text":"Pub. L. 96–221, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/184"},"text":"94 Stat. 184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df54d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799df54e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799df54f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" substituted provisions relating to duties of creditor whenever a credit balance in excess of $1 is created in connection with a consumer credit transaction, for provisions relating to duties of creditor whenever an obligor transmits funds to creditor in excess of the total balance due on an open end consumer credit account."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df550-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799df551-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" effective on expiration of two years and six months after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", with all regulations, forms, and clauses required to be prescribed to be promulgated at least one year prior to such effective date, and allowing any creditor to comply with any amendments, in accordance with the regulations, forms, and clauses prescribed by the Board prior to such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s625"},"text":"section 625 of Pub. L. 96–221","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
