{"tag":"section","attrib":{"id":"id77e4d354-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q"},"text":null,"children":[{"tag":"num","attrib":{"value":"77q"},"text":"§ 77q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent interstate transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e4d355-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of interstate commerce for purpose of fraud or deceit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person in the offer or sale of any securities (including security-based swaps) or any security-based swap agreement (as defined in section 78c(a)(78) ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) by the use of any means or instruments of transportation or communication in interstate commerce or by use of the mails, directly or indirectly—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d356-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employ any device, scheme, or artifice to defraud, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d357-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain money or property by means of any untrue statement of a material fact or any omission to state a material fact necessary in order to make the statements made, in light of the circumstances under which they were made, not misleading; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d358-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in any transaction, practice, or course of business which operates or would operate as a fraud or deceit upon the purchaser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d359-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of interstate commerce for purpose of offering for sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person, by the use of any means or instruments of transportation or communication in interstate commerce or by the use of the mails, to publish, give publicity to, or circulate any notice, circular, advertisement, newspaper, article, letter, investment service, or communication which, though not purporting to offer a security for sale, describes such security for a consideration received or to be received, directly or indirectly, from an issuer, underwriter, or dealer, without fully disclosing the receipt, whether past or prospective, of such consideration and the amount thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d35a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions of section 77c not applicable to this section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exemptions provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c"},"text":"section 77c of this title","children":[],"tail":" shall not apply to the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d35b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority with respect to security-based swap agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Commission under this section with respect to security-based swap agreements (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/78"},"text":"section 78c(a)(78) of this title","children":[],"tail":") shall be subject to the restrictions and limitations of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b–1/b"},"text":"section 77b–1(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e4d35c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 17, "},{"tag":"ref","attrib":{"href":"/us/stat/48/84"},"text":"48 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-10/ch667"},"text":"Aug. 10, 1954, ch. 667","children":[],"tail":", title I, § 10, "},{"tag":"ref","attrib":{"href":"/us/stat/68/686"},"text":"68 Stat. 686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tIII/s302/b"},"text":"Pub. L. 106–554, § 1(a)(5) [title III, § 302(b), (c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–452; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s762/c/2"},"text":"Pub. L. 111–203, title VII, § 762(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1759"},"text":"124 Stat. 1759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e4d35d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e4d35e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77e4d35f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/78"},"text":"Section 78c(a)(78) of this title","children":[],"tail":", referred to in subsec. (a), was in the original “section 3(a)(78) of the Securities Exchange Act”, and was translated as meaning section 3(a)(78) of "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e4d360-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s762/c/2/A"},"text":"Pub. L. 111–203, § 762(c)(2)(A)","children":[],"tail":", in introductory provisions, inserted “(including security-based swaps)” after “securities” and substituted “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/78"},"text":"section 78c(a)(78) of this title","children":[],"tail":")” for “(as defined in section 206B of the Gramm-Leach-Bliley Act)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s762/c/2/B"},"text":"Pub. L. 111–203, § 762(c)(2)(B)","children":[],"tail":", substituted “78c(a)(78) of this title” for “206B of the Gramm-Leach-Bliley Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tIII/s302/b"},"text":"Pub. L. 106–554, § 1(a)(5) [title III, § 302(b)]","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “It shall be unlawful for any person in the offer or sale of any securities by the use of any means or instruments of transportation or communication in interstate commerce or by the use of the mails, directly or indirectly—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to employ any device, scheme, or artifice to defraud, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to obtain money or property by means of any untrue statement of a material fact or any omission to state a material fact necessary in order to make the statements made, in the light of the circumstances under which they were made, not misleading, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) to engage in any transaction, practice, or course of business which operates or would operate as a fraud or deceit upon the purchaser.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tIII/s302/c"},"text":"Pub. L. 106–554, § 1(a)(5) [title III, § 302(c)]","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", inserted “offer or” before “sale” in introductory text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e4d361-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e4d362-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the later of 360 days after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle B (§§ 761–774) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle B, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s774"},"text":"section 774 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e4d363-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1954 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", effective 60 days after "},{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", see note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
