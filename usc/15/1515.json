{"tag":"section","attrib":{"id":"id7983dca9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1515"},"text":null,"children":[{"tag":"num","attrib":{"value":"1515"},"text":"§ 1515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records, etc., of bureaus transferred to Department of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The official records and papers on file in and pertaining exclusively to the business of any bureau, office, department, or branch of the public service transferred to the Department of Commerce, together with the furniture in use in such bureau, office, department, or branch of the public service, are transferred to the Department of Commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7983dcaa-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s4"},"text":"Feb. 14, 1903, ch. 552, § 4","children":[],"tail":" (part), "},{"tag":"ref","attrib":{"href":"/us/stat/32/826"},"text":"32 Stat. 826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7983dcab-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7983dcac-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7983dcad-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s598"},"text":"section 598 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on the second par. of section 4 of act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":". The first par. of section 4 is classified to sections 1511 and 1516 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7983dcae-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7983dcaf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141"},"text":"Act Mar. 4, 1913, ch. 141","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":", provided that the Department of Commerce and Labor and Secretary of Commerce and Labor were to be thereafter called the Department of Commerce and Secretary of Commerce and that the act creating the Department of Commerce and Labor (act "},{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":") was amended accordingly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
