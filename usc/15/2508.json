{"tag":"section","attrib":{"id":"id79ef2269-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2508"},"text":null,"children":[{"tag":"num","attrib":{"value":"2508"},"text":"§ 2508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement and protection of small business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ef226a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to participate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall take such steps as are feasible to assure that small business concerns have a realistic and adequate opportunity to participate in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ef226b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist in accomplishing the objectives of subsection (a), the Secretary of Energy shall reserve, for contracts with small business concerns, a reasonable portion of the funds made available pursuant to this chapter for research, development, or demonstration of electric or hybrid vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ef226c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract terms and conditions; planning grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall, in addition to the requirements set forth in subsections (a) and (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ef226d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2508/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in all contracts for research, development, or demonstration of electric or hybrid vehicles such terms, conditions, and payment schedules as may assist in meeting the needs of small business concerns, and shall take steps to avoid the inclusion in such contracts of any terms, conditions, or penalties which would tend to prevent such concerns from participating in the program under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef226e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2508/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make planning grants available to qualified small business concerns which require assistance in developing, submitting, and entering into such contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ef226f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/413/s9"},"text":"Pub. L. 94–413, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-17"},"text":"Sept. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1266"},"text":"90 Stat. 1266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIII/s301/a"},"text":"Pub. L. 95–91, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/577"},"text":"91 Stat. 577","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ef2270-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ef2271-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79ef2272-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Energy” substituted in text for “Administrator” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/s301/a"},"text":"section 301(a) of Pub. L. 95–91","children":[],"tail":", see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2502"},"text":"section 2502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
