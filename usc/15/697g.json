{"tag":"section","attrib":{"id":"id7932af4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g"},"text":null,"children":[{"tag":"num","attrib":{"value":"697g"},"text":"§ 697g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreclosure and liquidation of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7932af4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with this section, the Administration shall delegate to any qualified State or local development company (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697/e"},"text":"section 697(e) of this title","children":[],"tail":") that meets the eligibility requirements of subsection (b)(1) the authority to foreclose and liquidate, or to otherwise treat in accordance with this section, defaulted loans in its portfolio that are funded with the proceeds of debentures guaranteed by the Administration under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for delegation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified State or local development company shall be eligible for a delegation of authority under subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the company—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has participated in the loan liquidation pilot program established by the Small Business Programs Improvement Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s695"},"text":"15 U.S.C. 695","children":[],"tail":" note), as in effect on the day before promulgation of final regulations by the Administration implementing this section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is participating in the Premier Certified Lenders Program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697e"},"text":"section 697e of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 3 fiscal years immediately prior to seeking such a delegation, has made an average of not less than 10 loans per year that are funded with the proceeds of debentures guaranteed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the company—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has one or more employees—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7932af58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with not less than 2 years of substantive, decision-making experience in administering the liquidation and workout of problem loans secured in a manner substantially similar to loans funded with the proceeds of debentures guaranteed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s697"},"text":"section 697 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have completed a training program on loan liquidation developed by the Administration in conjunction with qualified State and local development companies that meet the requirements of this paragraph; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Administration documentation demonstrating that the company has contracted with a qualified third-party to perform any liquidation activities and secures the approval of the contract by the Administration with respect to the qualifications of the contractor and the terms and conditions of liquidation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request the Administration shall examine the qualifications of any company described in subsection (a) to determine if such company is eligible for the delegation of authority under this section. If the Administration determines that a company is not eligible, the Administration shall provide the company with the reasons for such ineligibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of delegated authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each qualified State or local development company to which the Administration delegates authority under section ","children":[{"tag":"ref","attrib":{"idref":"fn002274"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002274"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) may with respect to any loan described in subsection (a)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform all liquidation and foreclosure functions, including the purchase in accordance with this subsection of any other indebtedness secured by the property securing the loan, in a reasonable and sound manner according to commercially accepted practices, pursuant to a liquidation plan approved in advance by the Administration under paragraph (2)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" litigate any matter relating to the performance of the functions described in subparagraph (A), except that the Administration may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" defend or bring any claim if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7932af61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outcome of the litigation may adversely affect the Administration’s management of the loan program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s696"},"text":"section 696 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administration is entitled to legal remedies not available to a qualified State or local development company and such remedies will benefit either the Administration or the qualified State or local development company; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the conduct of any such litigation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take other appropriate actions to mitigate loan losses in lieu of total liquidation or foreclosures, including the restructuring of a loan in accordance with prudent loan servicing practices and pursuant to a workout plan approved in advance by the Administration under paragraph (2)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration approval","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation plan","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before carrying out functions described in paragraph (1)(A), a qualified State or local development company shall submit to the Administration a proposed liquidation plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration action on plan","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7932af69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 business days after a liquidation plan is received by the Administration under clause (i), the Administration shall approve or reject the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of no decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any plan that cannot be approved or denied within the 15-day period required by subclause (I), the Administration shall within such period provide in accordance with subparagraph (E) notice to the company that submitted the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Routine actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out functions described in paragraph (1)(A), a qualified State or local development company may undertake routine actions not addressed in a liquidation plan without obtaining additional approval from the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of indebtedness","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out functions described in paragraph (1)(A), a qualified State or local development company shall submit to the Administration a request for written approval before committing the Administration to the purchase of any other indebtedness secured by the property securing a defaulted loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration action on request","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7932af6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 business days after receiving a request under clause (i), the Administration shall approve or deny the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of no decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any request that cannot be approved or denied within the 15-day period required by subclause (I), the Administration shall within such period provide in accordance with subparagraph (E) notice to the company that submitted the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workout plan","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out functions described in paragraph (1)(C), a qualified State or local development company shall submit to the Administration a proposed workout plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration action on plan","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7932af74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 business days after a workout plan is received by the Administration under clause (i), the Administration shall approve or reject the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7932af75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of no decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any workout plan that cannot be approved or denied within the 15-day period required by subclause (I), the Administration shall within such period provide in accordance with subparagraph (E) notice to the company that submitted the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compromise of indebtedness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out functions described in paragraph (1)(A), a qualified State or local development company may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider an offer made by an obligor to compromise the debt for less than the full amount owing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to such an offer, release any obligor or other party contingently liable, if the company secures the written approval of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice of no decision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any notice provided by the Administration under subparagraph (A)(ii)(II), (B)(ii)(II), or (C)(ii)(II)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall state the specific reason for the Administration’s inability to act on a plan or request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include an estimate of the additional time required by the Administration to act on the plan or request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administration cannot act because insufficient information or documentation was provided by the company submitting the plan or request, shall specify the nature of such additional information or documentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out functions described in paragraph (1), a qualified State or local development company shall take no action that would result in an actual or apparent conflict of interest between the company (or any employee of the company) and any third party lender, associate of a third party lender, or any other person participating in a liquidation, foreclosure, or loss mitigation action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or revocation of authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administration may revoke or suspend a delegation of authority under this section to any qualified State or local development company, if the Administration determines that the company—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not meet the requirements of subsection (b)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has violated any applicable rule or regulation of the Administration or any other applicable law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to comply with any reporting requirement that may be established by the Administration relating to carrying out of functions described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7932af83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7932af84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on information provided by qualified State and local development companies and the Administration, the Administration shall annually submit to the Committees on Small Business of the House of Representatives and of the Senate a report on the results of delegation of authority under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7932af85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under paragraph (1) shall include the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7932af86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to each loan foreclosed or liquidated by a qualified State or local development company under this section, or for which losses were otherwise mitigated by the company pursuant to a workout plan under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the project financed with the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total original dollar amount guaranteed by the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total dollar amount of the loan at the time of liquidation, foreclosure, or mitigation of loss;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total dollar losses resulting from the liquidation, foreclosure, or mitigation of loss; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total recoveries resulting from the liquidation, foreclosure, or mitigation of loss, both as a percentage of the amount guaranteed and the total cost of the project financed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to each qualified State or local development company to which authority is delegated under this section, the totals of each of the amounts described in clauses (i) through (v) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to all loans subject to foreclosure, liquidation, or mitigation under this section, the totals of each of the amounts described in clauses (i) through (v) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comparison between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7932af8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information provided under subparagraph (C) with respect to the 12-month period preceding the date on which the report is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7932af90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same information with respect to loans foreclosed and liquidated, or otherwise treated, by the Administration during the same period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7932af91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s697g/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of times that the Administration has failed to approve or reject a liquidation plan in accordance with subparagraph (A)(i), a workout plan in accordance with subparagraph (C)(i), or to approve or deny a request for purchase of indebtedness under subparagraph (B)(i), including specific information regarding the reasons for the Administration’s failure and any delays that resulted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7932af92-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tV/s510"},"text":"Pub. L. 85–699, title V, § 510","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tIII/s307/a"},"text":"Pub. L. 106–554, § 1(a)(9) [title III, § 307(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–685.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7932af93-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7932af94-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7932af95-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Small Business Programs Improvement Act of 1996, referred to in subsec. (b)(1)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dD"},"text":"Pub. L. 104–208, div. D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-724"},"text":"110 Stat. 3009–724","children":[],"tail":". Provisions relating to loan liquidation pilot program are contained in "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dD/tII/s204"},"text":"section 204 of title II of div. D of Pub. L. 104–208","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s695"},"text":"section 695 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1996 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7932af96-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7932af97-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Small Business of Senate changed to Committee on Small Business and Entrepreneurship of Senate. See Senate Resolution No. 123, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-06-29"},"text":"June 29, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7932af98-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/9/tIII/s307/b"},"text":"Pub. L. 106–554, § 1(a)(9) [title III, § 307(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–689, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/9/tIII/s307/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 150 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"], the Administrator shall issue such regulations as may be necessary to carry out section 510 of the Small Business Investment Act of 1958 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s697g"},"text":"15 U.S.C. 697g","children":[],"tail":"], as added by subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of pilot program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date on which final regulations are issued under paragraph (1), section 204 of the Small Business Programs Improvement Act of 1996 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dD"},"text":"Pub. L. 104–208, div. D","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s695"},"text":"15 U.S.C. 695","children":[],"tail":" note) shall cease to have effect.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
