{"tag":"section","attrib":{"id":"id7964bbda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1141i"},"text":"§ 1141i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of extension of protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7964bbdb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of extension of protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless a request for extension of protection is refused under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1141h"},"text":"section 1141h of this title","children":[],"tail":", the Director shall issue a certificate of extension of protection pursuant to the request and shall cause notice of such certificate of extension of protection to be published in the Official Gazette of the United States Patent and Trademark Office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7964bbdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of extension of protection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the date on which a certificate of extension of protection is issued under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7964bbdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such extension of protection shall have the same effect and validity as a registration on the Principal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bbde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of the international registration shall have the same rights and remedies as the owner of a registration on the Principal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7964bbdf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title XII, § 69, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13402"},"text":"Pub. L. 107–273, div. C, title III, § 13402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1918"},"text":"116 Stat. 1918","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
