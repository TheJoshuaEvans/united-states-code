{"tag":"section","attrib":{"id":"id7a6b0940-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108"},"text":null,"children":[{"tag":"num","attrib":{"value":"7108"},"text":"§ 7108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b0941-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administration” means the Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0942-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0943-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “control” means exercising the power to make policy decisions concerning a business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0944-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Council” means the National Women’s Business Council, established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7105"},"text":"section 7105 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0945-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Interagency Committee” means the Interagency Committee on Women’s Business Enterprise, established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7101"},"text":"section 7101 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0946-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “operate” means being actively involved in the day-to-day management of a business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0947-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “women’s business enterprise” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b0948-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business or businesses owned by a woman or a group of women; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0949-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment, maintenance, or development of a business or businesses by a woman or a group of women; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b094a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “women-owned business” means a small business which a woman or a group of women—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b094b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control and operate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b094c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7108/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" own not less than 51 percent of the business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b094d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/tIV/s408"},"text":"Pub. L. 100–533, title IV, § 408","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tIV/s413"},"text":"Pub. L. 103–403, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4197"},"text":"108 Stat. 4197","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
