{"tag":"section","attrib":{"id":"id7ab5095b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708"},"text":null,"children":[{"tag":"num","attrib":{"value":"9708"},"text":"§ 9708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Committee on Water Management and Infrastructure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab5095c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a committee, to be known as the “Interagency Committee on Water Management and Infrastructure” (in this section referred to as the “Water Policy Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab5095d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Water Policy Committee shall be composed of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab5095e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5095f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50960-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50961-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50962-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50963-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50964-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50965-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The heads of such other agencies as the co-chairs consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50966-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-chairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Water Policy Committee shall be co-chaired by the Secretary of the Interior and the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50967-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Water Policy Committee shall meet not less frequently than 6 times each year, at the call of the co-chairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50968-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General purpose and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Water Policy Committee shall ensure that agencies and departments across the Federal Government that engage in water-related matters, including water storage and supplies, water quality and restoration activities, water infrastructure, transportation on United States rivers and inland waterways, and water forecasting, work together where such agencies and departments have joint or overlapping responsibilities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab50969-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve interagency coordination among Federal agencies and departments on water resource management and water infrastructure issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5096a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate existing water-related Federal task forces, working groups, and other formal cross-agency initiatives, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5096b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prioritize managing the water resources of the United States and promoting resilience of the water-related infrastructure of the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab5096c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing water storage, water supply reliability, and drought resiliency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5096d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving water quality, source water protection, and nutrient management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5096e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting restoration activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5096f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving water systems, including with respect to drinking water, desalination, water reuse, wastewater, and flood control; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50970-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving water data management, research, modeling, and forecasting;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50971-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve interagency coordination of data management, access, modeling, and visualization with respect to water-related matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50972-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote integrated planning for Federal investments in water-related infrastructure to enhance coordination and protect taxpayer investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50973-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support workforce development and efforts to recruit, train, and retain professionals to operate and maintain essential drinking water, wastewater, flood control, hydropower, water delivery, and water storage facilities in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50974-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9708/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cross-agency priority research needs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", the Water Policy Committee shall develop and submit to Congress a list of research needs that includes needs for cross-agency research and coordination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab50975-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s13"},"text":"Pub. L. 117–316, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4414"},"text":"136 Stat. 4414","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
