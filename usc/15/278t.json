{"tag":"section","attrib":{"id":"id789a195d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t"},"text":null,"children":[{"tag":"num","attrib":{"value":"278t"},"text":"§ 278t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced communications research activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id789a195e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced communications research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789a195f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Assistant Secretary for Communications and Information, the Director of the National Science Foundation, and heads of other Federal agencies, as appropriate, shall carry out a program of measurement research for advanced communications technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a1960-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research areas may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789a1961-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radio frequency emissions and interference, including technologies and techniques to mitigate such emissions and interference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1962-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced antenna arrays and artificial intelligence systems capable of operating advanced antenna arrays;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1963-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" artificial intelligence systems to enable internet of things networks, immersive technology, and other advanced communications technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1964-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" network sensing and monitoring technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1965-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies to enable spectrum flexibility and agility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1966-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optical and quantum communications technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1967-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security of advanced communications systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1968-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1969-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resilient internet of things applications for advanced manufacturing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a196a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research areas determined necessary by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a196b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testbeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In coordination with the Assistant Secretary for Communications and Information, the private sector, and other Federal agencies as appropriate, the Director may develop and manage testbeds for research and development of advanced communications technologies, avoiding duplication of existing testbeds run by other agencies or the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a196c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities under this subsection, the Director shall seek input from other Federal agencies and from private sector stakeholders, on an ongoing basis, to help inform research and development priorities, including through workshops and other multistakeholder activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a196d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical roadmaps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the activities under this subsection, the Director shall convene industry, institutions of higher education, nonprofit organizations, Federal laboratories, and other Federal agencies engaged in advanced communications research and development to develop, and periodically update, coordinated technical roadmaps for advanced communications research in priority areas, such as those described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789a196e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advanced Spectrum and Communications Test Network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789a196f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in coordination with the Administrator of the National Telecommunications and Information Administration and heads of other Federal agencies, as appropriate, shall operate a national network of government, academic, and commercial test capabilities and facilities to be known as the National Advanced Spectrum and Communications Test Network (referred to in this section as “NASCTN”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a1970-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"NASCTN shall be for the purposes of facilitating and coordinating the use of intellectual capacity, modeling and simulation, laboratory facilities, and test facilities to meet national spectrum interests and challenges, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789a1971-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurements and analyses of electromagnetic propagation, radio systems characteristics, and operating techniques affecting the utilization of the electromagnetic spectrum in coordination with specialized, related research and analysis performed by other Federal agencies in their areas of responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1972-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research and analysis in the general field of telecommunications sciences in support of the Institute’s mission and in support of other Government agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1973-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing methodologies for testing, measuring, and setting guidelines for interference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1974-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting interference tests to better understand the impact of current and proposed Federal and commercial spectrum activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1975-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research and testing to improve spectrum interference tolerance, flexibility, agility, and interference mitigation methods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1976-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278t/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities as determined necessary by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789a1977-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s35"},"text":"Mar. 3, 1901, ch. 872, § 35","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10230/2"},"text":"Pub. L. 117–167, div. B, title II, § 10230(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1482"},"text":"136 Stat. 1482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
