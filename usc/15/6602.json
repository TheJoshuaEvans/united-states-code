{"tag":"section","attrib":{"id":"id7a5a675f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602"},"text":null,"children":[{"tag":"num","attrib":{"value":"6602"},"text":"§ 6602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a6760-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Y2K action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Y2K action”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a6761-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a civil action commenced in any Federal or State court, or an agency board of contract appeal proceeding, in which the plaintiff’s alleged harm or injury arises from or is related to an actual or potential Y2K failure, or a claim or defense arises from or is related to an actual or potential Y2K failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6762-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a civil action commenced in any Federal or State court by a government entity when acting in a commercial or contracting capacity; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6763-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an action brought by a government entity acting in a regulatory, supervisory, or enforcement capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6764-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Y2K failure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Y2K failure” means failure by any device or system (including any computer system and any microchip or integrated circuit embedded in another device or product), or any software, firmware, or other set or collection of processing instructions to process, to calculate, to compare, to sequence, to display, to store, to transmit, or to receive year-2000 date-related data, including failures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a6765-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deal with or account for transitions or comparisons from, into, and between the years 1999 and 2000 accurately;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6766-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize or accurately to process any specific date in 1999, 2000, or 2001; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6767-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accurately to account for the year 2000’s status as a leap year, including recognition and processing of the correct date on ","children":[{"tag":"date","attrib":{"date":"2000-02-29"},"text":"February 29, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6768-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “government entity” means an agency, instrumentality, or other entity of Federal, State, or local government (including multijurisdictional agencies, instrumentalities, and entities).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6769-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Material defect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “material defect” means a defect in any item, whether tangible or intangible, or in the provision of a service, that substantially prevents the item or service from operating or functioning as designed or according to its specifications. The term “material defect” does not include a defect that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a676a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an insignificant or de minimis effect on the operation or functioning of an item or computer program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a676b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affects only a component of an item or program that, as a whole, substantially operates or functions as designed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a676c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an insignificant or de minimis effect on the efficacy of the service provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a676d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal injury","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “personal injury” means physical injury to a natural person, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a676e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" death as a result of a physical injury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a676f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental suffering, emotional distress, or similar injuries suffered by that person in connection with a physical injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6770-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Northern Mariana Islands, the United States Virgin Islands, Guam, American Samoa, and any other territory or possession of the United States, and any political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6771-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract” means a contract, tariff, license, or warranty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6772-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative dispute resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “alternative dispute resolution” means any process or proceeding, other than adjudication by a court or in an administrative proceeding, to assist in the resolution of issues in controversy, through processes such as early neutral evaluation, mediation, minitrial, and arbitration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5a6773-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s3"},"text":"Pub. L. 106–37, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/187"},"text":"113 Stat. 187","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
