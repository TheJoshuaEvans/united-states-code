{"tag":"section","attrib":{"id":"id7a82fd04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206"},"text":null,"children":[{"tag":"num","attrib":{"value":"8206"},"text":"§ 8206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a82fd05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admitted insurer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “admitted insurer” means, with respect to a State, an insurer licensed to engage in the business of insurance in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliate” means, with respect to an insured, any entity that controls, is controlled by, or is under common control with the insured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affiliated group” means any group of entities that are all affiliated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity has “control” over another entity if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fd09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity directly or indirectly or acting through 1 or more other persons owns, controls, or has the power to vote 25 percent or more of any class of voting securities of the other entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity controls in any manner the election of a majority of the directors or trustees of the other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt commercial purchaser","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “exempt commercial purchaser” means any person purchasing commercial insurance that, at the time of placement, meets the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fd0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person employs or retains a qualified risk manager to negotiate insurance coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person has paid aggregate nationwide commercial property and casualty insurance premiums in excess of $100,000 in the immediately preceding 12 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a82fd0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The person meets at least 1 of the following criteria:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a82fd10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person possesses a net worth in excess of $20,000,000, as such amount is adjusted pursuant to clause (ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a82fd11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person generates annual revenues in excess of $50,000,000, as such amount is adjusted pursuant to clause (ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a82fd12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person employs more than 500 full-time or full-time equivalent employees per individual insured or is a member of an affiliated group employing more than 1,000 employees in the aggregate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a82fd13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is a not-for-profit organization or public entity generating annual budgeted expenditures of at least $30,000,000, as such amount is adjusted pursuant to clause (ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a82fd14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is a municipality with a population in excess of 50,000 persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a82fd15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective on the fifth January 1 occurring after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", and each fifth January 1 occurring thereafter, the amounts in subclauses (I), (II), and (IV) of clause (i) shall be adjusted to reflect the percentage change for such 5-year period in the Consumer Price Index for All Urban Consumers published by the Bureau of Labor Statistics of the Department of Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home State","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fd17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “home State” means, with respect to an insured—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a82fd18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State in which an insured maintains its principal place of business or, in the case of an individual, the individual’s principal residence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a82fd19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if 100 percent of the insured risk is located out of the State referred to in clause (i), the State to which the greatest percentage of the insured’s taxable premium for that insurance contract is allocated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affiliated groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than 1 insured from an affiliated group are named insureds on a single nonadmitted insurance contract, the term “home State” means the home State, as determined pursuant to subparagraph (A), of the member of the affiliated group that has the largest percentage of premium attributed to it under such insurance contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independently procured insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “independently procured insurance” means insurance procured directly by an insured from a nonadmitted insurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NAIC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NAIC” means the National Association of Insurance Commissioners or any successor entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonadmitted insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonadmitted insurance” means any property and casualty insurance permitted to be placed directly or through a surplus lines broker with a nonadmitted insurer eligible to accept such insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Admitted Insurance Model Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Non-Admitted Insurance Model Act” means the provisions of the Non-Admitted Insurance Model Act, as adopted by the NAIC on ","children":[{"tag":"date","attrib":{"date":"1994-08-03"},"text":"August 3, 1994","children":[],"tail":", and amended on "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-06"},"text":"December 6, 1997","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-02"},"text":"October 2, 1999","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2002-06-08"},"text":"June 8, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonadmitted insurer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “nonadmitted insurer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fd20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means, with respect to a State, an insurer not licensed to engage in the business of insurance in such State; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a risk retention group, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3901/a/4"},"text":"section 3901(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “premium tax” means, with respect to surplus lines or independently procured insurance coverage, any tax, fee, assessment, or other charge imposed by a government entity directly or indirectly based on any payment made as consideration for an insurance contract for such insurance, including premium deposits, assessments, registration fees, and any other compensation given in consideration for a contract of insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified risk manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified risk manager” means, with respect to a policyholder of commercial insurance, a person who meets all of the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fd24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person is an employee of, or third-party consultant retained by, the commercial policyholder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The person provides skilled services in loss prevention, loss reduction, or risk and insurance coverage analysis, and purchase of insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a82fd27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a82fd28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a bachelor’s degree or higher from an accredited college or university in risk management, business administration, finance, economics, or any other field determined by a State insurance commissioner or other State regulatory official or entity to demonstrate minimum competence in risk management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a82fd29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a82fd2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has 3 years of experience in risk financing, claims administration, loss prevention, risk and insurance analysis, or purchasing commercial lines of insurance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a82fd2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has—","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"id7a82fd2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II/bb/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designation as a Chartered Property and Casualty Underwriter (in this subparagraph referred to as “CPCU”) issued by the American Institute for CPCU/Insurance Institute of America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id7a82fd2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II/bb/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designation as an Associate in Risk Management (ARM) issued by the American Institute for CPCU/Insurance Institute of America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id7a82fd2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II/bb/CC"},"text":null,"children":[{"tag":"num","attrib":{"value":"CC"},"text":"(CC)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designation as Certified Risk Manager (CRM) issued by the National Alliance for Insurance Education & Research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id7a82fd2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II/bb/DD"},"text":null,"children":[{"tag":"num","attrib":{"value":"DD"},"text":"(DD)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designation as a RIMS Fellow (RF) issued by the Global Risk Management Institute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"id7a82fd30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/i/II/bb/EE"},"text":null,"children":[{"tag":"num","attrib":{"value":"EE"},"text":"(EE)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other designation, certification, or license determined by a State insurance commissioner or other State insurance regulatory official or entity to demonstrate minimum competency in risk management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a82fd31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a82fd32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 7 years of experience in risk financing, claims administration, loss prevention, risk and insurance coverage analysis, or purchasing commercial lines of insurance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a82fd33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has any 1 of the designations specified in subitems (AA) through (EE) of clause (i)(II)(bb);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a82fd34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 10 years of experience in risk financing, claims administration, loss prevention, risk and insurance coverage analysis, or purchasing commercial lines of insurance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a82fd35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/13/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a graduate degree from an accredited college or university in risk management, business administration, finance, economics, or any other field determined by a State insurance commissioner or other State regulatory official or entity to demonstrate minimum competence in risk management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinsurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reinsurance” means the assumption by an insurer of all or part of a risk undertaken originally by another insurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus lines broker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “surplus lines broker” means an individual, firm, or corporation which is licensed in a State to sell, solicit, or negotiate insurance on properties, risks, or exposures located or to be performed in a State with nonadmitted insurers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8206/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Northern Mariana Islands, the Virgin Islands, and American Samoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a82fd39-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tV/s527"},"text":"Pub. L. 111–203, title V, § 527","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1591"},"text":"124 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a82fd3a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a82fd3b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a82fd3c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
