{"tag":"section","attrib":{"id":"id7900a2b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s643"},"text":null,"children":[{"tag":"num","attrib":{"value":"643"},"text":"§ 643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair charge for use of Government-owned property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the fullest extent the Administration deems practicable, it shall make a fair charge for the use of Government-owned property and make and let contracts on a basis that will result in a recovery of the direct costs incurred by the Administration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7900a2b4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s14"},"text":"Pub. L. 85–536, § 2[14]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/395"},"text":"72 Stat. 395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7900a2b5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7900a2b6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7900a2b7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior similar provisions were contained in section 220 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-07-30/ch282/tII"},"text":"act July 30, 1953, ch. 282, title II","children":[],"tail":", "},{"tag":"ref","attrib":{