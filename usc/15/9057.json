{"tag":"section","attrib":{"id":"id7aa1f6c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057"},"text":null,"children":[{"tag":"num","attrib":{"value":"9057"},"text":"§ 9057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forbearance of residential mortgage loan payments for multifamily properties with Federally backed loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa1f6c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the covered period, a multifamily borrower with a Federally backed multifamily mortgage loan experiencing a financial hardship due, directly or indirectly, to the COVID–19 emergency may request a forbearance under the terms set forth in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f6c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A multifamily borrower with a Federally backed multifamily mortgage loan that was current on its payments as of ","children":[{"tag":"date","attrib":{"date":"2020-02-01"},"text":"February 1, 2020","children":[],"tail":", may submit an oral or written request for forbearance under subsection (a) to the borrower’s servicer affirming that the multifamily borrower is experiencing a financial hardship during the COVID–19 emergency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f6c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forbearance period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f6c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of an oral or written request for forbearance from a multifamily borrower, a servicer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document the financial hardship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the forbearance for up to 30 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the forbearance for up to 2 additional 30 day periods upon the request of the borrower provided that, the borrower’s request for an extension is made during the covered period, and, at least 15 days prior to the end of the forbearance period described under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to discontinue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A multifamily borrower shall have the option to discontinue the forbearance at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f6cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renter protections during forbearance period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A multifamily borrower that receives a forbearance under this section may not, for the duration of the forbearance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f6cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evict or initiate the eviction of a tenant from a dwelling unit located in or on the applicable property solely for nonpayment of rent or other fees or charges; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge any late fees, penalties, or other charges to a tenant described in paragraph (1) for late payment of rent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f6cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A multifamily borrower that receives a forbearance under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f6d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not require a tenant to vacate a dwelling unit located in or on the applicable property before the date that is 30 days after the date on which the borrower provides the tenant with a notice to vacate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not issue a notice to vacate under paragraph (1) until after the expiration of the forbearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f6d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f6d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable property","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable property”, with respect to a Federally backed multifamily mortgage loan, means the residential multifamily property against which the mortgage loan is secured by a lien.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally backed multifamily mortgage loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federally backed multifamily mortgage loan” includes any loan (other than temporary financing such as a construction loan) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is secured by a first or subordinate lien on residential multifamily real property designed principally for the occupancy of 5 or more families, including any such secured loan, the proceeds of which are used to prepay or pay off an existing loan secured by the same property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made in whole or in part, or insured, guaranteed, supplemented, or assisted in any way, by any officer or agency of the Federal Government or under or in connection with a housing or urban development program administered by the Secretary of Housing and Urban Development or a housing or related program administered by any other such officer or agency, or is purchased or securitized by the Federal Home Loan Mortgage Corporation or the Federal National Mortgage Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multifamily borrower","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"the term “multifamily borrower” means a borrower of a residential mortgage loan that is secured by a lien against a property comprising 5 or more dwelling units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" COVID–19 emergency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “COVID–19 emergency” means the national emergency concerning the novel coronavirus disease (COVID–19) outbreak declared by the President on ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":" under the National Emergencies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f6d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered period” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and ending on the sooner of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f6da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination date of the national emergency concerning the novel coronavirus disease (COVID–19) outbreak declared by the President on ","children":[{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":" under the National Emergencies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f6db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9057/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa1f6dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4023"},"text":"Pub. L. 116–136, div. A, title IV, § 4023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/491"},"text":"134 Stat. 491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa1f6dd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa1f6de-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7aa1f6df-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Emergencies Act, referred to in subsec. (f)(4), (5)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412"},"text":"Pub. L. 94–412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":", which is classified principally to chapter 34 (§ 1601 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"section 1601 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
