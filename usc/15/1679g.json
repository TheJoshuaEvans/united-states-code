{"tag":"section","attrib":{"id":"id79a2d6a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679g"},"text":"§ 1679g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a2d6aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who fails to comply with any provision of this subchapter with respect to any other person shall be liable to such person in an amount equal to the sum of the amounts determined under each of the following paragraphs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d6ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actual damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a2d6ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any actual damage sustained by such person as a result of such failure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d6ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount paid by the person to the credit repair organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punitive damages","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a2d6af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any action by an individual, such additional amount as the court may allow.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d6b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a class action, the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a2d6b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of the amount which the court may allow for each named plaintiff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a2d6b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of the amount which the court may allow for each other class member, without regard to any minimum individual recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorneys’ fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any successful action to enforce any liability under paragraph (1) or (2), the costs of the action, together with reasonable attorneys’ fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d6b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to be considered in awarding punitive damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of any liability of any credit repair organization under subsection (a)(2), the court shall consider, among other relevant factors—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d6b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency and persistence of noncompliance by the credit repair organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the noncompliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which such noncompliance was intentional; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any class action, the number of consumers adversely affected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a2d6b9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s409"},"text":"Pub. L. 90–321, title IV, § 409","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-459"},"text":"110 Stat. 3009–459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2d6ba-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a2d6bb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a2d6bc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable after the end of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", except with respect to contracts entered into by a credit repair organization before the end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s413"},"text":"section 413 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
