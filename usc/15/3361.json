{"tag":"section","attrib":{"id":"id7a1a0209-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361"},"text":null,"children":[{"tag":"num","attrib":{"value":"3361"},"text":"§ 3361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1a020a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential declaration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may declare a natural gas supply emergency (or extend a previously declared emergency) if he finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1a020b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a severe natural gas shortage, endangering the supply of natural gas for high-priority uses, exists or is imminent in the United States or in any region thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a020c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exercise of authorities under section 3362 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3363"},"text":"section 3363 of this title","children":[],"tail":" is reasonably necessary, having exhausted other alternatives to the maximum extent practicable, to assist in meeting natural gas requirements for such high-priority uses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1a020d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1a020e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any declaration of a natural gas supply emergency (or extension thereof) under subsection (a), shall terminate at the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1a020f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the President finds that any shortage described in subsection (a) does not exist or is not imminent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1a0210-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 120 days after the date of such declaration of emergency (or extension thereof).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1a0211-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3361/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall prohibit the President from extending, under subsection (a), any emergency (or extension thereof), previously declared under subsection (a), upon the expiration of such declaration of emergency (or extension thereof) under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1a0212-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tIII/s301"},"text":"Pub. L. 95–621, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3381"},"text":"92 Stat. 3381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1a0213-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a1a0214-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id7a1a0215-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this subchapter, except for authority to declare, extend, and terminate a national gas supply emergency pursuant to this section, delegated to Secretary of Energy, see section 1–101 of Ex. Ord. No. 12235, ","children":[{"tag":"date","attrib":{"date":"1980-09-03"},"text":"Sept. 3, 1980","children":[],"tail":", 45 F.R. 58803, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3364"},"text":"section 3364 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
