{"tag":"section","attrib":{"id":"id79a065c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667c"},"text":"§ 1667c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer lease advertising; liability of advertising media","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a065c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an advertisement for a consumer lease includes a statement of the amount of any payment or a statement that any or no initial payment is required, the advertisement shall clearly and conspicuously state, as applicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a065c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transaction advertised is a lease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a065c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of any initial payments required on or before consummation of the lease or delivery of the property, whichever is later;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a065c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a security deposit is required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a065c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, amount, and timing of scheduled payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a065c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a lease in which the liability of the consumer at the end of the lease term is based on the anticipated residual value of the property, that an extra charge may be imposed at the end of the lease term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a065ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising medium not liable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No owner or employee of any entity that serves as a medium in which an advertisement appears or through which an advertisement is disseminated, shall be liable under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a065cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radio advertisements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a065cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An advertisement by radio broadcast to aid, promote, or assist, directly or indirectly, any consumer lease shall be deemed to be in compliance with the requirements of subsection (a) if such advertisement clearly and conspicuously—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a065cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the information required by paragraphs (1) and (2) of subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a065ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the number, amounts, due dates or periods of scheduled payments, and the total of such payments under the lease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a065cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a065d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a referral to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79a065d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a toll-free telephone number established in accordance with paragraph (2) that may be used by consumers to obtain the information required under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79a065d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a written advertisement that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id79a065d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/C/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appears in a publication in general circulation in the community served by the radio station on which such advertisement is broadcast during the period beginning 3 days before any such broadcast and ending 10 days after such broadcast; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id79a065d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/C/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the information required to be disclosed under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a065d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and dates of any publication referred to in clause (i)(II); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a065d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any other information which the Bureau determines necessary to carry out this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a065d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of toll-free number","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a065d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a radio broadcast advertisement described in paragraph (1) that includes a referral to a toll-free telephone number, the lessor who offers the consumer lease shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a065d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such a toll-free telephone number not later than the date on which the advertisement including the referral is broadcast;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a065da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such telephone number for a period of not less than 10 days, beginning on the date of any such broadcast; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a065db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the information required under subsection (a) with respect to the lease to any person who calls such number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a065dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required to be provided under subparagraph (A)(iii) shall be provided verbally or, if requested by the consumer, in written form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a065dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall affect the requirements of Federal law as such requirements apply to advertisement by any medium other than radio broadcast.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a065de-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s184"},"text":"Pub. L. 90–321, title I, § 184","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/240/s3"},"text":"Pub. L. 94–240, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-23"},"text":"Mar. 23, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/259"},"text":"90 Stat. 259","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s336/a"},"text":"Pub. L. 103–325, title III, § 336(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2234"},"text":"108 Stat. 2234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2605/c"},"text":"Pub. L. 104–208, div. A, title II, § 2605(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-473"},"text":"110 Stat. 3009–473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", (10)(A), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":", 2109.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a065df-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a065e0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a065e1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100A/2"},"text":"Pub. L. 111–203, § 1100A(2)","children":[],"tail":", (10)(A), made similar amendments, resulting in the substitution of “the Bureau” for “the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2605/c/1"},"text":"Pub. L. 104–208, § 2605(c)(1)","children":[],"tail":", (3), added subsec. (a) and struck out former subsec. (a) consisting of introductory provisions and 5 pars. relating to contents of lease agreements required if consumer lease advertisement stated amount of payment, number of required payments, or that any or no payments were required at lease inception."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2605/c/3"},"text":"Pub. L. 104–208, § 2605(c)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2605/c/1"},"text":"Pub. L. 104–208, § 2605(c)(1)","children":[],"tail":", (2), redesignated subsec. (b) as (c) and struck out former subsec. (c) which read as follows: “There is no liability under this section on the part of any owner or personnel, as such, of any medium in which an advertisement appears or through which it is disseminated.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a065e2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a065e3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79a065e4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Advertising Rules","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIII/s336/b"},"text":"Pub. L. 103–325, title III, § 336(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2235"},"text":"108 Stat. 2235","children":[],"tail":", provided that not later than 365 days after "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", the Board of Governors of the Federal Reserve System shall submit a report to the Congress on credit advertising rules."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
