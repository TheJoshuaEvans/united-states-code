{"tag":"section","attrib":{"id":"id7a212e44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this chapter to improve the economic, environmental, and social well-being of the United States by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a212e45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing organizations in the executive branch to study and stimulate technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting technology development through the establishment of cooperative research centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulating improved utilization of federally funded technology developments, including inventions, software, and training technologies, by State and local governments and the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing encouragement for the development of technology through the recognition of individuals and companies which have made outstanding contributions in technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a212e49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the exchange of scientific and technical personnel among academia, industry, and Federal laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a212e4a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s3"},"text":"Pub. L. 96–480, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2312"},"text":"94 Stat. 2312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/1"},"text":"Pub. L. 99–502, § 9(b)(1)","children":[],"tail":", (f)(2), "},{"tag":"date","attrib":{"date":"1986-10-20"},"text":"Oct. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1795"},"text":"100 Stat. 1795","children":[],"tail":", 1797.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a212e4b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a212e4c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a212e4d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/b/1"},"text":"Pub. L. 99–502, § 9(b)(1)","children":[],"tail":", substituted “cooperative research centers” for “centers for industrial technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/f/2"},"text":"Pub. L. 99–502, § 9(f)(2)","children":[],"tail":", inserted “, including inventions, software, and training technologies,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
