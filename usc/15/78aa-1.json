{"tag":"section","attrib":{"id":"id78491358-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78aa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"78aa–1"},"text":"§ 78aa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provision relating to statute of limitations on private causes of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78491359-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78aa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on pending causes of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation period for any private civil action implied under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j/b"},"text":"section 78j(b) of this title","children":[],"tail":" that was commenced on or before "},{"tag":"date","attrib":{"date":"1991-06-19"},"text":"June 19, 1991","children":[],"tail":", shall be the limitation period provided by the laws applicable in the jurisdiction, including principles of retroactivity, as such laws existed on "},{"tag":"date","attrib":{"date":"1991-06-19"},"text":"June 19, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7849135a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78aa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on dismissed causes of action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any private civil action implied under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j/b"},"text":"section 78j(b) of this title","children":[],"tail":" that was commenced on or before "},{"tag":"date","attrib":{"date":"1991-06-19"},"text":"June 19, 1991","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7849135b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78aa–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which was dismissed as time barred subsequent to ","children":[{"tag":"date","attrib":{"date":"1991-06-19"},"text":"June 19, 1991","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7849135c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78aa–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which would have been timely filed under the limitation period provided by the laws applicable in the jurisdiction, including principles of retroactivity, as such laws existed on ","children":[{"tag":"date","attrib":{"date":"1991-06-19"},"text":"June 19, 1991","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be reinstated on motion by the plaintiff not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"December 19, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7849135d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 27A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/242/tIV/s476"},"text":"Pub. L. 102–242, title IV, § 476","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2387"},"text":"105 Stat. 2387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7849135e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"t