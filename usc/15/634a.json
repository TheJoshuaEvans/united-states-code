{"tag":"section","attrib":{"id":"id78c03ee5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634a"},"text":null,"children":[{"tag":"num","attrib":{"value":"634a"},"text":"§ 634a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Advocacy within Small Business Administration; Chief Counsel for Advocacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established within the Small Business Administration an Office of Advocacy. The management of the Office shall be vested in a Chief Counsel for Advocacy who shall be appointed from civilian life by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78c03ee6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305/tII/s201"},"text":"Pub. L. 94–305, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/668"},"text":"90 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c03ee7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c03ee8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c03ee9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
