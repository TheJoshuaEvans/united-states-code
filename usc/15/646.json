{"tag":"section","attrib":{"id":"id790a3f9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s646"},"text":null,"children":[{"tag":"num","attrib":{"value":"646"},"text":"§ 646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liens","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any interest held by the Administration in property, as security for a loan, shall be subordinate to any lien on such property for taxes due on the property to a State, or political subdivision thereof, in any case where such lien would, under applicable State law, be superior to such interest if such interest were held by any party other than the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id790a3f9b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s17"},"text":"Pub. L. 85–536, § 2[17]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/396"},"text":"72 Stat. 396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id790a3f9c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id790a3f9d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id790a3f9e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 217 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-07-30/ch282/tII"},"text":"act July 30, 1953, ch. 282, title II","children":[],"tail":