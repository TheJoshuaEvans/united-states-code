{"tag":"section","attrib":{"id":"id77f59bce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77aaaa"},"text":null,"children":[{"tag":"num","attrib":{"value":"77aaaa"},"text":"§ 77aaaa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contrary stipulations void","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any condition, stipulation, or provision binding any person to waive compliance with any provision of this subchapter or with any rule, regulation, or order thereunder shall be void.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77f59bcf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title III, § 327, as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-03/ch411"},"text":"Aug. 3, 1939, ch. 411","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1177"},"text":"53 Stat. 1177","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
