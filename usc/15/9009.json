{"tag":"section","attrib":{"id":"id7a960fcd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009"},"text":null,"children":[{"tag":"num","attrib":{"value":"9009"},"text":"§ 9009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency EIDL grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a960fce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a960fcf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered period” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-01-31"},"text":"January 31, 2020","children":[],"tail":" and ending on "},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960fd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a960fd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business with not more than 500 employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who operates under a sole proprietorship, with or without employees, or as an independent contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cooperative with not more than 500 employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ESOP (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":") with not more than 500 employees;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal small business concern, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657a/b/2/C"},"text":"section 657a(b)(2)(C) of this title","children":[],"tail":", with not more than 500 employees; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fd6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agricultural enterprise (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s647/b"},"text":"section 647(b) of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002620"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002620"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":" with not more than 500 employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a960fd7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the covered period, in addition to small business concerns, private nonprofit organizations, and small agricultural cooperatives, an eligible entity shall be eligible for a loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a960fd8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms; credit elsewhere","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":" in response to COVID–19 during the covered period, the Administrator shall waive—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a960fd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rules related ","children":[{"tag":"ref","attrib":{"idref":"fn002621"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002621"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “to”."}],"tail":" the personal guarantee on advances and loans of not more than $200,000 during the covered period for all applicants;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960fda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement that an applicant needs to be in business for the 1-year period before the disaster, except that no waiver may be made for a business that was not in operation on ","children":[{"tag":"date","attrib":{"date":"2020-01-31"},"text":"January 31, 2020","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960fdb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement in the flush matter following subparagraph (E) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":", as so redesignated by subsection (f) of this section,"},{"tag":"ref","attrib":{"idref":"fn002622"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002622"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See Codification note below."}],"tail":" that an applicant be unable to obtain credit elsewhere."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a960fdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and ability to repay for small dollar loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":" in response to COVID–19 during the covered period, the Administrator may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a960fdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" approve an applicant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a960fde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based solely on the credit score of the applicant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by using alternative appropriate methods to determine an applicant’s ability to repay; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960fe0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use information from the Department of the Treasury to confirm that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a960fe1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicant is eligible to receive such a loan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fe2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information contained in an application for such a loan is accurate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a960fe3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a960fe4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a960fe5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the covered period, an entity included for eligibility in subsection (b), including small business concerns, private nonprofit organizations, and small agricultural cooperatives, that applies for a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":" in response to COVID–19 may request that the Administrator provide an advance that is, subject to paragraph (3), in the amount requested by such applicant to such applicant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fe6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each request submitted to the Administrator under subparagraph (A), the Administrator shall, not later than 21 days after the date on which the Administrator receives the request—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a960fe7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify whether the entity is an entity that is eligible for a loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":" during the covered period, as described in subsection (b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a960fe8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator, under clause (i), verifies that the entity submitting the request is an entity that is eligible, as described in that clause, provide the advance requested by the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a960fe9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an entity that the Administrator determines is not entitled to receive an advance under this subsection, provide the entity with a notification explaining why the Administrator reached that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960fea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before disbursing amounts under this subsection, the Administrator shall verify that the applicant is an eligible entity by accepting a self-certification from the applicant under penalty of perjury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1746"},"text":"section 1746 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960feb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of an advance provided under this subsection shall be not more than $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960fec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An advance provided under this subsection may be used to address any allowable purpose for a loan made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a960fed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing paid sick leave to employees unable to work due to the direct effect of the COVID–19;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining payroll to retain employees during business disruptions or substantial slowdowns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960fef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting increased costs to obtain materials unavailable from the applicant’s original source due to interrupted supply chains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960ff0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making rent or mortgage payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a960ff1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repaying obligations that cannot be met due to revenue losses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960ff2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant shall not be required to repay any amounts of an advance provided under this subsection, even if subsequently denied a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/2"},"text":"section 636(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960ff3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tIII/s333/c"},"text":"Pub. L. 116–260, div. N, title III, § 333(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2046"},"text":"134 Stat. 2046","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960ff4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administration $40,000,000,000 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960ff5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to carry out grants under this subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a960ff6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9009/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, any criminal charge or civil enforcement action alleging that a borrower engaged in fraud with respect to the use of an advance received under this subsection shall be filed not later than 10 years after the offense was committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a960ff7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tI/s1110"},"text":"Pub. L. 116–136, div. A, title I, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/306"},"text":"134 Stat. 306","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/139/dA/s101/b"}