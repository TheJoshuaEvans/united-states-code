{"tag":"section","attrib":{"id":"id7a50f06b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5527"},"text":null,"children":[{"tag":"num","attrib":{"value":"5527"},"text":"§ 5527.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a50f06c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5527/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent the appropriate Federal agency or department head determines, the provisions of this chapter shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f06d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5527/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs or activities regarding computer systems that process classified information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f06e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5527/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer systems the function, operation, or use of which are those delineated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3552/b/6/A/i"},"text":"section 3552(b)(6)(A)(i) of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f06f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5527/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of prototype and early production models","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with Federal contracting law, Federal agencies and departments participating in the Program may acquire prototype or early production models of new networking and information technology systems and subsystems to stimulate hardware and software development. Items of computing equipment acquired under this subsection shall be considered research computers for purposes of applicable acquisition regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a50f070-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/194/tII/s207"},"text":"Pub. L. 102–194, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1602"},"text":"105 Stat. 1602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s105/p"},"text":"Pub. L. 114–329, title I, § 105(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2984"},"text":"130 Stat. 2984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a50f071-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a50f072-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a50f073-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/p/1"},"text":"Pub. L. 114–329, § 105(p)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3552/b/6/A/i"},"text":"section 3552(b)(6)(A)(i) of title 44","children":[],"tail":"” for “paragraphs (1) through (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2315/a"},"text":"section 2315(a) of title 10","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/p/2"},"text":"Pub. L. 114–329, § 105(p)(2)","children":[],"tail":", substituted “networking and information technology” for “high-performance computing”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
