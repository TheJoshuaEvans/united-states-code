{"tag":"section","attrib":{"id":"id7a49c4bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907"},"text":null,"children":[{"tag":"num","attrib":{"value":"4907"},"text":"§ 4907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of Data Bank","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall manage the Data Bank to provide the most appropriate data retrieval system or systems possible. Such system or systems shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c4be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to utilize data processing and retrieval technology in monitoring, organizing, analyzing, and disseminating the data and information contained in the Data Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use the most effective and meaningful means of organizing and making such information available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c4c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Government policymakers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States business firms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States industry associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States agricultural interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local economic development agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other interested United States persons who could benefit from such information;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be of such quality and timeliness and in such form as to assist coordinated trade strategies for the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4907/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate dissemination of information through nonprofit organizations with significant outreach programs which complement the regional outreach programs of the United States and Foreign Commercial Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c4c9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5407"},"text":"Pub. L. 100–418, title V, § 5407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1466"},"text":"102 Stat. 1466","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
