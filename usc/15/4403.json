{"tag":"section","attrib":{"id":"id7a38fcaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403"},"text":null,"children":[{"tag":"num","attrib":{"value":"4403"},"text":"§ 4403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ingredient reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a38fcab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fcac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each person who manufactures, packages, or imports smokeless tobacco products shall annually provide the Secretary with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38fcad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the ingredients added to tobacco in the manufacture of smokeless tobacco products which does not identify the company which uses the ingredients or the brand of smokeless tobacco which contains the ingredients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fcae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification of the quantity of nicotine contained in each such product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fcaf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person or group of persons required to provide information by this subsection may designate an individual or entity to provide the information required by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a38fcb0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a38fcb1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At such times as the Secretary considers appropriate, the Secretary shall transmit to the Congress a report, based on the information provided under subsection (a), respecting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38fcb2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of research activities and proposed research activities on the health effects of ingredients added to tobacco in the manufacture of smokeless tobacco products and the findings of such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fcb3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information pertaining to any such ingredient which in the judgment of the Secretary poses a health risk to users of smokeless tobacco; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fcb4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information which the Secretary determines to be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a38fcb5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a38fcb6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any information provided to the Secretary under subsection (a) shall be treated as a trade secret or confidential information subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" and shall not be revealed, except as provided in paragraph (1), to any person other than those authorized by the Secretary in carrying out their official duties under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fcb7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) does not authorize the withholding of information provided under subsection (a) of this section from any duly authorized subcommittee or committee of the Congress. If a subcommittee or committee of the Congress requests the Secretary to provide it such information, the Secretary shall make the information available to the subcommittee or committee and shall, at the same time, notify in writing the person who provided the information of such request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a38fcb8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish written procedures to assure the confidentiality of information provided under subsection (a) of this section. Such procedures shall include the designation of a duly authorized agent to serve as custodian of such information. The agent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a38fcb9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take physical possession of the information and, when not in use by any person authorized to have access to such information, shall store it in a locked cabinet or file; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a38fcba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4403/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall maintain a complete record of any person who inspects or uses the information.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such procedures shall require that any person permitted access to the information shall be instructed in writing not to disclose the information to anyone who is not entitled to have access to the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a38fcbb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/252/s4"},"text":"Pub. L. 99–252, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/32"},"text":"100 Stat. 32","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a38fcbc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a38fcbd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a38fcbe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a) effective one year after ","children":[{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", and subsec. (b) effective "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/252/s11"},"text":"section 11 of Pub. L. 99–252","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4401"},"text":"section 4401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
