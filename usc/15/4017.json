{"tag":"section","attrib":{"id":"id7a31d0a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4017"},"text":null,"children":[{"tag":"num","attrib":{"value":"4017"},"text":"§ 4017.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a31d0aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4017/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance; content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To promote greater certainty regarding the application of the antitrust laws to export trade, the Secretary, with the concurrence of the Attorney General, may issue guidelines—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31d0ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4017/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing specific types of conduct with respect to which the Secretary, with the concurrence of the Attorney General, has made or would make, determinations under sections 4013 and 4014 of this title, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d0ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4017/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summarizing the factual and legal bases in support of the determinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d0ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4017/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative rulemaking requirements n