{"tag":"section","attrib":{"id":"id7977ce72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1331"},"text":null,"children":[{"tag":"num","attrib":{"value":"1331"},"text":"§ 1331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy and purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the Congress, and the purpose of this chapter, to establish a comprehensive Federal Program to deal with cigarette labeling and advertising with respect to any relationship between smoking and health, whereby—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7977ce73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1331/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public may be adequately informed about any adverse health effects of cigarette smoking by inclusion of warning notices on each package of cigarettes and in each advertisement of cigarettes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7977ce74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1331/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commerce and the national economy may be (A) protected to the maximum extent consistent with this declared policy and (B) not impeded by diverse, nonuniform, and confusing cigarette labeling and advertising regulations with respect to any relationship between smoking and health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7977ce75-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92/s2"},"text":"Pub. L. 89–92, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/282"},"text":"79 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/222/s2"},"text":"Pub. L. 91–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-01"},"text":"Apr. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/87"},"text":"84 Stat. 87","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/474/s6/a"},"text":"Pub. L. 98–474, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2204"},"text":"98 Stat. 2204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7977ce76-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7977ce77-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7977ce78-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/474"},"text":"Pub. L. 98–474","children":[],"tail":" substituted “about any adverse health effects of cigarette smoking by inclusion of warning notices on each package of cigarettes and in each advertisement;” for “that cigarette smoking may be hazardous to health by inclusion of a warning to that effect on each package of cigarettes;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/222"},"text":"Pub. L. 91–222","children":[],"tail":" reenacted section without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7977ce79-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7977ce7a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/222/s3"},"text":"Pub. L. 91–222, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-01"},"text":"Apr. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/90"},"text":"84 Stat. 90","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/222/s3"},"text":"“All other provisions of the amendment made by this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1340"},"text":"section 1340 of this title","children":[],"tail":", amending this section and sections 1332 and 1335 to 1339 of this title, and enacting provisions set out as notes under this section] except where otherwise specified shall take effect on "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"January 1, 1970","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7977ce7b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92/s12"},"text":"Pub. L. 89–92, § 12","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/284"},"text":"79 Stat. 284","children":[],"tail":", as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/98/474/s5/a"},"text":"Pub. L. 98–474, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2203"},"text":"98 Stat. 2203","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/474/s5/a"},"text":"“This Act [this chapter] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7977ce7c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/474/s1"},"text":"Pub. L. 98–474, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2200"},"text":"98 Stat. 2200","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/474/s1"},"text":"“This Act [enacting sections 1335a and 1341 of this title, amending this section and sections 1332, 1333, 1336, and 1337 of this title, and enacting provisions set out as notes under this section and sections 1333 and 1335a of this title] may be cited as the ‘Comprehensive Smoking Education Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7977ce7d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/109/s1"},"text":"Pub. L. 93–109, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-21"},"text":"Sept. 21, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/352"},"text":"87 Stat. 352","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/109/s1"},"text":"“That this Act [amending sections 1332 and 1335 of this title] may be cited as the ‘Little Cigar Act of 1973’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7977ce7e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/222/s1"},"text":"Pub. L. 91–222, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-01"},"text":"Apr. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/87"},"text":"84 Stat. 87","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/222/s1"},"text":"“That this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1340"},"text":"section 1340 of this title","children":[],"tail":", amending this section and sections 1332 to 1339 of this title, and enacting provisions set out as notes under this section and sections 1333 and 1334 of this title] may be cited as the ‘Public Health Cigarette Smoking Act of 1969’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7977ce7f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92/s1"},"text":"Pub. L. 89–92, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/282"},"text":"79 Stat. 282","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/92/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Federal Cigarette Labeling and Advertising Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id7977ce80-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/92/s13"},"text":"Pub. L. 89–92, § 13","children":[],"tail":", formerly § 12, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/222/s2"},"text":"Pub. L. 91–222, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-01"},"text":"Apr. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/90"},"text":"84 Stat. 90","children":[],"tail":", and renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/98/474/s5/a"},"text":"Pub. L. 98–474, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2203"},"text":"98 Stat. 2203","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/474/s5/a"},"text":"“If any provision of this Act [this chapter] or the application thereof to any person or circumstances is held invalid, the other provisions of this Act [this chapter] and the application of such provisions to other persons or circumstances shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7977ce81-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/474/s2"},"text":"Pub. L. 98–474, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2200"},"text":"98 Stat. 2200","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/474/s2"},"text":"“It is the purpose of this Act [see Short Title of 1984 Amendment note above] to provide a new strategy for making Americans more aware of any adverse health effects of smoking, to assure the timely and widespread dissemination of research findings and to enable individuals to make informed decisions about smoking.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
