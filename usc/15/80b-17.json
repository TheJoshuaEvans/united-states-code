{"tag":"section","attrib":{"id":"id78824b7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"80b–17"},"text":"§ 80b–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates any provision of this subchapter, or any rule, regulation, or order promulgated by the Commission under authority thereof, shall, upon conviction, be fined not more than $10,000, imprisoned for not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78824b7d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title II, § 217, "},{"tag":"ref","attrib":{"href":"/us/stat/54/857"},"text":"54 Stat. 857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/750/s15"},"text":"Pub. L. 86–750, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/888"},"text":"74 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s27/f"},"text":"Pub. L. 94–29, § 27(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/163"},"text":"89 Stat. 163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78824b7e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78824b7f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","child