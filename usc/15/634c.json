{"tag":"section","attrib":{"id":"id78c03f00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c"},"text":null,"children":[{"tag":"num","attrib":{"value":"634c"},"text":"§ 634c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties of Office of Advocacy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78c03f01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Advocacy shall also perform the following duties on a continuing basis:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78c03f02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a focal point for the receipt of complaints, criticisms, and suggestions concerning the policies and activities of the Administration and any other Federal agency which affects small businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counsel small businesses on how to resolve questions and problems concerning the relationship of the small business to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop proposals for changes in the policies and activities of any agency of the Federal Government which will better fulfill the purposes of the Small Business Act and communicate such proposals to the appropriate Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the views and interests of small businesses before other Federal agencies whose policies and activities may affect small business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlist the cooperation and assistance of public and private agencies, businesses, and other organizations in disseminating information about the programs and services provided by the Federal Government which are of benefit to small businesses, and information on how small businesses can participate in or make use of such programs and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the responsibilities of the Office of Advocacy under chapter 6 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78c03f08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and input from small businesses on trade promotion authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78c03f09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78c03f0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c03f0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Chief Counsel for Advocacy” means the Chief Counsel for Advocacy of the Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c03f0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered trade agreement” means a trade agreement being negotiated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4202/b"},"text":"section 4202(b) of title 19","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c03f0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Working Group” means the Interagency Working Group convened under paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working group","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78c03f0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date on which the President submits the notification required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4204/a"},"text":"section 4204(a) of title 19","children":[],"tail":", the Chief Counsel for Advocacy shall convene an Interagency Working Group, which shall consist of an employee from each of the following agencies, as selected by the head of the agency or an official delegated by the head of the agency:"}],"tail":null},{"tag":"clause","attrib":{"id":"id78c03f10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other agency that the Chief Counsel for Advocacy, in consultation with the United States Trade Representative, determines to be relevant with respect to the subject of the covered trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c03f14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Views of small businesses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which the Chief Counsel for Advocacy convenes the Working Group under subparagraph (A), the Chief Counsel for Advocacy shall identify a diverse group of small businesses, representatives of small businesses, or a combination thereof, to provide to the Working Group the views of small businesses in the manufacturing, services, and agriculture industries on the potential economic effects of the covered trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78c03f15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78c03f16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the Chief Counsel for Advocacy convenes the Working Group under paragraph (2)(A), the Chief Counsel for Advocacy shall submit to the Committee on Small Business and Entrepreneurship and the Committee on Finance of the Senate and the Committee on Small Business and the Committee on Ways and Means of the House of Representatives a report on the economic impacts of the covered trade agreement on small businesses, which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78c03f17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the most important priorities, opportunities, and challenges to various industries from the covered trade agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the impact for new small businesses to start exporting, or increase their exports, to markets in countries that are parties to the covered trade agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze the competitive position of industries likely to be significantly affected by the covered trade agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id78c03f1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State-owned enterprises in each country participating in negotiations for the covered trade agreement that could pose a threat to small businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id78c03f1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any steps to take to create a level playing field for those small businesses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any rule of an agency that should be modified to become compliant with the covered trade agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78c03f1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an overview of the methodology used to develop the report, including the number of small business participants by industry, how those small businesses were selected, and any other factors that the Chief Counsel for Advocacy may determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c03f1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delayed submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that negotiations for the covered trade agreement are not disrupted, the President may require that the Chief Counsel for Advocacy delay submission of the report under subparagraph (A) until after the negotiations for the covered trade agreement are concluded, provided that the delay allows the Chief Counsel for Advocacy to submit the report to Congress not later than 45 days before the Senate or the House of Representatives acts to approve or disapprove the covered trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78c03f20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoidance of duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Counsel for Advocacy shall, to the extent practicable, coordinate the submission of the report under this paragraph with the United States International Trade Commission, the United States Trade Representative, other agencies, and trade advisory committees to avoid unnecessary duplication of reporting requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78c03f21-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305/tII/s203"},"text":"Pub. L. 94–305, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/669"},"text":"90 Stat. 669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/240/tI/s1602/a"},"text":"Pub. L. 111–240, title I, § 1602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2551"},"text":"124 Stat. 2551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tV/s502"},"text":"Pub. L. 114–125, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/172"},"text":"130 Stat. 172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c03f22-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c03f23-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78c03f24-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Small Business Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2"},"text":"Pub. L. 85–536, § 2","children":[],"tail":"(1 et seq.), "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/384"},"text":"72 Stat. 384","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c03f25-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78c03f26-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240"},"text":"Pub. L. 111–240","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id78c03f27-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78c03f28-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority Under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s634c/b/3/B"},"text":"15 U.S.C. 634c(b)(3)(B)","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2020-10-09"},"text":"Oct. 9, 2020","children":[],"tail":", 85 F.R. 65631, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the United States Trade Representative","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to the United States Trade Representative the authority vested in the President by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s634c/b/3/B"},"text":"section 634c(b)(3)(B) of title 15","children":[],"tail":", United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Donald J. Trump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
