{"tag":"section","attrib":{"id":"id7a475427-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806"},"text":null,"children":[{"tag":"num","attrib":{"value":"4806"},"text":"§ 4806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a475428-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may, for the purpose of carrying out the provisions of this chapter, hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence, as the Council considers appropriate. The Council may administer oaths or affirmations to witnesses appearing before the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475429-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a47542a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a47542b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the Council may secure directly from any Federal agency information necessary to enable the Council to carry out the provisions of this chapter. Upon request of the chairman of the Council, the head of such agency shall promptly furnish such information to the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47542c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) does not apply to matters that are specifically authorized under criteria established by an Executive order to be kept secret in the interest of national defense or foreign policy and are in fact properly classified pursuant to such Executive order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47542d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the Council receives any information from a Federal agency, the Council shall not disclose such information to the public unless such agency is authorized to disclose such information pursuant to Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47542e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 120 days after the initial members are appointed to the Council, the Council shall submit a report to the President, the Senate Governmental Affairs Committee, and the appropriate committees of the House of Representatives and of the Senate, that proposes the type and scope of activities the Council shall undertake, including the extent to which the Council will coordinate activities with other advisory committees relating to trade and competitiveness in order to maximize the effectiveness of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47542f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may accept, use, and dispose of gifts or donations of services or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475430-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of mails","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council may use the United States mails in the same manner and under the same conditions as other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475431-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall provide to the Council, on a reimbursable basis, such administrative and support services as the Council may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475432-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcouncils","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475433-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council may establish, for such period of time as the Council determines appropriate, subcouncils of public and private leaders to analyze specific competitive issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475434-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such subcouncil shall include representatives of business, labor, government, and other individuals or representatives of groups whose participation is considered by the Council to be important to developing a full understanding of the subject with which the subcouncil is concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475435-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such subcouncil shall include a representative of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475436-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any such subcouncil shall assess the actual or potential competitiveness problems facing the industry or the specific policy issues with which the subcouncil is concerned and shall formulate specific recommendations for responses by business, government, and labor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a475437-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage adjustment and modernization of the industry involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a475438-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to monitor and facilitate industry responsiveness to opportunities identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4807/b/1/B"},"text":"section 4807(b)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a475439-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the ability of the industry involved to compete in markets identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4807/b/1/C"},"text":"section 4807(b)(1)(C) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47543a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alleviate the problems in a specific policy area facing more than one industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47543b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any discussion held by any subcouncil shall not be considered to violate any Federal or State antitrust law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47543c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any discussion held by any subcouncil shall not be subject to the provisions of chapter 10 of title 5, except that a Federal representative shall attend all subcouncil meetings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47543d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any subcouncil shall terminate 30 days after making recommendations, unless the Council specifically requests that the subcouncil continue in operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47543e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4806/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of subsections (e) and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009"},"text":"section 1009 of title 5","children":[],"tail":" shall not apply to the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a47543f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5207"},"text":"Pub. L. 100–418, title V, § 5207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1459"},"text":"102 Stat. 1459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/382/tI/s133/c"},"text":"Pub. L. 101–382, title I, § 133(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/649"},"text":"104 Stat. 649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/74"},"text":"Pub. L. 117–286, § 4(a)(74)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4314"},"text":"136 Stat. 4314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a475440-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a475441-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a475442-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/74/A"},"text":"Pub. L. 117–286, § 4(a)(74)(A)","children":[],"tail":", substituted “chapter 10 of title 5,” for “the Federal Advisory Committee Act,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/74/B"},"text":"Pub. L. 117–286, § 4(a)(74)(B)","children":[],"tail":", substituted “chapter 10 of title 5” for “Advisory Committee Act” in heading and “subsections (e) and (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009"},"text":"section 1009 of title 5","children":[],"tail":"” for “subsections (e) and (f) of section 10, of the Federal Advisory Committee Act” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382"},"text":"Pub. L. 101–382","children":[],"tail":" redesignated subsec. (d) as (c), and substituted “120” for “60”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s133/c/1"},"text":"Pub. L. 101–382, § 133(c)(1)","children":[],"tail":", redesignated subsecs. (e) to (i) as (d) to (h), respectively. Former subsec. (d) redesignated (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a475443-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a475444-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
