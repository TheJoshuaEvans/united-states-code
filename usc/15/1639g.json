{"tag":"section","attrib":{"id":"id7999394a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1639g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639g"},"text":"§ 1639g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for payoff amounts of home loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A creditor or servicer of a home loan shall send an accurate payoff balance within a reasonable time, but in no case more than 7 business days, after the receipt of a written request for such balance from or on behalf of the borrower.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7999394b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s129G"},"text":"Pub. L. 90–321, title I, § 129G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tXIV/s1464/b"},"text":"Pub. L. 111–203, title XIV, § 1464(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2184"},"text":"124 Stat. 2184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7999394c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7999394d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7999394e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date on which final regulations implementing such section take effect, or on the date that is 18 months after the designated transfer date if such regulations have not been issued by that date, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1400/c"},"text":"section 1400(c) of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
