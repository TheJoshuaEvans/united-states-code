{"tag":"section","attrib":{"id":"id7a5a6774-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603"},"text":null,"children":[{"tag":"num","attrib":{"value":"6603"},"text":"§ 6603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5a6775-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter applies to any Y2K action brought after ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", for a Y2K failure occurring before "},{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":", or for a potential Y2K failure that could occur or has allegedly caused harm or injury before "},{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":", including any appeal, remand, stay, or other judicial, administrative, or alternative dispute resolution proceeding in such an action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a6776-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No new cause of action created","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter creates a new cause of action, and, except as otherwise explicitly provided in this chapter, nothing in this chapter expands any liability otherwise imposed or limits any defense otherwise available under Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a6777-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims for personal injury or wrongful death excluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter does not apply to a claim for personal injury or for wrongful death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a6778-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warranty and contract preservation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a6779-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), in any Y2K action any written contractual term, including a limitation or an exclusion of liability, or a disclaimer of warranty, shall be strictly enforced unless the enforcement of that term would manifestly and directly contravene applicable State law embodied in any statute in effect on ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", specifically addressing that term."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a677a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpretation of contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any Y2K action in which a contract to which paragraph (1) applies is silent as to a particular issue, the interpretation of the contract as to that issue shall be determined by applicable law in effect at the time the contract was executed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a677b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unconscionability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall prevent enforcement of State law doctrines of unconscionability, including adhesion, recognized as of ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", in controlling judicial precedent by the courts of the State whose law applies to the Y2K action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a677c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption of State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter supersedes State law to the extent that it establishes a rule of law applicable to a Y2K action that is inconsistent with State law, but nothing in this chapter implicates, alters, or diminishes the ability of a State to defend itself against any claim on the basis of sovereign immunity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a677d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with Year 2000 Information and Readiness Disclosure Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter supersedes any provision of the Year 2000 Information and Readiness Disclosure Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a677e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to actions brought by a government entity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a677f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent provided in this subsection, this chapter shall apply to an action brought by a government entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6602/1/C"},"text":"section 6602(1)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6780-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a6781-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defendant","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a6782-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “defendant” includes a State or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a6783-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a6784-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “local government” means—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a5a6785-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any county, city, town, township, parish, village, or other general purpose political subdivision of a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5a6786-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of political subdivisions described in subclause (I) recognized by the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6787-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Y2K upset","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Y2K upset”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a6788-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an exceptional temporary noncompliance with applicable federally enforceable measurement, monitoring, or reporting requirements directly related to a Y2K failure that are beyond the reasonable control of the defendant charged with compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a6789-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a5a678a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncompliance with applicable federally enforceable measurement, monitoring, or reporting requirements that constitutes or would create an imminent threat to public health, safety, or the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5a678b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncompliance with applicable federally enforceable measurement, monitoring, or reporting requirements that provide for the safety and soundness of the banking or monetary system, or for the integrity of the national securities markets, including the protection of depositors and investors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5a678c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncompliance with applicable federally enforceable measurement, monitoring, or reporting requirements to the extent caused by operational error or negligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5a678d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack of reasonable preventative maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5a678e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack of preparedness for a Y2K failure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5a678f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/2/B/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncompliance with the underlying federally enforceable requirements to which the applicable federally enforceable measurement, monitoring, or reporting requirement relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6790-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions necessary for a demonstration of a Y2K upset","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defendant who wishes to establish the affirmative defense of Y2K upset shall demonstrate, through properly signed, contemporaneous operating logs, or other relevant evidence that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a6791-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant previously made a reasonable good faith effort to anticipate, prevent, and effectively remediate a potential Y2K failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6792-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Y2K upset occurred as a result of a Y2K failure or other emergency directly related to a Y2K failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6793-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncompliance with the applicable federally enforceable measurement, monitoring, or reporting requirement was unavoidable in the face of an emergency directly related to a Y2K failure and was necessary to prevent the disruption of critical functions or services that could result in harm to life or property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6794-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon identification of noncompliance the defendant invoking the defense began immediate actions to correct any violation of federally enforceable measurement, monitoring, or reporting requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a6795-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant submitted notice to the appropriate Federal regulatory authority of a Y2K upset within 72 hours from the time that the defendant became aware of the upset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6796-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant of a Y2K upset defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the other provisions of this subsection, the Y2K upset defense shall be a complete defense to the imposition of a penalty in any action brought as a result of noncompliance with federally enforceable measurement, monitoring, or reporting requirements for any defendant who establishes by a preponderance of the evidence that the conditions set forth in paragraph (3) are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6797-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Length of Y2K upset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maximum allowable length of the Y2K upset shall be not more than 15 days beginning on the date of the upset unless specific relief by the appropriate regulatory authority is granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6798-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent invocation of Y2K upset defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fraudulent use of the Y2K upset defense provided for in this subsection shall be subject to the sanctions provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6799-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Y2K upset defense may not be asserted for a Y2K upset occurring after ","children":[{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a679a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/g/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall affect the authority of a government entity to seek injunctive relief or require a defendant to correct a violation of a federally enforceable measurement, monitoring, or reporting requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a679b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer protection from Y2K failures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a679c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person who transacts business on matters directly or indirectly affecting residential mortgages shall cause or permit a foreclosure on any such mortgage against a consumer as a result of an actual Y2K failure that results in an inability to accurately or timely process any mortgage payment transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a679d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A consumer who is affected by an inability described in paragraph (1) shall notify the servicer for the mortgage, in writing and within 7 business days from the time that the consumer becomes aware of the Y2K failure and the consumer’s inability to accurately or timely fulfill his or her obligation to pay, of such failure and inability and shall provide to the servicer any available documentation with respect to the failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a679e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions may resume after grace period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), an action prohibited under paragraph (1) may be resumed, if the consumer’s mortgage obligation has not been paid and the servicer of the mortgage has not expressly and in writing granted the consumer an extension of time during which to pay the consumer’s mortgage obligation, but only after the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a679f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four weeks after ","children":[{"tag":"date","attrib":{"date":"2000-01-01"},"text":"January 1, 2000","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four weeks after notification is made as required under paragraph (2), except that any notification made on or after ","children":[{"tag":"date","attrib":{"date":"2000-03-15"},"text":"March 15, 2000","children":[],"tail":", shall not be effective for purposes of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection does not apply to transactions upon which a default has occurred before ","children":[{"tag":"date","attrib":{"date":"1999-12-15"},"text":"December 15, 1999","children":[],"tail":", or with respect to which an imminent default was foreseeable before "},{"tag":"date","attrib":{"date":"1999-12-15"},"text":"December 15, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of obligations merely tolled","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection delays but does not prevent the enforcement of financial obligations, and does not otherwise affect or extinguish the obligation to pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consumer” means a natural person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “residential mortgage” has the meaning given the term “federally related mortgage loan” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2602"},"text":"section 2602 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/h/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “servicer” means the person, including any successor, responsible for receiving any scheduled periodic payments from a consumer pursuant to the terms of a residential mortgage, including amounts for any escrow account, and for making the payments of principal and interest and such other payments with respect to the amounts received from the borrower as may be required pursuant to the terms of the mortgage. Such term includes the person, including any successor, who makes or holds a loan if such person also services the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a67a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6603/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to securities litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any Y2K action in which the underlying claim arises under the securities laws (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a"},"text":"section 78c(a) of this title","children":[],"tail":"), the provisions of this chapter, other than "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6612/b"},"text":"section 6612(b) of this title","children":[],"tail":", shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5a67a8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s4"},"text":"Pub. L. 106–37, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/188"},"text":"113 Stat. 188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a5a67a9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a5a67aa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a5a67ab-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Year 2000 Information and Readiness Disclosure Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/271"},"text":"Pub. L. 105–271","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2386"},"text":"112 Stat. 2386","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
