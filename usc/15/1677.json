{"tag":"section","attrib":{"id":"id79a0663b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1677"},"text":null,"children":[{"tag":"num","attrib":{"value":"1677"},"text":"§ 1677.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on State laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This subchapter does not annul, alter, or affect, or exempt any person from complying with, the laws of any State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a0663c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1677/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibiting garnishments or providing for more limited garnishment than are allowed under this subchapter, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a0663d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1677/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibiting the discharge of any employee by reason of the fact that his earnings have been subjected to garnishment for more than one indebtedness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a0663e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIII/s307"},"text":"Pub. L. 90–321, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/164"},"text":"82 Stat. 164","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
