{"tag":"section","attrib":{"id":"id7a8c740d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709"},"text":null,"children":[{"tag":"num","attrib":{"value":"8709"},"text":"§ 8709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation and power to subpoena","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8c740e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct such investigations as the Secretary considers necessary for the effective administration of this chapter, or to determine whether any person has engaged or is engaging in any act that constitutes a violation of this chapter or any order or regulation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c740f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas, oaths, and affirmations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c7410-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of conducting an investigation under subsection (a), the Secretary may administer oaths and affirmations, subpoena witnesses, compel the attendance of witnesses, take evidence, and require the production of any records that are relevant to the inquiry. The production of the records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7411-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an administrative hearing held under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8707/a/2"},"text":"section 8707(a)(2) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8708/c/4"},"text":"section 8708(c)(4) of this title","children":[],"tail":", the presiding officer may administer oaths and affirmations, subpoena witnesses, compel the attendance of witnesses, take evidence, and require the production of any records that are relevant to the inquiry. The attendance of witnesses and the production of the records may be required from any place in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c7412-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid of courts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c7413-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of contumacy by, or refusal to obey a subpoena issued under subsection (b) to, any person, the Secretary may invoke the aid of any court of the United States within the jurisdiction of which the investigation or proceeding is conducted, or where the person resides or conducts business, in order to enforce a subpoena issued under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee414-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may issue an order requiring the person referred to in paragraph (1) to comply with a subpoena referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee415-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to obey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any failure to obey the order of the court may be punished by the court as a contempt of court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee416-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8709/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Process in any proceeding under this subsection may be served in the United States judicial district in which the person being proceeded against resides or conducts business, or wherever the person may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee417-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1310"},"text":"Pub. L. 115–254, div. E, § 1310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3482"},"text":"132 Stat. 3482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
