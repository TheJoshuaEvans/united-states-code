{"tag":"section","attrib":{"id":"id78063d4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"78d–4"},"text":"§ 78d–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties of Inspector General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78063d4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suggestion submissions by Commission employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063d4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hotline established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General of the Commission shall establish and maintain a telephone hotline or other electronic means for the receipt of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063d4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suggestions by employees of the Commission for improvements in the work efficiency, effectiveness, and productivity, and the use of the resources, of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allegations by employees of the Commission of waste, abuse, misconduct, or mismanagement within the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General shall maintain as confidential—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063d51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of any individual who provides information by the means established under paragraph (1), unless the individual requests otherwise, in writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of any such individual, any specific information provided by the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General shall consider any suggestions or allegations received by the means established under subsection (a)(1), and shall recommend appropriate action in relation to such suggestions or allegations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General may recognize any employee who makes a suggestion under subsection (a)(1) (or by other means) that would or does—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063d55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the work efficiency, effectiveness, or productivity of the Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce waste, abuse, misconduct, or mismanagement within the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General of the Commission shall submit to Congress an annual report containing a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063d58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, number, and potential benefits of any suggestions received under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, number, and seriousness of any allegations received under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations made or actions taken by the Inspector General in response to substantiated allegations received under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action the Commission has taken in response to suggestions or allegations received under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The activities of the Inspector General under this subsection shall be funded by the Securities and Exchange Commission Investor Protection Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78u–6"},"text":"section 78u–6 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78063d5d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 4D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s966"},"text":"Pub. L. 111–203, title IX, § 966","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1912"},"text":"124 Stat. 1912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78063d5e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78063d5f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78063d60-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
