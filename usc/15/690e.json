{"tag":"section","attrib":{"id":"id792b83e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e"},"text":null,"children":[{"tag":"num","attrib":{"value":"690e"},"text":"§ 690e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and guarantee of trust certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792b83ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may issue trust certificates representing ownership of all or a fractional part of debentures issued by a Renewable Fuel Capital Investment company and guaranteed by the Administrator under this part, if such certificates are based on and backed by a trust or pool approved by the Administrator and composed solely of guaranteed debentures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b83ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may, under such terms and conditions as it determines appropriate, guarantee the timely payment of the principal of and interest on trust certificates issued by the Administrator or its agents for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each guarantee under this subsection shall be limited to the extent of principal and interest on the guaranteed debentures that compose the trust or pool.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment or default","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a debenture in a trust or pool is prepaid, or in the event of default of such a debenture, the guarantee of timely payment of principal and interest on the trust certificates shall be reduced in proportion to the amount of principal and interest such prepaid debenture represents in the trust or pool. Interest on prepaid or defaulted debentures shall accrue and be guaranteed by the Administrator only through the date of payment of the guarantee. At any time during its term, a trust certificate may be called for redemption due to prepayment or default of all debentures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to pay all amounts that may be required to be paid under any guarantee of a trust certificate issued by the Administrator or its agents under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall not collect a fee for any guarantee of a trust certificate under this section, but any agent of the Administrator may collect a fee approved by the Administrator for the functions described in subsection (f)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation and ownership rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b83f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator pays a claim under a guarantee issued under this section, it shall be subrogated fully to the rights satisfied by such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No Federal, State, or local law shall preclude or limit the exercise by the Administrator of its ownership rights in the debentures residing in a trust or pool against which trust certificates are issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management and administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b83f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may provide for a central registration of all trust certificates issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting of functions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792b83f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may contract with an agent or agents to carry out on behalf of the Administrator the pooling and the central registration functions provided for in this section, including, not withstanding any other provision of law—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792b83f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance, on behalf of and under the direction of the Administrator, of such commercial bank accounts or investments in obligations of the United States as may be necessary to facilitate the creation of trusts or pools backed by debentures guaranteed under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792b83f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of trust certificates to facilitate the creation of such trusts or pools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b83fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fidelity bond or insurance requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agent performing functions on behalf of the Administrator under this paragraph shall provide a fidelity bond or insurance in such amounts as the Administrator determines to be necessary to fully protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of brokers and dealers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may regulate brokers and dealers in trust certificates issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690e/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed to prohibit the use of a book-entry or other electronic form of registration for trust certificates issued under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792b83fd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s386"},"text":"Pub. L. 85–699, title III, § 386","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1779"},"text":"121 Stat. 1779","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
