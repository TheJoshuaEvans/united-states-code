{"tag":"section","attrib":{"id":"id79b5e8ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1691c–1"},"text":"§ 1691c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for self-testing and self-correction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b5e8ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileged information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e8f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for privilege","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report or result of a self-test (as that term is defined by regulations of the Bureau) shall be considered to be privileged under paragraph (2) if a creditor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e8f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts, or authorizes an independent third party to conduct, a self-test of any aspect of a credit transaction by a creditor, in order to determine the level or effectiveness of compliance with this subchapter by the creditor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e8f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has identified any possible violation of this subchapter by the creditor and has taken, or is taking, appropriate corrective action to address any such possible violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e8f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privileged self-test","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a creditor meets the conditions specified in subparagraphs (A) and (B) of paragraph (1) with respect to a self-test described in that paragraph, any report or results of that self-test—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e8f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be privileged; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e8f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not be obtained or used by any applicant, department, or agency in any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b5e8f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeding or civil action in which one or more violations of this subchapter are alleged; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b5e8f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examination or investigation relating to compliance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e8f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results of self-testing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e8f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No provision of this section may be construed to prevent an applicant, department, or agency from obtaining or using a report or results of any self-test in any proceeding or civil action in which a violation of this subchapter is alleged, or in any examination or investigation of compliance with this subchapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e8fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the creditor or any person with lawful access to the report or results—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79b5e8fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntarily releases or discloses all, or any part of, the report or results to the applicant, department, or agency, or to the general public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79b5e8fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refers to or describes the report or results as a defense to charges of violations of this subchapter against the creditor to whom the self-test relates; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e8fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report or results are sought in conjunction with an adjudication or admission of a violation of this subchapter for the sole purpose of determining an appropriate penalty or remedy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e8fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure for determination of penalty or remedy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any report or results of a self-test that are disclosed for the purpose specified in paragraph (1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e8ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used only for the particular proceeding in which the adjudication or admission referred to in paragraph (1)(B) is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e900-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used in any other action or proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e901-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant, department, or agency that challenges a privilege asserted under this section may seek a determination of the existence and application of that privilege in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e902-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court of competent jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e903-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative law proceeding with appropriate jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b5e904-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVII/s704A"},"text":"Pub. L. 90–321, title VII, § 704A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2302/a/1"},"text":"Pub. L. 104–208, div. A, title II, § 2302(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-420"},"text":"110 Stat. 3009–420","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1085/1"},"text":"Pub. L. 111–203, title X, § 1085(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2083"},"text":"124 Stat. 2083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b5e905-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b5e906-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79b5e907-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b5e908-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79b5e909-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79b5e90a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2302/c"},"text":"Pub. L. 104–208, div. A, title II, § 2302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-423"},"text":"110 Stat. 3009–423","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tII/s2302/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the privilege provided for in section 704A of the Equal Credit Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1691c–1"},"text":"15 U.S.C. 1691c–1","children":[],"tail":"] or section 814A of the Fair Housing Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3614–1"},"text":"42 U.S.C. 3614–1","children":[],"tail":"] (as those sections are added by this section) shall apply to a self-test (as that term is defined pursuant to the regulations prescribed under subsection (a)(2) [set out below] or (b)(2) of this section ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3614–1"},"text":"42 U.S.C. 3614–1","children":[],"tail":" note], as appropriate) conducted before, on, or after the effective date of the regulations prescribed under subsection (a)(2) or (b)(2), as appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The privilege referred to in paragraph (1) does not apply to such a self-test conducted before the effective date of the regulations prescribed under subsection (a) or (b), as appropriate, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before that effective date, a complaint against the creditor or person engaged in residential real estate related lending activities (as the case may be) was—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formally filed in any court of competent jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subject of an ongoing administrative law proceeding;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of section 704A of the Equal Credit Opportunity Act, the creditor has waived the privilege pursuant to subsection (b)(1)(A)(i) of that section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of section 814A of the Fair Housing Act, the person engaged in residential real estate related lending activities has waived the privilege pursuant to subsection (b)(1)(A)(i) of that section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79b5e90b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2302/a/2"},"text":"Pub. L. 104–208, div. A, title II, § 2302(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-421"},"text":"110 Stat. 3009–421","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tII/s2302/a/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"], in consultation with the Secretary of Housing and Urban Development and the agencies referred to in section 704 of the Equal Credit Opportunity Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1691c"},"text":"15 U.S.C. 1691c","children":[],"tail":"], and after providing notice and an opportunity for public comment, the Board shall prescribe final regulations to implement section 704A of the Equal Credit Opportunity Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1691c–1"},"text":"15 U.S.C. 1691c–1","children":[],"tail":"], as added by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Self-test.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed under subparagraph (A) shall include a definition of the term ‘self-test’ for purposes of section 704A of the Equal Credit Opportunity Act, as added by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for self-test","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed under subparagraph (A) shall specify that a self-test shall be sufficiently extensive to constitute a determination of the level and effectiveness of compliance by a creditor with the Equal Credit Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1691"},"text":"15 U.S.C. 1691","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantial similarity to certain fair housing act regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed under subparagraph (A) shall be substantially similar to the regulations prescribed by the Secretary of Housing and Urban Development to carry out section 814A(d) of the Fair Housing Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3614–1/d"},"text":"42 U.S.C. 3614–1(d)","children":[],"tail":"], as added by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
