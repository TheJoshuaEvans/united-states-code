{"tag":"section","attrib":{"id":"id78a144e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s330b"},"text":null,"children":[{"tag":"num","attrib":{"value":"330b"},"text":"§ 330b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a144ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s330b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records, maintenance; summaries, publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain a record of weather modification activities, including attempts, which take place in the United States and shall publish summaries thereof from time to time as he determines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a144eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s330b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of reports, documents, and other information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All reports, documents, and other information received by the Secretary under the provisions of this chapter shall be made available to the public to the fullest practicable extent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a144ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s330b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of confidential information; prohibition; exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the provisions of this section, the Secretary shall not disclose any information referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" and is otherwise unavailable to the public, except that such information shall be disclosed—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a144ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s330b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to other Federal Government departments, agencies, and officials for official use upon request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a144ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s330b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any judicial proceeding under court order formulated to preserve the confidentiality of such information without impairing the proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a144ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s330b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the public if necessary to protect their health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a144f0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/205/s3"},"text":"Pub. L. 92–205, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/736"},"text":"85 Stat. 736","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
