{"tag":"section","attrib":{"id":"id789c89a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s281a"},"text":null,"children":[{"tag":"num","attrib":{"value":"281a"},"text":"§ 281a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structural failures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Institute of Standards and Technology, on its own initiative but only after consultation with local authorities, may initiate and conduct investigations to determine the causes of structural failures in structures which are used or occupied by the general public. No part of any report resulting from such investigation, or from an investigation under the National Construction Safety Team Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7301"},"text":"15 U.S.C. 7301","children":[],"tail":" et seq.], shall be admitted as evidence or used in any suit or action for damages arising out of any matter mentioned in such report."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789c89a7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/73/s7"},"text":"Pub. L. 99–73, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-07-29"},"text":"July 29, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/173"},"text":"99 Stat. 173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/231/s13"},"text":"Pub. L. 107–231, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1476"},"text":"116 Stat. 1476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789c89a8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789c89a9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id789c89aa-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Construction Safety Team Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231"},"text":"Pub. L. 107–231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1471"},"text":"116 Stat. 1471","children":[],"tail":", which is classified generally to chapter 99 [§ 7301 et seq.] of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7301"},"text":"section 7301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id789c89ab-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id789c89ac-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/231"},"text":"Pub. L. 107–231","children":[],"tail":" inserted “, or from an investigation under the National Construction Safety Team Act,” after “from such investigation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “National Institute of Standards and Technology” for “National Bureau of Standards”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
