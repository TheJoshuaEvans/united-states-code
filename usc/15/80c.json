{"tag":"section","attrib":{"id":"id78824bb9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80c"},"text":null,"children":[{"tag":"num","attrib":{"value":"80c"},"text":"§ 80c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison between Securities and Exchange Commission and Small Business Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78824bba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on needs, problems, and costs of businesses; availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Securities and Exchange Commission shall gather, analyze, and make available to the public, information with respect to the capital formation needs, and the problems and costs involved with new, small, medium-sized, and independent businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824bbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of studies to Small Business Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make the results of such studies available to the Small Business Administration and otherwise have regular communication and liaison with such Administration in these matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78824bbc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/477/tV/s502"},"text":"Pub. L. 96–477, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2292"},"text":"94 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78824bbd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78824bbe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78824bbf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/477/tV/s507"},"text":"Pub. L. 96–477, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2294"},"text":"94 Stat. 2294","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/477/tV/s507"},"text":"“Except as otherwise specified, the amendments made by this title [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s"},"text":"section 77s of this title","children":[],"tail":"] shall become effective January 1 of the year following the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id78824bc0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/477/tV/s501"},"text":"Pub. L. 96–477, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2291"},"text":"94 Stat. 2291","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/477/tV/s501"},"text":"“This title [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77s"},"text":"section 77s of this title","children":[],"tail":"] may be cited as the ‘Omnibus Small Business Capital Formation Act of 1980’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
