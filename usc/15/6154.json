{"tag":"section","attrib":{"id":"id7a55ab94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6154"},"text":null,"children":[{"tag":"num","attrib":{"value":"6154"},"text":"§ 6154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a55ab95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":", and biennially thereafter, the Federal Trade Commission, in consultation with the Federal Communications Commission, shall transmit a report to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Energy and Commerce that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ab96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6154/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of consumers who have placed their telephone numbers on the registry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ab97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6154/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of persons paying fees for access to the registry and the amount of such fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ab98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6154/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":