{"tag":"section","attrib":{"id":"id7a5a66dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504"},"text":null,"children":[{"tag":"num","attrib":{"value":"6504"},"text":"§ 6504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5a66de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a66df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the attorney general of a State has reason to believe that an interest of the residents of that State has been or is threatened or adversely affected by the engagement of any person in a practice that violates any regulation of the Commission prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6502/b"},"text":"section 6502(b) of this title","children":[],"tail":", the State, as parens patriae, may bring a civil action on behalf of the residents of the State in a district court of the United States of appropriate jurisdiction to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a66e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enjoin that practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a66e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce compliance with the regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a66e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain damage, restitution, or other compensation on behalf of residents of the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a66e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain such other relief as the court may consider to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a66e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before filing an action under paragraph (1), the attorney general of the State involved shall provide to the Commission—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a66e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written notice of that action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a66e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the complaint for that action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a66e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a66e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply with respect to the filing of an action by an attorney general of a State under this subsection, if the attorney general determines that it is not feasible to provide the notice described in that subparagraph before the filing of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a66ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an action described in clause (i), the attorney general of a State shall provide notice and a copy of the complaint to the Commission at the same time as the attorney general files the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a66eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a66ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On receiving notice under subsection (a)(2), the Commission shall have the right to intervene in the action that is the subject of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of intervention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commission intervenes in an action under subsection (a), it shall have the right—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a66ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be heard with respect to any matter that arises in that action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a66ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file a petition for appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amicus curiae","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon application to the court, a person whose self-regulatory guidelines have been approved by the Commission and are relied upon as a defense by any defendant to a proceeding under this section may file amicus curiae in that proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a66f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of bringing any civil action under subsection (a), nothing in this chapter shall be construed to prevent an attorney general of a State from exercising the powers conferred on the attorney general by the laws of that State to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a66f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer oaths or affirmations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compel the attendance of witnesses or the production of documentary and other evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a66f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an action is instituted by or on behalf of the Commission for violation of any regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6502"},"text":"section 6502 of this title","children":[],"tail":", no State may, during the pendency of that action, institute an action under subsection (a) against any defendant named in the complaint in that action for violation of that regulation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a66f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue; service of process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a66f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action brought under subsection (a) may be brought in the district court of the United States that meets applicable requirements relating to venue under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under subsection (a), process may be served in any district in which the defendant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a66f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an inhabitant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a66fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6504/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5a66fb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tXIII/s1305"},"text":"Pub. L. 105–277, div. C, title XIII, § 1305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-733"},"text":"112 Stat. 2681–733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a5a66fc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a5a66fd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a5a66fe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1308"},"text":"section 1308 of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6501"},"text":"section 6501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
