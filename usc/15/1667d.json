{"tag":"section","attrib":{"id":"id79a065e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667d"},"text":"§ 1667d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability of lessors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a065e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for maintenance of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any lessor who fails to comply with any requirement imposed under section 1667a or 1667b of this title with respect to any person is liable to such person as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1640"},"text":"section 1640 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a065e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional grounds for maintenance of action; “creditor” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any lessor who fails to comply with any requirement imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1667c"},"text":"section 1667c of this title","children":[],"tail":" with respect to any person who suffers actual damage from the violation is liable to such person as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1640"},"text":"section 1640 of this title","children":[],"tail":". For the purposes of this section, the term “creditor” as used in sections 1640 and 1641 of this title shall include a lessor as defined in this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a065e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts; time limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1640/e"},"text":"section 1640(e) of this title","children":[],"tail":", any action under this section may be brought in any United States district court or in any other court of competent jurisdiction. Such actions alleging a failure to disclose or otherwise comply with the requirements of this part shall be brought within one year of the termination of the lease agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a065e9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s185"},"text":"Pub. L. 90–321, title I, § 185","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/240/s3"},"text":"Pub. L. 94–240, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-23"},"text":"Mar. 23, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/260"},"text":"90 Stat. 260","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/tVI/s624"},"text":"Pub. L. 96–221, title VI, § 624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/185"},"text":"94 Stat. 185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a065ea-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a065eb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a065ec-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" struck out applicability of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1614"},"text":"section 1614 of this title","children":[],"tail":" to term “creditor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a065ed-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a065ee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/221"},"text":"Pub. L. 96–221","children":[],"tail":" effective on expiration of two years and six months after "},{"tag":"date","attrib":{"date":"1980-03-31"},"text":"Mar. 31, 1980","children":[],"tail":", with all regulations, forms, and clauses required to be prescribed to be promulgated at least one year prior to such effective date, and allowing any creditor to comply with any amendments, in accordance with the regulations, forms, and clauses prescribed by the Board prior to such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/221/s625"},"text":"section 625 of Pub. L. 96–221","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
