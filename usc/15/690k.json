{"tag":"section","attrib":{"id":"id792b841e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690k"},"text":null,"children":[{"tag":"num","attrib":{"value":"690k"},"text":"§ 690k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each Renewable Fuel Capital Investment company that participates in the program established under this part shall provide to the Administrator such information as the Administrator may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b841f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information related to the measurement criteria that the company proposed in its program application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b8420-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each case in which the company makes, under this part, an investment in, or a loan or a grant to, a business that is not primarily engaged in the research, development, manufacture, or bringing to market or ","children":[{"tag":"ref","attrib":{"idref":"fn002268"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002268"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of”."}],"tail":" renewable energy sources, a report on the nature, origin, and revenues of the business in which investments are made."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792b8421-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s392"},"text":"Pub. L. 85–699, title III, § 392","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1782"},"text":"121 Stat. 1782","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
