{"tag":"section","attrib":{"id":"id7a82fd5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8231"},"text":null,"children":[{"tag":"num","attrib":{"value":"8231"},"text":"§ 8231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter or the amendments made by this subtitle ","children":[{"tag":"ref","attrib":{"idref":"fn002585"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002585"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be construed to modify, impair, or supersede the application of the antitrust laws. Any implied or actual conflict between this chapter and any amendments to this chapter and the antitrust laws shall be resolved in favor of the operation of the antitrust laws."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a82fd5b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tV/s541"},"text":"Pub. L. 111–203, title V, § 541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1596"},"text":"124 Stat. 1596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a82fd5c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a82fd5d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a82fd5e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[