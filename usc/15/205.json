{"tag":"section","attrib":{"id":"id78870651-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205"},"text":null,"children":[{"tag":"num","attrib":{"value":"205"},"text":"§ 205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metric system defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The metric system of measurement shall be defined as the International System of Units as established in 1960, and subsequently maintained, by the General Conference of Weights and Measures, and as interpreted or modified for the United States by the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78870652-552d-11f1-9071-ff305b7c3ff0"},"text":"(R.S. § 3570; ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII/s3013/c/1"},"text":"Pub. L. 110–69, title III, § 3013(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/598"},"text":"121 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78870653-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78870654-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78870655-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 3570 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-07-28/ch301/s2"},"text":"act July 28, 1866, ch. 301, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/339"},"text":"14 Stat. 339","children":[],"tail":", 340."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78870656-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The tables in the schedule annexed shall be recognized in the construction of contracts and in all legal proceedings as establishing, in terms of the weights and measures on "},{"tag":"date","attrib":{"date":"1874-06-22"},"text":"June 22, 1874","children":[],"tail":", in use in the United States, the equivalents of the weights and measures expressed therein in terms of the metric system; and the tables may lawfully be used for computing, determining, and expressing in customary weights and measures the weights and measures of the metric system.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
