<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id7a74a655-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407"><num value="7407">§ 7407.</num><heading> Authorization of appropriations</heading>
<chapeau style="-uslm-lc:I11" class="indent0">There are authorized to be appropriated to the Secretary of Commerce for the National Institute of Standards and Technology—</chapeau><paragraph style="-uslm-lc:I12" class="indent1" id="id7a74a656-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/1"><num value="1">(1)</num><chapeau> for activities under <ref href="/us/usc/t15/s278h">section 278h of this title</ref>—</chapeau><subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a657-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/1/A"><num value="A">(A)</num><content> $25,000,000 for fiscal year 2003;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a658-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/1/B"><num value="B">(B)</num><content> $40,000,000 for fiscal year 2004;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a659-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/1/C"><num value="C">(C)</num><content> $55,000,000 for fiscal year 2005;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a65a-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/1/D"><num value="D">(D)</num><content> $70,000,000 for fiscal year 2006;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a65b-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/1/E"><num value="E">(E)</num><content> $85,000,000 for fiscal year 2007; and</content>
</subparagraph>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="id7a74a65c-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/2"><num value="2">(2)</num><chapeau> for activities under section 278g–3(f) <ref class="footnoteRef" idref="fn002572">1</ref><note type="footnote" id="fn002572"><num>1</num> See References in Text note below.</note> of this title—</chapeau><subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a65d-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/2/A"><num value="A">(A)</num><content> $6,000,000 for fiscal year 2003;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a65e-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/2/B"><num value="B">(B)</num><content> $6,200,000 for fiscal year 2004;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a65f-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/2/C"><num value="C">(C)</num><content> $6,400,000 for fiscal year 2005;</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a660-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/2/D"><num value="D">(D)</num><content> $6,600,000 for fiscal year 2006; and</content>
</subparagraph>
<subparagraph style="-uslm-lc:I13" class="indent2" id="id7a74a661-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7407/2/E"><num value="E">(E)</num><content> $6,800,000 for fiscal year 2007.</content>
</subparagraph>
</paragraph>
