{"tag":"section","attrib":{"id":"id7854f9ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo"},"text":null,"children":[{"tag":"num","attrib":{"value":"78oo"},"text":"§ 78oo.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal National Mortgage Association, Federal Home Loan Mortgage Corporation, Federal Home Loan Banks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7854f9eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal National Mortgage Association and Federal Home Loan Mortgage Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No class of equity securities of the Federal National Mortgage Association or the Federal Home Loan Mortgage Corporation shall be treated as an exempted security for purposes of section 78","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 78m, 78n, or 78p of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854f9ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Home Loan Banks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854f9ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal Home Loan Bank shall register a class of its common stock under section 78","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(g) of this title, not later than 120 days after "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", and shall thereafter maintain such registration and be treated for purposes of this chapter as an “issuer”, the securities of which are required to be registered under section 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, regardless of the number of members holding such stock at any given time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854f9ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards relating to audit committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal Home Loan Bank shall comply with the rules issued by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j–1/m"},"text":"section 78j–1(m) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7854f9ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7854f9f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Home Loan Bank; member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Federal Home Loan Bank” and “member”, have the same meanings as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1422"},"text":"section 1422 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854f9f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal National Mortgage Association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal National Mortgage Association” means the corporation created by the Federal National Mortgage Association Charter Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1716"},"text":"12 U.S.C. 1716","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7854f9f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78oo/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Home Loan Mortgage Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal Home Loan Mortgage Corporation” means the corporation created by the Federal Home Loan Mortgage Corporation Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1451"},"text":"12 U.S.C. 1451","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7854f9f3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 38, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tI/s1112"},"text":"Pub. L. 110–289, div. A, title I, § 1112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2677"},"text":"122 Stat. 2677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7854f9f4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7854f9f5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7854f9f6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1), was in the original “this title”. See References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of this title","children":[],"tail":" and Codification note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal National Mortgage Association Charter Act, referred to in subsec. (c)(2), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-27/ch847"},"text":"act June 27, 1934, ch. 847","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1252"},"text":"48 Stat. 1252","children":[],"tail":", which is classified generally to subchapter III (§ 1716 et seq.) of chapter 13 of Title 12, Banks and Banking. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1716"},"text":"section 1716 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Home Loan Mortgage Corporation Act, referred to in subsec. (c)(3), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/351"},"text":"Pub. L. 91–351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/451"},"text":"84 Stat. 451","children":[],"tail":", which is classified generally to chapter 11A (§ 1451 et seq.) of Title 12, Banks and Banking. For complete classification of this Act to the Code, see Short Title and Statement of Purpose note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1451"},"text":"section 1451 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7854f9f7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/289"},"text":"Pub. L. 110–289","children":[],"tail":", which directed amendment of the Securities Exchange Act of 1934 by adding this section at the end, is reflected in the source credit above as adding this section to title I of the Securities Exchange Act of 1934, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
