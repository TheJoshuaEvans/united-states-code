{"tag":"section","attrib":{"id":"id79aebccb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1681n"},"text":"§ 1681n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability for willful noncompliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79aebccc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who willfully fails to comply with any requirement imposed under this subchapter with respect to any consumer is liable to that consumer in an amount equal to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79aebccd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79aebcce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any actual damages sustained by the consumer as a result of the failure or damages of not less than $100 and not more than $1,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79aebccf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of liability of a natural person for obtaining a consumer report under false pretenses or knowingly without a permissible purpose, actual damages sustained by the consumer as a result of the failure or $1,000, whichever is greater;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aebcd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amount of punitive damages as the court may allow; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79aebcd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any successful action to enforce any liability under this section, the costs of the action together with reasonable attorney’s fees as determined by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aebcd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability for knowing noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who obtains a consumer report from a consumer reporting agency under false pretenses or knowingly without a permissible purpose shall be liable to the consumer reporting agency for actual damages sustained by the consumer reporting agency or $1,000, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aebcd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney’s fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon a finding by the court that an unsuccessful pleading, motion, or other paper filed in connection with an action under this section was filed in bad faith or for purposes of harassment, the court shall award to the prevailing party attorney’s fees reasonable in relation to the work expended in responding to the pleading, motion, or other paper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79aebcd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1681n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of willful noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, any person who printed an expiration date on any receipt provided to a consumer cardholder at a point of sale or transaction between ","children":[{"tag":"date","attrib":{"date":"2004-12-04"},"text":"December 4, 2004","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2008-06-03"},"text":"June 3, 2008","children":[],"tail":", but otherwise complied with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681c/g"},"text":"section 1681c(g) of this title","children":[],"tail":" for such receipt shall not be in willful noncompliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681c/g"},"text":"section 1681c(g) of this title","children":[],"tail":" by reason of printing such expiration date on the receipt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79aebcd5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVI/s616"},"text":"Pub. L. 90–321, title VI, § 616","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tVI/s601"},"text":"Pub. L. 91–508, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1134"},"text":"84 Stat. 1134","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2412/a"},"text":"Pub. L. 104–208, div. A, title II, § 2412(a)","children":[],"tail":"–(c), (e)(1), "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-446"},"text":"110 Stat. 3009–446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/241/s3/a"},"text":"Pub. L. 110–241, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-03"},"text":"June 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1566"},"text":"122 Stat. 1566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79aebcd6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79aebcd7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79aebcd8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/241"},"text":"Pub. L. 110–241","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2412/a"},"text":"Pub. L. 104–208, § 2412(a)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, and in introductory provisions substituted “Any person who” for “Any consumer reporting agency or user of information which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2412/b"},"text":"Pub. L. 104–208, § 2412(b)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “any actual damages sustained by the consumer as a result of the failure;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2412/c"},"text":"Pub. L. 104–208, § 2412(c)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2412/e/1"},"text":"Pub. L. 104–208, § 2412(e)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79aebcd9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79aebcda-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective 365 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", with special rule for early compliance, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s2420"},"text":"section 2420 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a"},"text":"section 1681a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79aebcdb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon the expiration of one hundred and eighty days following ","children":[{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s504/d"},"text":"section 504(d) of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/508"},"text":"Pub. L. 91–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"section 1681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79aebcdc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159/tIII/s312/f"},"text":"Pub. L. 108–159, title III, § 312(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1993"},"text":"117 Stat. 1993","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/159/tIII/s312/f"},"text":"“Nothing in this section, the amendments made by this section, or any other provision of this Act [see Short Title of 2003 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":"] shall be construed to affect any liability under section 616 or 617 of the Fair Credit Reporting Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681n"},"text":"15 U.S.C. 1681n","children":[],"tail":", 1681"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") that existed on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-12-04"},"text":"Dec. 4, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79aebcdd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Statement of Findings and Purpose for 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/241/s2"},"text":"Pub. L. 110–241, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-03"},"text":"June 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1565"},"text":"122 Stat. 1565","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/241/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fair and Accurate Credit Transactions Act [of 2003] (commonly referred to as ‘FACTA’) [","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/159"},"text":"Pub. L. 108–159","children":[],"tail":", see Short Title of 2003 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":"] was enacted into law in 2003 and 1 of the purposes of such Act is to prevent criminals from obtaining access to consumers’ private financial and credit information in order to reduce identity theft and credit card fraud."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of that law, the Congress enacted a requirement, through an amendment to the Fair Credit Reporting Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"15 U.S.C. 1681","children":[],"tail":" et seq.], that no person that accepts credit cards or debit cards for the transaction of business shall print more than the last 5 digits of the card number or the expiration date upon any receipt provided to the card holder at the point of the sale or transaction."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Many merchants understood that this requirement would be satisfied by truncating the account number down to the last 5 digits based in part on the language of the provision as well as the publicity in the aftermath of the passage of the law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Almost immediately after the deadline for compliance passed, hundreds of lawsuits were filed alleging that the failure to remove the expiration date was a willful violation of the Fair Credit Reporting Act even where the account number was properly truncated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" None of these lawsuits contained an allegation of harm to any consumer’s identity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experts in the field agree that proper truncation of the card number, by itself as required by the amendment made by the Fair and Accurate Credit Transactions Act [of 2003], regardless of the inclusion of the expiration date, prevents a potential fraudster from perpetrating identity theft or credit card fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Despite repeatedly being denied class certification, the continued appealing and filing of these lawsuits represents a significant burden on the hundreds of companies that have been sued and could well raise prices to consumers without corresponding consumer protection benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this Act [amending this section and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":"] is to ensure that consumers suffering from any actual harm to their credit or identity are protected while simultaneously limiting abusive lawsuits that do not protect consumers but only result in increased cost to business and potentially increased prices to consumers.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"retroactiveDate","id":"id79aebcde-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactive Effect of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/241/s3/b"},"text":"Pub. L. 110–241, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-03"},"text":"June 3, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1566"},"text":"122 Stat. 1566","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/241/s3/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to any action, other than an action which has become final, that is brought for a violation of [section] 605(g) of the Fair Credit Reporting Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681c/g"},"text":"15 U.S.C. 1681c(g)","children":[],"tail":"] to which such amendment applies without regard to whether such action is brought before or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-06-03"},"text":"June 3, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
