{"tag":"section","attrib":{"id":"id7a0baab3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2704"},"text":null,"children":[{"tag":"num","attrib":{"value":"2704"},"text":"§ 2704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation by Secretary of Transportation on utilization of advanced technology by automobile industry","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, in furtherance of the purposes of this chapter, shall evaluate the extent to which the automobile industry utilizes advanced automotive technology which is or could be made available to it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a0baab4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/238/tIII/s305"},"text":"Pub. L. 95–238, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-02-25"},"text":"Feb. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/81"},"text":"92 Stat. 81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1121/i"},"text":"Pub. L. 104–66, title I, § 1121(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/724"},"text":"109 Stat. 724","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0baab5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a0baab6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a0baab7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out at end “The Secretary of Transportation shall submit a report to the Congress each year on the results of such evaluation including any appropriate recommendations which may encourage the utilization of advanced automobile technology by the automobile industry.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
