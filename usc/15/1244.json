{"tag":"section","attrib":{"id":"id796be8f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1244"},"text":null,"children":[{"tag":"num","attrib":{"value":"1244"},"text":"§ 1244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 1242 and 1243 of this title shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796be8f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1244/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any common carrier or contract carrier, with respect to any switchblade knife shipped, transported, or delivered for shipment in interstate commerce in the ordinary course of business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1244/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacture, sale, transportation, distribution, possession, or introduction into interstate commerce, of switchblade knives pursuant to contract with the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1244/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Armed Forces or any member or employee thereof acting in the performance of his duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1244/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the possession, and transportation upon his person, of any switchblade knife with a blade three inches or less in length by any individual who has only one arm; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1244/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a knife that contains a spring, detent, or other mechanism designed to create a bias toward closure of the blade and that requires exertion applied to the blade by hand, wrist, or arm to overcome the bias toward closure to assist in opening the knife.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796be8fb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623/s4"},"text":"Pub. L. 85–623, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/562"},"text":"72 Stat. 562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/83/tV/s562"},"text":"Pub. L. 111–83, title V, § 562","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2183"},"text":"123 Stat. 2183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be8fc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796be8fd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id796be8fe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":