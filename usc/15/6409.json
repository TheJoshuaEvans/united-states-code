{"tag":"section","attrib":{"id":"id7a57f67d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6409"},"text":null,"children":[{"tag":"num","attrib":{"value":"6409"},"text":"§ 6409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pricing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all cases, the price of propane shall be determined by market forces. Consistent with the antitrust laws, the Council may take no action, nor may any provision of this chapter be interpreted as establishing an agreement to pass along to consumers the cost of the assessment provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6405"},"text":"section 6405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a57f67e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/284/s10"},"text":"Pub. L. 104–284, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3375"},"text":"110 Stat. 3375","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
