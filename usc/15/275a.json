{"tag":"section","attrib":{"id":"id788e3250-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s275a"},"text":null,"children":[{"tag":"num","attrib":{"value":"275a"},"text":"§ 275a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall charge for services performed under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s273"},"text":"section 273 of this title","children":[],"tail":", except in cases where he determines that the interest of the Government would be best served by waiving the charge. Such charges may be based upon fixed prices or costs. The appropriation or fund bearing the cost of the services may be reimbursed, or the Secretary may require advance payment subject to such adjustment on completion of the work as may be agreed upon."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788e3251-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s7"},"text":"Mar. 3, 1901, ch. 872, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch906/s1"},"text":"Aug. 3, 1956, ch. 906, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/959"},"text":"70 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788e3252-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788e3253-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id788e3254-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib"