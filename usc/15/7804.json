{"tag":"section","attrib":{"id":"id7a7e1b62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804"},"text":null,"children":[{"tag":"num","attrib":{"value":"7804"},"text":"§ 7804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7e1b63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7e1b64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the attorney general of a State has reason to believe that an interest of the residents of that State has been or is threatened or adversely affected by the engagement of any athlete agent in a practice that violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7802"},"text":"section 7802 of this title","children":[],"tail":", the State may bring a civil action on behalf of the residents of the State in a district court of the United States of appropriate jurisdiction to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7e1b65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enjoin that practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7e1b66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce compliance with this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7e1b67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain damage, restitution, or other compensation on behalf of residents of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7e1b69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before filing an action under paragraph (1), the attorney general of the State involved shall provide to the Commission—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a7e1b6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written notice of that action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a7e1b6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the complaint for that action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7e1b6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply with respect to the filing of an action by an attorney general of a State under this subsection, if the attorney general determines that it is not feasible to provide the notice described in that subparagraph before filing of the action. In such case, the attorney general of a State shall provide notice and a copy of the complaint to the Commission at the same time as the attorney general files the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7e1b6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7e1b6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On receiving notice under subsection (a)(2), the Commission shall have the right to intervene in the action that is the subject of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of intervention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commission intervenes in an action under subsection (a), it shall have the right—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7e1b70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be heard with respect to any matter that arises in that action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7e1b71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file a petition for appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7e1b72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of bringing any civil action under subsection (a), nothing in this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002582"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002582"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be construed to prevent an attorney general of a State from exercising the powers conferred on the attorney general by the laws of that State to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7e1b73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer oaths or affirmations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compel the attendance of witnesses or the production of documentary and other evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7e1b76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by the Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which an action is instituted by or on behalf of the Commission for a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7802"},"text":"section 7802 of this title","children":[],"tail":", no State may, during the pendency of that action, institute an action under subsection (a) against any defendant named in the complaint in that action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7e1b77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action brought under subsection (a) may be brought in the district court of the United States that meets applicable requirements relating to venue under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7e1b78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action brought under subsection (a), process may be served in any district in which the defendant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7e1b79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an inhabitant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7804/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7e1b7b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/304/s5"},"text":"Pub. L. 108–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-09-24"},"text":"Sept. 24, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1127"},"text":"118 Stat. 1127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7e1b7c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a7e1b7d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a7e1b7e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this title” and was translated as reading “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/304"},"text":"Pub. L. 108–304","children":[],"tail":", to reflect the probable intent of Congress, because "},{"tag":"ref","attrib":{"href":"/us/pl/108/304"},"text":"Pub. L. 108–304","children":[],"tail":" does not contain titles."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
