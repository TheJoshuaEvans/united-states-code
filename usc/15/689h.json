{"tag":"section","attrib":{"id":"id79293a62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689h"},"text":null,"children":[{"tag":"num","attrib":{"value":"689h"},"text":"§ 689h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79293a63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), any national bank, any member bank of the Federal Reserve System, and (to the extent permitted under applicable State law) any insured bank that is not a member of such system, may invest in any New Markets Venture Capital company, or in any entity established to invest solely in New Markets Venture Capital companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No bank described in subsection (a) may make investments described in such subsection that are greater than 5 percent of the capital and surplus of the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293a65-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s359"},"text":"Pub. L. 85–699, title III, § 359","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–661.)"}],"tail":"\n"}],"tail":null}
