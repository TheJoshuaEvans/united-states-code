{"tag":"section","attrib":{"id":"id78680c5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–13"},"text":"§ 80a–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in investment policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78680c60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited actions for registered investment companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No registered investment company shall, unless authorized by the vote of a majority of its outstanding voting securities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78680c61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change its subclassification as defined in section 80a–5(a)(1) and (2) of this title or its subclassification from a diversified to a nondiversified company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78680c62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money, issue senior securities, underwrite securities issued by other persons, purchase or sell real estate or commodities or make loans to other persons, except in each case in accordance with the recitals of policy contained in its registration statement in respect thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78680c63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deviate from its policy in respect of concentration of investments in any particular industry or group of industries as recited in its registration statement, deviate from any investment policy which is changeable only if authorized by shareholder vote, or deviate from any policy recited in its registration statement pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–8/b/3"},"text":"section 80a–8(b)(3) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78680c64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change the nature of its business so as to cease to be an investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78680c65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority equivalent for common-law trusts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a common-law trust of the character described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–16/c"},"text":"section 80a–16(c) of this title","children":[],"tail":", either written approval by holders of a majority of the outstanding shares of beneficial interest or the vote of a majority of such outstanding shares cast in person or by proxy at a meeting called for the purpose shall for the purposes of subsection (a) be deemed the equivalent of the vote of a majority of the outstanding voting securities, and the provisions of paragraph (42) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–2/a"},"text":"section 80a–2(a) of this title","children":[],"tail":" as to a majority shall be applicable to the vote cast at such a meeting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78680c66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78680c67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of Federal or State law, no person may bring any civil, criminal, or administrative action against any registered investment company, or any employee, officer, director, or investment adviser thereof, based solely upon the investment company divesting from, or avoiding investing in, securities issued by persons that the investment company determines, using credible information available to the public—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78680c68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct or have direct investments in business operations in Sudan described in section 3(d) of the Sudan Accountability and Divestment Act of 2007 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78680c69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in investment activities in Iran described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8532/c"},"text":"section 8532(c) of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78680c6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78680c6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) shall be construed to create, imply, diminish, change, or affect in any way whether or not a private right of action exists under subsection (a) or any other provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78680c6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to a registered investment company, or any employee, officer, director, or investment adviser thereof, unless the investment company makes disclosures in accordance with regulations prescribed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78680c6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–13/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection the term “person” includes the Federal Government and any State or political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78680c6e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 13, "},{"tag":"ref","attrib":{"href":"/us/stat/54/811"},"text":"54 Stat. 811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/547"},"text":"Pub. L. 91–547","children":[],"tail":", §§ 2(b), 3(d), "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1414"},"text":"84 Stat. 1414","children":[],"tail":", 1415; "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s28/4"},"text":"Pub. L. 94–29, § 28(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/165"},"text":"89 Stat. 165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/174/s4/a"},"text":"Pub. L. 110–174, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"Dec. 31, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2519"},"text":"121 Stat. 2519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/195/tII"},"text":"Pub. L. 111–195, title II","children":[],"tail":", §§ 203(a), 205(b)(1), "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1343"},"text":"124 Stat. 1343","children":[],"tail":", 1345.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78680c6f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id78680c70-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of subsection (c)(1)(B) of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/174/s12"},"text":"section 12 of Pub. L. 110–174","children":[],"tail":", see Termination Date of 2007 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78680c71-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78680c72-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(d) of the Sudan Accountability and Divestment Act of 2007, referred to in subsec. (c)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/174/s3/d"},"text":"section 3(d) of Pub. L. 110–174","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78680c73-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/s203/a"},"text":"Pub. L. 111–195, § 203(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “Notwithstanding any other provision of Federal or State law, no person may bring any civil, criminal, or administrative action against any registered investment company, or any employee, officer, director, or investment adviser thereof, based solely upon the investment company divesting from, or avoiding investing in, securities issued by persons that the investment company determines, using credible information that is available to the public, conduct or have direct investments in business operations in Sudan described in section 3(d) of the Sudan Accountability and Divestment Act of 2007.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/s205/b/1"},"text":"Pub. L. 111–195, § 205(b)(1)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, text read as follows: “Paragraph (1) does not prevent a person from bringing an action based on a breach of a fiduciary duty owed to that person with respect to a divestment or non-investment decision, other than as described in paragraph (1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/174"},"text":"Pub. L. 110–174","children":[],"tail":", §§ 4(a), 12, temporarily added subsec. (c). See Termination Date of 2007 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/29"},"text":"Pub. L. 94–29","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–16/c"},"text":"section 80a–16(c) of this title","children":[],"tail":"” for “subsection (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–16"},"text":"section 80a–16 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/547/s3/d"},"text":"Pub. L. 91–547, § 3(d)","children":[],"tail":", prohibited deviation from any investment policy which is changeable only if authorized by shareholder vote, substituted “section 8(b)(3)” for “section 8(b)(2)”, and in the latter deviation provision struck out “fundamental” before “policy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/547/s2/b"},"text":"Pub. L. 91–547, § 2(b)","children":[],"tail":", substituted reference to “paragraph (42)” for “paragraph (40)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78680c74-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78680c75-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tII/s205/b/2"},"text":"Pub. L. 111–195, title II, § 205(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1345"},"text":"124 Stat. 1345","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/195/tII/s205/b/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply as if included in the Sudan Accountability and Divestment Act of 2007 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/174"},"text":"Public Law 110–174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id78680c76-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/174"},"text":"Pub. L. 110–174","children":[],"tail":" to terminate 30 days after the date on which the President has certified to Congress that the Government of Sudan has honored certain commitments, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/174/s12"},"text":"section 12 of Pub. L. 110–174","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78680c77-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/29"},"text":"Pub. L. 94–29","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-06-04"},"text":"June 4, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/29/s31/a"},"text":"section 31(a) of Pub. L. 94–29","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78b"},"text":"section 78b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78680c78-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/547"},"text":"Pub. L. 91–547","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/547/s30"},"text":"section 30 of Pub. L. 91–547","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–52"},"text":"section 80a–52 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78680c79-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"SEC Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tII/s203/b"},"text":"Pub. L. 111–195, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1344"},"text":"124 Stat. 1344","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/195/tII/s203/b"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"], the Securities and Exchange Commission shall issue any revisions the Commission determines to be necessary to the regulations requiring disclosure by each registered investment company that divests itself of securities in accordance with section 13(c) of the Investment Company Act of 1940 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–13/c"},"text":"15 U.S.C. 80a–13(c)","children":[],"tail":"] to include divestments of securities in accordance with paragraph (1)(B) of such section, as added by subsection (a) of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
