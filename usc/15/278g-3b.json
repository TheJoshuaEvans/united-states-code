{"tag":"section","attrib":{"id":"id7892ed67-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b"},"text":null,"children":[{"tag":"num","attrib":{"value":"278g–3b"},"text":"§ 278g–3b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security standards and guidelines for agencies on use and management of Internet of Things devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7892ed68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Institute of Standards and Technology development of standards and guidelines for use of Internet of Things devices by agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892ed69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-04"},"text":"December 4, 2020","children":[],"tail":", the Director of the Institute shall develop and publish under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"section 278g–3 of this title","children":[],"tail":" standards and guidelines for the Federal Government on the appropriate use and management by agencies of Internet of Things devices owned or controlled by an agency and connected to information systems owned or controlled by an agency, including minimum information security requirements for managing cybersecurity risks associated with such devices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with ongoing efforts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute shall ensure that the standards and guidelines developed under paragraph (1) are consistent with the efforts of the National Institute of Standards and Technology in effect on ","children":[{"tag":"date","attrib":{"date":"2020-12-04"},"text":"December 4, 2020","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7892ed6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7892ed6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examples of possible security vulnerabilities of Internet of Things devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7892ed6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considerations for managing the security vulnerabilities of Internet of Things devices; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7892ed6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the following considerations for Internet of Things devices:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7892ed6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Secure Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7892ed70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identity management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7892ed71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patching.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7892ed72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Configuration management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considering relevant standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the standards and guidelines under paragraph (1), the Director of the Institute shall consider relevant standards, guidelines, and best practices developed by the private sector, agencies, and public-private partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892ed74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of agency information security policies and principles","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892ed75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which the Director of the Institute completes the development of the standards and guidelines required under subsection (a), the Director of OMB shall review agency information security policies and principles on the basis of the standards and guidelines published under subsection (a) pertaining to Internet of Things devices owned or controlled by agencies (excluding agency information security policies and principles pertaining to Internet of Things of devices owned or controlled by agencies that are or comprise a national security system) for consistency with the standards and guidelines submitted under subsection (a) and issue such policies and principles as may be necessary to ensure those policies and principles are consistent with such standards and guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In reviewing agency information security policies and principles under paragraph (1) and issuing policies and principles under such paragraph, as may be necessary, the Director of OMB shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7892ed77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Director of the Cybersecurity and Infrastructure Security Agency of the Department of Homeland Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7892ed78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure such policies and principles are consistent with the information security requirements under subchapter II of chapter 35 of title 44.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any policy or principle issued by the Director of OMB under paragraph (1) shall not apply to national security systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892ed7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quinquennial review and revision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892ed7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revision of NIST standards and guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after the date on which the Director of the Institute publishes the standards and guidelines under subsection (a), and not less frequently than once every 5 years thereafter, the Director of the Institute, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7892ed7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review such standards and guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7892ed7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise such standards and guidelines as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892ed7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updated OMB policies and principles for agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the Director of the Institute makes a revision pursuant to paragraph (1), the Director of OMB, in consultation with the Director of the Cybersecurity and Infrastructure Security Agency of the Department of Homeland Security, shall update any policy or principle issued under subsection (b)(1) as necessary to ensure those policies and principles are consistent with the review and any revision under paragraph (1) under this subsection and paragraphs (2) and (3) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892ed7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–3b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of Federal Acquisition Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Acquisition Regulation shall be revised as necessary to implement any standards and guidelines promulgated in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7892ed80-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/207/s4"},"text":"Pub. L. 116–207, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-04"},"text":"Dec. 4, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1002"},"text":"134 Stat. 1002","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7892ed81-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7892ed82-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7892ed83-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Internet of Things Cybersecurity Improvement Act of 2020, also known as the IoT Cybersecurity Improvement Act of 2020, and not as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7892ed84-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7892ed85-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3a"},"text":"section 278g–3a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
