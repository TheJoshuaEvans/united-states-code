{"tag":"section","attrib":{"id":"id7970c9ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1267"},"text":null,"children":[{"tag":"num","attrib":{"value":"1267"},"text":"§ 1267.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions; criminal contempt; trial by court or jury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7970c9cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1267/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States district courts and the United States courts of the territories shall have jurisdiction, for cause shown and subject to the provisions of rule 65(a) and (b) of the Federal Rules of Civil Procedure, to restrain violations of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c9cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1267/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding for criminal contempt for violation of an injunction or restraining order issued under this section, which violation also constitutes a violation of this chapter, trial shall be by the court or, upon demand of the accused, by a jury. Such trial shall be conducted in accordance with the practice and procedure applicable in the case of proceedings subject to the provisions of rule 42(b) of the Federal Rules of Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7970c9cd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s8"},"text":"Pub. L. 86–613, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/378"},"text":"74 Stat. 378","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7970c9ce-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7970c9cf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7970c9d0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Secretary of Health, Education, and Welfare under this chapter transferred to Consumer Product Safety Commission, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079"},"text":"section 2079 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
