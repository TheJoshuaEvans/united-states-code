{"tag":"section","attrib":{"id":"id7897a812-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"278k–2"},"text":"§ 278k–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion awards pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7897a813-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms used in this section have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a814-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish, subject to the availability of appropriations, as a part of the Hollings Manufacturing Extension Partnership under sections 278k and 278k–1 of this title, a pilot program of expansion awards among participants described in subsection (c) for the purposes described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a815-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participants receiving awards under this section shall be Centers, or a consortium of Centers (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a816-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, an award for a recipient under this section shall be in an amount equal to the sum of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a817-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such amount as the Director considers appropriate as a minimum base funding level for each award under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a818-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such additional amount as the Director considers in proportion to the manufacturing density of the region of the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a819-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such supplemental amounts as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a81a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An award under this section shall be made for one or more of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a81b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide worker education, training, development, and entrepreneurship training and to connect individuals or business with such services offered in their community, which may include employee ownership and workforce training, including connecting manufacturers with career and technical education entities, institutions of higher education (including community colleges), workforce development boards, labor organizations, and nonprofit job training providers to develop and support training and job placement services, including apprenticeship and online learning platforms, for new and incumbent workers, programming to prevent job losses when adopting new technologies and processes, and development of employee ownership practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a81c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide services to improve the resiliency of domestic supply chains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a81d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To mitigate vulnerabilities to cyberattacks, including helping to offset the cost of cybersecurity projects for small manufacturers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a81e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To expand advanced technology services to United States-based small- and medium-sized manufacturers, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7897a81f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing technology demonstration laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a820-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and demonstration in areas of supply chain and critical technology needs, including a focus on the demonstration of technologies developed by companies based in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a821-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services for the adoption of advanced technologies, including smart manufacturing technologies and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a822-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing partnerships, for the development, demonstration, and deployment of advanced technologies, with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7897a823-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national laboratories (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of title 42","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7897a824-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7897a825-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Manufacturing USA institutes (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278s/d"},"text":"section 278s(d) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7897a826-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/4/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a827-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To build capabilities across the Hollings Manufacturing Extension Partnership for domestic supply chain resiliency and optimization, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7897a828-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of domestic manufacturing capabilities, expanded capacity for researching and deploying information on supply chain risk, hidden costs of reliance on offshore suppliers, redesigning products and processes to encourage reshoring, and other relevant topics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a829-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanded services to provide industrywide support that assists United States manufacturers with reshoring manufacturing to strengthen the resiliency of domestic supply chains, including in critical technology areas and foundational manufacturing capabilities that are key to domestic manufacturing competitiveness and resiliency, including forming, casting, machining, joining, surface treatment, tooling, and metal or chemical refining.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a82a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may reimburse Centers for costs incurred by the Centers under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a82b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications for awards under this section shall be submitted in such manner, at such time, and containing such information as the Director shall require in consultation with the Manufacturing Extension Partnership Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a82c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a82d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewed and merit-based","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that awards under this section are reviewed and merit-based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a82e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall endeavor to have broad geographic diversity among selected proposals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a82f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall select applications consistent with the purposes identified pursuant to subsection (e) to receive awards that the Director determines will achieve one or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7897a830-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvement of the competitiveness of industries in the region in which the Center or Centers are located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a831-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creation of jobs or training of newly hired employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a832-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotion of the transfer and commercialization of research and technology from institutions of higher education, national laboratories, or other federally funded research programs, and nonprofit research institutes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a833-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruitment of a diverse manufacturing workforce, including through outreach to underrepresented populations, including individuals identified in section 1885a or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1885b"},"text":"section 1885b of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7897a834-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/h/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other result the Director determines will advance the objective set forth in section 278k(c) or 278k–1 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a835-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of awards under this section shall not be required to provide a matching contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a836-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global marketplace projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making an award under this section, the Director, in consultation with the Manufacturing Extension Partnership Advisory Board and the Secretary, may take into consideration whether an application has significant potential for enhancing the competitiveness of small and medium-sized United States manufacturers in the global marketplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a837-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that the duration of an award under this section is aligned and consistent with a Center’s cooperative agreement established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k/e"},"text":"section 278k(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a838-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-10-01"},"text":"October 1, 2025","children":[],"tail":", the Director shall submit to Congress a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a839-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary description of what activities were funded and the measurable outcomes of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a83a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of which types of activities under paragraph (1) could remain as part of a permanent expansion awards program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a83b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of which types of activities under paragraph (1) could be integrated into, and supported under, the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a83c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of which types of activities under paragraph (1) could be integrated into, and supported under, the competitive awards program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k–1"},"text":"section 278k–1 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a83d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278k–2/l/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recommendation, supported by a clear explanation, as to whether the pilot program should be continued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7897a83e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s25B"},"text":"Mar. 3, 1901, ch. 872, § 25B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10251/a"},"text":"Pub. L. 117–167, div. B, title II, § 10251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1496"},"text":"136 Stat. 1496","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
