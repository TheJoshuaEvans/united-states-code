{"tag":"section","attrib":{"id":"id7a74a5de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404"},"text":null,"children":[{"tag":"num","attrib":{"value":"7404"},"text":"§ 7404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Science Foundation computer and network security programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a74a5df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computer and network security capacity building grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a74a5e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a program to award grants to institutions of higher education (or consortia thereof) to establish or improve undergraduate and master’s degree programs in computer and network security, to increase the number of students, including the number of students from groups historically underrepresented in these fields and students who are veterans, who pursue undergraduate or master’s degrees in fields related to computer and network security, and to provide students with experience in government or industry related to their computer and network security studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be awarded under this subsection on a merit-reviewed competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this subsection shall be used for activities that enhance the ability of an institution of higher education (or consortium thereof) to provide high-quality undergraduate and master’s degree programs in computer and network security and to recruit and retain increased numbers of students to such programs. Activities may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a5e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revising curriculum to better prepare undergraduate and master’s degree students for careers in computer and network security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing degree and certificate programs in computer and network security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating opportunities for undergraduate students to participate in computer and network security research projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring equipment necessary for student instruction in computer and network security, including the installation of testbed networks for student use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing opportunities for faculty to work with local or Federal Government agencies, private industry, nonprofit research institutions, or other academic institutions to develop new expertise or to formulate new research directions in computer and network security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing collaborations with other academic institutions or academic departments that seek to establish, expand, or enhance programs in computer and network security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing student internships in computer and network security at government agencies or in private industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing collaborations with other academic institutions to establish or enhance a web-based collection of computer and network security courseware and laboratory exercises for sharing with other institutions of higher education, including community colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or enhancing bridge programs in computer and network security between community colleges and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating opportunities for veterans to transition to careers in computer and network security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities the Director determines will accomplish the goals of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a5ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education (or a consortium thereof) seeking funding under this subsection shall submit an application to the Director at such time, in such manner, and containing such information as the Director may require. The application shall include, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a74a5f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the applicant’s computer and network security research and instructional capacity, and in the case of an application from a consortium of institutions of higher education, a description of the role that each member will play in implementing the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive plan by which the institution or consortium will build instructional capacity in computer and information security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of relevant collaborations with government agencies or private industry that inform the instructional program in computer and network security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a survey of the applicant’s historic student enrollment and placement data in fields related to computer and network security and a study of potential enrollment and placement for students enrolled in the proposed computer and network security program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to evaluate the success of the proposed computer and network security program, including post-graduation assessment of graduate school and job placement and retention rates as well as the relevance of the instructional program to graduate study and to the workplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a74a5f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall ensure, to the extent practicable, that grants are awarded under this subsection in a wide range of geographic areas and categories of institutions of higher education, including minority serving institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a74a5f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall award grants under this subsection for a period not to exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall evaluate the program established under this subsection no later than 6 years after the establishment of the program. At a minimum, the Director shall evaluate the extent to which the program achieved its objectives of increasing the quality and quantity of students, including students from groups historically underrepresented in computer and network security related disciplines, pursuing undergraduate or master’s degrees in computer and network security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a5f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the National Science Foundation to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a5fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a5fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a74a5ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific and Advanced Technology Act of 1992","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a74a600-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide grants under the Scientific and Advanced Technology Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862i"},"text":"42 U.S.C. 1862i","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862h"},"text":"42 U.S.C. 1862h","children":[],"tail":" et seq.] for the purposes of section 3(a) and (b) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862i/a"},"text":"42 U.S.C. 1862i(a)","children":[],"tail":", (b)], except that the activities supported pursuant to this subsection shall be limited to improving education in fields related to computer and network security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a601-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the National Science Foundation to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a602-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a603-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,250,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a604-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,250,000 for fiscal year 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a605-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,250,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a606-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,250,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a74a607-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graduate traineeships in computer and network security research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a74a608-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a program to award grants to institutions of higher education to establish traineeship programs for graduate students who pursue computer and network security research leading to a doctorate degree by providing funding and other assistance, and by providing graduate students with research experience in government or industry related to the students’ computer and network security studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a609-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be provided under this subsection on a merit-reviewed competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a60a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education shall use grant funds for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a60b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing traineeships to students who are citizens, nationals, or lawfully admitted permanent resident aliens of the United States and are pursuing research in computer or network security leading to a doctorate degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a60c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying tuition and fees for students receiving traineeships under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a60d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing scientific internship programs for students receiving traineeships under subparagraph (A) in computer and network security at for-profit institutions, nonprofit research institutions, or government laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a60e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other costs associated with the administration of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a60f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traineeship amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Traineeships provided under paragraph (3)(A) shall be in the amount of $25,000 per year, or the level of the National Science Foundation Graduate Research Fellowships, whichever is greater, for up to 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a610-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education seeking funding under this subsection shall submit an application to the Director at such time, in such manner, and containing such information as the Director may require. The application shall include, at a minimum, a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a611-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instructional program and research opportunities in computer and network security available to graduate students at the applicant’s institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a612-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the internship program to be established, including the opportunities that will be made available to students for internships at for-profit institutions, nonprofit research institutions, and government laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a613-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating the applications submitted under paragraph (5), the Director shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a614-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the applicant to effectively carry out the proposed program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a615-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of the applicant’s existing research and education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a616-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood that the program will recruit increased numbers of students, including students from groups historically underrepresented in computer and network security related disciplines or veterans, to pursue and earn doctorate degrees in computer and network security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a617-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and quality of the internship program established through collaborations with government laboratories, nonprofit research institutions, and for-profit institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a618-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of internship opportunities into graduate students’ research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a619-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevance of the proposed program to current and future computer and network security needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a61a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the National Science Foundation to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a61b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a61c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a61d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a61e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a61f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a74a620-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graduate Research Fellowships program support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Computer and network security shall be included among the fields of specialization supported by the National Science Foundation’s Graduate Research Fellowships program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1869"},"text":"section 1869 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a74a621-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber security faculty development traineeship program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a74a622-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a program to award grants to institutions of higher education to establish traineeship programs to enable graduate students to pursue academic careers in cyber security upon completion of doctoral degrees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a623-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review; competition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants shall be awarded under this section on a merit-reviewed competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a624-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each institution of higher education desiring to receive a grant under this subsection shall submit an application to the Director at such time, in such manner, and containing such information as the Director shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a625-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds received by an institution of higher education under this paragraph shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a626-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made available to individuals on a merit-reviewed competitive basis and in accordance with the requirements established in paragraph (7);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a627-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in an amount that is sufficient to cover annual tuition and fees for doctoral study at an institution of higher education for the duration of the graduate traineeship, and shall include, in addition, an annual living stipend of $25,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a628-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be provided to individuals for a duration of no more than 5 years, the specific duration of each graduate traineeship to be determined by the institution of higher education, on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a629-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each graduate traineeship shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a62a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (5)(B), be subject to full repayment upon completion of the doctoral degree according to a repayment schedule established and administered by the institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a62b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be forgiven at the rate of 20 percent of the total amount of the graduate traineeship assistance received under this section for each academic year that a recipient is employed as a full-time faculty member at an institution of higher education for a period not to exceed 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a62c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be monitored by the institution of higher education receiving a grant under this subsection to ensure compliance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a62d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may provide for the partial or total waiver or suspension of any service obligation or payment by an individual under this section whenever compliance by the individual is impossible or would involve extreme hardship to the individual, or if enforcement of such obligation with respect to the individual would be unconscionable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a62e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a graduate traineeship under this section, an individual shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a74a62f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a citizen, national, or lawfully admitted permanent resident alien of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a74a630-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a commitment to a career in higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a631-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making selections for graduate traineeships under this paragraph, an institution receiving a grant under this subsection shall consider, to the extent possible, a diverse pool of applicants whose interests are of an interdisciplinary nature, encompassing the social scientific as well as the technical dimensions of cyber security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a74a632-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7404/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the National Science Foundation to carry out this paragraph $5,000,000 for each of fiscal years 2003 through 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a74a633-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/305/s5"},"text":"Pub. L. 107–305, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2370"},"text":"116 Stat. 2370","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3/f"},"text":"Pub. L. 116–115, § 3(f)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"2020-02-11"},"text":"Feb. 11, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/107"},"text":"134 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a74a634-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a74a635-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a74a636-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Scientific and Advanced Technology Act of 1992, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/476"},"text":"Pub. L. 102–476","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2297"},"text":"106 Stat. 2297","children":[],"tail":", which enacted sections 1862h to 1862j of Title 42, The Public Health and Welfare, and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862"},"text":"section 1862 of Title 42","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1992 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"section 1861 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a74a637-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3/f/1"},"text":"Pub. L. 116–115, § 3(f)(1)","children":[],"tail":", inserted “and students who are veterans” after “these fields”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(J), (K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3/f/2"},"text":"Pub. L. 116–115, § 3(f)(2)","children":[],"tail":", added subpar. (J) and redesignated former subpar. (J) as (K)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3/g"},"text":"Pub. L. 116–115, § 3(g)","children":[],"tail":", inserted “or veterans” after “disciplines”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
