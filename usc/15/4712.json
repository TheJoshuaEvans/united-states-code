{"tag":"section","attrib":{"id":"id7a429932-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712"},"text":null,"children":[{"tag":"num","attrib":{"value":"4712"},"text":"§ 4712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barter and countertrade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a429933-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a429934-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish an interagency group on countertrade, to be composed of representatives of such departments and agencies of the United States as the President considers appropriate. The Secretary of Commerce shall be the chairman of the interagency group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429935-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the function of the interagency group to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a429936-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review and evaluate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a429937-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States policy on countertrade and offsets, in light of current trends in international countertrade and offsets and the impact of those trends on the United States economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a429938-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of countertrade and offsets in United States exports and bilateral United States foreign economic assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a429939-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for and the feasibility of negotiating with other countries, through the Organization for Economic Cooperation and Development and other appropriate international organizations, to reach agreements on the use of countertrade and offsets; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42993a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the President and the Congress on the basis of the review and evaluation referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a42993b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Other departments and agencies of the United States shall provide to the interagency group such information available to such departments and agencies as the interagency group may request, except that the requirements, including penalties for violation thereof, for preserving the confidentiality of such information which are applicable to the officials, employees, experts, or consultants of such departments and agencies shall apply in the same manner to each member of the interagency group and to any other person performing any function under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a42993c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Barter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a42993d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, within the International Trade Administration of the Department of Commerce, the Office of Barter (hereafter in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a42993e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be at the head of the Office a Director, who shall be appointed by the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a42993f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall transfer such staff to the Office as the Secretary determines is necessary to enable the Office to carry out its functions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429940-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the function of the Office to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a429941-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor information relating to trends in international barter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429942-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organize and disseminate information relating to international barter in a manner useful to business firms, educational institutions, export-related Federal, State, and local government agencies, and other interested persons, including publishing periodic lists of known commercial opportunities for barter transactions beneficial to United States enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429943-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify Federal agencies with operations abroad of instances where it would be beneficial to the United States for the Federal Government to barter Government-owned surplus commodities for goods and services purchased abroad by the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429944-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4712/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to enterprises seeking barter and countertrade opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a429945-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII/s2205"},"text":"Pub. L. 100–418, title II, § 2205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1332"},"text":"102 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a429946-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a429947-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a429948-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Composition of Interagency Group","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For composition of Interagency Group on Countertrade, see section 2–101 of Ex. Ord. No. 12661, ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"Dec. 27, 1988","children":[],"tail":", 54 F.R. 779, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2901"},"text":"section 2901 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
