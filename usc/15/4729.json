{"tag":"section","attrib":{"id":"id7a475392-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729"},"text":null,"children":[{"tag":"num","attrib":{"value":"4729"},"text":"§ 4729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on export policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a475393-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than May 31 of each year, the Secretary of Commerce shall submit to the Congress a report on the international economic position of the United States and, not later than June 30 of each year, shall appear before the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Foreign Affairs of the House of Representatives to testify on issues addressed in that report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475394-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475395-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under subsection (a) shall address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a475396-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the state of United States international economic competitiveness, focusing, in particular, on the efforts of the Department of Commerce—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a475397-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage research and development of technologies and products deemed critical for industrial leadership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a475398-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote investment in and improved manufacturing processes for such technologies and products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a475399-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase United States industrial exports of products using the technologies described in clause (i) to those markets where the United States Government has sought to reduce barriers to exports;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47539a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report on the Trade Promotion Coordinating Committee strategic plan submitted to the Congress in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4727/f"},"text":"section 4727(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47539b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other specific recommendations of the Department of Commerce to improve the United States balance of trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47539c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effects on the international economic competitiveness of the United States of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a47539d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formal and informal trade barriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a47539e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsidies by foreign countries to their domestic industries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47539f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Department of Commerce to reduce trade barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of export financing programs of the United States Government and recommendations for improving such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status, activities, and effectiveness of the United States commercial centers established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4723a"},"text":"section 4723a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of sections 5821 and 5822 of title 22 ","children":[{"tag":"ref","attrib":{"idref":"fn002535"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002535"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" concerning American Business Centers and the Independent States Business and Agriculture Advisory Council;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs of other industrialized nations to assist their companies with their efforts to transact business in the independent states of the former Soviet Union; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trading practices of other Organization for Economic Cooperation and Development nations, as well as the pricing practices of transitional economies in the independent states, that may disadvantage United States companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4729/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy basis for reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Portions of each report under this section may incorporate or be based upon relevant reports and testimony produced by the Department of Commerce or other agencies, but the policy views shall be those of the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4753a6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII/s2314"},"text":"Pub. L. 100–418, title II, § 2314","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/429/tII/s206"},"text":"Pub. L. 102–429, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2204"},"text":"106 Stat. 2204","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1022/b"},"text":"Pub. L. 104–66, title I, § 1022(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/713"},"text":"109 Stat. 713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4753a7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4753a8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a4753a9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 5821 and 5822 of title 22, referred to in subsec. (b)(1)(H), was, in the original, “sections 301 and 302 of the Freedom for Russia and Emerging Democracies and Open Markets Support Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5821"},"text":"22 U.S.C. 5821","children":[],"tail":" and 5822)”, and was translated as meaning sections 301 and 302 of the Freedom for Russia and Emerging Eurasian Democracies and Open Markets Support Act of 1992, "},{"tag":"ref","attrib":{"href":"/us/pl/102/511"},"text":"Pub. L. 102–511","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a4753aa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(1)(G) to (J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" added subpars. (G) to (J)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
