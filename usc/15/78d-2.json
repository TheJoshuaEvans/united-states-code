{"tag":"section","attrib":{"id":"id78063d3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"78d–2"},"text":"§ 78d–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions with respect to assignment of personnel to chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the functions transferred by the provisions of Reorganization Plan Numbered 10 of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":"), there are hereby transferred from the Commission to the Chairman of the Commission the functions of the Commission with respect to the assignment of Commission personnel, including Commissioners, to perform such functions as may have been delegated by the Commission to the Commission personnel, including Commissioners, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d–1"},"text":"section 78d–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78063d3b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 4B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/181/tIII/s308/a"},"text":"Pub. L. 100–181, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1255"},"text":"101 Stat. 1255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78063d3c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78063d3d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78063d3e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan Numbered 10 of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":"), referred to in text, is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78063d3f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 78d–2, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/592/s2"},"text":"Pub. L. 87–592, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-20"},"text":"Aug. 20, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/395"},"text":"76 Stat. 395","children":[],"tail":", provided for subject matter similar to the provisions comprising this section, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/181/s308/b"},"text":"section 308(b) of Pub. L. 100–181","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
