{"tag":"section","attrib":{"id":"id7a1546f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057"},"text":"§ 3057.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule violations and civil sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1546f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of rule violations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1546f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall issue, by rule in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":", a description of safety, performance, and anti-doping and medication control rule violations applicable to covered horses and covered persons."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The description of rule violations established under paragraph (1) may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1546f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a covered horse, strict liability for covered trainers for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1546f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of a prohibited substance or method in a sample or the use of a prohibited substance or method;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1546f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of a permitted substance in a sample in excess of the amount allowed by the horseracing anti-doping and medication control program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1546fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of a permitted method in violation of the applicable limitations established under the horseracing anti-doping and medication control program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attempted use of a prohibited substance or method on a covered horse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Possession of any prohibited substance or method.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attempted possession of any prohibited substance or method.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administration or attempted administration of any prohibited substance or method on a covered horse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Refusal or failure, without compelling justification, to submit a covered horse for sample collection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154700-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to cooperate with the Authority or an agent of the Authority during any investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154701-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to respond truthfully, to the best of a covered person’s knowledge, to a question of the Authority or an agent of the Authority with respect to any matter under the jurisdiction of the Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154702-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Tampering or attempted tampering with the application of the safety, performance, or anti-doping and medication control rules or process adopted by the Authority, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a154703-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intentional interference, or an attempt to interfere, with an official or agent of the Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a154704-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement or the provision of fraudulent information to the Authority or agent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a154705-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/I/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intimidation of, or an attempt to intimidate, a potential witness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154706-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trafficking or attempted trafficking in any prohibited substance or method.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154707-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting, encouraging, aiding, abetting, conspiring, covering up, or any other type of intentional complicity involving a safety, performance, or anti-doping and medication control rule violation or the violation of a period of suspension or eligibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154708-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Threatening or seeking to intimidate a person with the intent of discouraging the person from the good faith reporting to the Authority, an agent of the Authority or the Commission, or the anti-doping and medication control enforcement agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3054/e"},"text":"section 3054(e) of this title","children":[],"tail":", of information that relates to—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a154709-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/L/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alleged safety, performance, or anti-doping and medication control rule violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a15470a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/a/2/L/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alleged noncompliance with a safety, performance, or anti-doping and medication control rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a15470b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing laboratories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a15470c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation and standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days before the program effective date, the Authority shall, in consultation with the anti-doping and medication control enforcement agency, establish, by rule in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a15470d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards of accreditation for laboratories involved in testing samples from covered horses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15470e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process for achieving and maintaining accreditation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15470f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standards and protocols for testing such samples.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154710-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The accreditation of laboratories and the conduct of audits of accredited laboratories to ensure compliance with Authority rules shall be administered by the anti-doping and medication control enforcement agency. The anti-doping and medication control enforcement agency shall have the authority to require specific test samples to be directed to and tested by laboratories having special expertise in the required tests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154711-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of provisional or interim accreditation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may, by rule in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":", extend provisional or interim accreditation to a laboratory accredited by the Racing Medication and Testing Consortium, Inc., on a date before the program effective date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154712-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of laboratories","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a154713-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a State racing commission may select a laboratory accredited in accordance with the standards established under paragraph (1) to test samples taken in the applicable State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154714-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection by the authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State racing commission does not select an accredited laboratory under subparagraph (A), the Authority shall select such a laboratory to test samples taken in the State concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a154715-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results management and disciplinary process","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a154716-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days before the program effective date, the Authority shall establish in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a154717-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules for safety, performance, and anti-doping and medication control results management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154718-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disciplinary process for safety, performance, and anti-doping and medication control rule violations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154719-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules and process established under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a15471a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions for notification of safety, performance, and anti-doping and medication control rule violations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15471b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hearing procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15471c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Standards for burden of proof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15471d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Presumptions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15471e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidentiary rules.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15471f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appeals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154720-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guidelines for confidentiality and public reporting of decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154721-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Due process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules established under paragraph (1) shall provide for adequate due process, including impartial hearing officers or tribunals commensurate with the seriousness of the alleged safety, performance, or anti-doping and medication control rule violation and the possible civil sanctions for such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a154722-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a154723-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall establish uniform rules, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":", imposing civil sanctions against covered persons or covered horses for safety, performance, and anti-doping and medication control rule violations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154724-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a154725-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account the unique aspects of horseracing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154726-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to ensure fair and transparent horseraces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a154727-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deter safety, performance, and anti-doping and medication control rule violations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a154728-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The civil sanctions under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a154729-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lifetime bans from horseracing, disgorgement of purses, monetary fines and penalties, and changes to the order of finish in covered races; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a15472a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to anti-doping and medication control rule violators, an opportunity to reduce the applicable civil sanctions that is comparable to the opportunity provided by the Protocol for Olympic Movement Testing of the United States Anti-Doping Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a15472b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3057/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may propose a modification to any rule established under this section as the Authority considers appropriate, and the proposed modification shall be submitted to and considered by the Commission in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a15472c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1208"},"text":"Pub. L. 116–260, div. FF, title XII, § 1208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3269"},"text":"134 Stat. 3269","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
