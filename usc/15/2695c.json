{"tag":"section","attrib":{"id":"id7a0960c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2695c"},"text":"§ 2695c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental health program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0960c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Administrator, in consultation with the Secretary of Education, the Secretary of Health and Human Services, and other relevant agencies, shall issue voluntary guidelines for use by the State in developing and implementing an environmental health program for schools that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0960c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" takes into account the status and findings of Federal initiatives established under this subchapter or subtitle C of title IV of the Energy Independence and Security Act of 2007 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17091"},"text":"42 U.S.C. 17091","children":[],"tail":" et seq.] and other relevant Federal law with respect to school facilities, including relevant updates on trends in the field, such as the impact of school facility environments on student and staff—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0960c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health, safety, and productivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disabilities or special needs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account studies using relevant tools identified or developed in accordance with section 492 of the Energy Independence and Security Act of 2007 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17122"},"text":"42 U.S.C. 17122","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" takes into account, with respect to school facilities, each of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0960c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" environmental problems, contaminants, hazardous substances, and pollutant emissions, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a0960ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead from drinking water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0960cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead from materials and products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0960cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asbestos;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0960cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0960ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of elemental mercury releases from products and containers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0960cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pollutant emissions from materials and products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a0960d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other environmental problem, contaminant, hazardous substance, or pollutant emission that present or may present a risk to the health of occupants of the school facilities or environment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural day lighting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ventilation choices and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heating and cooling choices and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moisture control and mold;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance, cleaning, and pest control activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acoustics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other issues relating to the health, comfort, productivity, and performance of occupants of the school facilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides technical assistance on siting, design, management, and operation of school facilities, including facilities used by students with disabilities or special needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborates with federally funded pediatric environmental health centers to assist in on-site school environmental investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assists States and the public in better understanding and improving the environmental health of children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account the special vulnerability of children in low-income and minority communities to exposures from contaminants, hazardous substances, and pollutant emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0960dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Director and Commercial Director shall ensure, to the maximum extent practicable, that the public clearinghouse established under section 423 of the Energy Independence and Security Act of 2007 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17083"},"text":"42 U.S.C. 17083","children":[],"tail":"] receives and makes available—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0960dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information from the Administrator that is contained in the report described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2695b/a"},"text":"section 2695b(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the exposure of children to environmental hazards 