{"tag":"section","attrib":{"id":"id7a4c0f38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403"},"text":null,"children":[{"tag":"num","attrib":{"value":"5403"},"text":"§ 5403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of fasteners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4c0f39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for a manufacturer or distributor, in conjunction with the sale or offer for sale of fasteners from a single lot, to knowingly misrepresent or falsify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4c0f3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record of conformance for the lot of fasteners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification, characteristics, properties, mechanical or performance marks, chemistry, or strength of the lot of fasteners; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer’s insignia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0f3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A direct or indirect reference to a consensus standard to represent that a fastener conforms to particular requirements of the consensus standard shall not be construed as a representation that the fastener meets all the requirements of the consensus standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0f3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A direct or indirect contractual reference to a consensus standard for the purpose of identifying particular requirements of the consensus standard that serve as specifications shall not be construed to require that the fastener meet all the requirements of the consensus standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0f3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of accredited laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of fasteners manufactured solely to a consensus standard or standards, end-of-line testing required by the consensus standard or standards, if any, for the purpose of verifying that a lot of fasteners conforms with the grade identification marking called for in the consensus standard or standards to which the lot of fasteners has been manufactured shall be conducted by an accredited laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4c0f40-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s4"},"text":"Pub. L. 101–592, § 4","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/34/s4/a"},"text":"Pub. L. 106–34, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/121"},"text":"113 Stat. 121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4c0f41-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4c0f42-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a4c0f43-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5403, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s4"},"text":"Pub. L. 101–592, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2945"},"text":"104 Stat. 2945","children":[],"tail":", set out special rule under which Secretary could waive requirements of this chapter on determination that category of fasteners was not used in critical applications, but that Secretary could also determine in given case that fastener was used in critical applications and was governed accordingly, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/c"},"text":"Pub. L. 104–113, § 11(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-07"},"text":"Mar. 7, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/780"},"text":"110 Stat. 780","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a4c0f44-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a4c0f45-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/34/s4/b"},"text":"Pub. L. 106–34, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/122"},"text":"113 Stat. 122","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/34/s4/b"},"text":"“Subsection (d) of section 4 of the Fastener Quality Act [15 U.S.C. § 5403(d)], as added by subsection (a) of this section, shall take effect 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
