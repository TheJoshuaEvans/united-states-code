{"tag":"section","attrib":{"id":"id7a7234d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265"},"text":null,"children":[{"tag":"num","attrib":{"value":"7265"},"text":"§ 7265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of audit committee financial expert","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7234d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules defining “financial expert”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall issue rules, as necessary or appropriate in the public interest and consistent with the protection of investors, to require each issuer, together with periodic reports required pursuant to sections 78m(a) and 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title, to disclose whether or not, and if not, the reasons therefor, the audit committee of that issuer is comprised of at least 1 member who is a financial expert, as such term is defined by the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In defining the term “financial expert” for purposes of subsection (a), the Commission shall consider whether a person has, through education and experience as a public accountant or auditor or a principal financial officer, comptroller, or principal accounting officer of an issuer, or from a position involving the performance of similar functions—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an understanding of generally accepted accounting principles and financial statements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" experience in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7234dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation or auditing of financial statements of generally comparable issuers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7234de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of such principles in connection with the accounting for estimates, accruals, and reserves;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience with internal accounting controls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an understanding of audit committee functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for rulemaking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose rules to implement this section, not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7265/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue final rules to implement this section, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7234e4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIV/s407"},"text":"Pub. L. 107–204, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/790"},"text":"116 Stat. 790","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
