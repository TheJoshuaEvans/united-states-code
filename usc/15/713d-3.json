{"tag":"section","attrib":{"id":"id79376ac2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s713d–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"713d–3"},"text":"§ 713d–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations for appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such amounts as may be necessary for purposes of carrying out the provisions of this joint resolution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79376ac3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-12-30/ch526/s9"},"text":"Dec. 30, 1947, ch. 526, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/948"},"text":"61 Stat. 948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79376ac4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79376ac5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79376ac6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This joint resolution, referred to in text, means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-12-30/ch526"},"text":"act Dec. 30, 1947, ch. 526","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/945"},"text":"61 Stat. 945","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79376ac7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1919 of the former Appendix to Title 50, War and National Defense, prior to editorial reclassification and renumbering as this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
