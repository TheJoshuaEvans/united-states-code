{"tag":"section","attrib":{"id":"id7a50f13f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5714"},"text":null,"children":[{"tag":"num","attrib":{"value":"5714"},"text":"§ 5714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f140-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5714/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “pay-per-call services” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s228/i"},"text":"section 228(i) of title 47","children":[],"tail":", except that the Commission by rule may, notwithstanding subparagraphs (B) and (C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s228/i/1"},"text":"section 228(i)(1) of title 47","children":[],"tail":", extend such definition to other similar services providing audio information or audio entertainment if the Commission determines that such services are susceptible to the unfair and deceptive practices that are prohibited by the rules prescribed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5711/a"},"text":"section 5711(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f141-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5714/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “attorney general” means the chief legal officer of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f142-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5714/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any State of the United States, the District of Columbia, Puerto Rico, the Northern Mariana Islands, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f143-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5714/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a50f144-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/556/tII/s204"},"text":"Pub. L. 102–556, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4191"},"text":"106 Stat. 4191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/104/tVII/s701/b/1"},"text":"Pub. L. 104–104, title VII, § 701(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-08"},"text":"Feb. 8, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/147"},"text":"110 Stat. 147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a50f145-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a50f146-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a50f147-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/104"},"text":"Pub. L. 104–104","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The term ‘pay-per-call services’ has the meaning provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s228"},"text":"section 228 of title 47","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
