{"tag":"section","attrib":{"id":"id7a87b789-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402"},"text":null,"children":[{"tag":"num","attrib":{"value":"8402"},"text":"§ 8402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions against certain unfair and deceptive Internet sales practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b78a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for certain Internet-based sales","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any post-transaction third party seller to charge or attempt to charge any consumer’s credit card, debit card, bank account, or other financial account for any good or service sold in a transaction effected on the Internet, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b78b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before obtaining the consumer’s billing information, the post-transaction third party seller has clearly and conspicuously disclosed to the consumer all material terms of the transaction, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b78c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the goods or services being offered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b78d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fact that the post-transaction third party seller is not affiliated with the initial merchant, which may include disclosure of the name of the post-transaction third party in a manner that clearly differentiates the post-transaction third party seller from the initial merchant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b78e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of such goods or services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b78f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the post-transaction third party seller has received the express informed consent for the charge from the consumer whose credit card, debit card, bank account, or other financial account will be charged by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b790-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtaining from the consumer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a87b791-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full account number of the account to be charged; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b792-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer’s name and address and a means to contact the consumer; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b793-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring the consumer to perform an additional affirmative action, such as clicking on a confirmation button or checking a box that indicates the consumer’s consent to be charged the amount disclosed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b794-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on data-pass used to facilitate certain deceptive Internet sales transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for an initial merchant to disclose a credit card, debit card, bank account, or other financial account number, or to disclose other billing information that is used to charge a customer of the initial merchant, to any post-transaction third party seller for use in an Internet-based sale of any goods or services from that post-transaction third party seller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b795-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application with other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to supersede, modify, or otherwise affect the requirements of the Electronic Funds ","children":[{"tag":"ref","attrib":{"idref":"fn002596"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002596"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Fund”."}],"tail":" Transfer Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"15 U.S.C. 1693","children":[],"tail":" et seq.) or any regulation promulgated thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b796-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b797-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial merchant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “initial merchant” means a person that has obtained a consumer’s billing information directly from the consumer through an Internet transaction initiated by the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b798-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-transaction third party seller","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “post-transaction third party seller” means a person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b799-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sells, or offers for sale, any good or service on the Internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b79a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicits the purchase of such goods or services on the Internet through an initial merchant after the consumer has initiated a transaction with the initial merchant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b79b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a87b79c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial merchant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b79d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsidiary or corporate affiliate of the initial merchant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b79e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8402/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a successor of an entity described in clause (i) or (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b79f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/345/s3"},"text":"Pub. L. 111–345, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-29"},"text":"Dec. 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3619"},"text":"124 Stat. 3619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a87b7a0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a87b7a1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a87b7a2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Electronic Fund Transfer Act, referred to in subsec. (c), is title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXX/s2001"},"text":"Pub. L. 95–630, title XX, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3728"},"text":"92 Stat. 3728","children":[],"tail":", which is classified generally to subchapter VI (§ 1693 et seq.) of chapter 41 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
