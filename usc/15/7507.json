{"tag":"section","attrib":{"id":"id7a79617c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7507"},"text":null,"children":[{"tag":"num","attrib":{"value":"7507"},"text":"§ 7507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a79617d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research consortia","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a79617e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall establish a program to support, on a merit-reviewed and competitive basis, consortia to conduct interdisciplinary nanotechnology research and development designed to integrate newly developed nanotechnology and microfluidic tools with systems biology and molecular imaging.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a79617f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the sums authorized for the Department of Energy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7505/b"},"text":"section 7505(b) of this title","children":[],"tail":", $25,000,000 shall be used for each fiscal year 2005 through 2008 to carry out this section. Of these amounts, not less than $10,000,000 shall be provided to at least 1 consortium for each fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a796180-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research centers and major instrumentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall carry out projects to develop, plan, construct, acquire, operate, or support special equipment, instrumentation, or facilities for investigators conducting research and development in nanotechnology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a796181-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/153/s8"},"text":"Pub. L. 108–153, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-03"},"text":"Dec. 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1930"},"text":"117 Stat. 1930","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
