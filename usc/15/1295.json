{"tag":"section","attrib":{"id":"id797584fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1295"},"text":null,"children":[{"tag":"num","attrib":{"value":"1295"},"text":"§ 1295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Persons” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, “persons” means any individual, partnership, corporation, or unincorporated association or any combination or association thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797584fc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/331/s5"},"text":"Pub. L. 87–331, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-30"},"text":"Sept. 30, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/732"},"text":"75 Stat. 732","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
