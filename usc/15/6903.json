{"tag":"section","attrib":{"id":"id7a68bee1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6903"},"text":null,"children":[{"tag":"num","attrib":{"value":"6903"},"text":"§ 6903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A qualified organization shall use grants made under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bee2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training and technical assistance to disadvantaged entrepreneurs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bee3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training and capacity building services to microenterprise development organizations and programs and groups of such organizations to assist such organizations and programs in developing microenterprise training and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bee4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6903/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid in researching and developing the best practices in the field of microenterprise and technical assistance programs for disadvantaged entrepreneurs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bee5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6903/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other activities as the Administrator determines are consistent with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bee6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s174"},"text":"Pub. L. 103–325, title I, § 174","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1473"},"text":"113 Stat. 1473","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
