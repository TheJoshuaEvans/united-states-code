{"tag":"section","attrib":{"id":"id77cabb1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57"},"text":null,"children":[{"tag":"num","attrib":{"value":"57"},"text":"§ 57.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this subchapter, or the application thereof to any person, partnership, or corporation, or circumstance, is held invalid, the remainder of this subchapter, and the application of such provisions to any other person, partnership, corporation, or circumstance, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77cabb1b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s17"},"text":"Sept. 26, 1914, ch. 311, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1938-03-21/ch49/s4"},"text":"Mar. 21, 1938, ch. 49, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/114"},"text":"52 Stat. 114","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
