{"tag":"section","attrib":{"id":"id79ecb139-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2312"},"text":null,"children":[{"tag":"num","attrib":{"value":"2312"},"text":"§ 2312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective dates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ecb13a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b) of this section, this chapter shall take effect 6 months after ","children":[{"tag":"date","attrib":{"date":"1975-01-04"},"text":"January 4, 1975","children":[],"tail":", but shall not apply to consumer products manufactured prior to such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ecb13b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of section 2302(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2302/a"},"text":"Section 2302(a) of this title","children":[],"tail":" shall take effect 6 months after the final publication of rules respecting such section; except that the Commission, for good cause shown, may postpone the applicability of such sections until one year after such final publication in order to permit any designated classes of suppliers to bring their written warranties into compliance with rules promulgated pursuant to this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ecb13c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall promulgate rules for initial implementation of this chapter as soon as possible after ","children":[{"tag":"date","attrib":{"date":"1975-01-04"},"text":"January 4, 1975","children":[],"tail":", but in no event later than one year after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ecb13d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/637/tI/s112"},"text":"Pub. L. 93–637, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2192"},"text":"88 Stat. 2192","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
