{"tag":"section","attrib":{"id":"id7897a854-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"278n–1"},"text":"§ 278n–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency communication and tracking technologies research initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7897a855-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish a research initiative to support the development of emergency communication and tracking technologies for use in locating trapped individuals in confined spaces, such as underground mines, and other shielded environments, such as high-rise buildings or collapsed structures, where conventional radio communication is limited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a856-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out this section, the Director shall work with the private sector and appropriate Federal agencies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a857-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform a needs assessment to identify and evaluate the measurement, technical standards, and conformity assessment needs required to improve the operation and reliability of such emergency communication and tracking technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a858-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of technical standards and conformance architecture to improve the operation and reliability of such emergency communication and tracking technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a859-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate and build upon existing reports and studies on improving emergency communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a85a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2011-01-04"},"text":"January 4, 2011","children":[],"tail":", the Director shall submit to Congress and make publicly available a report describing the assessment performed under subsection (b)(1) and making recommendations about research priorities to address gaps in the measurement, technical standards, and conformity assessment needs identified by the assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7897a85b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV/s405"},"text":"Pub. L. 111–358, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4003"},"text":"124 Stat. 4003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7897a85c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7897a85d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7897a85e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and as part of the National Institute of Standards and Technology Authorization Act of 2010, and not as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7897a85f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7897a860-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV/s409"},"text":"Pub. L. 111–358, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4004"},"text":"124 Stat. 4004","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/358/tIV/s409"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and sections 273a and 278n–2 of this title, amending sections 274, 278g–1, 278g–2, 278g–2a, and 278k of this title and sections 5314 and 5315 of Title 5, Government Organization and Employees, and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1533"},"text":"section 1533 of this title","children":[],"tail":" and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"section 278k of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Director’ means the Director of the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Federal agency’ has the meaning given such term in section 4 of the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3703"},"text":"15 U.S.C. 3703","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High performance green building","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘high performance green building’ has the meaning given that term by section 401(13) of the Energy Independence and Security Act of 2009 [probably should be “2007”] (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17061/13"},"text":"42 U.S.C. 17061(13)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
