{"tag":"section","attrib":{"id":"id7a8ee41e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8711"},"text":null,"children":[{"tag":"num","attrib":{"value":"8711"},"text":"§ 8711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this chapter applicable to the order shall be applicable to any amendment to the order, except that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8707"},"text":"section 8707 of this title","children":[],"tail":" shall not apply to an amendment."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a8ee41f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1312"},"text":"Pub. L. 115–254, div. E, § 1312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3483"},"text":"132 Stat. 3483","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
