{"tag":"section","attrib":{"id":"id79baa4b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1693c"},"text":"§ 1693c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of transfers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79baa4b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosures; time; form; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms and conditions of electronic fund transfers involving a consumer’s account shall be disclosed at the time the consumer contracts for an electronic fund transfer service, in accordance with regulations of the Bureau. Such disclosures shall be in readily understandable language and shall include, to the extent applicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79baa4ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer’s liability for unauthorized electronic fund transfers and, at the financial institution’s option, notice of the advisability of prompt reporting of any loss, theft, or unauthorized use of a card, code, or other means of access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the telephone number and address of the person or office to be notified in the event the consumer believes than ","children":[{"tag":"ref","attrib":{"idref":"fn002404"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002404"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “that”."}],"tail":" an unauthorized electronic fund transfer has been or may be effected;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type and nature of electronic fund transfers which the consumer may initiate, including any limitations on the frequency or dollar amount of such transfers, except that the details of such limitations need not be disclosed if their confidentiality is necessary to maintain the security of an electronic fund transfer system, as determined by the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any charges for electronic fund transfers or for the right to make such transfers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer’s right to stop payment of a preauthorized electronic fund transfer and the procedure to initiate such a stop payment order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer’s right to receive documentation of electronic fund transfers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693d"},"text":"section 1693d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary, in a form prescribed by regulations of the Bureau, of the error resolution provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693f"},"text":"section 1693f of this title","children":[],"tail":" and the consumer’s rights thereunder. The financial institution shall thereafter transmit such summary at least once per calendar year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial institution’s liability to the consumer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693h"},"text":"section 1693h of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under what circumstances the financial institution will in the ordinary course of business disclose information concerning the consumer’s account to third persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a notice to the consumer that a fee may be imposed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79baa4c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an automated teller machine operator (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693b/d/3/D/i"},"text":"section 1693b(d)(3)(D)(i) of this title","children":[],"tail":") if the consumer initiates a transfer from an automated teller machine that is not operated by the person issuing the card or other means of access; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79baa4c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any national, regional, or local network utilized to effect the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79baa4c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of changes to consumer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A financial institution shall notify a consumer in writing at least twenty-one days prior to the effective date of any change in any term or condition of the consumer’s account required to be disclosed under subsection (a) if such change would result in greater cost or liability for such consumer or decreased access to the consumer’s account. A financial institution may, however, implement a change in the terms or conditions of an account without prior notice when such change is immediately necessary to maintain or restore the security of an electronic fund transfer system or a consumer’s account. Subject to subsection (a)(3), the Bureau shall require subsequent notification if such a change is made permanent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79baa4c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for disclosures respecting accounts accessible prior to effective date of this subchapter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any account of a consumer made accessible to electronic fund transfers prior to the effective date of this subchapter, the information required to be disclosed to the consumer under subsection (a) shall be disclosed not later than the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79baa4c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first periodic statement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693d/c"},"text":"section 1693d(c) of this title","children":[],"tail":" after the effective date of this subchapter; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79baa4c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" thirty days after the effective date of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79baa4ca-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIX/s905"},"text":"Pub. L. 90–321, title IX, § 905","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXX/s2001"},"text":"Pub. L. 95–630, title XX, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3730"},"text":"92 Stat. 3730","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s703"},"text":"Pub. L. 106–102, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1464"},"text":"113 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1084/1"},"text":"Pub. L. 111–203, title X, § 1084(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2081"},"text":"124 Stat. 2081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79baa4cb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79baa4cc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79baa4cd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this subchapter, referred to in subsec. (c), see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/s921"},"text":"section 921 of Pub. L. 90–321","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"section 1693 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79baa4ce-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" added par. (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79baa4cf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79baa4d0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
