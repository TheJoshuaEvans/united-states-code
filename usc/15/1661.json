{"tag":"section","attrib":{"id":"id799df496-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1661"},"text":null,"children":[{"tag":"num","attrib":{"value":"1661"},"text":"§ 1661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catalogs and multiple-page advertisements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this part, a catalog or other multiple-page advertisement shall be considered a single advertisement if it clearly and conspicuously displays a credit terms table on which the information required to be stated under this part is clearly set forth.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799df497-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s141"},"text":"Pub. L. 90–321, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/158"},"text":"82 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df498-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df499-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799df49a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tV/s504/b"},"text":"Pub. L. 90–321, title V, § 504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/167"},"text":"82 Stat. 167","children":[],"tail":", provided that chapter 3 of title I, which enacted sections 1661 to 1665 of this title, is effective "},{"tag":"date","attrib":{"date":"1969-07-01"},"text":"July 1, 1969","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
