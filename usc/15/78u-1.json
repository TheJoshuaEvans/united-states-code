sc/t5/s13101"},"text":"section 13101 of Title 5","children":[],"tail":", Government Organization and Employees.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105/s9/b/2/A"},"text":"Pub. L. 112–105, § 9(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-04-04"},"text":"Apr. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/297"},"text":"126 Stat. 297","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/105/s9/b/2/A"},"text":"“The purpose of the amendment made by this paragraph [amending this section] is to affirm a duty arising from a relationship of trust and confidence owed by each executive branch employee, judicial officer, and judicial employee.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “executive branch employee”, “judicial officer”, and “judicial employee”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105/s2"},"text":"section 2 of Pub. L. 112–105","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s13101"},"text":"section 13101 of Title 5","children":[],"tail":", Government Organization and Employees.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7841e740-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/704/s2"},"text":"Pub. L. 100–704, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4677"},"text":"102 Stat. 4677","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/704/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rules and regulations of the Securities and Exchange Commission under the Securities Exchange Act of 1934 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.] governing trading while in possession of material, nonpublic information are, as required by such Act, necessary and appropriate in the public interest and for the protection of investors;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission has, within the limits of accepted administrative and judicial construction of such rules and regulations, enforced such rules and regulations vigorously, effectively, and fairly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonetheless, additional methods are appropriate to deter and prosecute violations of such rules and regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7841e741-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Commission Recommendations for Additional Civil Penalty Authority Required","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/704/s3/c"},"text":"Pub. L. 100–704, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4680"},"text":"102 Stat. 4680","children":[],"tail":", provided that the Securities and Exchange Commission should, within 60 days after "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", submit to Congress any recommendations the Commission considers appropriate with respect to the extension of the Commission’s authority to seek civil penalties or impose administrative fines for violations other than those described in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
