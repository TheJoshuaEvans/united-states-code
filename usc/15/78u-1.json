/2/B"},"text":"Pub. L. 112–105, § 9(b)(2)(B)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/105/s12"},"text":"Pub. L. 112–105, § 12","children":[],"tail":", added subsec (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s762/d/7/A"},"text":"Pub. L. 111–203, § 762(d)(7)(A)","children":[],"tail":", struck out “(as defined in section 206B of the Gramm-Leach-Bliley Act)” after “security-based swap agreement” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s923/b/2/A"},"text":"Pub. L. 111–203, § 923(b)(2)(A)","children":[],"tail":", struck out “(subject to subsection (e) of this section)” after “shall” and inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78u–6"},"text":"section 78u–6 of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7246"},"text":"section 7246 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s923/b/2/B"},"text":"Pub. L. 111–203, § 923(b)(2)(B)","children":[],"tail":", (C), redesignated subsec. (f) as (e) and struck out former subsec. (e). Prior to amendment, text of subsec. (e) read as follows: “Notwithstanding the provisions of subsection (d)(1) of this section, there shall be paid from amounts imposed as a penalty under this section and recovered by the Commission or the Attorney General, such sums, not to exceed 10 percent of such amounts, as the Commission deems appropriate, to the person or persons who provide information leading to the imposition of such penalty. Any determinations under this subsection, including whether, to whom, or in what amount to make payments, shall be in the sole discretion of the Commission, except that no such payment shall be made to any member, officer, or employee of any appropriate regulatory agency, the Department of Justice, or a self-regulatory organization. Any such determination shall be final and not subject to judicial review.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s923/b/2/C"},"text":"Pub. L. 111–203, § 923(b)(2)(C)","children":[],"tail":", redesignated subsec. (g) as (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s762/d/7/B"},"text":"Pub. L. 111–203, § 762(d)(7)(B)","children":[],"tail":", which directed amendment of subsec. (g) by striking out “(as defined in section 206B of the Gramm-Leach-Bliley Act)”, was executed by making the strike out after “security-based swap agreements” in subsec. (f), to reflect the probable intent of Congress and the redesignation of subsec. (g) as (f) by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s923/b/2/C"},"text":"Pub. L. 111–203, § 923(b)(2)(C)","children":[],"tail":". See above and Effective Date of 2010 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s923/b/2/C"},"text":"Pub. L. 111–203, § 923(b)(2)(C)","children":[],"tail":", redesignated subsec. (g) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":" inserted “, except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7246"},"text":"section 7246 of this title","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tIII/s303/k"},"text":"Pub. L. 106–554, § 1(a)(5) [title