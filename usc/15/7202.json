{"tag":"section","attrib":{"id":"id7a6d7997-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202"},"text":null,"children":[{"tag":"num","attrib":{"value":"7202"},"text":"§ 7202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission rules and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6d7998-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall promulgate such rules and regulations, as may be necessary or appropriate in the public interest or for the protection of investors, and in furtherance of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6d7999-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6d799a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation by any person of this Act, any rule or regulation of the Commission issued under this Act, or any rule of the Board shall be treated for all purposes in the same manner as a violation of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.) or the rules and regulations issued thereunder, consistent with the provisions of this Act, and any such person shall be subject to the same penalties, and to the same extent, as for a violation of that Act or such rules or regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d799b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (4) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6d799c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on Commission authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act or the rules of the Board shall be construed to impair or limit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6d799d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Commission to regulate the accounting profession, accounting firms, or persons associated with such firms for purposes of enforcement of the securities laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d799e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Commission to set standards for accounting or auditing practices or auditor independence, derived from other provisions of the securities laws or the rules or regulations thereunder, for purposes of the preparation and issuance of any audit report, or otherwise under applicable law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6d799f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7202/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Commission to take, on the initiative of the Commission, legal, administrative, or disciplinary action against any registered public accounting firm or any associated person thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6d79a0-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s3"},"text":"Pub. L. 107–204, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/749"},"text":"116 Stat. 749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6d79a1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6d79a2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a6d79a3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204"},"text":"Pub. L. 107–204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/745"},"text":"116 Stat. 745","children":[],"tail":", known as the Sarbanes-Oxley Act of 2002. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Exchange Act of 1934, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a6d79a4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/s3"},"text":"section 3 of Pub. L. 107–204","children":[],"tail":". Subsec. (b)(2)–(4) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/204/s3"},"text":"section 3 of Pub. L. 107–204","children":[],"tail":" amended sections 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 78u, and 78u–3 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
