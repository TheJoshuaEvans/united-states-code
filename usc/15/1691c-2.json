{"tag":"section","attrib":{"id":"id79b5e90c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1691c–2"},"text":"§ 1691c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business loan data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79b5e90d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to facilitate enforcement of fair lending laws and enable communities, governmental entities, and creditors to identify business and community development needs and opportunities of women-owned, minority-owned, and small businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e90e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information gathering","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the requirements of this section, in the case of any application to a financial institution for credit for women-owned, minority-owned, or small business, the financial institution shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e90f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inquire whether the business is a women-owned, minority-owned, or small business, without regard to whether such application is received in person, by mail, by telephone, by electronic mail or other form of electronic transmission, or by any other means, and whether or not such application is in response to a solicitation by the financial institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e910-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a record of the responses to such inquiry, separate from the application and accompanying information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e911-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to refuse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any applicant for credit may refuse to provide any information requested pursuant to subsection (b) in connection with any application for credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e912-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No access by underwriters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e913-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where feasible, no loan underwriter or other officer or employee of a financial institution, or any affiliate of a financial institution, involved in making any determination concerning an application for credit shall have access to any information provided by the applicant pursuant to a request under subsection (b) in connection with such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e914-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a financial institution determines that a loan underwriter or other officer or employee of a financial institution, or any affiliate of a financial institution, involved in making any determination concerning an application for credit should have access to any information provided by the applicant pursuant to a request under subsection (b), the financial institution shall provide notice to the applicant of the access of the underwriter to such information, along with notice that the financial institution may not discriminate on the basis of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e915-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and manner of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e916-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each financial institution shall compile and maintain, in accordance with regulations of the Bureau, a record of the information provided by any loan applicant pursuant to a request under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e917-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Itemization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information compiled and maintained under paragraph (1) shall be itemized in order to clearly and conspicuously disclose—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e918-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of the application and the date on which the application was received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e919-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type and purpose of the loan or other credit being applied for;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e91a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the credit or credit limit applied for, and the amount of the credit transaction or the credit limit approved for such applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e91b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of action taken with respect to such application, and the date of such action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e91c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the census tract in which is located the principal place of business of the women-owned, minority-owned, or small business loan applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e91d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross annual revenue of the business in the last fiscal year of the women-owned, minority-owned, or small business loan applicant preceding the date of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e91e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the race, sex, and ethnicity of the principal owners of the business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e91f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional data that the Bureau determines would aid in fulfilling the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e920-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No personally identifiable information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In compiling and maintaining any record of information under this section, a financial institution may not include in such record the name, specific address (other than the census tract required under paragraph (1)(E)),","children":[{"tag":"ref","attrib":{"idref":"fn002395"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002395"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(2)(E)),”."}],"tail":" telephone number, electronic mail address, or any other personally identifiable information concerning any individual who is, or is connected with, the women-owned, minority-owned, or small business loan applicant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e921-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion to delete or modify publicly available data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau may, at its discretion, delete or modify data collected under this section which is or will be available to the public, if the Bureau determines that the deletion or modification of the data would advance a privacy interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e922-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e923-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data required to be compiled and maintained under this section by any financial institution shall be submitted annually to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e924-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information compiled and maintained under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e925-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retained for not less than 3 years after the date of preparation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e926-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to any member of the public, upon request, in the form required under regulations prescribed by the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e927-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually made available to the public generally by the Bureau, in such form and in such manner as is determined by the Bureau, by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e928-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation of aggregate data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau may, at its discretion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e929-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile and aggregate data collected under this section for its own use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e92a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make public such compilations of aggregate data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e92b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e92c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall prescribe such rules and issue such guidance as may be necessary to carry out, enforce, and compile data pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e92d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau, by rule or order, may adopt exceptions to any requirement of this section and may, conditionally or unconditionally, exempt any financial institution or class of financial institutions from the requirements of this section, as the Bureau deems necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e92e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall issue guidance designed to facilitate compliance with the requirements of this section, including assisting financial institutions in working with applicants to determine whether the applicants are women-owned, minority-owned, or small businesses for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79b5e92f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b5e930-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” means any partnership, company, corporation, association (incorporated or unincorporated), trust, estate, cooperative organization, or other entity that engages in any financial activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e931-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small business” has the same meaning as the term “small business concern” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e932-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small business loan” means a loan made to a small business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e933-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minority” has the same meaning as in section 1204(c)(3) of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e934-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority-owned business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “minority-owned business” means a business—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e935-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 percent of the ownership or control of which is held by 1 or more minority individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e936-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 percent of the net profit or loss of which accrues to 1 or more minority individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b5e937-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Women-owned business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “women-owned business” means a business—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79b5e938-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 percent of the ownership or control of which is held by 1 or more women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79b5e939-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1691c–2/h/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 percent of the net profit or loss of which accrues to 1 or more women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b5e93a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVII/s704B"},"text":"Pub. L. 90–321, title VII, § 704B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1071/a"},"text":"Pub. L. 111–203, title X, § 1071(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2056"},"text":"124 Stat. 2056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"us