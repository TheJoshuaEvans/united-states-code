{"tag":"section","attrib":{"id":"id792b8418-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690i"},"text":null,"children":[{"tag":"num","attrib":{"value":"690i"},"text":"§ 690i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792b8419-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), any national bank, any member bank of the Federal Reserve System, and (to the extent permitted under applicable State law) any insured bank that is not a member of such system, may invest in any Renewable Fuel Capital Investment company, or in any entity established to invest solely in Renewable Fuel Capital Investment companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b841a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No bank described in subsection (a) may make investments described in such subsection that are greater than 5 percent of the capital and surplus of the bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792b841b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s390"},"text":"Pub. L. 85–699, title III, § 390","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1782"},"text":"121 Stat. 1782","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
