{"tag":"section","attrib":{"id":"id77d4315a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b"},"text":null,"children":[{"tag":"num","attrib":{"value":"69b"},"text":"§ 69b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misbranded fur products","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, a fur product shall be considered to be misbranded—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77d4315b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if it is falsely or deceptively labeled or otherwise falsely or deceptively identified, or if the label contains any form of misrepresentation or deception, directly or by implication, with respect to such fur product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d4315c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if there is not affixed to the fur product a label showing in words and figures plainly legible—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77d4315d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name or names (as set forth in the Fur Products Name Guide) of the animal or animals that produced the fur, and such qualifying statement as may be required pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s69e/c"},"text":"section 69e(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77d4315e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the fur product contains or is composed of used fur, when such is the fact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77d4315f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the fur product contains or is composed of bleached, dyed, or otherwise artificially colored fur, when such is the fact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77d43160-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the fur product is composed in whole or in substantial part of paws, tails, bellies, or waste fur, when such is the fact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77d43161-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, or other identification issued and registered by the Commission, of one or more of the persons who manufacture such fur product for introduction into commerce, introduce it into commerce, sell it in commerce, advertise or offer it for sale in commerce, or transport or distribute it in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77d43162-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the country of origin of any imported furs used in the fur product;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77d43163-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s69b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the label required by paragraph (2)(A) of this section sets forth the name or names of any animal or animals other than the name or names provided for in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d43164-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-08-08/ch298/s4"},"text":"Aug. 8, 1951, ch. 298, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/177"},"text":"65 Stat. 177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d43165-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77d43166-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77d43167-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Federal Trade Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 8 of 1950, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1264"},"text":"64 Stat. 1264","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
