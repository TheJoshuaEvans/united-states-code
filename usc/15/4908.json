{"tag":"section","attrib":{"id":"id7a49c4ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908"},"text":null,"children":[{"tag":"num","attrib":{"value":"4908"},"text":"§ 4908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on service sector","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a49c4cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service sector information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that, to the extent possible, there is included in the Data Bank information on service sector economic activity that is as complete and timely as information on economic activity in the merchandise sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c4cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall undertake a new benchmark survey of service transactions, including transactions with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c4cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" banking services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information services, including computer software services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brokerage services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engineering services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c4d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General information and index of leading indicators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c4d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than once a year, comprehensive information on the service sector of the economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an index of leading indicators which includes the measurement of service sector activity in direct proportion to the contribution of the service sector to the gross national product of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c4d8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5408"},"text":"Pub. L. 100–418, title V, § 5408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1466"},"text":"102 Stat. 1466","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
