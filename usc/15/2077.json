{"tag":"section","attrib":{"id":"id79d99df5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077"},"text":null,"children":[{"tag":"num","attrib":{"value":"2077"},"text":"§ 2077.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chronic Hazard Advisory Panels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d99df6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall appoint Chronic Hazard Advisory Panels (hereinafter referred to as the Panel or Panels) to advise the Commission in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2080/b"},"text":"section 2080(b) of this title","children":[],"tail":" respecting the chronic hazards of cancer, birth defects, and gene mutations associated with consumer products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99df7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition; membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Panel shall consist of 7 members appointed by the Commission from a list of nominees who shall be nominated by the President of the National Academy of Sciences from scientists—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d99df8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are not officers or employees of the United States (other than employees of the National Institutes of Health, the National Toxicology Program, or the National Center for Toxicological Research), and who do not receive compensation from or have any substantial financial interest in any manufacturer, distributor, or retailer of a consumer product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d99df9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have demonstrated the ability to critically assess chronic hazards and risks to human health presented by the exposure of humans to toxic substances or as demonstrated by the exposure of animals to such substances.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The President of the National Academy of Sciences shall nominate for each Panel a number of individuals equal to three times the number of members to be appointed to the Panel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99dfa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman and Vice Chairman; election; term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman and Vice Chairman of the Panel shall be elected from among the members and shall serve for the duration of the Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99dfb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions of the Panel shall be made by a majority of the Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99dfc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall provide each Panel with such administrative support services as it may require to carry out its duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2080"},"text":"section 2080 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99dfd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of a Panel appointed under subsection (a) shall be paid at a rate not to exceed the daily equivalent of the annual rate of basic pay in effect for grade GS–18 of the General Schedule for each day (including traveltime) during which the member is engaged in the actual performance of the duties of the Panel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99dfe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for and disclosures of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Panel shall request information and disclose information to the public, as provided in subsection (h), only through the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99dff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from other Federal departments and agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d99e00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any statutory restriction on the authority of agencies and departments of the Federal Government to share information, such agencies and departments shall provide the Panel with such information and data as each Panel, through the Commission, may request to carry out its duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2080"},"text":"section 2080 of this title","children":[],"tail":". Each Panel may request information, through the Commission, from States, industry and other private sources as it may require to carry out its responsibilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d99e01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2077/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2055"},"text":"Section 2055 of this title","children":[],"tail":" shall apply to the disclosure of information by the Panel but shall not apply to the disclosure of information to the Panel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d99e02-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s28"},"text":"Pub. L. 92–573, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXII/s1206/a"},"text":"Pub. L. 97–35, title XII, § 1206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/716"},"text":"95 Stat. 716","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/608/tI/s116"},"text":"Pub. L. 101–608, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3121"},"text":"104 Stat. 3121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s235/c/6"},"text":"Pub. L. 110–314, title II, § 235(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3075"},"text":"122 Stat. 3075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d99e03-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d99e04-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79d99e05-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2077, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s28"},"text":"Pub. L. 92–573, § 28","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1230"},"text":"86 Stat. 1230","children":[],"tail":", provided for establishment and membership of Product Safety Advisory Council, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXII/s1205/a/1"},"text":"Pub. L. 97–35, title XII, § 1205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/716"},"text":"95 Stat. 716","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d99e06-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":", which directed amendment of this section by substituting “the appropriate Congressional committees” for “the Congress” in subsecs. (j)(10)(F) and (k)(1), (2), could not be executed because this section does not contain a subsec. (j) or (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/608"},"text":"Pub. L. 101–608","children":[],"tail":" inserted “(other than employees of the National Institutes of Health, the National Toxicology Program, or the National Center for Toxicological Research)” after “States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d99e07-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79d99e08-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to regulations under this chapter and chapters 25 and 30 of this title for which notices of proposed rulemaking are issued after ","children":[{"tag":"date","attrib":{"date":"1981-08-14"},"text":"Aug. 14, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1215"},"text":"section 1215 of Pub. L. 97–35","children":[],"tail":", set out as an Effective Date of 1981 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052"},"text":"section 2052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79d99e09-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
