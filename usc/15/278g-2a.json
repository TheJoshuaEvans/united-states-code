{"tag":"section","attrib":{"id":"id7890a316-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a"},"text":null,"children":[{"tag":"num","attrib":{"value":"278g–2a"},"text":"§ 278g–2a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Teacher science and technology enhancement Institute program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7890a317-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish within the Institute a teacher science and technology enhancement program to provide for professional development of mathematics and science teachers of elementary, middle, and secondary schools (as those terms are defined by the Director), including providing for the improvement of those teachers with respect to the understanding of science and the impacts of science on commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a318-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Areas of focus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under this section, the Director shall focus on the areas of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7890a319-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific measurements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a31a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tests and standards development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a31b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industrial competitiveness and quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a31c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a31d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a31e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other area of expertise of the Institute that the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a31f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures and selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall develop and issue procedures and selection criteria for participants in the program. The Director shall give special consideration to an application from a teacher from a high-need school, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1021"},"text":"section 1021 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a320-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scheduling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program under this section shall be conducted on an annual basis during the summer months, during the period of time when a majority of elementary, middle, and secondary schools have not commenced a school year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a321-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–2a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means of accomplishing goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall provide for teachers’ participation in activities at the laboratory facilities of the Institute, or shall utilize other means of accomplishing the goals of the program as determined by the Director, which may include the Internet, video conferencing and recording, and workshops and conferences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7890a322-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s19A"},"text":"Mar. 3, 1901, ch. 872, § 19A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/309/s7"},"text":"Pub. L. 105–309, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2937"},"text":"112 Stat. 2937","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV/s406/c"},"text":"Pub. L. 111–358, title IV, § 406(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4004"},"text":"124 Stat. 4004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7890a323-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7890a324-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7890a325-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" inserted at end “The Director shall give special consideration to an application from a teacher from a high-need school, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1021"},"text":"section 1021 of title 20","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
