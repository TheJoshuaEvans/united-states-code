{"tag":"section","attrib":{"id":"id788706b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205f"},"text":null,"children":[{"tag":"num","attrib":{"value":"205f"},"text":"§ 205f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Board","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out its duties under this subchapter, the Board may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id788706b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an Executive Committee, and such other committees as it deems desirable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788706b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such committees and advisory panels as it deems necessary to work with the various sectors of the Nation’s economy and with Federal and State governmental agencies in the development and implementation of detailed conversion plans for those sectors. The Board may reimburse, to the extent authorized by law, the members of such committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788976b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct hearings at such times and places as it deems appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788976ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, in accordance with chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41, with Federal or State agencies, private firms, institutions, and individuals for the conduct of research or surveys, the preparation of reports, and other activities necessary to the discharge of its duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788976bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegate to the Executive Director such authority as it deems advisable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id788976bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other acts as may be necessary to carry out the duties prescribed by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id788976bd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/168/s7"},"text":"Pub. L. 94–168, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1011"},"text":"89 Stat. 1011","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788976be-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788976bf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id788976c0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (4), “chapters 1 to 11 of title 40 and division C (except sections 3302, 3307(e), 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” substituted for “the Federal Property and Administrative Services Act of 1949, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s471"},"text":"40 U.S.C. 471","children":[],"tail":" et seq.)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", which Act enacted Title 40, Public Buildings, Property, and Works, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
