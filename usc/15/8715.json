{"tag":"section","attrib":{"id":"id7a8ee426-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715"},"text":null,"children":[{"tag":"num","attrib":{"value":"8715"},"text":"§ 8715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on obligation of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8ee427-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In each fiscal year of the covered period, the Board may not obligate an amount greater than the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee428-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 73 percent of the amount of assessments estimated to be collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8705"},"text":"section 8705 of this title","children":[],"tail":" in such fiscal year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee429-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 73 percent of the amount of assessments actually collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8705"},"text":"section 8705 of this title","children":[],"tail":" in the most recent fiscal year for which an audit report has been submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8704/f/2/B"},"text":"section 8704(f)(2)(B) of this title","children":[],"tail":" as of the beginning of the fiscal year for which the amount that may be obligated is being determined, less the estimate made pursuant to paragraph (1) for such most recent fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee42a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts permitted in preceding fiscal years to be obligated pursuant to this subsection that have not been obligated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee42b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess amounts deposited in escrow account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8705"},"text":"section 8705 of this title","children":[],"tail":" in excess of the amount permitted to be obligated under subsection (a) in a fiscal year shall be deposited in an escrow account for the duration of the covered period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee42c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amounts in escrow account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the covered period, the Board may not obligate, expend, or borrow against amounts required under subsection (b) to be deposited in the escrow account. Any interest earned on such amounts shall be deposited in the escrow account and shall be unavailable for obligation for the duration of the covered period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee42d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of amounts in escrow account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the covered period, the Board may withdraw and obligate in any fiscal year an amount in the escrow account that does not exceed ⅕ of the amount in the escrow account on the last day of the covered period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee42e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for estimates for particular fiscal years","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee42f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(1), the amount of assessments estimated to be collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8705"},"text":"section 8705 of this title","children":[],"tail":" in a fiscal year specified in paragraph (2) shall be equal to 62 percent of the amount of assessments actually collected under such section in the most recent fiscal year for which an audit report has been submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8704/f/2/B"},"text":"section 8704(f)(2)(B) of this title","children":[],"tail":" as of the beginning of the fiscal year for which the amount that may be obligated is being determined."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee430-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years specified","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fiscal years specified in this paragraph are the 9th and 10th fiscal years that begin on or after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee431-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8715/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered period defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered period” means the period that begins on ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", and ends on the last day of the 11th fiscal year that begins on or after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee432-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1316"},"text":"Pub. L. 115–254, div. E, § 1316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3483"},"text":"132 Stat. 3483","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
