{"tag":"section","attrib":{"id":"id79672d85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1178"},"text":null,"children":[{"tag":"num","attrib":{"value":"1178"},"text":"§ 1178.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of chapter to certain machines and devices","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"None of the provisions of this chapter shall be construed to apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79672d86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1178/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any machine or mechanical device designed and manufactured primarily for use at a racetrack in connection with parimutuel betting,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79672d87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1178/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any machine or mechanical device, such as a coin-operated bowling alley, shuffleboard, marble machine (a so-called pinball machine), or mechanical gun, which is not designed and manufactured primarily for use in connection with gambling, and (A) which when operated does not deliver, as a result of the application of an element of chance, any money or property, or (B) by the operation of which a person may not become entitled to receive, as the result of the application of an element of chance, any money or property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79672d88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1178/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any so-called claw, crane, or digger machine and similar devices which are not operated by coin, are actuated by a crank, and are designed and manufactured primarily for use at carnivals or county or State fairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79672d89-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-01-02/ch1194/s9"},"text":"Jan. 2, 1951, ch. 1194, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/840/s6"},"text":"Pub. L. 87–840, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-18"},"text":"Oct. 18, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1077"},"text":"76 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79672d8a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79672d8b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79672d8c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1962-10-18"},"text":"Oct. 18, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/840/s7"},"text":"section 7 of Pub. L. 87–840","children":[],"tail":", set out as an Effective Date of 1962 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1171"},"text":"section 1171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
