{"tag":"section","attrib":{"id":"id78766458-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–57"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–57"},"text":"§ 80a–57.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in investment policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No business development company shall, unless authorized by the vote of a majority of its outstanding voting securities or partnership interests, change the nature of its business so as to cease to be, or to withdraw its election as, a business development company.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78766459-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 58, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/477/tI/s105"},"text":"Pub. L. 96–477, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2285"},"text":"94 Stat. 2285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
