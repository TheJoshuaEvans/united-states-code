{"tag":"section","attrib":{"id":"id79672d1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1157"},"text":null,"children":[{"tag":"num","attrib":{"value":"1157"},"text":"§ 1157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to repeal or amend any other legislation pertaining to the Department of Commerce or its component offices or bureaus.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79672d1c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-09/ch936/s7"},"text":"Sept. 9, 1950, ch. 936, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/824"},"text":"64 Stat. 824","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
