{"tag":"section","attrib":{"id":"id78063d86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"78d–7"},"text":"§ 78d–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Triennial report on personnel management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78063d87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Triennial report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once every 3 years, the Comptroller General of the United States shall submit a report to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives on the quality of personnel management by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063d89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063d8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of supervisors in using the skills, talents, and motivation of the employees of the Commission to achieve the goals of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria for promoting employees of the Commission to supervisory positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fairness of the application of the promotion criteria to the decisions of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the competence of the professional staff of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficiency of communication between the units of the Commission regarding the work of the Commission (including communication between divisions and between subunits of a division) and the efforts by the Commission to promote such communication;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the turnover within subunits of the Commission, including the consideration of supervisors whose subordinates have an unusually high rate of turnover;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there are excessive numbers of low-level, mid-level, or senior-level managers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any initiatives of the Commission that increase the competence of the staff of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by the Commission regarding employees of the Commission who have failed to perform their duties and circumstances under which the Commission has issued to employees a notice of termination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors relating to the management of the Commission as the Comptroller General determines are appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of any improvements made with respect to the areas described in paragraph (1) since the date of submission of the previous report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for how the Commission can use the human resources of the Commission more effectively and efficiently to carry out the mission of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing the report under subsection (a), the Comptroller General shall consult with current employees of the Commission, retired employees and other former employees of the Commission, the Inspector General of the Commission, persons that have business before the Commission, any union representing the employees of the Commission, private management consultants, academics, and any other source that the Comptroller General deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date on which the Comptroller General submits each report under subsection (a), the Commission shall submit to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives a report describing the actions taken by the Commission in response to the recommendations contained in the report under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements for cost of reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063d99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursements required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall reimburse the Government Accountability Office for the full cost of making the reports under this section, as billed therefor by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting and use of reimbursements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such reimbursements shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063d9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the appropriation account “Salaries and Expenses, Government Accountability Office” current when the payment is received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–7/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to hire experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States may hire independent consultants with specialized expertise in any area relevant to the duties of the Comptroller General described in this section, in order to assist the Comptroller General in carrying out such duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78063d9e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s962"},"text":"Pub. L. 111–203, title IX, § 962","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1908"},"text":"124 Stat. 1908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78063d9f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78063da0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78063da1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Investor Protection and Securities Reform Act of 2010 and also as part of the Dodd-Frank Wall Street Reform and Consumer Protection Act, and not as part of the Securities Exchange Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78063da2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78063da3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id78063da4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Commission” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
