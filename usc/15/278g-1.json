{"tag":"section","attrib":{"id":"id7890a2e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"278g–1"},"text":"§ 278g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and outreach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7890a2e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to expend funds appropriated for activities of the Institute in any fiscal year, to support, promote, and coordinate activities and efforts to enhance public awareness and understanding of measurement sciences, standards and technology at the national measurement laboratories and otherwise in fulfillment of the mission of the Institute. The Director shall carry out activities under this subsection, including education and outreach activities to the general public, industry and diverse types of institutions of higher education, including historically Black colleges and universities, Tribal Colleges and Universities, and minority-serving institutions, and community colleges in support of the Institute’s mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a2e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, in coordination with the Director of the Office of Personnel Management, may revise the procedures the Director applies when making appointments to laboratory positions within the competitive service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7890a2e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure corporate memory of and expertise in the fundamental ongoing work, and on developing new capabilities in priority areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain high overall technical competence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve staff diversity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to balance emphases on the noncore and core areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the ability of the Institute to compete in the marketplace for qualified personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a2ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7890a2ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may establish a program to use volunteers in carrying out the programs of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may accept, subject to regulations issued by the Office of Personnel Management, voluntary service for the Institute for such purpose if the service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7890a2f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is to be without compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7890a2f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be used to displace any current employee or act as a substitute for any future full-time employee of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employee status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who provides voluntary service under this subsection shall not be considered a Federal employee, except for purposes of chapter 81 of title 5 (relating to compensation for injury), and sections 2671 through 2680 of title 28 (relating to tort claims).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a2f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research fellowships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7890a2f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may expend funds appropriated for activities of the Institute in any fiscal year, as the Director considers appropriate, for awards of research fellowships and other forms of financial and logistical assistance, including direct stipend awards to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7890a2f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students at institutions of higher learning within the United States who show promise as present or future contributors to the mission of the Institute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7890a2f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States citizens for research and technical activities of the Institute, including programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The selection of persons to receive such fellowships and assistance shall be made on the basis of ability and of the relevance of the proposed work to the mission and programs of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial and logistical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1345"},"text":"section 1345 of title 31","children":[],"tail":" or any other law to the contrary, the Director may include as a form of financial or logistical assistance under this subsection temporary housing and transportation to and from Institute facilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7890a2f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational outreach activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7890a2fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate education programs for undergraduate and graduate students, postdoctoral researchers, and academic and industry employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor summer workshops for STEM kindergarten through grade 12 teachers as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop programs for graduate student internships and visiting faculty researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" document publications, presentations, and interactions with visiting researchers and sponsoring interns as performance metrics for improving and continuing interactions with those individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate laboratory tours and provide presentations for educational, industry, and community groups; and ","children":[{"tag":"ref","attrib":{"idref":"fn002147"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002147"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a2ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to and develop research collaborations with historically Black colleges and universities, Tribal Colleges or Universities, and minority serving institutions, including through the recruitment of students and faculty at such institutions to participate in programs developed under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a300-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to and develop research collaborations with community colleges, including through the recruitment of students and faculty at such institutions to participate in programs developed under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a301-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other activities to increase the participation of persons historically underrepresented in STEM in the Institute’s programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7890a302-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–1/e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to and develop collaborations with nontraditional educational organizations, including those that offer training through nonprofit associations and professional associations or professional societies, to engage persons historically underrepresented in STEM through programs developed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7890a303-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s18"},"text":"Mar. 3, 1901, ch. 872, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s306/b"},"text":"Pub. L. 114–329, title III, § 306(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3008"},"text":"130 Stat. 3008","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10241"},"text":"Pub. L. 117–167, div. B, title II, § 10241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1486"},"text":"136 Stat. 1486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7890a304-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7890a305-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7890a306-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 278g–1, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s18"},"text":"act Mar. 3, 1901, ch. 872, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/574/s6/a"},"text":"Pub. L. 99–574, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-28"},"text":"Oct. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3237"},"text":"100 Stat. 3237","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/a/1"},"text":"Pub. L. 100–418, title V, § 5115(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/245/tI/s104/h/1"},"text":"Pub. L. 102–245, title I, § 104(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-14"},"text":"Feb. 14, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/11"},"text":"106 Stat. 11","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tIII"},"text":"Pub. L. 110–69, title III","children":[],"tail":", §§ 3008, 3013(a), "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/591"},"text":"121 Stat. 591","children":[],"tail":", 598; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV"},"text":"Pub. L. 111–358, title IV","children":[],"tail":", §§ 406(a), § 407(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4003"},"text":"124 Stat. 4003","children":[],"tail":", 4004, related to research fellowships and other financial assistance to students at institutes of higher education, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s306/a"},"text":"Pub. L. 114–329, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3008"},"text":"130 Stat. 3008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 18 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872"},"text":"act Mar. 3, 1901, ch. 872","children":[],"tail":", was renumbered section 32 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278q"},"text":"section 278q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7890a307-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10241/1"},"text":"Pub. L. 117–167, § 10241(1)","children":[],"tail":", substituted “shall” for “may” and “diverse types of institutions of higher education, including historically Black colleges and universities, Tribal Colleges and Universities, and minority-serving institutions, and community colleges” for “academia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(6) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10241/2"},"text":"Pub. L. 117–167, § 10241(2)","children":[],"tail":", added pars. (6) to (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7890a308-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id7890a309-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause for Research Fellowships and Other Financial Assistance to Students at Institutes of Higher Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s306/d/1"},"text":"Pub. L. 114–329, title III, § 306(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3010"},"text":"130 Stat. 3010","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/329/tIII/s306/d/1"},"text":"“The repeal made by subsection (a) of this section [repealing this section] shall not affect any award of a research fellowship or other form of financial assistance made under section 18 of the National Institute of Standards and Technology Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–1"},"text":"15 U.S.C. 278g–1","children":[],"tail":") before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":"]. Such award shall continue to be subject to the requirements to which such funds were subject under that section before the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
