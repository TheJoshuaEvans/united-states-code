{"tag":"section","attrib":{"id":"id79ffc314-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2621"},"text":null,"children":[{"tag":"num","attrib":{"value":"2621"},"text":"§ 2621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National defense waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall waive compliance with any provision of this chapter upon a request and determination by the President that the requested waiver is necessary in the interest of national defense. The Administrator shall maintain a written record of the basis upon which such waiver was granted and make such record available for in camera examination when relevant in a judicial proceeding under this chapter. Upon the issuance of such a waiver, the Administrator shall publish in the Federal Register a notice that the waiver was granted for national defense purposes, unless, upon the request of the President, the Administrator determines to omit such publication because the publication itself would be contrary to the interests of national defense, in which event the Administrator shall submit notice thereof to the Armed Services Committees of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79ffc315-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tI/s22"},"text":"Pub. L. 94–469, title I, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2044"},"text":"90 Stat. 2044","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s3/c/1"},"text":"Pub. L. 99–519, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2989"},"text":"100 Stat. 2989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79ffc316-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79ffc317-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79ffc318-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"Jan. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/469/s31"},"text":"section 31 of Pub. L. 94–469","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
