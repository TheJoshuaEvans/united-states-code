{"tag":"section","attrib":{"id":"id77e4d30b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77l"},"text":null,"children":[{"tag":"num","attrib":{"value":"77l"},"text":"§ 77l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liabilities arising in connection with prospectuses and communications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e4d30c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e4d30d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers or sells a security in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77e"},"text":"section 77e of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e4d30e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers or sells a security (whether or not exempted by the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c"},"text":"section 77c of this title","children":[],"tail":", other than paragraphs (2) and (14) of subsection (a) of said section), by the use of any means or instruments of transportation or communication in interstate commerce or of the mails, by means of a prospectus or oral communication, which includes an untrue statement of a material fact or omits to state a material fact necessary in order to make the statements, in the light of the circumstances under which they were made, not misleading (the purchaser not knowing of such untruth or omission), and who shall not sustain the burden of proof that he did not know, and in the exercise of reasonable care could not have known, of such untruth or omission,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be liable, subject to subsection (b), to the person purchasing such security from him, who may sue either at law or in equity in any court of competent jurisdiction, to recover the consideration paid for such security with interest thereon, less the amount of any income received thereon, upon the tender of such security, or for damages if he no longer owns the security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e4d30f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss causation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an action described in subsection (a)(2), if the person who offered or sold such security proves that any portion or all of the amount recoverable under subsection (a)(2) represents other than the depreciation in value of the subject security resulting from such part of the prospectus or oral communication, with respect to which the liability of that person is asserted, not being true or omitting to state a material fact required to be stated therein or necessary to make the statement not misleading, then such portion or amount, as the case may be, shall not be recoverable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e4d310-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 12, "},{"tag":"ref","attrib":{"href":"/us/stat/48/84"},"text":"48 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-10/ch667"},"text":"Aug. 10, 1954, ch. 667","children":[],"tail":", title I, § 9, "},{"tag":"ref","attrib":{"href":"/us/stat/68/686"},"text":"68 Stat. 686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/67/tI/s105"},"text":"Pub. L. 104–67, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/757"},"text":"109 Stat. 757","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tII/s208/a/3"},"text":"Pub. L. 106–554, § 1(a)(5) [title II, § 208(a)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–435.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e4d311-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e4d312-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e4d313-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “paragraphs (2) and (14)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/67"},"text":"Pub. L. 104–67","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, inserted “, subject to subsection (b),” after “shall be liable” in concluding provisions, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", inserted “offers or” before “sells” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e4d314-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e4d315-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/67/tI/s108"},"text":"Pub. L. 104–67, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/758"},"text":"109 Stat. 758","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/67/tI/s108"},"text":"“The amendments made by this title [enacting sections 77z–1, 77z–2, 78u–4, and 78u–5 of this title and amending this section and sections 77t, 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":", 78t, and 78u of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1964"},"text":"section 1964 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] shall not affect or apply to any private action arising under title I of the Securities Exchange Act of 1934 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.] or title I of the Securities Act of 1933 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.], commenced before and pending on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e4d316-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1954 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", effective 60 days after "},{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", see note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77e4d317-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/67"},"text":"Pub. L. 104–67","children":[],"tail":" to be deemed to create or ratify any implied right of action, or to prevent Commission, by rule or regulation, from restricting or otherwise regulating private actions under Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/67/s203"},"text":"section 203 of Pub. L. 104–67","children":[],"tail":", set out as a Construction note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j–1"},"text":"section 78j–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
