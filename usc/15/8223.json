{"tag":"section","attrib":{"id":"id7a82fd4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223"},"text":null,"children":[{"tag":"num","attrib":{"value":"8223"},"text":"§ 8223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a82fd4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ceding insurer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ceding insurer” means an insurer that purchases reinsurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domiciliary State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “State of domicile” and “domiciliary State” mean, with respect to an insurer or reinsurer, the State in which the insurer or reinsurer is incorporated or entered through, and licensed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NAIC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NAIC” means the National Association of Insurance Commissioners or any successor entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinsurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reinsurance” means the assumption by an insurer of all or part of a risk undertaken originally by another insurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinsurer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a82fd52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “reinsurer” means an insurer to the extent that the insurer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a82fd53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is principally engaged in the business of reinsurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a82fd54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not conduct significant amounts of direct insurance as a percentage of its net premiums; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a82fd55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not engaged in an ongoing basis in the business of soliciting direct insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a82fd56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A determination of whether an insurer is a reinsurer shall be made under the laws of the State of domicile in accordance with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8223/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” includes any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Northern Mariana Islands, the Virgin Islands, and American Samoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a82fd58-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tV/s533"},"text":"Pub. L. 111–203, title V, § 533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1595"},"text":"124 Stat. 1595","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
