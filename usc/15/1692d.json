{"tag":"section","attrib":{"id":"id79b8339d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1692d"},"text":"§ 1692d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harassment or abuse","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A debt collector may not engage in any conduct the natural consequence of which is to harass, oppress, or abuse any person in connection with the collection of a debt. Without limiting the general application of the foregoing, the following conduct is a violation of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79b8339e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use or threat of use of violence or other criminal means to harm the physical person, reputation, or property of any person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b8339f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of obscene or profane language or language the natural consequence of which is to abuse the hearer or reader.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b833a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The publication of a list of consumers who allegedly refuse to pay debts, except to a consumer reporting agency or to persons meeting the requirements of section 1681a(f) or 1681b(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002397"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002397"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b833a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The advertisement for sale of any debt to coerce payment of the debt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b833a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Causing a telephone to ring or engaging any person in telephone conversation repeatedly or continuously with intent to annoy, abuse, or harass any person at the called number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79b833a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692b"},"text":"section 1692b of this title","children":[],"tail":", the placement of telephone calls without meaningful disclosure of the caller’s identity."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79b833a4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVIII/s806"},"text":"Pub. L. 90–321, title VIII, § 806","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/877"},"text":"91 Stat. 877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79b833a5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79b833a6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79b833a7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b/3"},"text":"Section 1681b(3) of this title","children":[],"tail":", referred to in par. (3), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b/a/3"},"text":"section 1681b(a)(3) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2403/a/1"},"text":"Pub. L. 104–208, div. A, title II, § 2403(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-430"},"text":"110 Stat. 3009–430","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79b833a8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79b833a9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag"